@page "/components/empty-state"

<PageTitle>Empty State — Lumeo</PageTitle>

<PageHeader Title="Empty State" Description="A placeholder component for when there is no data to display." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="No results found" Description="Try adjusting your search or filters to find what you're looking for." />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="With Icon and Action" Code="@_actionCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="No projects yet" Description="Get started by creating your first project.">
                <Icon>
                    <DynamicIcon Name="Plus" Class="h-10 w-10" />
                </Icon>
                <Action>
                    <Button>Create Project</Button>
                </Action>
            </EmptyState>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Inbox Empty" Code="@_inboxCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="Inbox zero" Description="You have no new messages. Enjoy the silence.">
                <Icon>
                    <DynamicIcon Name="Mail" Class="h-10 w-10" />
                </Icon>
            </EmptyState>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">EmptyState</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Title</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Main heading text for the empty state.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Description</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Secondary description text.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Icon</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom icon displayed above the title.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Action</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Action buttons area below the description.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<EmptyState
    Title=""No results found""
    Description=""Try adjusting your search or filters."" />";

    private string _actionCode = @"<EmptyState Title=""No projects yet"" Description=""Get started by creating your first project."">
    <Icon>
        <DynamicIcon Name=""Plus"" Class=""h-10 w-10"" />
    </Icon>
    <Action>
        <Button>Create Project</Button>
    </Action>
</EmptyState>";

    private string _inboxCode = @"<EmptyState Title=""Inbox zero"" Description=""You have no new messages."">
    <Icon>
        <DynamicIcon Name=""Mail"" Class=""h-10 w-10"" />
    </Icon>
</EmptyState>";
}
