        // rail should stay put).
        if (Responsive.IsMobile) _navCollapsed = true;
        ClosePalette();
        StateHasChanged();
    }

    private Task ToggleSidebarAsync()
    {
        _navCollapsed = !_navCollapsed;
        return InvokeAsync(StateHasChanged);
    }

    private void OpenBilling()
    {
        _settingsTab = "billing";
        SetView("settings");
