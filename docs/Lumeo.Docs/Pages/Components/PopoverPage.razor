    private string _alignInteractiveCode = @"<Segmented @bind-Value=""_alignSel"" Options=""_alignOptions"" />
<Popover>
    <PopoverTrigger>
        <Button Variant=""Button.ButtonVariant.Outline"">Open (@_alignSel)</Button>
    </PopoverTrigger>
    <PopoverContent Align=""@_activeAlign"">
