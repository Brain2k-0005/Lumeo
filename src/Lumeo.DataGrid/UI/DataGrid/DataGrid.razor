@namespace Lumeo
@typeparam TItem
@attribute [CascadingTypeParameter(nameof(TItem))]
@implements IAsyncDisposable
@inject Lumeo.Services.Localization.ILumeoLocalizer L
@inject Lumeo.Services.ToastService Toast

@{
    // Defensive: keep the roving-focus cell within the current data extents.
    // This is a pure clamp of two ints — it never triggers a re-render — so it's
    // safe to run during render and covers every path that mutates _displayedItems
    // (sort, filter, paging, grouping, external data changes).
    ClampFocusedCell();
    var context = new DataGridContext<TItem>(
        Columns: _visibleColumns,
        // _visibleColumns is itself the filtered cache (Visible == true) — we
        // expose it explicitly under VisibleColumns so descendants don't have
        // to re-filter via Columns.Where(c => c.Visible) every render.
        VisibleColumns: _visibleColumns,
        DisplayedItems: _displayedItems.AsReadOnly(),
        SelectedItems: _selectedItems.AsReadOnly(),
        Sorts: _sorts,
        Filters: _filters,
        GlobalSearch: _globalSearch,
        CurrentPage: _currentPage,
        PageSize: PageSize,
        TotalCount: EffectiveTotalCount,
        SelectionMode: SelectionMode,
        EditMode: EditMode,
        IsLoading: IsLoading || (_serverService?.IsLoading ?? false),
        RowReorderable: RowReorderable,
        RowReorderPointerActive: RowReorderPointerActive,
        RowContextMenuEnabled: RowContextMenu is not null,
        OnRowClick: OnRowClick,
        OnRowDoubleClick: OnRowDoubleClick,
        OnSort: EventCallback.Factory.Create<SortDescriptor>(this, HandleSort),
        OnFilter: EventCallback.Factory.Create<FilterDescriptor>(this, HandleFilter),
        OnSelectionChanged: EventCallback.Factory.Create<TItem>(this, HandleSelectionChanged),
        OnCellEdit: OnCellEdit,
        IsRowSelected: IsRowSelected,
        IsRowExpanded: IsRowExpanded,
        IsRowEditing: IsRowEditing,
        ToggleSelection: ToggleSelection,
        SelectAll: SelectAll,
        ClearSelection: ClearSelection,
        ToggleRowExpand: ToggleRowExpand,
        StartRowEdit: StartRowEdit,
        CancelRowEdit: CancelRowEdit,
        CommitRowEdit: CommitRowEditAsync,
        GetEditValue: GetEditValue,
        SetEditValue: SetEditValue,
        RowClass: RowClass,
        RowStyle: RowStyle,
        PinnedLeftOffsets: ComputePinnedLeftOffsets(),
        PinnedRightOffsets: ComputePinnedRightOffsets(),
        GroupedSections: _groupedSections.Count > 0 ? _groupedSections.AsReadOnly() : null,
        GroupBy: GroupBy,
        IsGrouped: !IsTreeGridMode && EffectiveGroupFields.Count == 1 && _groupedSections.Count > 0,
        IsGroupExpanded: IsGroupExpanded,
        ToggleGroupExpand: ToggleGroupExpand,
        Culture: EffectiveCulture,
        GroupFields: _runtimeGroupFields.AsReadOnly(),
        GroupTree: (!IsTreeGridMode && EffectiveGroupFields.Count > 1 && _groupedTree.Count > 0)
            ? _groupedTree.AsReadOnly() : null,
        IsGroupPathExpanded: IsGroupPathExpanded,
        ToggleGroupPath: ToggleGroupPath,
        AddGroupField: AddGroupField,
        RemoveGroupField: RemoveGroupField,
        ShowGroupPanel: ShowGroupPanel,
        ChildItemsSelector: ChildItemsSelector,
        IsTreeGrid: IsTreeGridMode,
        TreeColumnField: EffectiveTreeColumnField,
        IsTreeNodeExpanded: IsTreeNodeExpanded,
        ToggleTreeNode: it => _ = ToggleTreeNodeAsync(it),
        TreeLevelOf: TreeLevelOf,
        TreeHasChildren: TreeHasChildrenOf,
        // --- Batch-edit context fields — wired to the per-cell pending-changes
        // buffer (_batchChanges) and the additive new-row buffer (_batchAdded).
        IsBatchEdit: EditMode == DataGridEditMode.Batch,
        IsCellDirty: IsCellDirty,
        GetBatchValue: GetBatchValue,
        SetBatchValue: SetBatchValue,
        GridId: _gridId,
        FocusedRow: _focusedRow,
        FocusedCol: _focusedCol,
        RowCount: _displayedItems.Count,
        ColCount: _visibleColumns.Count,
        OnCellKeyDown: HandleCellKeyDownAsync,
        OnHeaderKeyDown: HandleHeaderKeyDownAsync,
        Striped: Striped,
        HasPinnedLeft: _orderedColumns.Any(c => c.Visible && c.Pin == PinDirection.Left),
        Hoverable: Hoverable,
        ColumnGroups: _columnGroups,
        Compact: Compact
    );
}

@{
    RenderFragment gridRoot = @<div data-slot="datagrid" data-grid-id="@_gridId" class="@RootCssClass" style="@HeightStyle" @attributes="AdditionalAttributes">

        @* Declarative column definitions *@
        <div class="hidden">@ChildContent</div>

        @if (_serverService?.Error is not null)
        {
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-destructive/30 bg-destructive/10 text-sm">
                <SvgGlyph Svg="@(LumeoIcons.CircleAlert)" class="h-4 w-4 shrink-0 text-destructive" />
                <span class="flex-1 text-destructive-text">@L["DataGrid.ErrorLoadingData", _serverService.Error ?? ""]</span>
                <button type="button"
                        class="text-xs text-destructive underline hover:no-underline focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2 rounded"
                        @onclick="@(async () => { _serverService!.ClearError(); await RequestServerData(); })">
                    @L["DataGrid.Retry"]
                </button>
            </div>
        }

        @if (ShowToolbar)
        {
            <DataGridToolbar TItem="TItem"
                             SearchText="@_globalSearch"
                             SearchTextChanged="HandleGlobalSearch"
                             RegisteredContent="@RegisteredToolbarContent"
                             OnColumnToggle="HandleColumnVisibilityChanged"
                             OnColumnReorder="HandleColumnReorder"
                             OnExport="HandleExport"
                             OnRemoveFilter="RemoveFilter"
                             SelectedItems="_selectedItems"
                             AllItems="@(ServerMode ? _displayedItems : _processedItems)"
                             EffectiveColumns="EffectiveColumns.AsReadOnly()"
                             EnableLayoutPersistence="EnableLayoutPersistence"
                             OnSaveLayout="HandleSaveLayout"
                             OnResetLayout="HandleResetLayout"
                             GlobalLayouts="GlobalLayouts"
                             OnSaveNamedLayout="HandleSaveNamedLayout"
                             OnDeleteNamedLayout="OnDeleteNamedLayout"
                             OnApplyNamedLayout="HandleApplyNamedLayout"
                             LayoutStorageKey="LayoutStorageKey"
                             OnError="OnError"
                             Expandable="Expandable"
                             IsExpanded="_isExpanded"
                             OnToggleExpanded="ToggleExpanded"
                             ShowSearch="ShowSearch"
                             ShowColumnChooser="ShowColumnChooser"
                             ShowExport="ShowExport"
                             ExportFormats="ExportFormats" />
        }

        @if (_contextMenuVisible)
        {
            <div id="@_contextMenuId"
                 class="fixed z-50 min-w-[160px] rounded-md border border-border/40 bg-popover p-1 shadow-md"
                 style="left: @(_contextMenuX)px; top: @(_contextMenuY)px;"
                 @onclick:stopPropagation="true">
                @if (RowContextMenu is not null && _contextMenuItem is not null)
                {
                    @RowContextMenu(_contextMenuItem)
                }
            </div>
        }

        @if (EditMode == DataGridEditMode.Batch && HasPendingChanges)
        {
            @* Batch-edit pending-changes strip. Uses warning/amber theme tokens
               from lumeo.css (--color-warning, --color-warning-text). Sits
               above the table body so it's visually associated with dirty cells. *@
            <div data-slot="datagrid-batch-strip"
                 class="flex flex-wrap items-center gap-2 px-4 py-2 border-b border-warning/40 bg-warning/10 text-xs"
                 role="status"
                 aria-live="polite">
                <SvgGlyph Svg="@(LumeoIcons.CircleAlert)" class="h-4 w-4 text-warning-text shrink-0" />
                <span class="text-warning-text font-medium">
                    @{
                        // _batchChanges contains entries for both modified existing rows AND
                        // newly-added rows (the latter seeded with an empty dict). Count only
                        // changes to *existing* rows by excluding items that are in _batchAdded.
                        var modifiedCount = _batchChanges.Keys.Count(k => !_batchAdded.Contains(k));
                        var pendingTotal = modifiedCount + _batchAdded.Count;
                    }
                    @($"{pendingTotal} pending change(s)")
                </span>
                <div class="ms-auto flex items-center gap-2">
                    <button type="button"
                            data-slot="datagrid-batch-save"
                            class="inline-flex h-7 items-center rounded-md bg-primary px-3 text-xs font-medium text-primary-foreground hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2"
                            @onclick="SaveBatchAsync">
                        @BatchSaveAllText
                    </button>
                    <button type="button"
                            data-slot="datagrid-batch-discard"
                            class="inline-flex h-7 items-center rounded-md border border-border/60 bg-background px-3 text-xs font-medium hover:bg-muted focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2"
                            @onclick="DiscardBatch">
                        @BatchDiscardText
                    </button>
                </div>
            </div>
        }

        @if (ShowGroupPanel)
        {
            @* rc.41: real drop zone — header DnD now lands here. Visual highlight
               via _isGroupPanelDragOver. The dropped column's field comes from
               _dragState.SourceColumnId (set by HeaderCell.HandleDragStart). *@
            <div data-slot="datagrid-group-panel"
                 class="@($"flex flex-wrap items-center gap-2 px-3 py-2 border-b border-dashed text-xs transition-colors {(_isGroupPanelDragOver ? "border-primary bg-primary/10" : "border-border/40 bg-muted/30")}")"
                 @ondragover:preventDefault="true"
                 @ondragenter="HandleGroupPanelDragEnter"
                 @ondragleave="HandleGroupPanelDragLeave"
                 @ondrop="HandleGroupPanelDrop">
                @if (_runtimeGroupFields.Count == 0)
                {
                    <span class="text-muted-foreground select-none pointer-events-none">
                        @(GroupPanelText ?? L["DataGrid.GroupPanelPlaceholder"])
                    </span>
                }
                else
                {
                    @for (var gi = 0; gi < _runtimeGroupFields.Count; gi++)
                    {
                        var field = _runtimeGroupFields[gi];
                        var col = EffectiveColumns.FirstOrDefault(c => c.Field == field);
                        var label = col?.Title ?? field;
                        @* div (not span) wrapper: the Tooltip below renders a block <div>, which a <span>
                           cannot legally contain — the browser would auto-close the chip before the tooltip,
                           ejecting the remove button outside the bordered chip. inline-flex keeps the inline
                           chip layout on a div (Codex P3). *@
                        <div class="inline-flex items-center gap-1 rounded bg-card border border-border/60 px-2 py-0.5">
                            <SvgGlyph Svg="@(LumeoIcons.Group)" class="h-3 w-3 text-muted-foreground" />
                            <span>@label</span>
                            <Tooltip>
                                <TooltipTrigger AsChild>
                                    <ChildContentSlot Context="slot">
                                        <button type="button"
                                                class="inline-flex items-center justify-center h-4 w-4 rounded hover:bg-muted text-muted-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1"
                                                aria-label="@L["DataGrid.RemoveGrouping"]"
                                                @onclick="@(() => RemoveGroupField(field))"
                                                @attributes="slot.Attributes">
                                            <SvgGlyph Svg="@(LumeoIcons.X)" class="h-3 w-3" />
                                        </button>
                                    </ChildContentSlot>
                                </TooltipTrigger>
                                <TooltipContent>@L["DataGrid.RemoveGrouping"]</TooltipContent>
                            </Tooltip>
                        </div>
                        @if (gi < _runtimeGroupFields.Count - 1)
                        {
                            <SvgGlyph Svg="@(LumeoIcons.ChevronRight)" class="h-3 w-3 text-muted-foreground/60" />
                        }
                    }
                }
                @{
                    var addableCols = EffectiveColumns
                        .Where(c => c.Groupable && c.Field is not null && !_runtimeGroupFields.Contains(c.Field!))
                        .ToList();
                }
                @if (_runtimeGroupFields.Count > 0)
                {
                    @* Clear-all button: lives next to the chips so it's discoverable
                       and matches the per-chip X visual. rc.41 polish. *@
                    <Tooltip>
                        <TooltipTrigger AsChild>
                            <ChildContentSlot Context="slot">
                                <button type="button"
                                        class="ms-1 inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-xs text-muted-foreground hover:bg-muted hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1"
                                        aria-label="@L["DataGrid.ClearAllGrouping"]"
                                        @onclick="ClearGroupFields"
                                        @attributes="slot.Attributes">
                                    <SvgGlyph Svg="@(LumeoIcons.X)" class="h-3 w-3" />
                                    Clear
                                </button>
                            </ChildContentSlot>
                        </TooltipTrigger>
                        <TooltipContent>@L["DataGrid.ClearAllGrouping"]</TooltipContent>
                    </Tooltip>
                }
                @if (addableCols.Count > 0)
                {
                    @* 2.2.0 — was a native <select> with @key-on-count to work
                       around the browser's value-sticking, but the browser
                       chrome (white-on-blue on Windows, OS-default everywhere)
                       broke the theme entirely. DropdownMenu is the right
                       pattern here anyway: this is an "execute an action"
                       picker, not a "bind a value" picker, so it shouldn't
                       maintain a selected state in the first place. *@
                    @* The DropdownMenu component itself renders a relative-inline-block
                       wrapper div as its root, so ms-auto on the inner trigger button has
                       no effect on the flex parent. Wrap the whole component in a div that
                       takes the ms-auto so the picker sits at the inline-end of the panel. *@
                    <div class="ms-auto">
                        <DropdownMenu>
                            <DropdownMenuTrigger>
                                <button type="button"
                                        data-slot="datagrid-group-add-trigger"
                                        class="inline-flex items-center gap-1 h-6 rounded border border-border/60 bg-card px-2 text-xs text-muted-foreground hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2 transition-colors">
                                    <span>@L["DataGrid.AddGroupLevel"]</span>
                                    <SvgGlyph Svg="@(LumeoIcons.ChevronDown)" class="h-3 w-3 shrink-0 transition-transform duration-200 group-data-[state=open]:rotate-180" />
                                </button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent>
                                @foreach (var c in addableCols)
                                {
                                    var field = c.Field!;
                                    <DropdownMenuItem AdditionalAttributes="@(new Dictionary<string, object> { ["data-group-add-field"] = field })"
                                                      OnClick="@(() => { AddGroupField(field); return Task.CompletedTask; })">
                                        @(c.Title ?? c.Field)
                                    </DropdownMenuItem>
                                }
                            </DropdownMenuContent>
                        </DropdownMenu>
                    </div>
                }
            </div>
        }

        <div class="overflow-auto flex-1" @onclick="CloseContextMenu">
            <table class="w-full caption-bottom text-sm"
                   id="@_gridId"
                   role="@(IsTreeGridMode ? "treegrid" : "grid")"
                   aria-rowcount="@(_displayedItems.Count + 1)"
                   aria-colcount="@_visibleColumns.Count"
                   aria-readonly="@(EditMode == DataGridEditMode.None ? "true" : null)"
                   aria-multiselectable="@(SelectionMode == DataGridSelectionMode.Multiple ? "true" : null)">
                <DataGridHeader TItem="TItem"
                                HasDetailTemplate="@(DetailTemplate is not null)"
                                ActiveFilterColumn="@_activeFilterColumn"
                                OnFilterToggle="HandleFilterToggle"
                                OnFilterApply="HandleFilterApply"
                                Reorderable="Reorderable"
                                OnColumnReorder="HandleColumnReorder" />

                <DataGridBody TItem="TItem"
                              @ref="_bodyRef"
                              DetailTemplate="DetailTemplate"
                              EmptyContent="EmptyContent"
                              UseVirtualization="@UseVirtualization"
                              VirtualItemSize="@EffectiveVirtualItemSize"
                              VirtualOverscanCount="@VirtualOverscanCount"
                              ServerVirtualizationProvider="@(_useServerVirtualization ? ServerVirtualizationProviderImpl : null)"
                              HasDetailTemplate="@(DetailTemplate is not null)"
                              SkeletonRowCount="@PageSize"
                              OnContextMenu="@(args => HandleContextMenu(args.Item1, args.Item2, args.Item3))" />
            </table>
            @if (EditMode == DataGridEditMode.Batch && ShowAddRow && NewItemFactory is not null)
            {
                <div data-slot="datagrid-add-row"
                     class="flex items-center border-t border-border/40 bg-muted/20 px-3 py-1.5">
                    <button type="button"
                            data-slot="datagrid-add-row-button"
                            class="inline-flex h-7 items-center gap-1 rounded-md border border-dashed border-border/60 bg-card px-2 text-xs text-muted-foreground hover:bg-muted hover:text-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2"
                            @onclick="AddBatchRow">
                        <SvgGlyph Svg="@(LumeoIcons.Plus)" class="h-3.5 w-3.5" />
                        <span>@BatchAddRowText</span>
                    </button>
                </div>
            }
        </div>

        @* Aggregate strip — rendered OUTSIDE the scrolling table wrapper so the
           AVG/SUM/COUNT row always sits at the bottom of the card, flush above
           the pagination strip, regardless of whether the table itself scrolls. *@
        <DataGridFooter TItem="TItem"
                        AllItems="@_processedItems"
                        HasDetailTemplate="@(DetailTemplate is not null)" />

        @if (ShowPagination && !IsLoading && !_useServerVirtualization)
        {
            <DataGridPagination TItem="TItem"
                                PageChanged="HandlePageChanged"
                                PageSizeChanged="HandlePageSizeChanged"
                                PageSizeOptions="@PageSizeOptions" />
        }
    </div>;
}

<CascadingValue Value="this" IsFixed="true">
<CascadingValue Value="_dragState" IsFixed="true">
<CascadingValue Value="context" IsFixed="false">
<CascadingValue Value="_toolbarContext" IsFixed="false">
    @if (_isExpanded)
    {
        <div class="fixed inset-0 lumeo-datagrid-fullscreen-backdrop"
             style="z-index: 99;"
             aria-hidden="true"
             @onclick="ToggleExpanded"></div>
        <div class="fixed bg-background flex flex-col border border-border/60 rounded-xl shadow-2xl overflow-hidden lumeo-datagrid-fullscreen lumeo-datagrid-fullscreen-panel"
             style="z-index: 100; inset: 2.5rem;"
             role="dialog"
             aria-modal="true"
             aria-label="@(FullscreenTitle ?? "Expanded data grid")"
             tabindex="-1"
             @ref="_fullscreenRef"
             @onkeydown="HandleFullscreenKeyDown">
            @* Title strip — only shown when FullscreenTitle is set. The X was removed because the toolbar
               already renders a Minimize icon (DataGridToolbarFullscreen) that does the same thing. Users
               without that tool in a custom ToolbarContent can still press Esc. *@
            @if (!string.IsNullOrEmpty(FullscreenTitle))
            {
                <div class="flex items-center border-b border-border/40 px-5 py-2.5 shrink-0 bg-muted/30">
                    <Heading Level="3" Class="text-sm font-semibold m-0 tracking-tight">@FullscreenTitle</Heading>
                </div>
            }
            @* No extra padding — the grid component carries its own borders/rounded corners and fills the
               remaining modal height via CSS (see `.lumeo-datagrid-fullscreen-panel [data-slot=datagrid]`). *@
            <div class="flex-1 min-h-0 flex flex-col">
                @gridRoot
            </div>
        </div>
    }
    else
    {
        @gridRoot
    }
</CascadingValue>
</CascadingValue>
</CascadingValue>
</CascadingValue>

@code {
    // --- Data ---
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public List<DataGridColumn<TItem>>? Columns { get; set; }

    // --- Appearance ---
    [Parameter] public bool Striped { get; set; }
    [Parameter] public bool Bordered { get; set; }
    /// <summary>
    /// Dense layout: header and body cells drop from <c>px-3 py-2</c> to
    /// <c>px-2 py-1</c> (and the root text shrinks to <c>text-sm</c>), so the
    /// effective row height genuinely decreases — not just the font size. The
    /// flag flows to every cell through <see cref="DataGridContext{TItem}"/>, so
    /// toggling it after first render re-pads the grid live. When virtualization
    /// is active (see <see cref="VirtualItemSize"/>) the default row-height
    /// estimate is auto-tightened under Compact unless you pass an explicit
    /// <see cref="VirtualItemSize"/>. Default <c>false</c>.
    /// </summary>
    [Parameter] public bool Compact { get; set; }
    [Parameter] public bool Hoverable { get; set; } = true;
    [Parameter] public string? Height { get; set; }

    // --- Features ---
    [Parameter] public DataGridSelectionMode SelectionMode { get; set; } = DataGridSelectionMode.None;
    [Parameter] public DataGridEditMode EditMode { get; set; } = DataGridEditMode.None;
    [Parameter] public int PageSize { get; set; } = 10;
    /// <summary>The list of page-size options shown in the rows-per-page
    /// selector. Defaults to <c>{ 10, 25, 50, 100 }</c>. Set to e.g.
    /// <c>{ 10, 50, 100, 200, 300 }</c> for larger datasets, or to an
    /// empty array to hide the selector entirely.</summary>
    [Parameter] public int[] PageSizeOptions { get; set; } = new[] { 10, 25, 50, 100 };
    [Parameter] public bool ShowPagination { get; set; } = true;
    [Parameter] public bool ShowToolbar { get; set; }

    /// <summary>Show the global search box in the toolbar. Default true.</summary>
    [Parameter] public bool ShowSearch { get; set; } = true;

    /// <summary>Show the Columns button (visibility/reorder menu). Default true.</summary>
    [Parameter] public bool ShowColumnChooser { get; set; } = true;

    /// <summary>
    /// Show the Export button and its format dropdown. Default true.
    /// Set false to hide export entirely. For fine-grained per-format control see
    /// <see cref="ExportFormats"/>.
    /// </summary>
    [Parameter] public bool ShowExport { get; set; } = true;

    /// <summary>
    /// Which export formats appear in the Export dropdown. Default <see cref="DataGridExportFormat.All"/>.
    /// Set to e.g. <c>Csv | Excel</c> to hide PDF in WebAssembly where QuestPDF isn't supported.
    /// When no flags are set (or <see cref="ShowExport"/> is false), the Export button is hidden.
    /// </summary>
    [Parameter] public DataGridExportFormat ExportFormats { get; set; } = DataGridExportFormat.All;
    /// <summary>Item count above which Blazor's <c>&lt;Virtualize&gt;</c>
    /// kicks in. Only relevant when <see cref="ShowPagination"/> is false
    /// (or <see cref="PageSize"/> &gt; this threshold) — paged grids show
    /// at most <see cref="PageSize"/> rows at once and never trigger
    /// virtualization. Default 500.</summary>
    [Parameter] public int VirtualizeThreshold { get; set; } = 500;
    /// <summary>Estimated row height in CSS pixels — used by
    /// <c>&lt;Virtualize&gt;</c> to size the scroll spacers. Tune if your
    /// rows are taller (dense badges, two-line cells). Default 41px. When
    /// <see cref="Compact"/> is on and this parameter is left at its default,
    /// the estimate auto-tightens to <see cref="CompactVirtualItemSize"/>px so
    /// the scroll spacers match the shorter compact rows; pass an explicit value
    /// to override either way.</summary>
    [Parameter] public float VirtualItemSize { get; set; } = 41f;

    /// <summary>Row-height estimate used for virtualization when <see cref="Compact"/>
    /// is on and <see cref="VirtualItemSize"/> was not set explicitly. Matches the
    /// compact <c>py-1</c> cell padding.</summary>
    private const float CompactVirtualItemSize = 33f;

    // Tracks whether the consumer passed VirtualItemSize explicitly. Only then do
    // we keep it verbatim under Compact; otherwise Compact swaps in the tighter
    // default so the Virtualize scroll spacers don't overshoot the real rows.
    private bool _virtualItemSizeExplicit;

    /// <summary>The row-height estimate actually handed to <c>&lt;Virtualize&gt;</c>:
    /// the consumer's value when set, else the density-appropriate default.</summary>
    private float EffectiveVirtualItemSize =>
        _virtualItemSizeExplicit ? VirtualItemSize
        : (Compact ? CompactVirtualItemSize : VirtualItemSize);

    public override Task SetParametersAsync(ParameterView parameters)
    {
        // Detect an explicit VirtualItemSize BEFORE the values are applied so the
        // Compact auto-tighten only kicks in when the consumer left it defaulted.
        if (parameters.TryGetValue<float>(nameof(VirtualItemSize), out _))
            _virtualItemSizeExplicit = true;
        return base.SetParametersAsync(parameters);
    }
    /// <summary>Extra rows rendered above and below the viewport to
    /// hide pop-in during fast scrolling. Default 3.</summary>
    [Parameter] public int VirtualOverscanCount { get; set; } = 3;
    [Parameter] public bool Reorderable { get; set; }
    [Parameter] public bool RowReorderable { get; set; }
    [Parameter] public string? GroupBy { get; set; }
    [Parameter] public bool GroupsExpandedByDefault { get; set; } = true;

    /// <summary>
    /// Ordered list of fields for multi-level grouping. When set (non-empty) this
    /// takes precedence over the single <see cref="GroupBy"/> parameter. Each entry
    /// must be a column <c>Field</c>. The grid renders nested group rows with
    /// increasing indentation per level; per-level aggregates are shown on each
    /// group header row.
    /// </summary>
    [Parameter] public IReadOnlyList<string>? GroupByFields { get; set; }

    /// <summary>
    /// Shows a slim bar above the grid that lists the current grouping levels as
    /// removable chips, plus a dropdown to add a new level from any
    /// <see cref="DataGridColumn{TItem}.Groupable"/> column. Default false.
    /// </summary>
    [Parameter] public bool ShowGroupPanel { get; set; }

    /// <summary>Placeholder/hint text shown in the group panel when no fields are grouped.</summary>
    [Parameter] public string? GroupPanelText { get; set; }

    // --- Tree-grid mode ---
    /// <summary>
    /// When set, the grid renders a hierarchical tree-grid: this selector returns a
    /// row's child rows (null/empty = leaf). Each parent row gets an expand chevron
    /// in the tree column (see <see cref="TreeColumnField"/>). Distinct from
    /// <see cref="DetailTemplate"/>, which is a flat expand-for-detail fragment.
    /// Tree-grid mode and grouping are mutually exclusive — when both are configured,
    /// tree-grid mode wins.
