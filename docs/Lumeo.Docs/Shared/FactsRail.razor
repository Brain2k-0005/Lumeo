@namespace Lumeo.Docs.Shared
@using Lumeo.Docs.Services
@inject RegistryService Registry

@* The "Quick facts" rail (design B) — every fact comes from registry/{slug}.json,
   so it's complete, accurate, and consistent without a line of per-page maintenance.
   Sits above "On this page" in the right rail. *@
@if (_detail is { } d)
{
    <div class="text-sm flex flex-col gap-3">
        <div class="font-semibold text-foreground text-xs uppercase tracking-wide">Quick facts</div>

        <div class="flex flex-col gap-1">
            <span class="text-[11px] uppercase tracking-wide text-muted-foreground/60">Package</span>
            <code class="text-xs text-foreground">@d.NugetPackage</code>
        </div>

        @if (d.Api?.A11y is { } a && (a.FocusManaged || a.KeyboardInteractive || a.Roles.Count > 0))
        {
            <div class="flex flex-col gap-1">
                <span class="text-[11px] uppercase tracking-wide text-muted-foreground/60">Accessibility</span>
                <div class="flex flex-wrap gap-1">
                    @if (a.FocusManaged) {<span class="rounded bg-muted px-1.5 py-0.5 text-[11px] text-muted-foreground">focus-managed</span>}
                    @if (a.KeyboardInteractive) {<span class="rounded bg-muted px-1.5 py-0.5 text-[11px] text-muted-foreground">keyboard</span>}
                    @foreach (var role in a.Roles.Take(3)) {<span class="rounded bg-muted px-1.5 py-0.5 text-[11px] font-mono text-muted-foreground">@role</span>}
                </div>
            </div>
        }

        @if (d.Dependencies.Count > 0)
        {
            <div class="flex flex-col gap-1">
                <span class="text-[11px] uppercase tracking-wide text-muted-foreground/60">Depends on</span>
                <div class="flex flex-wrap gap-1">
                    @foreach (var dep in d.Dependencies)
                    {
                        <a href="components/@dep" class="rounded bg-muted px-1.5 py-0.5 text-[11px] text-foreground hover:bg-accent no-underline transition-colors">@dep</a>
                    }
                </div>
            </div>
        }

        @if (d.RelatedComponents.Count > 0)
        {
            <div class="flex flex-col gap-1">
                <span class="text-[11px] uppercase tracking-wide text-muted-foreground/60">Related</span>
                <div class="flex flex-col gap-0.5">
                    @foreach (var r in d.RelatedComponents.Take(5))
                    {
                        <a href="components/@Slugify(r.Name)" class="text-xs text-primary hover:underline">@r.Name</a>
                    }
                </div>
            </div>
        }

        @if (d.TestCoverage is { } tc)
        {
            <div class="flex flex-col gap-1">
                <span class="text-[11px] uppercase tracking-wide text-muted-foreground/60">Tested</span>
                <a href="test-coverage" class="text-xs text-muted-foreground hover:text-foreground no-underline transition-colors">Tier @tc.Tier · @tc.TierLabel · @tc.Tests tests</a>
            </div>
        }

        @if (d.SourceUrl.FirstOrDefault()?.Url is { } src)
        {
            <a href="@src" target="_blank" rel="noopener" class="text-xs text-primary hover:underline">View source ↗</a>
        }
    </div>
}

@code {
    [Parameter, EditorRequired] public string Slug { get; set; } = "";

    private RegistryComponentDetail? _detail;

    protected override async Task OnParametersSetAsync()
        => _detail = await Registry.GetComponentAsync(Slug);

    private static string Slugify(string name)
        => name.Trim().ToLowerInvariant().Replace(' ', '-');
}
