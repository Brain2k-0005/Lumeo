@page "/blocks/mail"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>Mail — Lumeo</PageTitle>

<PageHeader Title="Mail" Description="A three-column inbox with folder rail, message list, reading pane, and reply composer." />

<ComponentDemo Title="Mail / Inbox" Code="@_mailCode">
    <Stack Class="w-full min-w-[780px] border border-border/40 rounded-xl overflow-hidden" style="height: 580px;">
        <Flex Class="h-full">

            <!-- Icon Rail (col 1) -->
            <Flex Direction="col" Class="w-14 border-r border-border/40 bg-card items-center py-3 gap-1 flex-shrink-0">
                <Tooltip Content="Inbox" Placement="Tooltip.TooltipPlacement.Right">
                    <Stack Class="relative">
                        <Button Variant="@(_activeFolder == "inbox" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                                @onclick="@(() => _activeFolder = "inbox")">
                            <DynamicIcon Name="Inbox" Class="h-4 w-4" />
                        </Button>
                        <Lumeo.Text As="span" Class="absolute -top-1 -right-1 h-4 min-w-4 rounded-full bg-primary text-primary-foreground text-[10px] flex items-center justify-center px-1 pointer-events-none">3</Lumeo.Text>
                    </Stack>
                </Tooltip>
                <Tooltip Content="Sent" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="@(_activeFolder == "sent" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                            Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                            @onclick="@(() => _activeFolder = "sent")">
                        <DynamicIcon Name="Send" Class="h-4 w-4" />
                    </Button>
                </Tooltip>
                <Tooltip Content="Drafts" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="@(_activeFolder == "drafts" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                            Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                            @onclick="@(() => _activeFolder = "drafts")">
                        <DynamicIcon Name="FileEdit" Class="h-4 w-4" />
                    </Button>
                </Tooltip>
                <Tooltip Content="Starred" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="@(_activeFolder == "starred" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                            Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                            @onclick="@(() => _activeFolder = "starred")">
                        <DynamicIcon Name="Star" Class="h-4 w-4" />
                    </Button>
                </Tooltip>
                <Tooltip Content="Spam" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="@(_activeFolder == "spam" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                            Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                            @onclick="@(() => _activeFolder = "spam")">
                        <DynamicIcon Name="ShieldAlert" Class="h-4 w-4" />
                    </Button>
                </Tooltip>
                <Tooltip Content="Trash" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="@(_activeFolder == "trash" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                            Size="Button.ButtonSize.Icon" Class="h-9 w-9"
                            @onclick="@(() => _activeFolder = "trash")">
                        <DynamicIcon Name="Trash2" Class="h-4 w-4" />
                    </Button>
                </Tooltip>

                <Separator Class="my-1" />

                <!-- Labels -->
                <Tooltip Content="Work" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-9 w-9">
                        <Lumeo.Text As="span" Class="h-2.5 w-2.5 rounded-full bg-primary block"></Lumeo.Text>
                    </Button>
                </Tooltip>
                <Tooltip Content="Personal" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-9 w-9">
                        <Lumeo.Text As="span" Class="h-2.5 w-2.5 rounded-full bg-chart-2 block"></Lumeo.Text>
                    </Button>
                </Tooltip>
                <Tooltip Content="Important" Placement="Tooltip.TooltipPlacement.Right">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-9 w-9">
                        <Lumeo.Text As="span" Class="h-2.5 w-2.5 rounded-full bg-chart-4 block"></Lumeo.Text>
                    </Button>
                </Tooltip>

                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-9 w-9 mt-auto">
                    <DynamicIcon Name="Settings" Class="h-4 w-4" />
                </Button>
            </Flex>

            <!-- Message List (col 2) -->
            <Flex Direction="col" Class="w-72 border-r border-border/40 bg-card flex-shrink-0">
                <!-- Toolbar -->
                <Stack Gap="2" Class="p-3 border-b border-border/40">
                    <Flex Class="relative items-center">
                        <DynamicIcon Name="Search" Class="absolute left-2.5 top-1/2 -translate-y-1/2 h-3.5 w-3.5 text-muted-foreground pointer-events-none" />
                        <Input placeholder="Search mail..." Class="pl-8 h-8 text-xs w-full" />
                    </Flex>
                    <Flex Class="items-center gap-1">
                        <Button Variant="@(_activeFilter == "all" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Sm" Class="h-7 text-xs"
                                @onclick="@(() => _activeFilter = "all")">All</Button>
                        <Button Variant="@(_activeFilter == "unread" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Sm" Class="h-7 text-xs"
                                @onclick="@(() => _activeFilter = "unread")">Unread</Button>
                        <Button Variant="@(_activeFilter == "starred" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Sm" Class="h-7 text-xs"
                                @onclick="@(() => _activeFilter = "starred")">Starred</Button>
                        <Badge Class="ml-auto">@_mailItems.Count(m => !m.IsRead)</Badge>
                    </Flex>
                </Stack>

                <!-- Mail List -->
                <Stack Class="flex-1 overflow-y-auto">
                    @for (int i = 0; i < _mailItems.Count; i++)
                    {
                        var index = i;
                        var mail = _mailItems[i];
                        var isActive = _selectedIndex == index;
                        <Stack Class="@($"gap-1 px-3 py-2.5 border-b border-border/40 cursor-pointer transition-colors {(isActive ? "bg-accent" : "hover:bg-muted/40")}")"
                               @onclick="@(() => _selectedIndex = index)">
                            <Flex Class="items-center justify-between gap-2">
                                <Flex Class="items-center gap-2 min-w-0">
                                    @if (!mail.IsRead)
                                    {
                                        <Lumeo.Text As="span" Class="h-2 w-2 rounded-full bg-primary shrink-0 block"></Lumeo.Text>
                                    }
                                    else
                                    {
                                        <Lumeo.Text As="span" Class="h-2 w-2 shrink-0 block"></Lumeo.Text>
                                    }
                                    <Avatar Class="h-7 w-7 flex-shrink-0">
                                        <AvatarFallback Class="text-[10px]">@mail.Initials</AvatarFallback>
                                    </Avatar>
                                    <Lumeo.Text As="span" Class="@($"text-sm truncate {(!mail.IsRead ? "font-semibold text-foreground" : "font-medium text-foreground")}")">@mail.Sender</Lumeo.Text>
                                </Flex>
                                <Lumeo.Text As="span" Class="text-xs text-muted-foreground shrink-0">@mail.Time</Lumeo.Text>
                            </Flex>
                            <Lumeo.Text Class="@($"text-xs pl-4 truncate {(!mail.IsRead ? "font-semibold text-foreground" : "font-medium text-foreground/80")}")">@mail.Subject</Lumeo.Text>
                            <Lumeo.Text Class="text-xs text-muted-foreground pl-4 truncate">@mail.Preview</Lumeo.Text>
                            @if (mail.Tags?.Length > 0)
                            {
                                <Flex Class="gap-1 pl-4 flex-wrap">
                                    @foreach (var tag in mail.Tags)
                                    {
                                        <Badge Variant="Badge.BadgeVariant.Secondary" Class="text-[10px] h-4 px-1">@tag</Badge>
                                    }
                                </Flex>
                            }
                        </Stack>
                    }
                </Stack>
            </Flex>

            <!-- Reading Pane (col 3) -->
            <Flex Direction="col" Class="flex-1 bg-background min-w-0">
                @{
                    var selected = _mailItems[_selectedIndex];
                }

                <!-- Email Header -->
                <Stack Class="p-4 border-b border-border/40 bg-card">
                    <Flex Class="items-start justify-between gap-4">
                        <Flex Class="items-start gap-3 min-w-0">
                            <Avatar>
                                <AvatarFallback>@selected.Initials</AvatarFallback>
                            </Avatar>
                            <Stack Class="min-w-0">
                                <Flex Class="items-center gap-2 flex-wrap">
                                    <Lumeo.Text As="span" Class="text-sm font-semibold text-foreground">@selected.Sender</Lumeo.Text>
                                    <Lumeo.Text As="span" Class="text-xs text-muted-foreground border border-border/40 rounded px-1.5 py-0.5">@selected.SenderEmail</Lumeo.Text>
                                </Flex>
                                <Lumeo.Text Class="text-base font-semibold text-foreground mt-1 leading-tight">@selected.Subject</Lumeo.Text>
                                @if (selected.Tags?.Length > 0)
                                {
                                    <Flex Class="gap-1 flex-wrap mt-1">
                                        @foreach (var tag in selected.Tags)
                                        {
                                            <Badge Variant="Badge.BadgeVariant.Secondary" Class="text-xs">@tag</Badge>
                                        }
                                    </Flex>
                                }
                                <Lumeo.Text Class="text-xs text-muted-foreground mt-0.5">@selected.Date</Lumeo.Text>
                            </Stack>
                        </Flex>
                        <Flex Class="items-center gap-1 flex-shrink-0">
                            <Tooltip Content="Archive">
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                    <DynamicIcon Name="Archive" Class="h-4 w-4" />
                                </Button>
                            </Tooltip>
                            <Tooltip Content="Forward">
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                    <DynamicIcon Name="Forward" Class="h-4 w-4" />
                                </Button>
                            </Tooltip>
                            <Tooltip Content="Delete">
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                    <DynamicIcon Name="Trash2" Class="h-4 w-4" />
                                </Button>
                            </Tooltip>
                            <Tooltip Content="More">
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                    <DynamicIcon Name="Ellipsis" Class="h-4 w-4" />
                                </Button>
                            </Tooltip>
                        </Flex>
                    </Flex>
                </Stack>

                <!-- Email Body -->
                <Stack Class="flex-1 overflow-y-auto p-5">
                    <Lumeo.Text Class="text-sm text-foreground leading-relaxed whitespace-pre-line">@selected.Body</Lumeo.Text>
                </Stack>

                <Separator />

                <!-- Reply Composer -->
                <Stack Gap="2" Class="p-3 bg-card">
                    <Flex Class="items-center justify-between">
                        <Flex Class="items-center gap-2">
                            <DynamicIcon Name="CornerUpLeft" Class="h-3.5 w-3.5 text-muted-foreground" />
                            <Lumeo.Text Class="text-xs font-medium text-muted-foreground">Reply to @selected.Sender</Lumeo.Text>
                        </Flex>
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="h-auto py-0.5 px-2 text-muted-foreground text-xs">Cc / Bcc</Button>
                    </Flex>
                    <Textarea placeholder="Write your reply..." Class="min-h-[70px] text-sm resize-none" @bind-Value="_replyText" />
                    <Flex Class="justify-between items-center gap-2">
                        <Flex Class="items-center gap-1">
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                <DynamicIcon Name="Paperclip" Class="h-3.5 w-3.5" />
                            </Button>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" Class="h-8 w-8">
                                <DynamicIcon Name="Image" Class="h-3.5 w-3.5" />
                            </Button>
                        </Flex>
                        <Flex Class="items-center gap-2">
                            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">
                                <DynamicIcon Name="Forward" Class="h-3.5 w-3.5 mr-1.5" />
                                Forward
                            </Button>
                            <Button Size="Button.ButtonSize.Sm">
                                <DynamicIcon Name="Send" Class="h-3.5 w-3.5 mr-1.5" />
                                Send
                            </Button>
                        </Flex>
                    </Flex>
                </Stack>
            </Flex>

        </Flex>
    </Stack>
</ComponentDemo>

@code {
