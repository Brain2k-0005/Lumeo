@page "/components/mention"

<PageTitle>Mention — Lumeo</PageTitle>

<PageHeader Title="Mention" Description="A textarea with mention support that shows a dropdown when a trigger character is typed." />

<InstallUsage Component="Mention" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>@@user mentions in comments, messages, or chat interfaces</li>
        <li>Tagging team members in collaborative editing tools</li>
        <li>Referencing channels, issues, or documents with custom trigger characters</li>
        <li>Social features that require inline user or entity tagging</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Mention" Code="@_basicCode">
        <Mention @bind-Value="_text1" Options="@_people" Placeholder="Type to mention someone..." Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Custom Trigger" Code="@_triggerCode">
        <Mention @bind-Value="_text2" Options="@_channels" Trigger="@('#')" Placeholder="Type # to reference a channel..." Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Label, Required & Helper Text">
        <Mention @bind-Value="_text4"
                 Options="@_people"
                 Label="Comment"
                 Required="true"
                 HelperText="Type the at-sign to mention a teammate."
                 Placeholder="Write a comment..."
                 Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Invalid State">
        <Mention Value="@_text5"
                 Options="@_people"
                 Label="Note"
                 Invalid="true"
                 ErrorText="A note is required."
                 Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Rows">
        <Mention @bind-Value="_text6" Options="@_people" Rows="6" Placeholder="A taller textarea (6 rows)..." Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled">
        <Mention Value="@("This field is disabled.")" Options="@_people" Disabled="true" Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Trigger Character" Description="Switch the trigger character to see different completion lists." Code="@_triggerSwitchCode">
        <Stack Gap="3">
            <Flex Align="center" Gap="3" Wrap="true">
                <Lumeo.Text Size="sm" Weight="medium">Trigger:</Lumeo.Text>
                <Segmented @bind-Value="_mentionTriggerStr">
                    <SegmentedItem Value="@_atTrigger">@_atTrigger</SegmentedItem>
                    <SegmentedItem Value="#">#</SegmentedItem>
                    <SegmentedItem Value="/">/</SegmentedItem>
                </Segmented>
            </Flex>
            <Mention @bind-Value="_text3"
                     Options="@GetOptionsForTrigger(_mentionTriggerStr)"
                     Trigger="@(_mentionTriggerStr[0])"
                     Placeholder="@($"Type {_mentionTriggerStr} to trigger suggestions...")"
                     Class="max-w-md" />
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">Mention</Heading>
            <PropsTable Slug="mention" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/textarea" class="text-primary hover:underline">Textarea</a> — Basic multi-line text input without mention support</li>
        <li><a href="/components/combobox" class="text-primary hover:underline">Combobox</a> — Searchable dropdown for standalone entity selection</li>
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — Single-line text input for simpler text fields</li>
    </ul>
</div>

@code {
    private string? _text1;
    private string? _text2;
    private string? _text4;
    private string? _text5 = "Looks good to me";
    private string? _text6;

    private List<Mention.MentionOption> _people = new()
    {
        new("Alice Johnson", "alice", Description: "Engineering"),
        new("Bob Smith", "bob", Description: "Marketing"),
        new("Carol White", "carol", Description: "Design"),
        new("David Brown", "david", Description: "Sales"),
    };

    private List<Mention.MentionOption> _channels = new()
    {
        new("general", "general"),
        new("engineering", "engineering"),
        new("design", "design"),
        new("random", "random"),
    };

    private string? _text3;
    private string _mentionTriggerStr = "@";
    private const string _atTrigger = "@";

    private List<Mention.MentionOption> _commands = new()
    {
        new("help", "help", Description: "Show help"),
        new("search", "search", Description: "Search content"),
        new("settings", "settings", Description: "Open settings"),
        new("logout", "logout", Description: "Sign out"),
    };

    private List<Mention.MentionOption> GetOptionsForTrigger(string trigger) => trigger switch
    {
        "#" => _channels,
        "/" => _commands,
        _ => _people,
    };

    private string _triggerSwitchCode = @"<Segmented @bind-Value=""_mentionTriggerStr"">
    <SegmentedItem Value=""@"">@@</SegmentedItem>
    <SegmentedItem Value=""#"">#</SegmentedItem>
    <SegmentedItem Value=""/""> /</SegmentedItem>
</Segmented>

<Mention @bind-Value=""_text""
         Options=""@GetOptionsForTrigger(_mentionTriggerStr)""
         Trigger=""@(_mentionTriggerStr[0])""
         Placeholder=""@($\""Type {_mentionTriggerStr} to trigger suggestions...\"")"" />

@code {
    private string _mentionTriggerStr = ""@"";
    private string? _text;
}";

    private string _basicCode = @"<Mention @bind-Value=""_text"" Options=""@_people"" Placeholder=""Type @@ to mention..."" />";
    private string _triggerCode = @"<Mention @bind-Value=""_text"" Options=""@_channels"" Trigger='#' />";
}
