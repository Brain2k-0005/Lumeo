@namespace MyApp.Auth
@inject NavigationManager Navigation

@* Rendered by <AuthorizeRouteView>'s <NotAuthorized> in App.razor when an anonymous
   visitor hits a protected page. Bounces them to the sign-in experience, preserving the
   page they were trying to reach as a returnUrl. *@

@code {
    protected override void OnInitialized()
    {
@*#if (AuthOidc)
        Navigation.NavigateToLogin("authentication/login");
##else
        var returnUrl = Navigation.ToBaseRelativePath(Navigation.Uri);
        var query = string.IsNullOrEmpty(returnUrl) ? string.Empty : $"?returnUrl={Uri.EscapeDataString(returnUrl)}";
        Navigation.NavigateTo($"login{query}");
##endif*@
    }
}
