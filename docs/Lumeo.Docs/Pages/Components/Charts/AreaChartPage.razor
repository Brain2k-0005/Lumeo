    private List<AreaChart.ChartSeriesData> _bandwidthSeries = new()
    {
        new() { Name = "Inbound (GB)", Values = new()
        {
            1843, 2012, 1934, 2178, 2341, 2589, 2467, 2712, 2934, 3187,
            3042, 3298, 3512, 3789, 3634, 3912, 4123, 4389, 4234, 4523,
