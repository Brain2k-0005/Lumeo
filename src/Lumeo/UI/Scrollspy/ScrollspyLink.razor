@namespace Lumeo

<button data-slot="scrollspy-link"
        data-active="@(Context?.ActiveId == Target ? "true" : null)"
        aria-current="@(Context?.ActiveId == Target ? "location" : null)"
        class="@CssClass"
        @onclick="HandleClick"
        @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] public Scrollspy.ScrollspyContext? Context { get; set; }
    /// <summary>The id of the <see cref="ScrollspySection"/> this link scrolls to and highlights against. Required.</summary>
    [Parameter, EditorRequired] public string Target { get; set; } = "";
    /// <summary>The link's label content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>&lt;button&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the <c>&lt;button&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge(Class);

    private async Task HandleClick()
    {
        if (Context is not null)
        {
            await Context.OnNavigate.InvokeAsync(Target);
        }
    }
}
