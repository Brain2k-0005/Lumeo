    private string _inputCode = @"<Toolbar>
    <Input Placeholder=""Search..."" Class=""h-7 text-sm w-48"" />
    <ToolbarSeparator />
    <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"">Filter</Button>
