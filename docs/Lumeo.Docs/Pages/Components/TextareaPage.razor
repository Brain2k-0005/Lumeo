@page "/components/textarea"

<PageTitle>Textarea — Lumeo</PageTitle>

<PageHeader Title="Textarea" Description="Displays a form textarea for multi-line text input." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Textarea placeholder="Type your message here." />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Binding" Code="@_bindingCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Textarea Value="@_text" OnInput="@(e => _text = e.Value?.ToString() ?? "")" placeholder="Write something..." />
            <Lumeo.Text Size="sm" Color="muted">Character count: @_text.Length</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Textarea placeholder="This textarea is disabled." disabled />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Label" Code="@_labelCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Label="Your Bio" HelpText="You can use markdown for formatting.">
                <Textarea placeholder="Tell us a little bit about yourself." rows="4" />
            </FormField>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Custom Rows" Code="@_rowsCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Textarea placeholder="This textarea has 6 rows." rows="6" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Auto Resize" Code="@_autoResizeCode">
        <Stack Gap="3" Class="w-full max-w-sm">
            <Textarea Placeholder="Start typing... the textarea will grow automatically" AutoResize="true" />
            <Textarea Placeholder="Limited to 5 rows max" AutoResize="true" MaxRows="5" />
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">Textarea</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The current value of the textarea.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnInput</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChangeEventArgs&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked on every keystroke as the value changes.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">AutoResize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Automatically resize based on content.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MaxRows</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">10</td>
                            <td class="p-3 text-muted-foreground">Maximum number of rows when auto-resizing.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _text = "";

    private string _defaultCode = @"<Textarea placeholder=""Type your message here."" />";

    private string _bindingCode = @"<Textarea Value=""@_text"" OnInput=""@(e => _text = e.Value?.ToString() ?? """")"" placeholder=""Write something..."" />
<Lumeo.Text Size=""sm"" Color=""muted"">Character count: @_text.Length</Lumeo.Text>

@code {
    private string _text = """";
}";

    private string _disabledCode = @"<Textarea placeholder=""This textarea is disabled."" disabled />";

    private string _labelCode = @"<FormField Label=""Your Bio"" HelpText=""You can use markdown for formatting."">
    <Textarea placeholder=""Tell us a little bit about yourself."" rows=""4"" />
</FormField>";

    private string _rowsCode = @"<Textarea placeholder=""This textarea has 6 rows."" rows=""6"" />";

    private string _autoResizeCode = @"<Textarea Placeholder=""Start typing... the textarea will grow automatically"" AutoResize=""true"" />
<Textarea Placeholder=""Limited to 5 rows max"" AutoResize=""true"" MaxRows=""5"" />";
}
