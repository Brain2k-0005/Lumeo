@namespace Lumeo

<Chart Option="@_option" Width="@Width" Height="@Height" Theme="@Theme" Class="@Class" IsLoading="@IsLoading" ShowLoadingSkeleton="@ShowLoadingSkeleton" SkeletonKind="@SkeletonKind" SkeletonStyle="@SkeletonStyle" ShowLoadingLabel="@ShowLoadingLabel" LoadingText="@LoadingText" PhantomCycleMs="@PhantomCycleMs" ChildContent="@ChildContent" @attributes="AdditionalAttributes" />

@code {
    [Parameter] public List<string> Categories { get; set; } = new();
    [Parameter] public List<ChartSeriesData> Series { get; set; } = new();
    [Parameter] public bool Smooth { get; set; }
    [Parameter] public bool ShowDots { get; set; } = true;
    [Parameter] public bool Stacked { get; set; }
    /// <summary>When true (default) the fill uses a lighter opacity than a solid area.
    /// This is the legacy opacity-only behaviour and is unaffected by
    /// <see cref="GradientFill"/>.</summary>
    [Parameter] public bool Gradient { get; set; } = true;
    /// <summary>Opt into a <em>real</em> vertical gradient fill: each series' area fades
    /// from its own (brand/theme) colour at the top to transparent at the bottom, the
    /// look used by modern dashboards. Off by default so existing charts are unchanged.
    /// Override the stops with <see cref="GradientStops"/>.</summary>
    [Parameter] public bool GradientFill { get; set; }
    /// <summary>Explicit gradient colour-stops applied to every series' area fill when
    /// set (implies <see cref="GradientFill"/>). Offsets run 0 (top) → 1 (bottom);
    /// colours accept theme tokens like <c>var(--color-primary)</c>. When null and
    /// <see cref="GradientFill"/> is true, a per-series colour → transparent fade is used.</summary>
    [Parameter] public List<EChartGradientColorStop>? GradientStops { get; set; }
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool ShowTooltip { get; set; } = true;
    [Parameter] public List<string>? Colors { get; set; }
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "350px";
    [Parameter] public string? Theme { get; set; }
    [Parameter] public string? Class { get; set; }
    /// <summary>Declarative annotation children — <see cref="ChartThreshold"/> and
    /// <see cref="ChartReferenceZone"/>. Forwarded to the underlying <see cref="Chart"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
    /// <summary>When true, overlays a shape-aware loading skeleton on top of the chart (consumer is fetching data). Flips back to the real chart once set to false.</summary>
    [Parameter] public bool IsLoading { get; set; }
    /// <summary>When true (default), renders a shape-aware skeleton while the chart has not yet mounted and whenever <see cref="IsLoading"/> is true. Set to <c>false</c> to opt out.</summary>
    [Parameter] public bool ShowLoadingSkeleton { get; set; } = true;
    /// <summary>Shape family for the loading skeleton. Defaults to <c>ChartSkeletonKind.Area</c> for this chart type; override if you want a different silhouette.</summary>
    [Parameter] public ChartSkeletonKind SkeletonKind { get; set; } = ChartSkeletonKind.Area;
    /// <summary>Phantom (default) renders the real chart with placeholder data and morphs to real data via ECharts' option-change animation. Silhouette falls back to the legacy SVG skeleton overlay.</summary>
    [Parameter] public ChartSkeletonStyle SkeletonStyle { get; set; } = ChartSkeletonStyle.Phantom;
    /// <summary>Phantom-mode refresh interval in milliseconds. Lower = faster data cycling while loading. Defaults to 1400.</summary>
    [Parameter] public int PhantomCycleMs { get; set; } = 1400;
    /// <summary>When true (default), shows a small "Loading…" pill in the top-right corner whenever <see cref="IsLoading"/> is active. Works on top of any <see cref="SkeletonStyle"/>.</summary>
    [Parameter] public bool ShowLoadingLabel { get; set; } = true;
    /// <summary>Label rendered next to the spinner inside the loading pill. Set to empty to hide. Defaults to "Loading…".</summary>
    [Parameter] public string? LoadingText { get; set; } = "Loading…";

    [Parameter] public bool ShowDataLabels { get; set; }
    [Parameter] public string LabelPosition { get; set; } = "top";
    [Parameter] public string? LabelFormat { get; set; }

    /// <summary>Controls category-axis label rendering. Smart auto-rotates at higher
    /// densities; ShowAll forces all horizontal; Auto thins overlapping labels.</summary>
    [Parameter] public ChartLabelStrategy LabelStrategy { get; set; } = ChartLabelStrategy.Smart;

    /// <summary>Manual rotation override (degrees) for category-axis labels.</summary>
    [Parameter] public int? LabelRotate { get; set; }
    [Parameter] public bool DataZoom { get; set; }
    [Parameter] public bool Toolbox { get; set; }
    [Parameter] public List<string>? ColorPalette { get; set; }
    [Parameter] public int? AnimationDuration { get; set; }
    [Parameter] public string? AnimationEasing { get; set; }
    [Parameter] public EChartMarkLine? MarkLine { get; set; }
    [Parameter] public EChartMarkPoint? MarkPoint { get; set; }
    [Parameter] public EChartMarkArea? MarkArea { get; set; }
    [Parameter] public Dictionary<string, object>? OptionOverride { get; set; }

    private EChartOption _option = new();

    protected override void OnParametersSet()
    {
        var areaOpacity = Gradient ? 0.3 : 0.7;
        var useRealGradient = GradientFill || GradientStops is { Count: > 0 };

        var seriesList = Series.Select((s, i) => new EChartSeries
        {
            Name = s.Name,
            Type = "line",
            Data = s.Values,
            Smooth = Smooth ? true : null,
            ShowSymbol = ShowDots ? null : false,
            SymbolSize = ShowDots ? 6 : null,
            Stack = Stacked ? "total" : null,
            AreaStyle = useRealGradient
                ? new EChartAreaStyle { Gradient = BuildGradient(i) }
                : new EChartAreaStyle { Opacity = areaOpacity }
        }).ToList();

        if (ShowDataLabels)
            foreach (var s in seriesList)
                s.Label = new EChartLabel { Show = true, Position = LabelPosition, Formatter = LabelFormat };

        if (seriesList.Count > 0)
        {
            if (MarkLine is not null) seriesList[0].MarkLine = MarkLine;
            if (MarkPoint is not null) seriesList[0].MarkPoint = MarkPoint;
            if (MarkArea is not null) seriesList[0].MarkArea = MarkArea;
        }

        var categoryAxis = new EChartAxis { Type = "category", Data = Categories, BoundaryGap = false };
        ChartLabelHelper.ApplyTo(categoryAxis, LabelStrategy, Categories.Count, LabelRotate);

        _option = new EChartOption
        {
            XAxis = new List<EChartAxis> { categoryAxis },
            YAxis = new List<EChartAxis>
            {
                new() { Type = "value" }
            },
            Series = seriesList,
            Grid = new EChartGrid
            {
                Left = "3%", Right = "4%",
                Top = ShowLegend ? "14%" : "5%",
                Bottom = DataZoom ? "15%" : "3%",
                ContainLabel = true
            },
            Color = ColorPalette ?? Colors
        };

        if (ShowTooltip)
            _option.Tooltip = new EChartTooltip { Trigger = "axis" };

        if (ShowLegend && Series.Count > 0)
            _option.Legend = new EChartLegend { Data = Series.Select(s => s.Name).ToList() };

        if (DataZoom)
            _option.DataZoom = new List<EChartDataZoom> { new() { Type = "slider", Show = true }, new() { Type = "inside" } };

        if (Toolbox)
            _option.Toolbox = new EChartToolbox { Show = true, Feature = new EChartToolboxFeature { SaveAsImage = new() { Show = true }, Restore = new() { Show = true }, DataZoom = new() { Show = true } } };

        if (AnimationDuration.HasValue) _option.AnimationDuration = AnimationDuration;
        if (!string.IsNullOrEmpty(AnimationEasing)) _option.AnimationEasing = AnimationEasing;

        ChartHelper.ApplyOptionOverride(_option, OptionOverride);
    }

    // Build the per-series linear-gradient fill. When GradientStops is supplied it is
    // used verbatim for every series (the single-metric brand case); otherwise each
    // series fades from its own resolved palette colour (top) to transparent (bottom).
    private EChartLinearGradient BuildGradient(int seriesIndex)
    {
        var stops = GradientStops is { Count: > 0 } custom
            ? custom
            : new List<EChartGradientColorStop>
            {
                new(0, SeriesColorAt(seriesIndex)),
                new(1, "transparent"),
            };
        return new EChartLinearGradient { ColorStops = stops };
    }

    // Resolve the colour ECharts assigns to a series by index: an explicit palette
    // entry when provided, else the theme chart-N token (var(--color-chart-1..5)),
    // which the chart interop resolves to a concrete colour at render time. Keeping
    // this in lock-step with the line colour makes the gradient read as a brand fade.
    private string SeriesColorAt(int seriesIndex)
    {
        var palette = ColorPalette ?? Colors;
        if (palette is { Count: > 0 })
            return palette[seriesIndex % palette.Count];
        return $"var(--color-chart-{(seriesIndex % 5) + 1})";
    }

    public class ChartSeriesData
    {
        public string Name { get; set; } = "";
        public List<double> Values { get; set; } = new();
    }
}
