                            <td class="p-3 text-muted-foreground">Get rect by CSS selector.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">GetElementDimension(elementId, dimension)</td>
                            <td class="p-3 text-xs text-muted-foreground">Measure</td>
                            <td class="p-3 text-muted-foreground">Get a single dimension value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CopyToClipboard(text)</td>
