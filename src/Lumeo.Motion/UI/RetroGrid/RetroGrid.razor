@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    <div class="lumeo-retro-grid-scene" style="--lumeo-grid-angle:@(Angle)deg; --lumeo-grid-cell:@(CellSize)px; --lumeo-grid-color:@GridColor; --lumeo-grid-opacity:@(Opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture));">
        <div class="lumeo-retro-grid-floor"></div>
    </div>
    @if (ChildContent != null)
    {
        <div class="lumeo-retro-grid-content">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Perspective angle (degrees). Default 65.</summary>
    [Parameter] public int Angle { get; set; } = 65;
    /// <summary>Size of each grid cell in pixels.</summary>
    [Parameter] public int CellSize { get; set; } = 60;
    /// <summary>Grid line color. Defaults to theme foreground at low opacity.</summary>
    [Parameter] public string GridColor { get; set; } = "var(--color-foreground)";
    /// <summary>Grid line opacity 0–1.</summary>
    [Parameter] public double Opacity { get; set; } = 0.2;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[] { "lumeo-retro-grid", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));
}
