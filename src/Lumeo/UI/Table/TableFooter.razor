@namespace Lumeo

<tfoot class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</tfoot>

@code {
    /// <summary>The footer rows, typically summary/total <see cref="TableRow"/>s.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>&lt;tfoot&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the <c>&lt;tfoot&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // Mirrors shadcn's TableFooter: a top border, muted fill and medium weight
    // for summary / totals rows, with the last row's bottom border removed so
    // it sits flush against the table edge.
    private string CssClass => Cx.Merge("border-t border-border/40 bg-muted/50 font-medium [&>tr]:last:border-b-0", Class);
}
