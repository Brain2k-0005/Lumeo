@namespace Lumeo

@if (Context.ActiveItemId is not null)
{
    <div class="@CssClass" @attributes="AdditionalAttributes">
        <div class="relative top-[60%] h-2 w-2 rotate-45 rounded-ss-sm bg-border shadow-md"></div>
    </div>
}

@code {
    [CascadingParameter] public NavigationMenu.NavigationMenuContext Context { get; set; } = default!;
    /// <summary>Reserved for a custom indicator visual; currently unused (the default arrow caret always renders).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the root element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("absolute bottom-0 z-[1] flex h-1.5 items-end justify-center overflow-hidden", Class);
}
