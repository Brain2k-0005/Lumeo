@page "/components/reasoning-display"

<PageTitle>ReasoningDisplay — Lumeo</PageTitle>

<PageHeader Title="ReasoningDisplay" Description="Collapsible chain-of-thought block for AI reasoning traces." />

<InstallUsage Component="ReasoningDisplay" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Display reasoning traces from chain-of-thought models (e.g. Claude's extended thinking mode).</li>
        <li>Show an intermediate thinking step collapsed by default to avoid cluttering the chat UI.</li>
        <li>Use <code class="text-xs bg-muted px-1 py-0.5 rounded">IsStreaming</code> to animate while tokens are arriving, then set it to false when the trace is complete.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <Container MaxWidth="lg" Center="false">
            <div class="w-full max-w-xl h-[200px] overflow-y-auto pr-1">
                <ReasoningDisplay Text="@_reasoningText" Summary="Reasoning" />
            </div>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Duration" Code="@_durationCode">
        <Container MaxWidth="lg" Center="false">
            <div class="w-full max-w-xl h-[200px] overflow-y-auto pr-1">
                <ReasoningDisplay Text="@_reasoningText" DurationMs="4200" />
            </div>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Streaming State" Code="@_streamingCode">
        <Container MaxWidth="lg" Center="false">
            <div class="w-full max-w-xl h-[280px] overflow-y-auto pr-1">
                <ReasoningDisplay Text="@_partialReasoning" IsStreaming="@_isStreaming" DefaultOpen="true" />
                <Flex Gap="2" Class="mt-3">
                    <Button Size="Button.ButtonSize.Sm" OnClick="@StartStream" Disabled="@_isStreaming">Start Streaming</Button>
                    <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="@StopStream">Stop</Button>
                </Flex>
            </div>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Open by Default" Code="@_openCode">
        <Container MaxWidth="lg" Center="false">
            <div class="w-full max-w-xl h-[200px] overflow-y-auto pr-1">
                <ReasoningDisplay Text="@_reasoningText" DefaultOpen="true" Summary="Chain of thought" />
            </div>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Markdown Rendering">
        <Container MaxWidth="lg" Center="false">
            <div class="w-full max-w-xl h-[200px] overflow-y-auto pr-1">
                <ReasoningDisplay Text="@_markdownReasoning" Markdown="true" DefaultOpen="true" Summary="Reasoning (markdown)" />
            </div>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Variant (interactive)" Code="@_variantInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch variant to compare Default, Compact, and Detailed layouts.</Lumeo.Text>
            <Segmented @bind-Value="_rdVariant">
                <SegmentedItem Value="Default">Default</SegmentedItem>
                <SegmentedItem Value="Compact">Compact</SegmentedItem>
                <SegmentedItem Value="Detailed">Detailed</SegmentedItem>
            </Segmented>
            <Container MaxWidth="lg" Center="false">
                <div class="w-full max-w-xl h-[220px] overflow-y-auto pr-1">
                    <ReasoningDisplay Text="@_reasoningText" Variant="@_rdVariantEnum" DurationMs="2800" DefaultOpen="true" />
                </div>
            </Container>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Size (interactive)" Code="@_sizeInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch size to compare Small, Medium, and Large text scaling.</Lumeo.Text>
            <Segmented @bind-Value="_rdSize">
                <SegmentedItem Value="Small">Small</SegmentedItem>
                <SegmentedItem Value="Medium">Medium</SegmentedItem>
                <SegmentedItem Value="Large">Large</SegmentedItem>
            </Segmented>
            <Container MaxWidth="lg" Center="false">
                <div class="w-full max-w-xl h-[240px] overflow-y-auto pr-1">
                    <ReasoningDisplay Text="@_reasoningText" Size="@_rdSizeEnum" DefaultOpen="true" />
                </div>
            </Container>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">ReasoningDisplay</Heading>
            <PropsTable Slug="reasoning-display" />
            <Lumeo.Text Size="sm" Color="muted" Class="mt-3"><code class="text-xs">Variant</code>: <code class="text-xs">Default</code> renders the full block, <code class="text-xs">Compact</code> condenses the height, and <code class="text-xs">Detailed</code> expands with extra meta.</Lumeo.Text>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/streaming-text" class="text-primary hover:underline">StreamingText</a> — Token-by-token streaming text renderer for AI responses.</li>
        <li><a href="/components/tool-call-card" class="text-primary hover:underline">ToolCallCard</a> — AI tool-invocation card showing call and result.</li>
    </ul>
</div>

@code {
    private string _rdVariant = "Default";
    private ReasoningDisplay.ReasoningVariant _rdVariantEnum =>
        Enum.TryParse<ReasoningDisplay.ReasoningVariant>(_rdVariant, out var v) ? v : ReasoningDisplay.ReasoningVariant.Default;
    private string _rdSize = "Medium";
    private Lumeo.Size _rdSizeEnum =>
        Enum.TryParse<Lumeo.Size>(_rdSize, out var v) ? v : Lumeo.Size.Md;

    private const string _reasoningText =
        "First, I need to consider the user's question carefully. " +
        "The problem involves finding the optimal path through a weighted graph. " +
        "I should apply Dijkstra's algorithm here, starting from the source node. " +
        "Let me trace through the steps: initialize distances to infinity, process nodes by priority queue...\n\n" +
        "After analyzing all edges, the shortest path from A to D is A → B → C → D with total weight 7.";

    private const string _markdownReasoning =
        "Let me **break this down** into steps:\n\n" +
        "1. Parse the input graph\n" +
        "2. Run `Dijkstra` from the source\n" +
        "3. Return the shortest path\n\n" +
        "The result is `A → B → C → D` with total weight **7**.";

    private string _partialReasoning = "Analyzing the request...";
    private bool _isStreaming;
    private System.Threading.CancellationTokenSource? _cts;

    private async Task StartStream()
    {
        _cts?.Cancel();
        _cts = new System.Threading.CancellationTokenSource();
        _isStreaming = true;
        _partialReasoning = string.Empty;
        var words = _reasoningText.Split(' ');
        foreach (var word in words)
        {
            if (_cts.Token.IsCancellationRequested) break;
            _partialReasoning += word + " ";
            StateHasChanged();
            await Task.Delay(60);
        }
        _isStreaming = false;
    }

    private void StopStream()
    {
        _cts?.Cancel();
        _isStreaming = false;
    }

    private string _basicCode = @"<ReasoningDisplay Text=""@_reasoningText"" Summary=""Reasoning"" />";

    private string _durationCode = @"<ReasoningDisplay Text=""@_reasoningText"" DurationMs=""4200"" />";

    private string _streamingCode = @"<ReasoningDisplay Text=""@_partialText"" IsStreaming=""@_streaming"" DefaultOpen=""true"" />

@code {
    private string _partialText = string.Empty;
    private bool _streaming;
}";

    private string _openCode = @"<ReasoningDisplay Text=""@_reasoningText"" DefaultOpen=""true"" Summary=""Chain of thought"" />";

    private string _variantInteractiveCode = @"<Segmented @bind-Value=""_variant"">
    <SegmentedItem Value=""@ReasoningDisplay.ReasoningVariant.Default"">Default</SegmentedItem>
    <SegmentedItem Value=""@ReasoningDisplay.ReasoningVariant.Compact"">Compact</SegmentedItem>
    <SegmentedItem Value=""@ReasoningDisplay.ReasoningVariant.Detailed"">Detailed</SegmentedItem>
</Segmented>
<ReasoningDisplay Text=""@_text"" Variant=""@_variant"" DurationMs=""2800"" DefaultOpen=""true"" />

@code { private ReasoningDisplay.ReasoningVariant _variant = ReasoningDisplay.ReasoningVariant.Default; }";

    private string _sizeInteractiveCode = @"<Segmented @bind-Value=""_size"">
    <SegmentedItem Value=""@Lumeo.Size.Sm"">Small</SegmentedItem>
    <SegmentedItem Value=""@Lumeo.Size.Md"">Medium</SegmentedItem>
    <SegmentedItem Value=""@Lumeo.Size.Lg"">Large</SegmentedItem>
</Segmented>
<ReasoningDisplay Text=""@_text"" Size=""@_size"" DefaultOpen=""true"" />

@code { private Lumeo.Size _size = Lumeo.Size.Md; }";
}
