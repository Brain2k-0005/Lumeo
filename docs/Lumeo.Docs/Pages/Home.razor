@page "/"
@using Lumeo.Services
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Lumeo - The Blazor component library you would actually want to ship</PageTitle>

@* Off-screen animation pause: PauseWhenHidden toggles this class on decorative
   clusters (marquee, sparkles, border-beam, shimmer) when they scroll out of
   view, so their perpetual CSS keyframes stop waking the compositor. Paused
   animations resume from where they stopped — no visual jump. *@
<style>
    .lumeo-motion-paused,
    .lumeo-motion-paused *,
    .lumeo-motion-paused::before,
    .lumeo-motion-paused::after,
    .lumeo-motion-paused *::before,
    .lumeo-motion-paused *::after { animation-play-state: paused !important; }

    /* Reduced motion: the perpetual CSS primitives (Marquee, Sparkles, BorderBeam,
       Shimmer) are already stopped in lumeo.css; also freeze the small looping
       "live" status pulses so these users get a genuinely still page. */
    @@media (prefers-reduced-motion: reduce) {
        .animate-pulse { animation: none !important; }
    }
</style>

<!-- ======================= LIVE ADMIN-APP ======================= -->
<section class="relative min-h-screen overflow-hidden border-b border-border/40">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,#000_60%,transparent_110%)] pointer-events-none opacity-30"></div>

    <Container MaxWidth="[1400px]" Class="relative px-4 pt-8 pb-6">

        <!-- Announcement ribbon (single slim line) -->
        <BlurFade DelayMs="0">
            <Flex Justify="center" Class="mb-6">
                <Lumeo.Link Href="docs/changelog" Class="no-underline group">
                    <Flex Inline="true" Align="center" Gap="2" Class="whitespace-nowrap rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                        <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">v4.1</Badge>
                        <Lumeo.Text As="span" Class="hidden sm:inline">First-party icon system: 16 trimmable packs, 51,000+ icons, live-switchable</Lumeo.Text>
                        <Lumeo.Text As="span" Class="sm:hidden">New: first-party icon system</Lumeo.Text>
                        <DynamicIcon Name="ArrowRight" Class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                    </Flex>
                </Lumeo.Link>
            </Flex>
        </BlurFade>

        <!-- Category hero -->
        <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-12">
            <BlurFade DelayMs="40">
                <Flex Align="center" Gap="2" Class="w-fit mx-auto rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm">
                    <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
                    The Blazor UI platform you fully control
                </Flex>
            </BlurFade>
            <BlurFade DelayMs="90">
                <Heading Level="1" Class="mt-6 text-4xl sm:text-5xl md:text-6xl font-bold tracking-[-0.02em] leading-[1.05] text-foreground">
                    Own your Blazor UI.
                </Heading>
            </BlurFade>
            <BlurFade DelayMs="140">
                <Lumeo.Text Color="muted" Class="mt-4 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed">
                    Modern components, blocks, motion and production-ready data surfaces &mdash; with CLI vendoring, MCP for your agents, and a NuGet-free standalone eject. Ship fast without giving up control of design or source.
                </Lumeo.Text>
            </BlurFade>
            <BlurFade DelayMs="190">
                <Flex Wrap="true" Justify="center" Align="center" Gap="2" Class="mt-6">
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">164</span> components</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">24</span> blocks</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">16</span> icon packs</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">~627 KB</span> core</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">MIT</span></span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">5,331</span> tests</span>
                </Flex>
            </BlurFade>
            <BlurFade DelayMs="240">
                <Flex Wrap="true" Justify="center" Align="center" Gap="3" Class="mt-8">
                    <Lumeo.Link Href="docs/introduction" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Lg" Class="rounded-lg">
                            Get Started
                            <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="docs/guides/vendor-a-component" Class="inline-flex h-10 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background/80 backdrop-blur-sm px-6 text-sm font-semibold text-foreground hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <DynamicIcon Name="FolderGit2" Class="h-4 w-4" />
                        Own the source
                    </Lumeo.Link>
                </Flex>
            </BlurFade>
        </div>

        @* Below-hero blocks are NOT wrapped in scroll-reveal BlurFade: this docs layout
           scrolls inside a container (window scroll is a no-op), so an IntersectionObserver
           reveal can leave sections blank on a fast scroll. They paint immediately instead. *@

        <!-- Live-demo transition caption -->
        <Flex Align="center" Justify="center" Gap="2" Class="mb-4">
            <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
            <Lumeo.Text Size="xs" Color="muted">Live proof &mdash; this entire admin app is Lumeo. Interact with it, or open the full demo apps: <Lumeo.Link Href="demos/saas" Class="text-primary hover:underline">Northlight</Lumeo.Link> &middot; <Lumeo.Link Href="demos/enterprise" Class="text-primary hover:underline">Meridian Ops</Lumeo.Link> &middot; <Lumeo.Link Href="showcase" Class="text-primary hover:underline">Showcase</Lumeo.Link></Lumeo.Text>
        </Flex>

        <!-- KPI strip -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
            <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                <Flex Align="center" Justify="between" Class="mb-1">
                    <Lumeo.Text Size="xs" Color="muted">Revenue</Lumeo.Text>
                    <DynamicIcon Name="DollarSign" Class="h-3.5 w-3.5 text-primary" />
                </Flex>
                <div class="text-2xl font-bold tracking-tight text-foreground">
                    $<NumberTicker Value="1214" DurationMs="1600" />K
                </div>
                <Flex Align="center" Gap="1" Class="mt-1">
                    <DynamicIcon Name="TrendingUp" Class="h-3 w-3 text-primary" />
                    <Lumeo.Text Size="xs" Color="muted">+12.4% vs last Q</Lumeo.Text>
                </Flex>
            </div>
            <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                <Flex Align="center" Justify="between" Class="mb-1">
                    <Lumeo.Text Size="xs" Color="muted">Active users</Lumeo.Text>
                    <DynamicIcon Name="Users" Class="h-3.5 w-3.5 text-primary" />
                </Flex>
                <div class="text-2xl font-bold tracking-tight text-foreground">
                    <NumberTicker Value="8421" DurationMs="1800" />
                </div>
                <Flex Align="center" Gap="1" Class="mt-1">
                    <DynamicIcon Name="TrendingUp" Class="h-3 w-3 text-primary" />
                    <Lumeo.Text Size="xs" Color="muted">+841 this week</Lumeo.Text>
                </Flex>
            </div>
            <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                <Flex Align="center" Justify="between" Class="mb-1">
                    <Lumeo.Text Size="xs" Color="muted">Conversion</Lumeo.Text>
                    <DynamicIcon Name="Percent" Class="h-3.5 w-3.5 text-primary" />
                </Flex>
                <div class="text-2xl font-bold tracking-tight text-foreground">
                    <NumberTicker Value="12" DurationMs="1400" />.<NumberTicker Value="4" DurationMs="1400" />%
                </div>
                <Flex Align="center" Gap="1" Class="mt-1">
                    <DynamicIcon Name="TrendingDown" Class="h-3 w-3 text-muted-foreground" />
                    <Lumeo.Text Size="xs" Color="muted">-0.3% vs last Q</Lumeo.Text>
                </Flex>
            </div>
            <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                <Flex Align="center" Justify="between" Class="mb-1">
                    <Lumeo.Text Size="xs" Color="muted">Open tickets</Lumeo.Text>
                    <DynamicIcon Name="Ticket" Class="h-3.5 w-3.5 text-primary" />
                </Flex>
                <div class="text-2xl font-bold tracking-tight text-foreground">
                    <NumberTicker Value="47" DurationMs="1200" />
                </div>
                <Flex Align="center" Gap="1" Class="mt-1">
                    <DynamicIcon Name="Clock" Class="h-3 w-3 text-muted-foreground" />
                    <Lumeo.Text Size="xs" Color="muted">6 critical priority</Lumeo.Text>
                </Flex>
            </div>
        </div>
        <!-- Chart (60%) + Map (40%, desktop-only to keep the phone page short) -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-4">

            <div @ref="_chartCard" class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden"
                 @onmouseenter="@(() => _chartHovered = true)" @onmouseleave="@(() => _chartHovered = false)">
                <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                    <Stack Gap="0">
                        <Lumeo.Text Size="sm" Weight="semibold">Revenue by package</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted">Quarterly, last 6 periods</Lumeo.Text>
                    </Stack>
                    <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-5">
                        <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary mr-1 animate-pulse"></span>
                        Live
                    </Badge>
                </Flex>
                <div class="h-56 sm:h-64 lg:h-80 px-2 pb-3">
                    @* LazyRender gates ECharts' fetch + init behind the viewport: a cheap CSS
                       stacked-bar placeholder (built from the same data, so it matches the real
                       chart's shape) shows immediately, and the live BarChart — plus the ~334 KB
                       ECharts payload — only mounts when the card scrolls near view. On phones the
                       card is far below the fold, so ECharts never loads on first paint, cutting
                       TBT and transfer size. *@
                    <LazyRender Height="100%" RootMarginPx="150">
                        <Placeholder>
                            <div class="flex h-full items-end gap-1.5 sm:gap-2" aria-hidden="true">
                                @for (var i = 0; i < _barCategories.Count; i++)
                                {
                                    var total = _barSeries.Sum(s => s.Values[i]);
                                    var barPct = _chartMaxTotal > 0 ? total / _chartMaxTotal * 100 : 0;
                                    <div class="flex-1 flex flex-col-reverse rounded-t-sm overflow-hidden"
                                         style="height:@barPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%">
                                        @for (var s = 0; s < _barSeries.Count; s++)
                                        {
                                            var segPct = total > 0 ? _barSeries[s].Values[i] / total * 100 : 0;
                                            var op = (0.85 - s * 0.28).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);
                                            <div style="height:@segPct.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)%;background:hsl(var(--primary) / @op)"></div>
                                        }
                                    </div>
                                }
                            </div>
                        </Placeholder>
                        <ChildContent>
                            <BarChart Categories="_barCategories" Series="_barSeries" Stacked="true" Height="100%" ShowLoadingSkeleton="false" />
                        </ChildContent>
                    </LazyRender>
                </div>
            </div>

            <div class="hidden lg:block rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                    <Stack Gap="0">
                        <Lumeo.Text Size="sm" Weight="semibold">Global reach</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted">5 cities, animated arcs</Lumeo.Text>
                    </Stack>
                    <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-5">MapLibre</Badge>
                </Flex>
                <div class="h-56 sm:h-64 lg:h-80 overflow-hidden">
                    <LazyRender Height="100%">
                        <Map @bind-Center="_mapCenter" @bind-Zoom="_mapZoom" Height="100%" TileLayer="DarkMatter" Projection="globe">
                            <ChildContent>
                                <MapMarker Lat="51.5074"  Lon="-0.1278"   Title="London"    Variant="Dot" Color="teal" Label="London" />
                                <MapMarker Lat="40.7128"  Lon="-74.0060"  Title="New York"  Variant="Dot" Color="teal" Label="New York" />
                                <MapMarker Lat="35.6762"  Lon="139.6503"  Title="Tokyo"     Variant="Dot" Color="teal" Label="Tokyo" />
                                <MapMarker Lat="-33.8688" Lon="151.2093"  Title="Sydney"    Variant="Dot" Color="teal" Label="Sydney" />
                                <MapMarker Lat="-23.5505" Lon="-46.6333"  Title="Sao Paulo" Variant="Dot" Color="teal" Label="Sao Paulo" />
                                <MapArc From="(51.5074, -0.1278)"  To="(40.7128, -74.0060)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                <MapArc From="(51.5074, -0.1278)"  To="(35.6762, 139.6503)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                <MapArc From="(40.7128, -74.0060)" To="(-23.5505, -46.6333)" Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                            </ChildContent>
                        </Map>
                    </LazyRender>
                </div>
            </div>
        </div>

        <!-- DataGrid + Kanban -->
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-3">

            <div class="lg:col-span-3 rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                    <Stack Gap="0">
                        <Lumeo.Text Size="sm" Weight="semibold">Team roster</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted">Grouped by department, salary aggregated</Lumeo.Text>
                    </Stack>
                    <Lumeo.Link Href="components/data-grid" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Flex>
                <div class="px-3 pb-3">
                    @* RootMarginPx=0 so we only mount when the placeholder actually enters the viewport.
                       The default 200px margin would mount during prerender (1280x800) because this block
                       sits ~100px below the fold on the home layout — defeating the TBT deferral. *@
                    <LazyRender Height="420px" RootMarginPx="0">
                        <DataGrid TItem="Employee" Items="@_employees" PageSize="10" ShowPagination="false"
                                  GroupBy="Department" GroupsExpandedByDefault="true">
                            @* Grouping binds to a column's Field — without a Department
                               column the grid rendered flat (and 3.13+ logs a console
                               warning) while the caption claimed otherwise. *@
                            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
                            <DataGridColumnDef TItem="Employee" Title="Name"   Field="Name"   Sortable="true" />
                            <DataGridColumnDef TItem="Employee" Title="Role"   Field="Role" />
                            @* Explicit "$#,##0" instead of the "C0" standard specifier: C0 uses
                               CurrentCulture's currency symbol, which on the invariant docs culture
                               renders the generic "¤" glyph. A literal $ with a #,##0 pattern is
                               culture-invariant and matches the $ revenue KPI above. *@
                            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="$#,##0" Sortable="true" Aggregate="AggregateType.Sum" />
                        </DataGrid>
                    </LazyRender>
                </div>
            </div>

            <div class="lg:col-span-2 rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                    <Stack Gap="0">
                        <Lumeo.Text Size="sm" Weight="semibold">Sprint board</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted">Drag cards between columns</Lumeo.Text>
                    </Stack>
                    <Lumeo.Link Href="components/kanban" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Flex>
                <div class="px-3 pb-3 overflow-x-auto">
                    @* 200px matches the actual rendered Kanban: 3 columns (min-h-[130px]) + the row header
                       with a few compact cards. On lg the row height is driven by the taller DataGrid cell
                       in the same grid row, so the lower placeholder doesn't shorten the row.
                       RootMarginPx=0 keeps it deferred during prerender — see DataGrid note above. *@
                    <LazyRender Height="200px" RootMarginPx="0">
                        <Kanban Class="!p-0 !gap-2 min-w-[360px]">
                        <KanbanColumn Title="To do" Badge="@_kanbanTodo.Count"
                                      Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                      OnDrop="@(_ => MoveDraggingCard(_kanbanTodo))">
                            @foreach (var card in _kanbanTodo)
                            {
                                <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                    <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                Class="rounded-md border border-border/40 bg-card p-2 cursor-grab active:cursor-grabbing hover:border-primary/40 transition-colors" />
                                </div>
                            }
                        </KanbanColumn>
                        <KanbanColumn Title="Doing" Badge="@_kanbanDoing.Count"
                                      Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                      OnDrop="@(_ => MoveDraggingCard(_kanbanDoing))">
                            @foreach (var card in _kanbanDoing)
                            {
                                <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                    <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                Class="rounded-md border border-primary/40 bg-card p-2 ring-1 ring-primary/20 cursor-grab active:cursor-grabbing transition-colors" />
                                </div>
                            }
                        </KanbanColumn>
                        <KanbanColumn Title="Done" Badge="@_kanbanDone.Count"
                                      Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                      OnDrop="@(_ => MoveDraggingCard(_kanbanDone))">
                            @foreach (var card in _kanbanDone)
                            {
                                <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                    <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                Class="rounded-md border border-border/40 bg-card/60 p-2 opacity-70 cursor-grab active:cursor-grabbing transition-colors" />
                                </div>
                            }
                        </KanbanColumn>
                    </Kanban>
                    </LazyRender>
                </div>
            </div>
        </div>

        <!-- Attribution -->
        <Flex Align="center" Justify="center" Gap="3" Class="mt-5 pt-4 border-t border-border/30">
            <div class="flex items-center gap-1.5">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
                <Lumeo.Text Size="xs" Color="muted">Live data on a timer, real drag-and-drop, virtualized grid &mdash; every pixel MIT licensed.</Lumeo.Text>
            </div>
            <Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                View source <DynamicIcon Name="ExternalLink" Class="h-3 w-3" />
            </Lumeo.Link>
        </Flex>

    </Container>
</section>

<!-- ======================= BROWSE ALL (slim band, replaces constellation) ======================= -->
<section class="border-b border-border/40 bg-muted/[0.03]">
    <Container MaxWidth="[1400px]" Class="px-4 py-6">
        <Flex Align="center" Justify="between" Wrap="true" Gap="4">
            <Flex Align="center" Gap="3" Wrap="true">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="shrink-0">164 components</Badge>
                <Lumeo.Text Size="sm" Color="muted">Every primitive in one place &mdash; 13 categories, from Forms and Overlays to Data surfaces and AI.</Lumeo.Text>
            </Flex>
            <Lumeo.Link Href="components" Class="inline-flex h-9 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background px-4 text-sm font-semibold text-foreground hover:bg-accent hover:text-accent-foreground transition-colors no-underline shrink-0">
                <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                Browse all components
                <DynamicIcon Name="ArrowRight" Class="h-3.5 w-3.5" />
            </Lumeo.Link>
        </Flex>
    </Container>
</section>

<!-- ======================= SIZE / STATS BAND ======================= -->
<section class="py-16">
    <Container MaxWidth="[1400px]" Class="px-4">
        <Stack Gap="3" Class="text-center mb-10">
            <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Bundle size</Badge>
            <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">A fraction of the size.</Heading>
            <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                Brotli-compressed assembly size &mdash; what an end user's browser actually downloads from your published app.
            </Lumeo.Text>
        </Stack>

        <div class="grid gap-4 lg:grid-cols-3">
            <BentoTile Class="lg:col-span-2 border-border/60 p-6">
                <Stack Gap="5">
                    <Stack Gap="1">
                        <Heading Level="3" Class="text-2xl font-semibold tracking-tight">
                            164 components across 7 packages. <Lumeo.Text As="span" Class="text-primary">~627 KB core</Lumeo.Text>.
                        </Heading>
                        <Lumeo.Text Size="sm" Color="muted">Per-package breakdown &mdash; install only the satellites you use.</Lumeo.Text>
                    </Stack>

                    <Stack Gap="4">
                        @foreach (var row in _sizeRows)
                        {
                            <Stack Gap="1.5">
                                <Flex Align="center" Justify="between" Class="text-sm">
                                    <Flex Align="center" Gap="2">
                                        <span class="h-2 w-2 rounded-full @(row.IsCore ? "bg-primary" : "bg-primary/50")"></span>
                                        <Lumeo.Text As="span" Weight="@(row.IsCore ? "semibold" : "medium")" Color="foreground">@row.Name</Lumeo.Text>
                                        <span class="text-border select-none" aria-hidden="true">&middot;</span>
                                        <Lumeo.Text As="span" Size="xs" Color="muted">@row.Components</Lumeo.Text>
                                    </Flex>
                                    <Lumeo.Text As="span" Size="xs" Class="@(row.IsCore ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground")">@row.Size</Lumeo.Text>
                                </Flex>
                                <div class="relative h-2 rounded-md bg-muted/40 overflow-hidden">
                                    <div class="@(row.IsCore ? "bg-primary" : "bg-primary/50") h-full rounded-md transition-all"
                                         style="width: @(row.Percent)%;"></div>
                                </div>
                            </Stack>
                        }
                    </Stack>

