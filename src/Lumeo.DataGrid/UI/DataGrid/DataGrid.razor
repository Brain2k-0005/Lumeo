        _dragState = new DataGridDragState(_gridInstanceId);
    }

    // --- ToolbarContent component registration ---

    /// <summary>
    /// The <see cref="ToolbarContent{TItem}"/> component currently registered inside
    /// this grid (at most one). Forwarded to <c>DataGridToolbar</c> so it can
    /// render the custom ChildContent + Class in the toolbar's left-hand slot.
    /// </summary>
    internal ToolbarContent<TItem>? RegisteredToolbarContent { get; private set; }

    internal void RegisterToolbarContent(ToolbarContent<TItem> tc)
    {
        // Re-registration from the child's OnParametersSet happens on every render;
        // only flag a re-render when the instance actually changed, otherwise we'd
        // loop (StateHasChanged → child re-renders → re-registers → StateHasChanged).
        // Class/ChildContent updates on the SAME instance are already read by the
        // next natural parent render (we dereference them at render time).
        if (!ReferenceEquals(RegisteredToolbarContent, tc))
        {
            RegisteredToolbarContent = tc;
            InvokeAsync(StateHasChanged);
        }
    }

    internal void UnregisterToolbarContent(ToolbarContent<TItem> tc)
    {
        if (RegisteredToolbarContent == tc)
        {
            RegisteredToolbarContent = null;
            InvokeAsync(StateHasChanged);
        }
    }

    private List<DataGridColumn<TItem>> SourceColumns =>
        Columns is not null && Columns.Count > 0 ? Columns : _columnDefs;

    private List<DataGridColumn<TItem>> EffectiveColumns =>
        _orderedColumns.Count > 0 ? _orderedColumns : SourceColumns;

    private int EffectiveTotalCount => ServerMode ? TotalCount : _processedItems.Count;

    // Row virtualization is incompatible with the recursive group-tree / tree-grid
    // renderers (they need every group/parent row present to compute indentation
    // and expand state), so it's disabled when those modes are active.
    private bool UseVirtualization =>
        _displayedItems.Count > VirtualizeThreshold
        && !IsTreeGridMode
        && EffectiveGroupFields.Count <= 1;

    // The unified pointer-based row-reorder engine assumes a flat DOM: tr[data-row-index]
    // indices measured at drag-start must equal _displayedItems indices 1:1, and every
    // reorderable row must be present in the DOM to live-shift. Grouped (single or
    // multi-level) and tree-grid rows restart their local index per section/parent, and
    // virtualized rows aren't all mounted — either would desync the drag from
    // _displayedItems or make live-shift reach into rows that don't exist in the DOM.
    // Those modes keep RowReorderable's drag handle visible (DataGridRow) but inert: the
    // JS pointer listener is never registered for the grid (see OnAfterRenderAsync below),
    // so the handle grip has no [data-row-reorder-grip] behaviour wired to it there.
    private bool RowReorderPointerActive =>
        RowReorderable
        && !IsTreeGridMode
        && EffectiveGroupFields.Count == 0
        && !UseVirtualization
        && !_useServerVirtualization;

    private string? HeightStyle => Height is not null ? $"height: {Height};" : null;

    private string RootCssClass
    {
        get
        {
            return string.Join(" ", new[]
            {
                "w-full overflow-hidden border border-border/40 rounded-lg bg-card text-card-foreground flex flex-col",
                Compact ? "text-sm" : null,
                Bordered ? "[&_td]:border [&_td]:border-border/40 [&_th]:border [&_th]:border-border/40" : null,
                Striped ? "[&_tbody>tr:nth-child(even)]:bg-muted/30" : null,
                Class
            }.Where(s => !string.IsNullOrWhiteSpace(s)));
        }
    }

    /// <summary>
    /// Registers a column definition with the grid. Idempotent: if a column with
    /// the same stable key (Field when available, else Id) is already registered
    /// the existing entry is replaced in-place. This matters because Blazor can
    /// re-initialize <see cref="DataGridColumnDef{TItem}"/> children on every
    /// parent render when the ChildContent is captured inside a RenderFragment
    /// local — without this dedup the column list would accumulate duplicates
    /// (causing the filter popover to open N times, the "Toggle Columns" menu
    /// to list every column N times, etc.).
    /// </summary>
    public void AddColumnDef(DataGridColumn<TItem> column)
    {
        var key = ColumnKey(column);
        var existingIndex = _columnDefs.FindIndex(c => ColumnKey(c) == key);
        if (existingIndex >= 0)
        {
            // Preserve user-mutable state on the existing column object so a
            // re-init from the razor child doesn't blow away width/visibility/pin.
            var existing = _columnDefs[existingIndex];
            existing.Title = column.Title;
            existing.Field = column.Field;
            existing.FieldSelector = column.FieldSelector;
            existing.Sortable = column.Sortable;
            existing.Filterable = column.Filterable;
            existing.Resizable = column.Resizable;
            existing.FilterType = column.FilterType;
            existing.Aggregate = column.Aggregate;
            existing.Format = column.Format;
            existing.FooterFormat = column.FooterFormat;
            existing.ColumnGroupId = column.ColumnGroupId;
            existing.CellTemplate = column.CellTemplate;
            existing.HeaderTemplate = column.HeaderTemplate;
            existing.EditTemplate = column.EditTemplate;
            existing.FilterOptions = column.FilterOptions;
            existing.Operators = column.Operators;
            existing.FilterTemplate = column.FilterTemplate;
            existing.MinWidth = column.MinWidth;
            existing.MaxWidth = column.MaxWidth;
            existing.Pinnable = column.Pinnable;
            existing.Groupable = column.Groupable;
            existing.Reorderable = column.Reorderable;
            existing.CellClass = column.CellClass;
            existing.HeaderCssClass = column.HeaderCssClass;
            existing.CustomSort = column.CustomSort;
            existing.CssClass = column.CssClass;
            // Keep the two-way @bind-Visible callback fresh on the live column so a
            // re-declared column def still routes user toggles back to the consumer.
            existing.VisibleChanged = column.VisibleChanged;
            // Only apply width/pin from the redeclared column if the user has
            // not customised them at runtime (e.g. via resize/toggle).
            if (!existing.Visible && column.Visible) { /* keep user hidden */ }
            return;
        }

        _columnDefs.Add(column);
        SyncOrderedColumns();
        // If the parameter seed ran before this column existed and dropped a
        // requested group field because of it, re-seed now that the column is
        // here and rebuild the row set so GroupBy/GroupByFields take effect
        // for declarative columns. Guarded by _groupSeedIncomplete so runtime
        // group-panel edits are never stomped by late column registrations.
        if (_groupSeedIncomplete && column.Field is not null
            && (GroupBy == column.Field || GroupByFields?.Contains(column.Field) == true))
        {
            _seededGroupBy = null;
            _seededGroupByFieldsKey = null;
            SyncGroupFieldsFromParameters();
            if (ServerMode) RegroupServerItems();
            else ProcessClientData();
        }
        // DataGridColumnDef children register themselves from their own
        // OnInitialized, which runs AFTER the parent has already built its
        // render tree with an empty column list. Without this nudge the
        // header + body render blank until some other state change retriggers
        // a render. InvokeAsync defers the re-render to the next dispatcher
        // cycle so we don't recurse during the child's init.
        _ = InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Removes a previously-registered column definition (called when a
    /// <see cref="DataGridColumnDef{TItem}"/> child is disposed).
    /// </summary>
    public void RemoveColumnDef(DataGridColumn<TItem> column)
    {
        var key = ColumnKey(column);
        var removed = _columnDefs.RemoveAll(c => ColumnKey(c) == key) > 0;
        if (removed)
        {
            _orderedColumns.RemoveAll(c => ColumnKey(c) == key);
            RefreshVisibleColumns();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    // --- Column groups (parent header that spans multiple data columns) ---
    private List<DataGridColumnGroupInfo> _columnGroups = new();

    /// <summary>
    /// Called by <see cref="DataGridColumnGroup{TItem}"/> children during initialization to
    /// register a labelled parent header. The grid uses it during header rendering to add a
    /// second <c>tr</c> that spans the grouped columns via colspan. Idempotent on group id.
    /// </summary>
    public void RegisterColumnGroup(DataGridColumnGroupInfo info)
    {
        if (_columnGroups.Any(g => g.Id == info.Id)) return;
        _columnGroups.Add(info);
    }

    /// <summary>The registered column groups, surfaced via <see cref="DataGridContext{TItem}"/>
    /// for the header to look up labels by id.</summary>
    public IReadOnlyList<DataGridColumnGroupInfo> ColumnGroups => _columnGroups;

    /// <summary>Stable identity for a column: prefer Field (user-declared), fallback to Id.</summary>
    private static string ColumnKey(DataGridColumn<TItem> column) =>
        !string.IsNullOrWhiteSpace(column.Field) ? column.Field! : column.Id;

    /// <summary>
    /// Commits a new pixel width for the column identified by <paramref name="columnId"/>.
    /// Called by the resize handle's JS commit (pointer drag, keyboard nudge) and by the
    /// double-click auto-fit path (<paramref name="autoFit"/> = true). Clamps to the
    /// column's Min/Max, persists via the layout auto-save, and raises
    /// <see cref="OnColumnResize"/>.
    /// </summary>
    public void UpdateColumnWidth(string columnId, double width, bool autoFit = false)
    {
        var column = EffectiveColumns.FirstOrDefault(c => c.Id == columnId);
        if (column is not null)
        {
            column.Width = Math.Max(column.MinWidth ?? 50, width);
            if (column.MaxWidth.HasValue)
                column.Width = Math.Min(column.MaxWidth.Value, column.Width.Value);
            ScheduleAutoSave();
            if (OnColumnResize.HasDelegate)
            {
                // Fire-and-forget through SafeAsyncDispatcher so a faulting async
                // consumer handler is observed (logged) rather than swallowed, and
                // so this sync API doesn't have to change its signature.
                var args = new ColumnResizeEventArgs(column.Id, column.Width.Value, autoFit);
                Lumeo.Services.SafeAsyncDispatcher.FireAndForget(
                    InvokeAsync, () => OnColumnResize.InvokeAsync(args), "DataGrid.ColumnResize");
            }
            StateHasChanged();
        }
    }

    private void SyncOrderedColumns()
    {
        var source = SourceColumns;

        // If ordered columns has different column set (by ID), rebuild from source
        // Preserve user-reordered order for existing columns
        var sourceIds = source.Select(c => c.Id).ToHashSet();
        var orderedIds = _orderedColumns.Select(c => c.Id).ToHashSet();

        if (sourceIds.SetEquals(orderedIds)) return; // Same columns, keep user order

        // Columns changed — rebuild keeping existing order for known columns, append new ones
        var newOrder = _orderedColumns.Where(c => sourceIds.Contains(c.Id)).ToList();
        var added = source.Where(c => !orderedIds.Contains(c.Id)).ToList();
        newOrder.AddRange(added);
        _orderedColumns = newOrder;
        RefreshVisibleColumns();
    }

    protected override async Task OnParametersSetAsync()
    {
        // Sync IsExpanded parameter with internal state (allow external binding to drive it)
        if (IsExpanded != _lastIsExpandedParam)
        {
            _lastIsExpandedParam = IsExpanded;
            if (_isExpanded != IsExpanded)
            {
                _isExpanded = IsExpanded;
                if (_isExpanded)
                {
                    _fullscreenNeedsFocus = true;
                    try { await Interop.LockScroll(); } catch { /* best-effort */ }
                }
                else
                {
                    try { await Interop.UnlockScroll(); } catch { /* best-effort */ }
                }
            }
        }

        SyncOrderedColumns();
        // Keep the cached visible-columns list in sync whenever parameters are evaluated.
        // SyncOrderedColumns only calls RefreshVisibleColumns when the column-ID set changes;
        // calling it here covers the first render when Columns are provided via the Columns
        // parameter rather than via declarative ColumnDef children.
        RefreshVisibleColumns();

        // Re-seed runtime grouping levels from GroupBy / GroupByFields if those params changed.
        SyncGroupFieldsFromParameters();

        // Snapshot default layout once (before any external SavedLayout is applied)
        if (_defaultLayout is null && EffectiveColumns.Count > 0)
        {
            _defaultLayout = SnapshotCurrentLayout();
        }

        // Apply SavedLayout when provided externally and not yet applied
        if (SavedLayout is not null && !_savedLayoutApplied)
        {
            _savedLayoutApplied = true;
            await ApplyLayoutAsync(SavedLayout);
            return; // ApplyLayoutAsync calls ProcessClientData
        }

        if (ServerMode)
        {
            _serverPageItems = Items?.ToList() ?? new List<TItem>();
            RegroupServerItems();
        }
        else
        {
            ProcessClientData();
        }

        if (SelectedItems is not null)
        {
            _selectedItems = SelectedItems.ToList();
            _selectedSet = new HashSet<TItem>(_selectedItems);
        }

        PopulateToolbarContext();
    }

    /// <summary>
    /// Rebuilds the cascading <see cref="DataGridToolbarContext{TItem}"/> used by the
    /// extracted toolbar tool components (Fullscreen, CopySelected, Columns, Export,
    /// Layouts) as well as any custom tools placed inside <see cref="ToolbarContent{TItem}"/>.
    /// Called from OnParametersSetAsync so dependent values reflect the latest parameters.
    /// </summary>
    private void PopulateToolbarContext()
    {
        _toolbarContext.IsExpanded = _isExpanded;
        _toolbarContext.Expandable = Expandable;
        _toolbarContext.OnToggleExpanded = EventCallback.Factory.Create(this, ToggleExpanded);

        _toolbarContext.SelectedItems = _selectedItems;
        _toolbarContext.EffectiveColumns = EffectiveColumns.AsReadOnly();
        _toolbarContext.OnColumnToggle = EventCallback.Factory.Create<DataGridColumn<TItem>>(this, HandleColumnVisibilityChanged);
        _toolbarContext.OnColumnReorder = EventCallback.Factory.Create<ColumnReorderEventArgs>(this, HandleColumnReorder);
        _toolbarContext.OnColumnPin = EventCallback.Factory.Create<ColumnPinEventArgs>(this, HandleColumnPin);

        _toolbarContext.ExportFormats = ExportFormats;
        _toolbarContext.OnExport = EventCallback.Factory.Create<string>(this, HandleExport);

        _toolbarContext.EnableLayoutPersistence = EnableLayoutPersistence;
        _toolbarContext.GlobalLayouts = GlobalLayouts;
        _toolbarContext.OnSaveLayout = EventCallback.Factory.Create(this, HandleSaveLayout);
        _toolbarContext.OnResetLayout = EventCallback.Factory.Create(this, HandleResetLayout);
        _toolbarContext.OnSaveNamedLayout = EventCallback.Factory.Create<DataGridNamedLayout>(this, HandleSaveNamedLayout);
        _toolbarContext.OnDeleteNamedLayout = OnDeleteNamedLayout;
        _toolbarContext.OnApplyNamedLayout = EventCallback.Factory.Create<DataGridNamedLayout>(this, HandleApplyNamedLayout);
        _toolbarContext.LayoutStorageKey = LayoutStorageKey;
        _toolbarContext.OnError = OnError;

        _toolbarContext.Interop = Interop;
        _toolbarContext.Localizer = L;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _layoutService ??= new DataGridLayoutService(Interop, ex =>
            {
                if (OnError.HasDelegate)
                    InvokeAsync(() => OnError.InvokeAsync(ex));
            });
            _serverService ??= new DataGridServerService();

            // Snapshot default layout now that columns are registered (via ColumnDef)
            if (_defaultLayout is null && EffectiveColumns.Count > 0)
            {
                _defaultLayout = SnapshotCurrentLayout();
            }

            // All declarative columns have registered by now — if the grouping
            // seed is still missing fields, they're genuinely unknown (typo, or
            // a column Title was passed where the Field is required, or the
            // column has no Field at all). Grouping then silently renders flat,
            // which has cost real consumers real debugging time — say so.
            if (_groupSeedIncomplete && EffectiveColumns.Count > 0)
            {
                var requested = GroupByFields is { Count: > 0 }
                    ? GroupByFields
                    : (!string.IsNullOrEmpty(GroupBy) ? new[] { GroupBy! } : Array.Empty<string>());
                var unknown = requested
                    .Where(f => !EffectiveColumns.Any(c => c.Field == f))
                    .Distinct()
                    .ToList();
                if (unknown.Count > 0)
                {
                    var available = string.Join(", ", EffectiveColumns
                        .Where(c => !string.IsNullOrEmpty(c.Field))
                        .Select(c => c.Field));
                    Console.Error.WriteLine(
                        $"[Lumeo DataGrid] GroupBy/GroupByFields reference unknown column field(s): " +
                        $"{string.Join(", ", unknown)}. Grouping matches DataGridColumnDef.Field (not Title). " +
                        $"Available fields: {available}.");
                }
            }

            if (EnableLayoutPersistence && !_layoutService.LayoutLoaded)
            {
                var key = LayoutStorageKey ?? _layoutId;
                await _layoutService.LoadPersistedLayoutAsync(key, ApplyLayoutAsync);
            }

            // Suppress the browser default-scroll on the grid's keyboard-nav keys
            // so Arrow/Space/Home/End/PageUp/PageDown move the roving cell instead
            // of (or as well as) scrolling the page. Registered on the table (its
            // id is _gridId) once it's in the DOM; cell/header keydowns bubble to
            // it. SkipEditable leaves the inline-edit input's keys alone.
            if (!_navKeysPrevented)
            {
                try
                {
                    await Interop.RegisterPreventDefaultKeys(_gridId, NavKeyRules);
                    _navKeysPrevented = true;
                }
                catch (JSDisconnectedException) { /* circuit gone — nothing to suppress */ }
            }
        }

        // Unified pointer-based column reorder (mouse + touch + pen): one delegated
        // listener on the grid drives the whole gesture in JS — grip/header
        // pointerdown (with a movement threshold on mouse so header clicks still
        // sort), live sibling-shift preview, Escape/pointercancel abort, single
        // commit on release. Native HTML5 DnD is no longer used for reorder at all
        // (it's kept for the unrelated drag-to-group-panel gesture only — see
        // DataGridHeaderCell.IsDraggable). Re-check each render so a runtime
        // Reorderable flip is honoured.
        if (Reorderable && !_pointerReorderRegistered)
        {
            try
            {
                await Interop.RegisterColumnReorder(_gridId, async (srcId, tgtId) =>
                {
                    await ReorderColumnByIdAsync(srcId, tgtId);
                });
                _pointerReorderRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!Reorderable && _pointerReorderRegistered)
        {
            try { await Interop.UnregisterColumnReorder(_gridId); }
            catch (JSDisconnectedException) { }
            _pointerReorderRegistered = false;
        }

        // Unified pointer-based row reorder (mouse + touch + pen) — vertical mirror
        // of the column engine above. Handle-only initiation (DataGridRow's grip):
        // unlike a column header, a row's whole surface is a click-to-select target,
        // so there's no safe movement-threshold "arm from anywhere" the way column
        // headers do it (their surface click is a scoped sort <button>). Gated by
        // RowReorderPointerActive, not just RowReorderable — see that property's
        // doc comment for why grouped/tree/virtualized grids don't register.
        if (RowReorderPointerActive && !_pointerRowReorderRegistered)
        {
            try
            {
                await Interop.RegisterRowReorder(_gridId, async (srcKey, tgtKey) =>
                {
                    await ReorderRowByKeyAsync(srcKey, tgtKey);
                });
                _pointerRowReorderRegistered = true;
            }
            catch (JSDisconnectedException) { }
        }
        else if (!RowReorderPointerActive && _pointerRowReorderRegistered)
        {
            try { await Interop.UnregisterRowReorder(_gridId); }
            catch (JSDisconnectedException) { }
            _pointerRowReorderRegistered = false;
        }

        if (_isExpanded && _fullscreenNeedsFocus)
        {
            _fullscreenNeedsFocus = false;
            try { await _fullscreenRef.FocusAsync(); } catch { /* element may not be ready */ }
        }

        // FLIP-animate the columns that just moved. HandleColumnReorder
        // captured their pre-reorder rects before mutating _orderedColumns;
        // now that the new layout has rendered, JS computes deltas and
        // slides each column from its old to new position. Best-effort —
        // a failed JS call must never wedge subsequent reorders, so it's
        // wrapped in a try/catch and the flag is cleared unconditionally.
        if (_pendingReorderAnimation)
        {
            _pendingReorderAnimation = false;
            try { await Interop.AnimateColumnReorder(_gridId, ColumnReorderAnimationMs); }
            catch (JSDisconnectedException) { }
            catch (Exception ex)
            {
                // Non-disconnect JS / runtime failures shouldn't throw out of
                // OnAfterRenderAsync (Blazor would log unhandled-task) — route
                // through OnError so consumers can react, but keep the flag
                // cleared so a future render isn't blocked on a stale
                // pending-animation state (Codex review on #48).
                if (OnError.HasDelegate) await OnError.InvokeAsync(ex);
            }
        }

        // FLIP-animate the row that just moved, same handshake as columns:
        // ReorderRowByKeyAsync captured rects (keyed by stable row identity, not
        // index — the index that moved is exactly the one that's now wrong) before
        // mutating _displayedItems; now that the reordered list has rendered, JS
        // recomputes each row's new top and slides from old to new.
        if (_pendingRowReorderAnimation)
        {
            _pendingRowReorderAnimation = false;
            try { await Interop.AnimateRowReorder(_gridId, RowReorderAnimationMs); }
            catch (JSDisconnectedException) { }
            catch (Exception ex)
            {
                if (OnError.HasDelegate) await OnError.InvokeAsync(ex);
            }
        }
    }

    /// <summary>
    /// Toggles fullscreen expand mode for the grid. No-op when Expandable is false.
    /// Preserves grid state (selection, filters, sorts, pagination) across the transition
    /// because the underlying grid markup is rendered as the same render-tree sub-tree.
    /// </summary>
    public async Task ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
        _lastIsExpandedParam = _isExpanded;
        IsExpanded = _isExpanded;

        if (_isExpanded)
        {
            _fullscreenNeedsFocus = true;
            try { await Interop.LockScroll(); } catch { /* best-effort */ }
            try { await Interop.SetHtmlClass("lumeo-fullscreen-active", true); } catch { /* best-effort */ }
        }
        else
        {
            try { await Interop.UnlockScroll(); } catch { /* best-effort */ }
            try { await Interop.SetHtmlClass("lumeo-fullscreen-active", false); } catch { /* best-effort */ }
        }

        if (IsExpandedChanged.HasDelegate)
            await IsExpandedChanged.InvokeAsync(_isExpanded);

        // Rebuild the cascading toolbar context so DataGridToolbarFullscreen sees the updated
        // IsExpanded and swaps its Maximize2/Minimize2 icon. Without this, the context was
        // only refreshed on parameter changes and the fullscreen icon stayed stale.
        PopulateToolbarContext();
        StateHasChanged();
    }

    private async Task HandleFullscreenKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape" && _isExpanded)
        {
            await ToggleExpanded();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _layoutService ??= new DataGridLayoutService(Interop, ex =>
        {
            if (OnError.HasDelegate)
                InvokeAsync(() => OnError.InvokeAsync(ex));
        });
        _serverService ??= new DataGridServerService();

        if (ServerMode)
        {
            await RequestServerData();
        }
    }

    // Applies grouping to the server-returned page in ServerMode. The server has
    // already done sort/filter/page, so we treat _displayedItems as the buffer
    // and delegate to the same grouping routines client-mode uses — which keeps
    // multi-level, expand-state preservation, and aggregates symmetrical across
    // modes. Caveat: grouping is per-page; cross-page grouping requires the API
    // to deliver all rows (no pagination) or pre-aggregated groups.
    private void RegroupServerItems()
    {
        _processedItems = _serverPageItems;
        var fields = EffectiveGroupFields;
        if (fields.Count == 1 && _serverPageItems.Count > 0)
        {
            _groupedTree.Clear();
            ProcessSingleLevelGrouping(fields[0]);
        }
        else if (fields.Count > 1 && _serverPageItems.Count > 0)
        {
            _groupedSections.Clear();
            ProcessMultiLevelGrouping(fields);
        }
        else
        {
            _lastGroupBy = null;
            _groupedSections.Clear();
            _groupedTree.Clear();
            // No grouping active (or the current server page is genuinely empty): the
            // un-grouped row set IS the raw page. Previously this branch left
            // _displayedItems untouched, relying on the caller (OnParametersSetAsync) having
            // just assigned it from Items — which broke the moment RegroupServerItems() was
            // called from a local toggle handler instead (no Items reassignment that render).
            _displayedItems = _serverPageItems;
        }
    }

    private void ProcessClientData()
    {
        if (Items is null)
        {
            _processedItems = new List<TItem>();
            _displayedItems = new List<TItem>();
            return;
        }

        // Clean stale selections that reference items no longer in the data source.
        // When SelectionKeySelector is set, compare by key so server-mode fetches
        // (which produce fresh TItem instances per page) don't wipe selections.
        // null-key selections fall back to reference equality so mixed
        // keyed/unkeyed scenarios don't silently lose the unkeyed rows.
        if (_selectedItems.Count > 0)
        {
            int staleCount;
            if (SelectionKeySelector is not null)
            {
                var currentKeys = new HashSet<object>();
                var currentRefs = new HashSet<TItem>();
                foreach (var it in Items)
                {
                    var k = SelectionKeySelector(it);
                    if (k is not null) currentKeys.Add(k);
                    else currentRefs.Add(it);
                }
                staleCount = _selectedItems.RemoveAll(item =>
                {
                    var k = SelectionKeySelector(item);
                    return k is null
                        ? !currentRefs.Contains(item)
                        : !currentKeys.Contains(k);
                });
            }
            else
            {
                var currentItems = new HashSet<TItem>(Items);
                staleCount = _selectedItems.RemoveAll(item => !currentItems.Contains(item));
            }
            if (staleCount > 0)
            {
                _selectedSet = new HashSet<TItem>(_selectedItems);
                NotifySelectionChanged();
            }
        }

        // Re-anchor detail-expand and in-progress row-edit state onto the FRESH
        // item instances. _expandedRows/_editingRows/_rowEditValues are keyed by
        // TItem reference, so a same-content Items refresh that produces new
        // instances (server-mode page fetch, parent re-fetch) would otherwise
        // silently collapse expanded rows and discard open editors even though
        // the logical row is still present. When SelectionKeySelector is set we
        // remap by stable key (mirroring the _selectedItems cleanup above):
        // entries whose key still exists are rebound to the new instance, the
        // rest are dropped. Without a selector we leave the sets untouched —
        // reference identity is all we have and clobbering would lose state on
        // every benign re-render.
        if (SelectionKeySelector is not null &&
            (_expandedRows.Count > 0 || _editingRows.Count > 0))
        {
            var keyToCurrent = new Dictionary<object, TItem>();
            foreach (var it in Items)
            {
                var k = SelectionKeySelector(it);
                if (k is not null) keyToCurrent[k] = it;
            }

            RemapRowStateByKey(_expandedRows, keyToCurrent);
            RemapRowStateByKey(_editingRows, keyToCurrent);

            if (_rowEditValues.Count > 0)
            {
                var remappedEdits = new Dictionary<TItem, Dictionary<string, object?>>();
                foreach (var (oldItem, dict) in _rowEditValues)
                {
                    var k = SelectionKeySelector(oldItem);
                    if (k is null) remappedEdits[oldItem] = dict;
                    else if (keyToCurrent.TryGetValue(k, out var current))
                        remappedEdits[current] = dict;
                    // key gone -> drop the buffered edit (row no longer exists)
                }
                _rowEditValues = remappedEdits;
            }
        }

        var query = Items.AsEnumerable();

        // Global search
        if (!string.IsNullOrWhiteSpace(_globalSearch))
        {
            var search = _globalSearch;
            query = query.Where(item =>
                EffectiveColumns.Any(col =>
                {
                    var value = col.GetFormattedValue(item);
                    return value.Contains(search, StringComparison.OrdinalIgnoreCase);
                }));
        }

        // Column filters
        foreach (var filter in _filters)
        {
            var column = EffectiveColumns.FirstOrDefault(c => c.Field == filter.Field);
            if (column is null) continue;

            query = query.Where(item =>
            {
                var value = column.GetValue(item);
                return DataGridFilterOperator.Evaluate(filter, value);
            });
        }

        // Sort
        IOrderedEnumerable<TItem>? ordered = null;
        foreach (var sort in _sorts.Where(s => s.Direction != SortDirection.None))
        {
            var column = EffectiveColumns.FirstOrDefault(c => c.Field == sort.Field);
            if (column is null) continue;

            if (ordered is null)
            {
                if (column.CustomSort is not null)
                {
                    var comp = column.CustomSort;
                    ordered = sort.Direction == SortDirection.Ascending
                        ? query.OrderBy(item => column.GetValue(item), Comparer<object?>.Create(comp))
                        : query.OrderByDescending(item => column.GetValue(item), Comparer<object?>.Create(comp));
                }
                else
                {
                    ordered = sort.Direction == SortDirection.Ascending
                        ? query.OrderBy(item => column.GetValue(item) as IComparable)
                        : query.OrderByDescending(item => column.GetValue(item) as IComparable);
                }
            }
            else
            {
                if (column.CustomSort is not null)
                {
                    var comp = column.CustomSort;
                    ordered = sort.Direction == SortDirection.Ascending
                        ? ordered.ThenBy(item => column.GetValue(item), Comparer<object?>.Create(comp))
                        : ordered.ThenByDescending(item => column.GetValue(item), Comparer<object?>.Create(comp));
                }
                else
                {
                    ordered = sort.Direction == SortDirection.Ascending
                        ? ordered.ThenBy(item => column.GetValue(item) as IComparable)
                        : ordered.ThenByDescending(item => column.GetValue(item) as IComparable);
                }
            }
        }

        _processedItems = (ordered as IEnumerable<TItem> ?? query).ToList();

        // --- Tree-grid mode takes priority over grouping ---
        if (IsTreeGridMode)
        {
            _groupedSections.Clear();
            _groupedTree.Clear();
            _runtimeGroupFields.Clear();
            RebuildTreeView();
            _displayedItems = _treeDisplayRows;
            return; // tree-grid manages its own row set (no pagination)
        }
        _treeDisplayRows = new List<TItem>();

        // --- Row grouping (single- or multi-level) ---
        var groupFields = EffectiveGroupFields;
        if (groupFields.Count == 1)
        {
            _groupedTree.Clear();
            if (ProcessSingleLevelGrouping(groupFields[0]))
                return; // skip normal pagination when grouped
        }
        else if (groupFields.Count > 1)
        {
            _groupedSections.Clear();
            if (ProcessMultiLevelGrouping(groupFields))
                return;
        }
        _lastGroupBy = null;
        _groupedSections.Clear();
        _groupedTree.Clear();

        // Paginate
        if (ShowPagination && PageSize > 0)
        {
            var totalPages = Math.Max(1, (int)Math.Ceiling((double)_processedItems.Count / PageSize));
            if (_currentPage > totalPages) _currentPage = totalPages;
            if (_currentPage < 1) _currentPage = 1;

            _displayedItems = _processedItems
                .Skip((_currentPage - 1) * PageSize)
                .Take(PageSize)
                .ToList();
        }
        else
        {
            _displayedItems = _processedItems;
        }

        // Batch-edit: surface added-but-unsaved rows at the end of the
        // displayed list so the user can fill them in inline. They are NOT in
        // _processedItems (so not in sort/filter/aggregates) — they live only
        // in the batch buffer until OnBatchSave commits them upstream.
        if (EditMode == DataGridEditMode.Batch && _batchAdded.Count > 0)
        {
            if (ReferenceEquals(_displayedItems, _processedItems))
            {
                _displayedItems = new List<TItem>(_processedItems);
            }
            _displayedItems.AddRange(_batchAdded);
        }
    }

    // =====================================================================
    //  Multi-level grouping + tree-grid (rc.35)
    // =====================================================================

    /// <summary>True when the grid is in hierarchical tree-grid mode (a
    /// <see cref="ChildItemsSelector"/> is set and no grouping is active —
    /// tree-grid wins over grouping when both are configured).</summary>
    internal bool IsTreeGridMode => ChildItemsSelector is not null;

    /// <summary>The grouping levels actually in effect — runtime panel edits if
    /// any have been made, otherwise seeded from the parameters.</summary>
    private IReadOnlyList<string> EffectiveGroupFields => _runtimeGroupFields;

    /// <summary>Re-seeds <see cref="_runtimeGroupFields"/> from the parameters when
    /// <see cref="GroupBy"/> / <see cref="GroupByFields"/> change. Runtime panel
    /// edits (via AddGroupField/RemoveGroupField) are preserved across renders
    /// because the seed only re-applies when the parameter values themselves change.</summary>
    private void SyncGroupFieldsFromParameters()
    {
        var byFieldsKey = GroupByFields is null ? null : string.Join("", GroupByFields);
        if (byFieldsKey == _seededGroupByFieldsKey && GroupBy == _seededGroupBy) return;
        _seededGroupByFieldsKey = byFieldsKey;
        _seededGroupBy = GroupBy;

        var requested = (GroupByFields is { Count: > 0 }
            ? GroupByFields.ToList()
            : (!string.IsNullOrEmpty(GroupBy) ? new List<string> { GroupBy! } : new List<string>()))
            .Distinct()
            .ToList();
        _runtimeGroupFields = requested
            .Where(f => EffectiveColumns.Any(c => c.Field == f))
            .ToList();
        // Fields can be dropped here merely because their declarative column
        // hasn't registered yet — flag it so AddColumnDef re-seeds on arrival.
        _groupSeedIncomplete = _runtimeGroupFields.Count < requested.Count;
        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _lastGroupBy = null;
    }

    private void AddGroupField(string field)
    {
        if (string.IsNullOrEmpty(field)) return;
        if (_runtimeGroupFields.Contains(field)) return;
        var col = EffectiveColumns.FirstOrDefault(c => c.Field == field && c.Groupable);
        if (col is null) return;
        _runtimeGroupFields.Add(field);

        // Auto-unpin and auto-hide the grouped column so the value isn't shown
        // redundantly in the data cells (it's already shown in the group header).
        // Snapshot the original state so we can restore it on un-group.
        if (!_groupedColPrevState.ContainsKey(field))
        {
            _groupedColPrevState[field] = (col.Pin, col.Visible);
            col.Pin = PinDirection.None;
            col.Visible = false;
            RefreshVisibleColumns();
        }

        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _currentPage = 1;
        if (ServerMode) RegroupServerItems();
        else ProcessClientData();
        // Mirror Sort/Filter behaviour — persist the grouping change so a
        // reload restores it. Without this the snapshot serialization built
        // in v2.1.1 had nothing to act on for runtime-panel additions.
        ScheduleAutoSave();
        StateHasChanged();
    }

    private void RemoveGroupField(string field)
    {
        if (!_runtimeGroupFields.Remove(field)) return;

        // Restore previously-snapshotted Pin + Visible state if we auto-changed it.
        if (_groupedColPrevState.TryGetValue(field, out var prev))
        {
            _groupedColPrevState.Remove(field);
            var col = EffectiveColumns.FirstOrDefault(c => c.Field == field);
            if (col is not null)
            {
                col.Pin = prev.PrevPin;
                col.Visible = prev.PrevVisible;
                RefreshVisibleColumns();
            }
        }

        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _currentPage = 1;
        if (ServerMode) RegroupServerItems();
        else ProcessClientData();
        ScheduleAutoSave();
        StateHasChanged();
    }

    /// <summary>Removes all grouping levels at once. Wired to the panel's "Clear"
    /// button (rc.41). Resets group expansion state the same way single-field
    /// removal does so re-grouping after Clear has a clean slate.</summary>
    private void ClearGroupFields()
    {
        if (_runtimeGroupFields.Count == 0) return;

        // Restore all auto-hidden/unpinned columns.
        foreach (var (field, prev) in _groupedColPrevState)
        {
            var col = EffectiveColumns.FirstOrDefault(c => c.Field == field);
            if (col is not null)
            {
                col.Pin = prev.PrevPin;
                col.Visible = prev.PrevVisible;
            }
        }
        if (_groupedColPrevState.Count > 0)
        {
            _groupedColPrevState.Clear();
            RefreshVisibleColumns();
        }

        _runtimeGroupFields.Clear();
        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _currentPage = 1;
        if (ServerMode) RegroupServerItems();
        else ProcessClientData();
        ScheduleAutoSave();
        StateHasChanged();
    }

    // --- Drag-to-group: panel drop-zone handlers (rc.41) -----------------
    // HeaderCell sets _dragState.SourceColumnId on dragstart (when the column
    // is Groupable + ShowGroupPanel). The panel reads it on drop and resolves
    // back to the column field to add a grouping level.
    private bool _isGroupPanelDragOver;

    // Perf: there is deliberately no HandleGroupPanelDragOver. This panel lives on
    // the DataGrid root, so a bound @ondragover re-rendered the WHOLE grid on every
    // dragover tick (~60/s) — measured at ~198ms per render on a 640-row grid,
    // freezing the main thread while dragging a header over the panel. dragover is
    // left as a native :preventDefault-only directive in the markup so the browser
    // still accepts the drop without any .NET round-trip. The accept-highlight is
    // toggled by the enter/leave handlers below (boundary events, a few per drag).
    private void HandleGroupPanelDragEnter(DragEventArgs e)
    {
        // Only show the drop-accept highlight when the dragged column is
        // actually a valid drop target — Groupable, has a field, not already
        // grouped. Avoids the misleading "primary-blue ready" highlight for
        // Reorderable-only drags or columns the panel can't accept.
        if (_dragState.SourceColumnIndex < 0) return;
        var srcCol = EffectiveColumns.FirstOrDefault(c => c.Id == _dragState.SourceColumnId);
        if (srcCol?.Groupable != true || srcCol.Field is null) return;
        if (_runtimeGroupFields.Contains(srcCol.Field)) return;
        _isGroupPanelDragOver = true;
    }

    private void HandleGroupPanelDragLeave(DragEventArgs e)
    {
        _isGroupPanelDragOver = false;
    }

    private void HandleGroupPanelDrop(DragEventArgs e)
    {
        _isGroupPanelDragOver = false;
        if (_dragState.SourceColumnIndex < 0) return;

        // Resolve source column → field. Fall back to ID-based lookup if the
        // index drifted (column reorder during the drag); ID is stable.
        var srcCol = EffectiveColumns.FirstOrDefault(c => c.Id == _dragState.SourceColumnId)
                    ?? EffectiveColumns.ElementAtOrDefault(_dragState.SourceColumnIndex);
        _dragState.ResetColumn();

        if (srcCol?.Field is null || !srcCol.Groupable) return;
        AddGroupField(srcCol.Field);
    }

    /// <summary>Computes the per-group aggregate strip for a set of items.</summary>
    private IReadOnlyList<DataGridGroupAggregate> ComputeGroupAggregates(IReadOnlyList<TItem> items)
    {
        var result = new List<DataGridGroupAggregate>();
        foreach (var col in EffectiveColumns.Where(c => c.Visible && c.Aggregate != AggregateType.None))
        {
            result.Add(new DataGridGroupAggregate(
                col.Id,
                AggregateLabel(col.Aggregate),
                ComputeColumnAggregate(col, items)));
        }
        return result;
    }

    private string AggregateLabel(AggregateType t) => t switch
    {
        AggregateType.Sum => L["DataGrid.AggregateSum"],
        AggregateType.Average => L["DataGrid.AggregateAvg"],
        AggregateType.Count => L["DataGrid.AggregateCount"],
        AggregateType.Min => L["DataGrid.AggregateMin"],
        AggregateType.Max => L["DataGrid.AggregateMax"],
        _ => ""
    };

    private string ComputeColumnAggregate(DataGridColumn<TItem> col, IReadOnlyList<TItem> items)
    {
        if (items.Count == 0) return "-";
        var values = items.Select(col.GetValue).Where(v => v is not null).ToList();
        if (col.Aggregate == AggregateType.Count) return values.Count.ToString();

        var numeric = new List<double>();
        foreach (var v in values)
        {
            if (v is IConvertible conv)
            {
                try { numeric.Add(conv.ToDouble(System.Globalization.CultureInfo.InvariantCulture)); }
                catch { /* skip non-numeric */ }
            }
        }
        if (numeric.Count == 0) return "-";
        double r = col.Aggregate switch
        {
            AggregateType.Sum => numeric.Sum(),
            AggregateType.Average => numeric.Average(),
            AggregateType.Min => numeric.Min(),
            AggregateType.Max => numeric.Max(),
            _ => 0
        };
        return r.ToString("N2");
    }

    // ---- Single-level grouping (classic; now with per-group aggregates) ----
    private bool ProcessSingleLevelGrouping(string field)
    {
        var groupCol = EffectiveColumns.FirstOrDefault(c => c.Field == field);
        if (groupCol is null) return false;

        var groupByChanged = field != _lastGroupBy;
        _lastGroupBy = field;

        _groupedSections = _processedItems
            .GroupBy(item => groupCol.GetFormattedValue(item, EffectiveCulture))
            .OrderBy(g => g.Key, StringComparer.CurrentCulture)
            .Select(g =>
            {
                var its = g.ToList();
                return new DataGridGroupSection<TItem>(g.Key, its, its.Count)
                {
                    Aggregates = ComputeGroupAggregates(its)
                };
            })
            .ToList();

        // When the bound data is momentarily empty (an async refresh / loading
        // cycle that lots-of-data apps do frequently), there are no sections and
        // therefore no valid keys. Running the IntersectWith below against an
        // empty set would WIPE _expandedGroups / _knownGroupKeys — so when the
        // data returns every key looks "new" and gets re-expanded by default,
        // silently discarding the user's collapse choices. Bail out before
        // touching the expand-state sets, mirroring ProcessMultiLevelGrouping's
        // empty-tree guard (which is why multi-level grouping never had this bug).
        if (_groupedSections.Count == 0)
        {
            _displayedItems = new List<TItem>();
            return true;
        }

        var defaultChanged = _lastGroupsExpandedByDefault is not null && _lastGroupsExpandedByDefault != GroupsExpandedByDefault;
        _lastGroupsExpandedByDefault = GroupsExpandedByDefault;

        if (groupByChanged || defaultChanged)
        {
            _expandedGroups.Clear();
            _knownGroupKeys.Clear();
            foreach (var section in _groupedSections)
            {
                _knownGroupKeys.Add(section.Key);
                if (GroupsExpandedByDefault) _expandedGroups.Add(section.Key);
            }
        }
        else
        {
            // Do NOT IntersectWith the current section keys: a group key (e.g. "Engineering")
            // is a stable business value, not a per-page artifact. In ServerMode this method
            // runs after every page/sort/filter/search refresh — the new page's group keys are
            // almost never identical to the previous page's, so intersecting wiped nearly all
            // of _expandedGroups/_knownGroupKeys on every refresh, and every "new" key (i.e.
            // every key on the new page) got re-seeded from GroupsExpandedByDefault. That
            // silently discarded the user's manual expand/collapse choices on every page turn,
            // sort, or filter — the reported "auto-expands / content disappears" production bug.
            // Only ADD newly-seen keys; a key's expand state, once known, is never forgotten.
            foreach (var section in _groupedSections)
            {
                if (_knownGroupKeys.Contains(section.Key)) continue;
                _knownGroupKeys.Add(section.Key);
                if (GroupsExpandedByDefault) _expandedGroups.Add(section.Key);
            }
        }

        _displayedItems = _groupedSections
            .Where(g => _expandedGroups.Contains(g.Key))
            .SelectMany(g => g.Items)
            .ToList();
        return true;
    }

    // ---- Multi-level grouping (nested tree) ----
    private bool ProcessMultiLevelGrouping(IReadOnlyList<string> fields)
    {
        _groupedTree = BuildGroupNodes(_processedItems, fields, 0, "");
        if (_groupedTree.Count == 0)
        {
            _groupedSections.Clear();
            return false;
        }

        var defaultChanged = _lastGroupsExpandedByDefault is not null && _lastGroupsExpandedByDefault != GroupsExpandedByDefault;
        _lastGroupsExpandedByDefault = GroupsExpandedByDefault;

        // Collect every node path (depth-first) to manage expand state.
        var allPaths = new List<string>();
        void Collect(IEnumerable<DataGridGroupNode<TItem>> nodes)
        {
            foreach (var n in nodes) { allPaths.Add(n.Path); Collect(n.Children); }
        }
        Collect(_groupedTree);

        if (defaultChanged)
        {
            _expandedGroupPaths.Clear();
            _knownGroupPaths.Clear();
        }
        // Do NOT IntersectWith the current paths against a "valid set" — a path is a stable
        // business value derived from group field values, not a per-page artifact. In
        // ServerMode this runs after every page/sort/filter/search refresh, and the new page's
        // paths are almost never identical to the previous page's, so intersecting wiped nearly
        // all of _expandedGroupPaths/_knownGroupPaths on every refresh and re-seeded every path
        // on the new page from GroupsExpandedByDefault — silently discarding the user's manual
        // expand/collapse choices (the reported "auto-expands / content disappears" bug; see
        // the identical fix + rationale in ProcessSingleLevelGrouping's else branch above).
        foreach (var p in allPaths)
        {
            if (_knownGroupPaths.Contains(p)) continue;
            _knownGroupPaths.Add(p);
            if (GroupsExpandedByDefault) _expandedGroupPaths.Add(p);
        }

        // Flatten leaf items that live under fully-expanded ancestor chains.
        var visible = new List<TItem>();
        void Flatten(IEnumerable<DataGridGroupNode<TItem>> nodes)
        {
            foreach (var n in nodes)
            {
                if (!_expandedGroupPaths.Contains(n.Path)) continue;
                if (n.Children.Count > 0) Flatten(n.Children);
                else visible.AddRange(n.Items);
            }
        }
        Flatten(_groupedTree);
        _displayedItems = visible;
        return true;
    }

    private List<DataGridGroupNode<TItem>> BuildGroupNodes(
        IReadOnlyList<TItem> items, IReadOnlyList<string> fields, int level, string parentPath)
    {
        if (level >= fields.Count) return new();
        var col = EffectiveColumns.FirstOrDefault(c => c.Field == fields[level]);
        if (col is null)
        {
            // Skip a missing field — try the next level so grouping degrades gracefully.
            return BuildGroupNodes(items, fields, level + 1, parentPath);
        }
        return items
            .GroupBy(it => col.GetFormattedValue(it, EffectiveCulture))
            .OrderBy(g => g.Key, StringComparer.CurrentCulture)
            .Select(g =>
            {
                var its = g.ToList();
                var path = string.IsNullOrEmpty(parentPath) ? g.Key : parentPath + " / " + g.Key;
                var children = level + 1 < fields.Count
                    ? BuildGroupNodes(its, fields, level + 1, path)
                    : new List<DataGridGroupNode<TItem>>();
                return new DataGridGroupNode<TItem>(
                    Key: g.Key,
                    Path: path,
                    Level: level,
                    Field: fields[level],
                    TotalCount: its.Count,
                    Items: children.Count > 0 ? new List<TItem>() : its,
                    Children: children)
                {
                    Aggregates = ComputeGroupAggregates(its)
                };
            })
            .ToList();
    }

    private bool IsGroupPathExpanded(string path) => _expandedGroupPaths.Contains(path);

    private void ToggleGroupPath(string path)
    {
        if (!_expandedGroupPaths.Remove(path)) _expandedGroupPaths.Add(path);
        // ServerMode grids regroup the already-delivered page — ProcessClientData
        // early-returns without Items, so collapse/expand silently did nothing
        // on every ServerMode grid (same dispatch as RemoveGroupField).
        if (ServerMode) RegroupServerItems();
        else ProcessClientData();
        StateHasChanged();
    }

    // ---- Tree-grid mode ----

    /// <summary>Currently-resolved tree column field (null = first visible column).</summary>
    private string? EffectiveTreeColumnField
    {
        get
        {
            if (!string.IsNullOrEmpty(TreeColumnField) &&
                _visibleColumns.Any(c => c.Field == TreeColumnField))
                return TreeColumnField;
            return _visibleColumns.FirstOrDefault()?.Field;
        }
    }

    private bool MatchesCurrentFilters(TItem item)
    {
        if (!string.IsNullOrWhiteSpace(_globalSearch))
        {
            var s = _globalSearch;
            if (!EffectiveColumns.Any(col => col.GetFormattedValue(item, EffectiveCulture).Contains(s, StringComparison.OrdinalIgnoreCase)))
                return false;
        }
        foreach (var filter in _filters)
        {
            var column = EffectiveColumns.FirstOrDefault(c => c.Field == filter.Field);
            if (column is null) continue;
            if (!DataGridFilterOperator.Evaluate(filter, column.GetValue(item))) return false;
        }
        return true;
    }

    private IEnumerable<TItem> SortSiblings(IEnumerable<TItem> items)
    {
        IOrderedEnumerable<TItem>? ordered = null;
        foreach (var sort in _sorts.Where(s => s.Direction != SortDirection.None))
        {
            var column = EffectiveColumns.FirstOrDefault(c => c.Field == sort.Field);
            if (column is null) continue;
            Func<TItem, object?> keySel = column.GetValue;
            if (ordered is null)
            {
                ordered = column.CustomSort is not null
                    ? (sort.Direction == SortDirection.Ascending
                        ? items.OrderBy(keySel, Comparer<object?>.Create(column.CustomSort))
                        : items.OrderByDescending(keySel, Comparer<object?>.Create(column.CustomSort)))
                    : (sort.Direction == SortDirection.Ascending
                        ? items.OrderBy(it => column.GetValue(it) as IComparable)
                        : items.OrderByDescending(it => column.GetValue(it) as IComparable));
            }
            else
            {
                ordered = column.CustomSort is not null
                    ? (sort.Direction == SortDirection.Ascending
                        ? ordered.ThenBy(keySel, Comparer<object?>.Create(column.CustomSort))
                        : ordered.ThenByDescending(keySel, Comparer<object?>.Create(column.CustomSort)))
                    : (sort.Direction == SortDirection.Ascending
                        ? ordered.ThenBy(it => column.GetValue(it) as IComparable)
                        : ordered.ThenByDescending(it => column.GetValue(it) as IComparable));
            }
        }
        return ordered ?? items;
    }

    /// <summary>Recursively filters a tree: keeps a node when it matches the current
    /// filters OR has a kept descendant. Returns null when the node is pruned.</summary>
    private bool TreeNodeKept(TItem item)
    {
        if (MatchesCurrentFilters(item)) return true;
        var kids = ChildItemsSelector?.Invoke(item);
        return kids is not null && kids.Any(TreeNodeKept);
    }

    /// <summary>Rebuilds the flattened tree-grid view (visible rows + per-row level
    /// and has-children caches) from <see cref="_processedItems"/>.</summary>
    private void RebuildTreeView()
    {
        _treeDisplayRows = new List<TItem>();
        _treeLevelOf = new Dictionary<TItem, int>();
        _treeHasChildren = new Dictionary<TItem, bool>();

        var hasFilter = !string.IsNullOrWhiteSpace(_globalSearch) || _filters.Count > 0;

        // Seed expand state once we ACTUALLY have data. Latching this on an empty
        // render — the normal pre-load state of an async refresh (bind new List<>(),
        // then fill it) — would consume the one-shot seed against an empty list, so
        // when the real data arrives the tree renders fully collapsed despite
        // TreeGridDefaultExpanded=true. Same empty-data flicker the grouping branch
        // guards against (see DataGridGroupCollapsePersistenceTests).
        if (!_treeExpandSeeded && _processedItems.Count > 0)
        {
            _treeExpandSeeded = true;
            if (TreeGridDefaultExpanded)
            {
                void SeedExpand(IEnumerable<TItem> nodes)
                {
                    foreach (var n in nodes)
                    {
                        var kids = ChildItemsSelector?.Invoke(n);
                        if (kids is not null && kids.Any())
                        {
                            _expandedTreeNodes.Add(n);
                            SeedExpand(kids);
                        }
                    }
                }
                SeedExpand(_processedItems);
            }
        }

        void Walk(IEnumerable<TItem> nodes, int level)
        {
            // Sort siblings; in tree mode _processedItems was already sorted at root,
            // but children come straight from the selector, so sort them here too.
            var siblings = (level == 0 ? nodes : SortSiblings(nodes)).ToList();
            foreach (var node in siblings)
            {
                if (hasFilter && !TreeNodeKept(node)) continue;
                var kids = ChildItemsSelector?.Invoke(node)?.ToList();
                var keptKids = kids is null ? null : (hasFilter ? kids.Where(TreeNodeKept).ToList() : kids);
                var hasKids = keptKids is { Count: > 0 };
                _treeLevelOf[node] = level;
                _treeHasChildren[node] = hasKids;
                _treeDisplayRows.Add(node);
                if (hasKids && _expandedTreeNodes.Contains(node))
                    Walk(keptKids!, level + 1);
            }
        }
        Walk(_processedItems, 0);
    }

    private bool IsTreeNodeExpanded(TItem item) => _expandedTreeNodes.Contains(item);

    private int TreeLevelOf(TItem item) => _treeLevelOf.TryGetValue(item, out var l) ? l : 0;

    private bool TreeHasChildrenOf(TItem item) => _treeHasChildren.TryGetValue(item, out var b) && b;

    private async Task ToggleTreeNodeAsync(TItem item)
    {
        if (!_expandedTreeNodes.Remove(item)) _expandedTreeNodes.Add(item);
        if (!ServerMode) ProcessClientData();
        if (OnTreeNodeExpand.HasDelegate) await OnTreeNodeExpand.InvokeAsync(item);
        StateHasChanged();
    }

    private async Task HandleSort(SortDescriptor sort)
    {
        _sorts.RemoveAll(s => s.Field == sort.Field);
        if (sort.Direction != SortDirection.None)
        {
            _sorts.Add(sort);
        }

        _currentPage = 1;
        ScheduleAutoSave();

        if (_useServerVirtualization)
        {
            await RefreshVirtualizedAsync();
        }
        else if (ServerMode)
        {
            await RequestServerData();
        }
        else
        {
            ProcessClientData();
        }
    }

    private async Task HandleFilter(FilterDescriptor filter)
    {
        _filters.RemoveAll(f => f.Field == filter.Field);
        _filters.Add(filter);
        _currentPage = 1;
        ScheduleAutoSave();

        if (_useServerVirtualization)
        {
            await RefreshVirtualizedAsync();
        }
        else if (ServerMode)
        {
            await RequestServerData();
        }
        else
        {
            ProcessClientData();
        }
    }

    private async Task RemoveFilter(FilterDescriptor filter)
    {
        _filters.RemoveAll(f => f.Field == filter.Field);
        _currentPage = 1;
        ScheduleAutoSave();

        if (_useServerVirtualization)
        {
            await RefreshVirtualizedAsync();
        }
        else if (ServerMode)
        {
            await RequestServerData();
        }
        else
        {
            ProcessClientData();
        }
    }

    private async Task HandleGlobalSearch(string search)
    {
        _globalSearch = string.IsNullOrWhiteSpace(search) ? null : search;
        _currentPage = 1;
        ScheduleAutoSave();

        if (_useServerVirtualization)
        {
            // Debounce the same way ServerMode does — typing should not
            // round-trip on every keystroke. Guard against lazy init: the
            // service is normally created in OnAfterRender, but search may
            // fire before that on a slow first paint.
            _serverService ??= new DataGridServerService();
            _serverService.DebounceSearch(async ct =>
            {
                if (ct.IsCancellationRequested) return;
                await InvokeAsync(async () =>
                {
                    await RefreshVirtualizedAsync();
                    StateHasChanged();
                });
            });
        }
        else if (ServerMode)
        {
            _serverService!.DebounceSearch(async ct =>
            {
                if (ct.IsCancellationRequested) return;
                await InvokeAsync(async () =>
                {
                    await RequestServerData();
                    StateHasChanged();
                });
            });
        }
        else
        {
            ProcessClientData();
            StateHasChanged();
        }
    }

    private async Task HandlePageChanged(int page)
    {
        _currentPage = page;

        if (ServerMode)
        {
            await RequestServerData();
        }
        else
        {
            ProcessClientData();
            StateHasChanged();
        }
    }

    private async Task HandlePageSizeChanged(int pageSize)
    {
        PageSize = pageSize;
        _currentPage = 1;
        ScheduleAutoSave();

        if (ServerMode)
        {
            await RequestServerData();
        }
        else
        {
            ProcessClientData();
            StateHasChanged();
        }
    }

    private void HandleSelectionChanged(TItem item)
    {
        // Handled by ToggleSelection
    }

    private bool IsRowSelected(TItem item) => FindSelectionMatch(item).found;

    // Returns whether `item` is selected and, if so, the stored TItem
    // instance to mutate when toggling. Bool-flagged because TItem is
    // unconstrained — a `TItem?` sentinel would be non-null for value-type
    // rows (e.g. `int`) and every unselected row would falsely report
    // selected. Ref-match wins; key-match is only consulted when
    // SelectionKeySelector is set AND the item's key is non-null
    // (preserves the documented null-key → reference-equality fallback).
    private (bool found, TItem stored) FindSelectionMatch(TItem item)
    {
        if (_selectedSet.Contains(item)) return (true, item);

        if (SelectionKeySelector is null || _selectedItems.Count == 0)
            return (false, item);

        var key = SelectionKeySelector(item);
        if (key is null) return (false, item);

        foreach (var sel in _selectedItems)
        {
            var k = SelectionKeySelector(sel);
            if (k is not null && key.Equals(k)) return (true, sel);
        }
        return (false, item);
    }

    private bool IsRowExpanded(TItem item) => _expandedRows.Contains(item);

    private bool IsRowEditing(TItem item) => _editingRows.Contains(item);

    // Rebuilds a reference-keyed row-state set against fresh item instances.
    // Each stored item is re-resolved by its SelectionKeySelector key to the
    // current instance carrying that key; keyless entries are preserved as-is
    // (matching the null-key reference fallback used for selection), and
    // entries whose key has vanished from the data source are dropped. Called
    // only when SelectionKeySelector is non-null.
    private void RemapRowStateByKey(HashSet<TItem> set, Dictionary<object, TItem> keyToCurrent)
    {
        if (set.Count == 0) return;
        var rebuilt = new HashSet<TItem>();
        foreach (var oldItem in set)
        {
            var k = SelectionKeySelector!(oldItem);
            if (k is null) rebuilt.Add(oldItem);
            else if (keyToCurrent.TryGetValue(k, out var current)) rebuilt.Add(current);
            // key gone -> drop (logical row removed from the data source)
        }
        set.Clear();
        foreach (var it in rebuilt) set.Add(it);
    }

    private void ToggleSelection(TItem item)
    {
        // Capture both ref-membership and key-membership BEFORE mutating, so a
        // fresh server-mode wrapper (different ref, same key) is correctly
        // recognised as already-selected and deselects instead of doubling.
        var (wasSelected, stored) = FindSelectionMatch(item);

        if (SelectionMode == DataGridSelectionMode.Single)
        {
            _selectedSet.Clear();
            _selectedItems.Clear();

            if (!wasSelected)
            {
                _selectedSet.Add(item);
                _selectedItems.Add(item);
            }
        }
        else if (SelectionMode == DataGridSelectionMode.Multiple)
        {
            if (wasSelected)
            {
                // Use the stored instance (ref-match wins; otherwise the
                // key-matched stale wrapper) so we don't strand a duplicate.
                _selectedSet.Remove(stored);
                _selectedItems.Remove(stored);
            }
            else
            {
                _selectedSet.Add(item);
                _selectedItems.Add(item);
            }
        }

        NotifySelectionChanged();
        StateHasChanged();
    }

    private void SelectAll()
    {
        // With SelectionKeySelector + server mode, SelectAll must MERGE the
        // current page into _selectedItems instead of replacing — otherwise
        // tapping the header checkbox on page 2 silently drops every
        // selection made on page 1. Without a key selector the previous
        // page-replace behaviour is correct (single in-memory list).
        if (SelectionKeySelector is not null)
        {
            foreach (var item in _displayedItems)
            {
                if (!IsRowSelected(item))
                {
                    _selectedItems.Add(item);
                    _selectedSet.Add(item);
                }
            }
        }
        else
        {
            _selectedItems = _displayedItems.ToList();
            _selectedSet = new HashSet<TItem>(_selectedItems);
        }
        NotifySelectionChanged();
        StateHasChanged();
    }

    private void ClearSelection()
    {
        // Symmetric to SelectAll above: under SelectionKeySelector the
        // header checkbox represents the current page only, so clearing
        // must remove just the visible rows (not every other page's
        // selections).
        if (SelectionKeySelector is not null)
        {
            foreach (var item in _displayedItems)
            {
                var (found, stored) = FindSelectionMatch(item);
                if (found)
                {
                    _selectedItems.Remove(stored);
                    _selectedSet.Remove(stored);
                }
            }
        }
        else
        {
            _selectedItems.Clear();
            _selectedSet.Clear();
        }
        NotifySelectionChanged();
        StateHasChanged();
    }

    /// <summary>
    /// Invokes the <see cref="SelectedItemsChanged"/> EventCallback safely from sync
    /// call sites. The previous implementation discarded the returned Task; a faulting
    /// async consumer handler would surface as an UnobservedTaskException AND the parent
    /// re-render after <c>StateHasChanged</c> could race a still-running consumer
    /// callback. <see cref="Lumeo.Services.SafeAsyncDispatcher.FireAndForget"/> dispatches
    /// the InvokeAsync via the component's renderer, swallows lifecycle-class
    /// exceptions silently, and logs anything unexpected with a structured tag.
    /// </summary>
    private void NotifySelectionChanged()
    {
        if (!SelectedItemsChanged.HasDelegate) return;
        var snapshot = _selectedItems.AsReadOnly();
        Lumeo.Services.SafeAsyncDispatcher.FireAndForget(
            InvokeAsync,
            () => SelectedItemsChanged.InvokeAsync(snapshot),
            "DataGrid.SelectionChanged");
    }

    private void ToggleGroupExpand(string key)
    {
        if (_expandedGroups.Contains(key))
            _expandedGroups.Remove(key);
        else
            _expandedGroups.Add(key);
        // See ToggleGroupPath — ServerMode must regroup the server-delivered
        // rows; ProcessClientData is a no-op without client Items.
        if (ServerMode) RegroupServerItems();
        else ProcessClientData();
        StateHasChanged();
    }

    private bool IsGroupExpanded(string key) => _expandedGroups.Contains(key);

    private void ToggleRowExpand(TItem item)
    {
        if (_expandedRows.Contains(item))
            _expandedRows.Remove(item);
        else
            _expandedRows.Add(item);
        StateHasChanged();
    }

    // --- Row Editing ---

    private void StartRowEdit(TItem item)
    {
        if (_editingRows.Contains(item)) return;
        _editingRows.Add(item);
        // Snapshot current values for all editable columns
        var editDict = new Dictionary<string, object?>();
        foreach (var col in EffectiveColumns.Where(c => c.Field is not null))
        {
            editDict[col.Field!] = col.GetValue(item);
        }
        _rowEditValues[item] = editDict;
        StateHasChanged();
    }

    private void CancelRowEdit(TItem item)
    {
        _editingRows.Remove(item);
        _rowEditValues.Remove(item);
        StateHasChanged();
    }

    private async Task CommitRowEditAsync(TItem item)
    {
        if (!_editingRows.Contains(item)) return;
        _editingRows.Remove(item);

        if (_rowEditValues.TryGetValue(item, out var editDict))
        {
            _rowEditValues.Remove(item);
            if (OnRowEdit.HasDelegate)
            {
                await OnRowEdit.InvokeAsync(new RowEditEventArgs<TItem>(item, editDict));
            }
        }
        StateHasChanged();
    }

    private object? GetEditValue(TItem item, DataGridColumn<TItem> column)
    {
        if (column.Field is null) return null;
        if (_rowEditValues.TryGetValue(item, out var dict) && dict.TryGetValue(column.Field, out var val))
            return val;
        return column.GetValue(item);
    }

    private void SetEditValue(TItem item, DataGridColumn<TItem> column, object? value)
    {
        if (column.Field is null) return;
        if (!_rowEditValues.ContainsKey(item))
            _rowEditValues[item] = new Dictionary<string, object?>();
        _rowEditValues[item][column.Field] = value;
    }

    // --- Batch-edit buffer ---

    /// <summary>True when (item, field) currently has a buffered value.</summary>
    private bool IsCellDirty(TItem item, string field) =>
        item is not null
        && _batchChanges.TryGetValue(item, out var dict)
        && dict.ContainsKey(field);

    /// <summary>Returns the buffered batch value for (item, column) if any,
    /// else the row's current value. Used by cells in batch mode.</summary>
    private object? GetBatchValue(TItem item, DataGridColumn<TItem> column)
    {
        if (column.Field is not null
            && item is not null
            && _batchChanges.TryGetValue(item, out var dict)
            && dict.TryGetValue(column.Field, out var v))
        {
            return v;
        }
        return column.GetValue(item);
    }

    /// <summary>Writes a buffered value into the pending-changes buffer. No
    /// row mutation and no immediate OnCellEdit/OnRowEdit; the value lives
    /// until "Save all" or "Discard".</summary>
    internal void SetBatchValue(TItem item, DataGridColumn<TItem> column, object? value)
    {
        if (item is null || column.Field is null) return;
        if (!_batchChanges.TryGetValue(item, out var dict))
        {
            dict = new Dictionary<string, object?>();
            _batchChanges[item] = dict;
        }
        dict[column.Field] = value;
        StateHasChanged();
    }

    /// <summary>Fires <see cref="OnBatchSave"/> with the buffered changes.
    /// On a clean return the buffer is cleared.</summary>
    private async Task SaveBatchAsync()
    {
        if (!HasPendingChanges) return;

        var addedSet = new HashSet<TItem>(_batchAdded);
        var modified = new List<DataGridBatchChange<TItem>>();
        var added = new List<DataGridBatchChange<TItem>>();
        foreach (var (item, fields) in _batchChanges)
        {
            var copy = new Dictionary<string, object?>(fields);
            var change = new DataGridBatchChange<TItem>(item, copy, addedSet.Contains(item));
            (addedSet.Contains(item) ? added : modified).Add(change);
        }
        // Surface added rows that have no buffered field edits yet.
        foreach (var item in _batchAdded)
        {
            if (!_batchChanges.ContainsKey(item))
            {
                added.Add(new DataGridBatchChange<TItem>(item, new Dictionary<string, object?>(), true));
            }
        }

        var args = new DataGridBatchSaveEventArgs<TItem>(modified, added);
        if (OnBatchSave.HasDelegate)
        {
            await OnBatchSave.InvokeAsync(args);
        }
        // Consumer exceptions propagate to Blazor's error boundary; we don't
        // swallow them — but on clean return we clear the buffer.
        _batchChanges.Clear();
        _batchAdded.Clear();
        StateHasChanged();
    }

    /// <summary>Drops all buffered edits and any unsaved added rows.</summary>
    private void DiscardBatch()
    {
        if (!HasPendingChanges) return;
        _batchChanges.Clear();
        _batchAdded.Clear();
        StateHasChanged();
    }

    /// <summary>Append a new row via <see cref="NewItemFactory"/>. The row
    /// lives in the batch buffer until the consumer wires it up via
    /// <see cref="OnBatchSave"/>.</summary>
    private void AddBatchRow()
    {
        if (NewItemFactory is null) return;
        var item = NewItemFactory();
        if (item is null) return;
        _batchAdded.Add(item);
        // Seed an empty pending-changes dict so HasPendingChanges flips true
        // even before the user types anything.
        if (!_batchChanges.ContainsKey(item))
        {
            _batchChanges[item] = new Dictionary<string, object?>();
        }

        // Navigate to the last page so the newly-added row is visible.
        // ProcessClientData computes total pages from _processedItems; we
        // jump there first, then let ProcessClientData append the batch row
        // to _displayedItems at the end of that page.
        if (ShowPagination && PageSize > 0 && _processedItems.Count > 0)
        {
            _currentPage = Math.Max(1, (int)Math.Ceiling((double)_processedItems.Count / PageSize));
        }

        // ProcessClientData must be called (not just StateHasChanged) so
        // _displayedItems is rebuilt to include the new _batchAdded entry.
        // Without this the row doesn't appear until the next parameter change.
        ProcessClientData();
        StateHasChanged();
    }

    /// <summary>Test-only hook for inspecting a row's dirty-field set.</summary>
    internal IReadOnlyDictionary<string, object?>? GetBatchChanges(TItem item) =>
        item is not null && _batchChanges.TryGetValue(item, out var d) ? d : null;

    // --- Column Reordering ---

    private async Task HandleColumnReorder(ColumnReorderEventArgs args)
    {
        if (args.OldIndex < 0 || args.NewIndex < 0 || args.OldIndex >= _orderedColumns.Count || args.NewIndex >= _orderedColumns.Count)
            return;

        // FLIP "First": snapshot each header's viewport rect BEFORE we
        // mutate the column order. Reordering is followed by a Blazor
        // re-render that snaps columns to their new positions; the
        // matching AnimateColumnReorder call in OnAfterRenderAsync reads
        // the new positions, computes deltas, and slides each column
        // (header + its body cells, captured by index at snapshot time)
        // from its old visual position to its new one.
        try { await Interop.CaptureColumnRects(_gridId); }
        catch (JSDisconnectedException) { }
        catch (Exception captureEx)
        {
            // Non-disconnect failures (DOM gone, malformed rects) shouldn't
            // abort the column-order mutation that follows — the FLIP
            // animation is a visual nice-to-have. Surface to OnError and
            // continue so the data reorder still applies (Codex review #48).
            if (OnError.HasDelegate) await OnError.InvokeAsync(captureEx);
        }

        var col = _orderedColumns[args.OldIndex];
        // A locked (Reorderable=false) column is un-displaceable — mirror the
        // pointer-drag JS preview, which never proposes one as a drop target
        // and never shifts one aside when the dragged column skips over it
        // (see registerColumnReorder's applyProjection/computeTargetIdx in
        // components.js). A plain RemoveAt(OldIndex)+Insert(NewIndex) over the
        // FULL array breaks that invariant: any locked column sitting between
        // the source and target gets shifted to a new absolute index even
        // though it never visually moved. Reorder only within the reorderable
        // subsequence instead, keeping every locked column pinned at its
        // original absolute index (Codex round-3 #1).
        if (!col.Reorderable)
        {
            // A locked column can't be the one that moves at all.
            return;
        }
        // Cross-pin-partition moves are rejected up front — mirrors the
        // pointer-drag commit path's own guard (ReorderColumnByIdAsync:
        // `srcCol.Pin != tgtCol.Pin`). That path always proposes a
        // same-partition target (its JS preview never crosses a partition
        // boundary — see registerColumnReorder's computeTargetIdx/
        // applyProjection in components.js), but the columns panel's
        // SortableList (DataGridColumnVisibility) is a single flat list
        // spanning EVERY pin group with no drag restriction, so
        // args.NewIndex can legitimately land in a different partition than
        // args.OldIndex. Without this guard, `reordered` below is computed
        // against the PRE-repartition array — where crossing a pin boundary
        // still looks like a genuine move — and RefreshVisibleColumns's
        // partition-preserving stable sort (see its own remarks) then
        // silently restores every column to its own pin group, so the side
        // effects below (event, autosave, FLIP animation) would fire for a
        // move that never actually landed anywhere (round-6 finding).
        var targetIndex = Math.Clamp(args.NewIndex, 0, _orderedColumns.Count - 1);
        if (col.Pin != _orderedColumns[targetIndex].Pin)
        {
            return;
        }
        // A drop that resolves to a no-op order (e.g. the columns panel proposes
        // a slot past a locked edge column, which ReorderColumnsPreservingLocked
        // then redirects/clamps back to nothing) must not report a reorder to
        // consumers — the pointer-drag JS path never proposes such a target, but
        // the columns panel (index-based) does, and both funnel through here, so
        // guarding here covers the pointer commit path too (Codex round-5 #2).
        var reordered = ReorderColumnsPreservingLocked(args.OldIndex, args.NewIndex);
        if (!reordered) return;
        RefreshVisibleColumns();
        _pendingReorderAnimation = true;

        // Await consumer handler so async handlers complete before we re-render.
        // Previously the returned Task was discarded which let the next
        // StateHasChanged race a still-running consumer callback and let
        // exceptions in async handlers go unobserved.
        if (OnColumnReorder.HasDelegate)
            await OnColumnReorder.InvokeAsync(args);

        ScheduleAutoSave();
        StateHasChanged();
    }

    /// <summary>
    /// Moves the reorderable column at <paramref name="oldIndex"/> to the reorderable
    /// slot identified by <paramref name="newIndex"/>, WITHOUT ever changing the
    /// absolute index of any Reorderable=false column.
    ///
    /// Two-pass approach: first compute the plain RemoveAt(oldIndex)+Insert(newIndex)
    /// result over the FULL array — this is exactly what the (buggy) single-pass code
    /// used to commit directly, and it gets the RELATIVE order of the reorderable
    /// columns exactly right (that's the part the original formula was already
    /// correct about; "insert before" vs "insert after" falls out of using the raw,
    /// pre-removal NewIndex as the post-removal insert index, same as before). Locked
    /// columns can end up misplaced in that intermediate result, though, so the
    /// second pass splices them back into their ORIGINAL absolute slots and re-flows
    /// the intermediate result's reorderable columns (in the relative order that
    /// first pass produced) into the remaining slots.
    /// </summary>
    /// <returns>
    /// <see langword="true"/> if the resulting order actually differs from the
    /// order before the call; <see langword="false"/> for a no-op — either the
    /// skip-over redirect found nothing reorderable in that direction, or the
    /// resolved target settles every reorderable column back into its original
    /// slot (e.g. a drop past a locked edge column with no room beyond it). The
    /// caller (<see cref="HandleColumnReorder"/>) must skip its side effects
    /// (event, autosave, FLIP animation, rerender) when this returns false
    /// (Codex round-5 #2).
    /// </returns>
    private bool ReorderColumnsPreservingLocked(int oldIndex, int newIndex)
    {
        // Resolve the effective absolute target: if it lands exactly on a locked
        // column's slot (a caller other than the pointer-drag path, which never
        // proposes one, might still pass one), redirect to the nearest reorderable
        // neighbor in the drag direction — the same "skip over" rule the JS preview
        // applies before it ever proposes a target.
        var target = Math.Clamp(newIndex, 0, _orderedColumns.Count - 1);
        if (!_orderedColumns[target].Reorderable)
        {
            var dir = target >= oldIndex ? 1 : -1;
            while (target >= 0 && target < _orderedColumns.Count && !_orderedColumns[target].Reorderable)
                target += dir;
            if (target < 0 || target >= _orderedColumns.Count) return false; // nothing reorderable in that direction — no-op
        }

        // Pass 1: the plain (locked-unaware) result, exactly like the original code.
        var naive = new List<DataGridColumn<TItem>>(_orderedColumns);
        var movingCol = naive[oldIndex];
        naive.RemoveAt(oldIndex);
        naive.Insert(Math.Min(target, naive.Count), movingCol);

        // Pass 2: splice locked columns back into their original absolute slots;
        // everything else drains from `naive`, in the relative order pass 1 gave it.
        var reorderableInOrder = naive.Where(c => c.Reorderable).ToList();
        var changed = false;
        var next = 0;
        for (var i = 0; i < _orderedColumns.Count; i++)
        {
            if (!_orderedColumns[i].Reorderable) continue; // locked columns already sit at their own index — leave in place
            var replacement = reorderableInOrder[next++];
            if (!ReferenceEquals(_orderedColumns[i], replacement)) changed = true;
            _orderedColumns[i] = replacement;
        }
        return changed;
    }

    /// <summary>
    /// Reorders a column by id, moving <paramref name="sourceId"/> to the slot of
    /// <paramref name="targetId"/>. Drives the unified pointer-based reorder path
    /// (mouse + touch + pen) registered via <c>RegisterColumnReorder</c>: JS handles
    /// the whole drag in the DOM — including the live sibling-shift preview — and
    /// invokes this once on release. Operates on <c>_orderedColumns</c> by id (robust
    /// to hidden columns) and routes through <see cref="HandleColumnReorder"/> so it
    /// shares the exact FLIP animation, persistence, and OnColumnReorder callback.
    /// Cross-pin-partition and per-column non-reorderable drops are rejected.
    /// </summary>
    internal async Task ReorderColumnByIdAsync(string sourceId, string targetId)
    {
        if (!Reorderable || sourceId == targetId) return;
        var src = _orderedColumns.FindIndex(c => c.Id == sourceId);
        var tgt = _orderedColumns.FindIndex(c => c.Id == targetId);
        if (src < 0 || tgt < 0) return;
        var srcCol = _orderedColumns[src];
        var tgtCol = _orderedColumns[tgt];
        if (!srcCol.Reorderable) return;
        if (!tgtCol.Reorderable) return; // a locked column is un-displaceable: refuse drops onto its slot
        if (srcCol.Pin != tgtCol.Pin) return; // same-partition only
        await HandleColumnReorder(new ColumnReorderEventArgs(sourceId, src, tgt));
    }

    // --- Row Reordering ---

    public void MoveRow(int oldIndex, int newIndex)
    {
        if (oldIndex < 0 || newIndex < 0 || oldIndex >= _displayedItems.Count || newIndex >= _displayedItems.Count)
            return;

        var item = _displayedItems[oldIndex];
        _displayedItems.RemoveAt(oldIndex);
        _displayedItems.Insert(newIndex, item);

        // Public sync API — can't change return type without breaking consumers.
        // Dispatch the consumer callback through SafeAsyncDispatcher so faults
        // in async handlers are observed (logged) instead of becoming
        // UnobservedTaskExceptions, and so a faulting outer InvokeAsync (e.g.
        // disposed renderer) is also handled.
        if (OnRowReorder.HasDelegate)
        {
            var args = new RowReorderEventArgs<TItem>(item, oldIndex, newIndex);
            Lumeo.Services.SafeAsyncDispatcher.FireAndForget(
                InvokeAsync,
                () => OnRowReorder.InvokeAsync(args),
                "DataGrid.RowReorder");
        }

        StateHasChanged();
    }

    /// <summary>
    /// Reorders a row by stable identity, moving the row keyed <paramref name="sourceRowKey"/>
    /// to the slot of the row keyed <paramref name="targetRowKey"/>. Drives the unified
    /// pointer-based row-reorder path (mouse + touch + pen) registered via
    /// <c>RegisterRowReorder</c>: JS handles the whole drag in the DOM — including the
    /// live sibling-shift preview — and invokes this once on release with the row keys
    /// (<see cref="DataGridRowKeys"/>, the same identity backing Blazor's own <c>@key</c>
    /// and the FLIP capture) it read at drag END. Resolving indices fresh, by key, HERE
    /// — rather than trusting DOM indices captured at drag START — matters because the
    /// commit fires after a 180ms settle animation; if <c>Items</c>/<c>_displayedItems</c>
    /// changed underneath that window (server refresh, filter, sort triggered by the
    /// app), stale indices would move whatever rows currently occupy those slots instead
    /// of the ones the user actually dragged (Codex round-5 #6) — mirrors
    /// <see cref="ReorderColumnByIdAsync"/> resolving column ids fresh at call time.
    /// Captures FLIP "First" rects before mutating so the settled drag position and the
    /// post-render position can be diffed into one slide, then delegates the actual
    /// mutation + OnRowReorder callback to <see cref="MoveRow"/>.
    /// </summary>
    internal async Task ReorderRowByKeyAsync(string sourceRowKey, string targetRowKey)
    {
        if (!RowReorderPointerActive) return;
        if (string.IsNullOrEmpty(sourceRowKey) || string.IsNullOrEmpty(targetRowKey)) return;
        if (sourceRowKey == targetRowKey) return;

        // Mirrors the DOM key DataGridRow.RowKey stamped at drag start/read at
        // drag end (see DataGridRowKeys.DomKeyFor's contract) — reference-type
        // rows resolve by their live per-instance identity hash (survives
        // index drift below); value-type rows resolve positionally, which is
        // exactly why the "stale index" guard immediately below still matters
        // for them specifically.
        var oldIndex = DataGridRowKeys.ResolveDomKeyIndex(_displayedItems, sourceRowKey);
        var newIndex = DataGridRowKeys.ResolveDomKeyIndex(_displayedItems, targetRowKey);
        // Either key may no longer resolve — the row it identified was removed
        // from _displayedItems by a mutation that landed during the drag's
        // post-drop settle window. Silently drop the stale commit rather than
        // reorder whatever rows happen to occupy the old positions now.
        if (oldIndex < 0 || newIndex < 0 || oldIndex == newIndex) return;

        try { await Interop.CaptureRowRects(_gridId); }
        catch (JSDisconnectedException) { }
        catch (Exception captureEx)
        {
            // Same rationale as ReorderColumnByIdAsync's capture: a failed FLIP
            // snapshot must never block the actual row-order mutation.
            if (OnError.HasDelegate) await OnError.InvokeAsync(captureEx);
        }

        // Set BEFORE MoveRow, not after: MoveRow ends with StateHasChanged(), and a
        // synchronous-rendering host (bUnit's TestRenderer notably) can run the next
        // OnAfterRenderAsync inline from inside that call — if the flag flipped only
        // afterward, that render would see it still false and skip the animation with
        // nothing left to pick it up later (mirrors HandleColumnReorder's ordering).
        _pendingRowReorderAnimation = true;
        MoveRow(oldIndex, newIndex);
    }

    // --- Context Menu ---

    private void HandleContextMenu(TItem item, double x, double y)
    {
        if (RowContextMenu is null) return;
        _contextMenuItem = item;
        _contextMenuX = x;
        _contextMenuY = y;
        _contextMenuVisible = true;
        StateHasChanged();
    }

    private void CloseContextMenu()
    {
        if (_contextMenuVisible)
        {
            _contextMenuVisible = false;
            StateHasChanged();
        }
    }

    private async Task HandleColumnVisibilityChanged(DataGridColumn<TItem> column)
    {
        RefreshVisibleColumns();
        if (!ServerMode) ProcessClientData();
        ScheduleAutoSave();
        // Propagate the user toggle back to a consumer's @bind-Visible (no-op when
        // the column def isn't bound). The column-chooser already flipped
        // column.Visible, so we just surface the new value.
        if (column.VisibleChanged.HasDelegate)
            await column.VisibleChanged.InvokeAsync(column.Visible);
        StateHasChanged();
    }

    /// <summary>
    /// Applies a consumer-driven (<c>@bind-Visible</c>) visibility change from a
    /// <see cref="DataGridColumnDef{TItem}"/> to the live column identified by
    /// <paramref name="columnKey"/> (Field when set, else the column Id). Refreshes
    /// the visible-columns cache and reprocesses client data, but deliberately does
    /// NOT raise <see cref="DataGridColumn{TItem}.VisibleChanged"/> — the consumer is
    /// already the source of this change, so echoing it back would loop.
    /// </summary>
    public void SetColumnVisibility(string columnKey, bool visible)
    {
        var column = _columnDefs.FirstOrDefault(c => ColumnKey(c) == columnKey);
        if (column is null || column.Visible == visible) return;
        column.Visible = visible;
        RefreshVisibleColumns();
        if (!ServerMode) ProcessClientData();
        ScheduleAutoSave();
        StateHasChanged();
    }

    // End-user "pin column" action surfaced from the column chooser. Pin state
    // is purely visual layout (no data reprocessing required); we still refresh
    // the visible-columns cache so the header re-orders left/right pinned
    // columns on the next render, and trigger an autosave so layouts persist.
    private void HandleColumnPin(ColumnPinEventArgs args) => ApplyColumnPin(args.ColumnId, args.Direction);

    /// <summary>
    /// Applies a pin change to a column and re-lays out the grid. Shared by the
    /// column-chooser pin submenu (<see cref="HandleColumnPin"/>) and the header
    /// cell's inline pin control so both raise the exact same state transition.
    /// <see cref="RefreshVisibleColumns"/> re-partitions the columns so a
    /// right-pin physically moves to the right edge (sticky can't relocate a cell
    /// across siblings) and an unpin drops the column back into normal flow.
    /// </summary>
    /// <param name="columnId">The <see cref="DataGridColumn{TItem}.Id"/> to pin.</param>
    /// <param name="direction">Left, Right, or None (unpin).</param>
    internal void ApplyColumnPin(string columnId, PinDirection direction)
    {
        var column = EffectiveColumns.FirstOrDefault(c => c.Id == columnId);
        if (column is null || !column.Pinnable) return;

        column.Pin = direction;
        RefreshVisibleColumns();
        ScheduleAutoSave();
        StateHasChanged();
    }

    private void HandleFilterToggle(string? field)
    {
        _activeFilterColumn = _activeFilterColumn == field ? null : field;
        StateHasChanged();
    }

    private async Task HandleFilterApply(FilterApplyEventArgs args)
    {
        if (args.Filter is not null)
        {
            await HandleFilter(args.Filter);
        }
        else if (args.Field is not null)
        {
            var existing = _filters.FirstOrDefault(f => f.Field == args.Field);
            if (existing is not null)
            {
                await RemoveFilter(existing);
            }
        }

        _activeFilterColumn = null;
        StateHasChanged();
    }

    private async Task HandleExport(string format)
    {
        var items = ServerMode ? _displayedItems : _processedItems;
        var culture = EffectiveCulture;
        var visibleColumns = EffectiveColumns.Where(c => c.Visible).ToList();
        var exportColumns = visibleColumns.Select(c => new Lumeo.Services.DataGridExportColumn<TItem>(
            Header: c.Title ?? c.Field ?? c.Id,
            Accessor: row => c.GetValue(row),
            Format: c.Format
        )).ToList();

        try
        {
            switch (format)
            {
                case "json":
                    // JSON uses the formatted (culture-aware) string representation per column
                    // so consumers get a row shape that mirrors the visible grid.
                    {
                        var rows = items.Select(item =>
                        {
                            var dict = new Dictionary<string, string?>();
                            foreach (var col in visibleColumns)
                            {
                                var key = col.Title ?? col.Field ?? col.Id;
                                dict[key] = col.GetFormattedValue(item, culture);
                            }
                            return dict;
                        }).ToList();
                        var json = System.Text.Json.JsonSerializer.Serialize(rows, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
                        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
                        await Export.DownloadAsync(bytes, "export.json", "application/json");
                        break;
                    }
                case "excel":
                    {
                        await Lumeo.Services.DataGridExportLoader.EnsureExcelAssembliesAsync();
                        var bytes = Export.ToExcel(items, exportColumns, sheetName: "Data", culture: culture);
                        await Export.DownloadAsync(bytes, "export.xlsx",
                            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet");
                        break;
                    }
                case "pdf":
                    {
                        // QuestPDF isn't supported on browser-wasm — ToPdf throws PlatformNotSupportedException
                        // on that runtime. Consumers should restrict ExportFormats to exclude Pdf on WASM.
                        await Lumeo.Services.DataGridExportLoader.EnsurePdfAssembliesAsync();
                        var bytes = Export.ToPdf(items, exportColumns, title: FullscreenTitle ?? "Export", culture: culture);
                        await Export.DownloadAsync(bytes, "export.pdf", "application/pdf");
                        break;
                    }
                default:
                    {
                        var bytes = Export.ToCsv(items, exportColumns, culture: culture);
                        await Export.DownloadAsync(bytes, "export.csv", "text/csv; charset=utf-8");
                        break;
                    }
            }
        }
        catch (Exception ex) when (OnError.HasDelegate)
        {
            await OnError.InvokeAsync(ex);
        }
    }

    // --- Layout Persistence ---

    public DataGridLayout GetCurrentLayout() => SnapshotCurrentLayout();

    private DataGridLayout SnapshotCurrentLayout()
    {
        var cols = _orderedColumns.Select((c, i) => new ColumnLayout
        {
            Field = c.Field ?? c.Id,
            Width = c.Width,
            Visible = c.Visible,
            Pin = c.Pin,
            Order = i
        }).ToList();

        return new DataGridLayout
        {
            Columns = cols,
            Sorts = _sorts.Count > 0 ? new List<SortDescriptor>(_sorts) : null,
            Filters = _filters.Count > 0 ? new List<FilterDescriptor>(_filters) : null,
            PageSize = PageSize,
            GlobalSearch = _globalSearch,
            GroupByFields = _runtimeGroupFields.Count > 0
                ? new List<string>(_runtimeGroupFields)
                : null
        };
    }

    public async Task ApplyLayoutAsync(DataGridLayout layout)
    {
        // Restore column order, width, visibility, pin
        if (layout.Columns.Count > 0)
        {
            // Build a lookup from field → column object
            var colByField = EffectiveColumns.ToDictionary(c => c.Field ?? c.Id);

            var ordered = layout.Columns
                .OrderBy(cl => cl.Order)
                .Select(cl =>
                {
                    if (!colByField.TryGetValue(cl.Field, out var col)) return null;
                    col.Visible = cl.Visible;
                    col.Pin = cl.Pin;
                    if (cl.Width.HasValue) col.Width = cl.Width;
                    return col;
                })
                .Where(c => c is not null)
                .Select(c => c!)
                .ToList();

            // Append any columns not included in layout (new columns added since last save)
            var layoutFields = layout.Columns.Select(cl => cl.Field).ToHashSet();
            var missing = EffectiveColumns.Where(c => !layoutFields.Contains(c.Field ?? c.Id));
            ordered.AddRange(missing);

            _orderedColumns = ordered;
            RefreshVisibleColumns();
        }

        // Restore sorts
        _sorts = layout.Sorts is not null ? new List<SortDescriptor>(layout.Sorts) : new List<SortDescriptor>();

        // Restore filters. Values that came through JSON (persisted layout,
        // SavedLayout parameter, named layouts) arrive as JsonElement —
        // normalize them to CLR primitives here so both the client filter
        // pipeline and ServerMode consumers (who receive these descriptors in
        // OnServerDataRequest) get comparable values.
        _filters = layout.Filters is not null
            ? layout.Filters
                .Select(f => f with
                {
                    Value = DataGridFilterOperator.Normalize(f.Value),
                    ValueTo = DataGridFilterOperator.Normalize(f.ValueTo)
                })
                .ToList()
            : new List<FilterDescriptor>();

        // Restore page size
        if (layout.PageSize.HasValue)
            PageSize = layout.PageSize.Value;

        // Restore global search
        _globalSearch = layout.GlobalSearch;

        // Restore group-panel runtime fields (chip-strip). Only consider fields
        // that exist as a Groupable column on the current grid — silently drop
        // any that no longer match so a stale snapshot doesn't crash the grid.
        if (layout.GroupByFields is { Count: > 0 })
        {
            _runtimeGroupFields = layout.GroupByFields
                .Where(f => EffectiveColumns.Any(c => c.Field == f))
                .Distinct()
                .ToList();

            // Seed the un-group restore snapshot for restored chips. The
            // snapshot taken when a column is grouped LIVE isn't part of the
            // persisted layout, so after a restore _groupedColPrevState was
            // empty and removing a chip left its auto-hidden column hidden
            // forever. Restoring to visible/unpinned is the sane default —
            // post-restore we can't distinguish "auto-hidden by grouping"
            // from "user-hidden", and a removed chip is expected to bring
            // its column back.
            foreach (var f in _runtimeGroupFields)
            {
                if (!_groupedColPrevState.ContainsKey(f))
                    _groupedColPrevState[f] = (PinDirection.None, true);
            }
        }
        else
        {
            _runtimeGroupFields = new List<string>();
        }
        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _lastGroupBy = null;

        _currentPage = 1;

        if (ServerMode)
            await RequestServerData();
        else
            ProcessClientData();

        StateHasChanged();
    }

    public async Task ResetLayoutAsync()
    {
        if (_defaultLayout is not null)
        {
            await ApplyLayoutAsync(_defaultLayout);
        }
        else
        {
            // No snapshot — restore ordering from effective columns
            _orderedColumns = new List<DataGridColumn<TItem>>(EffectiveColumns);
            foreach (var col in _orderedColumns)
            {
                col.Visible = true;
                col.Pin = PinDirection.None;
                col.Width = null;
            }
            _sorts.Clear();
            _filters.Clear();
            _globalSearch = null;
            PageSize = 10;
            _currentPage = 1;
            ProcessClientData();
            StateHasChanged();
        }

        if (EnableLayoutPersistence)
        {
            var key = LayoutStorageKey ?? _layoutId;
            await _layoutService!.ClearPersistedAsync(key);
        }
    }

    private void ScheduleAutoSave()
    {
        if (!EnableLayoutPersistence && !OnLayoutSave.HasDelegate) return;
        var gen = _layoutService!.CurrentSaveGeneration;
        _layoutService.ScheduleAutoSave(async () =>
        {
            await InvokeAsync(() => PersistLayoutAsync(gen + 1));
        });
    }

    private async Task PersistLayoutAsync(int? generation = null)
    {
        // Generation guard — gates BOTH the LocalStorage write AND the consumer callback.
        // Without this, a stale debounced timer could deliver an outdated layout snapshot to
        // OnLayoutSave even when the in-service guard correctly suppressed the LocalStorage write.
        if (generation.HasValue && _layoutService is not null && generation.Value != _layoutService.CurrentSaveGeneration)
            return;

        var layout = SnapshotCurrentLayout();

        if (EnableLayoutPersistence)
        {
            var key = LayoutStorageKey ?? _layoutId;
            await _layoutService!.PersistAsync(key, layout, generation);
        }

        if (OnLayoutSave.HasDelegate)
        {
            // Generation guard above ensures we don't deliver stale snapshots to the consumer's backend.
            await OnLayoutSave.InvokeAsync(layout);
        }
    }

    // --- Toolbar layout actions ---

    private async Task HandleSaveLayout()
    {
        await PersistLayoutAsync();
    }

    private async Task HandleResetLayout()
    {
        await ResetLayoutAsync();
    }

    // --- Named Layout Handlers ---

    private async Task HandleSaveNamedLayout(DataGridNamedLayout namedLayout)
    {
        var layout = SnapshotCurrentLayout();
        var withLayout = namedLayout with { Layout = layout };

        if (namedLayout.Scope == "Personal")
        {
            var namedKey = (LayoutStorageKey ?? _layoutId) + "-named";
            var existing = await _layoutService!.GetPersonalLayoutsAsync(namedKey);
            existing.Add(withLayout);
            await _layoutService.SaveNamedLayoutsAsync(namedKey, existing);
        }

        if (OnSaveNamedLayout.HasDelegate)
            await OnSaveNamedLayout.InvokeAsync(withLayout);

        StateHasChanged();
    }

    private async Task HandleApplyNamedLayout(DataGridNamedLayout namedLayout)
    {
        await ApplyLayoutAsync(namedLayout.Layout);
    }

    public async Task<List<DataGridNamedLayout>> GetPersonalLayoutsAsync()
    {
        var key = (LayoutStorageKey ?? _layoutId) + "-named";
        return await _layoutService!.GetPersonalLayoutsAsync(key);
    }

    // --- Public JSON Layout API -----------------------------------------------
    //
    // These methods let dev consumers persist the grid's layout to any backend
    // (database, file, REST API) by treating a JSON string as the canonical
    // transport format. Use via @ref:
    //
    //     <DataGrid @ref="grid" ...> ... </DataGrid>
    //     var json = grid.ExportLayout();
    //     await grid.ApplyLayoutJsonAsync(json);

    /// <summary>
    /// Snapshot schema version — bump when <see cref="DataGridLayoutSnapshot"/>
    /// changes in a breaking way.
    /// v2 (2.1.1): added <c>GroupByFields</c> for multi-level group-panel
    /// persistence. v1 payloads still load — the new field is nullable and
    /// the legacy single-level <c>GroupBy</c> is honoured as a fallback.
    /// </summary>
    private const int LayoutSnapshotVersion = 2;

    /// <summary>
    /// Cached, shared JsonSerializerOptions used for every ExportLayout / ApplyLayoutJsonAsync
    /// call. Reusing the instance avoids the documented perf pitfall of creating a fresh options
    /// object per call (which rebuilds type metadata every time).
    /// </summary>
    private static readonly System.Text.Json.JsonSerializerOptions _layoutJsonOptions =
        new(System.Text.Json.JsonSerializerDefaults.Web)
        {
            WriteIndented = false,
            DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
            Converters = { new System.Text.Json.Serialization.JsonStringEnumConverter() }
        };

    /// <summary>
    /// Serializes the current grid layout (column order, widths, visibility, pin state,
    /// sorts, filters, global search, current page, page size, group-by) to a JSON string.
    /// Dev consumers can persist this to any storage — DB, file, API. Round-trips via
    /// <see cref="ApplyLayoutJsonAsync"/>.
    /// </summary>
    public string ExportLayout()
    {
        var snapshot = BuildLayoutSnapshot();
        return System.Text.Json.JsonSerializer.Serialize(snapshot, _layoutJsonOptions);
    }

    /// <summary>
    /// Deserializes a JSON layout produced by <see cref="ExportLayout"/> and applies it.
    /// Throws <see cref="System.Text.Json.JsonException"/> on malformed input; silently
    /// ignores columns the JSON references that no longer exist on the grid.
    /// </summary>
    public async Task ApplyLayoutJsonAsync(string json)
    {
        if (string.IsNullOrWhiteSpace(json))
            throw new System.Text.Json.JsonException("Empty or null layout JSON");

        var snapshot = System.Text.Json.JsonSerializer.Deserialize<DataGridLayoutSnapshot>(json, _layoutJsonOptions)
                       ?? throw new System.Text.Json.JsonException("Deserialized layout snapshot was null");

        await ApplyLayoutSnapshotAsync(snapshot);
    }

    /// <summary>
    /// Builds a <see cref="DataGridLayoutSnapshot"/> from the grid's current state.
    /// </summary>
    internal DataGridLayoutSnapshot BuildLayoutSnapshot()
    {
        var cols = _orderedColumns.Select((c, i) => new DataGridColumnLayout(
            Field: c.Field ?? c.Id,
            Order: i,
            Visible: c.Visible,
            Width: c.Width,
            Pin: c.Pin
        )).ToList();

        return new DataGridLayoutSnapshot(
            Version: LayoutSnapshotVersion,
            Columns: cols,
            Sorts: new List<SortDescriptor>(_sorts),
            Filters: new List<FilterDescriptor>(_filters),
            GlobalSearch: _globalSearch,
            CurrentPage: _currentPage,
            PageSize: PageSize,
            // Preserve the static parameter for back-compat readers; new
            // consumers should rely on GroupByFields for multi-level state.
            GroupBy: _runtimeGroupFields.Count > 0 ? _runtimeGroupFields[0] : GroupBy,
            GroupByFields: _runtimeGroupFields.Count > 0
                ? new List<string>(_runtimeGroupFields)
                : null
        );
    }

    /// <summary>
    /// Applies a <see cref="DataGridLayoutSnapshot"/> to the grid. Columns referenced
    /// by Field that no longer exist are silently skipped; columns present on the grid
    /// but missing from the snapshot are appended at the end in their current order.
    /// </summary>
    internal async Task ApplyLayoutSnapshotAsync(DataGridLayoutSnapshot snapshot)
    {
        // Column state (order, visibility, width, pin)
        if (snapshot.Columns.Count > 0)
        {
            var colByKey = EffectiveColumns.ToDictionary(c => c.Field ?? c.Id);
            var ordered = snapshot.Columns
                .OrderBy(cl => cl.Order)
                .Select(cl =>
                {
                    if (!colByKey.TryGetValue(cl.Field, out var col)) return null;
                    col.Visible = cl.Visible;
                    if (cl.Pin.HasValue) col.Pin = cl.Pin.Value;
                    if (cl.Width.HasValue) col.Width = cl.Width;
                    return col;
                })
                .Where(c => c is not null)
                .Select(c => c!)
                .ToList();

            // Append columns on the grid that weren't referenced in the snapshot
            var snapshotKeys = snapshot.Columns.Select(cl => cl.Field).ToHashSet();
            foreach (var col in EffectiveColumns)
            {
                if (!snapshotKeys.Contains(col.Field ?? col.Id))
                    ordered.Add(col);
            }
            _orderedColumns = ordered;
        }

        _sorts = new List<SortDescriptor>(snapshot.Sorts);
        _filters = new List<FilterDescriptor>(snapshot.Filters);
        _globalSearch = snapshot.GlobalSearch;
        if (snapshot.PageSize > 0) PageSize = snapshot.PageSize;
        _currentPage = snapshot.CurrentPage > 0 ? snapshot.CurrentPage : 1;

        // Restore group-panel runtime fields. v2 payloads carry the full
        // ordered list in GroupByFields; v1 payloads only have GroupBy
        // (single level) — fall back to that for back-compat.
        var groupFields = snapshot.GroupByFields is { Count: > 0 }
            ? snapshot.GroupByFields
            : (!string.IsNullOrEmpty(snapshot.GroupBy)
                ? new List<string> { snapshot.GroupBy! }
                : new List<string>());
        _runtimeGroupFields = groupFields
            .Where(f => EffectiveColumns.Any(c => c.Field == f))
            .Distinct()
            .ToList();
        _expandedGroupPaths.Clear();
        _knownGroupPaths.Clear();
        _expandedGroups.Clear();
        _knownGroupKeys.Clear();
        _lastGroupBy = null;

        if (ServerMode)
            await RequestServerData();
        else
            ProcessClientData();

        StateHasChanged();
    }

    private async Task RequestServerData()
    {
        var previousError = _serverService!.Error;

        await _serverService!.RequestDataAsync(
            _currentPage, PageSize,
            _sorts.Count > 0 ? _sorts : null,
            _filters.Count > 0 ? _filters : null,
            // The static GroupBy parameter goes stale the moment a consumer changes grouping
            // at runtime (group panel add/remove, multi-level GroupByFields) — _runtimeGroupFields
            // is the actual current grouping. DataGridServerRequest only carries a single field,
            // so fall back to the first runtime field (mirrors BuildLayoutSnapshot's identical
            // back-compat expression below). Without this, a consumer's OnServerRequest handler
            // never learns what the user is actually grouping by and can't pre-sort/pre-group
            // server-side to cooperate with it.
            _globalSearch, _runtimeGroupFields.Count > 0 ? _runtimeGroupFields[0] : GroupBy,
            OnServerRequest, OnError, StateHasChanged);

        // When no OnError handler is wired and a new error occurred, show a default toast
        if (!OnError.HasDelegate && _serverService.Error is not null && _serverService.Error != previousError)
        {
            Toast.Error(L["DataGrid.ErrorLoadingData", ""], _serverService.Error);
        }
    }

    private IReadOnlyDictionary<string, double> ComputePinnedLeftOffsets()
    {
        var offsets = new Dictionary<string, double>();
        double offset = 0;
        if (RowReorderable) offset += 32;
        if (SelectionMode != DataGridSelectionMode.None) offset += 40;
        if (DetailTemplate is not null) offset += 32;
        foreach (var col in _orderedColumns.Where(c => c.Visible && c.Pin == PinDirection.Left))
        {
            offsets[col.Id] = offset;
            offset += col.Width ?? 150;
        }
        return offsets;
    }

    private IReadOnlyDictionary<string, double> ComputePinnedRightOffsets()
    {
        var offsets = new Dictionary<string, double>();
        double offset = 0;
        if (EditMode == DataGridEditMode.Row) offset += 40;
        foreach (var col in _orderedColumns.Where(c => c.Visible && c.Pin == PinDirection.Right).Reverse())
        {
            offsets[col.Id] = offset;
            offset += col.Width ?? 150;
        }
        return offsets;
    }

    public async ValueTask DisposeAsync()
    {
        _layoutService?.Dispose();
        _serverService?.Dispose();

        // Tear down the native keydown-preventDefault listener registered on the
        // table in OnAfterRenderAsync so it doesn't outlive the element.
        if (_navKeysPrevented)
        {
            try { await Interop.UnregisterPreventDefaultKeys(_gridId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
            catch { /* best-effort */ }
            _navKeysPrevented = false;
        }

        // Tear down the pointer-based column-reorder listener registered on the grid.
        if (_pointerReorderRegistered)
        {
            try { await Interop.UnregisterColumnReorder(_gridId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
            catch { /* best-effort */ }
            _pointerReorderRegistered = false;
        }

        // Tear down the pointer-based row-reorder listener registered on the grid.
        if (_pointerRowReorderRegistered)
        {
            try { await Interop.UnregisterRowReorder(_gridId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
            catch { /* best-effort */ }
            _pointerRowReorderRegistered = false;
        }

        // Defensive: if disposed while still in fullscreen, unlock scroll AND drop
        // the html-level fullscreen class. ToggleExpanded adds
        // `lumeo-fullscreen-active` on <html> when entering fullscreen; disposing
        // the grid mid-fullscreen (route change, parent re-render) skips the
        // toggle-off path, so without this the class leaks onto the host page and
        // any CSS keyed off it (hidden scrollbars, dimmed chrome) stays stuck.
        if (_isExpanded)
        {
            try { await Interop.UnlockScroll(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
            catch { /* best-effort */ }

            try { await Interop.SetHtmlClass("lumeo-fullscreen-active", false); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
            catch { /* best-effort */ }
        }
    }
}
