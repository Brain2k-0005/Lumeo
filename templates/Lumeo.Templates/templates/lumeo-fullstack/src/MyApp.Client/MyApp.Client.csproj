<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Keep the component namespace short (MyApp.*) even though the assembly is
         MyApp.Client, so the shared code reads cleanly. -->
    <RootNamespace>MyApp</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.6" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.6" PrivateAssets="all" />
    <!-- Blazor authorization primitives: AuthenticationStateProvider, AuthorizeView,
         AuthorizeRouteView, [Authorize]. The provider here talks to the real Identity API. -->
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.6" />

    <!-- Lumeo component library (prebuilt CSS/JS ship inside the package). -->
    <PackageReference Include="Lumeo" Version="4.1.0-preview.15" />
    <PackageReference Include="Lumeo.DataGrid" Version="4.1.0-preview.15" />
  </ItemGroup>

</Project>
