@page "/e2e/gantt-v3-tree"
@using Lumeo.Tests.ServerHost.E2E

@* Gantt v2/v3 parity harness (feat/gantt-v3, T4) — v3-ONLY. v2 has no
   GanttTask.ParentId concept at all, so GanttParityFixtures.TreeTasks() (a
   3-level hierarchy) is never rendered through the v2 route; there is no
   parity assertion possible here by definition, only v3-specific behavior
   (tree pane rows/indent/collapse hides bars + arrows). ShowTreePane defaults
   to true here anyway (any task sets ParentId), set explicitly for clarity. *@

<PageTitle>E2E - Gantt v3 tree</PageTitle>

<div class="p-4" style="max-width: 1600px;">
    <h1 data-testid="gantt-e2e-title">Gantt v3 tree (parity fixture)</h1>
    <Gantt3 Tasks="@_tasks"
            ViewMode="GanttViewMode.Day"
            Height="900px"
            ShowTreePane="true"
            data-testid="gantt-v3-tree-root" />
</div>

@code {
    private readonly List<GanttTask> _tasks = GanttParityFixtures.TreeTasks();
}
