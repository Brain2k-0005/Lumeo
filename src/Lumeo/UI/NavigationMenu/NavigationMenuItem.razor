@namespace Lumeo
@implements IDisposable

@{
    var itemContext = new NavigationMenuItemContext(_itemId, _triggerId);
}

<CascadingValue Value="itemContext" IsFixed="true">
    <li class="@CssClass" @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave" @attributes="AdditionalAttributes">
        @ChildContent
    </li>
</CascadingValue>

@code {
    [CascadingParameter] public NavigationMenu.NavigationMenuContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _itemId = $"nav-item-{Guid.NewGuid():N}";
    private readonly string _triggerId = $"nav-trigger-{Guid.NewGuid():N}";
    private readonly DelayedDispatch _dispatch = new();
    private const int CloseDelay = 150;

    private string CssClass => $"relative {Class}".Trim();

    private void HandleMouseEnter()
    {
        _dispatch.Cancel();
    }

    private void HandleMouseLeave()
    {
        if (Context.ActiveItemId == _itemId)
        {
            _dispatch.Schedule(CloseDelay, () => InvokeAsync(async () =>
            {
                if (Context.ActiveItemId == _itemId)
                {
                    await Context.SetActiveItemId.InvokeAsync(null);
                    StateHasChanged();
                }
            }));
        }
    }

    public void Dispose() => _dispatch.Dispose();

    public record NavigationMenuItemContext(string ItemId, string TriggerId);
}
