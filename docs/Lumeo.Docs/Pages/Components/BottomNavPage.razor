    private BottomNav.BottomNavVariant _activeBottomNavVariant =>
        Enum.Parse<BottomNav.BottomNavVariant>(_variantSel);
    private List<Segmented.SegmentedOption> _variantOptions = new()
    {
        new() { Label = ""Default"", Value = ""Default"" },
        new() { Label = ""Pill"", Value = ""Pill"" },
    };
}";

    private void HandleCreate() { /* demo */ }

    private string _basicCode = @"<BottomNav>
