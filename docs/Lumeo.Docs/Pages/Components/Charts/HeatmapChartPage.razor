@page "/components/charts/heatmap"

<PageTitle>Heatmap Chart — Lumeo</PageTitle>

<PageHeader Title="Heatmap Chart" Description="Display density or intensity across two dimensions using color gradients. Useful for activity patterns, correlation matrices, and time-based analysis." />

<Stack Gap="8">
    <ComponentDemo Title="Activity Heatmap" Code="@_basicCode">
        <Container>
            <HeatmapChart XCategories="_xCats" YCategories="_yCats" Data="_data" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">HeatmapChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">XCategories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis category labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">YCategories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Y-axis category labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;double[]&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Data points as [x, y, value] arrays.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color range for the visual map.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private List<string> _xCats = new() { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private List<string> _yCats = new() { "Morning", "Afternoon", "Evening" };
    private List<double[]> _data = new()
    {
        new double[] { 0, 0, 42 }, new double[] { 1, 0, 68 }, new double[] { 2, 0, 55 }, new double[] { 3, 0, 73 }, new double[] { 4, 0, 61 }, new double[] { 5, 0, 29 }, new double[] { 6, 0, 18 },
        new double[] { 0, 1, 87 }, new double[] { 1, 1, 94 }, new double[] { 2, 1, 91 }, new double[] { 3, 1, 88 }, new double[] { 4, 1, 95 }, new double[] { 5, 1, 72 }, new double[] { 6, 1, 48 },
        new double[] { 0, 2, 31 }, new double[] { 1, 2, 56 }, new double[] { 2, 2, 63 }, new double[] { 3, 2, 47 }, new double[] { 4, 2, 79 }, new double[] { 5, 2, 84 }, new double[] { 6, 2, 67 }
    };

    private string _basicCode = @"<HeatmapChart XCategories=""_xCats"" YCategories=""_yCats"" Data=""_data"" />";
}
