@namespace Lumeo
@inject Services.ComponentInteropService Interop
@implements IAsyncDisposable

@if (Label is not null && !InsideFormField)
{
    <label class="block text-sm font-medium text-foreground mb-1.5">
        @Label
        @if (Required)
        {
            <span class="text-destructive ml-0.5">*</span>
        }
    </label>
}

<div class="@RootClass" @attributes="AdditionalAttributes" aria-required="@(Required ? "true" : "false")" aria-invalid="@(EffectiveInvalid ? "true" : "false")">
    @if (Toolbar != RichTextToolbarMode.None)
    {
        <div class="flex flex-wrap items-center gap-0.5 border-b border-border/40 bg-muted/30 px-2 py-1.5"
             role="toolbar"
             aria-label="Text formatting">

            @if (Toolbar == RichTextToolbarMode.Full)
            {
                @TbButton("Paragraph", "Pilcrow", _active?.Paragraph == true, async () => await RunCommand("setParagraph"))
                @TbButton("Heading 1", "Heading1", _active?.Heading1 == true, async () => await RunCommand("setHeading", 1))
                @TbButton("Heading 2", "Heading2", _active?.Heading2 == true, async () => await RunCommand("setHeading", 2))
                @TbButton("Heading 3", "Heading3", _active?.Heading3 == true, async () => await RunCommand("setHeading", 3))
                @TbSeparator()
            }

            @TbButton("Bold", "Bold", _active?.Bold == true, async () => await RunCommand("bold"))
            @TbButton("Italic", "Italic", _active?.Italic == true, async () => await RunCommand("italic"))

            @if (Toolbar == RichTextToolbarMode.Full)
            {
                @TbButton("Underline", "Underline", _active?.Underline == true, async () => await RunCommand("underline"))
            }

            @TbButton("Strikethrough", "Strikethrough", _active?.Strike == true, async () => await RunCommand("strike"))

            @if (Toolbar == RichTextToolbarMode.Full)
            {
                @TbButton("Inline code", "Code", _active?.Code == true, async () => await RunCommand("code"))
            }

            @TbSeparator()
            @TbButton("Bullet list", "List", _active?.BulletList == true, async () => await RunCommand("bulletList"))
            @TbButton("Numbered list", "ListOrdered", _active?.OrderedList == true, async () => await RunCommand("orderedList"))

            @if (Toolbar == RichTextToolbarMode.Full)
            {
                @TbSeparator()
                @TbButton("Quote", "Quote", _active?.Blockquote == true, async () => await RunCommand("blockquote"))
                @TbButton("Code block", "SquareCode", _active?.CodeBlock == true, async () => await RunCommand("codeBlock"))
                @TbButton("Horizontal rule", "Minus", false, async () => await RunCommand("hr"))
            }

            @TbSeparator()
            @TbButton("Link", "Link", _active?.Link == true, HandleLinkAsync)
            @TbButton("Unlink", "Unlink", false, async () => await RunCommand("unlink"), disabled: _active?.Link != true)

            @TbSeparator()
            @TbButton("Undo", "Undo", false, async () => await RunCommand("undo"), disabled: _active?.CanUndo == false)
            @TbButton("Redo", "Redo", false, async () => await RunCommand("redo"), disabled: _active?.CanRedo == false)

            @if (Toolbar == RichTextToolbarMode.Full)
            {
                @TbButton("Clear formatting", "RemoveFormatting", false, async () => await RunCommand("clearFormat"))
            }
        </div>
    }

    <div @ref="_contentRef" style="@ContentStyle" class="lumeo-rte-content bg-card"></div>
</div>

@if (!InsideFormField)
{
    @if (EffectiveInvalid && ErrorText is not null)
    {
        <p class="text-xs text-destructive mt-1.5">@ErrorText</p>
    }
    else if (HelperText is not null)
    {
        <p class="text-xs text-muted-foreground mt-1.5">@HelperText</p>
    }
}

@code {
    [CascadingParameter] private FormField.FormFieldContext? FormField { get; set; }

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string Placeholder { get; set; } = "Start writing…";
    [Parameter] public int MinHeight { get; set; } = 180;
    [Parameter] public int? MaxHeight { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public RichTextToolbarMode Toolbar { get; set; } = RichTextToolbarMode.Full;
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool EffectiveInvalid => Invalid || FormField?.HasError == true;
    private bool InsideFormField => FormField is not null;

    private Microsoft.AspNetCore.Components.ElementReference _contentRef;
    private DotNetObjectReference<RichTextEditor>? _selfRef;
    private string? _instanceId;
    private string? _lastSetValue;
    private bool _lastDisabled;
    private bool _lastReadOnly;
    private Services.Interop.RichTextActiveState? _active;
    private bool _initialized;

    private string RootClass =>
        $"rounded-lg border {(EffectiveInvalid ? "border-destructive focus-within:ring-destructive/20" : "border-border focus-within:border-ring/60 focus-within:ring-ring/40")} bg-card overflow-hidden transition-colors focus-within:ring-[1.5px] {Class}".Trim();

    private string ContentStyle
    {
        get
        {
            var parts = new List<string> { $"min-height: {MinHeight}px" };
            if (MaxHeight is int max)
            {
                parts.Add($"max-height: {max}px");
                parts.Add("overflow-y: auto");
            }
            return string.Join("; ", parts) + ";";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _lastSetValue = Value;
            _lastDisabled = Disabled;
            _lastReadOnly = ReadOnly;
            var options = new
            {
                content = Value ?? string.Empty,
                placeholder = Placeholder,
                disabled = Disabled,
                readOnly = ReadOnly,
            };
            _instanceId = await Interop.RichTextInitAsync(_contentRef, _selfRef, options);
            _initialized = !string.IsNullOrEmpty(_instanceId);
            if (_initialized)
            {
                await RefreshActiveAsync();
            }
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || _instanceId is null) return;

        if (!string.Equals(Value, _lastSetValue, StringComparison.Ordinal))
        {
            _lastSetValue = Value;
            await Interop.RichTextSetContentAsync(_instanceId, Value);
        }

        if (Disabled != _lastDisabled || ReadOnly != _lastReadOnly)
        {
            _lastDisabled = Disabled;
            _lastReadOnly = ReadOnly;
            await Interop.RichTextSetDisabledAsync(_instanceId, Disabled || ReadOnly);
        }
    }

    [JSInvokable]
    public async Task OnContentUpdate(string html)
    {
        // Echo back from TipTap — track it so OnParametersSetAsync doesn't push it back in a loop.
        _lastSetValue = html;
        Value = html;
        await ValueChanged.InvokeAsync(html);
        await RefreshActiveAsync();
    }

    [JSInvokable]
    public Task OnSelectionUpdate()
        => RefreshActiveAsync();

    private async Task RefreshActiveAsync()
    {
        if (_instanceId is null) return;
        _active = await Interop.RichTextGetActiveAsync(_instanceId);
        StateHasChanged();
    }

    private async Task RunCommand(string name, params object?[] args)
    {
        if (_instanceId is null || Disabled || ReadOnly) return;
        await Interop.RichTextCommandAsync(_instanceId, name, args);
        await RefreshActiveAsync();
    }

    private async Task HandleLinkAsync()
    {
        if (_instanceId is null || Disabled || ReadOnly) return;
        var url = await Interop.RichTextPromptLinkAsync(null);
        if (url is null) return; // user cancelled
        await RunCommand("link", url);
    }

    // --- Toolbar button render helpers ---

    private RenderFragment TbSeparator() => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "aria-hidden", "true");
        builder.AddAttribute(2, "class", "mx-0.5 h-5 w-px bg-border");
        builder.CloseElement();
    };

    private RenderFragment TbButton(string label, string icon, bool active, Func<Task> onClick, bool disabled = false)
        => builder =>
        {
            var isDisabled = disabled || Disabled || ReadOnly;
            var cls = active
                ? "inline-flex h-7 w-7 items-center justify-center rounded-md bg-accent text-accent-foreground transition-colors"
                : "inline-flex h-7 w-7 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground";
            if (isDisabled) cls += " opacity-50 cursor-not-allowed";

            builder.OpenElement(0, "button");
            builder.AddAttribute(1, "type", "button");
            builder.AddAttribute(2, "class", cls);
            builder.AddAttribute(3, "title", label);
            builder.AddAttribute(4, "aria-label", label);
            builder.AddAttribute(5, "aria-pressed", active ? "true" : "false");
            if (isDisabled)
            {
                builder.AddAttribute(6, "disabled", true);
            }
            else
            {
                builder.AddAttribute(7, "onclick",
                    Microsoft.AspNetCore.Components.EventCallback.Factory.Create(this, onClick));
                // Prevent the button from stealing focus away from the editor on mousedown —
                // TipTap loses selection if another element becomes the active element between
                // mousedown and click.
                builder.AddAttribute(8, "onmousedown", "event.preventDefault()");
            }
            builder.OpenComponent<Icon>(9);
            builder.AddAttribute(10, "Name", icon);
            builder.AddAttribute(11, "Size", Icon.IconSize.Sm);
            builder.CloseComponent();
            builder.CloseElement();
        };

    public async ValueTask DisposeAsync()
    {
        if (_instanceId is not null)
        {
            try
            {
                await Interop.RichTextDestroyAsync(_instanceId);
            }
            catch (JSDisconnectedException) { /* ignore — circuit already gone */ }
            _instanceId = null;
        }
        _selfRef?.Dispose();
        _selfRef = null;
    }

    public enum RichTextToolbarMode
    {
        None,
        Basic,
        Full,
    }
}
