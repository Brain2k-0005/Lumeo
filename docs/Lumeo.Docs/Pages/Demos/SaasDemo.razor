                <Flex Align="center" Justify="between"><Lumeo.Text Size="sm" Color="muted">Region</Lumeo.Text><Lumeo.Text Size="sm" Weight="medium">@c.Region</Lumeo.Text></Flex>
                <Flex Align="center" Justify="between"><Lumeo.Text Size="sm" Color="muted">Seats</Lumeo.Text><Lumeo.Text Size="sm" Weight="medium">@c.Seats.ToString("N0")</Lumeo.Text></Flex>
                <Flex Align="center" Justify="between"><Lumeo.Text Size="sm" Color="muted">Customer since</Lumeo.Text><Lumeo.Text Size="sm" Weight="medium">@c.Signup.ToString("MMM yyyy")</Lumeo.Text></Flex>
                <Flex Align="center" Justify="between" Class="pt-0.5">
