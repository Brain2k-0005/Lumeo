@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    <div class="lumeo-aurora-layer lumeo-aurora-layer--1" aria-hidden="true"></div>
    <div class="lumeo-aurora-layer lumeo-aurora-layer--2" aria-hidden="true"></div>
    <div class="lumeo-aurora-layer lumeo-aurora-layer--3" aria-hidden="true"></div>
    @if (ChildContent != null)
    {
        <div class="lumeo-aurora-content">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[] { "lumeo-aurora", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));
}
