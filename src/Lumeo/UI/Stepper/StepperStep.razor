@namespace Lumeo
@implements IDisposable

@* StepperStep registers itself into the parent Stepper's step list on each render.
   The actual rendering is done by Stepper using the registered data. Registration
   is keyed on this component instance (idempotent — OnParametersSet can fire more
   than once per parent render via the cascading-value double notification) and is
   withdrawn on dispose so conditionally-removed steps don't leave ghosts. *@

@code {
    // Stable identity generated ONCE per StepperStep instance. Threaded into the
    // registration so the KeepMounted panel wrapper can @key on the step's true
    // owner (#105) instead of its loop index — index keys make a reused panel
    // fragment track the WRONG owner across remove/insert, dragging stale input
    // state to a different step. A Guid is immutable for the instance lifetime,
    // so the keyed panel survives reorders without re-creating its DOM.
    private readonly Guid _id = Guid.NewGuid();

    [CascadingParameter] public Stepper.StepperContext? Context { get; set; }
    /// <summary>The step's title, shown next to (horizontal) or beside (vertical) its indicator.</summary>
    [Parameter] public string Title { get; set; } = "";
    /// <summary>Optional secondary text shown below the title.</summary>
    [Parameter] public string? Description { get; set; }
    /// <summary>When <c>true</c>, an "(optional)" hint renders below the title/description.</summary>
    [Parameter] public bool Optional { get; set; }
    /// <summary>Forces the step's indicator to render as completed (checkmark) even before the stepper's active index has passed it.</summary>
    [Parameter] public bool Completed { get; set; }
    /// <summary>Validity check consulted by the parent's Next/Finish buttons (disabled while it returns <c>false</c>) and to flag a past step's indicator as errored. <c>null</c> (default) is always valid.</summary>
    [Parameter] public Func<bool>? IsValid { get; set; }
    /// <summary>Custom icon rendered in the indicator instead of the step number, while the step is neither completed nor errored.</summary>
    [Parameter] public RenderFragment? IconContent { get; set; }
    /// <summary>The step's body content, shown in the stepper's panel while this step is active.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>When <c>true</c>, the step's body stays mounted (visually hidden, not removed) while inactive, preserving its input state across navigation instead of being recreated on each visit.</summary>
    [Parameter] public bool KeepMounted { get; set; }
    /// <summary>Reserved for API consistency with other components; not currently applied to any rendered element (the step's markup is composed by the parent <c>Stepper</c>).</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Reserved for API consistency with other components; not currently applied to any rendered element (the step's markup is composed by the parent <c>Stepper</c>).</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnParametersSet()
    {
        Context?.Parent.RegisterStep(this, new StepRegistration(
            _id,
            Title,
            Description,
            Optional,
            Completed,
            IsValid,
            IconContent,
            ChildContent,
            KeepMounted));
    }

    public void Dispose()
    {
        Context?.Parent.UnregisterStep(this);
    }

    public bool IsStepValid() => IsValid?.Invoke() ?? true;

    public record StepRegistration(
        Guid Id,
        string Title,
        string? Description,
        bool Optional,
        bool Completed,
        Func<bool>? IsValid,
        RenderFragment? IconContent,
        RenderFragment? ChildContent,
        bool KeepMounted)
    {
        public bool IsStepValid() => IsValid?.Invoke() ?? true;
    }
}
