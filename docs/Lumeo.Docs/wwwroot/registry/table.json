  "source": [
    {
      "path": "UI/Table/Table.razor",
      "content": "@namespace Lumeo\n\n<div class=\"relative w-full overflow-auto\">\n    <table class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n        @ChildContent\n    </table>\n</div>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"w-full caption-bottom text-sm {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableBody.razor",
      "content": "@namespace Lumeo\n\n<tbody class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</tbody>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"[&_tr:last-child]:border-0 {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableCaption.razor",
      "content": "@namespace Lumeo\n\n<caption class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</caption>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"mt-4 text-sm text-muted-foreground {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableCell.razor",
      "content": "@namespace Lumeo\n\n<td class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</td>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"p-2 align-middle [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableHead.razor",
      "content": "@namespace Lumeo\n\n<th class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</th>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"h-10 px-2 text-left align-middle font-medium text-muted-foreground [&:has([role=checkbox])]:pr-0 [&>[role=checkbox]]:translate-y-[2px] {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableHeader.razor",
      "content": "@namespace Lumeo\n\n<thead class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</thead>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"[&_tr]:border-b [&_tr]:border-border/40 {Class}\".Trim();\n}\n"
    },
    {
      "path": "UI/Table/TableRow.razor",
      "content": "@namespace Lumeo\n\n<tr class=\"@CssClass\" @attributes=\"AdditionalAttributes\">\n    @ChildContent\n</tr>\n\n@code {\n    [Parameter] public RenderFragment? ChildContent { get; set; }\n    [Parameter] public string? Class { get; set; }\n    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }\n\n    private string CssClass => $\"border-b border-border/40 transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted {Class}\".Trim();\n}\n"
    }
