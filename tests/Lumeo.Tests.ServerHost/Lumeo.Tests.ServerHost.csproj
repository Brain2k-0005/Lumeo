<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RootNamespace>Lumeo.Tests.ServerHost</RootNamespace>
    <!-- Minimal Blazor SERVER (interactive-server render mode, real SignalR
         circuit) host for the latency leg — everything else in this repo is
         Blazor WebAssembly (the docs app) or bUnit (component tests), neither
         of which exercises the circuit round-trip latency that Server mode
         is uniquely sensitive to (drag commits, toast bursts, dialog
         open/close all await a .NET round-trip through SignalR). -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Lumeo\Lumeo.csproj" />
    <ProjectReference Include="..\..\src\Lumeo.DataGrid\Lumeo.DataGrid.csproj" />
    <!-- Gantt v2/v3 parity harness (feat/gantt-v3, T4): /e2e/gantt-v2 + /e2e/gantt-v3
         + /e2e/gantt-v3-tree host pages render the same fixture through both
         Lumeo.Gantt.Gantt (v2, JS/SVG) and the working-name Gantt3 (v3, pure Razor)
         so the Lumeo.Tests.E2E Playwright suite can assert render-equivalence. -->
    <ProjectReference Include="..\..\src\Lumeo.Gantt\Lumeo.Gantt.csproj" />
  </ItemGroup>

</Project>
