@page "/components/rich-text-editor"

@using Lumeo.Services
@inject ToastService Toast

<PageTitle>Rich Text Editor — Lumeo</PageTitle>

<PageHeader Title="Rich Text Editor"
            Description="A fully-featured WYSIWYG editor built on TipTap/ProseMirror. Supports mentions, slash commands, tables, code blocks, task lists, AI actions, image upload, and Word import — all wired through Blazor parameters." />

<InstallUsage Component="RichTextEditor" Package="Lumeo.Editor" />

<Alert Variant="Alert.AlertVariant.Warning" ShowIcon="true" Class="mt-6">
    <ChildContent>
        <strong>In active development.</strong> The RichTextEditor is functional but still being polished —
        expect rough edges, occasional input lag, and ongoing improvements to the slash/mention dropdowns,
        Word import fidelity, and AI action wiring. Please report issues on
        <a href="https://github.com/Brain2k-0005/Lumeo/issues" class="underline hover:text-foreground">GitHub</a>.
    </ChildContent>
</Alert>

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-3">
    <ChildContent>
        <strong>Dependencies &amp; licensing — fully MIT, no paid extensions.</strong>
        Built on TipTap's free MIT extensions (<code>@@tiptap/core</code>, <code>starter-kit</code>, <code>extension-mention</code>,
        <code>extension-table</code>, <code>extension-code-block-lowlight</code>, <code>extension-image</code>, etc.) plus
        <code>lowlight</code> (MIT) and <code>Mammoth</code> 1.11.0 (BSD-2-Clause) for Word import.
        <strong>No <code>@@tiptap-pro/*</code> packages</strong> — the AI actions, drag handle, and bubble menu are all
        custom Lumeo code using the free MIT primitives. The AI actions invoke <strong>your own LLM</strong> via the
        <code>OnAiAction</code> callback (OpenAI, Anthropic, Mistral, Ollama — your choice, your bill). Lumeo doesn't
        ship credentials and doesn't take a cut.
    </ChildContent>
</Alert>

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Content authoring surfaces — blog posts, knowledge-base articles, product descriptions</li>
        <li>Long-form fields that benefit from headings, lists, quotes, links, and tables</li>
        <li>Comment or reply surfaces where users expect bold, italic, mentions, and emoji</li>
        <li>Document editors that need Word import, AI writing assistance, or collaborative slash commands</li>
        <li>Anywhere you currently use a Textarea but want structured HTML output</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    <!-- 1. Basic -->
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <RichTextEditor @bind-Value="_basicHtml" Placeholder="Start writing…" />
    </ComponentDemo>

    <!-- 2. Toolbar presets -->
    <ComponentDemo Title="Toolbar presets" Code="@_presetsCode">
        <Stack Gap="6">
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Minimal — Bold, Italic, Link</Lumeo.Text>
                <RichTextEditor @bind-Value="_minimalHtml" Toolbar="EditorToolbarPreset.Minimal" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Standard (default) — Headings, marks, lists, link, undo/redo</Lumeo.Text>
                <RichTextEditor @bind-Value="_standardHtml" Toolbar="EditorToolbarPreset.Standard" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Full — Standard + tables, image, code block, AI menu, Word import</Lumeo.Text>
                <RichTextEditor @bind-Value="_fullHtml" Toolbar="EditorToolbarPreset.Full" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">None — Toolbar hidden; bubble menu and keyboard shortcuts still active</Lumeo.Text>
                <RichTextEditor @bind-Value="_noneHtml" Toolbar="EditorToolbarPreset.None" MinHeight="100"
                                Placeholder="No toolbar — select text to see the bubble menu." />
            </div>
        </Stack>
    </ComponentDemo>

    <!-- 3. mentions -->
    <ComponentDemo Title="@("@-mentions")" Code="@_mentionsCode">
        <RichTextEditor @bind-Value="_mentionsHtml"
                        Triggers="_mentionTriggers"
                        Placeholder="@("Type @ to mention a team member…")" />
    </ComponentDemo>

    <!-- 4. Multiple triggers -->
    <ComponentDemo Title="@("Multiple triggers (@, #, $)")" Code="@_multiTriggerCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Type <code class="font-mono text-xs">@@</code> for users, <code class="font-mono text-xs">#</code> for tags, <code class="font-mono text-xs">$</code> for template variables.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_multiHtml" Triggers="_multiTriggers" />
        </Stack>
    </ComponentDemo>

    <!-- 5. Slash command -->
    <ComponentDemo Title="Slash command" Code="@_slashCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Type <code class="font-mono text-xs">/</code> on a new line to open the command palette. Built-in commands: Heading 1-3, Bullet list, Numbered list, Task list, Quote, Code block, Table, Image, Divider.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_slashHtml" EnableSlashCommand="true" />
        </Stack>
    </ComponentDemo>

    <!-- 6. Tables, code blocks, task lists -->
    <ComponentDemo Title="Tables, code, and task lists" Code="@_richBlocksCode">
        <RichTextEditor @bind-Value="_blocksHtml"
                        Toolbar="EditorToolbarPreset.Full"
                        EnableTables="true"
                        EnableCodeBlock="true"
                        EnableTaskList="true"
                        Placeholder="Use the Full toolbar or slash commands to insert a table, code block, or task list." />
    </ComponentDemo>

    <!-- 7. Image upload -->
    <ComponentDemo Title="Image upload" Code="@_imagesCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Click the image button in the toolbar (or type <code class="font-mono text-xs">/image</code>). The <code class="font-mono text-xs">OnImageRequested</code> callback returns the final URL; the demo returns a placeholder after a simulated upload delay.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_imageHtml"
                            Toolbar="EditorToolbarPreset.Full"
                            OnImageRequested="HandleImageUpload" />
        </Stack>
    </ComponentDemo>

    <!-- 8. AI actions -->
    <ComponentDemo Title="AI actions" Code="@_aiCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Select some text in the editor below to see the bubble menu's AI button. Actions: Improve, Shorten, Expand, Fix Grammar, Summarize, Translate.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_aiHtml"
                            EnableAiActions="true"
                            OnAiAction="HandleAiAction"
                            Placeholder="Write something here, select it, and try an AI action…" />
        </Stack>
    </ComponentDemo>

    <!-- 9. Word (.docx) import -->
    <ComponentDemo Title="Word (.docx) import" Code="@_wordCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>
                    Click the <em>Import</em> button in the toolbar and pick any <code class="font-mono text-xs">.docx</code> file.
                    Conversion runs entirely in your browser via <code class="font-mono text-xs">WordImporter</code> (Mammoth ships with the
                    Lumeo.Editor WASM bundle), so this demo works on static hosting with no server. The default style map handles
                    English and German Word default styles (<em>Title/Titel, Heading 1-6/Überschrift 1-6, Body Text/Textkörper,
                    List Paragraph/Listenabsatz</em>, etc.). For server-side conversion with custom callbacks (e.g. uploading
                    embedded images), set <code class="font-mono text-xs">OnWordImportRequested</code>.
                </ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_wordHtml"
                            Toolbar="EditorToolbarPreset.Full"
                            AllowWordImport="true" />
        </Stack>
    </ComponentDemo>

    <!-- 10. FormField validation -->
    <ComponentDemo Title="With FormField validation" Code="@_formFieldCode">
        <Stack Gap="3" Class="max-w-2xl">
            <FormField Label="Description"
                       Required="true"
                       HelpText="Markdown shortcuts work too — try '**bold**' or '# Heading'."
                       Error="@_formError">
                <RichTextEditor @bind-Value="_formHtml"
                                Required="true"
                                Invalid="@(_formError is not null)"
                                MinHeight="160" />
            </FormField>
            <Flex Gap="2">
                <Button OnClick="ValidateForm">Validate</Button>
                <Button Variant="Button.ButtonVariant.Ghost" OnClick="ResetForm">Reset</Button>
            </Flex>
        </Stack>
    </ComponentDemo>

    <!-- 11. Read-only & disabled -->
    <ComponentDemo Title="Read-only and disabled" Code="@_statesCode">
        <Stack Gap="4">
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Read-only — content is selectable but not editable</Lumeo.Text>
                <RichTextEditor Value="@_readOnlySample"
                                ReadOnly="true"
                                Toolbar="EditorToolbarPreset.None"
                                MinHeight="100" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Disabled — dimmed and non-interactive</Lumeo.Text>
                <RichTextEditor Value="@_disabledSample"
                                Disabled="true"
                                MinHeight="100" />
            </div>
        </Stack>
    </ComponentDemo>

    <!-- 12. Max-length & constrained height -->
    <ComponentDemo Title="Max length + bounded height" Code="@_constraintsCode">
        <RichTextEditor @bind-Value="_constrainedHtml"
                        MaxLength="500"
                        MinHeight="140"
                        MaxHeight="260"
                        HelperText="Plain-text character limit: 500. The editor scrolls internally when content overflows 260 px." />
    </ComponentDemo>

</Stack>

<!-- Keyboard shortcuts -->
<div class="mt-16">
    <Heading Id="keyboard" Level="2" Class="scroll-mt-20">Keyboard Shortcuts</Heading>
    <div class="overflow-x-auto mt-4">
        <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
            <table class="w-full min-w-[500px] text-sm">
                <thead>
                    <tr class="border-b border-border/40 bg-muted/40">
                        <th class="text-left p-3 font-medium text-foreground w-[220px]">Shortcut</th>
                        <th class="text-left p-3 font-medium text-foreground">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/40">
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + B</td><td class="p-3 text-muted-foreground">Bold</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + I</td><td class="p-3 text-muted-foreground">Italic</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + U</td><td class="p-3 text-muted-foreground">Underline</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Shift + X</td><td class="p-3 text-muted-foreground">Strikethrough</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Z</td><td class="p-3 text-muted-foreground">Undo</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Shift + Z</td><td class="p-3 text-muted-foreground">Redo</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Alt + 1 – 3</td><td class="p-3 text-muted-foreground">Heading 1 / 2 / 3</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">/ (on a new line)</td><td class="p-3 text-muted-foreground">Open slash-command palette</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">@@ # $</td><td class="p-3 text-muted-foreground">Open the corresponding trigger dropdown</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">**text**</td><td class="p-3 text-muted-foreground">Bold (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground"># text (space)</td><td class="p-3 text-muted-foreground">Heading 1 (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">- or * (space)</td><td class="p-3 text-muted-foreground">Bullet list (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">[ ] (space)</td><td class="p-3 text-muted-foreground">Task list item (markdown shortcut)</td></tr>
                </tbody>
            </table>
        </Stack>
    </div>
</div>

<!-- API Reference -->
<Stack Gap="6" Class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Stack Gap="8" Class="mt-4">

        <!-- RichTextEditor parameters -->
        <Stack Gap="3">
            <Heading Level="3">RichTextEditor</Heading>
            <PropsTable Slug="rich-text-editor" />
        </Stack>

        <!-- EditorTrigger -->
        <Stack Gap="3">
            <Heading Level="3">EditorTrigger</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[160px]">Property</th>
                            <th class="text-left p-3 font-medium text-foreground w-[260px]">Type</th>
                            <th class="text-left p-3 font-medium text-foreground w-[100px]">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">Char</td><td class="p-3 font-mono text-xs text-muted-foreground">char</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">The character that activates this trigger (e.g. <code class="font-mono text-xs">'@@'</code>).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ItemSource</td><td class="p-3 font-mono text-xs text-muted-foreground">Func&lt;string, ValueTask&lt;IReadOnlyList&lt;TriggerItem&gt;&gt;&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Async callback called on each keystroke with the partial query; returns matching items.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ItemTemplate</td><td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment&lt;TriggerItem&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Optional custom row renderer for the dropdown list.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ChipClass</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">CSS classes applied to the chip/pill inserted into the document when an item is selected.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <!-- TriggerItem -->
        <Stack Gap="3">
            <Heading Level="3">TriggerItem</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[140px]">Property</th>
                            <th class="text-left p-3 font-medium text-foreground w-[160px]">Type</th>
                            <th class="text-left p-3 font-medium text-foreground w-[100px]">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">Id</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Unique identifier stored in the document node's data attribute.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Label</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Display name shown in the dropdown and rendered in the chip.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Subtitle</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Secondary text shown below the label in the dropdown row.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">IconName</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Lucide icon name (e.g. <code class="font-mono text-xs">"User"</code>) displayed alongside the label.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Payload</td><td class="p-3 font-mono text-xs text-muted-foreground">object?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Arbitrary data passed back to the consumer for custom rendering or server look-ups.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <!-- TriggerDropdown -->
        <Stack Gap="3">
            <Heading Level="3">TriggerDropdown</Heading>
            <p class="text-sm text-muted-foreground">Floating suggestion list rendered above/below a trigger caret, driven by <code class="font-mono text-xs">Items</code> + a selected index. The live editor drives its own equivalent in JS; this Razor primitive exists for consumers who want to render their own trigger UI server-side (e.g. a standalone mention input).</p>
            <PropsTable Slug="rich-text-editor" SubComponent="TriggerDropdown" />
        </Stack>

        <!-- EditorImageRequest -->
        <Stack Gap="3">
            <Heading Level="3">EditorImageRequest</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[140px]">Property</th>
                            <th class="text-left p-3 font-medium text-foreground w-[140px]">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">FileName</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 text-muted-foreground">Original file name chosen by the user.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">MimeType</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 text-muted-foreground">MIME type of the selected file (e.g. <code class="font-mono text-xs">image/png</code>).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Size</td><td class="p-3 font-mono text-xs text-muted-foreground">long</td><td class="p-3 text-muted-foreground">File size in bytes.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <!-- EditorToolbarPreset -->
        <Stack Gap="3">
            <Heading Level="3">EditorToolbarPreset</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[500px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[140px]">Value</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">None</td><td class="p-3 text-muted-foreground">No toolbar. Bubble menu and keyboard shortcuts remain available.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Minimal</td><td class="p-3 text-muted-foreground">Bold, Italic, Link only.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Standard</td><td class="p-3 text-muted-foreground">Headings, basic marks (bold, italic, underline, strikethrough), lists, link, undo/redo. Default value.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Full</td><td class="p-3 text-muted-foreground">Standard plus tables, image, code block, AI action menu, and Word import button.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <!-- EditorToolbar -->
        <Stack Gap="3">
            <Heading Level="3">EditorToolbar</Heading>
            <p class="text-sm text-muted-foreground">The preset-driven toolbar rendered above the editor surface when <code class="font-mono text-xs">Toolbar</code> is not <code class="font-mono text-xs">None</code>. Rendered internally by <code class="font-mono text-xs">RichTextEditor</code>; each button invokes <code class="font-mono text-xs">OnCommand</code>, which the parent forwards to the JS editor.</p>
            <PropsTable Slug="rich-text-editor" SubComponent="EditorToolbar" />
        </Stack>

        <!-- BubbleMenu -->
        <Stack Gap="3">
            <Heading Level="3">BubbleMenu</Heading>
            <p class="text-sm text-muted-foreground">A static (non-floating) bubble-menu primitive consumers can drop into a custom toolbar. The live floating bubble menu is rendered in JS by <code class="font-mono text-xs">RichTextEditor</code> itself when <code class="font-mono text-xs">EnableBubbleMenu</code> is true; this component exists for building a selection menu out of band.</p>
            <PropsTable Slug="rich-text-editor" SubComponent="BubbleMenu" />
        </Stack>

        <!-- AiActionMenu -->
        <Stack Gap="3">
            <Heading Level="3">AiActionMenu</Heading>
            <p class="text-sm text-muted-foreground">Floating list of AI actions (Improve / Shorten / Expand / ...) wired to the editor's selection. Picking an item fires <code class="font-mono text-xs">OnAction</code> with the action record; the consumer returns replacement HTML for the current selection.</p>
            <PropsTable Slug="rich-text-editor" SubComponent="AiActionMenu" />
        </Stack>

        <!-- WordImporter -->
        <Stack Gap="3">
            <Heading Level="3">WordImporter (server-side)</Heading>
            <p class="text-sm text-muted-foreground">
                <code class="font-mono text-xs">WordImporter</code> is a static server-side helper in <code class="font-mono text-xs">Lumeo.Editor</code>
                that converts a <code class="font-mono text-xs">.docx</code> stream to clean HTML using Mammoth.NET.
                Call it from an API endpoint and return the result to the editor via
                <code class="font-mono text-xs">SetHtmlAsync</code>.
            </p>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[200px]">Member</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">ToHtmlAsync(stream, options?)</td><td class="p-3 text-muted-foreground">Converts a .docx stream to <code class="font-mono text-xs">WordImportResult</code> containing <code class="font-mono text-xs">Html</code> and <code class="font-mono text-xs">Warnings</code>.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">DefaultStyleMap</td><td class="p-3 text-muted-foreground">Built-in Mammoth style map covering English and German Word styles (Title, Heading 1-6, Body Text, Quote, etc.).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">WordImportOptions.StyleMap</td><td class="p-3 text-muted-foreground">Custom style map appended after the default map (so custom rules win).</td></tr>
