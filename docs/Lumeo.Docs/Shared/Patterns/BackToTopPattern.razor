@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="BackToTop" Code="@_codeBasic">
    <Stack Gap="1" Align="center">
        <Lumeo.Text Size="sm" Color="muted" Align="center">The BackToTop button appears in the bottom-right corner when you scroll down.</Lumeo.Text>
        <Lumeo.Text Size="sm" Color="muted" Align="center">Usage: add <code class="font-mono bg-muted px-1 rounded">&lt;BackToTop /&gt;</code> to your layout.</Lumeo.Text>
    </Stack>
</PatternCard>
</Stack>

@code {
    private string _codeBasic = @"<BackToTop />

<!-- With custom threshold -->
<BackToTop VisibilityThreshold=""500"" />";
}
