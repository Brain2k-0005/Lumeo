@page "/components/number-input"

<PageTitle>NumberInput — Lumeo</PageTitle>

<PageHeader Title="NumberInput" Description="A numeric input with increment/decrement buttons." />

<InstallUsage Component="NumberInput" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Quantity selectors in shopping carts or inventory forms</li>
        <li>Numeric settings such as font size, zoom level, or timeout values</li>
        <li>Price inputs requiring precise decimal control</li>
        <li>Any field where users should increment or decrement a number in defined steps</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_codeBasic">
        <NumberInput @bind-Value="_val1" />
    </ComponentDemo>

    <ComponentDemo Title="Min / Max / Step" Code="@_codeMinMax">
        <Stack Gap="2">
            <NumberInput @bind-Value="_val2" Min="0" Max="100" Step="5" />
            <Lumeo.Text Size="sm" Color="muted">Value: @_val2 (0-100, step 5)</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Precision" Code="@_codePrecision">
        <NumberInput @bind-Value="_val3" Step="0.01" Precision="2" Min="0" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_codeDisabled">
        <NumberInput Value="42" Disabled="true" />
    </ComponentDemo>

    <ComponentDemo Title="Prefix & Suffix" Code="@_codePrefixSuffix">
        <Stack Gap="3">
            <NumberInput @bind-Value="_valPrice" Min="0" Step="0.01" Precision="2" Prefix="$" />
            <NumberInput @bind-Value="_valWeight" Min="0" Step="0.5" Precision="1" Suffix="kg" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Mouse Wheel" Description="Scroll the wheel over the input to adjust the value." Code="@_codeWheel">
        <NumberInput @bind-Value="_valWheel" Min="0" Max="100" Step="1" UseMouseWheel="true" />
    </ComponentDemo>

    <ComponentDemo Title="Step & Precision" Description="Adjust the step size and decimal precision interactively." Code="@_codeStepPrecision">
        <Stack Gap="3">
            <Flex Align="center" Gap="3" Wrap="true">
                <Lumeo.Text Size="sm" Weight="medium">Step:</Lumeo.Text>
                <Segmented @bind-Value="_numStep">
                    <SegmentedItem Value="0.1">0.1</SegmentedItem>
                    <SegmentedItem Value="0.5">0.5</SegmentedItem>
                    <SegmentedItem Value="1">1</SegmentedItem>
                    <SegmentedItem Value="5">5</SegmentedItem>
                    <SegmentedItem Value="10">10</SegmentedItem>
                </Segmented>
            </Flex>
            <Flex Align="center" Gap="3" Wrap="true">
                <Lumeo.Text Size="sm" Weight="medium">Precision:</Lumeo.Text>
                <Segmented @bind-Value="_numPrecision">
                    <SegmentedItem Value="0">0</SegmentedItem>
                    <SegmentedItem Value="1">1</SegmentedItem>
                    <SegmentedItem Value="2">2</SegmentedItem>
                    <SegmentedItem Value="3">3</SegmentedItem>
                </Segmented>
            </Flex>
            <NumberInput @bind-Value="_numInteractiveVal"
                         Step="@(double.Parse(_numStep, System.Globalization.CultureInfo.InvariantCulture))"
                         Precision="@(int.Parse(_numPrecision))"
                         Class="max-w-xs" />
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Lumeo.Text Size="sm" Color="muted">
        <code>Density</code> falls back to an ancestor <a href="/docs/density" class="text-primary hover:underline">DensityScope</a>, then Comfortable. See the <a href="/docs/density" class="text-primary hover:underline">Density guide</a>.
    </Lumeo.Text>
    <div class="mt-2">
        <PropsTable Slug="number-input" />
    </div>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — General-purpose text input for free-form values</li>
        <li><a href="/components/slider" class="text-primary hover:underline">Slider</a> — Visual range selection when exact precision is less important</li>
        <li><a href="/components/form" class="text-primary hover:underline">Form</a> — Wrap NumberInput with validation and labels in form layouts</li>
    </ul>
</div>

@code {
    private double? _val1 = 5;
    private double? _val2 = 50;
    private double? _val3 = 9.99;
    private double? _valPrice = 19.99;
    private double? _valWeight = 2.5;
    private double? _valWheel = 50;

    private string _numStep = "1";
    private string _numPrecision = "0";
    private double? _numInteractiveVal = 0;

    private string _codeStepPrecision = @"<Segmented @bind-Value=""_numStep"">
    <SegmentedItem Value=""0.1"">0.1</SegmentedItem>
    <SegmentedItem Value=""0.5"">0.5</SegmentedItem>
    <SegmentedItem Value=""1"">1</SegmentedItem>
    <SegmentedItem Value=""5"">5</SegmentedItem>
    <SegmentedItem Value=""10"">10</SegmentedItem>
</Segmented>

<Segmented @bind-Value=""_numPrecision"">
    <SegmentedItem Value=""0"">0</SegmentedItem>
    <SegmentedItem Value=""1"">1</SegmentedItem>
    <SegmentedItem Value=""2"">2</SegmentedItem>
    <SegmentedItem Value=""3"">3</SegmentedItem>
</Segmented>

<NumberInput @bind-Value=""_value""
             Step=""@(double.Parse(_numStep, CultureInfo.InvariantCulture))""
             Precision=""@(int.Parse(_numPrecision))"" />

@code {
    private string _numStep = ""1"";
    private string _numPrecision = ""0"";
    private double? _value = 0;
}";

    private string _codeBasic = @"<NumberInput @bind-Value=""_value"" />";
    private string _codeMinMax = @"<NumberInput @bind-Value=""_value"" Min=""0"" Max=""100"" Step=""5"" />";
    private string _codePrecision = @"<NumberInput @bind-Value=""_value"" Step=""0.01"" Precision=""2"" />";
    private string _codeDisabled = @"<NumberInput Value=""42"" Disabled=""true"" />";
    private string _codePrefixSuffix = @"<NumberInput @bind-Value=""_price"" Min=""0"" Step=""0.01"" Precision=""2"" Prefix=""$"" />
<NumberInput @bind-Value=""_weight"" Min=""0"" Step=""0.5"" Precision=""1"" Suffix=""kg"" />";
    private string _codeWheel = @"<NumberInput @bind-Value=""_value"" Min=""0"" Max=""100"" Step=""1"" UseMouseWheel=""true"" />";
}
