@page "/components/context-menu"

<PageTitle>Context Menu — Lumeo</PageTitle>

<PageHeader Title="Context Menu" Description="Displays a menu triggered by right-clicking an element." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Class="h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm text-muted-foreground">
                    Right click here
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuItem>Back</ContextMenuItem>
                <ContextMenuItem>Forward</ContextMenuItem>
                <ContextMenuItem>Reload</ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>Save As...</ContextMenuItem>
                <ContextMenuItem>Print</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>

    <ComponentDemo Title="With Labels and Groups" Code="@_groupCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Class="h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm text-muted-foreground">
                    Right click here
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuLabel>Edit</ContextMenuLabel>
                <ContextMenuGroup>
                    <ContextMenuItem>Cut</ContextMenuItem>
                    <ContextMenuItem>Copy</ContextMenuItem>
                    <ContextMenuItem>Paste</ContextMenuItem>
                </ContextMenuGroup>
                <ContextMenuSeparator />
                <ContextMenuLabel>View</ContextMenuLabel>
                <ContextMenuGroup>
                    <ContextMenuItem>Zoom In</ContextMenuItem>
                    <ContextMenuItem>Zoom Out</ContextMenuItem>
                    <ContextMenuItem>Reset Zoom</ContextMenuItem>
                </ContextMenuGroup>
                <ContextMenuSeparator />
                <ContextMenuItem Disabled="true">Delete</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>

    <ComponentDemo Title="File Actions" Code="@_fileCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Align="center" Justify="center" Class="h-[150px] w-[300px] rounded-md border border-dashed">
                    <Stack Gap="0" Class="text-center">
                        <Lumeo.Text Size="sm" Weight="medium">document.pdf</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted" Class="mt-1">Right click for options</Lumeo.Text>
                    </Stack>
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuItem>
                    <DynamicIcon Name="Eye" Class="mr-2 h-4 w-4" />
                    Open
                </ContextMenuItem>
                <ContextMenuItem>
                    <DynamicIcon Name="Copy" Class="mr-2 h-4 w-4" />
                    Duplicate
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="ArrowRight" Class="mr-2 h-4 w-4" />
                    Move to...
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="Star" Class="mr-2 h-4 w-4" />
                    Add to Favorites
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="Trash" Class="mr-2 h-4 w-4" />
                    Delete
                </ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">ContextMenu</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpen</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Controls whether the context menu is visible. Use with @@bind-IsOpen.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpenChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;bool&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the open state changes.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">ContextMenuTrigger / ContextMenuContent / ContextMenuItem / ContextMenuSeparator / ContextMenuLabel / ContextMenuGroup</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Layout sub-components that accept ChildContent and Class. ContextMenuTrigger wraps the right-clickable area. ContextMenuContent is the floating panel. ContextMenuItem is a clickable item with optional Disabled and OnClick parameters.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

