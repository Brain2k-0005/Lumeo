@page "/blocks"
@namespace Lumeo.Docs.Pages.BlocksIndex

<PageTitle>Blocks — Lumeo</PageTitle>

<Stack Gap="8">
    <Stack>
        <Heading Level="1" Class="text-3xl">Blocks</Heading>
        <Lumeo.Text Color="muted" Class="mt-1">Full-page application layouts built with Lumeo components.</Lumeo.Text>
    </Stack>

    <Grid Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        @foreach (var item in _blocks)
        {
            <a href="@item.Route" class="group flex flex-col gap-2 rounded-lg border bg-card p-4 hover:bg-accent transition-colors no-underline">
                <Flex Class="items-center gap-2">
                    <Flex Class="h-8 w-8 shrink-0 items-center justify-center rounded-md bg-primary/10">
                        <DynamicIcon Name="@item.Icon" Class="h-4 w-4 text-primary" />
                    </Flex>
                    <Lumeo.Text As="span" Size="sm" Weight="semibold">@item.Label</Lumeo.Text>
                    <DynamicIcon Name="ArrowRight" Class="ml-auto h-4 w-4 text-muted-foreground group-hover:text-foreground transition-colors shrink-0" />
                </Flex>
                <Lumeo.Text Size="xs" Color="muted" Leading="relaxed">@item.Description</Lumeo.Text>
            </a>
        }
    </Grid>
</Stack>

@code {
    private record BlockItem(string Label, string Route, string Icon, string Description);

    private static readonly List<BlockItem> _blocks =
    [
        new("Analytics",      "/blocks/analytics",       "BarChart3",     "Charts, KPIs, and data visualization dashboard."),
        new("Authentication", "/blocks/authentication",   "Lock",          "Login, register, and password reset forms."),
        new("Calendar",       "/blocks/calendar",         "Calendar",      "Event scheduling and calendar views."),
        new("Chat",           "/blocks/chat",             "MessageCircle", "Real-time messaging interface."),
        new("Dashboard",      "/blocks/dashboard",        "LayoutDashboard","Overview panels with stats and activity."),
        new("E-Commerce",     "/blocks/ecommerce",        "ShoppingCart",  "Product listings, cart, and checkout flow."),
        new("File Manager",   "/blocks/file-manager",     "FolderOpen",    "File browser with upload and management."),
        new("Filters",        "/blocks/filters",          "SlidersHorizontal","Advanced filtering and search controls."),
        new("Form Wizard",    "/blocks/form-wizard",      "ClipboardList", "Multi-step form with validation."),
        new("Kanban Board",   "/blocks/kanban",           "Columns3",     "Drag-style task board with columns."),
        new("Mail",           "/blocks/mail",             "Mail",          "Email client with inbox and compose."),
        new("Music Player",   "/blocks/music",            "Music",         "Audio player with playlist management."),
        new("Notifications",  "/blocks/notifications",    "Bell",          "Notification center and alert management."),
        new("Settings",       "/blocks/settings",         "Settings",      "Application settings and preferences."),
        new("Social Feed",    "/blocks/social-feed",      "Users",         "Social media feed with posts and interactions."),
        new("Task Tracker",   "/blocks/task-tracker",     "CheckSquare",   "Task management with status tracking."),
    ];
}
