@namespace Lumeo
@implements IAsyncDisposable
@inject ComponentInteropService Interop

<div id="@_elementId" class="@CssClass" @attributes="AdditionalAttributes">
    <canvas id="@(_elementId + "-canvas")" class="lumeo-globe-canvas" width="@Size" height="@Size" style="width:@(Size)px;height:@(Size)px;" aria-label="Rotating globe illustration" role="img" />
</div>

@code {
    /// <summary>Canvas size in pixels (the canvas is always square).</summary>
    [Parameter] public int Size { get; set; } = 300;
    /// <summary>Color of the globe dots. Defaults to foreground.</summary>
    [Parameter] public string DotColor { get; set; } = "var(--color-foreground)";
    /// <summary>Color of the sweep arc highlight. Defaults to primary.</summary>
    [Parameter] public string GlowColor { get; set; } = "var(--color-primary)";
    /// <summary>Rotation speed multiplier (1 = normal).</summary>
    [Parameter] public double Speed { get; set; } = 1.0;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _elementId = $"lumeo-globe-{Guid.NewGuid():N}";
    private bool _registered;

    private string CssClass => string.Join(" ", new[] { "lumeo-globe", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_registered)
        {
            _registered = true;
            try
            {
                await Interop.MotionGlobe(_elementId, new
                {
                    size = Size,
                    dotColor = DotColor,
                    glowColor = GlowColor,
                    speed = Speed
                });
            }
            catch (JSDisconnectedException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            await Interop.MotionDisposeGlobe(_elementId);
        }
    }
}
