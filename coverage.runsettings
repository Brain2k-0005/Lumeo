<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <!-- Scope coverage to the core Lumeo assembly. The satellite packages
               (Charts, DataGrid, Editor, Gantt, Motion, Scheduler, ...) have their
               own, uneven coverage and would skew a single blanket threshold, so the
               CI gate measures the core component library only. -->
          <Include>[Lumeo]*</Include>
          <Format>cobertura</Format>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
