@page "/components/sidebar"

<PageTitle>Sidebar — Lumeo</PageTitle>

<PageHeader Title="Sidebar" Description="A collapsible sidebar layout with groups, menus, header, and footer. Supports Push, Overlay, and Icon variants." />

<Stack Gap="8">
    <ComponentDemo Title="Push (Default)" Code="@_pushCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_pushCollapsed">
                <SidebarComponent>
                    <SidebarHeader>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Stack Class="h-6 w-6 rounded bg-primary"></Stack>
                            <Lumeo.Text As="span" Size="sm" Class="font-semibold text-foreground">Acme Inc</Lumeo.Text>
                        </Flex>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Platform</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Dashboard</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Users" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Team</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                    <SidebarFooter>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Avatar Src="" Fallback="CN" />
                            <Lumeo.Text As="span" Size="sm" Class="text-foreground">User</Lumeo.Text>
                        </Flex>
                    </SidebarFooter>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Sidebar pushes the main content. Fully hidden when collapsed.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Overlay" Code="@_overlayCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_overlayCollapsed" Variant="SidebarProvider.SidebarVariant.Overlay">
                <SidebarComponent>
                    <SidebarHeader>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Stack Class="h-6 w-6 rounded bg-primary"></Stack>
                            <Lumeo.Text As="span" Size="sm" Class="font-semibold text-foreground">Workspace</Lumeo.Text>
                        </Flex>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Navigation</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Home</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Search</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Notifications</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Sidebar slides over the main content. Click the backdrop to dismiss.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Icon" Code="@_iconCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_iconCollapsed" Variant="SidebarProvider.SidebarVariant.Icon">
                <SidebarComponent>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true" Tooltip="Home">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Home</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Search">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Search</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Notifications">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Notifications</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Settings">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Compact icon-only sidebar. Toggle to expand with labels.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">SidebarProvider</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsCollapsed</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Controls the sidebar collapsed state. Use with @@bind-IsCollapsed.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsCollapsedChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;bool&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the collapsed state changes.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Variant</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">SidebarVariant</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Push</td>
                            <td class="p-3 text-muted-foreground">Sidebar display mode. Values: Push, Overlay.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">Sidebar</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Side</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">SidebarSide</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Left</td>
                            <td class="p-3 text-muted-foreground">Which side the sidebar appears on. Values: Left, Right.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">SidebarMenuButton</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Icon</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Icon content displayed at the start of the button.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Label</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Secondary label content.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Href</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Navigation URL. Renders as an anchor when set.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Tooltip</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Tooltip text shown when the sidebar is collapsed.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsActive</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Highlights the button as the active/current item.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">SidebarHeader / SidebarContent / SidebarFooter / SidebarGroup / SidebarGroupLabel / SidebarMenu / SidebarMenuItem / SidebarSeparator / SidebarTrigger</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Layout sub-components that accept ChildContent and Class. SidebarTrigger toggles the collapsed state. SidebarGroup wraps related menu items. SidebarGroupLabel provides a heading for each group.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

