@page "/components/color-picker"

<PageTitle>ColorPicker — Lumeo</PageTitle>

<PageHeader Title="ColorPicker" Description="A color selection dropdown with swatch grid, hue/lightness sliders, hex input, and optional presets." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Color selection for theme customization or branding settings</li>
        <li>Design tools where users pick colors for text, backgrounds, or borders</li>
        <li>Preset color swatches for quick selection with an option for custom values</li>
        <li>Any form field requiring a visual color input with hex value output</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_codeBasic">
        <ColorPicker @bind-Value="_color1" />
    </ComponentDemo>

    <ComponentDemo Title="With Presets" Code="@_codePresets">
        <ColorPicker @bind-Value="_color2" Presets="_presets" />
    </ComponentDemo>

    <ComponentDemo Title="With Alpha" Code="@_codeAlpha">
        <ColorPicker @bind-Value="_color3" ShowAlpha="true" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_codeDisabled">
        <ColorPicker Value="#6366f1" Disabled="true" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
        <table class="w-full min-w-[600px] text-sm">
            <thead>
                <tr class="border-b border-border/40 bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr><td class="p-3 font-mono text-xs text-primary">Value</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Selected color hex value.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">ShowAlpha</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Show opacity slider.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">Presets</td><td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Predefined color swatches to display.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">Disabled</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Disable the picker.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">IsOpen</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Controls dropdown open state.</td></tr>
                                    <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Two-way binding callback; fires when the color changes.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpenChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;bool&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Two-way binding callback for the popover open state.</td>
                        </tr>
</tbody>
        </table>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — Text input for manual hex or RGB color entry</li>
        <li><a href="/components/popover" class="text-primary hover:underline">Popover</a> — The underlying overlay mechanism used by ColorPicker</li>
        <li><a href="/components/form" class="text-primary hover:underline">Form</a> — Integrate ColorPicker into validated form layouts</li>
    </ul>
</div>

@code {
    private string _color1 = "#3b82f6";
    private string _color2 = "#ef4444";
    private string _color3 = "#22c55e";

    private List<string> _presets = new() { "#ef4444", "#f97316", "#eab308", "#22c55e", "#3b82f6", "#8b5cf6", "#ec4899" };

    private string _codeBasic = @"<ColorPicker @bind-Value=""_color"" />";
    private string _codePresets = @"<ColorPicker @bind-Value=""_color"" Presets=""_presets"" />";
    private string _codeAlpha = @"<ColorPicker @bind-Value=""_color"" ShowAlpha=""true"" />";
    private string _codeDisabled = @"<ColorPicker Value=""#6366f1"" Disabled=""true"" />";
}
