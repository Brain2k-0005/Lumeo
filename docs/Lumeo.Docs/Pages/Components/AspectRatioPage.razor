@page "/components/aspect-ratio"

<PageTitle>Aspect Ratio — Lumeo</PageTitle>

<PageHeader Title="Aspect Ratio" Description="Displays content within a desired ratio." />

<Stack Gap="8">
    <ComponentDemo Title="16:9 Ratio" Code="@_defaultCode">
        <Container MaxWidth="md">
            <AspectRatio Ratio="16.0 / 9.0" Class="rounded-md overflow-hidden bg-muted">
                <div class="flex items-center justify-center h-full text-muted-foreground text-sm">
                    16:9 Aspect Ratio
                </div>
            </AspectRatio>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Different Ratios" Code="@_ratiosCode">
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-3">
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">1:1 (Square)</Lumeo.Text>
                <AspectRatio Ratio="1" Class="rounded-md overflow-hidden bg-muted">
                    <div class="flex items-center justify-center h-full text-muted-foreground text-sm">1:1</div>
                </AspectRatio>
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">4:3</Lumeo.Text>
                <AspectRatio Ratio="4.0 / 3.0" Class="rounded-md overflow-hidden bg-muted">
                    <div class="flex items-center justify-center h-full text-muted-foreground text-sm">4:3</div>
                </AspectRatio>
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">21:9 (Ultra-wide)</Lumeo.Text>
                <AspectRatio Ratio="21.0 / 9.0" Class="rounded-md overflow-hidden bg-muted">
                    <div class="flex items-center justify-center h-full text-muted-foreground text-sm">21:9</div>
                </AspectRatio>
            </div>
        </Grid>
    </ComponentDemo>

    <ComponentDemo Title="Media Card" Code="@_mediaCardCode">
        <Container MaxWidth="sm">
            <Card>
                <AspectRatio Ratio="16.0 / 9.0" Class="rounded-t-lg overflow-hidden bg-muted">
                    <div class="flex items-center justify-center h-full text-muted-foreground text-sm">
                        <DynamicIcon Name="Eye" Class="h-8 w-8 opacity-50" />
                    </div>
                </AspectRatio>
                <CardContent Class="p-4">
                    <Lumeo.Text Class="font-semibold text-foreground">Getting Started with Lumeo</Lumeo.Text>
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-1">Learn how to build beautiful UIs with Lumeo components.</Lumeo.Text>
                </CardContent>
            </Card>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">AspectRatio</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Ratio</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">1</td>
                            <td class="p-3 text-muted-foreground">The desired width-to-height ratio (e.g. 16.0/9.0).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes for the inner container.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-md overflow-hidden bg-muted"">
    <div class=""flex items-center justify-center h-full"">
        16:9 Aspect Ratio
    </div>
</AspectRatio>";

    private string _ratiosCode = @"<AspectRatio Ratio=""1"" Class=""rounded-md overflow-hidden bg-muted"">
    <div class=""flex items-center justify-center h-full"">1:1</div>
</AspectRatio>

<AspectRatio Ratio=""4.0 / 3.0"" Class=""rounded-md overflow-hidden bg-muted"">
    <div class=""flex items-center justify-center h-full"">4:3</div>
</AspectRatio>";

    private string _mediaCardCode = @"<Card>
    <AspectRatio Ratio=""16.0 / 9.0"" Class=""rounded-t-lg overflow-hidden bg-muted"">
        <div class=""flex items-center justify-center h-full text-muted-foreground"">
            Thumbnail
        </div>
    </AspectRatio>
    <CardContent Class=""p-4"">
        <Lumeo.Text Weight=""semibold"">Getting Started with Lumeo</Lumeo.Text>
        <Lumeo.Text Size=""sm"" Color=""muted"" Class=""mt-1"">Learn how to build beautiful UIs.</Lumeo.Text>
    </CardContent>
</Card>";
}
