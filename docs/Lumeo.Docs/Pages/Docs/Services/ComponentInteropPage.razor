                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RegisterCarouselSwipe(elementId, orientation, ...)</td>
                            <td class="p-3 text-xs text-muted-foreground">Gesture</td>
                            <td class="p-3 text-muted-foreground">Handle swipe/scroll for carousel.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RegisterResizeHandle(elementId, direction, ...)</td>
                            <td class="p-3 text-xs text-muted-foreground">Resize</td>
                            <td class="p-3 text-muted-foreground">Drag-to-resize for resizable panels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RegisterScrollspy(containerId, offset, smooth, handler)</td>
                            <td class="p-3 text-xs text-muted-foreground">Scroll</td>
                            <td class="p-3 text-muted-foreground">Track active section during scroll.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RegisterAffix(elementId, offsetTop, ...)</td>
                            <td class="p-3 text-xs text-muted-foreground">Scroll</td>
