@page "/components/empty-state"

<PageTitle>Empty State — Lumeo</PageTitle>

<PageHeader Title="Empty State" Description="A placeholder component for when there is no data to display." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="No results found" Description="Try adjusting your search or filters to find what you're looking for." />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="With Icon and Action" Code="@_actionCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="No projects yet" Description="Get started by creating your first project.">
                <Icon>
                    <DynamicIcon Name="Plus" Class="h-10 w-10" />
                </Icon>
                <Action>
                    <Button>Create Project</Button>
                </Action>
            </EmptyState>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Inbox Empty" Code="@_inboxCode">
        <Stack Class="rounded-lg border bg-card">
            <EmptyState Title="Inbox zero" Description="You have no new messages. Enjoy the silence.">
                <Icon>
                    <DynamicIcon Name="Mail" Class="h-10 w-10" />
                </Icon>
            </EmptyState>
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="emptystate" Level="3" Class="mt-8 scroll-mt-20">EmptyState</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">Icon</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Custom icon displayed above the title.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Title</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Main heading text for the empty state.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Description</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Secondary description text below the title.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Action</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Action buttons area below the description.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

@code {
    private string _defaultCode = @"<EmptyState
    Title=""No results found""
    Description=""Try adjusting your search or filters."" />";

    private string _actionCode = @"<EmptyState Title=""No projects yet"" Description=""Get started by creating your first project."">
    <Icon>
        <DynamicIcon Name=""Plus"" Class=""h-10 w-10"" />
    </Icon>
    <Action>
        <Button>Create Project</Button>
    </Action>
</EmptyState>";

    private string _inboxCode = @"<EmptyState Title=""Inbox zero"" Description=""You have no new messages."">
    <Icon>
        <DynamicIcon Name=""Mail"" Class=""h-10 w-10"" />
    </Icon>
</EmptyState>";
}
