<ToastProvider />

@inject ToastService ToastService

@code {
    private void ShowWithAction()
    {
        ToastService.Show(new ToastOptions
        {
            Title = "Message sent",
            Description = "Your message has been delivered.",
            ActionLabel = "Undo",
            OnAction = () => ToastService.Info("Undone", "Message recalled."),
            Duration = 8000
        });
    }

    private void ShowPersistent()
    {
        var id = ToastService.Show(new ToastOptions
        {
            Title = "Uploading...",
            Description = "Please wait.",
            Dismissible = false,
            Duration = 0
        });
        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            ToastService.Update(id, new ToastOptions
            {
                Title = "Upload complete!",
                Variant = ToastVariant.Success,
                Duration = 3000,
                Dismissible = true
            });
        });
    }

    private async Task ShowPromise()
    {
        await ToastService.Promise(
            action: async () => { await Task.Delay(2000); return new { Id = 42 }; },
            loading: new ToastOptions { Title = "Saving...", Description = "Please wait." },
            success: result => new ToastOptions
            {
                Title = "Saved!",
                Description = $"Created record #{result.Id}",
                Variant = ToastVariant.Success
            },
            error: ex => new ToastOptions
            {
                Title = "Failed",
                Description = ex.Message,
                Variant = ToastVariant.Destructive
            }
        );
    }
}
