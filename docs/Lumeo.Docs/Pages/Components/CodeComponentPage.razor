@page "/components/code"

<PageTitle>Code — Lumeo</PageTitle>

<PageHeader Title="Code" Description="A component for displaying inline or block code snippets with consistent styling." />

<Stack Gap="8">
    <ComponentDemo Title="Inline Code" Code="@_inlineCode">
        <Lumeo.Text>
            Use the <Code>Console.WriteLine()</Code> method to print output. You can also use <Code>Debug.Log()</Code> for debugging.
        </Lumeo.Text>
    </ComponentDemo>

    <ComponentDemo Title="Block Code" Code="@_blockCode">
        <Code Variant="block" Class="w-full max-w-lg">
            var builder = WebApplication.CreateBuilder(args);<br />
            builder.Services.AddRazorComponents();<br />
            var app = builder.Build();<br />
            app.Run();
        </Code>
    </ComponentDemo>

    <ComponentDemo Title="With Custom Size" Code="@_sizeCode">
        <Stack Gap="3">
            <Lumeo.Text>Small: <Code Size="xs">npm install</Code></Lumeo.Text>
            <Lumeo.Text>Default: <Code>npm install</Code></Lumeo.Text>
            <Lumeo.Text>Large: <Code Size="lg">npm install</Code></Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <Stack Gap="6" Class="mt-12">
        <Heading Level="2">API Reference</Heading>
        <Stack Gap="8">
            <Stack>
                <Heading Level="3" Class="mb-3">Code</Heading>
                <Stack Class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Property</th>
                                <th class="text-left p-3 font-medium text-foreground">Type</th>
                                <th class="text-left p-3 font-medium text-foreground">Default</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Variant</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">"inline"</td>
                                <td class="p-3 text-muted-foreground">Display variant. Values: "inline" for within text, "block" for standalone code blocks.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Size</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Font size override. Maps to text-{value} (e.g. "xs", "sm", "lg").</td>
                            </tr>
                        </tbody>
                    </table>
                </Stack>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _inlineCode = @"<Text>
    Use the <Code>Console.WriteLine()</Code> method to print output.
</Text>";

    private string _blockCode = @"<Code Variant=""block"">
    var builder = WebApplication.CreateBuilder(args);
    builder.Services.AddRazorComponents();
    var app = builder.Build();
    app.Run();
</Code>";

    private string _sizeCode = @"<Code Size=""xs"">npm install</Code>
<Code>npm install</Code>
<Code Size=""lg"">npm install</Code>";
}
