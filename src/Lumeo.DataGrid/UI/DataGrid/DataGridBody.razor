@namespace Lumeo
@typeparam TItem
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@if (Context is not null && Context.IsLoading)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @{
            // Context.VisibleColumns is already filtered + cached at the grid level.
            var visibleColumns = Context.VisibleColumns;
            var fallbackCellCount = visibleColumns.Count > 0 ? visibleColumns.Count : (SkeletonRowCount > 0 ? 4 : 4);
        }
        @for (var i = 0; i < SkeletonRowCount; i++)
        {
            <tr class="border-b border-border/40">
                @if (Context.SelectionMode != DataGridSelectionMode.None)
                {
                    <td class="px-3 py-2 w-10">
                        <Skeleton Class="h-4 w-4 rounded" />
                    </td>
                }
                @if (HasDetailTemplate)
                {
                    <td class="px-1 py-2 w-8">
                        <Skeleton Class="h-4 w-4 rounded" />
                    </td>
                }
                @if (visibleColumns.Count > 0)
                {
                    @foreach (var column in visibleColumns)
                    {
                        <td class="px-3 py-2">
                            <Skeleton Class="h-4 w-full rounded" />
                        </td>
                    }
                }
                else
                {
                    @for (var j = 0; j < fallbackCellCount; j++)
                    {
                        <td class="px-3 py-2">
                            <Skeleton Class="h-4 w-full rounded" />
                        </td>
                    }
                }
            </tr>
        }
    </tbody>
}
else if (Context is not null && Context.IsTreeGrid)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @if (Context.DisplayedItems.Count == 0)
        {
            <tr>
                <td colspan="@ColSpan" class="px-3 py-8 text-center text-muted-foreground">
                    @if (EmptyContent is not null) { @EmptyContent }
                    else
                    {
                        <div class="flex flex-col items-center gap-2">
                            <SvgGlyph Svg="@(LumeoIcons.Inbox)" class="h-8 w-8 text-muted-foreground/50" />
                            <span class="text-sm">@L["DataGrid.NoData"]</span>
                        </div>
                    }
                </td>
            </tr>
        }
        else
        {
            var ti = 0;
            foreach (var item in Context.DisplayedItems)
            {
                <DataGridRow @key="DataGridRowKeys.KeyFor(item)" TItem="TItem"
                             Item="item"
                             RowIndex="ti"
                             DetailTemplate="DetailTemplate"
                             OnContextMenu="OnContextMenu" />
                ti++;
            }
        }
    </tbody>
}
else if (Context is not null && Context.GroupTree is not null && Context.GroupTree.Count > 0)
{
    // Multi-level grouping: render a nested forest of group rows.
    // globalIdx spans the WHOLE tbody (every group, every nesting level), not
    // just the current group — it's captured by the renderNode closure below
    // and mutated across recursive calls. A per-group counter that reset to 0
    // at each group boundary used to make DataGridRow.AriaRowIndex (and the
    // "Select/Expand/Collapse row N" labels built from it) collide across
    // groups, e.g. every group's first row announcing itself as "Select row 2"
    // — a global counter guarantees each row gets a distinct index.
    //
    // tableRowIdx is a SEPARATE global counter for aria-rowindex specifically:
    // it counts every rendered <tr> — group header rows AND item rows — while
    // globalIdx stays item-only (it also drives striping/select-row labels, which
    // must stay keyed to item order). A group header occupies a real table row, so
    // the item immediately after it — and every item after that — is one aria
    // position further along than globalIdx alone would report; tableRowIdx tracks
    // that. Fed to DataGridRow.TableRowIndex and DataGridGroupRow.RowIndex.
    var globalIdx = 0;
    var tableRowIdx = 0;
    RenderFragment<DataGridGroupNode<TItem>>? renderNode = null;
    renderNode = node => __builder =>
    {
        var expanded = Context.IsGroupPathExpanded(node.Path);
        <DataGridGroupRow @key="@("g:" + node.Path)" TItem="TItem"
                          GroupKey="@node.Key"
                          Count="@node.TotalCount"
                          Level="@node.Level"
                          IsExpanded="@expanded"
                          Aggregates="@node.Aggregates"
                          ColSpan="@ColSpan"
                          RowIndex="tableRowIdx"
                          OnToggle="@(() => Context.ToggleGroupPath(node.Path))" />
        tableRowIdx++;
        if (expanded)
        {
            if (node.Children.Count > 0)
            {
                foreach (var child in node.Children)
                {
                    @renderNode!(child)
                }
            }
            else
            {
                foreach (var item in node.Items)
                {
                    <DataGridRow @key="DataGridRowKeys.KeyFor(item)" TItem="TItem"
                                 Item="item"
                                 RowIndex="globalIdx"
                                 TableRowIndex="tableRowIdx"
                                 DetailTemplate="DetailTemplate"
                                 OnContextMenu="OnContextMenu" />
                    globalIdx++;
                    tableRowIdx++;
                }
            }
        }
    };
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @foreach (var root in Context.GroupTree)
        {
            @renderNode(root)
        }
    </tbody>
}
else if (Context is not null && Context.IsGrouped && Context.GroupedSections is not null && Context.GroupedSections.Count > 0)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @{
            // Spans every group in this tbody — see the GroupTree branch above
            // for why a per-group counter that resets at each group boundary
            // produces duplicate row labels/aria-rowindex across groups.
            //
            // tableRowIdx additionally counts each DataGridGroupRow's own row slot
            // (globalIdx deliberately doesn't — see the GroupTree branch above) so
            // the item rows after it report the correct aria-rowindex instead of
            // silently reusing the group header's.
            var globalIdx = 0;
            var tableRowIdx = 0;
        }
        @foreach (var grp in Context.GroupedSections)
        {
            var groupKey = grp.Key;
            var expanded = Context.IsGroupExpanded(groupKey);
            <DataGridGroupRow @key="groupKey" TItem="TItem"
                              GroupKey="@groupKey"
                              Count="@grp.TotalCount"
                              IsExpanded="@expanded"
                              Aggregates="@grp.Aggregates"
                              ColSpan="@ColSpan"
                              RowIndex="tableRowIdx"
                              OnToggle="@(() => Context.ToggleGroupExpand(groupKey))" />
            tableRowIdx++;
            if (expanded)
            {
                foreach (var item in grp.Items)
                {
                    <DataGridRow @key="DataGridRowKeys.KeyFor(item)" TItem="TItem"
                                 Item="item"
                                 RowIndex="globalIdx"
                                 TableRowIndex="tableRowIdx"
                                 DetailTemplate="DetailTemplate"
                                 OnContextMenu="OnContextMenu" />
                    globalIdx++;
                    tableRowIdx++;
                }
            }
        }
    </tbody>
}
else if (Context is not null && Context.DisplayedItems.Count == 0)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        <tr>
            <td colspan="@ColSpan" class="px-3 py-8 text-center text-muted-foreground">
                @if (EmptyContent is not null)
                {
                    @EmptyContent
                }
                else
                {
                    <div class="flex flex-col items-center gap-2">
                        <SvgGlyph Svg="@(LumeoIcons.Inbox)" class="h-8 w-8 text-muted-foreground/50" />
                        <span class="text-sm">@L["DataGrid.NoData"]</span>
                    </div>
                }
            </td>
        </tr>
    </tbody>
}
else if (Context is not null && ServerVirtualizationProvider is not null)
{
    @* Virtualised server mode: rows are fetched in scroll-driven windows
       via ItemsProvider, so the in-memory list is empty until the user
       scrolls. SpacerElement="tr" is non-negotiable inside <tbody>. *@
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        <Virtualize @ref="_virtualize" TItem="IndexedItem"
                    ItemsProvider="ServerVirtualizationProvider"
                    Context="entry"
                    SpacerElement="tr"
                    ItemSize="@VirtualItemSize"
                    OverscanCount="@VirtualOverscanCount">
            <ItemContent>
                <DataGridRow TItem="TItem"
                             Item="entry.Item"
                             RowIndex="entry.Index"
                             DetailTemplate="DetailTemplate"
                             OnContextMenu="OnContextMenu" />
            </ItemContent>
            <Placeholder>
                <tr class="border-b border-border/40">
                    <td colspan="@ColSpan" class="px-3 py-2">
                        <Skeleton Class="h-4 w-full rounded" />
                    </td>
                </tr>
            </Placeholder>
        </Virtualize>
    </tbody>
}
else if (Context is not null && UseVirtualization)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @* SpacerElement="tr" is required: <Virtualize> defaults to <div>
           spacers, but <div> is invalid as a direct child of <tbody> and the
           browser hoists it out of the table, breaking layout. *@
        <Virtualize Items="@_indexedItems" Context="entry"
                    SpacerElement="tr"
                    ItemSize="@VirtualItemSize"
                    OverscanCount="@VirtualOverscanCount">
            <DataGridRow TItem="TItem"
                         Item="entry.Item"
                         RowIndex="entry.Index"
                         DetailTemplate="DetailTemplate"
                         OnContextMenu="OnContextMenu" />
        </Virtualize>
    </tbody>
}
else if (Context is not null)
{
    <tbody data-slot="datagrid-body" class="@CssClass" @attributes="AdditionalAttributes">
        @if (Context.IsGrouped && Context.GroupedSections is not null)
        {
            // Spans every group in this tbody — see the GroupTree branch
            // above for why a per-group counter that resets at each group
            // boundary produces duplicate row labels/aria-rowindex across
            // groups.
            //
            // tableRowIdx additionally counts each DataGridGroupRow's own row
            // slot (globalIdx deliberately doesn't — see the GroupTree branch
            // above) so the item rows after it report the correct
            // aria-rowindex instead of silently reusing the group header's.
            var globalIdx = 0;
            var tableRowIdx = 0;
            @foreach (var grp in Context.GroupedSections)
            {
                var groupKey = grp.Key;
                var expanded = Context.IsGroupExpanded(groupKey);
                <DataGridGroupRow @key="groupKey" TItem="TItem"
                                  GroupKey="@groupKey"
                                  Count="@grp.TotalCount"
                                  IsExpanded="@expanded"
                                  ColSpan="@ColSpan"
                                  RowIndex="tableRowIdx"
                                  OnToggle="@(() => Context.ToggleGroupExpand(groupKey))" />
                tableRowIdx++;
                if (expanded)
                {
                    foreach (var item in grp.Items)
                    {
                        <DataGridRow @key="DataGridRowKeys.KeyFor(item)" TItem="TItem"
                                     Item="item"
                                     RowIndex="globalIdx"
                                     TableRowIndex="tableRowIdx"
                                     DetailTemplate="DetailTemplate"
                                     OnContextMenu="OnContextMenu" />
                        globalIdx++;
                        tableRowIdx++;
                    }
                }
            }
        }
        else
        {
            var idx = 0;
            foreach (var item in Context.DisplayedItems)
            {
                @* This is the ONLY DataGridRow render site where RowReorderPointerActive
                   can be true (flat, non-grouped, non-virtualized, non-tree — see that
                   property's remarks), so it's the only site that needs a real per-slot
                   RowToken; every other site below leaves it at its 0 default, which is
                   harmless since DataGridRow.RowKey is never evaluated there. *@
                <DataGridRow @key="DataGridRowKeys.KeyFor(item)" TItem="TItem"
                             Item="item"
                             RowIndex="idx"
                             RowToken="Context.RowTokenAt(idx)"
                             DetailTemplate="DetailTemplate"
                             OnContextMenu="OnContextMenu" />
                idx++;
            }
        }
    </tbody>
}

@code {
    [CascadingParameter] private DataGridContext<TItem>? Context { get; set; }

    /// <summary>Row-detail template forwarded to each rendered <see cref="DataGridRow{TItem}"/>.</summary>
    [Parameter] public RenderFragment<TItem>? DetailTemplate { get; set; }

    /// <summary>Custom content shown in the single empty-state <c>&lt;tr&gt;</c> when
    /// there are no rows to display. Falls back to a default "no data" message + icon.</summary>
    [Parameter] public RenderFragment? EmptyContent { get; set; }

    /// <summary>Renders rows through Blazor's <c>&lt;Virtualize&gt;</c> instead of a plain
    /// loop, for large in-memory item sets. Ignored when <see cref="ServerVirtualizationProvider"/>
    /// is set (that takes the ItemsProvider path instead).</summary>
    [Parameter] public bool UseVirtualization { get; set; }

    /// <summary>Estimated row height in CSS pixels, forwarded to <c>&lt;Virtualize&gt;</c>
    /// to size its scroll spacers. Defaults to 41.</summary>
    [Parameter] public float VirtualItemSize { get; set; } = 41f;

    /// <summary>Extra rows rendered above/below the viewport by <c>&lt;Virtualize&gt;</c>
    /// to hide pop-in during fast scrolling. Defaults to 3.</summary>
    [Parameter] public int VirtualOverscanCount { get; set; } = 3;
    /// <summary>When set, switches the body to ItemsProvider-mode
    /// virtualisation (window-fetched server scrolling). Null disables.</summary>
    [Parameter] public Microsoft.AspNetCore.Components.Web.Virtualization.ItemsProviderDelegate<IndexedItem>? ServerVirtualizationProvider { get; set; }

    /// <summary>Whether the grid has a <see cref="DetailTemplate"/> configured — adds
    /// an extra leading spacer column to <see cref="ColSpan"/> for the empty/skeleton rows.</summary>
    [Parameter] public bool HasDetailTemplate { get; set; }

    /// <summary>Number of placeholder skeleton rows rendered while <c>Context.IsLoading</c>
    /// is true. Defaults to 5.</summary>
    [Parameter] public int SkeletonRowCount { get; set; } = 5;

    /// <summary>Fires when a row is right-clicked, carrying the item and the pointer's
    /// client X/Y coordinates for positioning the context menu.</summary>
    [Parameter] public EventCallback<(TItem, double, double)> OnContextMenu { get; set; }

    /// <summary>Additional CSS classes merged onto the <c>&lt;tbody&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures unmatched attributes and applies them to the <c>&lt;tbody&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"{Class}".Trim();

    private List<IndexedItem> _indexedItems = new();
    private Microsoft.AspNetCore.Components.Web.Virtualization.Virtualize<IndexedItem>? _virtualize;

    /// <summary>Tells the inner <c>Virtualize</c> component to discard its
    /// window cache and refetch via <see cref="ServerVirtualizationProvider"/>.
    /// No-op when not in ItemsProvider mode (no virtualizer in tree).</summary>
    public Task RefreshVirtualizeAsync() =>
        _virtualize is not null ? _virtualize.RefreshDataAsync() : Task.CompletedTask;

    protected override void OnParametersSet()
    {
        if (UseVirtualization && Context is not null)
        {
            _indexedItems = Context.DisplayedItems
                .Select((item, idx) => new IndexedItem(item, idx))
                .ToList();
        }
    }

    private int ColSpan
    {
        get
        {
            var count = Context?.VisibleColumns.Count ?? 1;
            if (Context?.SelectionMode != DataGridSelectionMode.None) count++;
            if (HasDetailTemplate) count++;
            return count;
        }
    }

    public record IndexedItem(TItem Item, int Index);
}
