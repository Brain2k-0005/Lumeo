@page "/components/back-to-top"

<PageTitle>BackToTop — Lumeo</PageTitle>

<PageHeader Title="BackToTop" Description="A floating button that appears when the user scrolls down and smoothly scrolls back to the top." />

<div class="space-y-8">
    <ComponentDemo Title="Default" Code="@_codeDefault">
        <div class="text-sm text-muted-foreground">
            <Text>Scroll down the page to see the BackToTop button appear in the bottom-right corner.</Text>
            <Text Class="mt-2">The button appears after scrolling past 300px by default.</Text>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Custom Threshold" Code="@_codeThreshold">
        <Text Class="text-sm text-muted-foreground">Set <code class="font-mono bg-muted px-1 rounded">VisibilityThreshold</code> to control when the button appears.</Text>
    </ComponentDemo>
</div>

<!-- API Reference -->
<div class="mt-12 space-y-6">
    <Heading Level="2" Class="text-2xl font-bold text-foreground">API Reference</Heading>
    <div class="rounded-lg border border-border overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr><td class="p-3 font-mono text-xs text-primary">VisibilityThreshold</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">300</td><td class="p-3 text-muted-foreground">Scroll distance in pixels before the button appears.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">ChildContent</td><td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Custom content replacing the default arrow icon.</td></tr>
            </tbody>
        </table>
    </div>
</div>

@code {
    private string _codeDefault = @"<BackToTop />";
    private string _codeThreshold = @"<BackToTop VisibilityThreshold=""500"" />";
}
