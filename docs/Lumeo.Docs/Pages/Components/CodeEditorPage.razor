""";
    private const string _htmlCssCode = """
<CodeEditor @bind-Value="_html" Language="html" Height="200px" />
<CodeEditor @bind-Value="_css"  Language="css"  Height="200px" />
""";
    private const string _markdownCode = "<CodeEditor @bind-Value=\"_md\" Language=\"markdown\" Height=\"240px\" />";
    private const string _sqlCode = "<CodeEditor @bind-Value=\"_sql\" Language=\"sql\" Height=\"200px\" />";
    private const string _pythonCode = "<CodeEditor @bind-Value=\"_py\" Language=\"python\" Height=\"220px\" />";
    private const string _xmlCode = "<CodeEditor @bind-Value=\"_xml\" Language=\"xml\" Height=\"200px\" />";
    private const string _readOnlyCode = "<CodeEditor Value=\"@audit\" Language=\"json\" Height=\"160px\" ReadOnly=\"true\" />";
    private const string _darkCode = "<CodeEditor @bind-Value=\"_dark\" Language=\"javascript\" Theme=\"dark\" Height=\"200px\" />";
    private const string _wrapCode = "<CodeEditor @bind-Value=\"_text\" Language=\"plaintext\" WordWrap=\"on\" UseTabs=\"true\" TabSize=\"2\" Height=\"200px\" />";
    private const string _boundCode = """
<CodeEditor @bind-Value="_boundJson" Language="json" Height="160px" />
