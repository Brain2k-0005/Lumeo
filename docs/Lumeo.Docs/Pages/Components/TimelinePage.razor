</Timeline>
<Flex Gap=""2"">
    <Button OnClick=""() => { if (_activeIndex > 0) _activeIndex--; }"">Previous</Button>
    <Button OnClick=""() => { if (_activeIndex < 3) _activeIndex++; }"">Next</Button>
</Flex>

@code { private int _activeIndex = 1; }";
