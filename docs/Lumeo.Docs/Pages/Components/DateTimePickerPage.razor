@code {
    private DateTime? _dateTime1 = DateTime.Now;
    private DateTime? _dateTime2 = DateTime.Today.AddHours(10).AddMinutes(30);
    private DateTime? _dateTime3;
    private TimeZoneInfo _berlin = ResolveBerlin();
    private DateTimeOffset? _meeting;

    private static TimeZoneInfo ResolveBerlin()
    {
        try { return TimeZoneInfo.FindSystemTimeZoneById("Europe/Berlin"); }
        catch { return TimeZoneInfo.Utc; }
    }

    private string _timeZoneCode = @"<DateTimePicker @bind-OffsetValue=""_meeting""
                TimeZone=""@_berlin""
                ShowTimeZoneLabel=""true"" />

@code {
    TimeZoneInfo _berlin = TimeZoneInfo.FindSystemTimeZoneById(""Europe/Berlin"");
    DateTimeOffset? _meeting;
}";

    private DateTime? _dateTime4;
    private DateTime? _dateTime5;
    private DateTime? _dateTime6;
    private DateTime _dtMinDate = DateTime.Today;
    private DateTime _dtMaxDate = DateTime.Today.AddDays(30);

    private string _basicCode = @"<DateTimePicker @bind-Value=""_dateTime"" />";
    private string _clearableCode = @"<DateTimePicker @bind-Value=""_dateTime"" Clearable=""true"" />";
    private string _fullCode = @"<DateTimePicker @bind-Value=""_dateTime"" Use24Hour=""false"" ShowSeconds=""true"" />";
    private string _minMaxCode = @"<DateTimePicker @bind-Value=""_dateTime"" MinDate=""@_minDate"" MaxDate=""@_maxDate"" Placeholder=""Select within range"" />

@code {
    private DateTime? _dateTime;
    private DateTime _minDate = DateTime.Today;
    private DateTime _maxDate = DateTime.Today.AddDays(30);
}";
}
