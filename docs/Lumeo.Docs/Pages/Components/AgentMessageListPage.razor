@page "/components/agent-message-list"
@implements IDisposable
@inject Lumeo.Services.IComponentInteropService Interop

<PageTitle>AgentMessageList — Lumeo</PageTitle>

<PageHeader Title="AgentMessageList"
            Description="Auto-scrolling chat-style message list for AI agent conversations. Distinguishes user, assistant, and tool turns." />

<InstallUsage Component="AgentMessageList" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Rendering an LLM conversation where user, assistant, and tool messages need distinct styling.</li>
        <li>Streaming multi-turn responses — <code class="text-xs bg-muted px-1 py-0.5 rounded">AutoScroll</code> sticks to the bottom as new tokens arrive.</li>
        <li>Composing with <code class="text-xs bg-muted px-1 py-0.5 rounded">&lt;StreamingText&gt;</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">&lt;ToolCallCard&gt;</code>, and <code class="text-xs bg-muted px-1 py-0.5 rounded">&lt;ReasoningDisplay&gt;</code> for a full agent UI.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Live Chat Transcript" Code="@_demoCode">
        <div class="flex h-[520px] flex-col gap-3 rounded-lg border border-border/60 bg-background p-3">
            <AgentMessageList Class="flex-1 pr-1">
                <AgentMessage Role="AgentMessage.AgentMessageRole.System">
                    Session started @DateTime.Now.ToString("HH:mm")
                </AgentMessage>

                <AgentMessage Role="AgentMessage.AgentMessageRole.User" Name="You" Timestamp="DateTimeOffset.Now.AddMinutes(-2)">
                    Summarise the quarterly revenue numbers for EMEA and tell me which region grew fastest.
                </AgentMessage>

                <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Lumeo Copilot" Timestamp="DateTimeOffset.Now.AddMinutes(-2)">
                    <ReasoningDisplay Text="User wants EMEA revenue breakdown. I should call the sales tool to pull Q1–Q4 numbers, then compute growth per sub-region. DACH looked strong last quarter."
                                      DurationMs="2400" />
                </AgentMessage>

                <AgentMessage Role="AgentMessage.AgentMessageRole.Tool">
                    <ToolCallCard ToolName="query_sales_db"
                                  Status="ToolCallCard.ToolCallStatus.Success"
                                  Input="@("{\n  \"region\": \"EMEA\",\n  \"period\": \"2026-Q1\"\n}")"
                                  Output="@("{\n  \"DACH\": 12_400_000,\n  \"UK\": 9_800_000,\n  \"Nordics\": 4_200_000,\n  \"Iberia\": 3_100_000\n}")"
                                  DurationMs="842" />
                </AgentMessage>

                <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Lumeo Copilot" IsStreaming="@_isStreaming">
                    <StreamingText Text="@_streamedText" IsStreaming="@_isStreaming" />
                </AgentMessage>
            </AgentMessageList>

            <PromptInput @bind-Value="_promptValue"
                         Placeholder="Ask a follow-up…"
                         IsLoading="@_isStreaming"
                         OnSend="HandleSend">
                <LeadingContent>
                    <button type="button" class="inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-foreground" aria-label="Attach file">
                        <Icon Name="Paperclip" Size="Lumeo.Size.Sm" />
                    </button>
                </LeadingContent>
                <TrailingContent>
                    <span class="tabular-nums">@(_promptValue?.Length ?? 0) / 2000</span>
                </TrailingContent>
            </PromptInput>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Role Switcher — interactive" Description="Pick a role to see how a single AgentMessage renders for each turn type." Code="@_roleSwitcherCode">
        <Stack Gap="4" Class="w-full max-w-xl">
            <Segmented @bind-Value="_agentRole">
                <SegmentedItem Value="User">User</SegmentedItem>
                <SegmentedItem Value="Assistant">Assistant</SegmentedItem>
                <SegmentedItem Value="System">System</SegmentedItem>
                <SegmentedItem Value="Tool">Tool</SegmentedItem>
            </Segmented>
            <div class="w-full max-w-xl h-[280px] overflow-y-auto pr-1">
                <AgentMessageList>
                    @if (_agentRole == "Tool")
                    {
                        <AgentMessage Role="AgentMessage.AgentMessageRole.Tool">
                            <ToolCallCard ToolName="example_tool" Status="ToolCallCard.ToolCallStatus.Success"
                                          Input="@("{}")" Output="OK" DurationMs="12" />
                        </AgentMessage>
                    }
                    else
                    {
                        <AgentMessage Role="@_agentRoleEnum"
                                      Name="@(_agentRole == "User" ? "You" : _agentRole == "Assistant" ? "Copilot" : null)">
                            This is a <strong>@_agentRole</strong> message. Its bubble style, alignment, and label adapt to the selected role.
                        </AgentMessage>
                    }
                </AgentMessageList>
            </div>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Roles at a Glance" Code="@_rolesCode">
        <div class="w-full max-w-xl h-[420px] overflow-y-auto pr-1">
            <AgentMessageList>
                <AgentMessage Role="AgentMessage.AgentMessageRole.System">
                    System-level notice — session info, warnings, or injected context.
                </AgentMessage>
                <AgentMessage Role="AgentMessage.AgentMessageRole.User" Name="Alice">
                    A user turn — right-aligned bubble with name.
                </AgentMessage>
                <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Assistant">
                    An assistant turn — left-aligned with optional streaming caret.
                </AgentMessage>
                <AgentMessage Role="AgentMessage.AgentMessageRole.Tool">
                    <ToolCallCard ToolName="example_tool" Status="ToolCallCard.ToolCallStatus.Success"
                                  Input="@("{}")" Output="OK" DurationMs="12" />
                </AgentMessage>
            </AgentMessageList>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Actions, Branches & Markdown Export"
                   Description="Assistant turns can carry a copy/regenerate/retry toolbar and branch navigation between alternate responses. Export the whole thread to Markdown."
                   Code="@_actionsCode">
        <div class="w-full max-w-xl space-y-3">
            <AgentMessageList Class="h-[220px]">
                <AgentMessage Role="AgentMessage.AgentMessageRole.User" Name="You">
                    Give me a tagline for a productivity app.
                </AgentMessage>
                <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Copilot">
                    <ChildContent>
                        @_branches[_branchIndex]
                    </ChildContent>
                    <Actions>
                        <AgentMessageBranchNav @bind-Index="_branchIndex" Count="_branches.Length" />
                        <AgentMessageActions CopyText="@_branches[_branchIndex]"
                                             OnRegenerate="Regenerate" />
                    </Actions>
                </AgentMessage>
            </AgentMessageList>
            <button type="button" @onclick="ExportMarkdown"
                    class="inline-flex h-9 items-center gap-2 rounded-md border border-border bg-background px-3 text-sm font-medium hover:bg-accent">
                <Icon Name="Download" Size="Lumeo.Size.Sm" /> Export transcript (.md)
            </button>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Empty State" Description="Set IsEmpty to show a placeholder while there are no messages — a localized default, or your own EmptyState slot." Code="@_emptyCode">
        <div class="w-full max-w-xl h-[220px] rounded-lg border border-border/60">
            <AgentMessageList IsEmpty="true">
                <EmptyState>
                    <Icon Name="MessageCircle" Size="Lumeo.Size.Lg" Class="text-muted-foreground" />
                    <p class="text-sm font-medium text-foreground">No messages yet</p>
                    <p class="text-sm text-muted-foreground">Ask a question to get started.</p>
                </EmptyState>
            </AgentMessageList>
        </div>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">AgentMessageList</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ChildContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Usually one or more <code class="font-mono text-xs">&lt;AgentMessage&gt;</code> children.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">AutoScroll</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Keeps the list scrolled to the bottom when new content arrives via a MutationObserver.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowScrollButton</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows a floating scroll-to-latest button when the list is scrolled away from the bottom.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Virtualize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Opt-in virtualization for long threads. When true and <code class="text-xs">Items</code> is supplied, messages render through <code class="text-xs">Virtualize&lt;TItem&gt;</code> so only the rows near the viewport are in the DOM.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Items</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">IReadOnlyList&lt;RenderFragment&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The per-message render fragments to virtualize. Only used when <code class="text-xs">Virtualize</code> is true.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ItemSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">float</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">80</td>
                            <td class="p-3 text-muted-foreground">Estimated row height in pixels for the virtualizer.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OverscanCount</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">4</td>
                            <td class="p-3 text-muted-foreground">Extra rows to render above/below the viewport to smooth scrolling.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsEmpty</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Renders the <code class="text-xs">EmptyState</code> slot (or a localized default) instead of the messages.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">EmptyState</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Custom placeholder shown when <code class="text-xs">IsEmpty</code> is true.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ToMarkdown(…)</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">static string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Serializes <code class="text-xs">AgentMessageMarkdown</code> turns to a Markdown transcript (pair with <code class="text-xs">DownloadFile</code>).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes on the root scroll container.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">AgentMessage</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Role</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">AgentMessageRole</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Assistant</td>
                            <td class="p-3 text-muted-foreground">One of <code class="text-xs">User</code>, <code class="text-xs">Assistant</code>, <code class="text-xs">System</code>, <code class="text-xs">Tool</code>.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Name</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Display name shown above the message bubble.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Timestamp</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateTimeOffset?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Optional timestamp displayed next to the name.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">TimeZone</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">TimeZoneInfo?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Time zone to render <code class="text-xs">Timestamp</code> in — pass the end user's zone (Blazor Server runs on the server, so <code class="text-xs">ToLocalTime()</code> would show the server's zone). When null, the timestamp renders in the offset it already carries.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">TimestampFormat</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"HH:mm"</td>
                            <td class="p-3 text-muted-foreground">Custom format string for the visible timestamp.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">TimestampCulture</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">CultureInfo?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Culture used to format the timestamp. Defaults to <code class="text-xs">CultureInfo.CurrentCulture</code>.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsStreaming</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Appends a pulsing caret to the body while the model is generating.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Avatar</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Optional avatar rendered alongside the bubble.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Actions</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Toolbar under the body — typically <code class="text-xs">&lt;AgentMessageActions&gt;</code> (copy/regenerate/retry) and/or <code class="text-xs">&lt;AgentMessageBranchNav&gt;</code>.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ChildContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Message body — plain text, <code class="text-xs">&lt;StreamingText&gt;</code>, or any markup.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">AgentMessageActions</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CopyText</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Text copied to the clipboard by the built-in Copy action. When null, no Copy button is rendered.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnCopy</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Invoked after a successful copy (receives the copied text).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnRegenerate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">When set, renders a Regenerate action invoking this callback.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnRetry</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">When set, renders a Retry action invoking this callback.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">AgentMessageAction</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Label</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Accessible name for the button — used for <code class="text-xs">aria-label</code>, the visually-hidden label, and the tooltip fallback. Required for a11y.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Icon</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">IconSource?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Icon to render (e.g. <code class="text-xs">LumeoIcons.Copy</code>). Ignored when <code class="text-xs">ChildContent</code> is supplied.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Tooltip</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Native title tooltip; defaults to <code class="text-xs">Label</code> when unset.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnClick</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fires when the button is clicked.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Disables the button.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">AgentMessageBranchNav</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Index</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
