@page "/settings"
@inject ToastService Toast

<PageTitle>Settings — MyApp</PageTitle>

<Stack Gap="6">
    <Stack Gap="1">
        <Heading Level="1" Size="2xl">Settings</Heading>
        <Lumeo.Text Color="muted">Manage your workspace preferences.</Lumeo.Text>
    </Stack>

    <Tabs @bind-ActiveValue="_tab">
        <TabsList>
            <TabsTrigger Value="general">General</TabsTrigger>
            <TabsTrigger Value="notifications">Notifications</TabsTrigger>
        </TabsList>

        <TabsContent Value="general" Class="pt-4">
            <Card>
                <CardHeader>
                    <CardTitle>General</CardTitle>
                    <CardDescription>Update how you appear across the workspace.</CardDescription>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <FormField Label="Display name">
                            <Input @bind-Value="_displayName" />
                        </FormField>
                        <FormField Label="Email">
                            <Input @bind-Value="_email" type="email" />
                        </FormField>
                        <FormField Label="Timezone">
                            <Select @bind-Value="_timezone">
                                <SelectTrigger>
                                    <Lumeo.Text As="span" Class="@(_timezone is null ? "text-muted-foreground" : "")">
                                        @(_timezone ?? "Select a timezone")
                                    </Lumeo.Text>
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectItem Value="utc">UTC</SelectItem>
                                    <SelectItem Value="est">Eastern (EST)</SelectItem>
                                    <SelectItem Value="cet">Central European (CET)</SelectItem>
                                    <SelectItem Value="pst">Pacific (PST)</SelectItem>
                                </SelectContent>
                            </Select>
                        </FormField>
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Flex Justify="end" Class="w-full">
                        <Button OnClick="Save">Save changes</Button>
                    </Flex>
                </CardFooter>
            </Card>
        </TabsContent>

        <TabsContent Value="notifications" Class="pt-4">
            <Card>
                <CardHeader>
                    <CardTitle>Notifications</CardTitle>
                    <CardDescription>Choose what we email you about.</CardDescription>
                </CardHeader>
                <CardContent>
                    <Stack Gap="1" Class="divide-y divide-border/40">
                        @foreach (var pref in _prefs)
                        {
                            <Flex Align="center" Justify="between" Gap="4" Class="py-3">
                                <Stack Gap="0" Class="min-w-0">
                                    <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">@pref.Title</Lumeo.Text>
                                    <Lumeo.Text Size="sm" Color="muted">@pref.Description</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="pref.Enabled" />
                            </Flex>
                        }
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Flex Justify="end" Class="w-full">
                        <Button OnClick="Save">Save changes</Button>
                    </Flex>
                </CardFooter>
            </Card>
        </TabsContent>
    </Tabs>
</Stack>

@code {
    private sealed class NotifPref
    {
        public required string Title { get; init; }
        public required string Description { get; init; }
        public bool Enabled { get; set; }
    }

    private string _tab = "general";

    private string _displayName = "Jane Doe";
    private string _email = "jane@example.com";
    private string? _timezone = "utc";

    private readonly List<NotifPref> _prefs =
    [
        new() { Title = "Email notifications", Description = "Order updates and receipts.", Enabled = true },
        new() { Title = "Push notifications", Description = "Real-time alerts in your browser.", Enabled = false },
        new() { Title = "Weekly digest", Description = "A Monday summary of activity.", Enabled = true },
    ];

    private void Save() => Toast.Show(new ToastOptions
    {
        Title = "Settings saved",
        Variant = ToastVariant.Success,
    });
}
