@namespace Lumeo.Tests.Components.MegaMenu

@* Test host for #59 — exposes the active item's Disabled as a real parameter so
   flipping it on a re-render keeps the SAME MegaMenuItem instance (the cascade is
   provided internally by MegaMenu, so re-rendering this host never re-provides a
   cascading value through cut.Render). Validates that an open panel closes when
   its trigger is flipped Disabled while active. *@
<Lumeo.MegaMenu>
    <Lumeo.MegaMenuItem Label="Products" Disabled="ProductsDisabled">
        <Lumeo.MegaMenuPanel>
            <Lumeo.MegaMenuLink Title="Analytics" Href="#analytics" />
        </Lumeo.MegaMenuPanel>
    </Lumeo.MegaMenuItem>
</Lumeo.MegaMenu>

@code {
    [Parameter] public bool ProductsDisabled { get; set; }
}
