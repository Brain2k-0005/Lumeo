@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeBadgeDefault">
    <Badge>Badge</Badge>
</PatternCard>

<PatternCard Label="Secondary" Code="@_codeBadgeSecondary">
    <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
</PatternCard>

<PatternCard Label="Outline" Code="@_codeBadgeOutline">
    <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
</PatternCard>

<PatternCard Label="Destructive" Code="@_codeBadgeDestructive">
    <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
</PatternCard>

<PatternCard Label="Success" Code="@_codeBadgeSuccess">
    <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
</PatternCard>

<PatternCard Label="Warning" Code="@_codeBadgeWarning">
    <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
</PatternCard>
</Stack>

@code {
    private string _codeBadgeDefault = @"<Badge>Badge</Badge>";
    private string _codeBadgeSecondary = @"<Badge Variant=""Badge.BadgeVariant.Secondary"">Secondary</Badge>";

    private string _codeBadgeOutline = @"<Badge Variant=""Badge.BadgeVariant.Outline"">Outline</Badge>";
    private string _codeBadgeDestructive = @"<Badge Variant=""Badge.BadgeVariant.Destructive"">Destructive</Badge>";

    private string _codeBadgeSuccess = @"<Badge Variant=""Badge.BadgeVariant.Success"">Success</Badge>";
    private string _codeBadgeWarning = @"<Badge Variant=""Badge.BadgeVariant.Warning"">Warning</Badge>";
}
