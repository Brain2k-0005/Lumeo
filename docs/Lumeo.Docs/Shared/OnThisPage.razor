@namespace Lumeo.Docs.Shared
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (_headings.Count > 0)
{
    <aside class="hidden lg:block w-52 shrink-0">
        <div class="sticky py-4 pr-2 text-sm flex flex-col"
             style="top: 72px; max-height: calc(100vh - 72px - 16px); overflow-y: auto;">
            @* "On this page" (the page outline) gets the FULL right rail now — the Quick-facts
               moved to a horizontal strip at the top of the main content (ComponentFactsBar),
               so the outline isn't competing for vertical space. *@
            @if (_headings.Count > 0)
            {
                <div class="font-semibold text-foreground mb-3 text-xs uppercase tracking-wide shrink-0">On this page</div>
                <nav class="border-l border-border/40 overflow-y-auto lumeo-otp-scroll"
                     style="scrollbar-width: thin;">
                    @foreach (var h in _headings)
                    {
                        @* href must embed the current path. With <base href="/">, a bare
                           "#id" resolves against the base URL — i.e. right-click → "Copy
                           Link Address" shows "/#id" instead of "/components/datagrid#id".
                           Click-time scroll still goes through @onclick (preventDefault),
                           so the visible href is only used by the browser's copy-link
                           affordance and crawlers. *@
                        <a href="@($"{LocalPath}#{h.Id}")"
                           @onclick:preventDefault
                           @onclick="() => ScrollTo(h.Id)"
                           class="@LinkClass(h)"
                           style="@($"padding-left: {(h.Level == 3 ? 24 : 12)}px")">
                            @h.Text
                        </a>
                    }
                </nav>
            }
        </div>
    </aside>
}

@code {
    [Parameter] public string Container { get; set; } = "main";

    private readonly string _id = $"otp-{Guid.NewGuid():N}";
    private List<Heading> _headings = new();
    private string? _activeId;
    private IJSObjectReference? _module;
    private DotNetObjectReference<OnThisPage>? _selfRef;
    private string? _lastPath;
    private CancellationTokenSource? _scanCts;

    [Inject] NavigationManager Nav { get; set; } = default!;

    // Absolute-from-origin path of the current document — used to build the
    // TOC anchor hrefs explicitly so the browser's "Copy Link Address" gives
    // the deep link instead of the base-resolved "/#section" form (see #41).
    private string LocalPath
    {
        get
        {
            try
            {
                var uri = new Uri(Nav.Uri);
                var path = uri.AbsolutePath;
                if (string.IsNullOrEmpty(path)) path = "/";
                return path + uri.Query;
            }
            catch
            {
                return "/";
            }
        }
    }

    // The /components/{slug} the user is on, or null elsewhere — drives the
    // registry-fed Quick-facts rail. Only the flat components/{slug} form (not
    // deeper paths like components/charts/bar) maps 1:1 to a registry entry.
    private string? ComponentSlug
    {
        get
        {
            var p = LocalPath.Trim('/');
            var q = p.IndexOf('?');
            if (q >= 0) p = p[..q];
            const string prefix = "components/";
            if (!p.StartsWith(prefix, StringComparison.OrdinalIgnoreCase)) return null;
            var slug = p[prefix.Length..];
            return string.IsNullOrEmpty(slug) || slug.Contains('/') ? null : slug;
        }
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        _lastPath = Nav.Uri;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _scanCts?.Cancel();
            _scanCts?.Dispose();
            _scanCts = new CancellationTokenSource();
            var token = _scanCts.Token;
            try { await RescanWithRetry(token); }
            catch (OperationCanceledException) { /* superseded */ }
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_disposed) return;
        if (e.Location == _lastPath) return;
        _lastPath = e.Location;

        // Cancel any in-flight rescan from a previous route. The CTS can be
        // disposed concurrently when the component is unmounting — the
        // unsubscribe in DisposeAsync runs slightly after the cancel/dispose,
        // so a navigation that races with disposal would hit ObjectDisposed.
        try
        {
            _scanCts?.Cancel();
            _scanCts?.Dispose();
        }
        catch (ObjectDisposedException) { return; }

        if (_disposed) return;
        _scanCts = new CancellationTokenSource();
        var token = _scanCts.Token;

        _ = InvokeAsync(async () =>
        {
            try { await RescanWithRetry(token); }
            catch (OperationCanceledException) { /* superseded */ }
        });
    }

    private async Task RescanWithRetry(CancellationToken ct)
    {
        // Child page may not have rendered its headings yet when we first scan.
        // Try a few times with increasing delays.
        int[] delays = { 50, 150, 300, 600 };
        foreach (var d in delays)
        {
            await Task.Delay(d, ct);
            await Rescan();
            if (_headings.Count > 0) return;
        }
    }

    private async Task Rescan()
    {
        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./_content/Lumeo/js/components.js");
            _selfRef ??= DotNetObjectReference.Create(this);

            // Stop previous observer (new route / new content)
            try { await _module.InvokeVoidAsync("onThisPageUnobserve", _id); } catch { }

            var result = await _module.InvokeAsync<Heading[]>("onThisPageScan", Container);
            _headings = result.ToList();
            _activeId = _headings.FirstOrDefault()?.Id;

            if (_headings.Count > 0)
            {
                await _module.InvokeVoidAsync("onThisPageObserve", _id, Container, _selfRef);
            }

            await InvokeAsync(StateHasChanged);
        }
        catch (JSDisconnectedException) { }
        catch (Exception) { /* circuit lifecycle — ignore */ }
    }

    [JSInvokable]
    public Task SetActive(string? id)
    {
        if (_activeId != id)
        {
            _activeId = id;
            InvokeAsync(StateHasChanged);
        }
        return Task.CompletedTask;
    }

    private async Task ScrollTo(string id)
    {
        try
        {
            // docs.js is loaded as a regular global script — call via window.lumeo namespace
            await JS.InvokeVoidAsync("lumeo.navScrollActiveIntoView", id);
            _activeId = id;
            StateHasChanged();
        }
        catch (JSDisconnectedException) { }
    }

    private string LinkClass(Heading h)
    {
        var isActive = h.Id == _activeId;
        return string.Join(" ", new[]
        {
            "block -ml-px border-l-2 py-1 pr-2 no-underline transition-colors",
            isActive
                ? "border-primary text-foreground font-medium"
                : "border-transparent text-muted-foreground hover:text-foreground hover:border-border"
        });
    }

    private bool _disposed;

    public async ValueTask DisposeAsync()
    {
        // Unsubscribe FIRST so an in-flight LocationChanged doesn't race
        // against CTS disposal and throw ObjectDisposedException.
        Nav.LocationChanged -= OnLocationChanged;
        _disposed = true;
        try
        {
            _scanCts?.Cancel();
            _scanCts?.Dispose();
        }
        catch (ObjectDisposedException) { }
        if (_module is not null)
        {
            try { await _module.InvokeVoidAsync("onThisPageUnobserve", _id); } catch { }
            try { await _module.DisposeAsync(); } catch { }
        }
        _selfRef?.Dispose();
    }

    public record Heading(string Id, string Text, int Level);
}
