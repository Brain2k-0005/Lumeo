@page "/components/window"

<PageTitle>Window — Lumeo</PageTitle>

<PageHeader Title="Window" Description="A non-modal draggable and resizable floating panel — like a desktop application window." />

<InstallUsage Component="Window" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Display secondary content (logs, previews, tools) while the main page remains interactive.</li>
        <li>Create floating panels that users can reposition and resize to fit their workflow.</li>
        <li>Build desktop-like multi-window UIs in web applications.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Window" Code="@_basicCode">
        <div class="relative h-64 border border-border/40 rounded-lg overflow-hidden bg-muted/20">
            <Button @onclick="@(() => _win1Open = true)" Class="m-4">Open Window</Button>
            <Window Open="_win1Open"
                    OpenChanged="@((v) => _win1Open = v)"
                    Title="My Window"
                    Width="360px"
                    Height="200px"
                    InitialX="40"
                    InitialY="40">
                <p class="text-sm text-muted-foreground">This is a draggable, resizable floating window. Drag the title bar to move it.</p>
            </Window>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Window with Footer" Code="@_footerCode">
        <div class="relative h-72 border border-border/40 rounded-lg overflow-hidden bg-muted/20">
            <Button @onclick="@(() => _win2Open = true)" Class="m-4">Open Window</Button>
            <Window Open="_win2Open"
                    OpenChanged="@((v) => _win2Open = v)"
                    Title="Save Document"
                    Width="380px"
                    Height="220px"
                    InitialX="20"
                    InitialY="20">
                <ChildContent>
                    <p class="text-sm text-muted-foreground">You have unsaved changes. Would you like to save?</p>
                </ChildContent>
                <FooterContent>
                    <div class="flex gap-2 justify-end">
                        <Button Variant="Button.ButtonVariant.Outline" @onclick="@(() => _win2Open = false)">Discard</Button>
                        <Button @onclick="@(() => _win2Open = false)">Save</Button>
                    </div>
                </FooterContent>
            </Window>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Non-Resizable Window" Code="@_noResizeCode">
        <div class="relative h-64 border border-border/40 rounded-lg overflow-hidden bg-muted/20">
            <Button @onclick="@(() => _win3Open = true)" Class="m-4">Open Fixed Window</Button>
            <Window Open="_win3Open"
                    OpenChanged="@((v) => _win3Open = v)"
                    Title="Fixed Size Panel"
                    Width="300px"
                    Height="160px"
                    Resizable="false"
                    InitialX="20"
                    InitialY="20">
                <p class="text-sm text-muted-foreground">This window cannot be resized, but can still be dragged.</p>
            </Window>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Minimal Controls (close only, non-draggable)">
        <div class="relative h-64 border border-border/40 rounded-lg overflow-hidden bg-muted/20">
            <Button @onclick="@(() => _win4Open = true)" Class="m-4">Open Minimal Window</Button>
            <Window Open="_win4Open"
                    OpenChanged="@((v) => _win4Open = v)"
                    Title="Pinned Panel"
                    Width="300px"
                    Height="160px"
                    Draggable="false"
                    ShowMinimize="false"
                    ShowMaximize="false"
                    InitialX="20"
                    InitialY="20">
                <p class="text-sm text-muted-foreground">This window is pinned (not draggable) and only shows the close button.</p>
            </Window>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Custom Title Bar (TitleContent)">
        <div class="relative h-64 border border-border/40 rounded-lg overflow-hidden bg-muted/20">
            <Button @onclick="@(() => _win5Open = true)" Class="m-4">Open Window</Button>
            <Window Open="_win5Open"
                    OpenChanged="@((v) => _win5Open = v)"
                    Width="320px"
                    Height="160px"
                    InitialX="20"
                    InitialY="20">
                <TitleContent>
                    <Flex Gap="2" Align="center">
                        <DynamicIcon Name="Terminal" Class="h-4 w-4" />
                        <span class="text-sm font-medium">Console</span>
                    </Flex>
                </TitleContent>
                <ChildContent>
                    <p class="text-sm text-muted-foreground">A custom title bar via TitleContent.</p>
                </ChildContent>
            </Window>
        </div>
    </ComponentDemo>
</Stack>

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <strong>Mobile (rc.49).</strong> Title-bar buttons (close, minimize, maximize) are now 44×44 px on touch screens (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">h-11 w-11 sm:h-7 sm:w-7</code>) and the resize handle corner expands to a 44×44 px tap target, making the window fully usable on mobile.
</Alert>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Window</Heading>
            <PropsTable Slug="window" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/dialog" class="text-primary hover:underline">Dialog</a> — Modal dialog that blocks interaction with the rest of the page.</li>
        <li><a href="/components/sheet" class="text-primary hover:underline">Sheet</a> — Slide-in panel from an edge — less intrusive than a dialog.</li>
        <li><a href="/components/popover" class="text-primary hover:underline">Popover</a> — Anchored floating panel positioned relative to a trigger.</li>
    </ul>
</div>

@code {
    private bool _win1Open;
    private bool _win2Open;
    private bool _win3Open;
    private bool _win4Open;
    private bool _win5Open;

    private string _basicCode = @"<Window @bind-Open=""_open"" Title=""My Window"" Width=""360px"" Height=""200px"">
    <p class=""text-sm text-muted-foreground"">Drag the title bar to move. Drag the bottom-right corner to resize.</p>
</Window>

<Button @onclick=""@(() => _open = true)"">Open Window</Button>

@code { private bool _open; }";

    private string _footerCode = @"<Window @bind-Open=""_open"" Title=""Save Document"">
    <p class=""text-sm text-muted-foreground"">You have unsaved changes.</p>
    <FooterContent>
        <div class=""flex gap-2 justify-end"">
            <Button Variant=""Button.ButtonVariant.Outline"" @onclick=""@(() => _open = false)"">Discard</Button>
            <Button @onclick=""@(() => _open = false)"">Save</Button>
        </div>
    </FooterContent>
</Window>";

    private string _noResizeCode = @"<Window @bind-Open=""_open"" Title=""Fixed Panel"" Resizable=""false"">
    <p class=""text-sm text-muted-foreground"">This window has a fixed size.</p>
</Window>";
}
