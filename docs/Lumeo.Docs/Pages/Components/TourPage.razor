        new(""#tour-feature-3"", ""Settings"", ""Customize your workspace and account."", Tour.TourPlacement.Bottom),
    };

    private void HandleComplete() => _tourOpen = false;
}";

    private string _placementsCode = @"<Flex Class=""justify-between gap-3"">
