@page "/components/tour"

<PageTitle>Tour — Lumeo</PageTitle>

<PageHeader Title="Tour" Description="A guided tour component that highlights elements and shows step-by-step instructions." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Tour" Code="@_basicCode">
        <Stack Gap="4">
            <Flex Gap="4">
                <Button id="tour-target-1" Variant="Button.ButtonVariant.Outline">Step 1 Target</Button>
                <Button id="tour-target-2" Variant="Button.ButtonVariant.Outline">Step 2 Target</Button>
                <Button id="tour-target-3" Variant="Button.ButtonVariant.Outline">Step 3 Target</Button>
            </Flex>
            <Button OnClick="@(() => _tourOpen = true)">
                <DynamicIcon Name="Play" Class="h-4 w-4" />
                Start Tour
            </Button>
        </Stack>

        <Tour @bind-IsOpen="_tourOpen" Steps="@_tourSteps" OnComplete="@(() => _tourOpen = false)" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">Tour</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Steps</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;TourStepConfig&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Tour step definitions.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpen</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Whether the tour is active. Supports two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CurrentStep</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Current step index.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnComplete</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fired when the last step is finished.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnSkip</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fired when the tour is skipped.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private bool _tourOpen;

    private List<Tour.TourStepConfig> _tourSteps = new()
    {
        new("#tour-target-1", "Welcome", "This is the first step.", Tour.TourPlacement.Bottom),
        new("#tour-target-2", "Features", "Explore various features.", Tour.TourPlacement.Bottom),
        new("#tour-target-3", "Finish", "Tour complete!", Tour.TourPlacement.Bottom),
    };

    private string _basicCode = @"<Tour @bind-IsOpen=""_open"" Steps=""@_steps"" OnComplete=""@(() => _open = false)"" />

@code {
    private List<Tour.TourStepConfig> _steps = new()
    {
        new(""#target-1"", ""Welcome"", ""First step."", Tour.TourPlacement.Bottom),
        new(""#target-2"", ""Features"", ""Second step.""),
        new(""#target-3"", ""Done"", ""All done!""),
    };
}";
}
