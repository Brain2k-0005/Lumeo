@code {
    private bool _isOpen;
    private bool _isSimpleOpen;
    private bool _isConfirmOpen;
    private bool _preventCloseOpen;
    private bool _scrollableOpen;
    private bool _guardOpen;
    private bool _guardDirty;
    private string? _guardName;

    private Dictionary<DialogContent.DialogSize, bool> _sizeOpen = new();
    private void OnSizeOpenChanged(DialogContent.DialogSize size, bool open)
    {
        _sizeOpen[size] = open;
    }

    private Task GuardClose(Lumeo.DismissEventArgs e)
    {
        if (e.Reason is "escape" or "outside" && _guardDirty)
            e.Cancel = true;
        return Task.CompletedTask;
    }

    private string _onBeforeCloseCode = @"<Dialog @bind-Open=""_open"" OnBeforeClose=""GuardClose"">
    <DialogContent>
        <DialogHeader>
            <DialogTitle>Edit profile</DialogTitle>
        </DialogHeader>
        <Input @bind-Value=""_name"" @oninput=""() => _dirty = true"" />
        <DialogFooter>
            <Button OnClick=""Save"">Save</Button>
        </DialogFooter>
    </DialogContent>
</Dialog>

@code {
    bool _open;
    bool _dirty;
    string? _name;

    Task GuardClose(DismissEventArgs e)
    {
        // Block accidental dismissals while the form is dirty —
        // explicit Save / Cancel buttons still close normally.
        if (e.Reason is ""escape"" or ""outside"" && _dirty)
            e.Cancel = true;
        return Task.CompletedTask;
    }
}";

