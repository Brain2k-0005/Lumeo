@namespace Lumeo.Docs.Shared
@using Blazicons
@using Lumeo.Docs.Services
@inject IconService _iconService
@inject DynamicIconResolver _resolver
@implements IDisposable

@if (IsBlazionsPack)
{
    <Blazicon Svg="@GetPackIcon()" class="@Class" />
}
else
{
    <SvgGlyph Svg="@_resolver.Resolve(_iconService.ActiveLibrary, Name)" class="@Class" />
}

@code {
    [Parameter] public string Name { get; set; } = "Circle";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnInitialized()
    {
        _iconService.OnChange += OnIconLibraryChanged;
    }

    private void OnIconLibraryChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _iconService.OnChange -= OnIconLibraryChanged;
    }

    // Every first-party Lumeo.Icons pack class now resolves via the shared, data-driven
    // DynamicIconResolver (semantic name -> per-pack IconSource, rendered through <SvgGlyph>).
    // Only the three remaining Blazicons THIRD-PARTY INTEROP packs still render via <Blazicon>
    // (SvgIcon) — they have no first-party equivalent, so they keep their hand-written maps below.
    // Any unknown key (incl. the devicon/flag-icons novelty picks) falls through the resolver to
    // the eager Lucide pack, preserving the previous "unknown => Lucide" behaviour.
    private bool IsBlazionsPack => _iconService.ActiveLibrary is
        "font-awesome" or "ionicons" or "material-design";

    private SvgIcon GetPackIcon()
    {
        return _iconService.ActiveLibrary switch
        {
            "font-awesome" => GetFontAwesomeIcon(),
            "ionicons" => GetIonicon(),
            "material-design" => GetMdiIcon(),
            _ => GetFontAwesomeIcon(),
        };
    }

