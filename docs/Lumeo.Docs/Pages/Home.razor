    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _selfRef = DotNetObjectReference.Create(this);
                _visibilityHandle = await JS.InvokeAsync<IJSObjectReference>(
                    "lumeo.onPageVisibility", _selfRef, nameof(SetPageVisibility));
            }
            catch (JSException) { /* SSR / prerender */ }
            catch (JSDisconnectedException) { }
        }

        // The constellation lays out 154 nodes via JS and sits well below the
        // fold, so for real users we defer init until its section nears the
        // viewport — running it on first render just to (usually) never be seen
        // wastes main-thread time during the critical load.
        //
        // Exception: the prerender crawler doesn't scroll, so the
        // IntersectionObserver would never fire and the constellation would be
        // missing from the static HTML. There we init eagerly so it's baked in.
        if (firstRender && _constellationNodes.Count > 0)
        {
            try
            {
                if (await JS.InvokeAsync<bool>("lumeo.isPrerender"))
                {
                    await OnVisible();
                }
                else if (_selfRef is not null)
                {
                    _constellationObserver = await JS.InvokeAsync<IJSObjectReference?>(
                        "lumeo.observeVisibility", _constellationRoot, _selfRef, 300);
