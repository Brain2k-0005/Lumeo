@page "/components/sidebar"

<PageTitle>Sidebar — Lumeo</PageTitle>

<PageHeader Title="Sidebar" Description="A collapsible sidebar layout with groups, menus, header, and footer. Supports Push, Overlay, and Icon variants." />

<Stack Gap="8">
    <ComponentDemo Title="Push (Default)" Code="@_pushCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_pushCollapsed">
                <SidebarComponent>
                    <SidebarHeader>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Stack Class="h-6 w-6 rounded bg-primary"></Stack>
                            <Lumeo.Text As="span" Size="sm" Class="font-semibold text-foreground">Acme Inc</Lumeo.Text>
                        </Flex>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Platform</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Dashboard</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Users" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Team</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                    <SidebarFooter>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Avatar Src="" Fallback="CN" />
                            <Lumeo.Text As="span" Size="sm" Class="text-foreground">User</Lumeo.Text>
                        </Flex>
                    </SidebarFooter>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Sidebar pushes the main content. Fully hidden when collapsed.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Overlay" Code="@_overlayCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_overlayCollapsed" Variant="SidebarProvider.SidebarVariant.Overlay">
                <SidebarComponent>
                    <SidebarHeader>
                        <Flex Gap="2" Align="center" Class="px-2">
                            <Stack Class="h-6 w-6 rounded bg-primary"></Stack>
                            <Lumeo.Text As="span" Size="sm" Class="font-semibold text-foreground">Workspace</Lumeo.Text>
                        </Flex>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Navigation</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Home</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Search</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Notifications</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Sidebar slides over the main content. Click the backdrop to dismiss.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Icon" Code="@_iconCode">
        <Stack Class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_iconCollapsed" Variant="SidebarProvider.SidebarVariant.Icon">
                <SidebarComponent>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true" Tooltip="Home">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Home</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Search">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Search</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Notifications">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Notifications</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Settings">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><Lumeo.Text As="span">Settings</Lumeo.Text></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Compact icon-only sidebar. Toggle to expand with labels.</Lumeo.Text>
                </main>
            </SidebarProvider>
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="sidebarprovider" Level="3" Class="mt-8 scroll-mt-20">SidebarProvider</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">ChildContent</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The sidebar and main content.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsCollapsed</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Controls the sidebar collapsed state. Use with @@bind-IsCollapsed.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsCollapsedChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;bool&gt;</TableCell><TableCell Class="font-mono text-xs">-</TableCell><TableCell>Callback invoked when the collapsed state changes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Variant</TableCell><TableCell Class="font-mono text-xs">SidebarVariant</TableCell><TableCell Class="font-mono text-xs">Push</TableCell><TableCell>Sidebar display mode. Values: Push, Overlay, Icon.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

    <Heading Id="sidebarcomponent" Level="3" Class="mt-8 scroll-mt-20">SidebarComponent</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">ChildContent</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The sidebar content (header, content, footer).</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Side</TableCell><TableCell Class="font-mono text-xs">SidebarSide</TableCell><TableCell Class="font-mono text-xs">Left</TableCell><TableCell>Which side the sidebar appears on. Values: Left, Right.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

    <Heading Id="sidebarmenubutton" Level="3" Class="mt-8 scroll-mt-20">SidebarMenuButton</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">ChildContent</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Fallback content when Icon/Label are not used.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Icon</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Icon content displayed at the start of the button.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Label</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Label content hidden when sidebar is collapsed.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Href</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Navigation URL. Renders as an anchor when set.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Tooltip</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Tooltip text shown when the sidebar is collapsed.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsActive</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Highlights the button as the active/current item.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

    <Heading Id="sidebar-layout-components" Level="3" Class="mt-8 scroll-mt-20">SidebarHeader / SidebarContent / SidebarFooter / SidebarGroup / SidebarGroupLabel / SidebarMenu / SidebarMenuItem / SidebarSeparator / SidebarTrigger</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">ChildContent</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The component content. All layout sub-components accept ChildContent.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes. SidebarTrigger toggles collapsed state. SidebarGroupLabel hides text when collapsed. SidebarSeparator has no ChildContent.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

