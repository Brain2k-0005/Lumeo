@namespace Lumeo

<div class="@(Cx.Merge("inline-flex items-center justify-center", Class))" @attributes="AdditionalAttributes">
    <svg width="@Size" height="@Size" viewBox="0 0 @Size @Size" class="transform -rotate-90">
        <circle
            cx="@Center"
            cy="@Center"
            r="@Radius"
            fill="none"
            stroke="currentColor"
            stroke-width="@StrokeWidth"
            class="text-muted/20" />
        <circle
            cx="@Center"
            cy="@Center"
            r="@Radius"
            fill="none"
            stroke="currentColor"
            stroke-width="@StrokeWidth"
            stroke-dasharray="@Circumference"
            stroke-dashoffset="@DashOffset"
            stroke-linecap="round"
            class="text-primary transition-all duration-300" />
    </svg>
    @if (ChildContent is not null)
    {
        <div class="absolute flex items-center justify-center" style="width: @(Size)px; height: @(Size)px;">
            @ChildContent
        </div>
    }
    else if (ShowValue)
    {
        <div class="absolute flex items-center justify-center" style="width: @(Size)px; height: @(Size)px;">
            <span class="text-sm font-medium text-foreground">@DisplayValue</span>
        </div>
    }
</div>

@code {
    /// <summary>Current progress amount, clamped into <c>0..Max</c> for the rendered ring fill.</summary>
    [Parameter] public double Value { get; set; }
    /// <summary>The value that represents a complete (100%) ring. Default: 100.</summary>
    [Parameter] public double Max { get; set; } = 100;
    /// <summary>Diameter of the ring in px. Default: 64.</summary>
    [Parameter] public int Size { get; set; } = 64;
    /// <summary>Stroke width of the ring in px. Default: 4.</summary>
    [Parameter] public int StrokeWidth { get; set; } = 4;
    /// <summary>Renders the percentage (or <see cref="Format"/>ted value) centered inside the ring when
    /// <see cref="ChildContent"/> is not supplied. Default: true.</summary>
    [Parameter] public bool ShowValue { get; set; } = true;
    /// <summary>A composite format string applied to <see cref="Value"/> (e.g. <c>"{0:N1}"</c>) for the
    /// centered text. When null, the percentage (<c>N%</c>) is shown.</summary>
    [Parameter] public string? Format { get; set; }
    /// <summary>Custom content centered inside the ring, replacing the default value/percentage text.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the root wrapper.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Additional HTML attributes captured and forwarded to the root wrapper.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private double Center => Size / 2.0;
    private double Radius => (Size - StrokeWidth) / 2.0;
    private double Circumference => 2 * Math.PI * Radius;
    private double Percentage => Max > 0 ? Math.Clamp(Value / Max, 0, 1) : 0;
    private double DashOffset => Circumference * (1 - Percentage);

    private string DisplayValue => Format is not null
        ? string.Format(Format, Value)
        : $"{(int)(Percentage * 100)}%";
}
