@namespace Lumeo.Tests.Components.Scrollspy

@* Test host for lifecycle bug #100 — drives Scrollspy.Offset (and Smooth)
   through real parameters so a re-render exercises the runtime re-registration
   of the JS observer (which captures Offset/Smooth by value). *@
<Lumeo.Scrollspy Offset="@Offset" Smooth="@Smooth">
    <Lumeo.ScrollspyLink Target="intro">Intro</Lumeo.ScrollspyLink>
    <Lumeo.ScrollspySection Id="intro">Intro body</Lumeo.ScrollspySection>
</Lumeo.Scrollspy>

@code {
    [Parameter] public int Offset { get; set; }
    [Parameter] public bool Smooth { get; set; } = true;
}
