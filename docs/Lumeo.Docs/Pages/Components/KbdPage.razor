@page "/components/kbd"

<PageTitle>Kbd — Lumeo</PageTitle>

<PageHeader Title="Kbd" Description="Display keyboard shortcuts and register global hotkeys." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Align="center" Gap="4">
            <Flex Align="center" Gap="1">
                <Kbd>Ctrl</Kbd>
                <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                <Kbd>K</Kbd>
            </Flex>
            <Flex Align="center" Gap="1">
                <Kbd>Ctrl</Kbd>
                <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                <Kbd>Shift</Kbd>
                <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                <Kbd>P</Kbd>
            </Flex>
            <Kbd>Esc</Kbd>
            <Kbd>Enter</Kbd>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Code="@_sizesCode">
        <Flex Align="center" Gap="6">
            <Flex Align="center" Gap="1">
                <Lumeo.Text As="span" Size="sm" Color="muted" Class="mr-1">Small:</Lumeo.Text>
                <Kbd Size="Kbd.KbdSize.Sm">Ctrl</Kbd>
                <Lumeo.Text As="span" Size="xs" Color="muted">+</Lumeo.Text>
                <Kbd Size="Kbd.KbdSize.Sm">S</Kbd>
            </Flex>
            <Flex Align="center" Gap="1">
                <Lumeo.Text As="span" Size="sm" Color="muted" Class="mr-1">Default:</Lumeo.Text>
                <Kbd>Ctrl</Kbd>
                <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                <Kbd>S</Kbd>
            </Flex>
            <Flex Align="center" Gap="1">
                <Lumeo.Text As="span" Size="sm" Color="muted" Class="mr-1">Large:</Lumeo.Text>
                <Kbd Size="Kbd.KbdSize.Lg">Ctrl</Kbd>
                <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                <Kbd Size="Kbd.KbdSize.Lg">S</Kbd>
            </Flex>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="In Context" Code="@_contextCode">
        <Container MaxWidth="lg" Center="false" Padding="">
            <Stack Gap="4">
                <Flex Align="center" Justify="between" Class="rounded-md border px-3 py-2">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Open command palette</Lumeo.Text>
                    <Flex Align="center" Gap="1">
                        <Kbd>Ctrl</Kbd>
                        <Lumeo.Text As="span" Size="xs" Color="muted">+</Lumeo.Text>
                        <Kbd>K</Kbd>
                    </Flex>
                </Flex>
                <Flex Align="center" Justify="between" Class="rounded-md border px-3 py-2">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Search</Lumeo.Text>
                    <Flex Align="center" Gap="1">
                        <Kbd>Ctrl</Kbd>
                        <Lumeo.Text As="span" Size="xs" Color="muted">+</Lumeo.Text>
                        <Kbd>F</Kbd>
                    </Flex>
                </Flex>
                <Flex Align="center" Justify="between" Class="rounded-md border px-3 py-2">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Save</Lumeo.Text>
                    <Flex Align="center" Gap="1">
                        <Kbd>Ctrl</Kbd>
                        <Lumeo.Text As="span" Size="xs" Color="muted">+</Lumeo.Text>
                        <Kbd>S</Kbd>
                    </Flex>
                </Flex>
                <Flex Align="center" Justify="between" Class="rounded-md border px-3 py-2">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Close</Lumeo.Text>
                    <Kbd>Esc</Kbd>
                </Flex>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Keyboard Shortcut Service" Code="@_serviceCode">
        <Container MaxWidth="lg" Center="false" Padding="">
            <Stack Gap="4">
                <Alert>
                    <Flex Gap="3">
                        <DynamicIcon Name="Info" Class="h-4 w-4 mt-0.5" />
                        <Stack Gap="1">
                            <Heading Level="5" Class="leading-none tracking-tight">Try it!</Heading>
                            <Lumeo.Text Size="sm">Press <Kbd Size="Kbd.KbdSize.Sm">Ctrl</Kbd> + <Kbd Size="Kbd.KbdSize.Sm">K</Kbd> to trigger the shortcut counter.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </Alert>
                <Flex Align="center" Gap="4">
                    <Flex Align="center" Gap="1">
                        <Kbd>Ctrl</Kbd>
                        <Lumeo.Text As="span" Size="sm" Color="muted">+</Lumeo.Text>
                        <Kbd>K</Kbd>
                    </Flex>
                    <Lumeo.Text As="span" Size="sm" Color="muted">triggered @_count time(s)</Lumeo.Text>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="@(() => _count = 0)">Reset</Button>
                </Flex>
            </Stack>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Kbd</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Size</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">KbdSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Default</td>
                            <td class="p-3 text-muted-foreground">Size of the keyboard key. Values: Sm, Default, Lg.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">KeyboardShortcutService</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Method</th>
                            <th class="text-left p-3 font-medium text-foreground">Signature</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RegisterAsync</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RegisterAsync(keys, callback)</td>
                            <td class="p-3 text-muted-foreground">Registers a keyboard shortcut. Returns IDisposable to unregister.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@inject Lumeo.Services.KeyboardShortcutService Shortcuts
@implements IAsyncDisposable

@code {
    private int _count;
    private IDisposable? _shortcut;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _shortcut = await Shortcuts.RegisterAsync("ctrl+k", () =>
            {
                _count++;
                InvokeAsync(StateHasChanged);
                return Task.CompletedTask;
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        _shortcut?.Dispose();
    }

    private string _defaultCode = @"<Flex Align=""center"" Gap=""1"">
    <Kbd>Ctrl</Kbd>
    <Lumeo.Text As=""span"" Size=""sm"" Color=""muted"">+</Lumeo.Text>
    <Kbd>K</Kbd>
</Flex>";

    private string _sizesCode = @"<Kbd Size=""Kbd.KbdSize.Sm"">Ctrl</Kbd>
<Kbd>Ctrl</Kbd>
<Kbd Size=""Kbd.KbdSize.Lg"">Ctrl</Kbd>";

    private string _contextCode = @"<Flex Align=""center"" Justify=""between"" Class=""rounded-md border px-3 py-2"">
    <Lumeo.Text As=""span"" Size=""sm"" Color=""muted"">Open command palette</Lumeo.Text>
    <Flex Align=""center"" Gap=""1"">
        <Kbd>Ctrl</Kbd>
        <Lumeo.Text As=""span"" Size=""xs"" Color=""muted"">+</Lumeo.Text>
        <Kbd>K</Kbd>
    </Flex>
</Flex>";

    private string _serviceCode = @"@inject KeyboardShortcutService Shortcuts
@implements IAsyncDisposable

@code {
    private IDisposable? _shortcut;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _shortcut = await Shortcuts.RegisterAsync(""ctrl+k"", () =>
            {
                // Handle shortcut
                return Task.CompletedTask;
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        _shortcut?.Dispose();
    }
}";
}
