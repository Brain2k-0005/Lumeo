@namespace Lumeo

<ul class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</ul>

@code {
    /// <summary>The <see cref="NavigationMenuItem"/> elements that make up the top-level menu.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the root <c>ul</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the root <c>ul</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("group flex flex-1 list-none items-center justify-center space-x-1", Class);
}
