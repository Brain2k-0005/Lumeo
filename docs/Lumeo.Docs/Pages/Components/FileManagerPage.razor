@page "/components/file-manager"

<PageTitle>FileManager — Lumeo</PageTitle>

<PageHeader Title="FileManager" Description="A headless file and folder explorer with a folder tree, breadcrumb navigation, list and grid views, lazy loading, inline rename, and context-menu operations. The consumer provides the data and handles all filesystem operations." />

<InstallUsage Component="FileManager" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Cloud storage or asset manager UIs (S3 browser, media library, document vault)</li>
        <li>CMS file pickers where the tree of folders and files is fetched from an API</li>
        <li>Any app that needs to expose a hierarchical data store with rename / delete / new-folder operations</li>
        <li>Design tools or code editors with a sidebar file-explorer panel</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    @* ── Demo 1: Basic file manager ────────────────────────────────────────── *@
    <ComponentDemo Title="Basic File Manager" Description="A full-featured file explorer wired to an in-memory tree. Double-click a folder to navigate into it." Code="@_basicCode">
        <div style="height: 420px">
            <FileManager Root="@_tree"
                         @bind-CurrentPath="_currentPath"
                         @bind-SelectedNode="_selectedNode"
                         OnFileOpen="@(n => _openedFile = n.Name)" />
        </div>
        @if (_selectedNode is not null)
        {
            <Lumeo.Text Class="text-sm text-muted-foreground mt-2">
                Selected: @_selectedNode.Name (@(_selectedNode.IsFolder ? "folder" : FormatSizeStatic(_selectedNode.Size ?? 0)))
            </Lumeo.Text>
        }
        @if (_openedFile is not null)
        {
            <Lumeo.Text Class="text-sm text-muted-foreground mt-1">Opened: @_openedFile</Lumeo.Text>
        }
    </ComponentDemo>

    @* ── Demo 2: Grid view ─────────────────────────────────────────────────── *@
    <ComponentDemo Title="Grid View" Description="Switch to icon-grid tiles with ViewMode.Grid. The view-mode toggle in the toolbar is also available." Code="@_gridCode">
        <div style="height: 420px">
            <FileManager Root="@_tree"
                         ViewMode="FileManager.FileManagerViewMode.Grid"
                         @bind-CurrentPath="_currentPath2"
                         @bind-SelectedNode="_selectedNode2" />
        </div>
    </ComponentDemo>

    @* ── Demo 3: Rename / Delete wired up ─────────────────────────────────── *@
    <ComponentDemo Title="With Rename and Delete" Description="Right-click any item or use the toolbar to rename or delete. Changes are applied to the in-memory sample tree." Code="@_renameDeleteCode">
        <div style="height: 420px">
            <FileManager Root="@_editableTree"
                         @bind-CurrentPath="_currentPath3"
                         @bind-SelectedNode="_selectedNode3"
                         OnRename="@HandleRename"
                         OnDelete="@HandleDelete"
                         OnNewFolder="@HandleNewFolder" />
        </div>
        @if (_statusMessage is not null)
        {
            <Lumeo.Text Class="text-sm text-muted-foreground mt-2">@_statusMessage</Lumeo.Text>
        }
    </ComponentDemo>

</Stack>

