@namespace Lumeo
@implements IAsyncDisposable
@inject IComponentInteropService Interop
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@*
    AudioPlayer (3.1.0) — HTML5 <audio> wrapper with custom Lumeo chrome.
    Render owns its UI (cover slot, title/artist, play/pause, scrub bar, time,
    mute toggle, optional download). We never set the native `controls` attr —
    that would double up with our buttons. Playback state is driven entirely
    off the element's own events (@onplay / @onpause / @ontimeupdate /
    @onloadedmetadata / @onended) so the UI stays in sync even when an external
    actor (autoplay policy, picture-in-picture, media-session) toggles state.

    Scrubbing is intentionally pointer-driven rather than using <input type=range>:
    we need to *suppress* timeupdate-driven UI refresh while the user is dragging,
    otherwise the thumb jumps back to the current playback head on every event.
*@

<div class="@WrapperClass"
     id="@EffectiveWrapperId"
     role="region"
     aria-label="@L["AudioPlayer.Label"]"
     tabindex="0"
     @onkeydown="HandleKeyDown"
     @attributes="AdditionalAttributes">

    @* Cover art — slot wins, else fallback music icon tile *@
    <div class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-md bg-muted">
        @if (Cover is not null)
        {
            @Cover
        }
        else
        {
            <SvgGlyph Svg="@(LumeoIcons.Music)" class="h-6 w-6 text-muted-foreground" />
        }
    </div>

    @* Main column: title/artist + transport row *@
    <div class="flex min-w-0 flex-1 flex-col gap-1">
        @if (!string.IsNullOrEmpty(Title) || !string.IsNullOrEmpty(Artist))
        {
            <div class="flex min-w-0 flex-col leading-tight">
                @if (!string.IsNullOrEmpty(Title))
                {
                    <span class="truncate text-sm font-medium text-foreground">@Title</span>
                }
                @if (!string.IsNullOrEmpty(Artist))
                {
                    <span class="truncate text-xs text-muted-foreground">@Artist</span>
                }
            </div>
        }

        <div class="flex items-center gap-2">
            @if (ShowSkipButtons)
            {
                <Button Variant="Button.ButtonVariant.Ghost"
                        Size="Button.ButtonSize.Icon"
                        Class="h-8 w-8 shrink-0"
                        OnClick="() => Skip(-SkipSeconds)"
                        aria-label="@L["AudioPlayer.SkipBack", SkipSeconds]">
                    <SvgGlyph Svg="@(LumeoIcons.SkipBack)" class="h-4 w-4" />
                </Button>
            }

            <Button Variant="Button.ButtonVariant.Ghost"
                    Size="Button.ButtonSize.Icon"
                    Class="h-8 w-8 shrink-0"
                    OnClick="TogglePlay"
                    aria-label="@(_playing ? L["AudioPlayer.Pause"] : L["AudioPlayer.Play"])">
                @if (_playing)
                {
                    <SvgGlyph Svg="@(LumeoIcons.Pause)" class="h-4 w-4" />
                }
                else
                {
                    <SvgGlyph Svg="@(LumeoIcons.Play)" class="h-4 w-4" />
                }
            </Button>

            @if (ShowSkipButtons)
            {
                <Button Variant="Button.ButtonVariant.Ghost"
                        Size="Button.ButtonSize.Icon"
                        Class="h-8 w-8 shrink-0"
                        OnClick="() => Skip(SkipSeconds)"
                        aria-label="@L["AudioPlayer.SkipForward", SkipSeconds]">
                    <SvgGlyph Svg="@(LumeoIcons.SkipForward)" class="h-4 w-4" />
                </Button>
            }

            @* Progress bar — click-to-seek + drag-to-scrub.
               Pointer events drive a local _scrubValue so timeupdate doesn't
               yank the thumb back mid-drag. *@
            <div class="relative flex h-8 flex-1 items-center"
                 id="@_progressId"
                 role="slider"
                 aria-label="@L["AudioPlayer.Seek"]"
                 aria-valuemin="0"
                 aria-valuemax="@FormatAria(_duration)"
                 aria-valuenow="@FormatAria(DisplayTime)"
                 aria-valuetext="@Format(DisplayTime)"
                 @onpointerdown="OnScrubPointerDown"
                 @onpointermove="OnScrubPointerMove"
                 @onpointerup="OnScrubPointerUp"
                 @onpointercancel="OnScrubPointerUp">
                <div class="relative h-1.5 w-full overflow-hidden rounded-[calc(var(--radius)*2)] bg-primary/20">
                    @* Physical `left-0`, NOT logical `start-0`: the scrub seek math is physical
                       (e.OffsetX / width, left-to-right), so the fill must grow from the same physical
                       edge or RTL users get a fill + pointer-seek that are mirrored against each other
                       (dragging the visually-empty side seeks the opposite time) — Codex P2. *@
                    <div class="absolute inset-y-0 left-0 rounded-[calc(var(--radius)*2)] bg-primary"
                         style="width: @ProgressPercentCss%;"></div>
                </div>
            </div>

            <span class="shrink-0 tabular-nums text-xs text-muted-foreground">
                @Format(DisplayTime) / @Format(_duration)
            </span>

            @if (ShowPlaybackRate)
            {
                <Button Variant="Button.ButtonVariant.Ghost"
                        Size="Button.ButtonSize.Sm"
                        Class="h-8 shrink-0 px-2 tabular-nums text-xs"
                        OnClick="CyclePlaybackRate"
                        aria-label="@L["AudioPlayer.PlaybackRate", RateLabel]">
                    @RateLabel&times;
                </Button>
            }

            <Button Variant="Button.ButtonVariant.Ghost"
                    Size="Button.ButtonSize.Icon"
                    Class="h-8 w-8 shrink-0"
                    OnClick="ToggleMute"
                    aria-label="@(_muted ? L["AudioPlayer.Unmute"] : L["AudioPlayer.Mute"])">
                @if (_muted || _volume <= 0)
                {
                    <SvgGlyph Svg="@(LumeoIcons.VolumeX)" class="h-4 w-4" />
                }
                else
                {
                    <SvgGlyph Svg="@(LumeoIcons.Volume2)" class="h-4 w-4" />
                }
            </Button>

            @if (ShowVolume)
            {
                <input type="range" min="0" max="1" step="0.01"
                       value="@_volume.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture)"
                       @oninput="OnVolumeInput"
                       class="h-1.5 w-16 shrink-0 cursor-pointer accent-primary"
                       aria-label="@L["AudioPlayer.Volume"]"
                       aria-valuetext="@VolumePercentText" />
            }
        </div>
    </div>

    @if (ShowDownload && !string.IsNullOrEmpty(Src))
    {
        <a href="@Src"
           download
           class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2"
           aria-label="@L["AudioPlayer.Download"]">
            <SvgGlyph Svg="@(LumeoIcons.Download)" class="h-4 w-4" />
        </a>
    }

    @* The actual media element. No `controls` attribute — we render our own.
       Bound events keep the C# state in sync with whatever the browser does. *@
    <audio @ref="_audioRef"
           src="@Src"
           preload="@PreloadMode"
           autoplay="@Autoplay"
           loop="@Loop"
           class="sr-only"
           @onloadedmetadata="OnLoadedMetadata"
           @ontimeupdate="OnTimeUpdateInternal"
           @onplay="OnPlayInternal"
           @onpause="OnPauseInternal"
           @onended="OnEndedInternal" />
</div>

@code {
    /// <summary>URL of the audio file to play. Bound directly to the underlying
    /// <c>&lt;audio&gt;</c> element's <c>src</c>; required.</summary>
    [Parameter, EditorRequired] public string? Src { get; set; }

    /// <summary>Starts playback automatically once the media can play. Subject to
    /// browser autoplay policy — the UI reflects actual play/pause state from the
    /// element's own events, not this flag.</summary>
    [Parameter] public bool Autoplay { get; set; }

    /// <summary>Restarts playback from the beginning when the track ends.</summary>
    [Parameter] public bool Loop { get; set; }

    /// <summary>Shows a download link (rendered as an anchor with <c>download</c>)
    /// pointing at <see cref="Src"/>. Hidden when <see cref="Src"/> is empty.</summary>
    [Parameter] public bool ShowDownload { get; set; }

    /// <summary>Track title shown above the transport controls. Omitted from the
    /// layout entirely when both <see cref="Title"/> and <see cref="Artist"/> are empty.</summary>
    [Parameter] public string? Title { get; set; }

    /// <summary>Artist name shown beneath <see cref="Title"/> in a smaller, muted style.</summary>
    [Parameter] public string? Artist { get; set; }

    /// <summary>Custom cover art content rendered in the leading artwork tile. Falls
    /// back to a music-note icon when not provided.</summary>
    [Parameter] public RenderFragment? Cover { get; set; }

    /// <summary>Value forwarded to the native <c>&lt;audio&gt;</c> element's <c>preload</c>
    /// attribute (<c>"none"</c>, <c>"metadata"</c>, or <c>"auto"</c>). Defaults to <c>"metadata"</c>.</summary>
    [Parameter] public string? PreloadMode { get; set; } = "metadata";

    /// <summary>Show skip-back / skip-forward buttons (±<see cref="SkipSeconds"/>).</summary>
    [Parameter] public bool ShowSkipButtons { get; set; } = true;

    /// <summary>Seconds to jump per skip-button press / arrow key. Defaults to 10.</summary>
    [Parameter] public int SkipSeconds { get; set; } = 10;

    /// <summary>Show the playback-rate cycle button (0.5× → 2×).</summary>
    [Parameter] public bool ShowPlaybackRate { get; set; } = true;

    /// <summary>Selectable playback rates, cycled by the rate button. Defaults
    /// to 0.5×, 1×, 1.25×, 1.5×, 2×.</summary>
    [Parameter] public double[] PlaybackRates { get; set; } = { 0.5, 1.0, 1.25, 1.5, 2.0 };

    /// <summary>Show the volume slider next to the mute toggle.</summary>
    [Parameter] public bool ShowVolume { get; set; } = true;

    /// <summary>Fires on every playback-position update (native <c>timeupdate</c>,
    /// plus skip/seek actions) with the new current time in seconds.</summary>
    [Parameter] public EventCallback<double> OnTimeUpdate { get; set; }

    /// <summary>Fires when playback reaches the end of the track.</summary>
    [Parameter] public EventCallback OnEnded { get; set; }

    /// <summary>Fires when playback starts, driven by the element's own <c>play</c>
    /// event (not the button click) so it reflects actual playback state.</summary>
    [Parameter] public EventCallback OnPlay { get; set; }

    /// <summary>Fires when playback pauses, driven by the element's own <c>pause</c>
    /// event (not the button click) so it reflects actual playback state.</summary>
    [Parameter] public EventCallback OnPause { get; set; }

    /// <summary>Additional CSS classes merged onto the outer wrapper.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures unmatched attributes and applies them to the outer wrapper.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private ElementReference _audioRef;
    private readonly string _wrapperId = LumeoIds.New("audio-player");
    private readonly string _progressId = LumeoIds.New("audio-progress");
    // A consumer-supplied `id` overrides the generated one in the DOM, so the
    // keydown-suppression JS registration must target the rendered id.
    private string EffectiveWrapperId => LumeoIds.Effective(AdditionalAttributes, _wrapperId);
    private bool _preventKeysRegistered;

    private bool _playing;
    private bool _muted;
    private double _duration;
    private double _currentTime;
    private double _volume = 1.0;
    private double _playbackRate = 1.0;

    // Track the last Src we reconciled against. A playlist that swaps the
    // source (next-track) reuses the SAME component instance, so the element's
    // transient state — duration/currentTime/playing — must be reset and the
    // user's persisted volume/mute/rate re-applied to the freshly-loaded media.
    // Seeded lazily on first OnParametersSet; never stored in the [Parameter].
    private string? _lastSrc;
    private bool _srcInitialized;
    // When a real Src change happens we can't push volume/rate to the new
    // element until its metadata has loaded; defer the re-apply to OnLoadedMetadata.
    private bool _reapplyMediaSettings;

    // Scrub state — when the user is dragging the progress bar we suppress
    // timeupdate-driven UI refresh and show their finger position instead.
    // Commit happens on pointerup so we issue exactly one seek per drag.
    private bool _scrubbing;
    private double _scrubValue;
    private double _scrubBarWidth;
    private long? _capturedPointerId;

    private double DisplayTime => _scrubbing ? _scrubValue : _currentTime;

    private string WrapperClass => Cx.Merge(
        "flex items-center gap-3 rounded-xl border border-border/40 bg-card p-3",
        "focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2",
        Class);

    // Percent string for the inline width style. Uses InvariantCulture so the
    // decimal separator stays "." in locales like de-DE where it'd otherwise
    // become "," and silently invalidate the CSS declaration.
    private string ProgressPercentCss
    {
        get
        {
            var pct = _duration > 0 ? Math.Clamp(DisplayTime / _duration, 0, 1) * 100.0 : 0;
            return pct.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);
        }
    }

    // Compact rate label, e.g. "1", "1.25", "0.5" (no trailing zeros). The
    // "×" glyph is appended in the markup. Invariant so "1.25" never becomes
    // "1,25" in de-DE.
    private string RateLabel =>
        _playbackRate.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture);

    private string VolumePercentText =>
        $"{Math.Round((_muted ? 0 : _volume) * 100).ToString(System.Globalization.CultureInfo.InvariantCulture)}%";

    private static string FormatAria(double seconds) =>
        Math.Round(seconds).ToString(System.Globalization.CultureInfo.InvariantCulture);

    // A playlist swapping the source reuses the SAME component instance, so the
    // element's transient state — duration / currentTime / playing — would
    // otherwise stay pinned to the previous track while the new media loads.
    // Detect a real Src change against a cached backing field (NOT the
    // [Parameter] itself), reset the transient progress/play state, and flag a
    // re-apply so the user's persisted volume/mute/rate are pushed back to the
    // freshly-loaded element once its metadata arrives. Same-content re-renders
    // (an unrelated parent StateHasChanged) compare equal and are a no-op, so
    // they never clobber in-progress playback.
    protected override void OnParametersSet()
    {
        if (!_srcInitialized)
        {
            // First parameter set: adopt the initial Src as the baseline without
            // resetting (there is no prior playback to preserve or discard).
            _lastSrc = Src;
            _srcInitialized = true;
            return;
        }

        if (!string.Equals(Src, _lastSrc, StringComparison.Ordinal))
        {
            _lastSrc = Src;
            // The old track's progress/play state no longer describes the new
            // media. Reset so the UI reads "0:00 / 0:00", paused, until the new
            // element fires its own events.
            _playing = false;
            _currentTime = 0;
            _duration = 0;
            // Defensive: a Src swap mid-drag would otherwise leave a dangling
            // scrub/capture state pinned to the old media.
            _scrubbing = false;
            _capturedPointerId = null;
            // Volume / mute / rate are user choices that must survive a track
            // swap — re-apply them to the new element once it has loaded.
            _reapplyMediaSettings = true;
        }
    }

    // M:SS, e.g. 0:42, 3:14, 12:05. Negative / NaN -> "0:00" defensively.
    private static string Format(double seconds)
    {
        if (double.IsNaN(seconds) || double.IsInfinity(seconds) || seconds < 0) return "0:00";
        var total = (int)Math.Floor(seconds);
        var m = total / 60;
        var s = total % 60;
        return $"{m}:{s:00}";
    }

    private async Task TogglePlay()
    {
        if (_playing) await Interop.PauseMedia(_audioRef);
        else await Interop.PlayMedia(_audioRef);
        // Don't flip _playing here — wait for the <audio> element to fire
        // play/pause events. Autoplay policy or a missing src can reject the
        // play() promise, and we want our UI to reflect reality, not intent.
    }

    private async Task ToggleMute()
    {
        _muted = !_muted;
        await Interop.SetMediaVolume(_audioRef, _volume, _muted);
    }

    // --- Volume / rate / skip ---

    private async Task OnVolumeInput(ChangeEventArgs e)
    {
        if (e.Value is string s &&
            double.TryParse(s, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var v))
        {
            _volume = Math.Clamp(v, 0, 1);
            // Dragging the slider up from zero implicitly unmutes; dragging to
            // zero reads as muted. Keeps the icon honest.
            _muted = _volume <= 0;
            await Interop.SetMediaVolume(_audioRef, _volume, _muted);
        }
    }

    private async Task CyclePlaybackRate()
    {
        if (PlaybackRates is null || PlaybackRates.Length == 0) return;
        // Find the current rate's slot and advance to the next, wrapping round.
        var idx = Array.FindIndex(PlaybackRates, r => Math.Abs(r - _playbackRate) < 0.001);
        var next = PlaybackRates[(idx + 1) % PlaybackRates.Length];
        _playbackRate = next;
        await Interop.SetPlaybackRate(_audioRef, next);
    }

    private async Task Skip(double seconds)
    {
        var target = Math.Clamp(_currentTime + seconds, 0, _duration > 0 ? _duration : double.MaxValue);
        _currentTime = target;
        await Interop.SeekMedia(_audioRef, target);
        await OnTimeUpdate.InvokeAsync(target);
    }

    private async Task OnLoadedMetadata(EventArgs e)
    {
        // Blazor's EventArgs doesn't carry the element's `duration`; fetch
        // it via a one-shot JS read. After this the scrub bar and time
        // readout switch from "0:00 / 0:00" placeholder to real values.
        var state = await Interop.GetMediaState(_audioRef);
        _duration = state.Duration;
        _currentTime = state.CurrentTime;

        // After a Src swap the freshly-loaded element starts at the browser's
        // defaults (volume 1, unmuted, rate 1). Re-apply the user's persisted
        // choices so a track change doesn't silently reset them.
        if (_reapplyMediaSettings)
        {
            _reapplyMediaSettings = false;
            await Interop.SetMediaVolume(_audioRef, _volume, _muted);
            await Interop.SetPlaybackRate(_audioRef, _playbackRate);
        }
    }

    private async Task OnTimeUpdateInternal(EventArgs e)
    {
        // Skip the JS read while the user is dragging — we don't want the
        // element's still-old currentTime to overwrite the scrub preview.
        if (_scrubbing) return;
        var state = await Interop.GetMediaState(_audioRef);
        // Some sources expose duration only after some playback; refresh
        // it opportunistically so the UI doesn't get stuck at 0.
        if (state.Duration > 0) _duration = state.Duration;
        _currentTime = state.CurrentTime;
        await OnTimeUpdate.InvokeAsync(_currentTime);
    }

    private async Task OnPlayInternal(EventArgs e)
    {
        _playing = true;
        await OnPlay.InvokeAsync();
    }

    private async Task OnPauseInternal(EventArgs e)
    {
        _playing = false;
        await OnPause.InvokeAsync();
    }

    private async Task OnEndedInternal(EventArgs e)
    {
        _playing = false;
        _currentTime = _duration;
        await OnEnded.InvokeAsync();
    }

    // --- Scrubbing ---
    //
    // We compute the seek target from the pointer's offsetX inside the bar.
    // PointerEventArgs gives us OffsetX/OffsetY relative to the target — for
    // the inner pill that's exactly the bar's local coordinate space. We
    // capture the pointer so dragging outside the bar still tracks.

    private async Task OnScrubPointerDown(PointerEventArgs e)
    {
        if (_duration <= 0)
        {
            // Last-resort: probe duration once on first interaction in case
            // metadata loaded silently before we wired the event. Without
            // this an early click on the bar before timeupdate fires would
            // do nothing.
            var state = await Interop.GetMediaState(_audioRef);
            if (state.Duration > 0) _duration = state.Duration;
            if (_duration <= 0) return; // still no duration — bail
        }
        // Capture the bar's current width once per drag so subsequent
        // pointermove events can map offsetX -> percent without a JS
        // roundtrip per move. ResizeObserver would be overkill for a
        // single drag interaction.
        var rect = await Interop.GetElementRect(_progressId);
        _scrubBarWidth = rect?.Width > 0 ? rect.Width : 1;
        _scrubbing = true;
        _capturedPointerId = e.PointerId;
        try { await Interop.SetPointerCaptureOnElement(_progressId, e.PointerId); } catch (JSDisconnectedException) { }
        UpdateScrubFromPointer(e);
    }

    private void OnScrubPointerMove(PointerEventArgs e)
    {
        if (!_scrubbing) return;
        UpdateScrubFromPointer(e);
    }

    private async Task OnScrubPointerUp(PointerEventArgs e)
    {
        if (!_scrubbing) return;
        UpdateScrubFromPointer(e);
        var target = _scrubValue;
        _scrubbing = false;
        if (_capturedPointerId is long pid)
        {
            try { await Interop.ReleasePointerCaptureOnElement(_progressId, pid); } catch (JSDisconnectedException) { }
            _capturedPointerId = null;
        }
        _currentTime = target;
        await Interop.SeekMedia(_audioRef, target);
        await OnTimeUpdate.InvokeAsync(target);
    }

    private void UpdateScrubFromPointer(PointerEventArgs e)
    {
        // _scrubBarWidth is snapshotted on pointerdown — using it here avoids
        // a per-move JS roundtrip. OffsetX can go negative or exceed width
        // when pointer capture drags outside the element; clamp into [0, 1].
        if (_scrubBarWidth <= 0) return;
        var pct = Math.Clamp(e.OffsetX / _scrubBarWidth, 0, 1);
        _scrubValue = pct * _duration;
    }

    // --- Keyboard accessibility ---
    //
    // Space and "k" toggle play/pause when the wrapper has focus — matching
    // the de-facto YouTube/SoundCloud convention. Arrow keys nudge ±SkipSeconds.
    // The default-action of these keys is suppressed via RegisterPreventDefaultKeys
    // (see OnAfterRenderAsync) so Space doesn't scroll the page out from under
    // the focused player (#302) — but only when the player itself has focus.

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case " ":
            case "k":
            case "K":
                await TogglePlay();
                break;
            case "ArrowRight":
                await Skip(SkipSeconds);
                break;
            case "ArrowLeft":
                await Skip(-SkipSeconds);
                break;
            case "m":
            case "M":
                await ToggleMute();
                break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _preventKeysRegistered) return;
        try
        {
            // Suppress the browser default ONLY for keys we handle, and never
            // when focus is inside editable content (none here today, but the
            // SkipEditable guard keeps it future-proof and consistent with the
            // Carousel registration). Space is the important one — its default
            // is page scroll.
            await Interop.RegisterPreventDefaultKeys(EffectiveWrapperId, new[]
            {
                new PreventDefaultKeyRule(" ", SkipEditable: true),
                new PreventDefaultKeyRule("ArrowLeft", SkipEditable: true),
                new PreventDefaultKeyRule("ArrowRight", SkipEditable: true),
            });
            _preventKeysRegistered = true;
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { } // JS interop unavailable during prerender
    }

    public async ValueTask DisposeAsync()
    {
        // Pause on dispose so the element doesn't keep playing if the consumer
        // unmounts the component (e.g. SPA navigation). JSDisconnectedException
        // can fire if the circuit is already torn down.
        try
        {
            if (_preventKeysRegistered)
                await Interop.UnregisterPreventDefaultKeys(EffectiveWrapperId);
            await Interop.PauseMedia(_audioRef);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (InvalidOperationException) { }
    }
}
