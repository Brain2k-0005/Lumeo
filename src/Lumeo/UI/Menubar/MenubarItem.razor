@namespace Lumeo

<button class="@CssClass" role="menuitem" tabindex="-1" data-inset="@(Inset ? "true" : null)" data-variant="@VariantAttr" @onclick="HandleClick" disabled="@Disabled" @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] public Menubar.MenubarContext Context { get; set; } = default!;
    /// <summary>The item's label content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Raised when the item is clicked. The menu closes immediately afterward.</summary>
    [Parameter] public EventCallback OnClick { get; set; }
    /// <summary>Disables the item, preventing clicks and dimming its appearance.</summary>
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Indents the item by a label's width so it lines up with checkbox/radio
    /// items (shadcn <c>inset</c>). Adds <c>ps-8</c> and emits <c>data-inset</c>.
    /// </summary>
    [Parameter] public bool Inset { get; set; }

    /// <summary>
    /// Visual variant. <see cref="MenuItemVariant.Destructive"/> renders the item
    /// in the destructive color and emits <c>data-variant="destructive"</c>.
    /// </summary>
    [Parameter] public MenuItemVariant Variant { get; set; } = MenuItemVariant.Default;

    /// <summary>Additional CSS classes merged onto the item's <c>&lt;button&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the item's <c>&lt;button&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string? VariantAttr => Variant == MenuItemVariant.Destructive ? "destructive" : null;

    private const string DestructiveClass = "text-destructive hover:bg-destructive/10 hover:text-destructive focus:bg-destructive/10 focus:text-destructive";

    private string CssClass => Cx.Merge("relative flex w-full cursor-pointer select-none items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed", Cx.When(Inset, "ps-8"), Cx.When(Variant == MenuItemVariant.Destructive, DestructiveClass), Class);

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
        await Context.SetOpenMenuId.InvokeAsync(null);
    }
}
