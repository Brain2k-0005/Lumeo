@page "/components/file-upload"

<PageTitle>File Upload — Lumeo</PageTitle>

<PageHeader Title="File Upload" Description="A drag-and-drop file upload area with customizable labels and file type restrictions." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload OnFilesSelected="HandleFiles" />
            @if (_fileName is not null)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_fileName</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Image Upload" Code="@_imageCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload Label="Upload an image" Description="PNG, JPG or GIF up to 10MB" Accept="image/*" OnFilesSelected="HandleImageFiles" />
            @if (_imageName is not null)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_imageName</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Files" Code="@_multipleCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload Label="Upload documents" Description="Select one or more files" Multiple="true" OnFilesSelected="HandleMultipleFiles" />
            @if (_fileCount > 0)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">@_fileCount file(s) selected</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Progress" Code="@_progressCode">
        <Stack Gap="4" Class="w-full max-w-md">
            <FileUpload ShowProgress="true" Progress="@_uploadProgress" OnFilesSelected="@HandleFileUpload" Accept="image/*" Multiple="true"
                        Label="Upload Images" Description="PNG, JPG up to 10MB" />
            @if (_isUploading)
            {
                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" disabled>Uploading...</Button>
            }
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">FileUpload</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnFilesSelected</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;InputFileChangeEventArgs&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the user selects or drops files.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Accept</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">File types accepted by the input (e.g. "image/*", ".pdf,.docx").</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Multiple</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, allows selecting multiple files at once.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Label</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Click to upload"</td>
                            <td class="p-3 text-muted-foreground">Primary label text shown in the drop zone.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Description</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Secondary description text shown below the label.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowProgress</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, displays a progress bar inside the drop zone.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Progress</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Upload progress percentage (0–100), used when ShowProgress is true.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private string? _fileName;
    private string? _imageName;
    private int _fileCount;
    private int _uploadProgress;
    private bool _isUploading;

    private void HandleFiles(InputFileChangeEventArgs e)
    {
        _fileName = e.File.Name;
    }

    private void HandleImageFiles(InputFileChangeEventArgs e)
    {
        _imageName = e.File.Name;
    }

    private void HandleMultipleFiles(InputFileChangeEventArgs e)
    {
        _fileCount = e.FileCount;
    }

    private async void HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _uploadProgress = 0;
        for (int i = 0; i <= 100; i += 20)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(300);
        }
        _isUploading = false;
        StateHasChanged();
    }

    private string _defaultCode = @"<FileUpload OnFilesSelected=""HandleFiles"" />";

    private string _imageCode = @"<FileUpload
    Label=""Upload an image""
    Description=""PNG, JPG or GIF up to 10MB""
    Accept=""image/*""
    OnFilesSelected=""HandleFiles"" />";

    private string _multipleCode = @"<FileUpload
    Label=""Upload documents""
    Description=""Select one or more files""
    Multiple=""true""
    OnFilesSelected=""HandleFiles"" />";

    private string _progressCode = @"<FileUpload
    ShowProgress=""true""
    Progress=""@_uploadProgress""
    OnFilesSelected=""@HandleFileUpload""
    Accept=""image/*""
    Multiple=""true""
    Label=""Upload Images""
    Description=""PNG, JPG up to 10MB"" />

@code {
    private int _uploadProgress;
    private bool _isUploading;

    private async void HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _uploadProgress = 0;
        for (int i = 0; i <= 100; i += 20)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(300);
        }
        _isUploading = false;
        StateHasChanged();
    }
}";
}
