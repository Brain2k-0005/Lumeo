@page "/components/container"

<PageTitle>Container — Lumeo</PageTitle>

<PageHeader Title="Container" Description="A responsive container that constrains content width and centers it on the page." />

<Stack Gap="8">
    <ComponentDemo Title="Centered Content" Code="@_basicCode">
        <div class="w-full">
            <Container MaxWidth="md" Class="border border-dashed border-border rounded-lg py-6">
                <Text Color="muted" Align="center">Content centered within max-w-md</Text>
            </Container>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Different Max Widths" Code="@_widthsCode">
        <Stack Gap="4" Class="w-full">
            <Container MaxWidth="sm" Class="border border-dashed border-border rounded-lg py-3">
                <Text Size="sm" Color="muted" Align="center">max-w-sm</Text>
            </Container>
            <Container MaxWidth="md" Class="border border-dashed border-border rounded-lg py-3">
                <Text Size="sm" Color="muted" Align="center">max-w-md</Text>
            </Container>
            <Container MaxWidth="lg" Class="border border-dashed border-border rounded-lg py-3">
                <Text Size="sm" Color="muted" Align="center">max-w-lg</Text>
            </Container>
            <Container MaxWidth="xl" Class="border border-dashed border-border rounded-lg py-3">
                <Text Size="sm" Color="muted" Align="center">max-w-xl</Text>
            </Container>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <Stack Gap="6" Class="mt-12">
        <Heading Level="2">API Reference</Heading>
        <Stack Gap="8">
            <div>
                <Heading Level="3" Class="mb-3">Container</Heading>
                <div class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Property</th>
                                <th class="text-left p-3 font-medium text-foreground">Type</th>
                                <th class="text-left p-3 font-medium text-foreground">Default</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">MaxWidth</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">"lg"</td>
                                <td class="p-3 text-muted-foreground">Maximum width. Maps to max-w-{value} (e.g. "sm", "md", "lg", "xl", "2xl").</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Center</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                                <td class="p-3 text-muted-foreground">Whether to horizontally center the container using mx-auto.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Padding</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">"4"</td>
                                <td class="p-3 text-muted-foreground">Horizontal padding applied via px-{value}.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _basicCode = @"<Container MaxWidth=""md"">
    <p>Content centered within max-w-md</p>
</Container>";

    private string _widthsCode = @"<Container MaxWidth=""sm"">Small container</Container>
<Container MaxWidth=""md"">Medium container</Container>
<Container MaxWidth=""lg"">Large container</Container>
<Container MaxWidth=""xl"">Extra large container</Container>";
}
