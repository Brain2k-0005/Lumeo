@page "/components/data-grid"
@page "/components/datagrid"

<PageTitle>DataGrid — Lumeo</PageTitle>

<PageHeader Title="DataGrid" Description="A powerful data grid with sorting, filtering, pagination, selection, inline editing, column pinning, resizable columns, row editing, layout persistence, context menus, and CSV/Excel/JSON export." />

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <ChildContent>
        <strong>Dependencies &amp; licensing — read carefully if you're shipping commercially.</strong>
        <ul class="mt-2 space-y-1.5 list-disc list-inside">
            <li><strong>ClosedXML</strong> 0.104.2 (Excel <code>.xlsx</code> export) — MIT, fully free for any use.</li>
            <li><strong>QuestPDF</strong> 2024.12.3 (PDF export) — <strong>dual-licensed</strong>:
                <ul class="ml-6 mt-1 space-y-0.5 list-disc list-inside">
                    <li><strong>Free</strong> for individual developers and for organizations with annual gross revenue under $1M USD (Community License).</li>
                    <li><strong>Paid</strong> ($699/dev/year as of writing) for everyone else — purchased direct from
                        <a href="https://www.questpdf.com/license/" class="underline hover:text-foreground">questpdf.com</a>.
                        Lumeo doesn't take a cut.</li>
                </ul>
            </li>
            <li>CSV / JSON exports use built-in .NET serialization — no third-party dep, no licensing concern.</li>
        </ul>
        If you don't use the PDF export feature, the QuestPDF dependency is still loaded as a transitive package
        but never invoked — only calling <code>ExportPdfAsync</code> triggers the licensing requirement.
    </ChildContent>
</Alert>

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Complex data grids with advanced features like sorting, filtering, and grouping</li>
        <li>Enterprise table views with inline editing and cell-level validation</li>
        <li>Column pinning and resizable columns for wide data sets</li>
        <li>Scenarios requiring row selection, context menus, and data export (CSV/Excel/JSON)</li>
        <li>Dashboards where the grid starts compact but the user can expand it to fullscreen for a full view</li>
    </ul>
</div>

<div class="mt-10 space-y-6">
    <Heading Id="playground" Level="2" Class="scroll-mt-20">Live Playground</Heading>
    <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
        Flip switches to see every feature in action. The DataGrid below re-renders live with your selections — no rebuild, no reload.
    </Lumeo.Text>

    <div class="grid grid-cols-12 gap-6">
        <div class="col-span-12 lg:col-span-4 xl:col-span-3 space-y-6 lg:sticky lg:top-24 lg:self-start">
            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Toolbar</Heading>
                <Switch @bind-Checked="_pgShowToolbar" Label="Show toolbar" />
                <Switch @bind-Checked="_pgShowSearch" Label="Search box" Disabled="!_pgShowToolbar" />
                <Switch @bind-Checked="_pgShowColumnChooser" Label="Column chooser" Disabled="!_pgShowToolbar" />
                <Switch @bind-Checked="_pgShowExport" Label="Export button" Disabled="!_pgShowToolbar" />
                <Switch @bind-Checked="_pgExpandable" Label="Expand to fullscreen" Disabled="!_pgShowToolbar" />
            </Stack>

            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Columns</Heading>
                <Switch @bind-Checked="_pgSortable" Label="Sortable columns" />
                <Switch @bind-Checked="_pgFilterable" Label="Filterable columns" />
                <Switch @bind-Checked="_pgReorderable" Label="Reorder columns (drag)" />
                <Switch @bind-Checked="_pgPinnable" Label="Pin columns" />
            </Stack>

            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Grouping</Heading>
                <Switch @bind-Checked="_pgShowGroupPanel" Label="Show group panel" />
                <Switch @bind-Checked="_pgGroupsExpanded" Label="Groups expanded by default" />
            </Stack>

            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Pagination</Heading>
                <Switch @bind-Checked="_pgShowPagination" Label="Show pagination" />
                <NumberInput @bind-Value="_pgPageSizeNum" Min="3" Max="20" Step="1" Label="Page size" />
            </Stack>

            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Display</Heading>
                <Switch @bind-Checked="_pgStriped" Label="Striped rows" />
                <Switch @bind-Checked="_pgBordered" Label="Bordered" />
                <Switch @bind-Checked="_pgCompact" Label="Compact rows" />
                <Switch @bind-Checked="_pgHoverable" Label="Hover highlight" />
                <Switch @bind-Checked="_pgIsLoading" Label="Loading skeleton" />
            </Stack>

            <Stack Gap="2">
                <Heading Level="3" Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground">Selection &amp; editing</Heading>
                <Segmented @bind-Value="_pgSelectionMode" Block="true">
                    <SegmentedItem Value="None">None</SegmentedItem>
                    <SegmentedItem Value="Single">Single</SegmentedItem>
                    <SegmentedItem Value="Multiple">Multiple</SegmentedItem>
                </Segmented>
                <Segmented @bind-Value="_pgEditMode" Block="true">
                    <SegmentedItem Value="None">No edit</SegmentedItem>
                    <SegmentedItem Value="Cell">Cell</SegmentedItem>
                    <SegmentedItem Value="Row">Row</SegmentedItem>
                </Segmented>
            </Stack>
        </div>

        <div class="col-span-12 lg:col-span-8 xl:col-span-9">
            <DataGrid TItem="PlaygroundRow"
                      Items="@(_pgIsLoading ? new List<PlaygroundRow>() : _pgRows)"
                      ShowToolbar="_pgShowToolbar"
                      ShowSearch="_pgShowSearch"
                      ShowColumnChooser="_pgShowColumnChooser"
                      ShowExport="_pgShowExport"
                      Expandable="_pgExpandable"
                      ShowPagination="_pgShowPagination"
                      PageSize="_pgPageSize"
                      Striped="_pgStriped"
                      Bordered="_pgBordered"
                      Compact="_pgCompact"
                      Hoverable="_pgHoverable"
                      IsLoading="_pgIsLoading"
                      Reorderable="_pgReorderable"
                      ShowGroupPanel="_pgShowGroupPanel"
                      GroupsExpandedByDefault="_pgGroupsExpanded"
                      SelectionMode="@_pgSelectionModeEnum"
                      EditMode="@_pgEditModeEnum">
                <DataGridColumnDef TItem="PlaygroundRow" Title="Name" Field="Name"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   Pinnable="_pgPinnable" Groupable="true" />
                <DataGridColumnDef TItem="PlaygroundRow" Title="Team" Field="Team"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   Pinnable="_pgPinnable" Groupable="true" />
                <DataGridColumnDef TItem="PlaygroundRow" Title="Role" Field="Role"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   Pinnable="_pgPinnable" Groupable="true" />
                <DataGridColumnDef TItem="PlaygroundRow" Title="Salary" Field="Salary" Format="C0"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   FilterType="DataGridFilterType.Number"
                                   Pinnable="_pgPinnable"
                                   Aggregate="AggregateType.Average" />
                <DataGridColumnDef TItem="PlaygroundRow" Title="Status" Field="Status"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   Pinnable="_pgPinnable" Groupable="true" />
                <DataGridColumnDef TItem="PlaygroundRow" Title="Joined" Field="Joined" Format="yyyy-MM-dd"
                                   Sortable="_pgSortable" Filterable="_pgFilterable"
                                   FilterType="DataGridFilterType.Date"
                                   Pinnable="_pgPinnable" />
            </DataGrid>
        </div>
    </div>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic DataGrid" Description="A simple data grid with sortable columns and pagination." Code="@_basicCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Toolbar, Search & Filtering" Description="Enable the toolbar for global search, column visibility, and CSV export. Column filters appear as inline popovers." Code="@_toolbarCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true" ShowToolbar="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" Filterable="true" FilterType="DataGridFilterType.Number" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" Filterable="true" FilterType="DataGridFilterType.Date" />
        </DataGrid>
    </ComponentDemo>

    <div class="space-y-3">
        <Heading Id="toolbar-customization" Level="2" Class="scroll-mt-20">Toolbar customization</Heading>
        <Text Size="sm" Color="muted">
            The toolbar is composed of independent slots — Search, Columns, Export, and Expand — each togglable with its own parameter. Defaults preserve the full toolbar; opt-out by setting any of <code>ShowSearch</code>, <code>ShowColumnChooser</code>, <code>ShowExport</code>, or <code>Expandable</code> to <code>false</code>. For fine-grained control over which file formats appear in the Export dropdown, use the <code>ExportFormats</code> flags enum. This is especially useful in Blazor WebAssembly, where PDF generators like QuestPDF throw <code>PlatformNotSupportedException</code> — hide PDF by setting <code>ExportFormats="DataGridExportFormat.Csv | DataGridExportFormat.Excel"</code>.
        </Text>
    </div>

    <ComponentDemo Title="Minimal toolbar (search only)" Description="Hide the Columns and Export buttons to give users a cleaner toolbar with just global search." Code="@_toolbarMinimalCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  ShowToolbar="true"
                  ShowColumnChooser="false"
                  ShowExport="false">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Export-only toolbar" Description="Hide the search input and Columns button to keep only the Export dropdown — useful for read-only, report-style grids." Code="@_toolbarExportOnlyCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  ShowToolbar="true"
                  ShowSearch="false"
                  ShowColumnChooser="false">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="CSV-only export (WASM-friendly)" Description="Restrict the Export dropdown to CSV. Use this pattern in Blazor WebAssembly where PDF export libraries aren't supported." Code="@_toolbarCsvOnlyCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  ShowToolbar="true"
                  ExportFormats="DataGridExportFormat.Csv">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
        </DataGrid>
    </ComponentDemo>

    <div class="space-y-3">
        <Heading Id="filtering-extensibility" Level="2" Class="scroll-mt-20">Filtering Extensibility</Heading>
        <Text Size="sm" Color="muted">
            Column filters pick sensible defaults from <code>FilterType</code>, but two extension points let you customize the experience per-column without forking the grid.
        </Text>

        <Heading Level="3" Class="mt-4">Restricting operators per column</Heading>
        <Text Size="sm" Color="muted">
            Pass a <code>List&lt;FilterOperator&gt;</code> to the <code>Operators</code> parameter to limit which operators the built-in filter popover shows. The grid intersects this list with the defaults for the column's FilterType, so nonsensical combinations (e.g. <code>StartsWith</code> on a Number column) are filtered out automatically.
        </Text>
        <pre class="rounded-md border border-border/40 bg-muted/30 p-3 text-xs overflow-x-auto"><code>&lt;DataGridColumnDef TItem="Employee"
                   Title="Name"
                   Field="Name"
                   Filterable="true"
                   Operators="@@(new List&lt;FilterOperator&gt; { FilterOperator.Equals, FilterOperator.StartsWith })" /&gt;</code></pre>

        <Heading Level="3" Class="mt-4">Custom filter UI via FilterTemplate</Heading>
        <Text Size="sm" Color="muted">
            For columns that need a bespoke experience (range sliders, relative-date pickers, tag pickers, ...), supply a <code>FilterTemplate</code>. The render fragment receives a <code>DataGridFilterTemplateContext</code> exposing the field name, the currently-applied <code>FilterDescriptor</code> (or null), and an <code>Apply</code> callback. Invoke <code>Apply</code> with a descriptor to commit the filter, or with <code>null</code> to clear it.
        </Text>
        <pre class="rounded-md border border-border/40 bg-muted/30 p-3 text-xs overflow-x-auto"><code>&lt;DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Filterable="true"&gt;
    &lt;FilterTemplate Context="ctx"&gt;
        &lt;Slider Min="0" Max="200000" Value="_min" ValueChanged="v =&gt; _min = v" /&gt;
        &lt;Button OnClick="@@(async () =&gt; await ctx.Apply(
            new FilterDescriptor(ctx.Field!, FilterOperator.GreaterThanOrEqual, _min, FilterType: DataGridFilterType.Number)))"&gt;
            Apply
        &lt;/Button&gt;
        &lt;Button Variant="Button.ButtonVariant.Ghost" OnClick="@@(async () =&gt; await ctx.Apply(null))"&gt;
            Clear
        &lt;/Button&gt;
    &lt;/FilterTemplate&gt;
&lt;/DataGridColumnDef&gt;</code></pre>

        <Text Size="sm" Color="muted" Class="mt-2">
            What is <em>not</em> pluggable today (tracked for a future release):
            registering brand-new <code>FilterOperator</code> values,
            combining column filters with OR logic,
            and LINQ-expression compilation for server-side evaluation.
            Filters are always AND-combined across columns; within a column you get one operator + value at a time.
        </Text>
    </div>

    <ComponentDemo Title="Multi-Select with Checkboxes" Description="Select multiple rows with checkboxes. The header checkbox toggles select all." Code="@_multiSelectCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  SelectionMode="DataGridSelectionMode.Multiple"
                  SelectedItemsChanged="@OnMultiSelectionChanged">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_multiSelectedCount > 0)
        {
            <Alert Class="mt-4" Title="Selection" Description="@($"{_multiSelectedCount} row(s) selected.")">
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Single Row Selection" Description="Click a row to select it. Useful for master-detail views." Code="@_singleSelectCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  SelectionMode="DataGridSelectionMode.Single"
                  SelectedItemsChanged="@OnSelectionChanged">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
        </DataGrid>
        @if (_selectedEmployee is not null)
        {
            <Alert Class="mt-4" Title="Selected" Description="@($"{_selectedEmployee.Name} — {_selectedEmployee.Department} — {_selectedEmployee.Salary.ToString("C0")}")">
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Striped, Bordered & Compact" Description="Visual variants for different density needs." Code="@_styledCode">
        <DataGrid TItem="Employee" Items="@_employees" Striped="true" Bordered="true" Compact="true" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Custom Cell Templates" Description="Use CellTemplate to render custom content like avatars, badges, and action buttons." Code="@_templateCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Employee" Field="Name" Sortable="true">
                <CellTemplate>
                    <Flex Align="center" Gap="2">
                        <Avatar Size="Lumeo.Size.Sm">
                            <AvatarFallback>@context.Name[..2].ToUpper()</AvatarFallback>
                        </Avatar>
                        <Stack Gap="0">
                            <Lumeo.Text As="span" Weight="medium">@context.Name</Lumeo.Text>
                            <Lumeo.Text As="div" Size="xs" Color="muted">@context.Department</Lumeo.Text>
                        </Stack>
                    </Flex>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status">
                <CellTemplate>
                    <Badge Variant="@(context.Status == "Active" ? Badge.BadgeVariant.Default : Badge.BadgeVariant.Secondary)">
                        @context.Status
                    </Badge>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Actions" Field="Name">
                <CellTemplate>
                    <Flex Align="center" Gap="1">
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Pencil" Class="h-3.5 w-3.5" />
                        </Button>
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Trash2" Class="h-3.5 w-3.5 text-destructive" />
                        </Button>
                    </Flex>
                </CellTemplate>
            </DataGridColumnDef>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Expandable Detail Rows" Description="Use DetailTemplate to show additional information when a row is expanded." Code="@_detailCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DetailTemplate>
                <Stack Gap="2" Class="p-4">
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Full Name:</Lumeo.Text> @context.Name</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Department:</Lumeo.Text> @context.Department</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Annual Salary:</Lumeo.Text> @context.Salary.ToString("C0")</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Start Date:</Lumeo.Text> @context.StartDate.ToString("MMMM dd, yyyy")</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Status:</Lumeo.Text> @context.Status</Lumeo.Text>
                </Stack>
            </DetailTemplate>
            <ChildContent>
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            </ChildContent>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Column Pinning" Description="Pin columns to the left or right edge so they stay visible while scrolling horizontally." Code="@_pinCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Pin="PinDirection.Left" Width="180" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Width="150" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Width="120" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Width="120" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" Width="150" />
            <DataGridColumnDef TItem="Employee" Title="Actions" Field="Name" Pin="PinDirection.Right" Width="100">
                <CellTemplate>
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                        <DynamicIcon Name="Ellipsis" Class="h-4 w-4" />
                    </Button>
                </CellTemplate>
            </DataGridColumnDef>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Resizable Columns" Description="Drag the column border to resize. All columns are resizable by default. Use MinWidth and MaxWidth to constrain sizing." Code="@_resizeCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Width="200" MinWidth="100" MaxWidth="400" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Width="150" MinWidth="80" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Width="120" MinWidth="80" MaxWidth="200" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Width="100" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Inline Cell Editing" Description="Click a cell to edit it inline. Press Enter to commit, Escape to cancel." Code="@_editCode">
        <DataGrid TItem="Employee" Items="@_editableEmployees" PageSize="5" ShowPagination="true"
                  EditMode="DataGridEditMode.Cell" OnCellEdit="@HandleCellEdit">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_lastEditInfo is not null)
        {
            <Alert Class="mt-4" Title="Cell Edited" Description="@_lastEditInfo">
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Batch / Buffered Editing"
                   Description="Edit cells inline as in Cell mode, but commits land in a per-row pending-changes buffer. A pending strip and Save all / Discard buttons appear above the grid. Optional + Add row trigger pushes new rows into the Added buffer. OnBatchSave receives Modified + Added when the user clicks Save all.">
        <DataGrid TItem="Employee" Items="@_batchEmployees" PageSize="5" ShowPagination="true"
                  EditMode="DataGridEditMode.Batch"
                  ShowAddRow="true"
                  NewItemFactory="@(() => new Employee("(new)", "Engineering", 0, "Active", DateTime.Today))"
                  OnBatchSave="@HandleBatchSave">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_lastBatchSummary is not null)
        {
            <Alert Class="mt-4" Title="Batch Saved" Description="@_lastBatchSummary" />
        }
    </ComponentDemo>

    <ComponentDemo Title="Row Editing" Description="Edit an entire row at once. Click the edit button to enter edit mode, then save or cancel." Code="@_rowEditCode">
        <DataGrid TItem="Employee" Items="@_rowEditEmployees" PageSize="5" ShowPagination="true"
                  EditMode="DataGridEditMode.Row" OnRowEdit="@HandleRowEdit">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_lastRowEditInfo is not null)
        {
            <Alert Class="mt-4" Title="Row Edited" Description="@_lastRowEditInfo">
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Footer Aggregation" Description="Show computed summaries (Sum, Average, Count, Min, Max) in the table footer." Code="@_aggregateCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="20">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Aggregate="AggregateType.Count" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Aggregate="AggregateType.Average" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

