@page "/components/charts/scatter"

<PageTitle>Scatter Chart — Lumeo</PageTitle>

<PageHeader Title="Scatter Chart" Description="Reveal correlations and distributions between two continuous variables. Ideal for data exploration and identifying clusters or outliers." />

<Stack Gap="8">
    <ComponentDemo Title="Multi-Series Scatter" Code="@_basicCode">
        <Container>
            <ScatterChart Series="_series" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">ScatterChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Series</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;ScatterSeriesData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Data series with Name and Points (double[] coordinate pairs).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">BubbleSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Fixed symbol size in pixels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows legend when multiple series present.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<ScatterChart.ScatterSeriesData> _series = new()
    {
        new()
        {
            Name = "Team Alpha",
            Points = new()
            {
                new[] { 14.0, 82.3 }, new[] { 22.0, 74.1 }, new[] { 8.0, 91.5 },
                new[] { 31.0, 65.8 }, new[] { 18.0, 78.4 }, new[] { 25.0, 69.2 },
                new[] { 11.0, 87.6 }
            }
        },
        new()
        {
            Name = "Team Beta",
            Points = new()
            {
                new[] { 28.0, 55.3 }, new[] { 37.0, 48.7 }, new[] { 19.0, 62.1 },
                new[] { 43.0, 41.5 }, new[] { 33.0, 51.8 }, new[] { 24.0, 58.9 },
                new[] { 40.0, 45.2 }
            }
        }
    };

    private string _basicCode = @"<ScatterChart Series=""_series"" />";
}
