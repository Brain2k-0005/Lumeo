@namespace Lumeo
@inject Services.ComponentInteropService Interop
@implements IAsyncDisposable

@*
    CodeEditor — CodeMirror 6 wrapper.

    Why CodeMirror over Monaco:
      - Monaco's WASM/worker bundle is 5MB+; awkward on Cloudflare Pages
        (25MB asset ceiling) and slow to first-paint on Blazor WASM.
      - CodeMirror 6 is modular: ~150KB core + tiny language packs imported
        on demand from esm.sh, so a JSON-only page only pays for JSON.

    Language packs are loaded lazily via `import('https://esm.sh/@codemirror/lang-X')`
    from inside the JS module. Switching languages re-imports only the new pack.
*@

<div class="@RootClass"
     role="@(ReadOnly ? "document" : "textbox")"
     aria-label="@(Placeholder ?? "Code editor")"
     @attributes="AdditionalAttributes">
    <div id="@_editorId" style="height: @Height" class="lumeo-code-editor h-full w-full"></div>
</div>

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>
    /// Source language. Currently supported: csharp, javascript, typescript, html,
    /// css, json, markdown, xml, sql, python, plaintext. Unknown values fall back
    /// to plaintext.
    /// </summary>
    [Parameter] public string Language { get; set; } = "plaintext";

    /// <summary>light | dark | auto (follows page theme via the `dark` class on &lt;html&gt;).</summary>
    [Parameter] public string Theme { get; set; } = "auto";

    [Parameter] public string Height { get; set; } = "400px";
    [Parameter] public bool LineNumbers { get; set; } = true;
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>
    /// Shows a scrollbar-side minimap of the document. CodeMirror 6 has no
    /// built-in minimap, so this lazily loads the <c>@@replit/codemirror-minimap</c>
    /// extension from <see cref="EsmBase"/> on first enable. If that import fails
    /// (e.g. offline with no self-hosted copy of the package) the editor degrades
    /// gracefully — the rest of the editor keeps working, just without a minimap.
    /// Toggling at runtime adds/removes the extension without losing selection
    /// or scroll position.
    /// </summary>
    [Parameter] public bool ShowMinimap { get; set; }

    /// <summary>
    /// Base URL the CodeMirror core, language packs, theme, and minimap are
    /// imported from. Defaults to the public esm.sh CDN. Point this at a
    /// self-hosted ESM mirror (or a path served by your own app) for
    /// air-gapped / offline / strict-CSP deployments — e.g.
    /// <c>EsmBase="/_content/MyApp/esm"</c> or <c>EsmBase="https://esm.myco.internal"</c>.
    /// A trailing slash is optional. When null, falls back to the global
    /// <c>window.lumeoCdn.codeMirrorBase</c> override (if set) and then esm.sh.
    /// </summary>
    [Parameter] public string? EsmBase { get; set; }

    [Parameter] public int TabSize { get; set; } = 4;
    [Parameter] public bool UseTabs { get; set; }

    /// <summary>"off" | "on"</summary>
    [Parameter] public string WordWrap { get; set; } = "off";

    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Fires alongside ValueChanged; provided for symmetry with Monaco-style APIs.</summary>
    [Parameter] public EventCallback<string> OnChange { get; set; }

    [Parameter] public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _editorId = $"lumeo-code-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<CodeEditor>? _selfRef;
    private bool _initialized;
    private string? _lastSyncedValue;
    private string? _lastLanguage;
    private string? _lastTheme;
    private bool? _lastReadOnly;
    private bool? _lastShowMinimap;

    private string RootClass
        => $"rounded-lg border border-border/40 overflow-hidden bg-card {Class}".Trim();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);

            var options = new
            {
                value = Value ?? string.Empty,
                language = Language,
                theme = Theme,
                lineNumbers = LineNumbers,
                readOnly = ReadOnly,
                tabSize = TabSize,
                useTabs = UseTabs,
                wordWrap = WordWrap,
                placeholder = Placeholder,
                minimap = ShowMinimap,
                esmBase = EsmBase,
            };

            // Guard the whole init path: if the module import or the JS init
            // throws (offline with no self-hosted ESM mirror, CSP block, circuit
            // drop mid-init), we must not leave a half-built instance behind —
            // dispose the DotNetObjectReference and the partially-loaded module
            // so there's no managed/JS object leak. _initialized stays false so
            // later parameter syncs and DisposeAsync short-circuit cleanly.
            try
            {
                _module = await Interop.ImportModuleAsync("./_content/Lumeo.CodeEditor/js/code-editor.js");
                await _module.InvokeVoidAsync("init", _editorId, options, _selfRef);
                _initialized = true;
                _lastSyncedValue = Value;
                _lastLanguage = Language;
                _lastTheme = Theme;
                _lastReadOnly = ReadOnly;
                _lastShowMinimap = ShowMinimap;
            }
            catch (JSDisconnectedException)
            {
                await CleanupAfterFailedInitAsync();
            }
            catch (ObjectDisposedException)
            {
                await CleanupAfterFailedInitAsync();
            }
            catch (JSException)
            {
                // Init genuinely failed (bad bundle URL, ESM import error). Tear
                // down so we don't leak, then rethrow so a host that wants to
                // surface the failure still can — Blazor logs it as an unhandled
                // OnAfterRenderAsync task otherwise, which is the desired signal.
                await CleanupAfterFailedInitAsync();
                throw;
            }
            return;
        }

        if (!_initialized || _module is null) return;

        try
        {
            if (!string.Equals(_lastSyncedValue ?? string.Empty, Value ?? string.Empty, StringComparison.Ordinal))
            {
                _lastSyncedValue = Value;
                await _module.InvokeVoidAsync("setValue", _editorId, Value ?? string.Empty);
            }

            if (!string.Equals(_lastLanguage, Language, StringComparison.OrdinalIgnoreCase))
            {
                _lastLanguage = Language;
                await _module.InvokeVoidAsync("setLanguage", _editorId, Language);
            }

            if (!string.Equals(_lastTheme, Theme, StringComparison.OrdinalIgnoreCase))
            {
                _lastTheme = Theme;
                await _module.InvokeVoidAsync("setTheme", _editorId, Theme);
            }

            if (_lastReadOnly != ReadOnly)
            {
                _lastReadOnly = ReadOnly;
                await _module.InvokeVoidAsync("setReadOnly", _editorId, ReadOnly);
            }

            if (_lastShowMinimap != ShowMinimap)
            {
                _lastShowMinimap = ShowMinimap;
                await _module.InvokeVoidAsync("setMinimap", _editorId, ShowMinimap);
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    // Best-effort teardown for a failed first-render init. Disposes whatever was
    // allocated before the failure (module ref + DotNetObjectReference) and never
    // throws — it runs from inside catch blocks.
    private async Task CleanupAfterFailedInitAsync()
    {
        _initialized = false;
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (Exception) { /* never throw from cleanup */ }
            _module = null;
        }
        _selfRef?.Dispose();
        _selfRef = null;
    }

    [JSInvokable]
    public async Task OnEditorChange(string value)
    {
        // Track the latest text so OnAfterRenderAsync doesn't push it straight
        // back into CodeMirror after the bound field updates — a self-induced
        // re-set would move the caret to position 0 on every keystroke.
        _lastSyncedValue = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);
        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync(value);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("destroy", _editorId);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (Exception) { /* never throw from disposer */ }

        _selfRef?.Dispose();
    }
}
