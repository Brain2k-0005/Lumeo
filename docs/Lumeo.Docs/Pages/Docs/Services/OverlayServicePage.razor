@page "/docs/services/overlay"
@namespace Lumeo.Docs.Pages.Docs.Services

@using Lumeo.Services

<PageTitle>Overlay Service — Lumeo</PageTitle>

<PageHeader Title="Overlay Service" Description="Open dialogs, sheets, drawers, and alert dialogs programmatically from C# code and await their results." />

<Stack Gap="10">

    <!-- Quick Start -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Quick Start</Heading>
            <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
                The <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OverlayService</code> lets you open overlays imperatively
                (like MudBlazor's <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">DialogService</code>) instead of declaring them in markup.
                Each method returns a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Task&lt;OverlayResult&gt;</code> so you can
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">await</code> the user's response.
            </Lumeo.Text>

            <Heading Level="3">1. Add the provider to your layout</Heading>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">&lt;!-- MainLayout.razor --&gt;
&lt;div class="min-h-screen"&gt;
    @@Body
    &lt;OverlayProvider /&gt;
&lt;/div&gt;</div>

            <Heading Level="3">2. Create a content component</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                Your content component receives an <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OverlayReference</code> via
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">CascadingParameter</code>. Call
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Overlay.Close(data)</code> to return a result or
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Overlay.Cancel()</code> to dismiss.
            </Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">&lt;!-- EditProfileForm.razor --&gt;
&lt;Stack Gap="4"&gt;
    &lt;Input @@bind-Value="_name" Placeholder="Name" /&gt;
    &lt;Flex Justify="end" Gap="2"&gt;
        &lt;Button Variant="Button.ButtonVariant.Outline"
                OnClick="() =&gt; Overlay.Cancel()"&gt;Cancel&lt;/Button&gt;
        &lt;Button OnClick="Submit"&gt;Save&lt;/Button&gt;
    &lt;/Flex&gt;
&lt;/Stack&gt;

@@code {
    [CascadingParameter]
    public OverlayReference Overlay { get; set; } = default!;

    private string _name = "";

    private void Submit()
    {
        Overlay.Close(new { Name = _name });
    }
}</div>

            <Heading Level="3">3. Open from code</Heading>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">@@inject OverlayService OverlayService

@@code {
    private async Task EditProfile()
    {
        var result = await OverlayService.ShowDialogAsync&lt;EditProfileForm&gt;("Edit Profile");

        if (!result.Cancelled)
        {
            // result.Data contains what you passed to Close()
            var name = result.GetData&lt;dynamic&gt;()?.Name;
        }
    }
}</div>
        </Stack>
    </section>

    <Separator />

    <!-- Dialog -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Dialog</Heading>
            <Lumeo.Text Size="sm" Color="muted">Opens a centered modal dialog with your component inside.</Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">var result = await OverlayService.ShowDialogAsync&lt;MyComponent&gt;(
    title: "Edit Profile",
    parameters: new OverlayParameters()
        .Add("UserId", 42)
        .Add("Mode", "edit"),
    options: new OverlayOptions
    {
        PreventClose = false,
        Class = "max-w-2xl"
    }
);</div>
            <Button OnClick="ShowDialog">Try Dialog</Button>
            @if (_dialogResult is not null)
            {
                <Alert>@_dialogResult</Alert>
            }
        </Stack>
    </section>

    <Separator />

    <!-- Sheet -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Sheet</Heading>
            <Lumeo.Text Size="sm" Color="muted">Opens a panel that slides in from any edge of the screen.</Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">var result = await OverlayService.ShowSheetAsync&lt;MyComponent&gt;(
    title: "Settings",
    side: SheetSide.Right,   // Top, Right, Bottom, Left
    size: SheetSize.Lg       // Sm, Default, Lg, Xl, Full
);</div>
            <Flex Gap="2" Wrap="true">
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(SheetSide.Right)">Right</Button>
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(SheetSide.Left)">Left</Button>
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(SheetSide.Bottom)">Bottom</Button>
            </Flex>
        </Stack>
    </section>

    <Separator />

    <!-- Drawer -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Drawer</Heading>
            <Lumeo.Text Size="sm" Color="muted">Opens a bottom drawer, ideal for mobile-friendly interactions.</Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">var result = await OverlayService.ShowDrawerAsync&lt;MyComponent&gt;("Pick a date");</div>
            <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowDrawer">Open Drawer</Button>
        </Stack>
    </section>

    <Separator />

    <!-- Alert Dialog -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Alert Dialog</Heading>
            <Lumeo.Text Size="sm" Color="muted">A simple confirm/cancel dialog — no custom component needed.</Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
{
    Title = "Delete this item?",
    Description = "This action cannot be undone.",
    ConfirmText = "Delete",
    CancelText = "Cancel",
    IsDestructive = true
});

if (!result.Cancelled)
{
    await DeleteItemAsync();
}</div>
            <Flex Gap="2" Wrap="true">
                <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowConfirm">Confirm</Button>
                <Button Variant="Button.ButtonVariant.Destructive" OnClick="ShowDestructive">Delete</Button>
            </Flex>
            @if (_alertResult is not null)
            {
                <Alert Variant="@(_alertCancelled ? Alert.AlertVariant.Destructive : Alert.AlertVariant.Default)">@_alertResult</Alert>
            }
        </Stack>
    </section>

    <Separator />

    <!-- Passing Parameters -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Passing Parameters</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                Use <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OverlayParameters</code> to pass data to your content component.
                Parameters are fed to <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">DynamicComponent</code>, so they map to
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">[Parameter]</code> properties on your component.
            </Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">// Caller
var result = await OverlayService.ShowDialogAsync&lt;EditUserForm&gt;(
    "Edit User",
    parameters: new OverlayParameters()
        .Add("UserId", 42)
        .Add("ReadOnly", false)
);

// Content component
@@code {
    [Parameter] public int UserId { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [CascadingParameter] public OverlayReference Overlay { get; set; } = default!;
}</div>
        </Stack>
    </section>

    <Separator />

    <!-- API Reference -->
    <section>
        <Stack Gap="6">
            <Heading Level="2">API Reference</Heading>

            <Stack>
                <Heading Level="3" Class="mb-3">OverlayService Methods</Heading>
                <div class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Method</th>
                                <th class="text-left p-3 font-medium text-foreground">Returns</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">ShowDialogAsync&lt;T&gt;(title?, params?, options?)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">Task&lt;OverlayResult&gt;</td>
                                <td class="p-3 text-muted-foreground">Opens a dialog with component T.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">ShowSheetAsync&lt;T&gt;(title?, side, size, params?, options?)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">Task&lt;OverlayResult&gt;</td>
                                <td class="p-3 text-muted-foreground">Opens a sheet panel with component T.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">ShowDrawerAsync&lt;T&gt;(title?, params?, options?)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">Task&lt;OverlayResult&gt;</td>
                                <td class="p-3 text-muted-foreground">Opens a drawer with component T.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">ShowAlertDialogAsync(AlertDialogOptions)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">Task&lt;OverlayResult&gt;</td>
                                <td class="p-3 text-muted-foreground">Shows a confirm/cancel alert.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Close(overlayId, result?)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">void</td>
                                <td class="p-3 text-muted-foreground">Closes an overlay with a result.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Cancel(overlayId)</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">void</td>
                                <td class="p-3 text-muted-foreground">Cancels an overlay.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </Stack>

            <Stack>
                <Heading Level="3" Class="mb-3">OverlayResult</Heading>
                <div class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Member</th>
                                <th class="text-left p-3 font-medium text-foreground">Type</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Cancelled</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                                <td class="p-3 text-muted-foreground">True when dismissed without confirming.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Data</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">object?</td>
                                <td class="p-3 text-muted-foreground">The value passed to Close().</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">GetData&lt;T&gt;()</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">T?</td>
                                <td class="p-3 text-muted-foreground">Casts Data to T.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </Stack>

            <Stack>
                <Heading Level="3" Class="mb-3">OverlayReference (cascaded to content)</Heading>
                <div class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Member</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Close(result?)</td>
                                <td class="p-3 text-muted-foreground">Close the overlay and return data to the caller.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Cancel()</td>
                                <td class="p-3 text-muted-foreground">Dismiss the overlay (Cancelled = true).</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Parameters</td>
                                <td class="p-3 text-muted-foreground">Access the OverlayParameters passed at open time.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </Stack>

        </Stack>
    </section>

</Stack>

@inject OverlayService OverlayService

@code {
    private string? _dialogResult;
    private string? _alertResult;
    private bool _alertCancelled;

    private async Task ShowDialog()
    {
        _dialogResult = null;
        var result = await OverlayService.ShowDialogAsync<OverlayDemoContent>("Edit Profile");
        _dialogResult = result.Cancelled ? "Cancelled" : $"Result: {result.Data}";
    }

    private async Task ShowSheet(SheetSide side)
    {
        await OverlayService.ShowSheetAsync<OverlayDemoContent>("Settings", side);
    }

    private async Task ShowDrawer()
    {
        await OverlayService.ShowDrawerAsync<OverlayDemoContent>("Edit Profile");
    }

    private async Task ShowConfirm()
    {
        _alertResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Save changes?",
            Description = "This will overwrite your existing data.",
            ConfirmText = "Save"
        });
        _alertCancelled = result.Cancelled;
        _alertResult = result.Cancelled ? "Cancelled" : "Confirmed";
    }

    private async Task ShowDestructive()
    {
        _alertResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Delete this item?",
            Description = "This action cannot be undone.",
            ConfirmText = "Delete",
            IsDestructive = true
        });
        _alertCancelled = result.Cancelled;
        _alertResult = result.Cancelled ? "Cancelled" : "Deleted";
    }
}
