@namespace Lumeo

@*  A single row inside a <MapLegend>. Renders a colored dot + label. *@

<div class="flex items-center gap-2 @Class" @attributes="AdditionalAttributes">
    <span class="inline-block w-2.5 h-2.5 rounded-full flex-shrink-0" style="background:@_resolvedColor"></span>
    <span class="text-muted-foreground">@Label</span>
</div>

@code {
    /// <summary>Dot color. Friendly names (<c>"red"</c>, <c>"green"</c>, etc.)
    /// or any CSS color value.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>Label text shown next to the dot.</summary>
    [Parameter] public string? Label { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private static readonly Dictionary<string, string> _colorMap = new()
    {
        ["red"]    = "#ef4444",
        ["green"]  = "#22c55e",
        ["yellow"] = "#eab308",
        ["blue"]   = "#3b82f6",
        ["purple"] = "#a855f7",
        ["pink"]   = "#ec4899",
        ["orange"] = "#f97316",
        ["teal"]   = "#14b8a6",
        ["gray"]   = "#6b7280",
        ["slate"]  = "#64748b",
        ["violet"] = "#8b5cf6",
        ["cyan"]   = "#06b6d4",
        ["emerald"]= "#10b981",
        ["rose"]   = "#f43f5e",
        ["amber"]  = "#f59e0b",
        ["sky"]    = "#0ea5e9",
    };

    private string _resolvedColor => Color is null
        ? "hsl(var(--primary))"
        : (_colorMap.TryGetValue(Color.ToLowerInvariant(), out var hex) ? hex : Color);
}
