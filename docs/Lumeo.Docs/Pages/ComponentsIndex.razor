@page "/components"

<PageTitle>Components — Lumeo</PageTitle>

<PageHeader Title="Components" Description="Explore all available Lumeo components. Click any component to see live demos and code examples." />

<Grid Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    @foreach (var group in _componentGroups)
    {
        <Stack Gap="3">
            <Heading Level="3" Class="text-sm">@group.Category</Heading>
            @foreach (var comp in group.Components)
            {
                <a href="components/@comp.Href" class="block rounded-lg border bg-card p-4 hover:bg-accent/50 transition-colors no-underline group">
                    <Lumeo.Text Weight="medium" Class="group-hover:text-accent-foreground">@comp.Name</Lumeo.Text>
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-1">@comp.Description</Lumeo.Text>
                </a>
            }
        </Stack>
    }
</Grid>

