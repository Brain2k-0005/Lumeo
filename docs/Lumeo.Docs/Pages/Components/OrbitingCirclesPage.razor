@page "/components/orbiting-circles"

<PageTitle>OrbitingCircles — Lumeo</PageTitle>

<PageHeader Title="OrbitingCircles"
            Description="Renders children on circular orbital paths around a central element. Use rings with different radii and durations to build animated icon constellations." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Hero sections showing an ecosystem of tools orbiting a central product logo.</li>
        <li>Feature spotlights where supporting icons rotate around a core concept.</li>
        <li>Loading spinners or animated decorative rings.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Logo Constellation" Code="@_basicCode">
        <div class="flex items-center justify-center py-12">
            <OrbitingCircles @ref="_orbit1" Size="280">
                <div class="h-14 w-14 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center shadow-sm">
                    <Blazicon Svg="Lucide.Zap" class="h-7 w-7 text-primary" />
                </div>
            </OrbitingCircles>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Two Rings — Inner &amp; Outer" Code="@_twoRingCode">
        <div class="flex items-center justify-center py-12">
            <OrbitingCircles @ref="_orbit2" Size="320">
                <div class="h-16 w-16 rounded-2xl bg-primary flex items-center justify-center shadow-md">
                    <Blazicon Svg="Lucide.Layers" class="h-8 w-8 text-primary-foreground" />
                </div>
            </OrbitingCircles>
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">OrbitingCircles</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Size</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">200</td>
                            <td class="p-3 text-muted-foreground">Container size in pixels (width and height).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ChildContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Center element (logo, icon, etc.).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/animated-beam" class="text-primary hover:underline">AnimatedBeam</a> — Animated SVG beam between two elements.</li>
        <li><a href="/components/motion" class="text-primary hover:underline">Motion</a> — Overview of all motion primitives.</li>
    </ul>
</div>

@code {
    private OrbitingCircles? _orbit1;
    private OrbitingCircles? _orbit2;
    private bool _orbitsAdded;

    // Pre-build RenderFragment lambdas (valid in @code — no @<> syntax needed)
    private static RenderFragment IconBubble(SvgIcon icon, string colorClass, string size = "w-9 h-9")
        => b => {
            b.OpenElement(0, "div");
            b.AddAttribute(1, "class", $"flex items-center justify-center {size} rounded-full bg-card border border-border/60 shadow-sm");
            b.OpenComponent<Blazicon>(2);
            b.AddAttribute(3, "Svg", icon);
            b.AddAttribute(4, "class", $"h-4 w-4 {colorClass}");
            b.CloseComponent();
            b.CloseElement();
        };

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender || _orbitsAdded) return;
        _orbitsAdded = true;

        // Single ring
        _orbit1?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Star,     "text-primary"),  80, 16000, false, 0));
        _orbit1?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Sparkles, "text-primary"),  80, 16000, false, 120));
        _orbit1?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Zap,      "text-primary"),  80, 16000, false, 240));

        // Two rings
        _orbit2?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Bell,   "text-amber-500"),  70, 12000, false, 0));
        _orbit2?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Shield, "text-blue-500"),   70, 12000, false, 180));
        _orbit2?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Globe,  "text-green-500", "w-10 h-10"), 128, 22000, true, 60));
        _orbit2?.AddOrbit(new OrbitingCircles.OrbitDef(IconBubble(Lucide.Star,   "text-violet-500", "w-10 h-10"), 128, 22000, true, 240));
    }

    private const string _basicCode = @"@* Orbits are added imperatively via @ref after first render *@
<OrbitingCircles @ref=""_orbits"" Size=""280"">
    <div class=""h-14 w-14 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center"">
        <Blazicon Svg=""Lucide.Zap"" class=""h-7 w-7 text-primary"" />
    </div>
</OrbitingCircles>

@code {
    OrbitingCircles? _orbits;
    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _orbits?.AddOrbit(new OrbitingCircles.OrbitDef(
            Content: b => { b.OpenElement(0,""div""); b.AddAttribute(1,""class"",""w-9 h-9 rounded-full bg-card""); b.CloseElement(); },
            Radius: 80, DurationMs: 16000, Reverse: false, Offset: 0));
    }
}";

    private const string _twoRingCode = @"<OrbitingCircles @ref=""_orbits"" Size=""320"">
    <div class=""h-16 w-16 rounded-2xl bg-primary flex items-center justify-center"">
        <Blazicon Svg=""Lucide.Layers"" class=""h-8 w-8 text-primary-foreground"" />
    </div>
</OrbitingCircles>";
}
