@page "/docs/services/toast"
@namespace Lumeo.Docs.Pages.Docs.Services

@using Lumeo.Services

<PageTitle>Toast Service — Lumeo</PageTitle>

<PageHeader Title="Toast Service" Description="Show, dismiss, and update toast notifications programmatically from C# code." />

<Stack Gap="10">

    <!-- Quick Start -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Quick Start</Heading>
            <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
                The <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">ToastService</code> is registered automatically by
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">AddLumeo()</code>. Inject it into any component and call
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Show()</code> to display a toast.
            </Lumeo.Text>

            <Heading Level="3">1. Add the provider to your layout</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                Place <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">&lt;ToastProvider /&gt;</code> once in your
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">MainLayout.razor</code>. This renders toast notifications.
            </Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">&lt;!-- MainLayout.razor --&gt;
&lt;div class="min-h-screen"&gt;
    @@Body
    &lt;ToastProvider Position="ToastViewport.ToastPosition.BottomRight"
                   DefaultDuration="5000"
                   MaxToasts="5" /&gt;
&lt;/div&gt;</div>

            <Heading Level="3">2. Inject and use</Heading>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">@@inject ToastService ToastService

&lt;Button OnClick="HandleSave"&gt;Save&lt;/Button&gt;

@@code {
    private void HandleSave()
    {
        ToastService.Success("Saved", "Your changes have been saved.");
    }
}</div>
        </Stack>
    </section>

    <Separator />

    <!-- Examples -->
    <section>
        <Stack Gap="6">
            <Heading Level="2">Examples</Heading>

            <Stack Gap="4">
                <Heading Level="3">Variants</Heading>
                <Lumeo.Text Size="sm" Color="muted">Convenience methods for common toast types:</Lumeo.Text>
                <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">// Default toast
ToastService.Show("Event created", "Monday, January 1st at 5:00 PM");

// Success
ToastService.Success("Saved", "Your profile has been updated.");

// Error
ToastService.Error("Error", "Something went wrong. Please try again.");

// Warning
ToastService.Warning("Warning", "Your session will expire in 5 minutes.");

// Info
ToastService.Info("Tip", "You can drag items to reorder them.");</div>
                <Flex Gap="2" Wrap="true">
                    <Button OnClick='() => ToastService.Show("Event created", "Monday, January 1st")'>Default</Button>
                    <Button Variant="Button.ButtonVariant.Secondary" OnClick='() => ToastService.Success("Saved", "Profile updated.")'>Success</Button>
                    <Button Variant="Button.ButtonVariant.Destructive" OnClick='() => ToastService.Error("Error", "Something went wrong.")'>Error</Button>
                    <Button Variant="Button.ButtonVariant.Outline" OnClick='() => ToastService.Warning("Warning", "Session expiring.")'>Warning</Button>
                    <Button Variant="Button.ButtonVariant.Outline" OnClick='() => ToastService.Info("Tip", "Drag to reorder.")'>Info</Button>
                </Flex>
            </Stack>

            <Stack Gap="4">
                <Heading Level="3">With Options</Heading>
                <Lumeo.Text Size="sm" Color="muted">Full control with <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">ToastOptions</code>:</Lumeo.Text>
                <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">// Toast with action button
ToastService.Show(new ToastOptions
{
    Title = "Message sent",
    Description = "Your message has been delivered.",
    ActionLabel = "Undo",
    OnAction = () => UndoSend(),
    Duration = 8000
});

// Non-dismissible persistent toast
ToastService.Show(new ToastOptions
{
    Title = "Uploading...",
    Description = "Please wait while your file uploads.",
    Dismissible = false,
    Duration = 0  // stays until dismissed programmatically
});</div>
                <Flex Gap="2" Wrap="true">
                    <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowWithAction">With Action</Button>
                    <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowPersistent">Persistent</Button>
                </Flex>
            </Stack>

            <Stack Gap="4">
                <Heading Level="3">Dismiss and Update</Heading>
                <Lumeo.Text Size="sm" Color="muted">Control toasts after showing them:</Lumeo.Text>
                <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">// Show returns an ID you can use later
var id = ToastService.Show("Processing...");

// Update an existing toast
ToastService.Update(id, new ToastOptions
{
    Title = "Done!",
    Variant = ToastVariant.Success,
    Duration = 3000
});

// Dismiss a specific toast
ToastService.Dismiss(id);

// Dismiss all toasts
ToastService.DismissAll();</div>
            </Stack>

            <Stack Gap="4">
                <Heading Level="3">Promise Toast</Heading>
                <Lumeo.Text Size="sm" Color="muted">Show loading, success, or error states automatically for async operations:</Lumeo.Text>
                <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">await ToastService.Promise(
    action: () => SaveDataAsync(),
    loading: new ToastOptions { Title = "Saving...", Description = "Please wait." },
    success: result => new ToastOptions
    {
        Title = "Saved!",
        Description = $"Created record #{result.Id}",
        Variant = ToastVariant.Success
    },
    error: ex => new ToastOptions
    {
        Title = "Failed",
        Description = ex.Message,
        Variant = ToastVariant.Destructive
    }
);</div>
                <Button OnClick="ShowPromise">Try Promise Toast</Button>
            </Stack>
        </Stack>
    </section>

