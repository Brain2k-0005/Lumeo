@namespace Lumeo

<div class="@(Cx.Merge("flex flex-col space-y-1.5", PadClass, Class))" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The header content, typically a <see cref="CardTitle"/> and optional
    /// <see cref="CardDescription"/> stacked with vertical spacing.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the header's root <c>div</c>, after the
    /// density-driven padding classes.</summary>
    [Parameter] public string? Class { get; set; }
    [CascadingParameter] private Lumeo.Density? Density { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string PadClass => Density switch
    {
        Lumeo.Density.Compact => "p-4",
        Lumeo.Density.Spacious => "p-8",
        _ => "p-6"
    };
}
