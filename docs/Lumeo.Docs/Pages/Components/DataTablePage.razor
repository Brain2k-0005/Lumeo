@page "/components/data-table"

<PageTitle>Data Table — Lumeo</PageTitle>

<PageHeader Title="Data Table" Description="A powerful table component with templated headers, rows, loading states, and empty states." />

<div class="space-y-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <DataTable Items="_payments" Context="payment">
            <HeaderTemplate>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Status</th>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Email</th>
                <th class="h-10 px-4 text-right align-middle font-medium text-muted-foreground">Amount</th>
            </HeaderTemplate>
            <RowTemplate>
                <td class="p-4 align-middle">
                    <Badge Variant="@(payment.Status == "Success" ? Badge.BadgeVariant.Success : payment.Status == "Pending" ? Badge.BadgeVariant.Warning : Badge.BadgeVariant.Destructive)">
                        @payment.Status
                    </Badge>
                </td>
                <td class="p-4 align-middle text-foreground">@payment.Email</td>
                <td class="p-4 align-middle text-right text-foreground">$@payment.Amount.ToString("N2")</td>
            </RowTemplate>
        </DataTable>
    </ComponentDemo>

    <ComponentDemo Title="Loading State" Code="@_loadingCode">
        <DataTable Items="Array.Empty<Payment>()" TItem="Payment" IsLoading="true" SkeletonRows="3">
            <HeaderTemplate>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Status</th>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Email</th>
                <th class="h-10 px-4 text-right align-middle font-medium text-muted-foreground">Amount</th>
            </HeaderTemplate>
            <LoadingTemplate>
                <td class="p-4"><Skeleton Class="h-4 w-16" /></td>
                <td class="p-4"><Skeleton Class="h-4 w-40" /></td>
                <td class="p-4"><Skeleton Class="h-4 w-20 ml-auto" /></td>
            </LoadingTemplate>
            <RowTemplate>
                <td></td><td></td><td></td>
            </RowTemplate>
        </DataTable>
    </ComponentDemo>

    <ComponentDemo Title="Empty State" Code="@_emptyCode">
        <DataTable Items="Array.Empty<Payment>()" TItem="Payment">
            <HeaderTemplate>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Status</th>
                <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Email</th>
                <th class="h-10 px-4 text-right align-middle font-medium text-muted-foreground">Amount</th>
            </HeaderTemplate>
            <EmptyTemplate>
                <EmptyState Title="No payments found" Description="There are no payments to display yet." />
            </EmptyTemplate>
            <RowTemplate>
                <td></td><td></td><td></td>
            </RowTemplate>
        </DataTable>
    </ComponentDemo>

    <ComponentDemo Title="Sortable Columns" Code="@_sortableCode">
        <DataTable Items="@GetSortedData()" TItem="SortableItem">
            <HeaderTemplate>
                <DataTableSortableHeader Column="name" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Name</DataTableSortableHeader>
                <DataTableSortableHeader Column="email" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Email</DataTableSortableHeader>
                <DataTableSortableHeader Column="role" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Role</DataTableSortableHeader>
            </HeaderTemplate>
            <RowTemplate>
                <td class="p-4 align-middle font-medium text-foreground">@context.Name</td>
                <td class="p-4 align-middle text-foreground">@context.Email</td>
                <td class="p-4 align-middle text-foreground">@context.Role</td>
            </RowTemplate>
        </DataTable>
    </ComponentDemo>

    <ComponentDemo Title="Row Selection" Code="@_selectionCode">
        <div class="space-y-2">
            <DataTable Items="_selectableData" TItem="SortableItem" Selectable="true" SelectedItems="@_selectedItems" SelectedItemsChanged="@(v => _selectedItems = v)">
                <HeaderTemplate>
                    <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Name</th>
                    <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Email</th>
                    <th class="h-10 px-4 text-left align-middle font-medium text-muted-foreground">Role</th>
                </HeaderTemplate>
                <RowTemplate>
                    <td class="p-4 align-middle font-medium text-foreground">@context.Name</td>
                    <td class="p-4 align-middle text-foreground">@context.Email</td>
                    <td class="p-4 align-middle text-foreground">@context.Role</td>
                </RowTemplate>
            </DataTable>
            <Text Class="text-sm text-muted-foreground">@_selectedItems.Count of @_selectableData.Count row(s) selected</Text>
        </div>
    </ComponentDemo>
</div>

<!-- API Reference -->
<div class="mt-12 space-y-6">
    <Heading Level="2" Class="text-2xl font-bold text-foreground">API Reference</Heading>

    <div class="space-y-8">
        <div>
            <Heading Level="3" Class="text-lg font-semibold text-foreground mb-3">DataTable</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SortColumn</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The currently sorted column key. Use with @@bind-SortColumn.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SortDir</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DataTable&lt;TItem&gt;.SortDirection</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Ascending</td>
                            <td class="p-3 text-muted-foreground">The current sort direction. Enum: None, Ascending, Descending.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnSort</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;(string, SortDirection)&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked with the column key and new direction when a sortable header is clicked.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Selectable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, adds a checkbox column for row selection.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SelectedItems</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">HashSet&lt;TItem&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">new()</td>
                            <td class="p-3 text-muted-foreground">The set of currently selected items. Use with @@bind-SelectedItems.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Virtualize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, enables virtualized rendering for large datasets.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ItemSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">float</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">48</td>
                            <td class="p-3 text-muted-foreground">The estimated height (px) of each row, used when Virtualize is true.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div>
            <Heading Level="3" Class="text-lg font-semibold text-foreground mb-3">DataTableSortableHeader</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Column</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">""</td>
                            <td class="p-3 text-muted-foreground">The column key this header controls sorting for.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SortColumn</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The currently active sort column, used to highlight this header.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SortDirection</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DataTable&lt;object&gt;.SortDirection</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">None</td>
                            <td class="p-3 text-muted-foreground">The current sort direction, used to render the appropriate arrow icon.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnSort</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;(string Column, SortDirection)&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked with the column key and toggled direction when clicked.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private record Payment(string Status, string Email, decimal Amount);
    private record SortableItem(string Name, string Email, string Role);

    private readonly Payment[] _payments =
    [
        new("Success", "ken@example.com", 316.00m),
        new("Success", "abe@example.com", 242.00m),
        new("Pending", "monserrat@example.com", 837.00m),
        new("Failed", "silas@example.com", 874.00m),
        new("Success", "carmella@example.com", 721.00m),
    ];

    private List<SortableItem> _sortableData =
    [
        new("Alice Johnson", "alice@example.com", "Admin"),
        new("Bob Smith", "bob@example.com", "User"),
        new("Carol White", "carol@example.com", "Editor"),
        new("Dave Brown", "dave@example.com", "User"),
    ];

    private List<SortableItem> _selectableData =
    [
        new("Alice Johnson", "alice@example.com", "Admin"),
        new("Bob Smith", "bob@example.com", "User"),
        new("Carol White", "carol@example.com", "Editor"),
        new("Dave Brown", "dave@example.com", "User"),
    ];

    private string? _sortColumn;
    private DataTable<object>.SortDirection _sortDir = DataTable<object>.SortDirection.None;
    private HashSet<SortableItem> _selectedItems = new();

    private void HandleSort((string Column, DataTable<object>.SortDirection Direction) sort)
    {
        _sortColumn = sort.Column;
        _sortDir = sort.Direction;
    }

    private IEnumerable<SortableItem> GetSortedData()
    {
        if (_sortColumn is null || _sortDir == DataTable<object>.SortDirection.None) return _sortableData;
        return _sortDir == DataTable<object>.SortDirection.Ascending
            ? _sortColumn switch
            {
                "email" => _sortableData.OrderBy(x => x.Email),
                "role"  => _sortableData.OrderBy(x => x.Role),
                _       => _sortableData.OrderBy(x => x.Name),
            }
            : _sortColumn switch
            {
                "email" => _sortableData.OrderByDescending(x => x.Email),
                "role"  => _sortableData.OrderByDescending(x => x.Role),
                _       => _sortableData.OrderByDescending(x => x.Name),
            };
    }

    private string _defaultCode = @"<DataTable Items=""_payments"" Context=""payment"">
    <HeaderTemplate>
        <th class=""h-10 px-4 text-left font-medium text-muted-foreground"">Status</th>
        <th class=""h-10 px-4 text-left font-medium text-muted-foreground"">Email</th>
        <th class=""h-10 px-4 text-right font-medium text-muted-foreground"">Amount</th>
    </HeaderTemplate>
    <RowTemplate>
        <td class=""p-4"">@payment.Status</td>
        <td class=""p-4"">@payment.Email</td>
        <td class=""p-4 text-right"">$@payment.Amount</td>
    </RowTemplate>
</DataTable>";

    private string _loadingCode = @"<DataTable Items=""Array.Empty<Item>()"" TItem=""Item"" IsLoading=""true"" SkeletonRows=""3"">
    <HeaderTemplate>...</HeaderTemplate>
    <LoadingTemplate>
        <td class=""p-4""><Skeleton Class=""h-4 w-16"" /></td>
    </LoadingTemplate>
    <RowTemplate>...</RowTemplate>
</DataTable>";

    private string _emptyCode = @"<DataTable Items=""Array.Empty<Item>()"" TItem=""Item"">
    <HeaderTemplate>...</HeaderTemplate>
    <EmptyTemplate>
        <EmptyState Title=""No data"" Description=""Nothing to display."" />
    </EmptyTemplate>
    <RowTemplate>...</RowTemplate>
</DataTable>";

    private string _sortableCode = @"<DataTable Items=""@GetSortedData()"" TItem=""Item"" SortColumn=""@_sortColumn"" SortDir=""@_sortDir"" OnSort=""@HandleSort"">
    <HeaderTemplate>
        <DataTableSortableHeader Column=""name"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""@HandleSort"">Name</DataTableSortableHeader>
        <DataTableSortableHeader Column=""email"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""@HandleSort"">Email</DataTableSortableHeader>
        <DataTableSortableHeader Column=""role"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""@HandleSort"">Role</DataTableSortableHeader>
    </HeaderTemplate>
    <RowTemplate>
        <td class=""p-4"">@context.Name</td>
        <td class=""p-4"">@context.Email</td>
        <td class=""p-4"">@context.Role</td>
    </RowTemplate>
</DataTable>

@code {
    private string? _sortColumn;
    private DataTable<Item>.SortDirection _sortDir = DataTable<Item>.SortDirection.None;

    private void HandleSort((string Column, DataTable<Item>.SortDirection Direction) sort)
    {
        _sortColumn = sort.Column;
        _sortDir = sort.Direction;
    }
}";

    private string _selectionCode = @"<DataTable Items=""_data"" TItem=""Item"" Selectable=""true"" @bind-SelectedItems=""_selectedItems"">
    <HeaderTemplate>
        <TableRow>
            <TableHead>Name</TableHead>
            <TableHead>Email</TableHead>
            <TableHead>Role</TableHead>
        </TableRow>
    </HeaderTemplate>
    <RowTemplate>
        <TableCell Class=""font-medium"">@context.Name</TableCell>
        <TableCell>@context.Email</TableCell>
        <TableCell>@context.Role</TableCell>
    </RowTemplate>
</DataTable>
<p class=""text-sm text-muted-foreground"">@_selectedItems.Count of @_data.Count row(s) selected</p>

@code {
    private HashSet<Item> _selectedItems = new();
}";
}
