@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Drop Zone" Code="@_codeFileUploadDefault">
    <FileUpload Description="PNG, JPG up to 10MB" Class="w-full max-w-sm" />
</PatternCard>

<PatternCard Label="Multiple Files" Code="@_codeFileUploadMultiple">
    <FileUpload Multiple="true" Accept=".csv,.xlsx" Description=".CSV or .XLSX files" Class="w-full max-w-sm" />
</PatternCard>
</Stack>

@code {
    private string _codeOtpDefault = @"<OtpInput @bind-Value=""_otp"" Length=""6"" />";
    
    // FileUpload
    private string _codeFileUploadDefault = @"<FileUpload Description=""PNG, JPG up to 10MB"" />";

        private string _codeFileUploadMultiple = @"<FileUpload Multiple=""true"" Accept="".csv,.xlsx"" Description="".CSV or .XLSX files"" />";
    
        // AspectRatio
        private string _codeAspectRatio = @"<AspectRatio Ratio=""16.0/9.0"" Class=""rounded-md overflow-hidden bg-muted"">
        <div class=""flex h-full w-full items-center justify-center text-sm text-muted-foreground"">
            16 / 9
        </div>
    </AspectRatio>";
}
