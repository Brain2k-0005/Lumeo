@namespace Lumeo

<button id="@SubContext.TriggerId"
        type="button"
        role="menuitem"
        tabindex="-1"
        class="@CssClass"
        data-state="@(SubContext.IsOpen ? "open" : "closed")"
        aria-haspopup="menu"
        aria-expanded="@SubContext.IsOpen.ToString().ToLower()"
        aria-controls="@SubContext.ContentId"
        disabled="@Disabled"
        @onclick="HandleClick"
        @onmouseenter="HandleMouseEnter"
        @onmouseleave="HandleMouseLeave"
        @onkeydown="HandleKeyDown"
        @attributes="AdditionalAttributes">
    @ChildContent
    <SvgGlyph Svg="@(LumeoIcons.ChevronRight)" class="ms-auto h-4 w-4" />
</button>

@inject IComponentInteropService Interop

@code {
    [CascadingParameter] public MenubarSub.MenubarSubContext SubContext { get; set; } = default!;
    [CascadingParameter] public MenubarContent.MenubarKeyNavGuard? KeyNavGuard { get; set; }
    /// <summary>The trigger's label content, rendered before the chevron-right indicator.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Disables the trigger, preventing the submenu from opening via click, hover, or ArrowRight.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Additional CSS classes merged onto the trigger's <c>&lt;button&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the trigger's <c>&lt;button&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("relative flex w-full cursor-default select-none items-center gap-2 rounded-sm px-2 py-1.5 text-sm outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed", Class);

    private async Task HandleClick()
    {
        if (Disabled) return;
        SubContext.CancelClose();
        await SubContext.SetOpen.InvokeAsync(!SubContext.IsOpen);
    }

    private async Task HandleMouseEnter()
    {
        if (Disabled) return;
        SubContext.CancelClose();
        if (!SubContext.IsOpen)
        {
            await SubContext.SetOpen.InvokeAsync(true);
        }
    }

    private void HandleMouseLeave()
    {
        if (!SubContext.IsOpen) return;
        SubContext.ScheduleClose();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter and Space are deliberately NOT handled here: this is a native
        // <button>, so the browser synthesizes a click for them and HandleClick
        // performs the toggle. Opening from keydown as well made keyboard
        // activation a net no-op (keydown opened, the synthesized click
        // immediately toggled the submenu closed again).
        switch (e.Key)
        {
            case "ArrowRight":
                // Mark the key as consumed so the parent MenubarContent does not
                // also treat it as "move to the next menubar menu", which would
                // unmount the submenu that just opened.
                if (KeyNavGuard is not null) KeyNavGuard.Consumed = true;
                SubContext.CancelClose();
                if (!SubContext.IsOpen)
                {
                    await SubContext.SetOpen.InvokeAsync(true);
                }
                _ = InvokeAsync(async () =>
                {
                    await Task.Delay(20);
                    try { await Interop.FocusMenuItemByIndex(SubContext.ContentId, 0); }
                    catch (JSDisconnectedException) { }
                });
                break;
        }
    }
}
