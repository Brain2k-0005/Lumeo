            <DrawerTitle>Snap Drawer</DrawerTitle>
            <DrawerDescription>Drag the handle to snap between 40%, 75%, and full height.</DrawerDescription>
        </DrawerHeader>
        <Stack Gap=""2"" Class=""p-4"">
            @* …content… *@
        </Stack>
        <DrawerFooter>
            <DrawerClose><Button Class=""w-full"">Close</Button></DrawerClose>
        </DrawerFooter>
    </DrawerContent>
</Drawer>

@code {
    private bool _snapOpen;
    private int _snapIndex = 1;                      // open at 75%
    private double[] _snapPoints = { 0.4, 0.75, 1.0 };
}";

    private Task GuardDrawerClose(Lumeo.DismissEventArgs e)
    {
        if (e.Reason is "escape" or "outside" or "swipe" && _guardDirty)
            e.Cancel = true;
        return Task.CompletedTask;
    }

    private string _onBeforeCloseCode = @"<Drawer @bind-Open=""_open"" OnBeforeClose=""GuardClose"">
    <DrawerContent>
        <DrawerHeader>
            <DrawerTitle>New entry</DrawerTitle>
        </DrawerHeader>
        <Textarea @bind-Value=""_note"" @oninput=""() => _dirty = true"" />
    </DrawerContent>
</Drawer>

@code {
    bool _open;
    bool _dirty;
    string? _note;

    Task GuardClose(DismissEventArgs e)
    {
        // Mobile gestures are easy to trigger by accident — guard them while dirty.
        if (e.Reason is ""escape"" or ""outside"" or ""swipe"" && _dirty)
            e.Cancel = true;
        return Task.CompletedTask;
    }
}";

    // Interactive: Side
    private string _drawerSideSel = "Bottom";
    private Lumeo.Side _activeSide => Enum.Parse<Lumeo.Side>(_drawerSideSel);
    private List<Segmented.SegmentedOption> _drawerSideOptions = new()
    {
        new() { Label = "Top", Value = "Top" },
        new() { Label = "Right", Value = "Right" },
        new() { Label = "Bottom", Value = "Bottom" },
        new() { Label = "Left", Value = "Left" },
    };
    private string _sideInteractiveCode = @"<Segmented @bind-Value=""_drawerSideSel"" Options=""_drawerSideOptions"" />
<Drawer @bind-Open=""_open"">
    <DrawerTrigger>
        <Button Variant=""Button.ButtonVariant.Outline"">Open Drawer (@_drawerSideSel)</Button>
    </DrawerTrigger>
    <DrawerContent Side=""@_activeSide"">
        <DrawerHeader>
            <DrawerTitle>@_drawerSideSel Drawer</DrawerTitle>
            <DrawerDescription>Slides in from the @_drawerSideSel.ToLower().</DrawerDescription>
        </DrawerHeader>
        <DrawerFooter>
            <DrawerClose><Button Class=""w-full"">Close</Button></DrawerClose>
        </DrawerFooter>
    </DrawerContent>
</Drawer>

@code {
    private string _drawerSideSel = ""Bottom"";
    private Lumeo.Side _activeSide => Enum.Parse<Lumeo.Side>(_drawerSideSel);
    private List<Segmented.SegmentedOption> _drawerSideOptions = new()
    {
        new() { Label = ""Top"", Value = ""Top"" },
        new() { Label = ""Right"", Value = ""Right"" },
        new() { Label = ""Bottom"", Value = ""Bottom"" },
        new() { Label = ""Left"", Value = ""Left"" },
    };
}";
    private string? _filterCategory;
    private string? _filterSort = "popular";
    private int _goal = 350;

    private void Increase() => _goal = Math.Min(1000, _goal + 10);
    private void Decrease() => _goal = Math.Max(100, _goal - 10);

    private string _preventCloseCode = @"<Drawer @bind-Open=""_preventDrawerOpen"">
