@namespace Lumeo

@* Groups related menu items under a single role="group" (shadcn MenubarGroup).
   Mirrors DropdownMenuGroup. Pair with a MenubarLabel for a titled section. *@
<div role="group" aria-label="@AriaLabel" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The grouped <see cref="MenubarItem"/> (or similar) elements.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Accessible name for the group's <c>role="group"</c> element, announced by assistive technology. Pair with a visible <see cref="MenubarLabel"/> when a titled section is desired.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>Additional CSS classes merged onto the group <c>&lt;div&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the group <c>&lt;div&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge(Class);
}
