@page "/register"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject DemoAuthenticationStateProvider Auth
@inject NavigationManager Nav
@inject ToastService Toast

<PageTitle>Create your account — MyApp</PageTitle>

<Card Class="w-full max-w-md border-border/60 shadow-lg">
    <CardContent Class="px-8 pt-10 pb-8">
        <Stack Gap="6">
            <Stack Gap="4" Class="items-center text-center">
                <Flex Class="h-12 w-12 items-center justify-center rounded-[var(--radius-lg)] bg-primary text-primary-foreground shadow-sm">
                    <SvgGlyph Svg="@(LumeoIcons.Sparkles)" class="h-6 w-6" />
                </Flex>
                <Stack Gap="1.5">
                    <Heading Level="1" Class="text-2xl font-bold tracking-tight">Create your account</Heading>
                    <Lumeo.Text Color="muted" Size="sm">Start your 14-day free trial — no credit card required</Lumeo.Text>
                </Stack>
            </Stack>

            @if (_error is not null)
            {
                <Alert Variant="Alert.AlertVariant.Destructive">
                    <Flex Align="center" Gap="2">
                        <SvgGlyph Svg="@(LumeoIcons.CircleAlert)" class="h-4 w-4 shrink-0" />
                        <Lumeo.Text Size="sm">@_error</Lumeo.Text>
                    </Flex>
                </Alert>
            }

            <Stack Gap="4">
                <Grid Class="grid-cols-2 gap-3">
                    <Stack Gap="2">
                        <Label for="reg-first">First name</Label>
                        <Input id="reg-first" @bind-Value="_firstName" placeholder="Ada" />
                    </Stack>
                    <Stack Gap="2">
                        <Label for="reg-last">Last name</Label>
                        <Input id="reg-last" @bind-Value="_lastName" placeholder="Lovelace" />
                    </Stack>
                </Grid>

                <Stack Gap="2">
                    <Label for="reg-email">Work email</Label>
                    <Lumeo.Input id="reg-email" type="email" placeholder="you@company.com" @bind-Value="_email">
                        <Prefix><SvgGlyph Svg="@(LumeoIcons.Mail)" class="h-4 w-4 text-muted-foreground" /></Prefix>
                    </Lumeo.Input>
                </Stack>

                <Stack Gap="2">
                    <Label for="reg-pass">Password</Label>
                    <PasswordInput @bind-Value="_password" Placeholder="At least 6 characters" ShowStrength="true" />
                </Stack>

                <Flex Align="start" Gap="2">
                    <Checkbox @bind-Checked="_terms" Class="mt-0.5" />
                    <Lumeo.Text Size="sm" Color="muted">
                        I agree to the
                        <Lumeo.Link Href="#" Class="text-primary hover:underline">Terms of Service</Lumeo.Link>
                        and
                        <Lumeo.Link Href="#" Class="text-primary hover:underline">Privacy Policy</Lumeo.Link>.
                    </Lumeo.Text>
                </Flex>

                <Button Class="w-full" IsLoading="@_loading" Disabled="@(!_terms)" OnClick="HandleRegister">
                    @if (!_loading)
                    {
                        <SvgGlyph Svg="@(LumeoIcons.UserPlus)" class="h-4 w-4" />
                    }
                    Create account
                </Button>
            </Stack>

            <Lumeo.Text Size="sm" Color="muted" Align="center">
                Already have an account?
                <Lumeo.Link Href="login" Class="text-primary hover:underline font-medium ml-1">Sign in</Lumeo.Link>
            </Lumeo.Text>
        </Stack>
    </CardContent>
</Card>

@code {
    private string _firstName = string.Empty;
    private string _lastName = string.Empty;
    private string _email = string.Empty;
    private string _password = string.Empty;
    private bool _terms;
    private bool _loading;
    private string? _error;

    private async Task HandleRegister()
    {
        _error = null;
        _loading = true;
        await Task.Delay(600);
        var name = $"{_firstName} {_lastName}".Trim();
        var ok = await Auth.RegisterAsync(name, _email, _password);
        _loading = false;

        if (!ok)
        {
            _error = "Enter an email and a password with at least 6 characters.";
            return;
        }

        Toast.Success("Account created", $"Welcome aboard{(string.IsNullOrWhiteSpace(_firstName) ? "" : $", {_firstName}")}!");
        Nav.NavigateTo("");
    }
}
