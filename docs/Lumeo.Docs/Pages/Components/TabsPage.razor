@page "/components/tabs"

<PageTitle>Tabs — Lumeo</PageTitle>

<PageHeader Title="Tabs" Description="A set of layered sections of content, known as tab panels, that are displayed one at a time." />

<div class="mt-6 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Switch between different views or categories within the same context.</li>
        <li>Organize related content like account settings, security, and notifications.</li>
        <li>Reduce page length by showing one content section at a time.</li>
    </ul>
</div>

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="md" Center="false">
            <Tabs ActiveValue="account">
                <TabsList>
                    <TabsTrigger Value="account">Account</TabsTrigger>
                    <TabsTrigger Value="password">Password</TabsTrigger>
                </TabsList>
                <TabsContent Value="account">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Account</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Make changes to your account here. Click save when you're done.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="4">
                                <FormField Label="Name">
                                    <Input Value="Pedro Duarte" />
                                </FormField>
                                <FormField Label="Username">
                                    <Input Value="@("@peduarte")" />
                                </FormField>
                            </Stack>
                        </CardContent>
                        <CardFooter>
                            <Button>Save changes</Button>
                        </CardFooter>
                    </Card>
                </TabsContent>
                <TabsContent Value="password">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Password</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Change your password here. After saving, you'll be logged out.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="4">
                                <FormField Label="Current password">
                                    <Input type="password" />
                                </FormField>
                                <FormField Label="New password">
                                    <Input type="password" />
                                </FormField>
                            </Stack>
                        </CardContent>
                        <CardFooter>
                            <Button>Save password</Button>
                        </CardFooter>
                    </Card>
                </TabsContent>
            </Tabs>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Notifications" Code="@_notifCode">
        <Container MaxWidth="md" Center="false">
            <Tabs ActiveValue="all">
                <TabsList>
                    <TabsTrigger Value="all">All</TabsTrigger>
                    <TabsTrigger Value="unread">Unread</TabsTrigger>
                    <TabsTrigger Value="archived">Archived</TabsTrigger>
                </TabsList>
                <TabsContent Value="all">
                    <Stack Gap="2" Class="pt-2">
                        @foreach (var n in _notifications)
                        {
                            <Flex Gap="3" Align="start" Class="p-3 rounded-lg border bg-card">
                                <Text As="span" Class="@($"mt-1.5 h-2 w-2 rounded-full shrink-0 {(n.Unread ? "bg-primary" : "bg-muted")}")"></Text>
                                <Stack Gap="0">
                                    <Lumeo.Text Size="sm" Weight="medium">@n.Title</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">@n.Time</Lumeo.Text>
                                </Stack>
                            </Flex>
                        }
                    </Stack>
                </TabsContent>
                <TabsContent Value="unread">
                    <Stack Gap="2" Class="pt-2">
                        @foreach (var n in _notifications.Where(x => x.Unread))
                        {
                            <Flex Gap="3" Align="start" Class="p-3 rounded-lg border bg-card">
                                <Lumeo.Text As="span" Class="mt-1.5 h-2 w-2 rounded-full shrink-0 bg-primary"></Lumeo.Text>
                                <Stack Gap="0">
                                    <Lumeo.Text Size="sm" Weight="medium">@n.Title</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">@n.Time</Lumeo.Text>
                                </Stack>
                            </Flex>
                        }
                    </Stack>
                </TabsContent>
                <TabsContent Value="archived">
                    <Lumeo.Text Size="sm" Color="muted" Class="p-4 text-center">No archived notifications.</Lumeo.Text>
                </TabsContent>
            </Tabs>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Vertical Tabs" Code="@_verticalCode">
        <Tabs Orientation="Tabs.TabsOrientation.Vertical" @bind-ActiveValue="_verticalTab" Class="flex gap-4">
            <TabsList>
                <TabsTrigger Value="account">Account</TabsTrigger>
                <TabsTrigger Value="security">Security</TabsTrigger>
                <TabsTrigger Value="notifications">Notifications</TabsTrigger>
            </TabsList>
            <Stack Class="flex-1">
                <TabsContent Value="account">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Account</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Manage your account settings.</Lumeo.Text>
                        </CardHeader>
                        <CardContent><Lumeo.Text Size="sm" Color="muted">Account settings content goes here.</Lumeo.Text></CardContent>
                    </Card>
                </TabsContent>
                <TabsContent Value="security">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Security</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Update your security preferences.</Lumeo.Text>
                        </CardHeader>
                        <CardContent><Lumeo.Text Size="sm" Color="muted">Security settings content goes here.</Lumeo.Text></CardContent>
                    </Card>
                </TabsContent>
                <TabsContent Value="notifications">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Notifications</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Configure notification preferences.</Lumeo.Text>
                        </CardHeader>
                        <CardContent><Lumeo.Text Size="sm" Color="muted">Notification settings content goes here.</Lumeo.Text></CardContent>
                    </Card>
                </TabsContent>
            </Stack>
        </Tabs>
    </ComponentDemo>

    <ComponentDemo Title="Simple" Code="@_simpleCode">
        <Container MaxWidth="md" Center="false">
            <Tabs ActiveValue="overview">
                <TabsList>
                    <TabsTrigger Value="overview">Overview</TabsTrigger>
                    <TabsTrigger Value="analytics">Analytics</TabsTrigger>
                    <TabsTrigger Value="reports">Reports</TabsTrigger>
                </TabsList>
                <TabsContent Value="overview">
                    <Lumeo.Text Size="sm" Color="muted" Class="p-4">Overview content goes here. View a summary of your data.</Lumeo.Text>
                </TabsContent>
                <TabsContent Value="analytics">
                    <Lumeo.Text Size="sm" Color="muted" Class="p-4">Analytics content goes here. Dive deeper into the numbers.</Lumeo.Text>
                </TabsContent>
                <TabsContent Value="reports">
                    <Lumeo.Text Size="sm" Color="muted" Class="p-4">Reports content goes here. Download and share your reports.</Lumeo.Text>
                </TabsContent>
            </Tabs>
        </Container>
    </ComponentDemo>
</Stack>

<div class="mt-12">
    <Heading Id="keyboard-interactions" Level="2" Class="scroll-mt-20">Keyboard Interactions</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Key</TableHead>
                    <TableHead>Action</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell><Kbd>ArrowLeft</Kbd></TableCell><TableCell>Moves focus to the previous tab trigger (horizontal orientation).</TableCell></TableRow>
                <TableRow><TableCell><Kbd>ArrowRight</Kbd></TableCell><TableCell>Moves focus to the next tab trigger (horizontal orientation).</TableCell></TableRow>
                <TableRow><TableCell><Kbd>ArrowUp</Kbd></TableCell><TableCell>Moves focus to the previous tab trigger (vertical orientation).</TableCell></TableRow>
                <TableRow><TableCell><Kbd>ArrowDown</Kbd></TableCell><TableCell>Moves focus to the next tab trigger (vertical orientation).</TableCell></TableRow>
                <TableRow><TableCell><Kbd>Home</Kbd></TableCell><TableCell>Moves focus to the first tab trigger.</TableCell></TableRow>
                <TableRow><TableCell><Kbd>End</Kbd></TableCell><TableCell>Moves focus to the last tab trigger.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Tabs</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ActiveValue</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">""</td>
                            <td class="p-3 text-muted-foreground">The value of the currently active tab. Use with @@bind-ActiveValue for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ActiveValueChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the active tab changes.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Orientation</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">TabsOrientation</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Horizontal</td>
                            <td class="p-3 text-muted-foreground">Layout direction of the tabs. Values: Tabs.TabsOrientation.Horizontal, Tabs.TabsOrientation.Vertical.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">TabsTrigger</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">""</td>
                            <td class="p-3 text-muted-foreground">The value this tab trigger activates. Must match the Value of the corresponding TabsContent. Required.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">TabsContent</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">""</td>
                            <td class="p-3 text-muted-foreground">The value of this tab panel. Renders only when it matches the parent Tabs ActiveValue. Required.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">TabsList</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Container for tab triggers with tablist role. Accepts Class and AdditionalAttributes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/accordion" class="text-primary hover:underline">Accordion</a> — Use when multiple sections can be expanded at once in a vertical layout.</li>
        <li><a href="/components/navigation-menu" class="text-primary hover:underline">NavigationMenu</a> — Use for top-level site navigation rather than in-page content switching.</li>
        <li><a href="/components/toggle-group" class="text-primary hover:underline">ToggleGroup</a> — A segmented control for switching between a small set of views.</li>
    </ul>
</div>

