@namespace Lumeo
@implements IAsyncDisposable
@inject ComponentInteropService Interop

<CascadingValue Value="_context" IsFixed="true">
    <div id="@_mapId"
         role="application"
         aria-label="Map"
         class="@RootClass"
         style="@RootStyle"
         @attributes="AdditionalAttributes">
    </div>
    @* Markers + shapes register via the cascading context but do not render
       DOM themselves — Leaflet draws them on the canvas. We still walk the
       child content so the OnInitialized / OnParametersSet hooks fire. *@
    <div style="display:none">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public (double Lat, double Lon) Center { get; set; } = (51.0, 10.4);
    [Parameter] public EventCallback<(double Lat, double Lon)> CenterChanged { get; set; }

    [Parameter] public int Zoom { get; set; } = 5;
    [Parameter] public EventCallback<int> ZoomChanged { get; set; }

    [Parameter] public string Height { get; set; } = "400px";

    /// <summary>Accepts a CARTO style preset (<c>Positron</c>, <c>DarkMatter</c>,
    /// <c>Voyager</c>), a legacy raster name (<c>OpenStreetMap</c>,
    /// <c>CartoLight</c>, <c>CartoDark</c>, <c>Satellite</c>, <c>Terrain</c>) —
    /// kept as aliases pointing at the closest GL vector style — or a raw
    /// MapLibre <c>style.json</c> URL. <c>Auto</c> (the default) picks Positron
    /// or DarkMatter based on the host page's theme, matching mapcn.dev.</summary>
    [Parameter] public string TileLayer { get; set; } = "Auto";

    /// <summary>When set, renders a chip-style switcher in the top-right that
    /// lets the user pick between presets (or custom <c>{ name, url }</c> records).</summary>
    [Parameter] public string[]? Layers { get; set; }

    [Parameter] public bool ZoomControl { get; set; } = true;
    [Parameter] public bool Attribution { get; set; } = true;
    [Parameter] public bool ScrollWheelZoom { get; set; } = true;

    /// <summary>Marker clustering via leaflet.markercluster. CDN-loaded on
    /// first use; falls back to plain markers if the script fails to fetch.</summary>
    [Parameter] public bool Cluster { get; set; }

    /// <summary>Adds a "My location" button that geolocates the user.</summary>
    [Parameter] public bool Geolocate { get; set; }

    /// <summary>Adds a fullscreen toggle button.</summary>
    [Parameter] public bool Fullscreen { get; set; }

    /// <summary>Adds a metric scale bar in the bottom-left corner.</summary>
    [Parameter] public bool Scale { get; set; }

    /// <summary>Adds a Nominatim-backed search bar in the top-left.</summary>
    [Parameter] public bool Search { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<(double Lat, double Lon)> OnClick { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _mapId = $"lumeo-map-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<Map>? _selfRef;
    private MapContext _context = null!;
    private readonly List<MapMarker> _markers = new();
    private readonly Dictionary<object, MapShape> _shapes = new();
    private bool _initialized;
    private (double Lat, double Lon) _lastCenter;
    private int _lastZoom;
    private string _lastMarkerJson = "[]";
    private string _lastShapeJson = "[]";

    private string RootClass => $"lumeo-map relative {Class}".Trim();
    private string RootStyle => $"width: 100%; height: {Height};";

    protected override void OnInitialized()
    {
        _context = new MapContext(this);
        _lastCenter = Center;
        _lastZoom = Zoom;
    }

    internal void RegisterMarker(MapMarker marker)
    {
        if (!_markers.Contains(marker)) _markers.Add(marker);
        if (_initialized) _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void UnregisterMarker(MapMarker marker)
    {
        if (_markers.Remove(marker) && _initialized)
            _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void NotifyMarkerChanged(MapMarker marker)
    {
        if (_initialized) _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void RegisterShape(object owner, MapShape shape)
    {
        _shapes[owner] = shape;
        if (_initialized) _ = InvokeAsync(SyncShapesAsync);
    }

    internal void UnregisterShape(object owner)
    {
        if (_shapes.Remove(owner) && _initialized)
            _ = InvokeAsync(SyncShapesAsync);
    }

    internal void NotifyShapeChanged(object owner, MapShape shape)
    {
        _shapes[owner] = shape;
        if (_initialized) _ = InvokeAsync(SyncShapesAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await Interop.ImportModuleAsync("./_content/Lumeo.Maps/js/map.js");
            _selfRef = DotNetObjectReference.Create(this);

            var options = new
            {
                lat = Center.Lat,
                lon = Center.Lon,
                zoom = Zoom,
                tileLayer = TileLayer,
                layers = Layers,
                zoomControl = ZoomControl,
                attribution = Attribution,
                scrollWheelZoom = ScrollWheelZoom,
                cluster = Cluster,
                geolocate = Geolocate,
                fullscreen = Fullscreen,
                scale = Scale,
                search = Search,
            };

            try
            {
                await _module.InvokeVoidAsync("init", _mapId, options, _selfRef);
                _initialized = true;
                await SyncMarkersAsync();
                await SyncShapesAsync();
            }
            catch (JSDisconnectedException) { }
            return;
        }

        if (!_initialized || _module is null) return;

        if (Center != _lastCenter || Zoom != _lastZoom)
        {
            _lastCenter = Center;
            _lastZoom = Zoom;
            try
            {
                await _module.InvokeVoidAsync("setCenter", _mapId, Center.Lat, Center.Lon, Zoom);
            }
            catch (JSDisconnectedException) { }
        }
    }

    private async Task SyncMarkersAsync()
    {
        if (_module is null || !_initialized) return;
        var payload = _markers.Select((m, i) => new
        {
            id = i,
            lat = m.Lat,
            lon = m.Lon,
            title = m.Title,
            iconUrl = m.IconUrl,
            variant = m.Variant,
            color = m.Color,
            label = m.Label,
            iconHostId = m.HasIcon ? m.IconHostId : null,
            popupHtml = m.HasRichPopup ? null : m.GetPopupHtml(),
            popupHostId = m.HasRichPopup ? m.PopupHostId : null,
            hasClick = m.OnClick.HasDelegate,
        }).ToArray();

        var json = System.Text.Json.JsonSerializer.Serialize(payload);
        if (json == _lastMarkerJson) return;
        _lastMarkerJson = json;

        try
        {
            await _module.InvokeVoidAsync("setMarkers", _mapId, payload);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task SyncShapesAsync()
    {
        if (_module is null || !_initialized) return;
        var payload = _shapes.Values.ToArray();
        var json = System.Text.Json.JsonSerializer.Serialize(payload);
        if (json == _lastShapeJson) return;
        _lastShapeJson = json;

        try
        {
            await _module.InvokeVoidAsync("setShapes", _mapId, payload);
        }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Imperatively re-center the map. Useful for parent components
    /// driving the view from non-parameter state (e.g. a "Fit to results" button).</summary>
    public async Task FitBoundsAsync(double south, double west, double north, double east, int paddingPx = 30)
    {
        if (_module is null || !_initialized) return;
        try
        {
            await _module.InvokeVoidAsync("fitBounds", _mapId, south, west, north, east, paddingPx);
        }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public async Task OnMapClick(double lat, double lon)
    {
        if (OnClick.HasDelegate) await OnClick.InvokeAsync((lat, lon));
    }

    [JSInvokable]
    public async Task OnViewChanged(double lat, double lon, int zoom)
    {
        var newCenter = (lat, lon);
        if (newCenter != Center)
        {
            Center = newCenter;
            _lastCenter = newCenter;
            if (CenterChanged.HasDelegate) await CenterChanged.InvokeAsync(newCenter);
        }
        if (zoom != Zoom)
        {
            Zoom = zoom;
            _lastZoom = zoom;
            if (ZoomChanged.HasDelegate) await ZoomChanged.InvokeAsync(zoom);
        }
    }

    [JSInvokable]
    public async Task OnMarkerClick(int markerId)
    {
        if (markerId < 0 || markerId >= _markers.Count) return;
        var marker = _markers[markerId];
        if (marker.OnClick.HasDelegate) await marker.OnClick.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroy", _mapId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
        _selfRef?.Dispose();
    }

    /// <summary>Cascading context passed to <see cref="MapMarker"/> + shape
    /// children so they can register themselves with the parent <see cref="Map"/>.</summary>
    public record MapContext(Map Owner);
}
