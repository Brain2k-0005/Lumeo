    private string _renderModeCode = @"@* Lazy: a panel renders the first time its tab is shown,
   then stays in the DOM (hidden) — its state survives switches.
   Active (default): only the active panel exists; switching unmounts it.
   Eager: every panel renders up-front, inactive ones hidden. *@
<Tabs @bind-ActiveValue=""_tab"" RenderMode=""Tabs.TabsRenderMode.Lazy"">
    <TabsList>
        <TabsTrigger Value=""form"">Form</TabsTrigger>
        <TabsTrigger Value=""preview"">Preview</TabsTrigger>
    </TabsList>
    <TabsContent Value=""form"">
        <Input Placeholder=""Survives a tab switch"" />
    </TabsContent>
    <TabsContent Value=""preview"">...</TabsContent>

    @* Or pin just one panel, leaving the rest on the light default: *@
    @* <TabsContent Value=""form"" ForceMount=""true"">...</TabsContent> *@
</Tabs>";

