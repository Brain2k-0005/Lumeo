    private List<string> _shortCategories = new() { "Q1", "Q2", "Q3", "Q4" };

    private List<LineChart.ChartSeriesData> _series = new()
    {
        new() { Name = "Revenue",  Values = new() { 18200, 21500, 19800, 27300, 31600, 44800, 40100, 37700, 42600, 48400, 51900, 60200 } },
