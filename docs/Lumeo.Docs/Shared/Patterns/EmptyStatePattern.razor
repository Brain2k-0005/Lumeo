@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeEmptyStateDefault">
    <EmptyState Title="No results" Description="Try adjusting your search or filter." Class="w-full max-w-sm">
        <IconContent>
            <DynamicIcon Name="SearchX" Class="h-8 w-8" />
        </IconContent>
    </EmptyState>
</PatternCard>

<PatternCard Label="With Action" Code="@_codeEmptyStateAction">
    <EmptyState Title="No projects yet" Description="Create your first project to get started." Class="w-full max-w-sm">
        <IconContent>
            <DynamicIcon Name="FolderOpen" Class="h-8 w-8" />
        </IconContent>
        <Action>
            <Button>
                <DynamicIcon Name="Plus" Class="mr-2 h-4 w-4" />
                New Project
            </Button>
        </Action>
    </EmptyState>
</PatternCard>
</Stack>

@code {
        private string _codeEmptyStateDefault = @"<EmptyState Title=""No results"" Description=""Try adjusting your search or filter."">
        <IconContent>
            <Blazicon Svg=""Lucide.SearchX"" class=""h-8 w-8"" />
        </IconContent>
    </EmptyState>";

        private string _codeEmptyStateAction = @"<EmptyState Title=""No projects yet"" Description=""Create your first project to get started."">
        <IconContent>
            <Blazicon Svg=""Lucide.FolderOpen"" class=""h-8 w-8"" />
        </IconContent>
        <Action>
            <Button>
                <Blazicon Svg=""Lucide.Plus"" class=""mr-2 h-4 w-4"" />
                New Project
            </Button>
        </Action>
    </EmptyState>";
}
