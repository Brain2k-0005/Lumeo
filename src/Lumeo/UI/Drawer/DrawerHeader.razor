@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The header's content, typically a <see cref="DrawerTitle"/> and <see cref="DrawerDescription"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the header element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the header element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // shrink-0 (feedback wave, alongside DrawerContent's own overflow-y-auto
    // fix): the header is a flex item of the panel's flex-col — pinning it so
    // it never gets squeezed by the flex-shrink algorithm if a future content
    // change puts height pressure back on the panel (defensive; the panel
    // itself scrolling is what actually keeps the body/footer reachable).
    private string CssClass => Cx.Merge("shrink-0 grid gap-1.5 p-4 text-center sm:text-start", Class);
}
