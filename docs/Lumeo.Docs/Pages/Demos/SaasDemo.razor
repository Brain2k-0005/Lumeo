    };

    // Charts
    private readonly List<string> _trendMonths = new() { "Jul", "Aug", "Sep", "Oct", "Nov", "Dec", "Jan", "Feb", "Mar", "Apr", "May", "Jun" };
    private readonly List<AreaChart.ChartSeriesData> _trendSeries = new()
    {
        new() { Name = "MRR", Values = new() { 31200, 33100, 34800, 36900, 38400, 39800, 41200, 43100, 44500, 45900, 47100, 48231 } },
    };
    private readonly List<string> _planQuarters = new() { "Q1", "Q2", "Q3", "Q4" };
    private readonly List<BarChart.ChartSeriesData> _planSeries = new()
    {
        new() { Name = "Starter",    Values = new() { 42, 55, 61, 74 } },
