@page "/components/form-field"

<PageTitle>Form Field — Lumeo</PageTitle>

<PageHeader Title="Form Field" Description="A composite form field that wraps an input with a label, help text, and error messaging." />

<Stack Gap="8">
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Label="Email">
                <Input Type="email" placeholder="you@example.com" />
            </FormField>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Help Text" Code="@_helpCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Label="Username" HelpText="This will be your public display name.">
                <Input placeholder="johndoe" />
            </FormField>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Error" Code="@_errorCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Label="Password" Error="Password must be at least 8 characters.">
                <Input Type="password" placeholder="Enter password" />
            </FormField>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Required" Code="@_requiredCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Label="Full Name" Required="true">
                <Input placeholder="Jane Doe" />
            </FormField>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Horizontal Layout" Code="@_horizontalCode">
        <Container MaxWidth="lg" Center="false" Padding="">
            <Stack Gap="4">
                <FormField Label="First Name" Orientation="FormField.FormFieldOrientation.Horizontal" LabelWidth="120px">
                    <Input placeholder="Jane" />
                </FormField>
                <FormField Label="Last Name" Orientation="FormField.FormFieldOrientation.Horizontal" LabelWidth="120px">
                    <Input placeholder="Doe" />
                </FormField>
                <FormField Label="Email" Orientation="FormField.FormFieldOrientation.Horizontal" LabelWidth="120px" HelpText="We'll never share your email.">
                    <Input Type="email" placeholder="jane@example.com" />
                </FormField>
            </Stack>
        </Container>
    </ComponentDemo>

    <!-- API Reference -->
    <Stack Gap="4">
        <Heading Level="2">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Label</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>The label text displayed above or beside the input.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">HelpText</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Helper text shown below the input. Hidden when an error is present.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Error</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Error message displayed below the input in red.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Required</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Shows a red asterisk next to the label.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Orientation</TableCell>
                    <TableCell Class="font-mono text-xs">FormFieldOrientation</TableCell>
                    <TableCell Class="font-mono text-xs">Vertical</TableCell>
                    <TableCell>Layout direction. Vertical stacks label above input; Horizontal places them side by side.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">LabelWidth</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Fixed width for the label in horizontal orientation (e.g. "120px").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Name</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Field name passed to the cascading FormFieldContext.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </Stack>
</Stack>

@code {
    private string _basicCode = @"<FormField Label=""Email"">
    <Input Type=""email"" placeholder=""you@example.com"" />
</FormField>";

    private string _helpCode = @"<FormField Label=""Username"" HelpText=""This will be your public display name."">
    <Input placeholder=""johndoe"" />
</FormField>";

    private string _errorCode = @"<FormField Label=""Password"" Error=""Password must be at least 8 characters."">
    <Input Type=""password"" placeholder=""Enter password"" />
</FormField>";

    private string _requiredCode = @"<FormField Label=""Full Name"" Required=""true"">
    <Input placeholder=""Jane Doe"" />
</FormField>";

    private string _horizontalCode = @"<FormField Label=""First Name"" Orientation=""FormField.FormFieldOrientation.Horizontal"" LabelWidth=""120px"">
    <Input placeholder=""Jane"" />
</FormField>";
}
