@page "/components/map"
@inject HttpClient Http

<PageTitle>Map — Lumeo</PageTitle>

<PageHeader Title="Map"
            Description="Interactive geographic map with declarative markers. Powered by MapLibre GL — open-source, no API key required. Ships with named tile presets including Auto, which follows the site theme automatically, and accepts raw style.json URLs." />

<InstallUsage Component="Map" Package="Lumeo.Maps" />

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <ChildContent>
        <strong>Satellite package.</strong> The Map lives in
        <code>Lumeo.Maps</code> — install it alongside the core <code>Lumeo</code>
        package. MapLibre GL and its stylesheet are loaded on demand from unpkg the
        first time a Map mounts; no npm build step is required for consumers.
    </ChildContent>
</Alert>

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Locating addresses, stores, or events on a slippy map</li>
        <li>Visualizing point data sets with up to a few hundred markers</li>
        <li>Pickers that capture a lat/lon from a click anywhere on the map</li>
        <li>Read-only embeds in dashboards, contact pages, and event details</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    @* Demo 1: Basic — info chip top-left (safe zone, no MapLibre controls there) *@
    @* TileLayer="Auto" (the default) picks Positron or DarkMatter based on the site theme. Toggle the theme switch to see tiles swap. *@
    <ComponentDemo Title="Basic (Auto theme)" Code="@_basicCode">
        <LazyRender Height="400px">
            <Map @bind-Center="_center"
                 @bind-Zoom="_zoom"
                 Height="400px"
                 TileLayer="Auto">
                <Overlay>
                    <MapInfoChip Position="top-left">
                        @_center.Lat.ToString("F3"), @_center.Lon.ToString("F3") — zoom @_zoom
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 2: Marker variants (replaces both "Multiple markers" and "Marker variants") *@
    <ComponentDemo Title="Marker variants" Code="@_variantsCode">
        <LazyRender Height="450px">
            <Map Center="(50.5, 10.5)" Zoom="5" Height="450px">
                <ChildContent>
                    <MapMarker Lat="48.137" Lon="11.575" Title="Default (primary)" Label="Munich" />
                    <MapMarker Lat="52.520" Lon="13.405" Title="Outline" Variant="Outline" Label="Berlin" LabelHoverOnly="true" />
                    <MapMarker Lat="53.551" Lon="9.993"  Title="Pin" Variant="Pin" Color="red" Label="Hamburg" LabelHoverOnly="true" />
                    <MapMarker Lat="50.937" Lon="6.960"  Title="Dot" Variant="Dot" Color="green" Label="Cologne" LabelHoverOnly="true" />
                    <MapMarker Lat="48.783" Lon="9.183"  Title="Numbered (custom icon)" Label="Stuttgart">
                        <Icon><span>A</span></Icon>
                    </MapMarker>
                    <MapMarker Lat="51.339" Lon="12.373" Title="Yellow warning" Color="yellow" />
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        Permanent label on Munich · hover others for label
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 3: Rich popup *@
    <ComponentDemo Title="Rich popup content (RenderFragment)" Code="@_richPopupCode">
        <LazyRender Height="420px">
            <Map Center="(48.137, 11.575)" Zoom="11" Height="420px" TileLayer="CartoLight">
                <ChildContent>
                    <MapMarker Lat="48.137" Lon="11.575" Title="Marienplatz" Color="red">
                        <Popup>
                            <div class="space-y-2 min-w-[220px]">
                                <div class="font-semibold text-sm">Marienplatz</div>
                                <p class="text-xs text-muted-foreground m-0">
                                    Munich's central square, home of the Neues Rathaus and the
                                    famous Glockenspiel.
                                </p>
                                <div class="flex gap-2 pt-1">
                                    <Badge Variant="Badge.BadgeVariant.Secondary">Historic</Badge>
                                    <Badge Variant="Badge.BadgeVariant.Outline">Free</Badge>
                                </div>
                            </div>
                        </Popup>
                    </MapMarker>
                </ChildContent>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 4: Click-to-pick *@
    <ComponentDemo Title="Click-to-pick coordinate" Code="@_clickCode">
        <LazyRender Height="400px">
            <Map Center="_pickedCenter"
                 Zoom="4"
                 Height="400px"
                 OnClick="HandleMapClick">
                <ChildContent>
                    @if (_pickedPoint is { } p)
                    {
                        <MapMarker Lat="p.Lat" Lon="p.Lon" Title="@($"Picked: {p.Lat:F3}, {p.Lon:F3}")" />
                    }
                </ChildContent>
                <Overlay>
                    @* bottom-left: safe — no MapLibre default controls there *@
                    <MapInfoChip Position="bottom-left">
                        @if (_pickedPoint is { } pp)
                        {
                            <span>@pp.Lat.ToString("F4"), @pp.Lon.ToString("F4")</span>
                        }
                        else
                        {
                            <span>Click to drop a marker</span>
                        }
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 5: Draggable marker — chip moved from bottom-right to bottom-left *@
    <ComponentDemo Title="Draggable marker" Code="@_draggableCode">
        <LazyRender Height="400px">
            <Map Center="(48.137, 11.575)" Zoom="9" Height="400px">
                <ChildContent>
                    <MapMarker Lat="@_dragLat"
                               Lon="@_dragLon"
                               Title="Drag me"
                               Draggable="true"
                               OnDragEnd="HandleMarkerDragEnd" />
                </ChildContent>
                <Overlay>
                    @* bottom-left: safe — attribution is bottom-right *@
                    <MapInfoChip Position="bottom-left">
                        @_dragLat.ToString("F4"), @_dragLon.ToString("F4")
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 6: Heatmap *@
    <ComponentDemo Title="Heatmap" Code="@_heatmapCode">
        <LazyRender Height="450px">
            <Map Center="(51.5, 10.0)" Zoom="4" Height="450px" TileLayer="DarkMatter">
                <ChildContent>
                    <MapHeatmap Points="_heatPoints" Radius="25" Opacity="0.85" />
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        Population density — Europe
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 7: Polyline styles — solid + dashed + activity (merged 3→1) *@
    <ComponentDemo Title="Polyline styles — solid, dashed, animated loop" Code="@_polylineCode">
        <LazyRender Height="430px">
            <Map Center="(40.785, -73.968)" Zoom="14" Height="430px" TileLayer="Voyager">
                <ChildContent>
                    <MapPolyline Points="_centralParkLoop" Color="#22c55e" Weight="4" Animate="true" Tooltip="Central Park Loop" />
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        <SvgGlyph Svg="@(Lucide.Bike)" Class="w-3.5 h-3.5" />
                        6.2 mi · 32 min · 285 cal
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
        <div class="mt-4">
            <LazyRender Height="420px">
                <Map Center="(47.5, -30.0)" Zoom="3" Height="420px">
                    <ChildContent>
                        <MapMarker Lat="51.507" Lon="-0.128" Title="London" Variant="Pin" Color="blue" />
                        <MapMarker Lat="40.712" Lon="-74.006" Title="New York City" Variant="Pin" Color="blue" />
                        <MapPolyline Points="_londonNycRoute" Color="var(--color-primary)" Weight="3" Animate="true" Tooltip="London → NYC" />
                        <MapPolyline Points="_londonNycRoute" Color="#3b82f6" Weight="2" Dashed="true" Opacity="0.5" Tooltip="Dashed overlay" />
                    </ChildContent>
                    <Overlay>
                        <MapInfoChip Position="top-left">
                            Solid + dashed — London → NYC
                        </MapInfoChip>
                    </Overlay>
                </Map>
            </LazyRender>
        </div>
    </ComponentDemo>

    @* Demo 8: Shapes — polygon + circle (merged 2→1) *@
    <ComponentDemo Title="Shapes — polygon and circle" Code="@_polygonCode">
        <LazyRender Height="420px">
            <Map Center="(51.5, -0.09)" Zoom="12" Height="420px" TileLayer="CartoLight">
                <ChildContent>
                    <MapPolygon Points="_serviceAreaPolygon"
                                Color="#6366f1"
                                FillColor="#6366f1"
                                FillOpacity="0.15"
                                Weight="2"
                                Tooltip="Delivery service area" />
                    <MapCircle Center="(51.505, -0.09)"
                               RadiusMeters="800"
                               Color="#f97316"
                               FillColor="#f97316"
                               FillOpacity="0.12"
                               Weight="2"
                               Tooltip="800 m depot radius" />
                    <MapMarker Lat="51.505" Lon="-0.09" Title="Depot" Variant="Pin" Color="purple" />
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        Delivery zone + depot radius — East London
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 9: Globe + arcs (merged 2→1: "Globe projection" + "Arcs — globe projection") *@
    <ComponentDemo Title="Globe projection with arcs" Code="@_arcsGlobeCode">
        <LazyRender Height="500px">
            <Map Center="(20.0, 10.0)" Zoom="1" Height="500px" TileLayer="DarkMatter" Projection="globe">
                <ChildContent>
                    @foreach (var (lat, lon, name) in _globeCities)
                    {
                        <MapMarker Lat="lat" Lon="lon" Title="@name" Label="@name" Variant="Dot" Color="teal" LabelHoverOnly="false" />
                    }
                    @foreach (var (from, to) in _globalArcs)
                    {
                        <MapArc From="from" To="to" Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                    }
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        <SvgGlyph Svg="@(Lucide.Globe)" Class="w-3.5 h-3.5" />
                        Globe projection — great-circle arcs
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 10: Interactive arcs — chip moved from top-right to top-left *@
    <ComponentDemo Title="Interactive arcs — Air vs Sea routes" Code="@_interactiveArcsCode">
        <LazyRender Height="500px">
            <Map Center="(30.0, 0.0)" Zoom="2" Height="500px" TileLayer="CartoDark">
                <ChildContent>
                    @foreach (var (lat, lon, name) in _globeCities)
                    {
                        <MapMarker Lat="lat" Lon="lon" Title="@name" Variant="Dot" Color="gray" />
                    }
                    @foreach (var (from, to) in _airArcs)
                    {
                        <MapArc From="from" To="to"
                                Color="#3b82f6" HoverColor="#93c5fd" HoverWeight="4"
                                Weight="2" Opacity="0.8" Dashed="false"
                                Tooltip="Air route" />
                    }
                    @foreach (var (from, to) in _seaArcs)
                    {
                        <MapArc From="from" To="to"
                                Color="#14b8a6" HoverColor="#5eead4" HoverWeight="4"
                                Weight="2" Opacity="0.7" Dashed="true"
                                Tooltip="Sea route" />
                    }
                </ChildContent>
                <Overlay>
                    @* Single chip combining hint + legend, no overlap. *@
                    <MapInfoChip Position="top-left" Title="Hover arcs to highlight" Layout="stack" Class="min-w-[140px]">
                        <div class="flex flex-col gap-1">
                            <div class="flex items-center gap-2">
                                <span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#3b82f6"></span>
                                <span class="text-foreground/85">Air</span>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="inline-block w-2.5 h-2.5 rounded-full" style="background:#14b8a6"></span>
                                <span class="text-foreground/85">Sea</span>
                            </div>
                        </div>
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 11: Clustered markers *@
    <ComponentDemo Title="Clustered markers" Code="@_clusterCode">
        <LazyRender Height="480px">
            <Map Center="(20.0, 10.0)" Zoom="2" Height="480px" Cluster="true">
                <ChildContent>
                    @foreach (var (lat, lon, name) in _worldCities)
                    {
                        <MapMarker Lat="lat" Lon="lon" Title="@name" Highlighted="@_recommendedCities.Contains(name)" />
                    }
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        @_worldCities.Length markers — <code>Cluster="true"</code>. A cluster holding a
                        <span class="font-medium text-amber-600 dark:text-amber-400">recommended</span> marker turns amber.
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 12: Auto-fit bounds — chip moved from top-right to top-left *@
    <ComponentDemo Title="Auto-fit bounds" Code="@_autoFitCode">
        <LazyRender Height="460px">
            <Map Center="(20.0, 0.0)" Zoom="2" Height="460px" AutoFitBounds="true">
                <ChildContent>
                    @foreach (var (lat, lon, name) in _spreadMarkers)
                    {
                        <MapMarker Lat="lat" Lon="lon" Title="@name" Variant="Pin" />
                    }
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left">
                        <code>AutoFitBounds="true"</code> — auto-zoom to all markers
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 13: Route Planning *@
    <ComponentDemo Title="Route Planning" Code="@_routePlanningCode">
        <LazyRender Height="480px">
            <Map Center="(52.15, 4.69)" Zoom="8" Height="480px" TileLayer="CartoLight">
                <ChildContent>
                    @* Inactive routes rendered first (underneath) *@
                    @for (int i = 0; i < _routes.Count; i++)
                    {
                        int idx = i;
                        if (idx != _selectedRoute)
                        {
                            <MapPolyline Points="_routes[idx].Points"
                                         Color="#94a3b8"
                                         Weight="4"
                                         Opacity="0.6"
                                         Tooltip="@_routes[idx].Label" />
                        }
                    }
                    @* Active route on top *@
                    @if (_routes.Count > 0)
                    {
                        <MapPolyline Points="_routes[_selectedRoute].Points"
                                     Color="#3b82f6"
                                     Weight="5"
                                     Opacity="0.95"
                                     Tooltip="@_routes[_selectedRoute].Label" />
                    }
                    <MapMarker Lat="52.3676" Lon="4.9041" Title="Amsterdam" Variant="Pin" Color="green" Label="Amsterdam" />
                    <MapMarker Lat="51.9244" Lon="4.4777" Title="Rotterdam" Variant="Pin" Color="red" Label="Rotterdam" />
                </ChildContent>
                <Overlay>
                    <MapInfoChip Position="top-left" Title="Route options" Layout="stack" Class="min-w-[200px] max-w-[240px]">
                        @if (_routesLoading)
                        {
                            <span class="text-muted-foreground text-xs">Fetching routes…</span>
                        }
                        else
                        {
                            <div class="flex flex-col gap-1">
                                @for (int i = 0; i < _routes.Count; i++)
                                {
                                    int idx = i;
                                    bool active = idx == _selectedRoute;
                                    <button type="button"
                                            class="w-full text-left rounded-md px-2 py-1 text-xs transition-colors leading-tight @(active ? "bg-primary text-primary-foreground font-medium" : "hover:bg-accent text-foreground/80")"
                                            @onclick="() => _selectedRoute = idx">
                                        @_routes[idx].Label
                                    </button>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_routeNote))
                        {
                            <span class="text-muted-foreground text-[10px] mt-1 leading-tight block">@_routeNote</span>
                        }
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 14: Export to PNG *@
    <ComponentDemo Title="Export to PNG" Code="@_exportCode">
        <Stack Gap="3" Class="w-full">
            <LazyRender Height="400px">
                <Map @ref="_exportMapRef"
                     Center="(51.505, -0.09)"
                     Zoom="12"
                     Height="400px">
                    <ChildContent>
                        <MapMarker Lat="51.507" Lon="-0.128" Title="London" Variant="Pin" Color="blue" />
                        <MapMarker Lat="51.503" Lon="-0.119" Title="Tower Bridge" Variant="Pin" Color="red" />
                        <MapMarker Lat="51.501" Lon="-0.142" Title="Buckingham Palace" Variant="Pin" Color="purple" />
                    </ChildContent>
                </Map>
            </LazyRender>
            <div class="flex items-center gap-3">
                <Button OnClick="HandleExportClick" Variant="Button.ButtonVariant.Outline">
                    <SvgGlyph Svg="@(Lucide.Download)" Class="w-4 h-4 mr-1.5" />
                    Export to PNG
                </Button>
                @if (_exportBusy)
                {
                    <span class="text-xs text-muted-foreground">Exporting…</span>
                }
                @if (_exportDataUrl is not null)
                {
                    <Button OnClick="@(() => _exportDataUrl = null)" Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                        <SvgGlyph Svg="@(Lucide.X)" Class="w-3.5 h-3.5 mr-1" />
                        Clear
                    </Button>
                }
            </div>
            @if (_exportDataUrl is { } url)
            {
                <div class="rounded-lg overflow-hidden border border-border">
                    <img src="@url" alt="Exported map snapshot" class="w-full block" />
                </div>
            }
        </Stack>
    </ComponentDemo>

    @* Demo 15: Map controls — Geolocate, Fullscreen, Scale, Search, Layers switcher *@
    <ComponentDemo Title="Map controls — Geolocate, Fullscreen, Scale, Search, Layers">
        <LazyRender Height="460px">
            <Map Center="(48.137, 11.575)"
                 Zoom="11"
                 Height="460px"
                 Geolocate="true"
                 Fullscreen="true"
                 Scale="true"
                 Search="true"
                 Layers="@(new[] { "Positron", "DarkMatter", "Voyager", "Satellite" })">
                <Overlay>
                    <MapInfoChip Position="bottom-left">
                        Geolocate · Fullscreen · Scale · Search · Layer switcher
                    </MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

</Stack>

<div class="mt-12 space-y-3">
    <Heading Id="self-hosting" Level="2" Class="scroll-mt-20">Self-hosting MapLibre</Heading>
    <Lumeo.Text Size="sm" Color="muted">
        By default the Map lazy-loads <Code>MapLibre GL JS</Code> and its stylesheet from unpkg
        the first time a <Code>Map</Code> mounts. That's the right tradeoff for most apps, but
        it doesn't work behind a strict CSP, on an air-gapped intranet, or in compliance
        scenarios where every third-party script call is a no-go.
    </Lumeo.Text>
    <Lumeo.Text Size="sm" Color="muted">
        The Lumeo CLI ships a one-shot installer that vendors MapLibre into
        <Code>wwwroot/lib/lumeo-vendor/</Code> and writes a bootstrap that wires up
        <Code>window.lumeoCdn</Code> so the runtime loads from your own origin:
    </Lumeo.Text>
    <div class="rounded-lg overflow-hidden ring-1 ring-border/40" style="background-color: #0a0a0a;">
        <div class="flex items-center justify-between px-3 py-2 border-b" style="border-color: rgba(255,255,255,0.08);">
            <div class="flex items-center gap-1.5">
                <span class="h-2.5 w-2.5 rounded-full" style="background-color: #ff5f56;"></span>
                <span class="h-2.5 w-2.5 rounded-full" style="background-color: #ffbd2e;"></span>
                <span class="h-2.5 w-2.5 rounded-full" style="background-color: #27c93f;"></span>
            </div>
            <span class="font-mono text-[10px]" style="color: rgba(255,255,255,0.70);">bash</span>
        </div>
<pre class="font-mono text-[12px] leading-relaxed whitespace-pre overflow-x-auto px-4 py-3 m-0" style="color: #e4e4e7;"><span style="color: #94a3b8;"># 1. Install the Lumeo CLI as a global dotnet tool</span>
<span style="color: #27c93f;">$</span> <span style="color: #60a5fa;">dotnet</span> tool install -g <span style="color: #fbbf24;">Lumeo.Cli</span>

<span style="color: #94a3b8;"># 2. Vendor MapLibre into wwwroot/lib/lumeo-vendor/ and write the bootstrap</span>
<span style="color: #27c93f;">$</span> <span style="color: #60a5fa;">lumeo</span> deps install --lib maplibre --write-bootstrap

<span style="color: #94a3b8;"># 3. Include the bootstrap before _content/Lumeo.Maps/js/* in index.html</span>
<span style="color: #94a3b8;">#    &lt;script src="js/lumeo-cdn-init.js"&gt;&lt;/script&gt;</span></pre>
    </div>
    <Lumeo.Text Size="sm" Color="muted">
        See <Lumeo.Link Href="docs/cdn-deps">CDN dependencies</Lumeo.Link> for the full list
        of self-hostable libraries and the <Code>window.lumeoCdn</Code> override surface.
        For more granular control (custom URL, integrity hash, alternative CDN) you can
        set <Code>window.lumeoCdn = { mapLibreJs: "/my/cdn/maplibre-gl.js", mapLibreCss: "/my/cdn/maplibre-gl.css" };</Code>
        before the first <Code>Map</Code> mounts.
    </Lumeo.Text>
</div>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="map" Level="3" Class="mt-8 scroll-mt-20">Map</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" />
    </div>

    <Heading Id="map-marker" Level="3" Class="mt-8 scroll-mt-20">MapMarker</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapMarker" />
    </div>

    <Heading Id="map-heatmap" Level="3" Class="mt-8 scroll-mt-20">MapHeatmap</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapHeatmap" />
    </div>

    <Heading Id="map-polyline" Level="3" Class="mt-8 scroll-mt-20">MapPolyline</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapPolyline" />
    </div>

    <Heading Id="map-polygon" Level="3" Class="mt-8 scroll-mt-20">MapPolygon</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapPolygon" />
    </div>

    <Heading Id="map-circle" Level="3" Class="mt-8 scroll-mt-20">MapCircle</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapCircle" />
    </div>

    <Heading Id="map-arc" Level="3" Class="mt-8 scroll-mt-20">MapArc</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapArc" />
    </div>

    <Heading Id="map-popup" Level="3" Class="mt-8 scroll-mt-20">MapPopup</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapPopup" />
    </div>

    <Heading Id="map-legend" Level="3" Class="mt-8 scroll-mt-20">MapLegend</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapLegend" />
    </div>

    <Heading Id="map-legend-item" Level="3" Class="mt-8 scroll-mt-20">MapLegendItem</Heading>
    <div class="overflow-x-auto mt-4">
        <PropsTable Slug="map" SubComponent="MapLegendItem" />
    </div>
</div>

@code {
    // Route Planning demo
    private record RouteOption(string Label, List<(double Lat, double Lon)> Points);
    private List<RouteOption> _routes = new();
    private int _selectedRoute;
    private bool _routesLoading = true;
    private string? _routeNote;

    // Hardcoded fallback routes Amsterdam → Rotterdam (used when OSRM CORS is blocked)
    private static readonly List<(double Lat, double Lon)> _fallbackRoute1 =
    [
        (52.3676, 4.9041), (52.340, 4.870), (52.290, 4.820),
        (52.230, 4.760), (52.170, 4.700), (52.100, 4.640),
