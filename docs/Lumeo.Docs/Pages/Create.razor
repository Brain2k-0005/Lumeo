@page "/create"

<PageTitle>Create — Lumeo</PageTitle>

<Stack Gap="2" Class="mb-8">
    <Heading Level="1" Size="3xl">Create</Heading>
    <Lumeo.Text Size="lg" Color="muted">
        Make Lumeo your own — pick a theme, base color, radius, font and icon library and watch the
        preview update live. Copy the preset when you're happy with it.
    </Lumeo.Text>
</Stack>

<div class="flex flex-col lg:flex-row gap-6 items-start">

    @* ---------- Live preview ---------- *@
    @* The preview deliberately uses DynamicIcon so switching the icon library in the
       customizer is visible here. Every other docs page uses static Lucide icons. *@
    <div class="flex-1 min-w-0 w-full space-y-6">

        <Card>
            <CardHeader>
                <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Buttons</Heading>
                <Lumeo.Text Size="sm" Color="muted">Variants, sizes and icon buttons.</Lumeo.Text>
            </CardHeader>
            <CardContent>
                <Stack Gap="4">
                    <Flex Gap="2" Wrap="true">
                        <Button>Default</Button>
                        <Button Variant="Button.ButtonVariant.Secondary">Secondary</Button>
                        <Button Variant="Button.ButtonVariant.Destructive">Destructive</Button>
                        <Button Variant="Button.ButtonVariant.Outline">Outline</Button>
                        <Button Variant="Button.ButtonVariant.Ghost">Ghost</Button>
                        <Button Variant="Button.ButtonVariant.Link">Link</Button>
                    </Flex>
                    <Flex Gap="2" Wrap="true" Align="center">
                        <Button Size="Button.ButtonSize.Sm">Small</Button>
                        <Button>Default</Button>
                        <Button Size="Button.ButtonSize.Lg">Large</Button>
                        <Button>
                            <DynamicIcon Name="Mail" Class="h-4 w-4" />
                            Login with Email
                        </Button>
                        <Button Size="Button.ButtonSize.Icon">
                            <DynamicIcon Name="Plus" Class="h-4 w-4" />
                        </Button>
                    </Flex>
                </Stack>
            </CardContent>
        </Card>

        <Card>
            <CardHeader>
                <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Badges</Heading>
            </CardHeader>
            <CardContent>
                <Flex Wrap="true" Align="center" Gap="2">
                    <Badge>Default</Badge>
                    <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
                    <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
                    <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
                    <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
                </Flex>
            </CardContent>
        </Card>

        <Tabs ActiveValue="account">
            <TabsList>
                <TabsTrigger Value="account">Account</TabsTrigger>
                <TabsTrigger Value="notifications">Notifications</TabsTrigger>
            </TabsList>
            <TabsContent Value="account">
                <Card>
                    <CardHeader>
                        <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Account</Heading>
                        <Lumeo.Text Size="sm" Color="muted">Update your profile details.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="4">
                            <Flex Align="center" Gap="4">
                                <Avatar>
                                    <AvatarImage Src="https://github.com/shadcn.png" Alt="User avatar" />
                                    <AvatarFallback>CN</AvatarFallback>
                                </Avatar>
                                <Stack Gap="0">
                                    <Lumeo.Text Size="sm" Weight="medium">Pedro Duarte</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">@("@peduarte")</Lumeo.Text>
                                </Stack>
                            </Flex>
                            <FormField Label="Name">
                                <Input Value="Pedro Duarte" />
                            </FormField>
                            <FormField Label="Username">
                                <Input Value="@("@peduarte")" />
                            </FormField>
                        </Stack>
                    </CardContent>
                    <CardFooter>
                        <Button>
                            <DynamicIcon Name="Check" Class="h-4 w-4" />
                            Save changes
                        </Button>
                    </CardFooter>
                </Card>
            </TabsContent>
            <TabsContent Value="notifications">
                <Card>
                    <CardHeader>
                        <Heading Level="3" Size="lg" Class="leading-none tracking-tight">Notifications</Heading>
                        <Lumeo.Text Size="sm" Color="muted">Choose what you want to be notified about.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="4">
                            <Flex Align="center" Justify="between">
                                <Flex Align="center" Gap="2">
                                    <DynamicIcon Name="Bell" Class="h-4 w-4 text-muted-foreground" />
                                    <Label>Push notifications</Label>
                                </Flex>
                                <Switch @bind-Checked="_push" />
                            </Flex>
                            <Flex Align="center" Justify="between">
                                <Flex Align="center" Gap="2">
                                    <DynamicIcon Name="Mail" Class="h-4 w-4 text-muted-foreground" />
                                    <Label>Email digest</Label>
                                </Flex>
                                <Switch @bind-Checked="_email" />
                            </Flex>
                        </Stack>
                    </CardContent>
                </Card>
            </TabsContent>
        </Tabs>

        <Alert>
            <Heading Level="5" Size="sm" Weight="medium" Class="mb-1 leading-none tracking-tight">Heads up!</Heading>
            <Lumeo.Text Size="sm" Leading="relaxed">
                These styles apply to the whole site while you're on this page. Use Share preset to keep them.
            </Lumeo.Text>
        </Alert>
    </div>

    @* ---------- Customizer rail ---------- *@
    <div class="w-full lg:w-auto flex justify-center lg:block shrink-0">
        <CustomizerSidebar IsOpen="true" ShowClose="false" />
    </div>
</div>

@code {
    private bool _push = true;
    private bool _email;
}
