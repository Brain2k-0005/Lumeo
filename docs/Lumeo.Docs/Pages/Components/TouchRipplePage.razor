    private string[] _listItems = ["Alice Johnson", "Bob Martinez", "Carol Williams"];
    private string? _selectedItem;

    private string _basicCode = @"<TouchRipple Class=""inline-block rounded-md"">
    <Button>Tap me</Button>
</TouchRipple>";

    private string _colorCode = @"<TouchRipple Color=""#3b82f6"" Class=""inline-block rounded-md"">
    <Button Variant=""ButtonVariant.Secondary"">Blue ripple</Button>
</TouchRipple>

<TouchRipple Color=""#ef4444"" Class=""inline-block rounded-md"">
    <Button Variant=""ButtonVariant.Secondary"">Red ripple</Button>
</TouchRipple>";

    private string _opacityCode = @"<!-- High opacity, fast -->
<TouchRipple Opacity=""0.5"" DurationMs=""300"" Class=""inline-block rounded-md"">
    <Button Variant=""ButtonVariant.Outline"">Fast (300 ms)</Button>
</TouchRipple>

<!-- Low opacity, slow -->
<TouchRipple Opacity=""0.1"" DurationMs=""900"" Class=""inline-block rounded-md"">
    <Button Variant=""ButtonVariant.Outline"">Slow (900 ms)</Button>
</TouchRipple>";

    private string _cardCode = @"<TouchRipple Class=""block rounded-xl w-full max-w-sm cursor-pointer"">
    <Card Class=""p-5"">
        <Text Class=""font-medium"">Interactive card</Text>
        <Text Size=""sm"" Color=""muted"">Tap anywhere to see the ripple.</Text>
    </Card>
</TouchRipple>";

    private string _listRowCode = @"<Card Class=""divide-y divide-border/40 overflow-hidden"">
    @foreach (var item in _listItems)
    {
        var captured = item;
        <TouchRipple Class=""block w-full cursor-pointer"" @key=""captured"">
            <div class=""flex items-center gap-3 px-4 py-3"" @onclick=""@(() => _selectedItem = captured)"">
                <div class=""h-9 w-9 rounded-full bg-primary/10 flex items-center justify-center shrink-0"">
                    <SvgGlyph Svg=""@(Lucide.User)"" class=""h-4 w-4 text-primary"" />
                </div>
                <Text Size=""sm"" Class=""font-medium truncate"">@captured</Text>
            </div>
        </TouchRipple>
    }
</Card>

@code {
    private string[] _listItems = [""Alice Johnson"", ""Bob Martinez"", ""Carol Williams""];
    private string? _selectedItem;
}";
}
