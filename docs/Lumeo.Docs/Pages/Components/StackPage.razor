@page "/components/stack"

<PageTitle>Stack — Lumeo</PageTitle>

<PageHeader Title="Stack" Description="A flex-based layout component for stacking elements vertically or horizontally with consistent spacing." />

<InstallUsage Component="Stack" />

<Stack Gap="8">
    <ComponentDemo Title="Basic Vertical" Code="@_basicCode">
        <Stack Gap="3" Class="w-full max-w-xs">
            <Flex Class="h-10 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 1</Flex>
            <Flex Class="h-10 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 2</Flex>
            <Flex Class="h-10 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 3</Flex>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Horizontal" Code="@_horizontalCode">
        <Stack Direction="Lumeo.Orientation.Horizontal" Gap="3">
            <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 1</Flex>
            <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 2</Flex>
            <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 3</Flex>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Gap Sizes" Code="@_gapCode">
        <Stack Gap="6" Class="w-full">
            <Stack>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">Gap 1</Lumeo.Text>
                <Stack Direction="Lumeo.Orientation.Horizontal" Gap="1">
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                </Stack>
            </Stack>
            <Stack>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">Gap 4</Lumeo.Text>
                <Stack Direction="Lumeo.Orientation.Horizontal" Gap="4">
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                </Stack>
            </Stack>
            <Stack>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2">Gap 8</Lumeo.Text>
                <Stack Direction="Lumeo.Orientation.Horizontal" Gap="8">
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                    <Stack Class="h-8 w-16 rounded bg-primary/20"></Stack>
                </Stack>
            </Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Alignment" Code="@_alignCode">
        <Stack Direction="Lumeo.Orientation.Horizontal" Gap="4" Align="center" Justify="between" Class="w-full">
            <Stack Class="h-8 w-20 rounded bg-primary/20"></Stack>
            <Stack Class="h-12 w-20 rounded bg-primary/20"></Stack>
            <Stack Class="h-6 w-20 rounded bg-primary/20"></Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Wrap">
        <Stack Direction="Lumeo.Orientation.Horizontal" Gap="2" Wrap="true" Class="w-full max-w-xs">
            @for (var i = 1; i <= 8; i++)
            {
                <Flex Class="h-10 w-20 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item @i</Flex>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Direction — interactive" Code="@_directionInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Pick a direction to see it applied live.</Lumeo.Text>
            <Flex Gap="2">
                <Button Size="Button.ButtonSize.Sm"
                        Variant="@(_stackDir == Lumeo.Orientation.Vertical ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                        OnClick="@(() => _stackDir = Lumeo.Orientation.Vertical)">Vertical</Button>
                <Button Size="Button.ButtonSize.Sm"
                        Variant="@(_stackDir == Lumeo.Orientation.Horizontal ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                        OnClick="@(() => _stackDir = Lumeo.Orientation.Horizontal)">Horizontal</Button>
            </Flex>
            <Stack Direction="@_stackDir" Gap="3">
                <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 1</Flex>
                <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 2</Flex>
                <Flex Class="h-10 w-24 rounded-md bg-primary/20 items-center justify-center text-sm text-primary">Item 3</Flex>
            </Stack>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <Stack Gap="6" Class="mt-12">
        <Heading Level="2">API Reference</Heading>
        <Stack Gap="8">
            <Stack>
                <Heading Level="3" Class="mb-3">Stack</Heading>
                <PropsTable Slug="stack" />
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private Lumeo.Orientation _stackDir = Lumeo.Orientation.Vertical;

    private string _directionInteractiveCode = @"<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";

    private string _basicCode = @"<Stack Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";

    private string _horizontalCode = @"<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";

    private string _gapCode = @"<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""1"">...</Stack>
<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""4"">...</Stack>
<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""8"">...</Stack>";

    private string _alignCode = @"<Stack Direction=""Lumeo.Orientation.Horizontal"" Gap=""4"" Align=""center"" Justify=""between"" Class=""w-full"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";
}
