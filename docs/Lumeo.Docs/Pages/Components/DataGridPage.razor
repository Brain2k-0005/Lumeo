@code {
    private List<Employee> _serverItems = new();
    private int _totalCount;

    private async Task LoadData(DataGridServerRequest request)
    {
        try
        {
            // Pass CancellationToken to your HTTP client — in-flight requests
            // are cancelled automatically when a newer interaction fires.
            var result = await _api.GetEmployees(
                page: request.Page,
                pageSize: request.PageSize,
                sorts: request.Sorts,
                filters: request.Filters,
                search: request.GlobalSearch,
                ct: request.CancellationToken);

            _serverItems = result.Items.ToList();
            _totalCount = result.TotalCount;
            // IsLoading is managed internally — do not set it manually.
        }
        catch (OperationCanceledException) { /* superseded request — ignore */ }
    }
}";

    private string _errorHandlingCode = @"<DataGrid TItem=""Employee"" Items=""@_items"" TotalCount=""@_total""
          ServerMode=""true"" OnServerRequest=""@LoadData""
          OnError=""@(ex => _errorMsg = ex.Message)"">
    <DataGridColumnDef TItem=""Employee"" Title=""Name"" Field=""Name"" Sortable=""true"" />
    <DataGridColumnDef TItem=""Employee"" Title=""Department"" Field=""Department"" />
    <DataGridColumnDef TItem=""Employee"" Title=""Salary"" Field=""Salary"" Format=""C0"" />
</DataGrid>

@if (!string.IsNullOrEmpty(_errorMsg))
{
    <Alert>
        <AlertTitle>Server Error</AlertTitle>
        <AlertDescription>@_errorMsg</AlertDescription>
    </Alert>
}

@code {
    private string? _errorMsg;

    private async Task LoadData(DataGridServerRequest request)
    {
        // Exceptions thrown here are forwarded to OnError
        // instead of crashing the grid.
        var result = await _api.GetEmployees(request);
        _items = result.Items.ToList();
        _total = result.TotalCount;
    }
}";

