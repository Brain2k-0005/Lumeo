@namespace Lumeo.Tests.Components.Splitter

@* Test host for #258 — adds a third pane after the initial layout to verify
   late panes still receive a size and become visible. *@
<Lumeo.Splitter Orientation="Lumeo.Orientation.Horizontal">
    <Lumeo.SplitterPane><span data-testid="pane-0">0</span></Lumeo.SplitterPane>
    <Lumeo.SplitterDivider />
    <Lumeo.SplitterPane><span data-testid="pane-1">1</span></Lumeo.SplitterPane>
    @if (ShowThird)
    {
        <Lumeo.SplitterDivider />
        <Lumeo.SplitterPane><span data-testid="pane-2">2</span></Lumeo.SplitterPane>
    }
</Lumeo.Splitter>

@code {
    [Parameter] public bool ShowThird { get; set; }
}
