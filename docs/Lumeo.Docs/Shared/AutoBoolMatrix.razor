@*  Renders the user template once with the param off, once with it on, side-by-side.  *@
<Stack Gap="3">
    @if (Title is not null)
    {
        <Heading Level="3" Size="sm" Class="font-semibold tracking-tight">@Title</Heading>
    }
    <div class="grid grid-cols-2 gap-4">
        <div class="flex flex-col gap-2">
            <Lumeo.Text Size="xs" Color="muted" Class="font-mono">@ParameterName = false</Lumeo.Text>
            @OffContent
        </div>
        <div class="flex flex-col gap-2">
            <Lumeo.Text Size="xs" Color="muted" Class="font-mono">@ParameterName = true</Lumeo.Text>
            @OnContent
        </div>
    </div>
</Stack>

@code {
    [Parameter, EditorRequired] public string ParameterName { get; set; } = "";
    [Parameter] public string? Title { get; set; }
    [Parameter] public RenderFragment? OffContent { get; set; }
    [Parameter] public RenderFragment? OnContent { get; set; }
}
