        builder.OpenElement(11, "tr");
        builder.AddAttribute(12, "class", "border-b border-border/40 text-muted-foreground");
        AppendTh(builder, 13, L["FileManager.Name"], "text-start p-2 font-medium w-full");
        AppendTh(builder, 14, L["FileManager.Size"], "text-end p-2 font-medium whitespace-nowrap w-28");
        AppendTh(builder, 15, L["FileManager.Modified"], "text-end p-2 font-medium whitespace-nowrap w-40");
        AppendTh(builder, 16, "", "w-8 p-2"); // context menu column
        builder.CloseElement(); // tr
        builder.CloseElement(); // thead

        // tbody
        builder.OpenElement(20, "tbody");
        var rowIndex = 0;
        foreach (var node in items)
        {
            var n = node;
