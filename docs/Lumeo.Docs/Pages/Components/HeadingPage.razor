@page "/components/heading"

<PageTitle>Heading — Lumeo</PageTitle>

<PageHeader Title="Heading" Description="A semantic heading component that renders h1-h6 elements with sensible default sizes and weights." />

<Stack Gap="8">
    <ComponentDemo Title="All Levels" Code="@_levelsCode">
        <Stack Gap="3" Class="w-full">
            <Heading Level="1">Heading Level 1</Heading>
            <Heading Level="2">Heading Level 2</Heading>
            <Heading Level="3">Heading Level 3</Heading>
            <Heading Level="4">Heading Level 4</Heading>
            <Heading Level="5">Heading Level 5</Heading>
            <Heading Level="6">Heading Level 6</Heading>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom Sizes" Code="@_customCode">
        <Stack Gap="3">
            <Heading Level="2" Size="sm">h2 with small text</Heading>
            <Heading Level="3" Size="3xl">h3 with 3xl text</Heading>
            <Heading Level="4" Size="lg" Weight="normal">h4 with lg text, normal weight</Heading>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Tracking" Code="@_trackingCode">
        <Stack Gap="3">
            <Heading Level="1">Default tight tracking (h1)</Heading>
            <Heading Level="1" Tracking="normal">Normal tracking</Heading>
            <Heading Level="1" Tracking="wide">Wide tracking</Heading>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Level</TableCell>
                    <TableCell Class="font-mono text-xs">int</TableCell>
                    <TableCell Class="font-mono text-xs">2</TableCell>
                    <TableCell>Heading level (1-6). Determines the HTML element (h1-h6) and default styles.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Size</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">auto</TableCell>
                    <TableCell>Override the default text size. Maps to text-{value}. Defaults: h1=4xl, h2=3xl, h3=2xl, h4=xl, h5=lg, h6=base.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Weight</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">auto</TableCell>
                    <TableCell>Override the default font weight. Defaults: h1/h2=bold, h3/h4=semibold, h5/h6=medium.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Tracking</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">auto</TableCell>
                    <TableCell>Letter spacing. Defaults to "tight" for h1/h2. Maps to tracking-{value}.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _levelsCode = @"<Heading Level=""1"">Heading Level 1</Heading>
<Heading Level=""2"">Heading Level 2</Heading>
<Heading Level=""3"">Heading Level 3</Heading>
<Heading Level=""4"">Heading Level 4</Heading>
<Heading Level=""5"">Heading Level 5</Heading>
<Heading Level=""6"">Heading Level 6</Heading>";

    private string _customCode = @"<Heading Level=""2"" Size=""sm"">h2 with small text</Heading>
<Heading Level=""3"" Size=""3xl"">h3 with 3xl text</Heading>
<Heading Level=""4"" Size=""lg"" Weight=""normal"">h4 with lg text, normal weight</Heading>";

    private string _trackingCode = @"<Heading Level=""1"">Default tight tracking</Heading>
<Heading Level=""1"" Tracking=""normal"">Normal tracking</Heading>
<Heading Level=""1"" Tracking=""wide"">Wide tracking</Heading>";
}
