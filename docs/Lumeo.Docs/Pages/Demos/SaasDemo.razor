@page "/demos/saas"
@layout SaasDemoLayout
@namespace Lumeo.Docs.Pages.Demos
@using Lumeo
@using Lumeo.Docs.Shared
@using Microsoft.AspNetCore.Components.Web
@implements IAsyncDisposable
@inject Lumeo.Services.ToastService Toast
@inject Lumeo.Services.KeyboardShortcutService Shortcuts
@inject Lumeo.Services.IResponsiveService Responsive
@inject Lumeo.Services.ComponentInteropService Interop

<PageTitle>Northlight — Lumeo SaaS demo</PageTitle>

@* Row-density override. The DataGrid's Compact parameter only swaps the root
   font-size (text-sm) and never reaches the body cells, whose padding is
   hard-coded px-3 py-2 — so toggling Compact does NOT change row height. Since
   this demo can only touch its own files, we drive density from a wrapper class
   and override the cell block-padding here (higher specificity than Tailwind's
   .py-2, so no !important needed). Emitted as raw markup so Razor doesn't try to
   parse the CSS braces. *@
@((MarkupString)DensityStyles)

<SidebarProvider @bind-IsCollapsed="_navCollapsed"
                 Variant="SidebarProvider.SidebarVariant.Icon"
                 MobileSheet="true"
                 Class="bg-background">

    <SidebarComponent Class="@_railSurfaceClass">
        <SidebarHeader Class="@(_navCollapsed ? "p-2" : "p-4")">
            <Flex Align="center" Justify="@(_navCollapsed ? "center" : "start")" Gap="2" Class="min-w-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-primary text-primary-foreground shadow-sm">
                    <DynamicIcon Name="Compass" Class="h-4 w-4" />
                </span>
                @if (!_navCollapsed)
                {
                    <Stack Gap="0" Class="min-w-0">
                        <Lumeo.Text As="span" Size="sm" Weight="semibold" Class="truncate leading-tight">Northlight</Lumeo.Text>
                        <Lumeo.Text As="span" Size="xs" Color="muted" Class="truncate leading-tight">Product analytics</Lumeo.Text>
                    </Stack>
                }
            </Flex>
        </SidebarHeader>

        @* Nav items are hand-rolled <button>s (not SidebarMenuButton) on purpose:
           these switch an in-page view via @onclick, not navigate to a route, and
           SidebarMenuButton is anchor/Href-based. We still lean on every structural
           Sidebar primitive (Group / GroupLabel / Menu / MenuItem / Separator) and
           dogfood the Lumeo Tooltip for the collapsed-rail labels — see NavLink. *@
        <SidebarContent>
            <SidebarGroup>
                <SidebarGroupLabel>Workspace</SidebarGroupLabel>
                <SidebarMenu>
                    @foreach (var item in NorthlightData.PrimaryNav)
                    {
                        @NavLink(item)
                    }
                </SidebarMenu>
            </SidebarGroup>

            <SidebarSeparator />

            <SidebarGroup>
                <SidebarGroupLabel>Account</SidebarGroupLabel>
                <SidebarMenu>
                    @foreach (var item in NorthlightData.SecondaryNav)
                    {
                        @NavLink(item)
                    }
                </SidebarMenu>
            </SidebarGroup>
        </SidebarContent>

        <SidebarFooter Class="@(_navCollapsed ? "p-2" : "p-4")">
            <Flex Align="center" Justify="@(_navCollapsed ? "center" : "start")" Gap="2" Class="min-w-0">
                <Avatar Size="Lumeo.Size.Sm" Class="shrink-0">
                    <AvatarFallback>AC</AvatarFallback>
                </Avatar>
                @if (!_navCollapsed)
                {
                    <Stack Gap="0" Class="min-w-0 flex-1">
                        <Lumeo.Text As="span" Size="xs" Weight="medium" Class="truncate leading-tight">Ava Chen</Lumeo.Text>
                        <Lumeo.Text As="span" Size="xs" Color="muted" Class="truncate leading-tight">Admin</Lumeo.Text>
                    </Stack>
                    <span class="inline-flex h-2 w-2 shrink-0 rounded-full bg-emerald-500" title="Online"></span>
                }
            </Flex>
        </SidebarFooter>
    </SidebarComponent>

    <!-- App column: topbar + scrollable view -->
    <div class="flex min-w-0 flex-1 flex-col">

        <header class="flex h-14 shrink-0 items-center gap-2 border-b border-border/50 px-3 sm:px-4">
            <SidebarTrigger />
            <div class="min-w-0">
                <Heading Level="1" Class="truncate text-base font-semibold leading-none tracking-tight">@CurrentTitle</Heading>
                <Lumeo.Text Size="xs" Color="muted" Class="hidden truncate sm:block">@CurrentSubtitle</Lumeo.Text>
            </div>

            <div class="flex-1"></div>

            <!-- Command palette trigger -->
            <button type="button" @onclick="OpenPalette"
                    class="hidden w-56 items-center gap-2 rounded-md border border-border bg-muted/50 px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground lg:flex">
                <DynamicIcon Name="Search" Class="h-3.5 w-3.5 shrink-0" />
                <span class="flex-1 text-left">Search…</span>
                <kbd class="pointer-events-none inline-flex rounded border bg-background px-1.5 py-0.5 text-[10px] font-medium">⌘K</kbd>
            </button>
            <button type="button" @onclick="OpenPalette" aria-label="Search"
                    class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground lg:hidden">
                <DynamicIcon Name="Search" Class="h-4 w-4" />
            </button>

            <!-- Notifications -->
            <DropdownMenu>
                <DropdownMenuTrigger AsChild>
                    <ChildContentSlot Context="slot">
                        <button type="button" id="@slot.Id" aria-label="@($"Notifications, {_unread} unread")"
                                @attributes="slot.Attributes" @onclick="slot.OnClick"
                                class="relative inline-flex h-9 w-9 cursor-pointer items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring">
                            <DynamicIcon Name="Bell" Class="h-4 w-4" />
                            @if (_unread > 0)
                            {
                                <span class="absolute right-1 top-1 inline-flex h-4 min-w-4 items-center justify-center rounded-full bg-primary px-1 text-[10px] font-semibold leading-none text-primary-foreground">@_unread</span>
                            }
                        </button>
                    </ChildContentSlot>
                </DropdownMenuTrigger>
                <DropdownMenuContent Align="Lumeo.Align.End" Class="w-80">
                    <DropdownMenuLabel>Notifications</DropdownMenuLabel>
                    <DropdownMenuSeparator />
                    @foreach (var n in _notifications)
                    {
                        <DropdownMenuItem>
                            <Flex Gap="2" Align="start" Class="w-full">
                                <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-accent/60 text-primary">
                                    <DynamicIcon Name="@n.Icon" Class="h-3.5 w-3.5" />
                                </span>
                                <Stack Gap="0" Class="min-w-0 flex-1">
                                    <Lumeo.Text Size="sm" Class="leading-snug"><Lumeo.Text As="span" Weight="medium">@n.Actor</Lumeo.Text> @n.Action <Lumeo.Text As="span" Color="muted">@n.Target</Lumeo.Text></Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">@n.When</Lumeo.Text>
                                </Stack>
                            </Flex>
                        </DropdownMenuItem>
                    }
                    <DropdownMenuSeparator />
                    <DropdownMenuItem OnClick="MarkAllRead">
                        <Flex Align="center" Gap="2"><DynamicIcon Name="CheckCheck" Class="h-3.5 w-3.5" /> Mark all as read</Flex>
                    </DropdownMenuItem>
                </DropdownMenuContent>
            </DropdownMenu>

            <!-- Profile -->
            <DropdownMenu>
                <DropdownMenuTrigger AsChild>
                    <ChildContentSlot Context="slot">
                        <button type="button" id="@slot.Id" aria-label="Account menu — Ava Chen"
                                @attributes="slot.Attributes" @onclick="slot.OnClick"
                                class="inline-flex cursor-pointer rounded-full outline-none focus-visible:ring-2 focus-visible:ring-ring">
                            <Avatar Size="Lumeo.Size.Sm"><AvatarFallback>AC</AvatarFallback></Avatar>
                        </button>
                    </ChildContentSlot>
                </DropdownMenuTrigger>
                <DropdownMenuContent Align="Lumeo.Align.End" Class="w-56">
                    <DropdownMenuLabel>
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="medium">Ava Chen</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">ava@northlight.app</Lumeo.Text>
                        </Stack>
                    </DropdownMenuLabel>
                    <DropdownMenuSeparator />
                    <DropdownMenuItem OnClick="@(() => SetView("settings"))">
                        <Flex Align="center" Gap="2"><DynamicIcon Name="User" Class="h-3.5 w-3.5" /> Profile settings</Flex>
                    </DropdownMenuItem>
                    <DropdownMenuItem OnClick="@(() => OpenBilling())">
                        <Flex Align="center" Gap="2"><DynamicIcon Name="CreditCard" Class="h-3.5 w-3.5" /> Billing</Flex>
                    </DropdownMenuItem>
                    <DropdownMenuSeparator />
                    <DropdownMenuItem OnClick="LogOut">
                        <Flex Align="center" Gap="2"><DynamicIcon Name="LogOut" Class="h-3.5 w-3.5" /> Log out</Flex>
                    </DropdownMenuItem>
                </DropdownMenuContent>
            </DropdownMenu>
        </header>

        <main class="min-h-0 flex-1 overflow-y-auto">
            <div class="mx-auto w-full max-w-[1400px] px-3 py-5 sm:px-6 sm:py-6">

                @if (_view == "dashboard")
                {
                    <div @key="'d'">
                        <!-- KPI row -->
                        <BlurFade DelayMs="0">
                            <Flex Align="center" Justify="between" Class="mb-4">
                                <Lumeo.Text Size="sm" Color="muted">Last 30 days · all workspaces</Lumeo.Text>
                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="RefreshDashboard" Disabled="_refreshing">
                                    @if (_refreshing)
                                    {
                                        <Spinner Size="Lumeo.Size.Sm" Class="mr-2" />
                                        <span>Refreshing…</span>
                                    }
                                    else
                                    {
                                        <DynamicIcon Name="RefreshCw" Class="mr-2 h-3.5 w-3.5" />
                                        <span>Refresh</span>
                                    }
                                </Button>
                            </Flex>
                        </BlurFade>

                        <BlurFade DelayMs="60">
                            <div class="mb-4 grid grid-cols-2 gap-3 lg:grid-cols-4">
                                @foreach (var k in _kpis)
                                {
                                    <div class="rounded-xl border border-border/50 bg-card p-4">
                                        <Flex Align="center" Justify="between" Class="mb-1">
                                            <Lumeo.Text Size="xs" Color="muted">@k.Label</Lumeo.Text>
                                            <DynamicIcon Name="@k.Icon" Class="h-3.5 w-3.5 text-primary" />
                                        </Flex>
                                        <div class="text-2xl font-bold tracking-tight text-foreground">
                                            @if (_refreshing)
                                            {
                                                <Skeleton Class="h-7 w-24 rounded-md" />
                                            }
                                            else
                                            {
                                                <span>@k.Prefix</span><NumberTicker Value="@k.Value" DurationMs="1400" /><span>@k.Suffix</span>
                                            }
                                        </div>
                                        <Flex Align="center" Gap="1" Class="mt-1">
                                            <DynamicIcon Name="TrendingUp" Class="h-3 w-3 text-primary" />
                                            <Lumeo.Text Size="xs" Color="muted">@k.Trend</Lumeo.Text>
                                        </Flex>
                                    </div>
                                }
                            </div>
                        </BlurFade>

                        <!-- Charts -->
                        <BlurFade DelayMs="120">
                            <div class="mb-4 grid grid-cols-1 gap-3 lg:grid-cols-5">
                                <div class="rounded-xl border border-border/50 bg-card overflow-hidden lg:col-span-3">
                                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-1">
                                        <Stack Gap="0">
                                            <Lumeo.Text Size="sm" Weight="semibold">Monthly recurring revenue</Lumeo.Text>
                                            <Lumeo.Text Size="xs" Color="muted">Trailing 12 months</Lumeo.Text>
                                        </Stack>
                                        <Badge Variant="Badge.BadgeVariant.Success" Class="text-[10px] h-5">+38% YoY</Badge>
                                    </Flex>
                                    <div class="h-64 px-2 pb-2">
                                        <AreaChart Categories="_trendMonths" Series="_trendSeries" Smooth="true" Gradient="true"
                                                   Colors="_mrrColors" ShowDots="false" ShowLegend="false" Height="100%"
                                                   IsLoading="_chartsLoading" ShowLoadingLabel="false"
                                                   SkeletonStyle="ChartSkeletonStyle.Silhouette" AriaLabel="Monthly recurring revenue, trailing 12 months" />
                                    </div>
                                </div>
                                <div class="rounded-xl border border-border/50 bg-card overflow-hidden lg:col-span-2">
                                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-1">
                                        <Stack Gap="0">
                                            <Lumeo.Text Size="sm" Weight="semibold">New signups by plan</Lumeo.Text>
                                            <Lumeo.Text Size="xs" Color="muted">By quarter</Lumeo.Text>
                                        </Stack>
                                    </Flex>
                                    <div class="h-64 px-2 pb-2">
                                        <BarChart Categories="_planQuarters" Series="_planSeries" Stacked="true" Height="100%"
                                                  IsLoading="_chartsLoading" ShowLoadingLabel="false"
                                                  SkeletonStyle="ChartSkeletonStyle.Silhouette" AriaLabel="New signups by plan, by quarter" />
                                    </div>
                                </div>
                            </div>
                        </BlurFade>

                        <!-- Activity -->
                        <BlurFade DelayMs="180">
                            <div class="rounded-xl border border-border/50 bg-card">
                                <Flex Align="center" Justify="between" Class="border-b border-border/40 px-4 py-3">
                                    <Lumeo.Text Size="sm" Weight="semibold">Recent activity</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">Live feed</Lumeo.Text>
                                </Flex>
                                <Stack Gap="0" Class="divide-y divide-border/40">
                                    @foreach (var a in NorthlightData.Activity)
                                    {
                                        <Flex Align="center" Gap="3" Class="px-4 py-3">
                                            <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-accent/50 text-primary">
                                                <DynamicIcon Name="@a.Icon" Class="h-4 w-4" />
                                            </span>
                                            <Lumeo.Text Size="sm" Class="min-w-0 flex-1">
                                                <Lumeo.Text As="span" Weight="medium">@a.Actor</Lumeo.Text>
                                                <Lumeo.Text As="span" Color="muted"> @a.Action </Lumeo.Text>
                                                <Lumeo.Text As="span">@a.Target</Lumeo.Text>
                                            </Lumeo.Text>
                                            <Lumeo.Text Size="xs" Color="muted" Class="shrink-0">@a.When</Lumeo.Text>
                                        </Flex>
                                    }
                                </Stack>
                            </div>
                        </BlurFade>
                    </div>
                }
                else if (_view == "board")
                {
                    <div @key="'b'">
                        <BlurFade DelayMs="0">
                            <Flex Align="center" Justify="between" Wrap="true" Gap="2" Class="mb-4">
                                <Lumeo.Text Size="sm" Color="muted">Drag cards between columns · Q3 delivery sprint</Lumeo.Text>
                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="@(() => Toast.Info("New card", "This is a demo — cards are seeded in-memory."))">
                                    <DynamicIcon Name="Plus" Class="mr-2 h-3.5 w-3.5" /> New card
                                </Button>
                            </Flex>
                        </BlurFade>
                        <BlurFade DelayMs="80">
                            <div class="overflow-x-auto pb-2">
                                <Kanban Class="!p-0 !gap-3 min-w-[900px]">
                                    @BoardColumn("To do", _todo)
                                    @BoardColumn("In progress", _doing)
                                    @BoardColumn("In review", _review)
                                    @BoardColumn("Done", _done)
                                    <KanbanColumn Title="Archived" Badge="_archived.Count"
                                                  Class="flex flex-1 min-w-0 flex-col rounded-lg border border-border/40 bg-background min-h-[130px]"
                                                  OnDrop="@(_ => MoveCard(_archived, "Archived"))">
                                        @if (_archived.Count == 0)
                                        {
                                            <EmptyState Title="Nothing archived" Description="Drag a finished card here to archive it." Class="py-8">
                                                <IconContent><DynamicIcon Name="Archive" Class="h-8 w-8" /></IconContent>
                                            </EmptyState>
                                        }
                                        else
                                        {
                                            @foreach (var card in _archived)
                                            {
                                                @DraggableCard(card)
                                            }
                                        }
                                    </KanbanColumn>
                                </Kanban>
                            </div>
                        </BlurFade>
                    </div>
                }
                else if (_view == "customers")
                {
                    <div @key="'c'">
                        <BlurFade DelayMs="0">
                            <Lumeo.Text Size="sm" Color="muted" Class="mb-3 block">@FilteredCustomers.Count of @_customers.Count accounts · drag a column header onto the group panel, reorder headers, pin, filter and expand a row for the full profile. Ungrouped rows virtualize for scroll performance.</Lumeo.Text>
                        </BlurFade>

                        <!-- CRM controls: lifecycle quick-filter chips + density toggle.
                             Grouping now lives in the grid's own drag-to-group panel
                             (ShowGroupPanel="true") — drag a Groupable column header onto
                             it, or use its "Add group level" dropdown — so the standalone
                             group-by Select is gone. -->
                        <div class="mb-3">
                            <Flex Align="center" Justify="between" Wrap="true" Gap="3">
                                <div class="flex flex-wrap items-center gap-1.5" role="group" aria-label="Filter by lifecycle stage">
                                    @foreach (var chip in _statusChips)
                                    {
                                        var active = _statusFilter == chip.Key;
                                        <button type="button" @onclick="() => SetStatusFilter(chip.Key)" aria-pressed="@active"
                                                class="@ChipClass(active)">
                                            @if (chip.Key != "all")
                                            {
                                                <span class="h-1.5 w-1.5 shrink-0 rounded-full @chip.Dot"></span>
                                            }
                                            <span>@chip.Label</span>
                                            <span class="tabular-nums opacity-60">@StatusCount(chip.Key)</span>
                                        </button>
                                    }
                                </div>

                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="ToggleDensity"
                                        Class="shrink-0" title="Toggle row density">
                                    <DynamicIcon Name="@(_gridCompact ? "List" : "LayoutList")" Class="mr-2 h-3.5 w-3.5" />
                                    <span>@(_gridCompact ? "Compact" : "Comfortable")</span>
                                </Button>
                            </Flex>
                        </div>

                        <BlurFade DelayMs="60">
                            <div class="@_densityWrapClass rounded-xl border border-border/50 bg-card p-2 sm:p-3">
                                <DataGrid TItem="NorthlightCustomer" Items="FilteredCustomers"
                                          GroupsExpandedByDefault="false"
                                          ShowGroupPanel="true"
                                          GroupPanelText="Drag a column header here — or use Add group level — to roll accounts up by Plan, Status, Region or Owner."
                                          ShowPagination="false" Height="calc(100dvh - 320px)"
                                          ShowToolbar="true" ShowSearch="true" ShowColumnChooser="true" ShowExport="false"
                                          Striped="true" Hoverable="true" Compact="_gridCompact" Reorderable="true"
                                          VirtualizeThreshold="200" VirtualItemSize="@(_gridCompact ? 40f : 52f)"
                                          DetailTemplate="CustomerDetail">
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Company" Field="Company" Sortable="true" Filterable="true"
                                                       Pin="PinDirection.Left" Pinnable="true" MinWidth="240">
                                        <CellTemplate Context="c">
                                            <Flex Align="center" Gap="2" Class="min-w-0">
                                                <Avatar Size="Lumeo.Size.Sm" Class="shrink-0">
                                                    <AvatarFallback>@Monogram(c.Company)</AvatarFallback>
                                                </Avatar>
                                                <Stack Gap="0" Class="min-w-0">
                                                    <Lumeo.Text Size="sm" Weight="medium" Class="truncate leading-tight">@c.Company</Lumeo.Text>
                                                    <Lumeo.Text As="span" Size="xs" Color="muted" Class="truncate leading-tight">@c.ContactEmail</Lumeo.Text>
                                                </Stack>
                                            </Flex>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Plan" Field="Plan" Sortable="true" Filterable="true"
                                                       FilterType="DataGridFilterType.Select" FilterOptions="_planOptions" Groupable="true">
                                        <CellTemplate Context="c">
                                            <Badge Variant="@PlanVariant(c.Plan)">@c.Plan</Badge>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Status" Field="Status" Sortable="true" Filterable="true"
                                                       FilterType="DataGridFilterType.Select" FilterOptions="_statusOptions" Groupable="true">
                                        <CellTemplate Context="c">
                                            <Badge Variant="@StatusVariant(c.Status)">@c.Status</Badge>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Health" Field="Health" Sortable="true">
                                        <CellTemplate Context="c">
                                            <span class="@HealthClass(c.Health)">
                                                <span class="h-1.5 w-1.5 rounded-full @HealthDot(c.Health)"></span>
                                                @HealthLabel(c.Health)
                                                <span class="tabular-nums opacity-70">@c.Health</span>
                                            </span>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="MRR ($/mo)" Field="Mrr" Sortable="true"
                                                       Format="N0" Aggregate="AggregateType.Sum" FooterFormat="N0" MinWidth="140">
                                        <CellTemplate Context="c">
                                            <Flex Align="center" Gap="2" Justify="end" Class="tabular-nums">
                                                <span class="font-medium">@c.Mrr.ToString("N0")</span>
                                                @if (c.Mrr > 0)
                                                {
                                                    <span class="@DeltaClass(c.MrrDelta)">
                                                        <DynamicIcon Name="@(c.MrrDelta >= 0 ? "TrendingUp" : "TrendingDown")" Class="h-3 w-3" />
                                                        @Math.Abs(c.MrrDelta)%
                                                    </span>
                                                }
                                            </Flex>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Seats" Field="Seats" Sortable="true" Format="N0" Aggregate="AggregateType.Sum" />
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Region" Field="Region" Sortable="true" Filterable="true"
                                                       FilterType="DataGridFilterType.Select" FilterOptions="_regionOptions" Groupable="true" />
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Owner" Field="Owner" Sortable="true" Filterable="true"
                                                       FilterType="DataGridFilterType.Select" FilterOptions="_ownerOptions" Groupable="true">
                                        <CellTemplate Context="c">
                                            <Flex Align="center" Gap="2" Class="min-w-0">
                                                <span class="inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-accent/60 text-[10px] font-semibold text-foreground">@Initials(c.Owner)</span>
                                                <Lumeo.Text Size="sm" Class="truncate">@c.Owner</Lumeo.Text>
                                            </Flex>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Last seen" Field="LastSeenDays" Sortable="true">
                                        <CellTemplate Context="c">
                                            <span class="@LastSeenClass(c.LastSeenDays)">@LastSeenLabel(c.LastSeenDays)</span>
                                        </CellTemplate>
                                    </DataGridColumnDef>
                                    <DataGridColumnDef TItem="NorthlightCustomer" Title="Signed up" Field="Signup" Sortable="true" Format="MMM d, yyyy" />
                                </DataGrid>
                            </div>
                        </BlurFade>
                    </div>
                }
                else if (_view == "settings")
                {
                    <div @key="'s'" class="mx-auto max-w-5xl">
                        <BlurFade DelayMs="0">
                            <div class="grid grid-cols-1 gap-5 lg:grid-cols-3 lg:items-start">
                            <div class="min-w-0 lg:col-span-2">
                            <Tabs @bind-ActiveValue="_settingsTab">
                                <TabsList>
                                    <TabsTrigger Value="profile">Profile</TabsTrigger>
                                    <TabsTrigger Value="notifications">Notifications</TabsTrigger>
                                    <TabsTrigger Value="billing">Billing</TabsTrigger>
                                </TabsList>

                                <TabsContent Value="profile">
                                    <Card>
                                        <CardHeader>
                                            <CardTitle>Profile</CardTitle>
                                            <CardDescription>Update how you appear across the Northlight workspace.</CardDescription>
                                        </CardHeader>
                                        <CardContent>
                                            <Stack Gap="4">
                                                <FormField Label="Full name" Required="true" Error="@_nameError">
                                                    <Input @bind-Value="_name" Placeholder="Your name" />
                                                </FormField>
                                                <FormField Label="Email" Required="true" Error="@_emailError">
                                                    <Input @bind-Value="_email" type="email" Placeholder="you@company.com" />
                                                </FormField>
                                                <FormField Label="Role">
                                                    <Select @bind-Value="_role" Placeholder="Select a role">
                                                        <SelectTrigger><span>@(_role ?? "Select a role")</span></SelectTrigger>
                                                        <SelectContent>
                                                            <SelectItem Value="admin">Admin</SelectItem>
                                                            <SelectItem Value="editor">Editor</SelectItem>
