@page "/components/otp-input"

<PageTitle>OTP Input — Lumeo</PageTitle>

<PageHeader Title="OTP Input" Description="A one-time password input with auto-focus and auto-advance between fields." />

<InstallUsage Component="OtpInput" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Verification code entry for email or SMS confirmation</li>
        <li>Two-factor authentication (2FA) flows</li>
        <li>PIN entry screens for secure access</li>
        <li>Any scenario requiring a fixed-length numeric or alphanumeric code</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default (6 digits)" Code="@_defaultCode">
        <Stack Gap="4" Align="center">
            <OtpInput @bind-Value="_otpValue" OnComplete="HandleComplete" />
            @if (!string.IsNullOrEmpty(_otpValue))
            {
                <Lumeo.Text Size="sm" Color="muted">Value: @_otpValue</Lumeo.Text>
            }
            @if (_completed)
            {
                <Badge Variant="Badge.BadgeVariant.Success">Code entered</Badge>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="2FA Verification" Code="@_tfaCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="leading-none tracking-tight">Two-factor authentication</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Enter the 6-digit code from your authenticator app.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4" Align="center">
                        <OtpInput @bind-Value="_tfaValue" OnComplete="HandleTfa" />
                        @if (_tfaVerified)
                        {
                            <Badge Variant="Badge.BadgeVariant.Success">
                                <DynamicIcon Name="Check" Class="h-3 w-3 mr-1" /> Verified
                            </Badge>
                        }
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Button Class="w-full" Disabled="@(_tfaValue.Length < 6)">Verify</Button>
                </CardFooter>
            </Card>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="4 Digit Code" Code="@_fourDigitCode">
        <Stack Gap="4" Align="center">
            <OtpInput @bind-Value="_shortOtp" Length="4" />
            @if (!string.IsNullOrEmpty(_shortOtp))
            {
                <Lumeo.Text Size="sm" Color="muted">Value: @_shortOtp</Lumeo.Text>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Variable Length" Description="Dynamically change the number of OTP digits." Code="@_lengthCode">
        <Stack Gap="3">
            <Flex Align="center" Gap="3" Wrap="true">
                <Lumeo.Text Size="sm" Weight="medium">Length:</Lumeo.Text>
                <Segmented @bind-Value="_otpLength">
                    <SegmentedItem Value="4">4 digits</SegmentedItem>
                    <SegmentedItem Value="6">6 digits</SegmentedItem>
                    <SegmentedItem Value="8">8 digits</SegmentedItem>
                </Segmented>
            </Flex>
            <Stack Gap="2" Align="center">
                <OtpInput Length="@(int.Parse(_otpLength))" Value="@_otpLengthValue" ValueChanged="@(v => _otpLengthValue = v)" />
                @if (!string.IsNullOrEmpty(_otpLengthValue))
                {
                    <Lumeo.Text Size="sm" Color="muted">Value: @_otpLengthValue</Lumeo.Text>
                }
            </Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Masked (PIN)" Code="@_maskedCode">
        <Stack Gap="2" Align="center">
            <OtpInput Length="4" Masked="true" @bind-Value="_maskedOtp" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Grouped with Separator" Code="@_groupedCode">
        <Stack Gap="2" Align="center">
            <OtpInput Length="6" GroupSizes="@(new[] { 3, 3 })" Separator="-" @bind-Value="_groupedOtp" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Alphanumeric" Code="@_alphaCode">
        <Stack Gap="2" Align="center">
            <OtpInput Length="6" InputMode="Alphanumeric" @bind-Value="_alphaOtp" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Stack Gap="2" Align="center">
            <OtpInput Length="6" Disabled="true" Value="123456" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Invalid State" Code="@_invalidCode">
        <Stack Gap="2" Align="center">
            <OtpInput Length="6" Invalid="true" ErrorText="That code didn't match. Try again." Value="000000" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Paste Support" Code="@_pasteCode">
        <Stack Gap="3">
            <Lumeo.Text Size="sm" Color="muted">Try pasting a code like "123456" into any field</Lumeo.Text>
            <OtpInput Length="6" @bind-Value="_pasteOtp" OnComplete="@HandlePasteComplete" />
            @if (!string.IsNullOrEmpty(_pasteResult))
            {
                <Lumeo.Text Size="sm" Class="text-green-600">Pasted code: @_pasteResult</Lumeo.Text>
            }
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="otpinput" Level="3" Class="mt-8 scroll-mt-20">OtpInput</Heading>
    <div class="mt-4">
        <PropsTable Slug="otp-input" />
    </div>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — Standard text input for general free-form text</li>
        <li><a href="/components/password-input" class="text-primary hover:underline">PasswordInput</a> — Password field with visibility toggle and strength meter</li>
        <li><a href="/components/form" class="text-primary hover:underline">Form</a> — Combine OtpInput with form validation and labels</li>
    </ul>
</div>

@code {
    private string _otpValue = "";
    private string _shortOtp = "";
    private string _tfaValue = "";
    private bool _completed;
    private bool _tfaVerified;

    private void HandleComplete(string code)
    {
        _completed = true;
    }

    private void HandleTfa(string code)
    {
        _tfaVerified = true;
    }

    private string _defaultCode = @"<OtpInput @bind-Value=""_otpValue"" OnComplete=""HandleComplete"" />";

    private string _tfaCode = @"<Card>
    <CardHeader>
        <Heading Level=""3"">Two-factor authentication</Heading>
        <Lumeo.Text Size=""sm"" Color=""muted"">Enter the 6-digit code from your authenticator app.</Lumeo.Text>
    </CardHeader>
    <CardContent>
        <OtpInput @bind-Value=""_tfaValue"" OnComplete=""HandleTfa"" />
        @if (_tfaVerified)
        {
            <Badge Variant=""Badge.BadgeVariant.Success"">Verified</Badge>
        }
    </CardContent>
    <CardFooter>
        <Button Class=""w-full"" Disabled=""@(_tfaValue.Length < 6)"">Verify</Button>
    </CardFooter>
</Card>";

    private string _fourDigitCode = @"<OtpInput @bind-Value=""_otp"" Length=""4"" />";

    private string _maskedOtp = "";
    private string _groupedOtp = "";
    private string _alphaOtp = "";

    private string _maskedCode = @"<OtpInput Length=""4"" Masked=""true"" @bind-Value=""_pin"" />";

    private string _groupedCode = @"<OtpInput Length=""6"" GroupSizes=""@(new[] { 3, 3 })"" Separator=""-"" @bind-Value=""_otp"" />";

    private string _alphaCode = @"<OtpInput Length=""6"" InputMode=""Alphanumeric"" @bind-Value=""_otp"" />";

    private string _disabledCode = @"<OtpInput Length=""6"" Disabled=""true"" Value=""123456"" />";

    private string _invalidCode = @"<OtpInput Length=""6"" Invalid=""true"" ErrorText=""That code didn't match. Try again."" Value=""000000"" />";

    private string _otpLength = "6";
    private string _otpLengthValue = "";

    private string _lengthCode = @"<Segmented @bind-Value=""_otpLength"">
    <SegmentedItem Value=""4"">4 digits</SegmentedItem>
    <SegmentedItem Value=""6"">6 digits</SegmentedItem>
    <SegmentedItem Value=""8"">8 digits</SegmentedItem>
</Segmented>

<OtpInput Length=""@(int.Parse(_otpLength))"" Value=""@_otpValue"" ValueChanged=""@(v => _otpValue = v)"" />

@if (!string.IsNullOrEmpty(_otpValue))
{
    <Lumeo.Text Size=""sm"" Color=""muted"">Value: @_otpValue</Lumeo.Text>
}

@code {
    private string _otpLength = ""6"";
    private string _otpValue = """";
}";

    private string _pasteOtp = "";
    private string _pasteResult = "";

    private void HandlePasteComplete(string code)
    {
        _pasteResult = code;
    }

    private string _pasteCode = @"<Lumeo.Text Size=""sm"" Color=""muted"">Try pasting a code like ""123456"" into any field</Lumeo.Text>
<OtpInput Length=""6"" @bind-Value=""_pasteOtp"" OnComplete=""@HandlePasteComplete"" />
@if (!string.IsNullOrEmpty(_pasteResult))
{
    <Lumeo.Text Size=""sm"" Class=""text-green-600"">Pasted code: @_pasteResult</Lumeo.Text>
}

@code {
    private string _pasteOtp = """";
    private string _pasteResult = """";
    private void HandlePasteComplete(string code)
    {
        _pasteResult = code;
    }
}";
}
