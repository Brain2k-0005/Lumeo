@page "/components/pdf-viewer"

<PageTitle>PDF Viewer — Lumeo</PageTitle>

<PageHeader Title="PDF Viewer"
            Description="Inline PDF document viewer powered by Mozilla pdf.js — renders documents page-by-page on a canvas with page navigation, zoom controls, optional text search, and a download shortcut." />

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <ChildContent>
        <strong>Satellite package.</strong> The PdfViewer lives in
        <code>Lumeo.PdfViewer</code> — install it alongside the core <code>Lumeo</code> package.
        pdf.js is loaded on demand from jsDelivr the first time a PdfViewer mounts; no
        npm build step is required for consumers.
    </ChildContent>
</Alert>

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Embedding PDFs (contracts, invoices, reports) inline in a Blazor page</li>
        <li>Document preview surfaces where the browser's built-in viewer is too heavy or inconsistent</li>
        <li>Read-only flows that benefit from page navigation, zoom, and text search</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    <ComponentDemo Title="Basic" Code="@_basicCode">
        <PdfViewer Src="@SamplePdfUrl"
                   @bind-Page="_page"
                   @bind-Zoom="_zoom"
                   OnLoaded="HandleLoaded"
                   Class="h-[600px]" />
        <div class="mt-3 text-xs text-muted-foreground">
            Page @_page of @_totalPages — zoom @($"{(int)Math.Round(_zoom * 100)}%")
        </div>
    </ComponentDemo>

    <ComponentDemo Title="With search bar" Code="@_searchCode">
        <PdfViewer Src="@SamplePdfUrl"
                   ShowSearch="true"
                   Class="h-[600px]" />
    </ComponentDemo>

    <ComponentDemo Title="Toolbar-less (chromeless embed)" Code="@_chromelessCode">
        <PdfViewer Src="@SamplePdfUrl"
                   ShowToolbar="false"
                   Class="h-[500px]" />
    </ComponentDemo>

</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="pdf-viewer" Level="3" Class="mt-8 scroll-mt-20">PdfViewer</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[200px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">Src</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>PDF URL or <code>data:</code> URL. Required.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Page</TableCell><TableCell Class="font-mono text-xs">int</TableCell><TableCell Class="font-mono text-xs">1</TableCell><TableCell>1-based current page. Two-way bindable.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">PageChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;int&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Fires when the user navigates to a different page.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Zoom</TableCell><TableCell Class="font-mono text-xs">double</TableCell><TableCell Class="font-mono text-xs">1.0</TableCell><TableCell>Render scale clamped to [0.5, 4.0]. Two-way bindable.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ZoomChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;double&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Fires when the user changes zoom.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowToolbar</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">true</TableCell><TableCell>Hide the whole toolbar row for a chromeless embed.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowPageNav</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">true</TableCell><TableCell>Show prev/next + page input.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowZoomControls</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">true</TableCell><TableCell>Show ± zoom buttons and percentage.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowDownload</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">true</TableCell><TableCell>Show the download shortcut linking to <code>Src</code>.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowSearch</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Show the text-search input (returns total match count).</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">OnLoaded</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;int&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Fires once with the total page count when the PDF finishes loading.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">OnPageChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;int&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Non-binding alternative to <code>PageChanged</code>.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">OnError</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;string&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Fires when the PDF fails to load or render (CDN unreachable, malformed PDF, worker init failure). Receives the exception message; the built-in EmptyState fallback still renders.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Extra CSS classes on the root container.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

    <div class="mt-6 text-sm text-muted-foreground">
        <strong>Accessibility.</strong> The canvas wrapper renders <code>role="document"</code>
        with <code>aria-label="PDF document"</code> and a <code>tabindex="0"</code> so it
        receives keyboard focus. <kbd>PageDown</kbd> / <kbd>ArrowRight</kbd> advances, <kbd>PageUp</kbd> /
        <kbd>ArrowLeft</kbd> rewinds, and <kbd>+</kbd> / <kbd>-</kbd> zoom.
    </div>
</div>

@code {
    // Public Mozilla sample — small (13kB) and CORS-enabled, so the demo loads quickly.
    private const string SamplePdfUrl = "https://mozilla.github.io/pdf.js/web/compressed.tracemonkey-pldi-09.pdf";

    private int _page = 1;
    private double _zoom = 1.0;
    private int _totalPages;

    private void HandleLoaded(int total) => _totalPages = total;

    private string _basicCode = @"<PdfViewer Src=""@SamplePdfUrl""
           @bind-Page=""_page""
           @bind-Zoom=""_zoom""
           OnLoaded=""HandleLoaded""
           Class=""h-[600px]"" />";

    private string _searchCode = @"<PdfViewer Src=""@SamplePdfUrl""
           ShowSearch=""true""
           Class=""h-[600px]"" />";

    private string _chromelessCode = @"<PdfViewer Src=""@SamplePdfUrl""
           ShowToolbar=""false""
           Class=""h-[500px]"" />";
}
