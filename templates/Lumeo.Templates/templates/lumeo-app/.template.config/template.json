{
  "$schema": "http://json.schemastore.org/template",
  "author": "nativ.sh",
  "classifications": ["Blazor", "Lumeo", "Web", "WebAssembly"],
  "identity": "Lumeo.Templates.App",
  "name": "Lumeo Blazor WASM App",
  "shortName": "lumeo-app",
  "sourceName": "MyApp",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "symbols": {
    "auth": {
      "type": "parameter",
      "datatype": "choice",
      "allowMultipleValues": false,
      "displayName": "Authentication",
      "description": "How authentication is scaffolded into the app.",
      "defaultValue": "demo",
      "choices": [
        {
          "choice": "demo",
          "displayName": "Demo (localStorage)",
          "description": "A full auth UI — /login, /register, /forgot-password built from Lumeo's auth blocks — backed by an in-browser localStorage provider. No backend required; the whole app is protected and the sidebar shows the signed-in user."
        },
        {
          "choice": "none",
          "displayName": "None",
          "description": "No authentication. The original starter with public pages and a static sidebar user card."
        },
        {
          "choice": "oidc",
          "displayName": "OIDC / OAuth",
          "description": "Real OIDC wiring via Microsoft.AspNetCore.Components.WebAssembly.Authentication. Configure your authority in wwwroot/appsettings.json; the login UI reuses the same Lumeo auth layout."
        }
      ]
    },
    "AuthNone": {
      "type": "computed",
      "value": "(auth == \"none\")"
    },
    "AuthDemo": {
      "type": "computed",
      "value": "(auth == \"demo\")"
    },
    "AuthOidc": {
      "type": "computed",
      "value": "(auth == \"oidc\")"
    },
    "AuthEnabled": {
      "type": "computed",
      "value": "(auth != \"none\")"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/*.in"
          ]
        },
        {
          "condition": "(!AuthEnabled)",
          "exclude": [
            "Auth/**",
            "Layout/AuthLayout.razor",
            "Pages/Auth/**",
            "wwwroot/appsettings.json"
          ]
        },
        {
          "condition": "(!AuthDemo)",
          "exclude": [
            "Auth/DemoAuthenticationStateProvider.cs",
            "Pages/Auth/Login.razor",
            "Pages/Auth/Register.razor",
            "Pages/Auth/ForgotPassword.razor"
          ]
        },
        {
          "condition": "(!AuthOidc)",
          "exclude": [
            "Pages/Auth/Authentication.razor",
            "wwwroot/appsettings.json"
          ]
        }
      ]
    }
  ]
}
