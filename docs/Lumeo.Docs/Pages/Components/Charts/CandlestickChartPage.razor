@page "/components/charts/candlestick"

<PageTitle>Candlestick Chart — Lumeo</PageTitle>

<PageHeader Title="Candlestick Chart" Description="Display financial OHLC (Open, High, Low, Close) data. Essential for stock market analysis and price movement visualization." />

<Stack Gap="8">
    <ComponentDemo Title="Stock Price Candlestick" Code="@_basicCode">
        <Container>
            <CandlestickChart Categories="_categories" Data="_data" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">CandlestickChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis date/time labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;double[]&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">OHLC data as [open, close, low, high] arrays.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">DataZoom</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Enables zoom slider for scrolling through data.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Feb 17", "Feb 18", "Feb 19", "Feb 20", "Feb 21", "Feb 24", "Feb 25" };
    private List<double[]> _data = new()
    {
        new[] { 142.30, 148.50, 140.80, 149.20 },
        new[] { 148.00, 145.30, 143.60, 150.10 },
        new[] { 145.50, 151.80, 144.90, 153.40 },
        new[] { 151.20, 147.60, 145.30, 152.70 },
        new[] { 147.80, 153.20, 147.10, 154.80 },
        new[] { 153.00, 149.40, 148.20, 155.30 },
        new[] { 149.50, 156.10, 149.00, 157.20 }
    };

    private string _basicCode = @"<CandlestickChart Categories=""_categories"" Data=""_data"" />";
}
