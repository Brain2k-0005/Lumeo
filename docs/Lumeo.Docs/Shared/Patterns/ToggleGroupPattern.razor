@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Single Select" Code="@_codeToggleGroupSingle">
    <ToggleGroup Type="ToggleGroup.ToggleGroupType.Single">
        <ToggleGroupItem Value="left">
            <Blazicon Svg="Lucide.AlignStartHorizontal" class="h-4 w-4" />
        </ToggleGroupItem>
        <ToggleGroupItem Value="center">
            <Blazicon Svg="Lucide.AlignCenterHorizontal" class="h-4 w-4" />
        </ToggleGroupItem>
        <ToggleGroupItem Value="right">
            <Blazicon Svg="Lucide.AlignEndHorizontal" class="h-4 w-4" />
        </ToggleGroupItem>
    </ToggleGroup>
</PatternCard>

<PatternCard Label="Multiple Select" Code="@_codeToggleGroupMultiple">
    <ToggleGroup Type="ToggleGroup.ToggleGroupType.Multiple">
        <ToggleGroupItem Value="bold">
            <Blazicon Svg="Lucide.Bold" class="h-4 w-4" />
        </ToggleGroupItem>
        <ToggleGroupItem Value="italic">
            <Blazicon Svg="Lucide.Italic" class="h-4 w-4" />
        </ToggleGroupItem>
        <ToggleGroupItem Value="underline">
            <Blazicon Svg="Lucide.Underline" class="h-4 w-4" />
        </ToggleGroupItem>
    </ToggleGroup>
</PatternCard>
</Stack>

@code {
        private string _codeToggleGroupSingle = @"<ToggleGroup Type=""ToggleGroup.ToggleGroupType.Single"">
        <ToggleGroupItem Value=""left"">
            <Blazicon Svg=""Lucide.AlignLeft"" class=""h-4 w-4"" />
        </ToggleGroupItem>
        <ToggleGroupItem Value=""center"">
            <Blazicon Svg=""Lucide.AlignCenter"" class=""h-4 w-4"" />
        </ToggleGroupItem>
        <ToggleGroupItem Value=""right"">
            <Blazicon Svg=""Lucide.AlignRight"" class=""h-4 w-4"" />
        </ToggleGroupItem>
    </ToggleGroup>";

        private string _codeToggleGroupMultiple = @"<ToggleGroup Type=""ToggleGroup.ToggleGroupType.Multiple"">
        <ToggleGroupItem Value=""bold"">
            <Blazicon Svg=""Lucide.Bold"" class=""h-4 w-4"" />
        </ToggleGroupItem>
        <ToggleGroupItem Value=""italic"">
            <Blazicon Svg=""Lucide.Italic"" class=""h-4 w-4"" />
        </ToggleGroupItem>
        <ToggleGroupItem Value=""underline"">
            <Blazicon Svg=""Lucide.Underline"" class=""h-4 w-4"" />
        </ToggleGroupItem>
    </ToggleGroup>";
}
