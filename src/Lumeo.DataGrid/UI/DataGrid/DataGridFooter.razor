@namespace Lumeo
@typeparam TItem
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@*  3.0.4 — moved OUT of the <table> into a sibling strip below the scrolling
    table wrapper. CSS `position: sticky` inside <tfoot> turned out unreliable
    across browsers AND only worked when the table itself was actually
    scrolling. Rendering as a sibling div pins the aggregate row to the bottom
    of the DataGrid card regardless of row count. role="row" + sr-only label
    keeps it accessible to screen readers. *@
@if (Context is not null && HasAggregates)
{
    <div data-slot="datagrid-aggregate-strip"
         role="status"
         aria-live="polite"
         aria-label="@L["DataGrid.AggregateRow"]"
         class="@CssClass flex items-center border-t border-border/40 bg-muted/60 px-3 py-2 text-xs font-medium text-muted-foreground"
         @attributes="AdditionalAttributes">
        @foreach (var column in Context.VisibleColumns.Where(c => c.Aggregate != AggregateType.None))
        {
            <div @key="column.Id" class="flex-1 min-w-0 px-2">
                <span class="text-foreground/70 mr-1">@GetAggregateLabel(column.Aggregate):</span>
                <span class="font-mono text-foreground">@ComputeAggregate(column)</span>
            </div>
        }
    </div>
}

@code {
    [CascadingParameter] private DataGridContext<TItem>? Context { get; set; }
    [Parameter] public IReadOnlyList<TItem>? AllItems { get; set; }
    [Parameter] public bool HasDetailTemplate { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"{Class}".Trim();

    private bool HasAggregates => Context?.Columns.Any(c => c.Visible && c.Aggregate != AggregateType.None) ?? false;

    private IEnumerable<TItem> ItemsForAggregate => AllItems ?? Context?.DisplayedItems ?? Enumerable.Empty<TItem>();

    private string ComputeAggregate(DataGridColumn<TItem> column)
    {
        var items = ItemsForAggregate.ToList();
        if (items.Count == 0) return "-";

        var values = items.Select(i => column.GetValue(i)).Where(v => v is not null).ToList();
        // FooterFormat wins; falls back to the cell Format; "N2" is the historic default
        // when neither is set so existing grids keep their familiar 2-decimal totals.
        var format = column.FooterFormat ?? column.Format ?? "N2";

        return column.Aggregate switch
        {
            AggregateType.Count => values.Count.ToString(),
            AggregateType.Sum => ComputeNumeric(values, vals => vals.Sum(), format),
            AggregateType.Average => ComputeNumeric(values, vals => vals.Average(), format),
            AggregateType.Min => ComputeNumeric(values, vals => vals.Min(), format),
            AggregateType.Max => ComputeNumeric(values, vals => vals.Max(), format),
            _ => ""
        };
    }

    private string ComputeNumeric(List<object?> values, Func<IEnumerable<double>, double> aggregator, string format)
    {
        var numericValues = new List<double>();
        foreach (var v in values)
        {
            if (v is IConvertible conv)
            {
                try
                {
                    numericValues.Add(conv.ToDouble(System.Globalization.CultureInfo.InvariantCulture));
                }
                catch
                {
                    // Skip non-numeric values
                }
            }
        }

        if (numericValues.Count == 0) return "-";
        // Use the grid's cascaded Culture so footer totals format the same way the cells do
        // (DataGrid.Culture lets a single grid render in a non-app-default locale; without
        // this footer-side override we'd silently fall back to CultureInfo.CurrentCulture
        // and mismatch the column's own cell formatting).
        var culture = Context?.Culture ?? System.Globalization.CultureInfo.CurrentCulture;
        return aggregator(numericValues).ToString(format, culture);
    }

    private string GetAggregateLabel(AggregateType aggregate) => aggregate switch
    {
        AggregateType.Sum => L["DataGrid.AggregateSum"],
        AggregateType.Average => L["DataGrid.AggregateAvg"],
        AggregateType.Count => L["DataGrid.AggregateCount"],
        AggregateType.Min => L["DataGrid.AggregateMin"],
        AggregateType.Max => L["DataGrid.AggregateMax"],
        _ => ""
    };
}
