    private int _focusedRow = -1;
    private int _focusedCol = 0;
    // Approximate "page" jump for PageUp/PageDown in rows.
    private int KeyboardPageStep => Math.Max(1, Math.Min(PageSize, 10));

    private string CellElementId(int row, int col) => $"{_gridId}-cell-{(row < 0 ? "h" : row.ToString())}-{col}";

    // --- Selective keydown preventDefault (battle-test n=8) ---
    // The roving-tabindex grid handles Arrow/Home/End/PageUp/PageDown to move the
    // focused cell, and Space to toggle selection. Without suppressing the browser
    // default these keys ALSO scroll the page/scroll-container, fighting the cell
    // navigation. We can't use @onkeydown:preventDefault on the <td>/<th> because
    // that directive's value is fixed at render time and would also swallow Tab
    // (which must stay live to leave the grid). Instead we register a key-selective
    // native preventDefault on the table once it's in the DOM — same idiom as
    // Select/DateTimePicker/Calendar. SkipEditable keeps the inline-edit <input>'s
    // caret/typing keys (and its own Tab/Enter/Escape handling) untouched, since
    // those keydowns originate inside the editor input.
    private bool _navKeysPrevented;
    private static readonly Lumeo.Services.PreventDefaultKeyRule[] NavKeyRules =
    [
        new("ArrowDown",  SkipEditable: true),
        new("ArrowUp",    SkipEditable: true),
        new("ArrowLeft",  SkipEditable: true),
        new("ArrowRight", SkipEditable: true),
        new("Home",       SkipEditable: true),
        new("End",        SkipEditable: true),
        new("PageDown",   SkipEditable: true),
        new("PageUp",     SkipEditable: true),
        new(" ",          SkipEditable: true),
        new("Spacebar",   SkipEditable: true),
    ];

    /// <summary>Clamp the roving-focus coordinates to the current data extents.
    /// Called after any data/sort/filter/page change so the stored cell never
    /// dangles past the visible range.</summary>
    private void ClampFocusedCell()
    {
        var colCount = _visibleColumns.Count;
        if (colCount == 0) { _focusedCol = 0; _focusedRow = -1; return; }
        if (_focusedCol < 0) _focusedCol = 0;
        if (_focusedCol >= colCount) _focusedCol = colCount - 1;
        var rowCount = _displayedItems.Count;
        if (_focusedRow < -1) _focusedRow = -1;
        if (_focusedRow >= rowCount) _focusedRow = rowCount - 1; // may land on -1 if no rows
    }

    private async Task MoveFocusAsync(int newRow, int newCol)
    {
        var colCount = _visibleColumns.Count;
        if (colCount == 0) return;
        newCol = Math.Clamp(newCol, 0, colCount - 1);
        var rowCount = _displayedItems.Count;
        // Allow -1 (header). Don't allow going past last body row.
        if (newRow < -1) newRow = -1;
        if (newRow > rowCount - 1) newRow = Math.Max(-1, rowCount - 1);
        if (newRow == _focusedRow && newCol == _focusedCol)
        {
            // Still re-focus the DOM element (e.g. Home pressed twice).
            await FocusCellAsync(newRow, newCol);
            return;
        }
        _focusedRow = newRow;
        _focusedCol = newCol;
        StateHasChanged();
        await FocusCellAsync(newRow, newCol);
    }

    private async Task FocusCellAsync(int row, int col)
    {
        try { await Interop.FocusElement(CellElementId(row, col)); }
        catch (Microsoft.JSInterop.JSDisconnectedException) { /* circuit gone */ }
        catch { /* element may not be rendered (virtualized / grouped) — acceptable */ }
    }

    /// <summary>Keydown handler invoked from a body <see cref="DataGridCell{TItem}"/>
    /// whose <c>&lt;td&gt;</c> currently has focus.</summary>
    internal async Task HandleCellKeyDownAsync(int row, int col, KeyboardEventArgs e)
    {
        // Keep our notion of the focused cell in sync with where the event came from.
        _focusedRow = row;
        _focusedCol = col;
        var colCount = _visibleColumns.Count;
        var rowCount = _displayedItems.Count;
        if (colCount == 0) return;

        switch (e.Key)
        {
            case "ArrowDown":
                await MoveFocusAsync(row + 1, col);
                break;
            case "ArrowUp":
                // From the first body row, jump up into the header row.
                await MoveFocusAsync(row <= 0 ? -1 : row - 1, col);
                break;
            case "ArrowRight":
                await MoveFocusAsync(row, col + 1);
                break;
            case "ArrowLeft":
                await MoveFocusAsync(row, col - 1);
                break;
            case "Home":
                if (e.CtrlKey) await MoveFocusAsync(0, 0);
                else await MoveFocusAsync(row, 0);
                break;
            case "End":
                if (e.CtrlKey) await MoveFocusAsync(rowCount - 1, colCount - 1);
                else await MoveFocusAsync(row, colCount - 1);
                break;
            case "PageDown":
                await MoveFocusAsync(row + KeyboardPageStep, col);
                break;
            case "PageUp":
                // Clamp to -1 (header band) instead of 0, so PageUp on row 0
                // moves focus up to the column-header row instead of being a
                // no-op. MoveFocusAsync already understands row=-1 as the
                // header (line 684).
                await MoveFocusAsync(Math.Max(-1, row - KeyboardPageStep), col);
                break;
            case " ":
            case "Spacebar":
                if (SelectionMode != DataGridSelectionMode.None && row >= 0 && row < rowCount)
                {
                    ToggleSelection(_displayedItems[row]);
                }
                break;
            case "a":
            case "A":
                if (e.CtrlKey && SelectionMode == DataGridSelectionMode.Multiple)
                {
                    SelectAll();
                }
                break;
            // Enter / F2 (enter edit mode) are handled inside DataGridCell itself
            // because that's where the per-cell edit state lives.
        }
    }

    /// <summary>Keydown handler invoked from a header <see cref="DataGridHeaderCell{TItem}"/>.</summary>
    internal async Task HandleHeaderKeyDownAsync(int col, KeyboardEventArgs e)
    {
        _focusedRow = -1;
        _focusedCol = col;
        var colCount = _visibleColumns.Count;
        if (colCount == 0) return;

        switch (e.Key)
        {
            case "ArrowRight":
                await MoveFocusAsync(-1, col + 1);
                break;
            case "ArrowLeft":
                await MoveFocusAsync(-1, col - 1);
                break;
            case "ArrowDown":
                await MoveFocusAsync(0, col);
                break;
            case "Home":
                await MoveFocusAsync(-1, 0);
                break;
            case "End":
                await MoveFocusAsync(-1, colCount - 1);
                break;
            // Enter / Space → trigger sort is handled inside DataGridHeaderCell.
        }
    }

    private async ValueTask<Microsoft.AspNetCore.Components.Web.Virtualization.ItemsProviderResult<DataGridBody<TItem>.IndexedItem>>
        ServerVirtualizationProviderImpl(Microsoft.AspNetCore.Components.Web.Virtualization.ItemsProviderRequest req)
    {
        if (OnRangeRequest is null)
        {
            return new Microsoft.AspNetCore.Components.Web.Virtualization.ItemsProviderResult<DataGridBody<TItem>.IndexedItem>(
                Array.Empty<DataGridBody<TItem>.IndexedItem>(), 0);
        }
        var rangeRequest = new DataGridRangeRequest(
            req.StartIndex,
            req.Count,
            _sorts.Count > 0 ? new List<SortDescriptor>(_sorts) : null,
            _filters.Count > 0 ? new List<FilterDescriptor>(_filters) : null,
            _globalSearch,
            req.CancellationToken);
        var resp = await OnRangeRequest(rangeRequest);
        var indexed = resp.Items
            .Select((it, i) => new DataGridBody<TItem>.IndexedItem(it, req.StartIndex + i))
            .ToList();
        TotalCount = resp.TotalCount;
        return new Microsoft.AspNetCore.Components.Web.Virtualization.ItemsProviderResult<DataGridBody<TItem>.IndexedItem>(
            indexed, resp.TotalCount);
    }

    /// <summary>
    /// Forces the virtualised server view to discard its window cache and
    /// refetch from the current scroll position. Called automatically when
    /// sort/filter/search change; expose as <c>@ref</c> if you need to
    /// trigger it manually (e.g. after an external data mutation).
    /// </summary>
    public Task RefreshVirtualizedAsync() =>
        _bodyRef is not null ? _bodyRef.RefreshVirtualizeAsync() : Task.CompletedTask;

    private List<DataGridColumn<TItem>> _columnDefs = new();
    private List<DataGridColumn<TItem>> _orderedColumns = new();
    // Cached visible-columns projection — recomputed only when columns change or
    // visibility is toggled, not on every Blazor render cycle.
    private System.Collections.ObjectModel.ReadOnlyCollection<DataGridColumn<TItem>> _visibleColumns =
        new List<DataGridColumn<TItem>>().AsReadOnly();

    private void RefreshVisibleColumns()
    {
        // Pinned columns must be PHYSICALLY partitioned in the render/DOM order —
        // left-pinned first, unpinned in the middle, right-pinned last — because
        // `position: sticky` can only anchor a cell to a scroll-container edge; it
        // cannot relocate the cell across its siblings. A right-pinned column left
        // in its declared position (e.g. the leading column) would keep rendering
        // on the LEFT while carrying a `right:` offset that never visually engages —
        // the exact "pin right ends up on the left" defect. LINQ OrderBy is a stable
        // sort, so each pin group keeps its relative order; partitioning here — the
        // single chokepoint every pin path funnels through (column chooser, header
        // pin control, restored layouts, declared pins, drag-reorder) — makes the
        // DOM order match the sticky edge everywhere at once. Idempotent: an
        // already-partitioned order sorts to itself, so the frequent parameter-set
        // refreshes cost only a stable sort over the (small) column list.
        _orderedColumns = _orderedColumns
            .OrderBy(c => c.Pin switch { PinDirection.Left => 0, PinDirection.Right => 2, _ => 1 })
            .ToList();

        IEnumerable<DataGridColumn<TItem>> q = _orderedColumns.Where(c => c.Visible);
        // Simplified column virtualization (rc.36): cap the rendered-column
        // count to keep wide grids cheap. Pinned columns always make the cut;
        // unpinned columns are taken in order until MaxVisibleColumns is hit.
        if (ColumnVirtualize && MaxVisibleColumns > 0)
        {
            var all = q.ToList();
            if (all.Count > MaxVisibleColumns)
            {
                var pinned = all.Where(c => c.Pin != PinDirection.None).ToList();
                var unpinned = all.Where(c => c.Pin == PinDirection.None).ToList();
                var roomForUnpinned = Math.Max(0, MaxVisibleColumns - pinned.Count);
                q = pinned.Concat(unpinned.Take(roomForUnpinned));
            }
            else
            {
                q = all;
            }
        }
        _visibleColumns = q.ToList().AsReadOnly();
    }
