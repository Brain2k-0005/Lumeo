@inject ToastService ToastService

@code {
    // -- Dismiss & Update state --
    private string? _lastDismissableId;
    private string? _updatableId;

    // ==============================
    // Section 3: With Options
    // ==============================

    private void ShowWithAction()
    {
        ToastService.Show(new ToastOptions
        {
            Title = "Message archived",
            Description = "1 conversation moved to archive.",
            ActionLabel = "Undo",
            OnAction = () => ToastService.Info("Restored", "Message moved back to inbox."),
            Duration = 8000
        });
    }

    private void ShowPersistent()
    {
        var id = ToastService.Show(new ToastOptions
        {
            Title = "Processing payment...",
            Description = "Please do not close this page.",
            Variant = ToastVariant.Info,
            Dismissible = false,
            Duration = 0
        });

        // Auto-resolve after 4 seconds for the demo
        _ = Task.Delay(4000).ContinueWith(_ =>
        {
            ToastService.Update(id, new ToastOptions
            {
                Title = "Payment processed!",
                Description = "Your receipt has been emailed.",
                Variant = ToastVariant.Success,
                Dismissible = true,
                Duration = 4000
            });
        });
    }

    private void ShowLongDuration()
    {
        ToastService.Show(new ToastOptions
        {
            Title = "Deployment started",
            Description = "Building and deploying to production...",
            Variant = ToastVariant.Info,
            Duration = 10000
        });
    }

    private void ShowCustomClass()
    {
        ToastService.Show(new ToastOptions
        {
            Title = "Styled toast",
            Description = "This toast has a custom border style.",
            Class = "border-2 border-primary"
        });
    }

    private void ShowWithDismissCallback()
    {
        ToastService.Show(new ToastOptions
        {
            Title = "Feedback requested",
            Description = "Rate your experience before this disappears.",
            OnDismiss = () => ToastService.Info("Callback fired", "OnDismiss was invoked."),
            Duration = 6000
        });
    }

    // ==============================
    // Section 4: Dismiss & Update
    // ==============================

    private void ShowDismissable()
    {
        _lastDismissableId = ToastService.Show(new ToastOptions
        {
            Title = "Persistent notification",
            Description = "Click 'Dismiss It' to remove this toast.",
            Duration = 0
        });
    }

    private void DismissLast()
    {
        if (_lastDismissableId is not null)
        {
            ToastService.Dismiss(_lastDismissableId);
            _lastDismissableId = null;
        }
    }

    private void ShowMultipleToasts()
    {
        ToastService.Show("First toast", "This is toast #1.");
        ToastService.Success("Second toast", "This is toast #2.");
        ToastService.Info("Third toast", "This is toast #3.");
    }

    private void ShowUpdatable()
    {
        _updatableId = ToastService.Show(new ToastOptions
        {
            Title = "Connecting...",
            Description = "Establishing connection to server.",
            Variant = ToastVariant.Default,
            Duration = 0
        });
    }

    private void UpdateToast()
    {
        if (_updatableId is not null)
        {
            ToastService.Update(_updatableId, new ToastOptions
            {
                Title = "Connected!",
                Description = "You are now online.",
                Variant = ToastVariant.Success,
                Duration = 4000
            });
            _updatableId = null;
        }
    }

    private void ShowUploadProgress()
    {
        var id = ToastService.Show(new ToastOptions
        {
            Title = "Uploading file...",
            Description = "report-q4.pdf (2.3 MB)",
            Dismissible = false,
            Duration = 0
        });

        _ = Task.Delay(3000).ContinueWith(_ =>
        {
            ToastService.Update(id, new ToastOptions
            {
                Title = "Upload complete!",
                Description = "report-q4.pdf uploaded successfully.",
                Variant = ToastVariant.Success,
                Dismissible = true,
                Duration = 4000
            });
        });
    }

    // ==============================
    // Section 5: Promise Toast
    // ==============================

    private async Task ShowPromiseSuccess()
    {
        await ToastService.Promise(
            action: async () =>
            {
                await Task.Delay(2500);
                return new { OrderId = 1042 };
            },
            loading: new ToastOptions
            {
                Title = "Placing order...",
                Description = "Processing your payment."
            },
            success: result => new ToastOptions
            {
                Title = "Order confirmed!",
                Description = $"Order #{result.OrderId} is on its way.",
                Variant = ToastVariant.Success,
                Duration = 5000
            },
            error: ex => new ToastOptions
            {
                Title = "Order failed",
                Description = ex.Message,
                Variant = ToastVariant.Destructive
            }
        );
    }

    private async Task ShowPromiseError()
    {
        await ToastService.Promise(
            action: async () =>
            {
                await Task.Delay(2000);
                throw new InvalidOperationException("403 Forbidden — insufficient permissions");
#pragma warning disable CS0162
                return false;
#pragma warning restore CS0162
            },
            loading: new ToastOptions
            {
                Title = "Deleting resource...",
                Description = "Removing item from server."
            },
            success: _ => new ToastOptions
            {
                Title = "Deleted",
                Variant = ToastVariant.Success
            },
            error: ex => new ToastOptions
            {
                Title = "Delete failed",
                Description = $"Server returned: {ex.Message}",
                Variant = ToastVariant.Destructive,
                Duration = 8000
            }
        );
    }

    // ==============================
    // Section 6: Custom Content
    // ==============================

    private void ShowCustomContent()
    {
        ToastService.Show(new ToastOptions
        {
            CustomContent = @<div class="flex items-center gap-3">
                <Avatar Fallback="JD" Size="Avatar.AvatarSize.Sm" />
                <div>
                    <p class="font-medium text-sm">Jane Doe</p>
                    <p class="text-xs text-muted-foreground">Sent you a message: "Hey, are we still on for lunch?"</p>
                </div>
            </div>,
            Duration = 6000
        });
    }

    private void ShowCustomFragment()
    {
        ToastService.Show(
            @<Flex Gap="2" Align="center">
                <Badge Variant="Badge.BadgeVariant.Success">New</Badge>
                <span class="text-sm">Version 2.1 is now available</span>
            </Flex>,
            variant: ToastVariant.Default,
            duration: 7000
        );
    }
}
