        "ArrowLeftRight" => Lucide.ArrowLeftRight,
        "ArrowRight" => Lucide.ArrowRight,
        "ArrowUp" => Lucide.ArrowUp,
        "ArrowUpDown" => Lucide.ArrowUpDown,
