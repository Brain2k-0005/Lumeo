@page "/blocks/form-wizard"

<PageTitle>Form Wizard — Lumeo Patterns</PageTitle>

<PageHeader Title="Multi-Step Form Wizard" Description="A multi-step form with step indicator, validation, and a review summary before submission." />

<Stack Gap="12">

    <ComponentDemo Title="Form Wizard" Code="@_wizardCode">
        <Stack Class="w-full min-w-[700px] max-w-2xl mx-auto">
            <Card>
                <CardHeader>
                    <!-- Step Indicator -->
                    <Flex Class="items-center justify-between">
                        @for (int i = 1; i <= 4; i++)
                        {
                            var step = i;
                            var stepLabel = step switch { 1 => "Personal", 2 => "Address", 3 => "Preferences", 4 => "Review", _ => "" };
                            var isDone = _currentStep > step;
                            var isActive = _currentStep == step;

                            <Flex Class="@($"items-center {(step < 4 ? "flex-1" : "")}")">
                                <Flex Direction="col" Class="items-center gap-1">
                                    <Flex Class="@($"w-8 h-8 rounded-full items-center justify-center text-sm font-medium transition-colors {(isDone ? "bg-primary text-primary-foreground" : isActive ? "bg-primary text-primary-foreground" : "bg-muted text-muted-foreground")}")">
                                        @if (isDone)
                                        {
                                            <DynamicIcon Name="Check" Class="h-4 w-4" />
                                        }
                                        else
                                        {
                                            @step
                                        }
                                    </Flex>
                                    <Lumeo.Text As="span" Class="@($"text-xs {(isActive ? "text-foreground font-medium" : "text-muted-foreground")} hidden sm:block")">@stepLabel</Lumeo.Text>
                                </Flex>
                                @if (step < 4)
                                {
                                    <Stack Class="@($"flex-1 h-px {(isDone ? "bg-primary" : "bg-border")} mx-2 mb-4")"></Stack>
                                }
                            </Flex>
                        }
                    </Flex>
                </CardHeader>

                <CardContent>
                    <!-- Step 1: Personal Info -->
                    @if (_currentStep == 1)
                    {
                        <Stack Gap="4">
                            <Heading Level="4" Class="text-base font-semibold text-foreground">Personal Information</Heading>
                            <Grid Class="grid-cols-1 sm:grid-cols-2 gap-4">
                                <Stack Gap="2">
                                    <Label Class="text-sm font-medium text-foreground">First Name</Label>
                                    <Input @bind-Value="_firstName" placeholder="John" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label Class="text-sm font-medium text-foreground">Last Name</Label>
                                    <Input @bind-Value="_lastName" placeholder="Doe" />
                                </Stack>
                            </Grid>
                            <Stack Gap="2">
                                <Label Class="text-sm font-medium text-foreground">Email Address</Label>
                                <Input @bind-Value="_email" type="email" placeholder="john.doe@example.com" />
                            </Stack>
                            <Stack Gap="2">
                                <Label Class="text-sm font-medium text-foreground">Phone Number</Label>
                                <Input @bind-Value="_phone" type="tel" placeholder="+1 (555) 000-0000" />
                            </Stack>
                        </Stack>
                    }

                    <!-- Step 2: Address -->
                    @if (_currentStep == 2)
                    {
                        <Stack Gap="4">
                            <Heading Level="4" Class="text-base font-semibold text-foreground">Address</Heading>
                            <Stack Gap="2">
                                <Label Class="text-sm font-medium text-foreground">Street Address</Label>
                                <Input @bind-Value="_street" placeholder="123 Main Street" />
                            </Stack>
                            <Grid Class="grid-cols-1 sm:grid-cols-2 gap-4">
                                <Stack Gap="2">
                                    <Label Class="text-sm font-medium text-foreground">City</Label>
                                    <Input @bind-Value="_city" placeholder="San Francisco" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label Class="text-sm font-medium text-foreground">State</Label>
                                    <Select @bind-Value="_state">
                                        <SelectTrigger>
                                            <Lumeo.Text As="span" Class="@(_state == null ? "text-muted-foreground" : "")">
                                                @(_state ?? "Select state")
                                            </Lumeo.Text>
                                        </SelectTrigger>
                                        <SelectContent>
                                            <SelectItem Value="CA">California</SelectItem>
                                            <SelectItem Value="NY">New York</SelectItem>
                                            <SelectItem Value="TX">Texas</SelectItem>
                                            <SelectItem Value="FL">Florida</SelectItem>
                                            <SelectItem Value="WA">Washington</SelectItem>
                                            <SelectItem Value="IL">Illinois</SelectItem>
                                        </SelectContent>
                                    </Select>
                                </Stack>
                            </Grid>
                            <Stack Gap="2">
                                <Label Class="text-sm font-medium text-foreground">ZIP Code</Label>
                                <Input @bind-Value="_zip" placeholder="94105" Class="max-w-32" />
                            </Stack>
                        </Stack>
                    }

                    <!-- Step 3: Preferences -->
                    @if (_currentStep == 3)
                    {
                        <Stack Gap="6">
                            <Heading Level="4" Class="text-base font-semibold text-foreground">Preferences</Heading>

                            <!-- Notifications -->
                            <Stack Gap="3">
                                <Heading Level="5" Class="text-sm font-medium text-foreground">Notifications</Heading>
                                <Stack Gap="3">
                                    <Flex Class="items-center justify-between">
                                        <Stack>
                                            <Lumeo.Text Class="text-sm text-foreground">Email notifications</Lumeo.Text>
                                            <Lumeo.Text Class="text-xs text-muted-foreground">Receive updates via email</Lumeo.Text>
                                        </Stack>
                                        <Switch @bind-Checked="_emailNotif" />
                                    </Flex>
                                    <Flex Class="items-center justify-between">
                                        <Stack>
                                            <Lumeo.Text Class="text-sm text-foreground">SMS notifications</Lumeo.Text>
                                            <Lumeo.Text Class="text-xs text-muted-foreground">Receive updates via text message</Lumeo.Text>
                                        </Stack>
                                        <Switch @bind-Checked="_smsNotif" />
                                    </Flex>
                                    <Flex Class="items-center justify-between">
                                        <Stack>
                                            <Lumeo.Text Class="text-sm text-foreground">Push notifications</Lumeo.Text>
                                            <Lumeo.Text Class="text-xs text-muted-foreground">Receive browser push notifications</Lumeo.Text>
                                        </Stack>
                                        <Switch @bind-Checked="_pushNotif" />
                                    </Flex>
                                </Stack>
                            </Stack>

                            <Separator />

                            <!-- Interests -->
                            <Stack Gap="3">
                                <Heading Level="5" Class="text-sm font-medium text-foreground">Interests</Heading>
                                <Grid Class="grid-cols-1 sm:grid-cols-2 gap-2">
                                    @foreach (var interest in _interests)
                                    {
                                        var i = interest;
                                        <Flex Class="items-center gap-2">
                                            <Checkbox Checked="@i.Selected" CheckedChanged="@(v => i.Selected = v)" />
                                            <Label Class="text-sm text-foreground cursor-pointer">@i.Label</Label>
                                        </Flex>
                                    }
                                </Grid>
                            </Stack>

                            <Separator />

                            <!-- Communication Preference -->
                            <Stack Gap="3">
                                <Heading Level="5" Class="text-sm font-medium text-foreground">Preferred Communication</Heading>
                                <RadioGroup @bind-Value="_communication">
                                    <Flex Class="items-center gap-2">
                                        <RadioGroupItem Value="email" />
                                        <Label Class="text-sm text-foreground">Email</Label>
                                    </Flex>
                                    <Flex Class="items-center gap-2">
                                        <RadioGroupItem Value="phone" />
                                        <Label Class="text-sm text-foreground">Phone</Label>
                                    </Flex>
                                    <Flex Class="items-center gap-2">
                                        <RadioGroupItem Value="sms" />
                                        <Label Class="text-sm text-foreground">SMS</Label>
                                    </Flex>
                                </RadioGroup>
                            </Stack>
                        </Stack>
                    }

                    <!-- Step 4: Review -->
                    @if (_currentStep == 4)
                    {
                        <Stack Gap="6">
                            <Heading Level="4" Class="text-base font-semibold text-foreground">Review Your Information</Heading>

                            <Card Class="bg-muted/40">
                                <CardContent Class="pt-4">
                                    <Stack Gap="4" Class="text-sm">
                                        <Grid Class="grid-cols-2 gap-x-4 gap-y-2">
                                            <Lumeo.Text As="span" Class="text-muted-foreground">Name</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground font-medium">@(_firstName) @(_lastName)</Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">Email</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@(_email.Length > 0 ? _email : "—")</Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">Phone</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@(_phone.Length > 0 ? _phone : "—")</Lumeo.Text>
                                        </Grid>

                                        <Separator />

                                        <Grid Class="grid-cols-2 gap-x-4 gap-y-2">
                                            <Lumeo.Text As="span" Class="text-muted-foreground">Address</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@(_street.Length > 0 ? _street : "—")</Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">City / State</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@(_city) @(_state)</Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">ZIP</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@(_zip.Length > 0 ? _zip : "—")</Lumeo.Text>
                                        </Grid>

                                        <Separator />

                                        <Grid Class="grid-cols-2 gap-x-4 gap-y-2">
                                            <Lumeo.Text As="span" Class="text-muted-foreground">Notifications</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">
                                                @string.Join(", ", new[] {
                                                    _emailNotif ? "Email" : null,
                                                    _smsNotif ? "SMS" : null,
                                                    _pushNotif ? "Push" : null
                                                }.Where(x => x != null))
                                            </Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">Interests</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground">@string.Join(", ", _interests.Where(x => x.Selected).Select(x => x.Label))</Lumeo.Text>

                                            <Lumeo.Text As="span" Class="text-muted-foreground">Communication</Lumeo.Text>
                                            <Lumeo.Text As="span" Class="text-foreground capitalize">@(_communication ?? "—")</Lumeo.Text>
                                        </Grid>
                                    </Stack>
                                </CardContent>
                            </Card>

                            <Flex Class="items-center gap-2">
                                <Checkbox @bind-Checked="_confirmed" />
                                <Label Class="text-sm text-foreground">
                                    I confirm that the information above is accurate and I agree to the <Lumeo.Link Href="#" Class="text-primary hover:underline">terms and conditions</Lumeo.Link>.
                                </Label>
                            </Flex>
                        </Stack>
                    }
                </CardContent>

                <CardFooter>
                    <Flex Class="justify-between w-full">
                        <Button Variant="Button.ButtonVariant.Outline"
                                OnClick="@PreviousStep"
                                Disabled="@(_currentStep == 1)">
                            <DynamicIcon Name="ChevronLeft" Class="h-4 w-4" />
                            Previous
                        </Button>

                        @if (_currentStep < 4)
                        {
                            <Button OnClick="@NextStep">
                                Next
                                <DynamicIcon Name="ChevronRight" Class="h-4 w-4" />
                            </Button>
                        }
                        else
                        {
                            <Button OnClick="@Submit" Disabled="@(!_confirmed)">
                                <DynamicIcon Name="Check" Class="h-4 w-4" />
                                Submit
                            </Button>
                        }
                    </Flex>
                </CardFooter>
            </Card>

            @if (_submitted)
            {
                <Stack Class="mt-4">
                    <Alert>
                        <Flex Class="gap-3">
                            <DynamicIcon Name="Check" Class="h-4 w-4 mt-0.5 text-primary" />
                            <Stack>
                                <Heading Level="5" Class="mb-1 font-medium leading-none tracking-tight">Form submitted!</Heading>
                                <Stack Class="text-sm [&_p]:leading-relaxed">
                                    <Lumeo.Text>Thank you, @_firstName. Your information has been received.</Lumeo.Text>
                                </Stack>
                            </Stack>
                        </Flex>
                    </Alert>
                </Stack>
            }
        </Stack>
    </ComponentDemo>

</Stack>

@code {
    private int _currentStep = 1;
    private bool _submitted = false;

    // Step 1
    private string _firstName = "";
    private string _lastName = "";
    private string _email = "";
    private string _phone = "";

    // Step 2
    private string _street = "";
    private string _city = "";
    private string? _state;
    private string _zip = "";

    // Step 3
    private bool _emailNotif = true;
    private bool _smsNotif = false;
    private bool _pushNotif = false;
    private string? _communication = "email";

    private List<InterestItem> _interests = new()
    {
        new("Technology", false),
        new("Design", false),
        new("Marketing", false),
        new("Business", false),
        new("Science", false),
    };

    // Step 4
    private bool _confirmed = false;

    private void NextStep()
    {
        if (_currentStep < 4) _currentStep++;
    }

    private void PreviousStep()
    {
        if (_currentStep > 1) _currentStep--;
    }

    private void Submit()
    {
        if (_confirmed)
        {
            _submitted = true;
        }
    }

    private class InterestItem
    {
        public string Label { get; init; }
        public bool Selected { get; set; }
        public InterestItem(string label, bool selected) { Label = label; Selected = selected; }
    }

    private string _wizardCode = @"<!-- Multi-step form wizard with 4 steps -->
<Card>
    <CardHeader>
        <!-- Step indicator with numbered circles and connecting lines -->
        <Flex Align=""center"">
            @for (int step = 1; step <= 4; step++)
