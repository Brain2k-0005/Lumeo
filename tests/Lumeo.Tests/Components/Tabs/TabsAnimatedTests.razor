@inherits Bunit.BunitContext

@code {
    public TabsAnimatedTests() { this.AddLumeoServices(); }

    [Fact]
    public void AnimatedIndicator_False_Is_Default_And_Omits_Indicator()
    {
        var cut = Render(@<Tabs ActiveValue="tab1">
            <TabsList>
                <TabsTrigger Value="tab1">Tab 1</TabsTrigger>
                <TabsTrigger Value="tab2">Tab 2</TabsTrigger>
            </TabsList>
        </Tabs>);

        Assert.DoesNotContain("lumeo-tabs-indicator", cut.Markup);
        Assert.DoesNotContain("lumeo-tabs-underline", cut.Markup);
        Assert.DoesNotContain("lumeo-tabs-list", cut.Markup);
    }

    [Fact]
    public void AnimatedIndicator_True_Adds_Pill_Indicator_By_Default()
    {
        // Default variant slides a pill indicator behind the active trigger.
        var cut = Render(@<Tabs ActiveValue="tab1" AnimatedIndicator="true">
            <TabsList>
                <TabsTrigger Value="tab1">Tab 1</TabsTrigger>
                <TabsTrigger Value="tab2">Tab 2</TabsTrigger>
            </TabsList>
        </Tabs>);

        Assert.Contains("lumeo-tabs-indicator", cut.Markup);
        Assert.Contains("lumeo-tabs-list", cut.Markup);
    }

    [Fact]
    public void AnimatedIndicator_True_Renders_Indicator_Style_Variables()
    {
        var cut = Render(@<Tabs ActiveValue="tab1" AnimatedIndicator="true">
            <TabsList>
                <TabsTrigger Value="tab1">Tab 1</TabsTrigger>
            </TabsList>
        </Tabs>);

        Assert.Contains("--lumeo-tabs-indicator-x", cut.Markup);
        Assert.Contains("--lumeo-tabs-indicator-w", cut.Markup);
    }

    [Fact]
    public void AnimatedIndicator_True_Vertical_Skips_Underline()
    {
        var cut = Render(@<Tabs ActiveValue="tab1" AnimatedIndicator="true" Orientation="Tabs.TabsOrientation.Vertical">
            <TabsList>
                <TabsTrigger Value="tab1">Tab 1</TabsTrigger>
            </TabsList>
        </Tabs>);

        // Indicator is horizontal-only; vertical tabs should not render it.
        Assert.DoesNotContain("lumeo-tabs-indicator", cut.Markup);
        Assert.DoesNotContain("lumeo-tabs-underline", cut.Markup);
    }
}
