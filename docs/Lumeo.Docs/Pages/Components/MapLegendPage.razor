@namespace Lumeo.Docs.Pages.Components
@page "/components/map-legend"

<PageTitle>MapLegend — Lumeo</PageTitle>

<PageHeader Title="MapLegend"
            Description="A small overlay panel that explains the symbols and colours used on a map. Place MapLegend inside the Map Overlay slot; nest MapLegendItem children to define rows." />

<InstallUsage Component="MapLegend" Package="Lumeo.Maps" />

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <ChildContent>
        <strong>Satellite package.</strong> <code>MapLegend</code> and <code>MapLegendItem</code>
        live in <code>Lumeo.Maps</code> — install it alongside the core <code>Lumeo</code> package.
    </ChildContent>
</Alert>

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Explaining fill colours on a choropleth or density map</li>
        <li>Labelling marker categories (e.g., store types, risk levels)</li>
        <li>Distinguishing route types — air vs. sea, fastest vs. scenic</li>
        <li>Identifying threshold bands on a heatmap</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    @* Demo 1 — Basic legend in bottom-left corner *@
    <ComponentDemo Title="Basic legend — traffic conditions" Code="@_basicCode">
        <LazyRender Height="380px">
            <Map Center="(51.505, -0.09)" Zoom="11" Height="380px" TileLayer="CartoLight">
                <ChildContent>
                    <MapMarker Lat="51.507" Lon="-0.128" Title="London" Variant="Dot" Color="green" />
                    <MapMarker Lat="51.503" Lon="-0.119" Title="Tower Bridge" Variant="Dot" Color="yellow" />
                    <MapMarker Lat="51.501" Lon="-0.142" Title="Buckingham Palace" Variant="Dot" Color="red" />
                </ChildContent>
                <Overlay>
                    <MapLegend Title="Traffic" Position="bottom-left">
                        <MapLegendItem Color="green"  Label="Clear" />
                        <MapLegendItem Color="yellow" Label="Slow" />
                        <MapLegendItem Color="red"    Label="Congested" />
                    </MapLegend>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 2 — Air vs Sea route legend combined with polylines *@
    <ComponentDemo Title="Route legend — Air vs. Sea arcs" Code="@_routeLegendCode">
        <LazyRender Height="480px">
            <Map Center="(30.0, 0.0)" Zoom="2" Height="480px" TileLayer="CartoDark">
                <ChildContent>
                    @foreach (var (lat, lon, name) in _globeCities)
                    {
                        <MapMarker Lat="lat" Lon="lon" Title="@name" Variant="Dot" Color="gray" />
                    }
                    @foreach (var (from, to) in _airArcs)
                    {
                        <MapArc From="from" To="to"
                                Color="#3b82f6" HoverColor="#93c5fd" HoverWeight="4"
                                Weight="2" Opacity="0.8" Dashed="false"
                                Tooltip="Air route" />
                    }
                    @foreach (var (from, to) in _seaArcs)
                    {
                        <MapArc From="from" To="to"
                                Color="#14b8a6" HoverColor="#5eead4" HoverWeight="4"
                                Weight="2" Opacity="0.7" Dashed="true"
                                Tooltip="Sea route" />
                    }
                </ChildContent>
                <Overlay>
                    <MapLegend Title="Routes" Position="bottom-left">
                        <MapLegendItem Color="blue" Label="Air" />
                        <MapLegendItem Color="teal" Label="Sea (dashed)" />
                    </MapLegend>
                    <MapInfoChip Position="top-left">Hover arcs to highlight</MapInfoChip>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 3 — All four Position values *@
    <ComponentDemo Title="All four corner positions" Code="@_cornersCode">
        <LazyRender Height="380px">
            <Map Center="(20.0, 10.0)" Zoom="1" Height="380px" TileLayer="Positron">
                <Overlay>
                    <MapLegend Title="Top-Left" Position="top-left">
                        <MapLegendItem Color="blue"   Label="Ocean" />
                        <MapLegendItem Color="green"  Label="Forest" />
                    </MapLegend>
                    <MapLegend Title="Top-Right" Position="top-right">
                        <MapLegendItem Color="orange" Label="Desert" />
                        <MapLegendItem Color="teal"   Label="Tundra" />
                    </MapLegend>
                    <MapLegend Title="Bottom-Left" Position="bottom-left">
                        <MapLegendItem Color="purple" Label="Urban" />
                        <MapLegendItem Color="rose"   Label="Industrial" />
                    </MapLegend>
                    <MapLegend Title="Bottom-Right" Position="bottom-right">
                        <MapLegendItem Color="amber"  Label="Savanna" />
                        <MapLegendItem Color="cyan"   Label="Wetland" />
                    </MapLegend>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

    @* Demo 4 — Heatmap legend with custom CSS colors *@
    <ComponentDemo Title="Heatmap density legend with CSS color values" Code="@_heatLegendCode">
        <LazyRender Height="420px">
            <Map Center="(51.5, 10.0)" Zoom="4" Height="420px" TileLayer="DarkMatter">
                <ChildContent>
                    <MapHeatmap Points="_heatPoints" Radius="25" Opacity="0.85" />
                </ChildContent>
                <Overlay>
                    <MapLegend Title="Density" Position="bottom-left">
                        <MapLegendItem Color="#ef4444" Label="Very high" />
                        <MapLegendItem Color="#f97316" Label="High" />
                        <MapLegendItem Color="#eab308" Label="Medium" />
                        <MapLegendItem Color="#22c55e" Label="Low" />
                    </MapLegend>
                </Overlay>
            </Map>
        </LazyRender>
    </ComponentDemo>

</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="map-legend" Level="3" Class="mt-8 scroll-mt-20">MapLegend</Heading>
    <div class="mt-4">
        <PropsTable Slug="map" SubComponent="MapLegend" />
    </div>

    <Heading Id="map-legend-item" Level="3" Class="mt-8 scroll-mt-20">MapLegendItem</Heading>
    <p class="text-sm text-muted-foreground mt-2">
        <code class="text-xs bg-muted px-1 py-0.5 rounded">Color</code> friendly names: <code class="text-xs bg-muted px-1 py-0.5 rounded">red</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">green</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">blue</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">yellow</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">orange</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">teal</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">purple</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">pink</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">rose</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">amber</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">sky</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">cyan</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">emerald</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">violet</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">gray</code>, <code class="text-xs bg-muted px-1 py-0.5 rounded">slate</code> — or any CSS color value. Null falls back to the theme primary color.
    </p>
    <div class="mt-4">
        <PropsTable Slug="map" SubComponent="MapLegendItem" />
    </div>
</div>

