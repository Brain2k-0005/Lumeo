{
  "name": "lumeo-editor-bundle",
  "private": true,
  "description": "Internal esbuild step that bundles TipTap/ProseMirror/Lowlight/highlight.js into a single self-hosted ESM file at wwwroot/js/tiptap-bundle.js. Lets RichTextEditor work under strict CSP and offline (no esm.sh runtime fetch).",
  "scripts": {
    "build:tiptap": "esbuild scripts/tiptap-entry.js --bundle --format=esm --outfile=wwwroot/js/tiptap-bundle.js --minify --legal-comments=external --target=es2020"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "@tiptap/core": "2.27.2",
    "@tiptap/pm": "2.27.2",
    "@tiptap/starter-kit": "2.27.2",
    "@tiptap/suggestion": "2.27.2",
    "@tiptap/extension-link": "2.27.2",
    "@tiptap/extension-underline": "2.27.2",
    "@tiptap/extension-placeholder": "2.27.2",
    "@tiptap/extension-typography": "2.27.2",
    "@tiptap/extension-mention": "2.27.2",
    "@tiptap/extension-table": "2.27.2",
    "@tiptap/extension-table-row": "2.27.2",
    "@tiptap/extension-table-cell": "2.27.2",
    "@tiptap/extension-table-header": "2.27.2",
    "@tiptap/extension-image": "2.27.2",
    "@tiptap/extension-task-list": "2.27.2",
    "@tiptap/extension-task-item": "2.27.2",
    "@tiptap/extension-code-block-lowlight": "2.27.2",
    "lowlight": "^3.1.0",
    "highlight.js": "^11.10.0"
  }
}
