@namespace Lumeo
@typeparam TItem

<tr class="@CssClass" role="row" aria-rowindex="@AriaRowIndex" @attributes="AdditionalAttributes">
    <td colspan="@ColSpan" class="p-4">
        @if (DetailTemplate is not null)
        {
            @DetailTemplate(Item)
        }
    </td>
</tr>

@code {
    /// <summary>The row data whose detail content is being expanded, passed to
    /// <see cref="DetailTemplate"/>.</summary>
    [Parameter] public TItem Item { get; set; } = default!;

    /// <summary>1-based <c>aria-rowindex</c> for this detail row, among EVERY rendered
    /// <c>&lt;tr&gt;</c> in the table (per ARIA grid semantics — a detail row occupies a
    /// real table row, same as a data or group-header row). Allocated by
    /// <see cref="DataGridBody{TItem}"/>'s <see cref="DataGridRowIndexer"/> via
    /// <see cref="DataGridRow{TItem}.DetailAriaRowIndex"/>. Null at render sites that
    /// don't yet compute a table-wide index for detail rows (the virtualized branches —
    /// see <see cref="DataGridRowIndexer"/>'s remarks), in which case the attribute is
    /// omitted and the browser falls back to DOM order.</summary>
    [Parameter] public int? AriaRowIndex { get; set; }

    /// <summary>Template rendered inside the spanning detail cell. Renders nothing
    /// when unset.</summary>
    [Parameter] public RenderFragment<TItem>? DetailTemplate { get; set; }

    /// <summary>Number of columns the detail cell spans, matching the parent row's
    /// total column count. Defaults to 1.</summary>
    [Parameter] public int ColSpan { get; set; } = 1;

    /// <summary>Additional CSS classes merged onto the <c>&lt;tr&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures unmatched attributes and applies them to the <c>&lt;tr&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"bg-muted/20 {Class}".Trim();
}
