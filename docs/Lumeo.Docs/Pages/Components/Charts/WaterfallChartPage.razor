@page "/components/charts/waterfall"

<PageTitle>Waterfall Chart — Lumeo</PageTitle>

<PageHeader Title="Waterfall Chart" Description="Show how an initial value is affected by successive positive and negative changes. Commonly used for financial statements, budget analysis, and variance breakdowns." />

<Stack Gap="8">
    <ComponentDemo Title="Income Statement Waterfall" Code="@_basicCode">
        <Container>
            <WaterfallChart Categories="_categories" Values="_values" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">WaterfallChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis labels for each step.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Values</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Positive or negative values for each step.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IncreaseColor</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">var(--color-primary)</td>
                            <td class="p-3 text-muted-foreground">Color for positive values.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">DecreaseColor</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">var(--color-destructive)</td>
                            <td class="p-3 text-muted-foreground">Color for negative values.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Revenue", "COGS", "Gross Profit", "R&D", "Sales & Mktg", "G&A", "Operating Income" };
    private List<double> _values = new() { 12400, -4800, 7600, -1200, -2100, -800, 3500 };

    private string _basicCode = @"<WaterfallChart Categories=""_categories"" Values=""_values"" />";
}
