</Alert>
<Alert Variant=""Alert.AlertVariant.Destructive"">
    <Flex Gap=""3"">
        <SvgGlyph Svg=""@(Lucide.CircleAlert)"" class=""h-4 w-4 mt-0.5"" />
        <Stack Gap=""0"">
            <Heading Level=""5"" Size=""sm"" Weight=""medium"" Class=""mb-1 leading-none tracking-tight"">Something went wrong</Heading>
            <Lumeo.Text Size=""sm"" Leading=""relaxed"">Could not save your changes. Please try again.</Lumeo.Text>
        </Stack>
    </Flex>
</Alert>";

    private bool _showBanner = true;
    private bool _showAlert = true;

    private string _actionCode = @"<Alert>
    <Flex Align=""start"" Justify=""between"" Gap=""4"">
        <Flex Gap=""3"">
            <SvgGlyph Svg=""@(Lucide.Bell)"" class=""h-4 w-4 mt-0.5 text-primary"" />
            <Stack Gap=""0"">
                <Heading Level=""5"" Size=""sm"" Weight=""medium"" Class=""mb-1 leading-none tracking-tight"">New feature available</Heading>
                <Lumeo.Text Size=""sm"" Leading=""relaxed"">Dark mode is now available for all users.</Lumeo.Text>
            </Stack>
        </Flex>
        <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Try it</Button>
    </Flex>
</Alert>";

    private string _dismissCode = @"@if (_showBanner)
{
    <Alert>
        <Flex Align=""start"" Justify=""between"" Gap=""2"">
            <Flex Gap=""3"">
                <SvgGlyph Svg=""@(Lucide.Star)"" class=""h-4 w-4 mt-0.5 text-primary"" />
                <Stack Gap=""0"">
                    <Heading Level=""5"" Size=""sm"" Weight=""medium"" Class=""mb-1 leading-none tracking-tight"">Welcome to Lumeo!</Heading>
                    <Lumeo.Text Size=""sm"" Leading=""relaxed"">Get started by exploring the components library.</Lumeo.Text>
                </Stack>
            </Flex>
            <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon""
                    OnClick=""@(() => _showBanner = false)"">
                <SvgGlyph Svg=""@(Lucide.X)"" class=""h-4 w-4"" />
            </Button>
        </Flex>
