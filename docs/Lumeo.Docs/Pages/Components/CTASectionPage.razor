@page "/components/cta-section"

<PageTitle>CTA Section — Lumeo</PageTitle>

<PageHeader Title="CTA Section" Description="A tinted, centered call-to-action band with a title, optional subtitle, and an Actions slot for primary and secondary buttons. Part of the Splash Kit." />

<InstallUsage Component="CTASection" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>The closing call-to-action band of a landing or marketing page</li>
        <li>"Ready to get started?" prompts before the footer</li>
        <li>Newsletter or sign-up nudges that need visual separation from the surrounding content</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic CTA" Code="@_basicCode">
        <CTASection Title="Ready to build with Lumeo?"
                    Subtitle="Install the package and ship your first component in minutes.">
            <Actions>
                <Button>Get started</Button>
                <Button Variant="Button.ButtonVariant.Outline">Read the docs</Button>
            </Actions>
        </CTASection>
    </ComponentDemo>

    <ComponentDemo Title="Single Action" Code="@_singleCode">
        <CTASection Title="Join the newsletter"
                    Subtitle="Monthly updates on new components and releases. No spam.">
            <Actions>
                <Button>Subscribe</Button>
            </Actions>
        </CTASection>
    </ComponentDemo>

    <ComponentDemo Title="Custom Title Slot" Code="@_slotCode">
        <CTASection Subtitle="Use TitleSlot when you need custom title markup.">
            <TitleSlot>
                <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-foreground">
                    Start shipping <span class="text-primary">today</span>
                </h2>
            </TitleSlot>
            <Actions>
                <Button>Get started</Button>
            </Actions>
        </CTASection>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">CTASection</Heading>
            <PropsTable Slug="cta-section" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/hero" class="text-primary hover:underline">Hero</a> — Opening hero band for the top of the page</li>
        <li><a href="/components/feature-grid" class="text-primary hover:underline">Feature Grid</a> — Feature highlights section</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — Used inside the Actions slot</li>
    </ul>
</div>

@code {
    private string _basicCode = @"<CTASection Title=""Ready to build with Lumeo?""
            Subtitle=""Install the package and ship your first component in minutes."">
    <Actions>
        <Button>Get started</Button>
        <Button Variant=""Button.ButtonVariant.Outline"">Read the docs</Button>
    </Actions>
</CTASection>";

    private string _singleCode = @"<CTASection Title=""Join the newsletter""
            Subtitle=""Monthly updates on new components and releases. No spam."">
    <Actions>
        <Button>Subscribe</Button>
    </Actions>
</CTASection>";

    private string _slotCode = @"<CTASection Subtitle=""Use TitleSlot when you need custom title markup."">
    <TitleSlot>
        <h2 class=""text-3xl sm:text-4xl font-bold tracking-tight text-foreground"">
            Start shipping <span class=""text-primary"">today</span>
        </h2>
    </TitleSlot>
    <Actions>
        <Button>Get started</Button>
    </Actions>
</CTASection>";
}
