@page "/"

<PageTitle>Lumeo - The Blazor component library you would actually want to ship</PageTitle>

<!-- ======================= HERO ======================= -->
@* Minimal, shadcn-scale landing. The hero below is the ONLY interactive-motion
   surface (BlurFade one-shot entrance + the CSS-only ShimmerButton sweep). Every
   section under it is static, prerender-identical content — nothing heavy mounts
   after hydration. Live demos live at /demos/saas and /demos/enterprise. *@
<section class="relative overflow-hidden border-b border-border/40">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,#000_60%,transparent_110%)] pointer-events-none opacity-30"></div>

    <Container MaxWidth="[1400px]" Class="relative px-4 pt-8 pb-6">

        <!-- Announcement ribbon (single slim line) -->
        <BlurFade DelayMs="0">
            <Flex Justify="center" Class="mb-6">
                <Lumeo.Link Href="components/data-grid" Class="no-underline group">
                    <Flex Inline="true" Align="center" Gap="2" Class="whitespace-nowrap rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                        <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">v4.2</Badge>
                        <Lumeo.Text As="span" Class="hidden sm:inline">DataGrid: live column/row reorder animation, pixel-exact resize, double-click auto-fit</Lumeo.Text>
                        <Lumeo.Text As="span" Class="sm:hidden">New: DataGrid reorder &amp; resize</Lumeo.Text>
                        <DynamicIcon Name="ArrowRight" Class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                    </Flex>
                </Lumeo.Link>
            </Flex>
        </BlurFade>

        <!-- Category hero -->
        <div class="text-center max-w-3xl mx-auto mb-10 sm:mb-12">
            <BlurFade DelayMs="40">
                <Flex Align="center" Gap="2" Class="w-fit mx-auto rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm">
                    <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary"></span>
                    The Blazor UI platform you fully control
                </Flex>
            </BlurFade>
            <BlurFade DelayMs="90">
                <Heading Level="1" Class="mt-6 text-4xl sm:text-5xl md:text-6xl font-bold tracking-[-0.02em] leading-[1.05] text-foreground">
                    Own your Blazor UI.
                </Heading>
            </BlurFade>
            <BlurFade DelayMs="140">
                <Lumeo.Text Color="muted" Class="mt-4 mx-auto max-w-2xl text-base sm:text-lg leading-relaxed">
                    Modern components, blocks, motion and production-ready data surfaces &mdash; with CLI vendoring, MCP for your agents, and a NuGet-free standalone eject. Ship fast without giving up control of design or source.
                </Lumeo.Text>
            </BlurFade>
            <BlurFade DelayMs="190">
                <Flex Wrap="true" Justify="center" Align="center" Gap="2" Class="mt-6">
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">164</span> components</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">24</span> blocks</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">16</span> icon packs</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">~627 KB</span> core</span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">MIT</span></span>
                    <span class="inline-block rounded-full border border-border/50 bg-card/60 px-3 py-1 text-xs text-muted-foreground"><span class="font-semibold text-foreground">5,800+</span> tests</span>
                </Flex>
            </BlurFade>
            <BlurFade DelayMs="240">
                <Flex Wrap="true" Justify="center" Align="center" Gap="3" Class="mt-8">
                    <Lumeo.Link Href="docs/introduction" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Lg" Class="rounded-lg">
                            Get Started
                            <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="docs/guides/vendor-a-component" Class="inline-flex h-10 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background/80 backdrop-blur-sm px-6 text-sm font-semibold text-foreground hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <DynamicIcon Name="FolderGit2" Class="h-4 w-4" />
                        Own the source
                    </Lumeo.Link>
                </Flex>
            </BlurFade>
        </div>
    </Container>
</section>

<!-- ======================= SEE IT LIVE ======================= -->
@* Two rich link-cards to the full demo apps + a slim showcase card. Static content
   only — no live components mount here; each card just links out. *@
<section class="py-16 sm:py-20 border-b border-border/40">
    <Container MaxWidth="[1400px]" Class="px-4">
        <Stack Gap="3" Class="text-center mb-10 sm:mb-12">
            <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">See it live</Badge>
            <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Real apps, built entirely with Lumeo.</Heading>
            <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                Two full applications on deterministic in-memory data &mdash; every pixel is Lumeo. Open one, interact with it, then read the source.
            </Lumeo.Text>
        </Stack>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <!-- Northlight -->
            <Lumeo.Link Href="demos/saas" Class="group block h-full no-underline">
                <Stack Gap="4" Class="h-full rounded-xl border border-border/40 bg-card p-6 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200">
                    <Flex Align="center" Justify="between">
                        <Flex Align="center" Gap="3" Class="min-w-0">
                            <Flex Align="center" Justify="center" Class="h-10 w-10 rounded-lg bg-accent/40 text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                                <DynamicIcon Name="LayoutDashboard" Class="h-5 w-5" />
                            </Flex>
                            <Stack Gap="0" Class="min-w-0">
                                <Heading Level="3" Class="text-lg font-semibold tracking-tight">Northlight</Heading>
                                <Lumeo.Text Size="xs" Color="muted">Product analytics SaaS</Lumeo.Text>
                            </Stack>
                        </Flex>
                        <DynamicIcon Name="ArrowUpRight" Class="h-4 w-4 text-muted-foreground shrink-0 group-hover:text-foreground group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all" />
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        A full SaaS admin &mdash; collapsible sidebar, command palette, dashboards with MRR and signup charts, notifications and toasts.
                    </Lumeo.Text>
                    <Flex Wrap="true" Gap="1">
                        @foreach (var chip in new[] { "SidebarProvider", "Command", "Charts", "DataGrid", "Toast" })
                        {
                            <span class="inline-flex items-center rounded-md bg-muted/60 px-2 py-0.5 text-xs font-mono text-muted-foreground ring-1 ring-border/40">@chip</span>
                        }
                    </Flex>
                </Stack>
            </Lumeo.Link>

            <!-- Meridian Ops -->
            <Lumeo.Link Href="demos/enterprise" Class="group block h-full no-underline">
                <Stack Gap="4" Class="h-full rounded-xl border border-border/40 bg-card p-6 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200">
                    <Flex Align="center" Justify="between">
                        <Flex Align="center" Gap="3" Class="min-w-0">
                            <Flex Align="center" Justify="center" Class="h-10 w-10 rounded-lg bg-accent/40 text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                                <DynamicIcon Name="Boxes" Class="h-5 w-5" />
                            </Flex>
                            <Stack Gap="0" Class="min-w-0">
                                <Heading Level="3" Class="text-lg font-semibold tracking-tight">Meridian Ops</Heading>
                                <Lumeo.Text Size="xs" Color="muted">Enterprise operations console</Lumeo.Text>
                            </Stack>
                        </Flex>
                        <DynamicIcon Name="ArrowUpRight" Class="h-4 w-4 text-muted-foreground shrink-0 group-hover:text-foreground group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all" />
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        A freight control tower &mdash; schedule board, shipment grid, approvals queue, audit trail, a Gantt panel and a record editor.
                    </Lumeo.Text>
                    <Flex Wrap="true" Gap="1">
                        @foreach (var chip in new[] { "Scheduler", "Gantt", "DataGrid", "Tabs", "Kanban" })
                        {
                            <span class="inline-flex items-center rounded-md bg-muted/60 px-2 py-0.5 text-xs font-mono text-muted-foreground ring-1 ring-border/40">@chip</span>
                        }
                    </Flex>
                </Stack>
            </Lumeo.Link>
        </div>

        <!-- Showcase (slim) -->
        <Lumeo.Link Href="showcase" Class="group block no-underline mt-4">
            <Flex Align="center" Justify="between" Gap="3" Class="rounded-xl border border-border/40 bg-card px-6 py-4 hover:border-primary/50 hover:shadow-sm transition-all duration-200">
                <Flex Align="center" Gap="3" Class="min-w-0">
                    <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-accent/40 text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                        <DynamicIcon Name="Star" Class="h-4 w-4" />
                    </Flex>
                    <Stack Gap="0" Class="min-w-0">
                        <Lumeo.Text Weight="semibold" Class="text-sm">Showcase</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted" Class="truncate">Real, maintained projects built with Lumeo.</Lumeo.Text>
                    </Stack>
                </Flex>
                <Flex Align="center" Gap="1" Class="shrink-0 text-xs font-medium text-muted-foreground group-hover:text-foreground transition-colors">
                    View
                    <DynamicIcon Name="ArrowRight" Class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
                </Flex>
            </Flex>
        </Lumeo.Link>
    </Container>
</section>

<!-- ======================= BROWSE ALL (slim band) ======================= -->
<section class="border-b border-border/40 bg-muted/[0.03]">
    <Container MaxWidth="[1400px]" Class="px-4 py-6">
        <Flex Align="center" Justify="between" Wrap="true" Gap="4">
            <Flex Align="center" Gap="3" Wrap="true">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="shrink-0">164 components</Badge>
                <Lumeo.Text Size="sm" Color="muted">Every primitive in one place &mdash; 13 categories, from Forms and Overlays to Data surfaces and AI.</Lumeo.Text>
            </Flex>
            <Lumeo.Link Href="components" Class="inline-flex h-9 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background px-4 text-sm font-semibold text-foreground hover:bg-accent hover:text-accent-foreground transition-colors no-underline shrink-0">
                <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                Browse all components
                <DynamicIcon Name="ArrowRight" Class="h-3.5 w-3.5" />
            </Lumeo.Link>
        </Flex>
    </Container>
</section>

<!-- ======================= SIZE / STATS BAND ======================= -->
<section class="py-16">
    <Container MaxWidth="[1400px]" Class="px-4">
        <Stack Gap="3" Class="text-center mb-10">
            <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Bundle size</Badge>
            <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">A fraction of the size.</Heading>
            <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                Brotli-compressed assembly size &mdash; what an end user's browser actually downloads from your published app.
            </Lumeo.Text>
        </Stack>

        <div class="grid gap-4 lg:grid-cols-3">
            <BentoTile Class="lg:col-span-2 border-border/60 p-6">
                <Stack Gap="5">
                    <Stack Gap="1">
                        <Heading Level="3" Class="text-2xl font-semibold tracking-tight">
                            164 components across 11 packages. <Lumeo.Text As="span" Class="text-primary">~627 KB core</Lumeo.Text>.
                        </Heading>
                        <Lumeo.Text Size="sm" Color="muted">Per-package breakdown &mdash; install only the satellites you use.</Lumeo.Text>
                    </Stack>

                    <Stack Gap="4">
                        @foreach (var row in _sizeRows)
                        {
                            <Stack Gap="1.5">
                                <Flex Align="center" Justify="between" Class="text-sm">
                                    <Flex Align="center" Gap="2">
                                        <span class="h-2 w-2 rounded-full @(row.IsCore ? "bg-primary" : "bg-primary/50")"></span>
                                        <Lumeo.Text As="span" Weight="@(row.IsCore ? "semibold" : "medium")" Color="foreground">@row.Name</Lumeo.Text>
                                        <span class="text-border select-none" aria-hidden="true">&middot;</span>
                                        <Lumeo.Text As="span" Size="xs" Color="muted">@row.Components</Lumeo.Text>
                                    </Flex>
                                    <Lumeo.Text As="span" Size="xs" Class="@(row.IsCore ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground")">@row.Size</Lumeo.Text>
                                </Flex>
                                <div class="relative h-2 rounded-md bg-muted/40 overflow-hidden">
                                    <div class="@(row.IsCore ? "bg-primary" : "bg-primary/50") h-full rounded-md transition-all"
                                         style="width: @(row.Percent)%;"></div>
                                </div>
                            </Stack>
                        }
                    </Stack>

                    <Flex Align="center" Gap="2" Class="text-xs text-muted-foreground border-t border-border/40 pt-4">
                        <DynamicIcon Name="Info" Class="h-3.5 w-3.5" />
                        <Lumeo.Text As="span">Brotli-compressed assembly bytes. Core brotli-compresses to ~627 KB in your published app.</Lumeo.Text>
                    </Flex>
                </Stack>
            </BentoTile>

            <div class="grid grid-cols-2 lg:grid-cols-1 gap-4 content-start">
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <DynamicIcon Name="TestTube" Class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Tests</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">5,800+</div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">CI green, every commit.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <DynamicIcon Name="Languages" Class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Locales</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">14</div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">Bundled ILumeoLocalizer.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <DynamicIcon Name="Palette" Class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Themes</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">8</div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">CSS-variable presets.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <DynamicIcon Name="Accessibility" Class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Compliance</Lumeo.Text>
                            <div class="text-xl font-semibold tracking-tight text-foreground leading-none">WCAG AA</div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">Keyboard + ARIA built in.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
            </div>
        </div>
    </Container>
</section>

<Separator Class="opacity-30" />

