                        <tr><td class="p-3 font-mono text-xs text-primary">ToolName</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 font-mono text-xs text-muted-foreground">""</td><td class="p-3 text-muted-foreground">Name of the tool being invoked (e.g. <code class="font-mono text-xs">search_web</code>).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Status</td><td class="p-3 font-mono text-xs text-muted-foreground">ToolCallStatus</td><td class="p-3 font-mono text-xs text-muted-foreground">Pending</td><td class="p-3 text-muted-foreground">Pending, Running, Success, or Error. Drives chip colors and icons.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Input</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Arguments to the tool call, shown in a <code class="font-mono text-xs">&lt;pre&gt;</code> block.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Output</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Tool result shown when expanded.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ErrorMessage</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Error details shown when Status=Error.</td></tr>
