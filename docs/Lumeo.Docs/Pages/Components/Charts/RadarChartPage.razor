@page "/components/charts/radar"

<PageTitle>Radar Chart — Lumeo</PageTitle>

<PageHeader Title="Radar Chart" Description="Compare multiple variables on a common scale. Useful for performance profiles, skill assessments, or comparing entities across dimensions." />

<Stack Gap="8">
    <ComponentDemo Title="Filled Radar" Code="@_basicCode">
        <Container>
            <RadarChart Indicators="_indicators" Series="_series" FillArea="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Circle Shape" Code="@_circleCode">
        <Container>
            <RadarChart Indicators="_indicators" Series="_series" FillArea="false" Shape="circle" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">RadarChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Indicators</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;RadarIndicator&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Axis definitions with Name and Max value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Series</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;RadarSeriesData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Data series, one value per indicator.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">FillArea</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Fills polygon area with semi-transparent color.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Shape</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"polygon"</td>
                            <td class="p-3 text-muted-foreground">Radar shape: "polygon" or "circle".</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<RadarChart.RadarIndicator> _indicators = new()
    {
        new() { Name = "Acquisition",  Max = 100 },
        new() { Name = "Activation",   Max = 100 },
        new() { Name = "Retention",    Max = 100 },
        new() { Name = "Referral",     Max = 100 },
        new() { Name = "Revenue",      Max = 100 },
        new() { Name = "Engagement",   Max = 100 }
    };
    private List<RadarChart.RadarSeriesData> _series = new()
    {
        new() { Name = "Q4 Actual", Values = new() { 78, 65, 82, 54, 88, 71 } },
        new() { Name = "Q4 Target", Values = new() { 85, 80, 75, 70, 90, 80 } }
    };

    private string _basicCode = @"<RadarChart Indicators=""_indicators"" Series=""_series"" FillArea=""true"" />";
    private string _circleCode = @"<RadarChart Indicators=""_indicators"" Series=""_series"" FillArea=""false"" Shape=""circle"" />";
}
