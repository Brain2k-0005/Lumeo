@namespace Lumeo.Tests.Components.Steps

@* Test host for #244 — toggles a trailing StepsItem via a real parameter so
   the conditional is re-evaluated on re-render (validates the registry
   renumbers stably when an item unmounts). *@
<Lumeo.Steps CurrentStep="0">
    <Lumeo.StepsItem Title="One" />
    <Lumeo.StepsItem Title="Two" />
    @if (ShowThird)
    {
        <Lumeo.StepsItem Title="Three" />
    }
</Lumeo.Steps>

@code {
    [Parameter] public bool ShowThird { get; set; } = true;
}
