@page "/components/date-time-picker"

<PageTitle>DateTimePicker — Lumeo</PageTitle>

<PageHeader Title="DateTimePicker" Description="A combined date and time picker with calendar and time columns." />

<Stack Gap="8">
    <ComponentDemo Title="Basic DateTimePicker" Code="@_basicCode">
        <Stack Gap="2" Class="max-w-sm">
            <DateTimePicker @bind-Value="_dateTime1" />
            <Lumeo.Text Size="sm" Color="muted">Selected: @(_dateTime1?.ToString("g") ?? "None")</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Clearable" Code="@_clearableCode">
        <DateTimePicker @bind-Value="_dateTime2" Clearable="true" Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="12-Hour with Seconds" Code="@_fullCode">
        <DateTimePicker @bind-Value="_dateTime3" Use24Hour="false" ShowSeconds="true" Class="max-w-sm" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">DateTimePicker</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateTime?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">The selected date and time.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Use24Hour</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Use 24-hour time format.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowSeconds</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Show seconds column in time picker.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">DateFormat</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"yyyy-MM-dd"</td>
                            <td class="p-3 text-muted-foreground">Date format string for display.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Clearable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Show a clear button when value is set.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Placeholder</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Select date and time"</td>
                            <td class="p-3 text-muted-foreground">Placeholder text when no value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Disable the picker.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private DateTime? _dateTime1 = DateTime.Now;
    private DateTime? _dateTime2 = DateTime.Today.AddHours(10).AddMinutes(30);
    private DateTime? _dateTime3;

    private string _basicCode = @"<DateTimePicker @bind-Value=""_dateTime"" />";
    private string _clearableCode = @"<DateTimePicker @bind-Value=""_dateTime"" Clearable=""true"" />";
    private string _fullCode = @"<DateTimePicker @bind-Value=""_dateTime"" Use24Hour=""false"" ShowSeconds=""true"" />";
}
