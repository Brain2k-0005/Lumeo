@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeAvatarDefault">
    <Avatar>
        <AvatarFallback>JD</AvatarFallback>
    </Avatar>
</PatternCard>

<PatternCard Label="Small" Code="@_codeAvatarSmall">
    <Avatar Size="Avatar.AvatarSize.Sm">
        <AvatarFallback>AB</AvatarFallback>
    </Avatar>
</PatternCard>

<PatternCard Label="Large" Code="@_codeAvatarLarge">
    <Avatar Size="Avatar.AvatarSize.Lg">
        <AvatarFallback>XY</AvatarFallback>
    </Avatar>
</PatternCard>
</Stack>

@code {
        private string _codeAvatarDefault = @"<Avatar>
        <AvatarFallback>JD</AvatarFallback>
    </Avatar>";

        private string _codeAvatarSmall = @"<Avatar Size=""Avatar.AvatarSize.Sm"">
        <AvatarFallback>AB</AvatarFallback>
    </Avatar>";

        private string _codeAvatarLarge = @"<Avatar Size=""Avatar.AvatarSize.Lg"">
        <AvatarFallback>XY</AvatarFallback>
    </Avatar>";
}
