@namespace Lumeo

<tbody class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</tbody>

@code {
    /// <summary>The body rows, typically <see cref="TableRow"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>&lt;tbody&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the <c>&lt;tbody&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("[&_tr:last-child]:border-0", Class);
}
