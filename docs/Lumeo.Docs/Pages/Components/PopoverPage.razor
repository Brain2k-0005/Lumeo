@page "/components/popover"

<PageTitle>Popover — Lumeo</PageTitle>

<PageHeader Title="Popover" Description="Displays rich content in a portal, triggered by a button." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Popover>
            <PopoverTrigger>
                <Button Variant="Button.ButtonVariant.Outline">Open Popover</Button>
            </PopoverTrigger>
            <PopoverContent>
                <Stack Gap="4">
                    <Stack Gap="2">
                        <Heading Level="4" Class="text-base font-medium leading-none">Dimensions</Heading>
                        <Lumeo.Text Size="sm" Color="muted">Set the dimensions for the layer.</Lumeo.Text>
                    </Stack>
                    <Grid Columns="3" Gap="4" Class="items-center">
                        <Label>Width</Label>
                        <Input Class="col-span-2 h-8" Value="100%" />
                        <Label>Height</Label>
                        <Input Class="col-span-2 h-8" Value="25px" />
                    </Grid>
                </Stack>
            </PopoverContent>
        </Popover>
    </ComponentDemo>

    <ComponentDemo Title="Alignment" Code="@_alignCode">
        <Flex Gap="4">
            <Popover>
                <PopoverTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Start</Button>
                </PopoverTrigger>
                <PopoverContent Align="PopoverContent.PopoverAlign.Start">
                    <Lumeo.Text Size="sm">This popover is aligned to the start.</Lumeo.Text>
                </PopoverContent>
            </Popover>
            <Popover>
                <PopoverTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Center</Button>
                </PopoverTrigger>
                <PopoverContent Align="PopoverContent.PopoverAlign.Center">
                    <Lumeo.Text Size="sm">This popover is centered.</Lumeo.Text>
                </PopoverContent>
            </Popover>
            <Popover>
                <PopoverTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">End</Button>
                </PopoverTrigger>
                <PopoverContent Align="PopoverContent.PopoverAlign.End">
                    <Lumeo.Text Size="sm">This popover is aligned to the end.</Lumeo.Text>
                </PopoverContent>
            </Popover>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Placement" Code="@_placementCode">
        <Flex Gap="4" Wrap="true" Align="center" Justify="center" Class="py-8">
            <Popover>
                <PopoverTrigger><Button Variant="Button.ButtonVariant.Outline">Top</Button></PopoverTrigger>
                <PopoverContent Side="PopoverContent.PopoverSide.Top">
                    <Lumeo.Text Size="sm">Popover on top</Lumeo.Text>
                </PopoverContent>
            </Popover>
            <Popover>
                <PopoverTrigger><Button Variant="Button.ButtonVariant.Outline">Bottom</Button></PopoverTrigger>
                <PopoverContent Side="PopoverContent.PopoverSide.Bottom">
                    <Lumeo.Text Size="sm">Popover on bottom</Lumeo.Text>
                </PopoverContent>
            </Popover>
            <Popover>
                <PopoverTrigger><Button Variant="Button.ButtonVariant.Outline">Left</Button></PopoverTrigger>
                <PopoverContent Side="PopoverContent.PopoverSide.Left">
                    <Lumeo.Text Size="sm">Popover on left</Lumeo.Text>
                </PopoverContent>
            </Popover>
            <Popover>
                <PopoverTrigger><Button Variant="Button.ButtonVariant.Outline">Right</Button></PopoverTrigger>
                <PopoverContent Side="PopoverContent.PopoverSide.Right">
                    <Lumeo.Text Size="sm">Popover on right</Lumeo.Text>
                </PopoverContent>
            </Popover>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="With Form" Code="@_formCode">
        <Popover>
            <PopoverTrigger>
                <Button>Update Settings</Button>
            </PopoverTrigger>
            <PopoverContent>
                <Stack Gap="4">
                    <Heading Level="4" Class="text-base font-medium leading-none">Settings</Heading>
                    <Grid Columns="3" Gap="4" Class="items-center">
                        <Label>Name</Label>
                        <Input Class="col-span-2 h-8" Value="My Project" />
                        <Label>Status</Label>
                        <Input Class="col-span-2 h-8" Value="Active" />
                    </Grid>
                    <Button Size="Button.ButtonSize.Sm">Save</Button>
                </Stack>
            </PopoverContent>
        </Popover>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Popover</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpen</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Controls whether the popover is open. Use with @@bind-IsOpen for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpenChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;bool&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the open state changes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">PopoverContent</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Side</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">PopoverSide</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Bottom</td>
                            <td class="p-3 text-muted-foreground">Which side of the trigger the popover appears on. Values: Top, Bottom, Left, Right.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Align</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">PopoverAlign</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Center</td>
                            <td class="p-3 text-muted-foreground">Horizontal alignment of the popover relative to its trigger. Values: Start, Center, End.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

