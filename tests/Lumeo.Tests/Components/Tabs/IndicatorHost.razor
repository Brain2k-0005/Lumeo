@namespace Lumeo.Tests.Components.Tabs

@* Test host for finding #46: the active tab value never changes ("a"); only the
   unrelated [Parameter] Wide flips, forcing a re-render. A data-wide attribute
   marks the change in the DOM so the render is observable, but ActiveValue stays
   constant — exactly the "geometry changes, value does not" scenario. *@
<div data-wide="@(Wide ? "true" : "false")">
    <Tabs ActiveValue="a" AnimatedIndicator="true">
        <TabsList>
            <TabsTrigger Value="a">Tab A</TabsTrigger>
            <TabsTrigger Value="b">Tab B</TabsTrigger>
        </TabsList>
        <TabsContent Value="a">Panel A</TabsContent>
        <TabsContent Value="b">Panel B</TabsContent>
    </Tabs>
</div>

@code {
    [Parameter] public bool Wide { get; set; }
}
