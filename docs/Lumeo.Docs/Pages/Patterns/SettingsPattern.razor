@page "/blocks/settings"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>Settings Pattern — Lumeo</PageTitle>

<PageHeader Title="Settings Page" Description="A full settings layout with sidebar navigation and multiple configuration sections." />

<Stack Class="w-full min-w-[700px]">
    <Flex Class="gap-8 min-h-[600px]">

        <!-- Left Nav -->
        <Stack Class="w-56 shrink-0 space-y-1">
            @foreach (var navItem in _sections)
            {
                <Button Variant="Button.ButtonVariant.Ghost"
                        Class="@($"w-full flex items-center gap-3 rounded-md px-3 py-2 text-sm font-medium transition-colors {(_activeSection == navItem.Id ? "bg-accent text-accent-foreground" : "text-muted-foreground hover:bg-accent hover:text-accent-foreground")}")"
                        @onclick="@(() => _activeSection = navItem.Id)">
                    <DynamicIcon Name="@navItem.IconName" Class="h-4 w-4" />
                    @(navItem.Label)
                </Button>
            }
        </Stack>

        <!-- Content -->
        <Stack Class="flex-1 min-w-0">

            <!-- Profile Section -->
            @if (_activeSection == "profile")
            {
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Profile</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Manage your public profile information.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="6">
                            <Flex Class="items-center gap-4">
                                <Flex Class="h-20 w-20 rounded-full bg-muted items-center justify-center shrink-0">
                                    <DynamicIcon Name="User" Class="h-10 w-10 text-muted-foreground" />
                                </Flex>
                                <Stack Gap="1">
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Profile photo</Lumeo.Text>
                                    <Lumeo.Text Class="text-xs text-muted-foreground">JPG, GIF or PNG. 1MB max.</Lumeo.Text>
                                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Change Avatar</Button>
                                </Stack>
                            </Flex>
                            <Separator />
                            <Grid Class="grid-cols-1 sm:grid-cols-2 gap-4">
                                <Stack Gap="2">
                                    <Label>First name</Label>
                                    <Input placeholder="First name" Value="Olivia" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label>Last name</Label>
                                    <Input placeholder="Last name" Value="Martin" />
                                </Stack>
                            </Grid>
                            <Stack Gap="2">
                                <Label>Email</Label>
                                <Input type="email" placeholder="name@example.com" Value="olivia.martin@example.com" />
                            </Stack>
                            <Stack Gap="2">
                                <Label>Bio</Label>
                                <Textarea placeholder="Tell us a little bit about yourself..." />
                            </Stack>
                        </Stack>
                    </CardContent>
                    <CardFooter>
                        <Flex Class="justify-end gap-2 w-full">
                            <Button Variant="Button.ButtonVariant.Outline">Cancel</Button>
                            <Button>Save changes</Button>
                        </Flex>
                    </CardFooter>
                </Card>
            }

            <!-- Account Section -->
            @if (_activeSection == "account")
            {
                <Stack Gap="6">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Change Password</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Update your password to keep your account secure.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="4" Class="max-w-sm">
                                <Stack Gap="2">
                                    <Label>Current password</Label>
                                    <Input type="password" placeholder="Enter current password" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label>New password</Label>
                                    <Input type="password" placeholder="Enter new password" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label>Confirm new password</Label>
                                    <Input type="password" placeholder="Confirm new password" />
                                </Stack>
                            </Stack>
                        </CardContent>
                        <CardFooter>
                            <Button>Update password</Button>
                        </CardFooter>
                    </Card>

                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Two-Factor Authentication</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Add an extra layer of security to your account.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Flex Class="items-center justify-between">
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Enable 2FA</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">Require a verification code when signing in.</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="_twoFactor" />
                            </Flex>
                        </CardContent>
                    </Card>

                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight text-destructive">Danger Zone</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Irreversible and destructive actions.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Alert Variant="Alert.AlertVariant.Destructive" Class="mb-4">
                                <Lumeo.Text Class="font-medium">Warning</Lumeo.Text>
                                <Lumeo.Text Class="text-sm mt-1">Deleting your account is permanent. All your data will be permanently removed and cannot be recovered.</Lumeo.Text>
                            </Alert>
                            <Button Variant="Button.ButtonVariant.Destructive">
                                <DynamicIcon Name="Trash" Class="h-4 w-4 mr-2" />
                                Delete account
                            </Button>
                        </CardContent>
                    </Card>
                </Stack>
            }

            <!-- Appearance Section -->
            @if (_activeSection == "appearance")
            {
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Appearance</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Customize how Lumeo looks on your device.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="6">
                            <Stack Gap="3">
                                <Label>Theme</Label>
                                <Lumeo.Text Class="text-sm text-muted-foreground">Select the theme for the interface.</Lumeo.Text>
                                <ToggleGroup Type="ToggleGroup.ToggleGroupType.Single" Variant="ToggleGroup.ToggleGroupVariant.Outline">
                                    <ToggleGroupItem Value="light">Light</ToggleGroupItem>
                                    <ToggleGroupItem Value="dark">Dark</ToggleGroupItem>
                                    <ToggleGroupItem Value="system">System</ToggleGroupItem>
                                </ToggleGroup>
                            </Stack>
                            <Separator />
                            <Stack Gap="3">
                                <Flex Class="items-center justify-between">
                                    <Stack>
                                        <Label>Font size</Label>
                                        <Lumeo.Text Class="text-sm text-muted-foreground">Adjust the base font size for readability.</Lumeo.Text>
                                    </Stack>
                                    <Lumeo.Text As="span" Class="text-sm font-medium text-foreground">@_fontSize px</Lumeo.Text>
                                </Flex>
                                <Slider @bind-Value="_fontSize" Min="12" Max="20" Step="1" Class="max-w-xs" />
                                <Flex Class="justify-between text-xs text-muted-foreground max-w-xs">
                                    <Lumeo.Text As="span">12px</Lumeo.Text>
                                    <Lumeo.Text As="span">20px</Lumeo.Text>
                                </Flex>
                            </Stack>
                            <Separator />
                            <Stack Gap="3">
                                <Label>Accent color</Label>
                                <Lumeo.Text Class="text-sm text-muted-foreground">Choose your preferred accent color.</Lumeo.Text>
                                <Flex Class="gap-3 flex-wrap">
                                    @foreach (var color in _accentColors)
                                    {
                                        <Button Variant="Button.ButtonVariant.Ghost"
                                                Class="@($"h-8 w-8 p-0 rounded-full transition-all ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 {(_selectedAccent == color.Name ? "ring-2 ring-ring ring-offset-2" : "hover:scale-110")}")"
                                                style="@($"background-color: {color.Hex};")"
                                                title="@color.Name"
                                                @onclick="@(() => _selectedAccent = color.Name)">
                                        </Button>
                                    }
                                </Flex>
                            </Stack>
                        </Stack>
                    </CardContent>
                    <CardFooter>
                        <Flex Class="justify-end gap-2 w-full">
                            <Button Variant="Button.ButtonVariant.Outline">Reset to defaults</Button>
                            <Button>Save preferences</Button>
                        </Flex>
                    </CardFooter>
                </Card>
            }

            <!-- Notifications Section -->
            @if (_activeSection == "notifications")
            {
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Notifications</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Configure how you receive notifications.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="6">
                            @foreach (var notif in _notifications)
                            {
                                <Flex Class="items-center justify-between py-3">
                                    <Stack Gap="1">
                                        <Lumeo.Text Class="text-sm font-medium text-foreground">@notif.Title</Lumeo.Text>
                                        <Lumeo.Text Class="text-sm text-muted-foreground">@notif.Description</Lumeo.Text>
                                    </Stack>
                                    <Switch @bind-Checked="notif.Enabled" />
                                </Flex>
                                @if (notif != _notifications.Last())
                                {
                                    <Separator />
                                }
                            }
                        </Stack>
                    </CardContent>
                    <CardFooter>
                        <Flex Class="justify-end w-full">
                            <Button>Save preferences</Button>
                        </Flex>
                    </CardFooter>
                </Card>
            }

            <!-- Display Section -->
            @if (_activeSection == "display")
            {
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Display</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Control what information is displayed in the app.</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="6">
                            <Flex Class="items-center justify-between">
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Show online status</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">Let others see when you are active.</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="_showOnlineStatus" />
                            </Flex>
                            <Separator />
                            <Flex Class="items-center justify-between">
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Compact mode</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">Reduce spacing for a denser layout.</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="_compactMode" />
                            </Flex>
                            <Separator />
                            <Flex Class="items-center justify-between">
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Show activity feed</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">Display recent activity on the dashboard.</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="_showActivityFeed" />
                            </Flex>
                            <Separator />
                            <Flex Class="items-center justify-between">
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-medium text-foreground">Keyboard shortcuts</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">Enable keyboard shortcuts for faster navigation.</Lumeo.Text>
                                </Stack>
                                <Switch @bind-Checked="_keyboardShortcuts" />
                            </Flex>
                        </Stack>
                    </CardContent>
                    <CardFooter>
                        <Flex Class="justify-end w-full">
                            <Button>Save preferences</Button>
                        </Flex>
                    </CardFooter>
                </Card>
            }

        </Stack>
    </Flex>
</Stack>

@code {
    private string _activeSection = "profile";

    private double _fontSize = 14;
    private string _selectedAccent = "Indigo";
    private bool _twoFactor;
    private bool _showOnlineStatus = true;
    private bool _compactMode;
    private bool _showActivityFeed = true;
    private bool _keyboardShortcuts = true;

    private record NavSection(string Id, string Label, string IconName);
    private record AccentColor(string Name, string Hex);

    private readonly List<NavSection> _sections = new()
    {
        new("profile", "Profile", "User"),
        new("account", "Account", "Settings"),
        new("appearance", "Appearance", "Sun"),
        new("notifications", "Notifications", "Bell"),
        new("display", "Display", "Monitor"),
    };

    private readonly List<AccentColor> _accentColors = new()
    {
        new("Slate", "#64748b"),
        new("Indigo", "#6366f1"),
        new("Violet", "#8b5cf6"),
        new("Blue", "#3b82f6"),
        new("Cyan", "#06b6d4"),
        new("Green", "#22c55e"),
        new("Orange", "#f97316"),
        new("Rose", "#f43f5e"),
    };

    private class NotificationSetting
    {
        public string Title { get; init; } = "";
        public string Description { get; init; } = "";
        public bool Enabled { get; set; }
    }

    private readonly List<NotificationSetting> _notifications = new()
    {
        new() { Title = "Email notifications", Description = "Receive notifications via email for account activity and updates.", Enabled = true },
        new() { Title = "Push notifications", Description = "Get push notifications on your device for important alerts.", Enabled = true },
        new() { Title = "SMS notifications", Description = "Receive text messages for critical account notifications.", Enabled = false },
        new() { Title = "Marketing emails", Description = "Receive emails about new features, tips, and special offers.", Enabled = false },
        new() { Title = "Security alerts", Description = "Be notified about new sign-ins and suspicious activity.", Enabled = true },
    };
}
