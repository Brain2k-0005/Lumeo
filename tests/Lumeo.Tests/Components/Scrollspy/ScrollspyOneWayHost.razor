@namespace Lumeo.Tests.Components.Scrollspy

@* Regression host for triage #99 (state-on-data-change, Gantt-class).
   ActiveId is bound ONE-WAY: the consumer supplies it but never round-trips the
   ActiveIdChanged callback back into it. Marker is an unrelated parameter used to
   force an unrelated re-render (OnParametersSet) without changing ActiveId. *@
<Lumeo.Scrollspy Offset="50" ActiveId="@ActiveId">
    <Lumeo.ScrollspyLink Target="intro">Intro</Lumeo.ScrollspyLink>
    <Lumeo.ScrollspyLink Target="features">Features</Lumeo.ScrollspyLink>
    <Lumeo.ScrollspySection Id="intro">Intro body</Lumeo.ScrollspySection>
    <Lumeo.ScrollspySection Id="features">Features body</Lumeo.ScrollspySection>
</Lumeo.Scrollspy>

@code {
    [Parameter] public string? ActiveId { get; set; }

    // Unrelated parameter: bumping it triggers a re-render (and OnParametersSet on
    // the Scrollspy) while ActiveId stays the same.
    [Parameter] public int Marker { get; set; }
}
