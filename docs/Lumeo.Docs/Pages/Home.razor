                        </Flex>
                        <Lumeo.Link Href="components/dropdown-menu" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- DatePicker + Dialog -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <Stack Gap="3" Class="flex-1 items-center justify-center p-5 min-h-[160px] bg-muted/10">
                        <div class="w-full max-w-[240px]">
