<Stack Gap="2" Class="mb-8">
    <Heading Level="1" Size="3xl">@Title</Heading>
    @if (Description != null)
    {
        <Lumeo.Text Size="lg" Color="muted">@Description</Lumeo.Text>
    }
</Stack>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string? Description { get; set; }
}
