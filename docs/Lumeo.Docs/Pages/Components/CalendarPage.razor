@page "/components/calendar"

<PageTitle>Calendar — Lumeo</PageTitle>

<PageHeader Title="Calendar" Description="A date picker calendar component for selecting dates." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_selectedDate" />
            </Stack>
        </Flex>
        @if (_selectedDate.HasValue)
        {
            <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-4">Selected: @_selectedDate.Value.ToString("MMMM d, yyyy")</Lumeo.Text>
        }
    </ComponentDemo>

    <ComponentDemo Title="Date Range Display" Code="@_rangeCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Stack Direction="Stack.StackDirection.Horizontal" Gap="4" Class="flex-col sm:flex-row">
                <Stack Gap="1.5" Class="flex-1">
                    <Label>Check-in</Label>
                    <Stack Class="rounded-md border bg-card p-1">
                        <Calendar @bind-Value="_checkIn" />
                    </Stack>
                </Stack>
            </Stack>
            @if (_checkIn.HasValue)
            {
                <Flex Align="center" Gap="2" Class="p-3 rounded-md bg-muted/50 text-sm">
                    <DynamicIcon Name="Calendar" Class="h-4 w-4 text-muted-foreground" />
                    <Lumeo.Text As="span" Size="sm">Check-in: <strong>@_checkIn.Value.ToString("MMM d, yyyy")</strong></Lumeo.Text>
                </Flex>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Pre-selected Date" Code="@_preselectedCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_preselectedDate" />
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Min & Max Date" Code="@_minMaxCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_constrainedDate" MinDate="@_minDate" MaxDate="@_maxDate" />
            </Stack>
        </Flex>
        <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-2">Selectable range: @_minDate.ToString("MMM d") — @_maxDate.ToString("MMM d, yyyy")</Lumeo.Text>
    </ComponentDemo>

    <ComponentDemo Title="Date Range" Code="@_dateRangeCode">
        <Stack Gap="2">
            <Flex Justify="center">
                <Stack Class="rounded-md border bg-card p-1">
                    <Calendar IsRange="true" @bind-RangeStart="_rangeStart" @bind-RangeEnd="_rangeEnd" />
                </Stack>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Class="text-center">
                @if (_rangeStart.HasValue && _rangeEnd.HasValue)
                {
                    @($"Selected: {_rangeStart:MMM dd} — {_rangeEnd:MMM dd}")
                }
                else if (_rangeStart.HasValue)
                {
                    @($"Start: {_rangeStart:MMM dd} — pick end date")
                }
                else
                {
                    <Lumeo.Text As="span">Pick a start date</Lumeo.Text>
                }
            </Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="calendar" Level="3" Class="mt-8 scroll-mt-20">Calendar</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">Value</TableCell><TableCell Class="font-mono text-xs">DateOnly?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The currently selected date. Use with @@bind-Value for two-way binding.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ValueChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;DateOnly?&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Callback invoked when the selected date changes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">MinDate</TableCell><TableCell Class="font-mono text-xs">DateOnly?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The earliest selectable date. Dates before this are disabled.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">MaxDate</TableCell><TableCell Class="font-mono text-xs">DateOnly?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The latest selectable date. Dates after this are disabled.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsRange</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Enables date range selection mode.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">RangeStart</TableCell><TableCell Class="font-mono text-xs">DateOnly?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The start of the selected date range. Use with @@bind-RangeStart.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">RangeStartChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;DateOnly?&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Callback invoked when the range start changes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">RangeEnd</TableCell><TableCell Class="font-mono text-xs">DateOnly?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>The end of the selected date range. Use with @@bind-RangeEnd.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">RangeEndChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;DateOnly?&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Callback invoked when the range end changes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">NumberOfMonths</TableCell><TableCell Class="font-mono text-xs">int</TableCell><TableCell Class="font-mono text-xs">1</TableCell><TableCell>Number of months to display side by side.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowWeekNumbers</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Displays ISO week numbers alongside the calendar rows.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ShowYearPicker</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Enables the year picker view.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">InitialView</TableCell><TableCell Class="font-mono text-xs">string</TableCell><TableCell Class="font-mono text-xs">"Days"</TableCell><TableCell>Initial calendar view. Values: "Days", "Months", "Years".</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsDateDisabled</TableCell><TableCell Class="font-mono text-xs">Func&lt;DateTime, bool&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Custom function to disable specific dates.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">DateClass</TableCell><TableCell Class="font-mono text-xs">Func&lt;DateTime, string&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Custom function to add CSS classes to specific dates.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">FirstDayOfWeek</TableCell><TableCell Class="font-mono text-xs">DayOfWeek</TableCell><TableCell Class="font-mono text-xs">Sunday</TableCell><TableCell>The first day of the week in the calendar grid.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Class</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional CSS classes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

@code {
    private DateOnly? _selectedDate;
    private DateOnly? _preselectedDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _checkIn;
    private DateOnly? _constrainedDate;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;

    private string _defaultCode = @"<Calendar @bind-Value=""_selectedDate"" />";

    private string _rangeCode = @"<Stack Gap=""1.5"">
    <Label>Check-in</Label>
    <div class=""rounded-md border p-1"">
        <Calendar @bind-Value=""_checkIn"" />
    </div>
</Stack>
@if (_checkIn.HasValue)
{
    <Flex Align=""center"" Gap=""2"" Class=""p-3 rounded-md bg-muted/50 text-sm"">
        <DynamicIcon Name=""Calendar"" Class=""h-4 w-4 text-muted-foreground"" />
        <Lumeo.Text As=""span"" Size=""sm"">Check-in: <strong>@_checkIn.Value.ToString(""MMM d, yyyy"")</strong></Lumeo.Text>
    </Flex>
}";

    private string _preselectedCode = @"<Calendar @bind-Value=""_date"" />

@code {
    private DateOnly? _date = DateOnly.FromDateTime(DateTime.Today);
}";

    private string _minMaxCode = @"<Calendar @bind-Value=""_date"" MinDate=""@_minDate"" MaxDate=""@_maxDate"" />

@code {
    private DateOnly? _date;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
}";

    private string _dateRangeCode = @"<Calendar IsRange=""true"" @bind-RangeStart=""_rangeStart"" @bind-RangeEnd=""_rangeEnd"" />

@if (_rangeStart.HasValue && _rangeEnd.HasValue)
{
    <Lumeo.Text Size=""sm"" Color=""muted"">Selected: @($""{_rangeStart:MMM dd} — {_rangeEnd:MMM dd}"")</Lumeo.Text>
}

@code {
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
}";
}
