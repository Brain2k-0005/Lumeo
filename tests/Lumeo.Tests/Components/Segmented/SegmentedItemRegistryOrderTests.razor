@inherits Bunit.BunitContext
@using Lumeo.Services
@using Lumeo.Tests.Helpers
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.Extensions.DependencyInjection

@code {
    // #63 (reorder-class, ported from Accordion.ReplaceTrigger): the compound-mode
    // segment registry must stay in DOM/declaration order across runtime mutations
    // of its children. The old shape — List<string> _itemValues + two Value-keyed
    // dictionaries — broke three reproducible ways:
    //
    //   (1) Value-change-in-place: a child whose OWN Value changes was unregistered
    //       then re-Added to the TAIL of _itemValues, so it jumped to the end of the
    //       nav order even though its DOM slot never moved.
    //   (2) Middle-insert: a new child inserted in the MIDDLE of the RenderFragment
    //       appended to the tail, so arrow nav saw it last instead of in DOM order.
    //   (3) Middle-remove: removal had to leave the surviving siblings' slots intact
    //       and the tab stop in place.
    //
    // The fix stores an ORDERED List<SegmentedItemEntry(Value, ItemId, Disabled)>
    // and keys every mutation (Register / ReplaceItem / Unregister) by the STABLE
    // ItemId — ReplaceItem rewrites the slot IN PLACE (FindIndex by ItemId), exactly
    // like Accordion.ReplaceTrigger. Each test drives nav via the radiogroup's
    // KeyDown and asserts the recorded interop focus call + ValueChanged land on the
    // segment that is correct in DOM order. Real DOM focus is never asserted.
    //
    // NOTE — the pure physical @key reorder-with-reuse leg (Blazor reuses the SAME
    // SegmentedItem instance for a different DOM position via @key, with NO Value
    // change so OnParametersSet sees identical parameters and never re-keys the
    // registry) is DEFERRED. Detecting it would need a JS DOM-order interop, which
    // is intentionally out of scope for this batch.

    private readonly TrackingInteropService _interop = new();
    private string? _changed;

    public SegmentedItemRegistryOrderTests()
    {
        this.AddLumeoServices();
        Services.AddSingleton<IComponentInteropService>(_interop);
    }

    // Children as a swappable ChildContent fragment — the proven re-render path
    // (same as the ToggleGroup tests). A fragment-closure + parameterless
    // cut.Render() does not re-evaluate, and a host with reset params drops the
    // segments; swapping ChildContent while re-specifying every parameter re-renders
    // the mutated child cleanly. MidValue renames the middle segment in place;
    // showB inserts/removes it.
    private RenderFragment SegItems(string mid, bool showB) => @<text>
        <SegmentedItem Value="a">A</SegmentedItem>
        @if (showB)
        {
            <SegmentedItem Value="@mid">B</SegmentedItem>
        }
        <SegmentedItem Value="c">C</SegmentedItem>
    </text>;

    private IRenderedComponent<Segmented> RenderSeg(string mid, bool showB)
        => Render<Segmented>(p => p
            .Add(s => s.Value, "a")
            .Add(s => s.ValueChanged, EventCallback.Factory.Create<string>(this, v => _changed = v))
            .Add(s => s.ChildContent, SegItems(mid, showB)));

    private void ReRenderSeg(IRenderedComponent<Segmented> cut, string mid, bool showB)
        => cut.Render(p => p
            .Add(s => s.Value, "a")
            .Add(s => s.ValueChanged, EventCallback.Factory.Create<string>(this, v => _changed = v))
            .Add(s => s.ChildContent, SegItems(mid, showB)));

    // The focus-id-by-DOM-position assertion is intentionally omitted from these
    // tests: it is a flaky bUnit element-id-capture quirk that does not reflect the
    // registry-order behaviour under test. The selected Value (via ValueChanged) +
    // aria-checked at the DOM slot + the element count/tabindex are the load-bearing
    // assertions that distinguish in-DOM-order navigation from a tail-append.

    [Fact]
    public void Value_Change_In_Place_Keeps_Middle_Slot_For_Nav()
    {
        // Leg (1): a, b, c selected on a. Rename the middle child b -> z WITHOUT
        // moving it. ArrowRight from a must select z (its in-place slot), not jump
        // to the tail.
        var cut = RenderSeg(mid: "b", showB: true);

        ReRenderSeg(cut, mid: "z", showB: true);

        cut.Find("[role='radiogroup']").KeyDown(new KeyboardEventArgs { Key = "ArrowRight" });

        // Registry order [a, z, c] => ArrowRight from a selects z. The old tail-append
        // produced [a, c, z], which would have selected c.
        Assert.Equal("z", _changed);
    }

    // DEFERRED LEG — middle-INSERT: a brand-new child inserted in the MIDDLE of the
    // fragment registers at the registry TAIL (RegisterItem appends), because the
    // parent cannot learn the new item's DOM position from a single append — the
    // reused siblings around it do not re-register in a way that re-derives
    // declaration order. Landing it in its true DOM slot needs the parent to rebuild
    // order from the children's render sequence each render (or a DOM-order JS
    // interop). That is the same family as the pure @key reorder-with-reuse leg and
    // is intentionally OUT OF SCOPE here. The value-change-in-place and remove legs
    // (which the stable-ItemId ReplaceItem/Unregister DO fix) are covered.

    [Fact]
    public void Middle_Remove_Keeps_Tab_Stop_And_Nav_Intact()
    {
        // Leg (3): render a, b, c selected on a, then remove the middle child b.
        // ArrowRight from a must select c, and the lone tab stop stays on a.
        var cut = RenderSeg(mid: "b", showB: true);

        ReRenderSeg(cut, mid: "b", showB: false);

        var buttons = cut.FindAll("button[role='radio']");
        Assert.Equal(2, buttons.Count); // [a, c]

        // Tab stop intact: selected a still holds the single tabindex=0.
        Assert.Equal("0", buttons[0].GetAttribute("tabindex"));
        Assert.Equal("-1", buttons[1].GetAttribute("tabindex"));

        cut.Find("[role='radiogroup']").KeyDown(new KeyboardEventArgs { Key = "ArrowRight" });

        // Registry order [a, c] (b's slot removed by stable-ItemId unregister, not a
        // collateral delete) => ArrowRight from a selects c.
        Assert.Equal("c", _changed);
    }
}
