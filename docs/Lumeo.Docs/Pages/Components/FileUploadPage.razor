@page "/components/file-upload"

<PageTitle>File Upload — Lumeo</PageTitle>

<PageHeader Title="File Upload" Description="A drag-and-drop file upload area with per-file progress tracking, validation, cancel, and retry." />

<InstallUsage Component="FileUpload" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>File attachments in forms such as resumes, invoices, or supporting documents</li>
        <li>Image uploads for profile pictures, product photos, or galleries</li>
        <li>Document submissions with drag-and-drop zones for a better user experience</li>
        <li>Bulk file uploads with per-file progress indicators, cancel, and retry</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload OnFilesSelected="HandleFiles" />
            @if (_fileName is not null)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_fileName</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Image Upload" Code="@_imageCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload Label="Upload an image" Description="PNG, JPG or GIF up to 10MB" Accept="image/*" OnFilesSelected="HandleImageFiles" />
            @if (_imageName is not null)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_imageName</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Files" Code="@_multipleCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload Label="Upload documents" Description="Select one or more files" Multiple="true" OnFilesSelected="HandleMultipleFiles" />
            @if (_fileCount > 0)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">@_fileCount file(s) selected</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Upload with progress (fake delay)" Code="@_uploadPipelineCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload
                Multiple="true"
                Label="Upload files"
                Description="Each file uploads with simulated progress"
                OnUpload="@SimulateUpload"
                OnFileUploaded="@(item => _uploadedCount++)"
                OnAllUploaded="@(items => _allDoneMsg = $"All {items.Count} file(s) done!")" />
            @if (_allDoneMsg is not null)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">@_allDoneMsg</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Manual upload trigger (AutoUpload=false)" Code="@_manualCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <FileUpload
                Multiple="true"
                AutoUpload="false"
                Label="Choose files, then click Upload"
                OnUpload="@SimulateUpload" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Immediate upload (ShowFileList=false + Reset)" Code="@_immediateUploadCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="3">
                <FileUpload @ref="_immediateUpload"
                            Label="Pick a file — it uploads immediately, no card shown"
                            ShowFileList="false"
                            OnUpload="@ImmediateUpload"
                            OnFileUploaded="@OnImmediateFileUploaded" />
                @if (_immediateFiles.Count > 0)
                {
                    <ul class="space-y-1">
                        @foreach (var name in _immediateFiles)
                        {
                            <li class="flex items-center gap-2 text-sm">
                                <span class="text-success">&#10003;</span>
                                <span>@name</span>
                            </li>
                        }
                    </ul>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm"
                            @onclick="ClearImmediateList">Clear list</Button>
                }
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Progress (legacy)" Code="@_progressCode">
        <Stack Gap="4" Class="w-full max-w-md">
            <FileUpload ShowProgress="true" Progress="@_uploadProgress" OnFilesSelected="@HandleFileUpload" Accept="image/*" Multiple="true"
                        Label="Upload Images" Description="PNG, JPG up to 10MB" />
            @if (_isUploading)
            {
                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" disabled>Uploading...</Button>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Variant — interactive preview" Code="@_variantInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch between Dropzone, Button, and Avatar to see the upload surface change.</Lumeo.Text>
            <Segmented @bind-Value="_previewVariant">
                <SegmentedItem Value="Dropzone">Dropzone</SegmentedItem>
                <SegmentedItem Value="Button">Button</SegmentedItem>
                <SegmentedItem Value="Avatar">Avatar</SegmentedItem>
            </Segmented>
            <Container MaxWidth="md" Center="false" Padding="">
                <FileUpload Variant="_fuVariantEnum"
                            Label="Upload file"
                            Description="PNG, JPG or PDF up to 10MB"
                            OnFilesSelected="@(e => _previewFileName = e.File.Name)" />
                @if (_previewFileName is not null)
                {
                    <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_previewFileName</Lumeo.Text>
                }
            </Container>
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="fileupload" Level="3" Class="mt-8 scroll-mt-20">FileUpload</Heading>
    <div class="mt-4">
        <PropsTable Slug="file-upload" />
    </div>

    <Heading Id="fileupload-methods" Level="3" Class="mt-8 scroll-mt-20">FileUpload — Public Methods</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[200px]">Method</TableHead>
                    <TableHead Class="w-[120px]">Returns</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">Reset()</TableCell><TableCell Class="font-mono text-xs">Task</TableCell><TableCell>Clears internal file selection and upload state. Cancels any in-flight uploads. Remounts the native file input so the same file can be re-picked without a DOM workaround. Does not fire any events.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">StartUploadAsync()</TableCell><TableCell Class="font-mono text-xs">Task</TableCell><TableCell>Starts uploads for all pending items when <code>AutoUpload=false</code>.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

    <Heading Id="fileuploaditem" Level="3" Class="mt-8 scroll-mt-20">FileUploadItem</Heading>
    <p class="mt-2 text-sm text-muted-foreground">Represents the state of each file in the upload queue. Passed to <code>OnUpload</code>, <code>OnFileUploaded</code>, <code>OnFileFailed</code>, etc.</p>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[160px]">Property</TableHead>
                    <TableHead Class="w-[160px]">Type</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">Id</TableCell><TableCell Class="font-mono text-xs">string</TableCell><TableCell>Unique identifier (Guid hex) for this upload item.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">File</TableCell><TableCell Class="font-mono text-xs">IBrowserFile</TableCell><TableCell>The underlying browser file reference.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Name</TableCell><TableCell Class="font-mono text-xs">string</TableCell><TableCell>File name.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Size</TableCell><TableCell Class="font-mono text-xs">long</TableCell><TableCell>File size in bytes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Status</TableCell><TableCell Class="font-mono text-xs">FileUploadStatus</TableCell><TableCell>Current status: <code>Pending</code>, <code>Uploading</code>, <code>Succeeded</code>, <code>Failed</code>, <code>Cancelled</code>.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ProgressPercent</TableCell><TableCell Class="font-mono text-xs">int</TableCell><TableCell>Upload progress 0–100, updated via IProgress.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ErrorMessage</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell>Error message if Status is Failed.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">Url</TableCell><TableCell Class="font-mono text-xs">string?</TableCell><TableCell>Server-returned URL or id after a successful upload.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">ChunkSize</TableCell><TableCell Class="font-mono text-xs">long</TableCell><TableCell>Chunk-size hint from the <code>ChunkSize</code> parameter (0 if not set).</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — For standard text and data entry fields</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — For triggering file selection via a button-style upload</li>
        <li><a href="/components/progress" class="text-primary hover:underline">Progress</a> — For showing upload progress as a standalone bar</li>
    </ul>
</div>

@code {
    private string? _fileName;
    private string? _imageName;
    private FileUpload? _immediateUpload;
    private List<string> _immediateFiles = new();
    private string _previewVariant = "Dropzone";
    private string? _previewFileName;
    private FileUpload.FileUploadVariant _fuVariantEnum =>
        Enum.TryParse<FileUpload.FileUploadVariant>(_previewVariant, out var v) ? v : FileUpload.FileUploadVariant.Dropzone;

    private string _variantInteractiveCode = @"<Segmented @bind-Value=""_variant"">
    <SegmentedItem Value=""Dropzone"">Dropzone</SegmentedItem>
    <SegmentedItem Value=""Button"">Button</SegmentedItem>
    <SegmentedItem Value=""Avatar"">Avatar</SegmentedItem>
</Segmented>
<FileUpload Variant=""@Enum.Parse<FileUpload.FileUploadVariant>(_variant)""
            Label=""Upload file"" Description=""PNG, JPG or PDF"" />

@code {
    private string _variant = ""Dropzone"";
}";
    private int _fileCount;
    private int _uploadProgress;
    private bool _isUploading;
    private int _uploadedCount;
    private string? _allDoneMsg;

    private async Task<string?> ImmediateUpload(
        FileUpload.FileUploadItem item,
        IProgress<int> progress,
        CancellationToken ct)
    {
        for (int pct = 0; pct <= 100; pct += 20)
        {
            ct.ThrowIfCancellationRequested();
            progress.Report(pct);
            await Task.Delay(50, ct);
        }
        return $"https://cdn.example.com/{item.Name}";
    }

    private async Task OnImmediateFileUploaded(FileUpload.FileUploadItem item)
    {
        _immediateFiles.Add(item.Name);
        if (_immediateUpload is not null)
            await _immediateUpload.Reset();
    }

    private void ClearImmediateList() => _immediateFiles.Clear();

    private void HandleFiles(InputFileChangeEventArgs e)
    {
        _fileName = e.File.Name;
    }

    private void HandleImageFiles(InputFileChangeEventArgs e)
    {
        _imageName = e.File.Name;
    }

    private void HandleMultipleFiles(InputFileChangeEventArgs e)
    {
        _fileCount = e.FileCount;
    }

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _uploadProgress = 0;
        for (int i = 0; i <= 100; i += 20)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(300);
        }
        _isUploading = false;
        StateHasChanged();
    }

    // Fake upload handler — simulates 500ms upload with progress reporting
    private async Task<string?> SimulateUpload(
        FileUpload.FileUploadItem item,
        IProgress<int> progress,
        CancellationToken ct)
    {
        for (int pct = 0; pct <= 100; pct += 10)
        {
            ct.ThrowIfCancellationRequested();
            progress.Report(pct);
            await Task.Delay(50, ct);
        }
        return $"https://cdn.example.com/{item.Name}";
    }

    private string _defaultCode = @"<FileUpload OnFilesSelected=""HandleFiles"" />";

    private string _imageCode = @"<FileUpload
    Label=""Upload an image""
    Description=""PNG, JPG or GIF up to 10MB""
    Accept=""image/*""
    OnFilesSelected=""HandleFiles"" />";

    private string _multipleCode = @"<FileUpload
    Label=""Upload documents""
    Description=""Select one or more files""
    Multiple=""true""
    OnFilesSelected=""HandleFiles"" />";

    private string _uploadPipelineCode = @"<FileUpload
    Multiple=""true""
    Label=""Upload files""
    OnUpload=""@SimulateUpload""
    OnFileUploaded=""@(item => _uploadedCount++)""
    OnAllUploaded=""@(items => _allDoneMsg = $""All {items.Count} file(s) done!"")""  />

@code {
    private async Task<string?> SimulateUpload(
        FileUpload.FileUploadItem item,
        IProgress<int> progress,
        CancellationToken ct)
    {
        for (int pct = 0; pct <= 100; pct += 10)
        {
            ct.ThrowIfCancellationRequested();
            progress.Report(pct);
            await Task.Delay(50, ct);
        }
        return $""https://cdn.example.com/{item.Name}"";
    }
}";

    private string _manualCode = @"<FileUpload
    Multiple=""true""
    AutoUpload=""false""
    Label=""Choose files, then click Upload""
    OnUpload=""@SimulateUpload"" />";

    private string _immediateUploadCode = @"<FileUpload @ref=""_upload""
    Label=""Pick a file — uploads immediately, no card shown""
    ShowFileList=""false""
    OnUpload=""@HandleUpload""
    OnFileUploaded=""@OnFileUploaded"" />

@code {
    private FileUpload? _upload;
    private List<string> _uploadedFiles = new();

    private async Task<string?> HandleUpload(
        FileUpload.FileUploadItem item,
        IProgress<int> progress,
        CancellationToken ct)
    {
        // ... your real upload logic ...
        return $""https://cdn.example.com/{item.Name}"";
    }

    private async Task OnFileUploaded(FileUpload.FileUploadItem item)
    {
        _uploadedFiles.Add(item.Name);   // app renders its own list
        if (_upload is not null)
            await _upload.Reset();       // clear internal state + remount input
    }
}";

    private string _progressCode = @"<FileUpload
    ShowProgress=""true""
    Progress=""@_uploadProgress""
    OnFilesSelected=""@HandleFileUpload""
    Accept=""image/*""
    Multiple=""true""
    Label=""Upload Images""
    Description=""PNG, JPG up to 10MB"" />

@code {
    private int _uploadProgress;
    private bool _isUploading;

    private async Task HandleFileUpload(InputFileChangeEventArgs e)
    {
        _isUploading = true;
        _uploadProgress = 0;
        for (int i = 0; i <= 100; i += 20)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(300);
        }
        _isUploading = false;
        StateHasChanged();
    }
}";
}
