@page "/components/progress"

<PageTitle>Progress — Lumeo</PageTitle>

<PageHeader Title="Progress" Description="Displays a progress bar indicating completion status." />

<InstallUsage Component="Progress" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Show upload or download progress with a percentage bar</li>
        <li>Indicate loading states when the duration is known or estimable</li>
        <li>Visualize step completion in multi-step workflows or wizards</li>
        <li>Display capacity usage such as storage, quotas, or limits</li>
        <li>Use the indeterminate variant for operations with unknown duration</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Stack Gap="2">
                    <Flex Justify="between">
                        <Lumeo.Text As="span" Size="sm" Color="muted">25%</Lumeo.Text>
                    </Flex>
                    <Progress Value="25" />
                </Stack>
                <Stack Gap="2">
                    <Flex Justify="between">
                        <Lumeo.Text As="span" Size="sm" Color="muted">50%</Lumeo.Text>
                    </Flex>
                    <Progress Value="50" />
                </Stack>
                <Stack Gap="2">
                    <Flex Justify="between">
                        <Lumeo.Text As="span" Size="sm" Color="muted">75%</Lumeo.Text>
                    </Flex>
                    <Progress Value="75" />
                </Stack>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Variants" Code="@_variantCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Stack Gap="1">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Default</Lumeo.Text>
                    <Progress Value="60" />
                </Stack>
                <Stack Gap="1">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Success</Lumeo.Text>
                    <Progress Value="100" Variant="Progress.ProgressVariant.Success" />
                </Stack>
                <Stack Gap="1">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Warning</Lumeo.Text>
                    <Progress Value="45" Variant="Progress.ProgressVariant.Warning" />
                </Stack>
                <Stack Gap="1">
                    <Lumeo.Text As="span" Size="sm" Color="muted">Destructive</Lumeo.Text>
                    <Progress Value="80" Variant="Progress.ProgressVariant.Destructive" />
                </Stack>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Interactive" Code="@_interactiveCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Progress Value="@_value" />
                <Flex Align="center" Gap="2">
                    <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="Decrease">-10</Button>
                    <Lumeo.Text As="span" Size="sm" Weight="medium" Color="foreground" Class="min-w-[3ch] text-center">@_value%</Lumeo.Text>
                    <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="Increase">+10</Button>
                </Flex>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Indeterminate" Code="@_indeterminateCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Stack Gap="4">
                <Progress IsIndeterminate="true" />
                <Progress IsIndeterminate="true" Variant="Progress.ProgressVariant.Success" />
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Label" Code="@_labelCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Stack Gap="4">
                <Progress Value="65" ShowLabel="true" />
                <Progress Value="40" ShowLabel="true" Label="Uploading..." />
                <Progress Value="90" ShowLabel="true" Variant="Progress.ProgressVariant.Success" />
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Animated Stripes" Code="@_stripeCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Progress Value="60" Animation="Progress.ProgressAnimation.Stripe" />
                <Progress Value="75" Animation="Progress.ProgressAnimation.Stripe" Variant="Progress.ProgressVariant.Success" />
                <Progress Value="45" Animation="Progress.ProgressAnimation.Stripe" Variant="Progress.ProgressVariant.Warning" />
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Indeterminate Sweep" Code="@_indeterminateSweepCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Progress Animation="Progress.ProgressAnimation.Indeterminate" />
                <Progress Animation="Progress.ProgressAnimation.Indeterminate" Variant="Progress.ProgressVariant.Success" />
                <Lumeo.Text Size="xs" Color="muted">
                    Use when the operation's duration is unknown. A narrow bright segment slides continuously from left to right.
                </Lumeo.Text>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Glow Pulse" Code="@_glowCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Progress Value="70" Animation="Progress.ProgressAnimation.Glow" />
                <Progress Value="40" Animation="Progress.ProgressAnimation.Glow" Variant="Progress.ProgressVariant.Success" />
                <Lumeo.Text Size="xs" Color="muted">
                    The fill bar breathes — suggests "active / in progress" without overwhelming motion.
                </Lumeo.Text>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Variant — interactive" Code="@_variantInteractiveCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Lumeo.Text Size="sm" Color="muted">Pick a variant to see it applied live.</Lumeo.Text>
                <Flex Wrap="true" Gap="2">
                    @foreach (var v in new[] { Progress.ProgressVariant.Default, Progress.ProgressVariant.Success, Progress.ProgressVariant.Warning, Progress.ProgressVariant.Destructive })
                    {
                        var variant = v;
                        <Button Size="Button.ButtonSize.Sm"
                                Variant="@(_progressVariant == variant ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                                OnClick="@(() => _progressVariant = variant)">@variant</Button>
                    }
                </Flex>
                <Progress Value="65" Variant="@_progressVariant" ShowLabel="true" />
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Shape — interactive" Code="@_shapeInteractiveCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <Stack Gap="4">
                <Lumeo.Text Size="sm" Color="muted">Pick a shape to see it applied live.</Lumeo.Text>
                <Flex Gap="2">
                    <Button Size="Button.ButtonSize.Sm"
                            Variant="@(_progressShape == Progress.ProgressShape.Linear ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                            OnClick="@(() => _progressShape = Progress.ProgressShape.Linear)">Linear</Button>
                    <Button Size="Button.ButtonSize.Sm"
                            Variant="@(_progressShape == Progress.ProgressShape.Circular ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                            OnClick="@(() => _progressShape = Progress.ProgressShape.Circular)">Circular</Button>
                </Flex>
                <Progress Value="72" Shape="@_progressShape" ShowLabel="true" />
            </Stack>
        </Container>
    </ComponentDemo>
</Stack>

<div class="mt-12">
    <Heading Id="keyboard-interactions" Level="2" Class="scroll-mt-20">Keyboard Interactions</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Key</TableHead>
                    <TableHead>Action</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell colspan="2"><Lumeo.Text Size="sm" Color="muted">Progress is a display-only component and has no keyboard interactions.</Lumeo.Text></TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

<div class="mt-12 space-y-4">
    <Heading Id="parameter-coverage" Level="2" Class="scroll-mt-20">Parameter Coverage</Heading>
    <Lumeo.Text Size="sm" Color="muted">ProgressVariant, ProgressShape, ProgressAnimation, and value thresholds.</Lumeo.Text>

    <Stack Gap="3">
        <Heading Level="3" Size="sm" Class="font-semibold tracking-tight">Value thresholds</Heading>
        <Stack Gap="2">
            @foreach (var v in new[] { 0, 25, 50, 75, 100 })
            {
                <div class="flex items-center gap-3">
                    <Lumeo.Text As="span" Size="xs" Color="muted" Class="font-mono min-w-[3rem]">@v%</Lumeo.Text>
                    <Progress Value="@v" Class="flex-1" />
                </div>
            }
        </Stack>
    </Stack>

    <AutoVariants TEnum="Progress.ProgressVariant" Title="ProgressVariant" Wrap="false">
        <Progress Value="60" Variant="@context" Class="w-full" />
    </AutoVariants>

    <AutoVariants TEnum="Progress.ProgressShape" Title="ProgressShape">
        <Progress Value="60" Shape="@context" Class="w-48" />
    </AutoVariants>

    <AutoVariants TEnum="Progress.ProgressAnimation" Title="ProgressAnimation" Wrap="false">
        <Progress Value="60" Animation="@context" Class="w-full" />
    </AutoVariants>

    <AutoBoolMatrix ParameterName="IsIndeterminate" Title="IsIndeterminate">
        <OffContent><Progress Value="40" /></OffContent>
        <OnContent><Progress IsIndeterminate="true" /></OnContent>
    </AutoBoolMatrix>

    <AutoBoolMatrix ParameterName="Striped" Title="Striped">
        <OffContent><Progress Value="60" /></OffContent>
        <OnContent><Progress Value="60" Striped="true" /></OnContent>
    </AutoBoolMatrix>
</div>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Progress</Heading>
            <PropsTable Slug="progress" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">CircularProgress</Heading>
            <PropsTable Slug="progress" SubComponent="CircularProgress" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">StepsProgress</Heading>
            <PropsTable Slug="progress" SubComponent="StepsProgress" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="styling-hooks" Level="2" Class="scroll-mt-20">Styling hooks (data-state)</Heading>
    <Lumeo.Text Size="base" Color="muted" Leading="relaxed" Class="mt-3">
        Progress exposes a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-state</code>
        of <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">loading</code>,
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">complete</code>, or
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">indeterminate</code>, plus
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-value</code> and
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-max</code>, so you can restyle the bar at
        completion (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-[state=complete]:…</code>) straight from CSS.
    </Lumeo.Text>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/spinner" class="text-primary hover:underline">Spinner</a> — Use for indeterminate loading states where a circular indicator is more appropriate</li>
        <li><a href="/components/skeleton" class="text-primary hover:underline">Skeleton</a> — Use to show placeholder shapes while content is loading</li>
    </ul>
</div>

@code {
    private int _value = 50;
    private Progress.ProgressVariant _progressVariant = Progress.ProgressVariant.Default;
    private Progress.ProgressShape _progressShape = Progress.ProgressShape.Linear;

    private void Increase() => _value = Math.Min(100, _value + 10);
    private void Decrease() => _value = Math.Max(0, _value - 10);

    private string _variantInteractiveCode = @"<Progress Value=""65"" Variant=""Progress.ProgressVariant.Success"" ShowLabel=""true"" />";
    private string _shapeInteractiveCode = @"@* Linear (default) *@
<Progress Value=""72"" Shape=""Progress.ProgressShape.Linear"" ShowLabel=""true"" />

@* Circular *@
<Progress Value=""72"" Shape=""Progress.ProgressShape.Circular"" ShowLabel=""true"" />";

    private string _defaultCode = @"<Progress Value=""25"" />
<Progress Value=""50"" />
<Progress Value=""75"" />";

    private string _variantCode = @"<Progress Value=""60"" />
<Progress Value=""100"" Variant=""Progress.ProgressVariant.Success"" />
<Progress Value=""45"" Variant=""Progress.ProgressVariant.Warning"" />
<Progress Value=""80"" Variant=""Progress.ProgressVariant.Destructive"" />";

    private string _interactiveCode = @"<Progress Value=""@_value"" />
<Flex Align=""center"" Gap=""2"">
    <Button OnClick=""Decrease"">-10</Button>
    <Lumeo.Text As=""span"" Size=""sm"" Weight=""medium"">@_value%</Lumeo.Text>
    <Button OnClick=""Increase"">+10</Button>
</Flex>

@code {
    private int _value = 50;
    private void Increase() => _value = Math.Min(100, _value + 10);
    private void Decrease() => _value = Math.Max(0, _value - 10);
}";

    private string _indeterminateCode = @"<Progress IsIndeterminate=""true"" />
<Progress IsIndeterminate=""true"" Variant=""Progress.ProgressVariant.Success"" />";

    private string _labelCode = @"<Progress Value=""65"" ShowLabel=""true"" />
<Progress Value=""40"" ShowLabel=""true"" Label=""Uploading..."" />
<Progress Value=""90"" ShowLabel=""true"" Variant=""Progress.ProgressVariant.Success"" />";

    private string _stripeCode = @"<Progress Value=""60"" Animation=""Progress.ProgressAnimation.Stripe"" />
<Progress Value=""75"" Animation=""Progress.ProgressAnimation.Stripe"" Variant=""Progress.ProgressVariant.Success"" />
<Progress Value=""45"" Animation=""Progress.ProgressAnimation.Stripe"" Variant=""Progress.ProgressVariant.Warning"" />";

    private string _indeterminateSweepCode = @"<Progress Animation=""Progress.ProgressAnimation.Indeterminate"" />
<Progress Animation=""Progress.ProgressAnimation.Indeterminate"" Variant=""Progress.ProgressVariant.Success"" />";

    private string _glowCode = @"<Progress Value=""70"" Animation=""Progress.ProgressAnimation.Glow"" />
<Progress Value=""40"" Animation=""Progress.ProgressAnimation.Glow"" Variant=""Progress.ProgressVariant.Success"" />";
