    // Server-side demo state
    private List<Employee> _serverItems = new();
    private int _serverTotalCount;

    private async Task LoadServerData(DataGridServerRequest request)
    {
        try
        {
            await Task.Delay(500, request.CancellationToken);

            var query = _employees.AsQueryable();

            if (!string.IsNullOrEmpty(request.GlobalSearch))
            {
                var s = request.GlobalSearch;
                query = query.Where(e =>
                    e.Name.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    e.Department.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                    e.Status.Contains(s, StringComparison.OrdinalIgnoreCase));
            }

            if (request.Sorts?.Count > 0)
            {
                var sort = request.Sorts[0];
                query = (sort.Field, sort.Direction) switch
                {
                    ("Name", SortDirection.Ascending) => query.OrderBy(e => e.Name),
                    ("Name", SortDirection.Descending) => query.OrderByDescending(e => e.Name),
                    ("Department", SortDirection.Ascending) => query.OrderBy(e => e.Department),
                    ("Department", SortDirection.Descending) => query.OrderByDescending(e => e.Department),
                    ("Salary", SortDirection.Ascending) => query.OrderBy(e => e.Salary),
                    ("Salary", SortDirection.Descending) => query.OrderByDescending(e => e.Salary),
                    _ => query
                };
            }

            _serverTotalCount = query.Count();
            _serverItems = query
                .Skip((request.Page - 1) * request.PageSize)
                .Take(request.PageSize)
                .ToList();
        }
        catch (OperationCanceledException) { }
    }

    // Error-handling demo state
    private List<Employee> _errorItems = new();
    private int _errorTotalCount;
    private bool _simulateError;
    private string? _serverErrorDisplay;

    private async Task LoadErrorData(DataGridServerRequest request)
    {
        await Task.Delay(300, request.CancellationToken);
        if (_simulateError)
            throw new InvalidOperationException("Connection timeout: the remote server did not respond.");
        _errorTotalCount = _employees.Count;
        _errorItems = _employees
            .Skip((request.Page - 1) * request.PageSize)
            .Take(request.PageSize)
            .ToList();
    }

