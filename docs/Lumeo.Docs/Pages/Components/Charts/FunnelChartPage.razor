@page "/components/charts/funnel"

<PageTitle>Funnel Chart — Lumeo</PageTitle>

<PageHeader Title="Funnel Chart" Description="Visualize sequential stages in a process and the drop-off between each stage. Perfect for conversion funnels, sales pipelines, and user journeys." />

<Stack Gap="8">
    <ComponentDemo Title="Conversion Funnel" Code="@_basicCode">
        <Container>
            <FunnelChart Data="_data" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">FunnelChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;FunnelData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Funnel stages with Name and Value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Sort</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"descending"</td>
                            <td class="p-3 text-muted-foreground">Sort order: "descending", "ascending", or "none".</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows or hides the chart legend.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color palette.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<FunnelChart.FunnelData> _data = new()
    {
        new() { Name = "Visitors",  Value = 100 },
        new() { Name = "Sign-ups",  Value = 58  },
        new() { Name = "Trials",    Value = 34  },
        new() { Name = "Qualified", Value = 18  },
        new() { Name = "Customers", Value = 7   }
    };

    private string _basicCode = @"<FunnelChart Data=""_data"" />";
}
