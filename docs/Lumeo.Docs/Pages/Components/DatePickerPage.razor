@page "/components/date-picker"

<PageTitle>Date Picker — Lumeo</PageTitle>

<PageHeader Title="Date Picker" Description="A popover-based date picker built on top of Calendar." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker @bind-Value="_selectedDate" />
            @if (_selectedDate.HasValue)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_selectedDate.Value.ToString("MMMM d, yyyy")</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Label" Code="@_labelCode">
        <Stack Gap="2" Class="w-full max-w-xs">
            <Label>Date of birth</Label>
            <DatePicker @bind-Value="_birthDate" Placeholder="Pick your date of birth" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom Format" Code="@_formatCode">
        <Stack Gap="2" Class="w-full max-w-xs">
            <Label>Event date</Label>
            <DatePicker @bind-Value="_eventDate" Format="yyyy-MM-dd" Placeholder="YYYY-MM-DD" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Min & Max Date" Code="@_minMaxCode">
        <Stack Gap="2" Class="w-full max-w-xs">
            <Label>Appointment date</Label>
            <DatePicker @bind-Value="_constrainedDate" MinDate="@_minDate" MaxDate="@_maxDate" Placeholder="Select within range" />
            <Lumeo.Text Size="sm" Color="muted">Available: @_minDate.ToString("MMM d") — @_maxDate.ToString("MMM d, yyyy")</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="With Presets" Code="@_presetsCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <DatePicker @bind-Value="_presetDate" Presets="@_presets" Placeholder="Pick a date" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Date Range Picker" Code="@_rangeCode">
        <Container MaxWidth="md" Center="false" Padding="">
            <DateRangePicker @bind-StartDate="_rangeStart" @bind-EndDate="_rangeEnd" />
            @if (_rangeStart.HasValue && _rangeEnd.HasValue)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">@_rangeStart.Value.ToString("MMM d, yyyy") — @_rangeEnd.Value.ToString("MMM d, yyyy")</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Month Picker" Code="@_monthCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker @bind-Value="_monthDate" Mode="Month" Placeholder="Select a month" />
            @if (_monthDate.HasValue)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_monthDate.Value.ToString("MMMM yyyy")</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Year Picker" Code="@_yearCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker @bind-Value="_yearDate" Mode="Year" Placeholder="Select a year" />
            @if (_yearDate.HasValue)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">Selected: @_yearDate.Value.Year</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Date Time Picker" Code="@_dateTimeCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker @bind-Value="_dateTimeDate" @bind-Time="_dateTimeTime" ShowTimePicker="true" Placeholder="Pick date and time" />
            @if (_dateTimeDate.HasValue)
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-2">@_dateTimeDate.Value.ToString("MMM d, yyyy") @(_dateTimeTime?.ToString(@"hh\:mm") ?? "")</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Clearable" Code="@_clearableCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker @bind-Value="_clearableDate" Clearable="true" Placeholder="Pick a date (clearable)" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledDateCode">
        <Container MaxWidth="xs" Center="false" Padding="">
            <DatePicker Value="@(DateOnly.FromDateTime(DateTime.Today))" Disabled="true" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">DatePicker</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The currently selected date. Use with @@bind-Value for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Placeholder</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Pick a date"</td>
                            <td class="p-3 text-muted-foreground">Text shown in the trigger button when no date is selected.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Format</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"dd.MM.yyyy"</td>
                            <td class="p-3 text-muted-foreground">The date format string used to display the selected date.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Mode</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Single"</td>
                            <td class="p-3 text-muted-foreground">Picker mode: "Single", "Range", "Month", or "Year".</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RangeStart</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Start date for range mode. Use with @@bind-RangeStart.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RangeEnd</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">End date for range mode. Use with @@bind-RangeEnd.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowTimePicker</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Shows a time picker below the calendar for date+time selection.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Time</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">TimeSpan?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The selected time value. Use with @@bind-Time when ShowTimePicker is true.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">NumberOfMonths</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">1</td>
                            <td class="p-3 text-muted-foreground">Number of months to display side by side. Defaults to 2 in Range mode.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MinDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The earliest selectable date. Dates before this are disabled.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MaxDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The latest selectable date. Dates after this are disabled.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Presets</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;DatePickerPreset&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">A list of quick-select preset dates shown beside the calendar.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Clearable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Shows a clear button to reset the selected date.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Disables the date picker trigger button.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">TriggerContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom content for the trigger button, overriding the default display.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
        <Stack Gap="3">
            <Heading Level="3">DateRangePicker</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">StartDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The start date of the range. Use with @@bind-StartDate.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">EndDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The end date of the range. Use with @@bind-EndDate.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Placeholder</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Select date range"</td>
                            <td class="p-3 text-muted-foreground">Text shown when no range is selected.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Clearable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows a clear button to reset the date range.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Presets</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;DateRangePreset&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Quick-select preset date ranges shown beside the calendar.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private DateOnly? _selectedDate;
    private DateOnly? _birthDate;
    private DateOnly? _eventDate;
    private DateOnly? _constrainedDate;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateOnly? _presetDate;
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
    private DateOnly? _monthDate;
    private DateOnly? _yearDate;
    private DateOnly? _dateTimeDate;
    private TimeSpan? _dateTimeTime;
    private DateOnly? _clearableDate;
    private List<DatePicker.DatePickerPreset> _presets =
    [
        new("Today", DateOnly.FromDateTime(DateTime.Today)),
        new("Tomorrow", DateOnly.FromDateTime(DateTime.Today.AddDays(1))),
        new("Next Week", DateOnly.FromDateTime(DateTime.Today.AddDays(7))),
        new("Next Month", DateOnly.FromDateTime(DateTime.Today.AddMonths(1))),
    ];

    private string _defaultCode = @"<DatePicker @bind-Value=""_selectedDate"" />";

    private string _labelCode = @"<Label>Date of birth</Label>
<DatePicker @bind-Value=""_date"" Placeholder=""Pick your date of birth"" />";

    private string _formatCode = @"<DatePicker @bind-Value=""_date"" Format=""yyyy-MM-dd"" Placeholder=""YYYY-MM-DD"" />";

    private string _minMaxCode = @"<DatePicker @bind-Value=""_date"" MinDate=""@_minDate"" MaxDate=""@_maxDate"" Placeholder=""Select within range"" />

@code {
    private DateOnly? _date;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
}";

    private string _presetsCode = @"<DatePicker @bind-Value=""_date"" Presets=""@_presets"" Placeholder=""Pick a date"" />

@code {
    private DateOnly? _date;
    private List<DatePicker.DatePickerPreset> _presets =
    [
        new(""Today"", DateOnly.FromDateTime(DateTime.Today)),
        new(""Tomorrow"", DateOnly.FromDateTime(DateTime.Today.AddDays(1))),
        new(""Next Week"", DateOnly.FromDateTime(DateTime.Today.AddDays(7))),
        new(""Next Month"", DateOnly.FromDateTime(DateTime.Today.AddMonths(1))),
    ];
}";

    private string _rangeCode = @"<DateRangePicker @bind-StartDate=""_rangeStart"" @bind-EndDate=""_rangeEnd"" />

@code {
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
}";

    private string _monthCode = @"<DatePicker @bind-Value=""_monthDate"" Mode=""Month"" Placeholder=""Select a month"" />";

    private string _yearCode = @"<DatePicker @bind-Value=""_yearDate"" Mode=""Year"" Placeholder=""Select a year"" />";

    private string _dateTimeCode = @"<DatePicker @bind-Value=""_date"" @bind-Time=""_time"" ShowTimePicker=""true"" Placeholder=""Pick date and time"" />

@code {
    private DateOnly? _date;
    private TimeSpan? _time;
}";

    private string _clearableCode = @"<DatePicker @bind-Value=""_date"" Clearable=""true"" Placeholder=""Pick a date (clearable)"" />";

    private string _disabledDateCode = @"<DatePicker Value=""@(DateOnly.FromDateTime(DateTime.Today))"" Disabled=""true"" />";
}
