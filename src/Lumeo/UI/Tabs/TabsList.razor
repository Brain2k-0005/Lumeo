@namespace Lumeo

<div role="tablist" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] public Tabs.TabsContext? Context { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsVertical => Context?.Orientation == Tabs.TabsOrientation.Vertical;

    private string CssClass => IsVertical
        ? $"flex flex-col h-auto w-auto items-stretch justify-start rounded-lg bg-muted p-1 text-muted-foreground {Class}".Trim()
        : $"inline-flex h-9 items-center justify-center rounded-lg bg-muted p-1 text-muted-foreground {Class}".Trim();
}
