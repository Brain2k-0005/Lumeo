@page "/components/animated-grid-pattern"

<PageTitle>AnimatedGridPattern — Lumeo</PageTitle>

<PageHeader Title="AnimatedGridPattern"
            Description="SVG grid where individual cells fade in and out at random with stagger. Adds subtle ambient motion to section backgrounds." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Feature section backgrounds on dark or light themes.</li>
        <li>Empty state illustrations needing subtle life.</li>
        <li>Hero backgrounds when Aurora or RetroGrid feel too heavy.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default Grid" Code="@_basicCode">
        <div class="relative h-56 w-full overflow-hidden rounded-xl border border-border/40">
            <AnimatedGridPattern Class="absolute inset-0 text-primary" />
            <div class="relative z-10 flex h-full items-center justify-center">
                <h2 class="text-xl font-semibold">Animated Grid</h2>
            </div>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Small Cells" Code="@_smallCode">
        <div class="relative h-40 w-full overflow-hidden rounded-xl border border-border/40">
            <AnimatedGridPattern CellSize="24" MaxLit="20" Class="absolute inset-0 text-primary" />
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">AnimatedGridPattern</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CellSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">40</td>
                            <td class="p-3 text-muted-foreground">Grid cell size in pixels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MaxLit</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">10</td>
                            <td class="p-3 text-muted-foreground">Maximum number of simultaneously illuminated cells.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Cols</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">20</td>
                            <td class="p-3 text-muted-foreground">Approximate number of columns.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Rows</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">12</td>
                            <td class="p-3 text-muted-foreground">Approximate number of rows.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/retro-grid" class="text-primary hover:underline">RetroGrid</a> — Perspective grid floor with scroll animation.</li>
        <li><a href="/components/aurora-background" class="text-primary hover:underline">AuroraBackground</a> — Multi-layer gradient aurora effect.</li>
    </ul>
</div>

@code {
    private const string _basicCode = @"<AnimatedGridPattern Class=""absolute inset-0 text-primary"" />";
    private const string _smallCode = @"<AnimatedGridPattern CellSize=""24"" MaxLit=""20"" Class=""absolute inset-0 text-primary"" />";
}
