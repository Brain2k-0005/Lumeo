    protected override void OnInitialized()
    {
        (_todo, _doing, _review, _done) = NorthlightData.Board();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Autofocus the palette search input once its DOM exists. CommandInput exposes no
        // AutoFocus parameter, so we drive focus() through the interop service after the
        // open render committed. Runs on every render; the flag makes it fire exactly once
        // per open.
        if (_focusPaletteInput && _paletteOpen)
        {
            _focusPaletteInput = false;
            try { await Interop.FocusElement(PaletteInputId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            catch (InvalidOperationException) { }
        }

        if (!firstRender) return;
        try
        {
            // Start collapsed on phones so the icon rail (or the mobile sheet) doesn't
            // eat the viewport; expanded on desktop.
            await Responsive.EnsureInitialisedAsync();
            if (Responsive.IsMobile && !_navCollapsed)
            {
                _navCollapsed = true;
                StateHasChanged();
            }

            _shortcuts.Add(await Shortcuts.RegisterAsync("ctrl+k", OpenPaletteAsync));
            _shortcuts.Add(await Shortcuts.RegisterAsync("meta+k", OpenPaletteAsync));
            // Sidebar toggle — wired here (like ⌘K) rather than via SidebarProvider's
            // ToggleShortcut, which didn't fire in this layout.
            _shortcuts.Add(await Shortcuts.RegisterAsync("ctrl+b", ToggleSidebarAsync));
            _shortcuts.Add(await Shortcuts.RegisterAsync("meta+b", ToggleSidebarAsync));

            // Reveal the charts once ECharts has had time to cold-load + paint, so the
            // skeleton silhouette covers the blank-white flash instead of the chart host.
            _chartsTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
            {
                _chartsLoading = false;
                StateHasChanged();
            }), null, 900, System.Threading.Timeout.Infinite);
        }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
        catch (InvalidOperationException) { /* JS unavailable during prerender */ }
    }

