@page "/components/tree-view"

<PageTitle>TreeView — Lumeo</PageTitle>

<PageHeader Title="TreeView" Description="A hierarchical tree structure with expand/collapse, checkboxes, and search." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Tree" Code="@_codeBasic">
        <TreeView TItem="string" Items="_basicItems" Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="With Checkboxes" Code="@_codeCheckbox">
        <TreeView TItem="string" Items="_checkItems" ShowCheckboxes="true" Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="With Search" Code="@_codeSearch">
        <TreeView TItem="string" Items="_basicItems" ShowSearch="true" Class="max-w-sm" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2" Class="text-2xl font-bold text-foreground">API Reference</Heading>
    <Stack Class="rounded-lg border border-border overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr><td class="p-3 font-mono text-xs text-primary">Items</td><td class="p-3 font-mono text-xs text-muted-foreground">List&lt;TreeViewItem&lt;T&gt;&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Tree data source.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">ShowCheckboxes</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Show checkboxes on each node.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">Expandable</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Allow expanding/collapsing nodes.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">ShowSearch</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Show search filter above the tree.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">OnItemClick</td><td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;TreeViewItem&lt;T&gt;&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Fired when a node is clicked.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">OnItemCheck</td><td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;TreeViewItem&lt;T&gt;&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Fired when a node checkbox is toggled.</td></tr>
            </tbody>
        </table>
    </Stack>
</Stack>

@code {
    private List<TreeView<string>.TreeViewItem<string>> _basicItems = new()
    {
        new() { Text = "Documents", Children = new()
        {
            new() { Text = "Resume.pdf", Value = "resume" },
            new() { Text = "Cover Letter.docx", Value = "cover" },
        }},
        new() { Text = "Photos", Children = new()
        {
            new() { Text = "Vacation", Children = new()
            {
                new() { Text = "beach.jpg", Value = "beach" },
                new() { Text = "sunset.jpg", Value = "sunset" },
            }},
            new() { Text = "profile.png", Value = "profile" },
        }},
        new() { Text = "Music", Children = new()
        {
            new() { Text = "playlist.m3u", Value = "playlist" },
        }},
    };

    private List<TreeView<string>.TreeViewItem<string>> _checkItems = new()
    {
        new() { Text = "Frontend", Children = new()
        {
            new() { Text = "React", Value = "react" },
            new() { Text = "Vue", Value = "vue" },
            new() { Text = "Blazor", Value = "blazor", IsChecked = true },
        }},
        new() { Text = "Backend", Children = new()
        {
            new() { Text = "ASP.NET", Value = "aspnet", IsChecked = true },
            new() { Text = "Node.js", Value = "nodejs" },
        }},
    };

    private string _codeBasic = @"<TreeView TItem=""string"" Items=""_items"" />";
    private string _codeCheckbox = @"<TreeView TItem=""string"" Items=""_items"" ShowCheckboxes=""true"" />";
    private string _codeSearch = @"<TreeView TItem=""string"" Items=""_items"" ShowSearch=""true"" />";
}
