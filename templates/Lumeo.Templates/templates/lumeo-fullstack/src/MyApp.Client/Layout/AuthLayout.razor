@namespace MyApp.Layout
@inherits LayoutComponentBase

@* Full-screen, centered auth shell — no sidebar. Used by /login, /register and
   /forgot-password (and, with --auth oidc, the RemoteAuthenticatorView route). A subtle
   dotted background keeps the focus on the card while staying on-theme in light and dark. *@

<div class="relative flex min-h-screen items-center justify-center overflow-hidden bg-muted/30 px-4 py-10">
    <div class="absolute right-4 top-4 z-10">
        <ThemeToggle IncludeSystem="false" />
    </div>

    <main class="relative z-10 w-full max-w-md">
        @Body
    </main>
</div>

<OverlayProvider />
<ToastProvider Position="ToastViewport.ToastPosition.BottomRight" />
