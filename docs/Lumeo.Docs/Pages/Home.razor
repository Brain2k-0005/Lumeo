            ("component:window",           "Window",            "Non-modal draggable and resizable floating panel with minimize/maximize support.",   "Overlay",      "/components/window"),
        };

        var countPerCat = registry.GroupBy(r => r.category).ToDictionary(g => g.Key, g => g.Count());
        var clusterIdx  = new Dictionary<string, int>();
        const double phi = 2.3999632297286535;

        foreach (var (id, title, summary, category, url) in registry)
        {
            if (!_clusterCenters.TryGetValue(category, out var cluster))
                cluster = new ClusterDef(500, 280, 60);

            clusterIdx.TryGetValue(category, out var idx);
            clusterIdx[category] = idx + 1;

            var total  = countPerCat.TryGetValue(category, out var ct) ? ct : 1;
            var angle  = idx * phi;
            var radius = cluster.R * Math.Sqrt((double)idx / Math.Max(1, total));
            var x      = Math.Clamp(cluster.Cx + radius * Math.Cos(angle), 8, 992);
            var y      = Math.Clamp(cluster.Cy + radius * Math.Sin(angle), 8, 552);

            _constellationNodes.Add(new ConstellationNode(id, title, summary, category, url, x, y));
        }
    }

    private async Task OnConstellationSearchInput(ChangeEventArgs e)
    {
        _constellationFilter = e.Value?.ToString() ?? "";
        if (_constellationInitialized)
        {
            try { await JS.InvokeVoidAsync("lumeoConstellation.filter", _constellationFilter); }
            catch (JSException) { }
            catch (JSDisconnectedException) { }
        }
    }

    // Navigation handled by lumeoConstellation.js (window.location.assign on click/tap).

    private void MoveDraggingCard(List<KanbanItem> target)
    {
        if (_draggingCard is null) return;
        if (_kanbanTodo.Remove(_draggingCard)
            || _kanbanDoing.Remove(_draggingCard)
            || _kanbanDone.Remove(_draggingCard))
        {
            if (!target.Contains(_draggingCard))
                target.Add(_draggingCard);
        }
        _draggingCard = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        foreach (var t in _timers) t.Dispose();
        _timers.Clear();
        try
        {
            if (_visibilityHandle is not null)
            {
                await _visibilityHandle.InvokeVoidAsync("dispose");
                await _visibilityHandle.DisposeAsync();
            }
            if (_constellationObserver is not null)
            {
                await JS.InvokeVoidAsync("lumeo.disconnectObserver", _constellationObserver);
                await _constellationObserver.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        catch { }
        _selfRef?.Dispose();
    }
