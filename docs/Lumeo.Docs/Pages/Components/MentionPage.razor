</tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/textarea" class="text-primary hover:underline">Textarea</a> — Basic multi-line text input without mention support</li>
        <li><a href="/components/combobox" class="text-primary hover:underline">Combobox</a> — Searchable dropdown for standalone entity selection</li>
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — Single-line text input for simpler text fields</li>
    </ul>
</div>

@code {
    private string? _text1;
    private string? _text2;

    private List<Mention.MentionOption> _people = new()
    {
        new("Alice Johnson", "alice", Description: "Engineering"),
        new("Bob Smith", "bob", Description: "Marketing"),
        new("Carol White", "carol", Description: "Design"),
        new("David Brown", "david", Description: "Sales"),
    };

    private List<Mention.MentionOption> _channels = new()
    {
        new("general", "general"),
        new("engineering", "engineering"),
        new("design", "design"),
        new("random", "random"),
    };

    private string? _text3;
    private string _mentionTriggerStr = "@";
    private const string _atTrigger = "@";

    private List<Mention.MentionOption> _commands = new()
    {
        new("help", "help", Description: "Show help"),
        new("search", "search", Description: "Search content"),
        new("settings", "settings", Description: "Open settings"),
        new("logout", "logout", Description: "Sign out"),
    };

    private List<Mention.MentionOption> GetOptionsForTrigger(string trigger) => trigger switch
    {
        "#" => _channels,
        "/" => _commands,
        _ => _people,
    };

    private string _triggerSwitchCode = @"<Segmented @bind-Value=""_mentionTriggerStr"">
    <SegmentedItem Value=""@"">@@</SegmentedItem>
    <SegmentedItem Value=""#"">#</SegmentedItem>
    <SegmentedItem Value=""/""> /</SegmentedItem>
</Segmented>

<Mention @bind-Value=""_text""
         Options=""@GetOptionsForTrigger(_mentionTriggerStr)""
         Trigger=""@(_mentionTriggerStr[0])""
         Placeholder=""@($\""Type {_mentionTriggerStr} to trigger suggestions...\"")"" />

@code {
    private string _mentionTriggerStr = ""@"";
    private string? _text;
}";

    private string _basicCode = @"<Mention @bind-Value=""_text"" Options=""@_people"" Placeholder=""Type @@ to mention..."" />";
    private string _triggerCode = @"<Mention @bind-Value=""_text"" Options=""@_channels"" Trigger='#' />";
}
