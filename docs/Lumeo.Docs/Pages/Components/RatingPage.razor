@page "/components/rating"

<PageTitle>Rating — Lumeo</PageTitle>

<PageHeader Title="Rating" Description="A star rating input for collecting feedback." />

<InstallUsage Component="Rating" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Product or service reviews where users submit star ratings</li>
        <li>Feedback forms for satisfaction or experience scoring</li>
        <li>Displaying average ratings in read-only mode on product cards</li>
        <li>Any scenario requiring a quick visual numeric rating (e.g., difficulty, quality)</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Rating" Code="@_codeBasic">
        <Rating @bind-Value="_rating1" />
    </ComponentDemo>

    <ComponentDemo Title="Half Stars" Code="@_codeHalf">
        <Stack Gap="2">
            <Rating @bind-Value="_rating2" AllowHalf="true" />
            <Lumeo.Text Size="sm" Color="muted">Value: @_rating2</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Code="@_codeSizes">
        <Stack Gap="3">
            <Rating Value="3" ReadOnly="true" Size="Lumeo.Size.Sm" />
            <Rating Value="3" ReadOnly="true" />
            <Rating Value="3" ReadOnly="true" Size="Lumeo.Size.Lg" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Read-Only" Code="@_codeReadonly">
        <Rating Value="4.5" ReadOnly="true" AllowHalf="true" />
    </ComponentDemo>

    <ComponentDemo Title="Custom Max" Code="@_codeMax">
        <Rating @bind-Value="_rating3" Max="10" />
    </ComponentDemo>

    <ComponentDemo Title="Custom Icon" Code="@_codeIcon">
        <Rating @bind-Value="_rating4">
            <IconContent>
                <SvgGlyph Svg="@(Lucide.Heart)" />
            </IconContent>
        </Rating>
    </ComponentDemo>

    <ComponentDemo Title="Size — interactive preview" Code="@_codeSizeInteractive">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Pick a size to see the star scale live.</Lumeo.Text>
            <Segmented @bind-Value="_previewRatingSize">
                <SegmentedItem Value="Small">Small</SegmentedItem>
                <SegmentedItem Value="Default">Default</SegmentedItem>
                <SegmentedItem Value="Large">Large</SegmentedItem>
            </Segmented>
            <Rating @bind-Value="_previewRatingValue"
                    Size="_ratingSizeEnum" />
            <Lumeo.Text Size="sm" Color="muted">Size: @_previewRatingSize — Value: @_previewRatingValue</Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <strong>Mobile (rc.49).</strong> The star rating now uses pointer events so users can drag a finger across the stars to set a value in one smooth gesture — no need to lift and tap each star individually.
</Alert>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Rating</Heading>
            <PropsTable Slug="rating" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/slider" class="text-primary hover:underline">Slider</a> — Continuous range input when discrete star levels are insufficient</li>
        <li><a href="/components/progress" class="text-primary hover:underline">Progress</a> — Display a score or completion percentage as a bar</li>
        <li><a href="/components/input" class="text-primary hover:underline">Input</a> — Free-form numeric input for precise rating values</li>
    </ul>
</div>

@code {
    private double _rating1 = 3;
    private double _rating2 = 3.5;
    private double _rating3 = 7;
    private double _rating4 = 3;

    private string _codeBasic = @"<Rating @bind-Value=""_rating"" />";
    private string _codeHalf = @"<Rating @bind-Value=""_rating"" AllowHalf=""true"" />";
    private string _codeSizes = @"<Rating Value=""3"" ReadOnly=""true"" Size=""Lumeo.Size.Sm"" />
<Rating Value=""3"" ReadOnly=""true"" />
<Rating Value=""3"" ReadOnly=""true"" Size=""Lumeo.Size.Lg"" />";
    private string _codeReadonly = @"<Rating Value=""4.5"" ReadOnly=""true"" AllowHalf=""true"" />";
    private string _codeMax = @"<Rating @bind-Value=""_rating"" Max=""10"" />";
    private string _codeIcon = @"<Rating @bind-Value=""_rating"">
    <IconContent>
        <SvgGlyph Svg=""@(Lucide.Heart)"" />
    </IconContent>
</Rating>";

    private string _previewRatingSize = "Default";
    private double _previewRatingValue = 3;
    private Lumeo.Size _ratingSizeEnum =>
        Enum.TryParse<Lumeo.Size>(_previewRatingSize, out var s) ? s : Lumeo.Size.Md;

    private string _codeSizeInteractive = @"<Segmented @bind-Value=""_size"">
    <SegmentedItem Value=""Small"">Small</SegmentedItem>
    <SegmentedItem Value=""Default"">Default</SegmentedItem>
    <SegmentedItem Value=""Large"">Large</SegmentedItem>
</Segmented>
<Rating @bind-Value=""_rating"" Size=""@Enum.Parse<Lumeo.Size>(_size)"" />

@code {
    private string _size = ""Default"";
    private double _rating = 3;
}";
}
