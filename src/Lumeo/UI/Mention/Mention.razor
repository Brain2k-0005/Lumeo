@namespace Lumeo
@implements IAsyncDisposable

@* Render the label, control and helper/error as ONE self-contained vertical block so the
   field never splays into a row when dropped in a flex / centered container (the docs
   preview, or a consumer's flex/grid layout). Standalone form-field structural fix. *@
<div class="flex flex-col items-start">
@if (Label is not null && !InsideFormField)
{
    <label class="block text-sm font-medium text-foreground mb-1.5">
        @Label
        @if (Required)
        {
            <span class="text-destructive ms-0.5">*</span>
        }
    </label>
}

<div class="relative" @attributes="AdditionalAttributes">
    <textarea id="@EffectiveTextareaId"
              class="@TextareaCssClass"
              value="@Value"
              rows="@Rows"
              placeholder="@Placeholder"
              disabled="@Disabled"
              name="@(Name ?? FormField?.Name)"
              role="combobox"
              aria-required="@(Required ? "true" : "false")"
              aria-invalid="@(EffectiveInvalid ? "true" : "false")"
              aria-autocomplete="list"
              aria-haspopup="listbox"
              aria-expanded="@((_showDropdown && FilteredOptions.Any()) ? "true" : "false")"
              aria-controls="@_dropdownId"
              aria-activedescendant="@((_showDropdown && FilteredOptions.Any()) ? OptionElementId(_activeIndex) : null)"
              aria-describedby="@FormFieldDescribedBy"
              @ref="_textareaRef"
              @oninput="HandleInput"
              @onkeydown="HandleKeyDown"
              @onfocus="HandleFocus"
              @onblur="HandleBlur" />

    @if (_showDropdown && FilteredOptions.Any())
    {
        <div id="@_dropdownId" class="@DropdownCssClass" role="listbox"
             style="position: absolute; left: @(_caretLeft.ToString(System.Globalization.CultureInfo.InvariantCulture))px; top: @(_caretTop.ToString(System.Globalization.CultureInfo.InvariantCulture))px;">
            @foreach (var (option, index) in FilteredOptions.Select((o, i) => (o, i)))
            {
                var isActive = index == _activeIndex;
                <button @key="option.Value"
                        id="@OptionElementId(index)"
                        role="option"
                        aria-selected="@(isActive ? "true" : "false")"
                        type="button"
                        class="@OptionCssClass(isActive)"
                        @onpointerdown:preventDefault
                        @onclick="() => SelectOption(option)">
                    @if (!string.IsNullOrEmpty(option.Avatar))
                    {
                        <img src="@option.Avatar" alt="" class="h-6 w-6 rounded-full" />
                    }
                    <div class="flex flex-col">
                        <span class="text-sm font-medium text-foreground">@option.Label</span>
                        @if (!string.IsNullOrEmpty(option.Description))
                        {
                            <span class="text-xs text-muted-foreground">@option.Description</span>
                        }
                    </div>
                </button>
            }
        </div>
    }
</div>

@if (!InsideFormField)
{
    @if (EffectiveInvalid && ErrorText is not null)
    {
        <p class="text-xs text-destructive mt-1.5">@ErrorText</p>
    }
    else if (HelperText is not null)
    {
        <p class="text-xs text-muted-foreground mt-1.5">@HelperText</p>
    }
}
</div>

@inject IComponentInteropService Interop

@code {
    [CascadingParameter] private FormField.FormFieldContext? FormField { get; set; }

    // aria-describedby on the textarea announces the FormField help/error to a screen
    // reader.
    private string? FormFieldDescribedBy => FormField?.DescribedBy;

    // Inside a FormField, adopt its ControlId as the textarea's id so the field's
    // <Label For> actually click-focuses the textarea (Base UI Field parity, matching
    // Select/Textarea/DatePicker/TimePicker). Standalone, keep our own generated id.
    // Every internal id use (rendered id, caret JS interop, prevent-default key
    // registration) flows through this so the rendered id and the JS targets stay
    // consistent.
    private string EffectiveTextareaId =>
        !string.IsNullOrEmpty(FormField?.ControlId) ? FormField!.ControlId : _textareaId;

    /// <summary>The textarea's raw text content, including any committed <c>@@mention</c> tokens.</summary>
    [Parameter] public string? Value { get; set; }
    /// <summary>Invoked on every keystroke and mention insertion with the updated text.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    /// <summary>The character that opens the mention suggestion dropdown. Default: <c>@@</c>.</summary>
    [Parameter] public char Trigger { get; set; } = '@';
    /// <summary>Candidate mentions. In local/uncontrolled mode (no <see cref="OnSearch"/> delegate) this
    /// full list is filtered client-side by the search term; when <see cref="OnSearch"/> is bound, the
    /// caller is expected to hand back an already-filtered list.</summary>
    [Parameter] public List<MentionOption> Options { get; set; } = [];
    /// <summary>Invoked with the text typed after the trigger character. Binding this switches to
    /// server-driven filtering — the caller supplies the matching <see cref="Options"/> instead of the
    /// component filtering the full list client-side.</summary>
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    /// <summary>Disables the textarea.</summary>
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Placeholder text shown when the textarea is empty.</summary>
    [Parameter] public string? Placeholder { get; set; }
    /// <summary>Visible row count of the textarea. Default: 3.</summary>
    [Parameter] public int Rows { get; set; } = 3;
    /// <summary>Marks the field as required, setting <c>aria-required</c>.</summary>
    [Parameter] public bool Required { get; set; }
    /// <summary>Renders the field in an invalid/error state. Also set implicitly when inside a
    /// <c>FormField</c> that has a validation error.</summary>
    [Parameter] public bool Invalid { get; set; }
    /// <summary>Error message shown below the field when <see cref="Invalid"/> is true and the field
    /// isn't inside a <c>FormField</c> (which renders its own error text).</summary>
    [Parameter] public string? ErrorText { get; set; }
    /// <summary>Helper text shown below the field when there's no error, and the field isn't inside a
    /// <c>FormField</c>.</summary>
    [Parameter] public string? HelperText { get; set; }
    /// <summary>Label rendered above the field. Ignored when inside a <c>FormField</c>, which renders
    /// its own label.</summary>
    [Parameter] public string? Label { get; set; }
    /// <summary>The <c>name</c> attribute on the textarea, for native form submission. Falls back to
    /// the enclosing <c>FormField</c>'s name when unset.</summary>
    [Parameter] public string? Name { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>textarea</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Additional HTML attributes captured and forwarded to the relative-positioned wrapper <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool EffectiveInvalid => Invalid || FormField?.HasError == true;
    private bool InsideFormField => FormField is not null;

    private readonly string _textareaId = LumeoIds.New("mention");

    // ARIA option ID generator. The textarea's aria-activedescendant
    // points at OptionElementId(_activeIndex); each option button renders
    // the same id. Lets AT track the highlighted option while focus stays
    // on the textarea — the combobox pattern.
    private string OptionElementId(int index) => $"{_dropdownId}-opt-{index}";
    private readonly string _dropdownId = LumeoIds.New("mention-dd");
    private ElementReference _textareaRef;
    private bool _showDropdown;
    private string _searchTerm = "";
    private int _triggerStartIndex = -1;
    private int _activeIndex;
    private double _caretTop;
    private double _caretLeft;
    private bool _hasFocus;
    private CancellationTokenSource? _blurDelayCts;

    private string TextareaCssClass => Cx.Merge("flex min-h-[60px] w-full rounded-md border", (EffectiveInvalid ? "border-destructive focus-visible:ring-destructive/20" : "border-border/60 focus-visible:ring-ring"), "bg-transparent px-3 py-2 text-sm text-foreground shadow-xs placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 disabled:cursor-not-allowed disabled:opacity-50", Class);
    private string DropdownCssClass => "z-50 min-w-[200px] max-h-[200px] overflow-auto rounded-md border border-border/60 bg-popover p-1 shadow-lg animate-fade-in";

    private static string OptionCssClass(bool isActive) =>
        $"flex w-full items-center gap-2 rounded-sm px-2 py-1.5 text-start outline-none transition-colors {(isActive ? "bg-accent text-accent-foreground" : "hover:bg-accent hover:text-accent-foreground")}";

    // In server-driven mode (OnSearch.HasDelegate) the parent already returns the
    // filtered Options for _searchTerm, so re-applying the client substring filter
    // would silently drop any option whose Label/Value does not literally contain
    // _searchTerm (e.g. fuzzy/remote matches). Only the local/uncontrolled mode,
    // which is handed the full Options list up front, applies the client filter.
    private List<MentionOption> FilteredOptions =>
        OnSearch.HasDelegate || string.IsNullOrEmpty(_searchTerm)
            ? Options
            : Options.Where(o => o.Label.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                 o.Value.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase)).ToList();

    private async Task HandleInput(ChangeEventArgs e)
    {
        var newValue = e.Value?.ToString() ?? "";
        Value = newValue;
        await ValueChanged.InvokeAsync(newValue);

        // Get caret position from JS
        var caretInfo = await Interop.GetTextareaCaretPosition(EffectiveTextareaId);
        if (caretInfo is null) return;
        var selectionStart = caretInfo.SelectionStart;

        // Check if we are in a mention context
        var textBeforeCaret = selectionStart <= newValue.Length ? newValue[..selectionStart] : newValue;
        var triggerIndex = textBeforeCaret.LastIndexOf(Trigger);

        if (triggerIndex >= 0)
        {
            // Ensure trigger is at start or preceded by whitespace
            var isValidTrigger = triggerIndex == 0 || char.IsWhiteSpace(textBeforeCaret[triggerIndex - 1]);
            var textAfterTrigger = textBeforeCaret[(triggerIndex + 1)..];
            var hasSpace = textAfterTrigger.Contains(' ');

            if (isValidTrigger && !hasSpace)
            {
                _searchTerm = textAfterTrigger;
                _triggerStartIndex = triggerIndex;
                _showDropdown = true;
                _activeIndex = 0;
                // Anchor the dropdown one line below the caret, positioned
                // absolutely against the component's relative wrapper so it
                // tracks the textarea on scroll (#205). OffsetTop/Left are
                // wrapper-relative; falling back to the legacy viewport values
                // keeps the test double (which only fills Top/Left) sane.
                _caretTop = caretInfo.OffsetTop + caretInfo.LineHeight;
                _caretLeft = caretInfo.OffsetLeft;

                if (OnSearch.HasDelegate)
                {
                    await OnSearch.InvokeAsync(_searchTerm);
                }
                return;
            }
        }

        _showDropdown = false;
        _searchTerm = "";
        _triggerStartIndex = -1;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (!_showDropdown) return;

        var filtered = FilteredOptions;
        switch (e.Key)
        {
            case "ArrowDown":
                // Guard: the dropdown stays logically open while zero options
                // match (markup hides via FilteredOptions.Any()) — the modulo
                // would throw DivideByZeroException and kill the circuit.
                if (filtered.Count > 0)
                    _activeIndex = (_activeIndex + 1) % filtered.Count;
                break;
            case "ArrowUp":
                if (filtered.Count > 0)
                    _activeIndex = (_activeIndex - 1 + filtered.Count) % filtered.Count;
                break;
            case "Home":
                // Jump the highlight to the first option (combobox APG parity).
                if (filtered.Count > 0)
                    _activeIndex = 0;
                break;
            case "End":
                // Jump the highlight to the last option (combobox APG parity).
                if (filtered.Count > 0)
                    _activeIndex = filtered.Count - 1;
                break;
            case "Enter" or "Tab":
                if (filtered.Count > 0 && _activeIndex < filtered.Count)
                {
                    await SelectOption(filtered[_activeIndex]);
                }
                break;
            case "Escape":
                _showDropdown = false;
                // Return focus to the textarea so screen readers announce the correct context.
                try { await _textareaRef.FocusAsync(); } catch { }
                break;
        }
    }

    private async Task SelectOption(MentionOption option)
    {
        // The parent may have shortened Value (controlled usage) since the
        // trigger was recorded, leaving _triggerStartIndex (and the caret's
        // selectionStart) pointing past the current end. Slicing with the stale
        // index would throw / mis-splice, so clamp both into range and bail out
        // cleanly if the trigger no longer fits.
        if (Value is not null && _triggerStartIndex >= 0 && _triggerStartIndex <= Value.Length)
        {
            var caretInfo = await Interop.GetTextareaCaretPosition(EffectiveTextareaId);
            if (caretInfo is null) return;
            var selectionStart = Math.Clamp(caretInfo.SelectionStart, _triggerStartIndex, Value.Length);
            var before = Value[.._triggerStartIndex];
            var after = Value[selectionStart..];
            Value = $"{before}{Trigger}{option.Value} {after}";
            await ValueChanged.InvokeAsync(Value);
        }

        _showDropdown = false;
        _searchTerm = "";
        _triggerStartIndex = -1;
        _activeIndex = 0;
    }

    private void HandleFocus()
    {
        _hasFocus = true;
        // Cancel any pending blur-hide so re-focusing within the 150 ms window
        // does not close the dropdown.
        _blurDelayCts?.Cancel();
    }

    private async Task HandleBlur()
    {
        _hasFocus = false;
        // Cancel any previous blur delay and start a fresh one.
        _blurDelayCts?.Cancel();
        _blurDelayCts?.Dispose();
        _blurDelayCts = new CancellationTokenSource();
        var token = _blurDelayCts.Token;
        // Small delay to allow click on dropdown item
        try { await Task.Delay(150, token); }
        catch (TaskCanceledException) { return; }
        if (_hasFocus) return; // re-focused during the wait
        _showDropdown = false;
        StateHasChanged();
    }

    // Tracks whether the dropdown's key suppression is currently registered.
    private bool _pdRegistered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // While the suggestion dropdown is open, Enter/Tab select and the
        // arrows move the highlight — but their textarea defaults fired FIRST
        // (newline inserted, caret moved) and SelectOption then read the moved
        // caret, mangling the insertion. Suppress those defaults in JS exactly
        // while the dropdown is open; when closed, Enter/Tab/arrows behave
        // natively again. (Conditional attach pattern — same as TabsContent's
        // swipe registration.)
        try
        {
            if (_showDropdown && !_pdRegistered)
            {
                _pdRegistered = true;
                await Interop.RegisterPreventDefaultKeys(
                    EffectiveTextareaId,
                    new[]
                    {
                        new Lumeo.Services.PreventDefaultKeyRule("Enter", SkipComposing: true),
                        new Lumeo.Services.PreventDefaultKeyRule("Tab"),
                        new Lumeo.Services.PreventDefaultKeyRule("ArrowDown"),
                        new Lumeo.Services.PreventDefaultKeyRule("ArrowUp"),
                        // Home/End jump the highlight to first/last option; suppress
                        // the textarea's native caret-to-line-start/end so the
                        // dropdown owns these keys while it is open.
                        new Lumeo.Services.PreventDefaultKeyRule("Home"),
                        new Lumeo.Services.PreventDefaultKeyRule("End"),
                    });
            }
            else if (!_showDropdown && _pdRegistered)
            {
                _pdRegistered = false;
                await Interop.UnregisterPreventDefaultKeys(EffectiveTextareaId);
            }
        }
        catch (JSDisconnectedException) { _pdRegistered = false; }
        catch (ObjectDisposedException) { _pdRegistered = false; }
        catch (InvalidOperationException) { _pdRegistered = false; } // prerender
    }

    public async ValueTask DisposeAsync()
    {
        _blurDelayCts?.Cancel();
        _blurDelayCts?.Dispose();
        _blurDelayCts = null;
        try
        {
            if (_pdRegistered)
                await Interop.UnregisterPreventDefaultKeys(EffectiveTextareaId);
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    public record MentionOption(string Label, string Value, string? Avatar = null, string? Description = null);
}
