@page "/components/icon"

<PageTitle>Icon — Lumeo</PageTitle>

<PageHeader Title="Icon" Description="A thin wrapper around Blazicons that gives Lumeo a native icon API. Pick from ~100 common icons by name, size via presets, or pass any Blazicons SvgIcon through the Svg parameter." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Any place you'd otherwise write <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Blazicon Svg="Lucide.X"&gt;</code> — use <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Icon Name="X"&gt;</code> instead.</li>
        <li>Hides the Blazicons dependency from your component code.</li>
        <li>Consistent <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Class</code> convention (rather than lowercase <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">class</code>).</li>
        <li>Lets Lumeo swap the icon provider in a future release without breaking consumer code.</li>
    </ul>
</div>

<Stack Gap="8">

    <ComponentDemo Title="Basic" Description="Pass a Lucide icon name in PascalCase." Code="@_basicCode">
        <Flex Gap="3" Align="center">
            <Icon Name="Search" />
            <Icon Name="Heart" />
            <Icon Name="Star" />
            <Icon Name="Bell" />
            <Icon Name="Settings" />
            <Icon Name="ChevronDown" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Description="Presets via the Size parameter: Xs (h-3), Sm (h-3.5), Md (h-4, default), Lg (h-5), Xl (h-6)." Code="@_sizesCode">
        <Flex Gap="4" Align="center">
            <Icon Name="Heart" Size="Icon.IconSize.Xs" />
            <Icon Name="Heart" Size="Icon.IconSize.Sm" />
            <Icon Name="Heart" />
            <Icon Name="Heart" Size="Icon.IconSize.Lg" />
            <Icon Name="Heart" Size="Icon.IconSize.Xl" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Color via Class" Description="Icons inherit currentColor, so any Tailwind text-* class tints them." Code="@_colorCode">
        <Flex Gap="4" Align="center">
            <Icon Name="CircleCheck" Class="text-success" />
            <Icon Name="CircleAlert" Class="text-destructive" />
            <Icon Name="TriangleAlert" Class="text-warning" />
            <Icon Name="Info" Class="text-info" />
            <Icon Name="Star" Class="text-primary" />
            <Icon Name="BadgeCheck" Class="text-muted-foreground" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Inside buttons" Description="Drop into any Lumeo component that takes a RenderFragment — Button, Badge, Alert, Card, etc." Code="@_buttonCode">
        <Flex Gap="3" Align="center" Class="flex-wrap">
            <Button>
                <Icon Name="Plus" Class="mr-2" />
                New project
            </Button>
            <Button Variant="Button.ButtonVariant.Outline">
                <Icon Name="Download" Class="mr-2" />
                Download
            </Button>
            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                <Icon Name="Settings" />
            </Button>
            <Button Variant="Button.ButtonVariant.Destructive">
                <Icon Name="Trash" Class="mr-2" />
                Delete
            </Button>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Direct Svg escape hatch" Description="Pass any Blazicons SvgIcon through the Svg parameter — works across Lucide, Bootstrap, FluentUI, Material, FontAwesome, Ionicons, and MDI." Code="@_svgCode">
        <Flex Gap="4" Align="center">
            <Icon Svg="Blazicons.Lucide.Search" />
            <Icon Svg="Blazicons.BootstrapIcon.Archive" />
            <Icon Svg="Blazicons.FluentUiIcon.Alert" />
            <Icon Svg="Blazicons.GoogleMaterialOutlinedIcon.Home" />
            <Icon Svg="Blazicons.FontAwesomeSolidIcon.Heart" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Common icon names" Description="PascalCase names map 1:1 to Lucide icons. Unknown names fall back to Circle." Code="@_catalogCode">
        <Grid Class="grid-cols-4 sm:grid-cols-6 md:grid-cols-8 gap-4">
            @foreach (var name in _catalog)
            {
                <Stack Gap="1" Align="center" Class="text-center">
                    <Icon Name="@name" Size="Icon.IconSize.Lg" Class="text-muted-foreground" />
                    <Lumeo.Text Size="xs" Color="muted" Class="truncate">@name</Lumeo.Text>
                </Stack>
            }
        </Grid>
    </ComponentDemo>

</Stack>

<div class="mt-12">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>
    <div class="mt-4 rounded-lg border border-border/40 overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border/40 bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Name</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">PascalCase Lucide icon name. Unknown names fall back to <code class="font-mono text-xs">Circle</code>.</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Svg</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">SvgIcon?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">Direct Blazicons icon. Takes precedence over <code class="font-mono text-xs">Name</code>.</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Size</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">Icon.IconSize</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">Md</td>
                    <td class="p-3 text-muted-foreground">Xs (h-3) · Sm (h-3.5) · Md (h-4) · Lg (h-5) · Xl (h-6).</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Class</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">Extra CSS classes appended after the size class.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/dynamic-icon" class="text-primary hover:underline">DynamicIcon</a> — docs-only multi-library variant used by the theme customizer.</li>
        <li><a href="https://github.com/AlenToma/Blazicons" class="text-primary hover:underline" target="_blank">Blazicons</a> — the underlying icon library Lumeo wraps.</li>
    </ul>
</div>

@code {
    private readonly string[] _catalog =
    {
        "Home", "Search", "Settings", "Bell", "User", "Users", "Mail", "Calendar",
        "Clock", "Heart", "Star", "Bookmark", "Flag", "Tag", "MapPin", "Phone",
        "ShoppingCart", "ShoppingBag", "CreditCard", "Wallet", "DollarSign", "Package", "Truck", "Activity",
        "ChevronUp", "ChevronDown", "ChevronLeft", "ChevronRight", "ArrowUp", "ArrowDown", "ArrowLeft", "ArrowRight",
        "Plus", "Minus", "X", "Check", "CheckCheck", "Copy", "Download", "Upload",
        "Edit", "Trash", "Eye", "EyeOff", "Filter", "Menu", "Ellipsis", "ExternalLink",
        "Info", "CircleCheck", "CircleAlert", "TriangleAlert", "Shield", "Lock", "LogIn", "LogOut",
        "FileText", "Folder", "Image", "Video", "Music", "Mic", "Camera", "Paperclip",
        "MessageCircle", "Send", "Share2", "Smile", "Sun", "Moon", "Palette", "Zap",
        "TrendingUp", "TrendingDown", "BarChart3", "LineChart", "PieChart", "LayoutDashboard", "LayoutGrid", "Github",
    };

    private string _basicCode = @"<Icon Name=""Search"" />
<Icon Name=""Heart"" />
<Icon Name=""Star"" />
<Icon Name=""Bell"" />
<Icon Name=""Settings"" />
<Icon Name=""ChevronDown"" />";

    private string _sizesCode = @"<Icon Name=""Heart"" Size=""Icon.IconSize.Xs"" />
<Icon Name=""Heart"" Size=""Icon.IconSize.Sm"" />
<Icon Name=""Heart"" />                      @* Md (default) *@
<Icon Name=""Heart"" Size=""Icon.IconSize.Lg"" />
<Icon Name=""Heart"" Size=""Icon.IconSize.Xl"" />";

    private string _colorCode = @"<Icon Name=""CircleCheck""   Class=""text-success"" />
<Icon Name=""CircleAlert""   Class=""text-destructive"" />
<Icon Name=""TriangleAlert"" Class=""text-warning"" />
<Icon Name=""Info""          Class=""text-info"" />
<Icon Name=""Star""          Class=""text-primary"" />";

    private string _buttonCode = @"<Button>
    <Icon Name=""Plus"" Class=""mr-2"" />
    New project
</Button>

<Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon"">
    <Icon Name=""Settings"" />
</Button>";

    private string _svgCode = @"@using Blazicons

<Icon Svg=""Lucide.Search"" />
<Icon Svg=""BootstrapIcon.Archive"" />
<Icon Svg=""FluentUiIcon.Alert"" />
<Icon Svg=""GoogleMaterialOutlinedIcon.Home"" />
<Icon Svg=""FontAwesomeSolidIcon.Heart"" />";

    private string _catalogCode = @"@foreach (var name in names)
{
    <Icon Name=""@name"" Size=""Icon.IconSize.Lg"" />
}";
}
