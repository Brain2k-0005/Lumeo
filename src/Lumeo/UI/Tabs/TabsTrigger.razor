@namespace Lumeo

<button type="button"
        id="@_tabId"
        role="tab"
        aria-selected="@IsActive.ToString().ToLower()"
        aria-controls="@_panelId"
        tabindex="@(IsActive ? 0 : -1)"
        class="@CssClass"
        @onclick="Activate"
        @onkeydown="HandleKeyDown"
        @onkeydown:preventDefault="@_preventKey"
        @attributes="AdditionalAttributes">
    @if (Icon is not null)
    {
        <span class="inline-flex shrink-0">@Icon</span>
    }
    @ChildContent
    @if (TrailingContent is not null)
    {
        <span class="inline-flex shrink-0">@TrailingContent</span>
    }
    @if (IsClosable)
    {
        <span class="ml-1 inline-flex items-center justify-center rounded-sm opacity-70 hover:opacity-100 transition-opacity"
              @onclick="HandleClose" @onclick:stopPropagation="true">
            <Blazicon Svg="Lucide.X" class="h-3 w-3" />
        </span>
    }
</button>

@inject ComponentInteropService Interop

@code {
    [CascadingParameter] public Tabs.TabsContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? Icon { get; set; }
    [Parameter] public RenderFragment? TrailingContent { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public bool IsClosable { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _tabId = $"tab-{Guid.NewGuid():N}";
    private readonly string _panelId = $"tabpanel-{Guid.NewGuid():N}";
    private bool _preventKey;

    private bool IsActive => Context.ActiveValue == Value;
    private string CurrentVariant => Context.Variant;

    protected override void OnInitialized()
    {
        Context.TabIds[Value] = (_tabId, _panelId);
    }

    private string CssClass
    {
        get
        {
            var variantClasses = CurrentVariant switch
            {
                "Card" => IsActive
                    ? "rounded-t-lg border border-b-0 border-border/40 bg-card text-foreground"
                    : "text-muted-foreground hover:text-foreground",
                "Pill" => IsActive
                    ? "rounded-full bg-primary text-primary-foreground"
                    : "text-muted-foreground hover:bg-muted/50 rounded-full",
                _ => IsActive
                    ? "bg-background text-foreground shadow"
                    : ""
            };
            return $"inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-md px-3 py-1.5 text-sm font-medium transition-all focus-visible:outline-none disabled:pointer-events-none disabled:opacity-50 {variantClasses} {Class}".Trim();
        }
    }

    private async Task Activate()
    {
        await Context.SetValue.InvokeAsync(Value);
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        var isHorizontal = Context.Orientation == Tabs.TabsOrientation.Horizontal;
        var keys = Context.TabIds.Keys.ToList();
        var idx = keys.IndexOf(Value);

        string? nextValue = e.Key switch
        {
            "ArrowRight" when isHorizontal  => idx < keys.Count - 1 ? keys[idx + 1] : keys[0],
            "ArrowLeft"  when isHorizontal  => idx > 0 ? keys[idx - 1] : keys[^1],
            "ArrowDown"  when !isHorizontal => idx < keys.Count - 1 ? keys[idx + 1] : keys[0],
            "ArrowUp"    when !isHorizontal => idx > 0 ? keys[idx - 1] : keys[^1],
            "Home" => keys.Count > 0 ? keys[0] : null,
            "End"  => keys.Count > 0 ? keys[^1] : null,
            _ => null
        };

        _preventKey = e.Key is "ArrowRight" or "ArrowLeft" or "ArrowDown" or "ArrowUp" or "Home" or "End";

        if (nextValue is not null && Context.TabIds.TryGetValue(nextValue, out var ids))
        {
            await Context.SetValue.InvokeAsync(nextValue);
            await Interop.FocusElement(ids.TabId);
        }
    }
}
