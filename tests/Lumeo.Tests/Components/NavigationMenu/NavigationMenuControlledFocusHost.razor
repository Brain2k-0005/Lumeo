@namespace Lumeo.Tests.Components.NavigationMenu

@* Round-8 (Codex) test host — an ACCEPTING controlled parent. It owns the open
   value and pushes the emitted value straight back into NavigationMenu.Value via
   @bind-Value, so a keyboard ArrowDown open is ACCEPTED. The accepted value is
   pushed back through a LATER OnParametersSet (after SetActiveItemId returns) —
   exactly the timing that made the old "clear right after ValueChanged" check
   drop the focus intent on an accepted open. The deferred focus-into-content must
   still fire. *@
<Lumeo.NavigationMenu @bind-Value="_value">
    <Lumeo.NavigationMenuList>
        <Lumeo.NavigationMenuItem Value="products">
            <Lumeo.NavigationMenuTrigger>Products</Lumeo.NavigationMenuTrigger>
            <Lumeo.NavigationMenuContent>Products content</Lumeo.NavigationMenuContent>
        </Lumeo.NavigationMenuItem>
    </Lumeo.NavigationMenuList>
</Lumeo.NavigationMenu>

@code {
    private string? _value;

    /// <summary>The value the accepting parent currently owns.</summary>
    public string? Value => _value;
}
