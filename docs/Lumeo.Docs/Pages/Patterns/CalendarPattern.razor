    private void PrevMonth() => _currentMonth = _currentMonth.AddMonths(-1);
    private void NextMonth() => _currentMonth = _currentMonth.AddMonths(1);
    private void GoToToday()
    {
        _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        _selectedDate = DateTime.Today;
    }

    private void ToggleFilter(string category)
    {
        if (_activeFilters.Contains(category))
            _activeFilters.Remove(category);
        else
            _activeFilters.Add(category);
    }

    private void AddEvent()
    {
        if (string.IsNullOrWhiteSpace(_newEventTitle)) return;

        var cat = _categories.FirstOrDefault(c => c.Name == _newEventCategory) ?? _categories[0];
        var timeLabel = string.IsNullOrEmpty(_newStartTime) ? "12:00 PM" : FormatTime(_newStartTime);

        _events.Add(new CalendarEvent(
            _selectedDate, _newEventTitle, timeLabel,
            cat.DotClass, cat.ChipClass, cat.Name,
            _newEventLocation, _newEventDesc
        ));

        _newEventTitle = "";
        _newEventLocation = "";
        _newEventDesc = "";
        _newStartTime = "09:00";
        _newEndTime = "10:00";
        _showComposer = false;
    }

    private void AddEventFromDialog()
    {
        if (string.IsNullOrWhiteSpace(_newEventTitle)) return;

        var cat = _categories.FirstOrDefault(c => c.Name == _newEventCategory) ?? _categories[0];
        var timeLabel = string.IsNullOrEmpty(_newStartTime) ? "12:00 PM" : FormatTime(_newStartTime);
        var eventDate = _newEventDate.HasValue
            ? _newEventDate.Value.ToDateTime(TimeOnly.Parse(_newStartTime.Length > 0 ? _newStartTime : "09:00"))
            : _selectedDate;

        var attendeeList = string.IsNullOrWhiteSpace(_newEventAttendees)
            ? new List<string>()
            : _newEventAttendees.Split(',').Select(a => a.Trim()).Where(a => a.Length > 0).ToList();

        _events.Add(new CalendarEvent(
            eventDate, _newEventTitle, timeLabel,
            cat.DotClass, cat.ChipClass, cat.Name,
            _newEventLocation, _newEventDesc,
            attendeeList.Count > 0 ? attendeeList : null
        ));

        // Reset form
        _newEventTitle = "";
        _newEventLocation = "";
        _newEventDesc = "";
        _newEventAttendees = "";
        _newStartTime = "09:00";
        _newEndTime = "10:00";
        _newEventDate = DateOnly.FromDateTime(DateTime.Today);
        _dialogOpen = false;
    }

    private static string FormatTime(string t24)
    {
        if (TimeOnly.TryParse(t24, out var to))
            return to.ToString("h:mm tt");
        return t24;
    }

