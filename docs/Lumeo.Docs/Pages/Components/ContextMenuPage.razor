@page "/components/context-menu"

<PageTitle>Context Menu — Lumeo</PageTitle>

<PageHeader Title="Context Menu" Description="Displays a menu triggered by right-clicking an element." />

<div class="mt-6 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Right-click actions on elements like files, cards, or table rows</li>
        <li>Custom context menus replacing the browser default for specific areas</li>
        <li>Element-specific operations such as copy, edit, delete, or move</li>
    </ul>
</div>

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Class="h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm text-muted-foreground">
                    Right click here
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuItem>Back</ContextMenuItem>
                <ContextMenuItem>Forward</ContextMenuItem>
                <ContextMenuItem>Reload</ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>Save As...</ContextMenuItem>
                <ContextMenuItem>Print</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>

    <ComponentDemo Title="With Labels and Groups" Code="@_groupCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Class="h-[150px] w-[300px] items-center justify-center rounded-md border border-dashed text-sm text-muted-foreground">
                    Right click here
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuLabel>Edit</ContextMenuLabel>
                <ContextMenuGroup>
                    <ContextMenuItem>Cut</ContextMenuItem>
                    <ContextMenuItem>Copy</ContextMenuItem>
                    <ContextMenuItem>Paste</ContextMenuItem>
                </ContextMenuGroup>
                <ContextMenuSeparator />
                <ContextMenuLabel>View</ContextMenuLabel>
                <ContextMenuGroup>
                    <ContextMenuItem>Zoom In</ContextMenuItem>
                    <ContextMenuItem>Zoom Out</ContextMenuItem>
                    <ContextMenuItem>Reset Zoom</ContextMenuItem>
                </ContextMenuGroup>
                <ContextMenuSeparator />
                <ContextMenuItem Disabled="true">Delete</ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>

    <ComponentDemo Title="File Actions" Code="@_fileCode">
        <ContextMenu>
            <ContextMenuTrigger>
                <Flex Align="center" Justify="center" Class="h-[150px] w-[300px] rounded-md border border-dashed">
                    <Stack Gap="0" Class="text-center">
                        <Lumeo.Text Size="sm" Weight="medium">document.pdf</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted" Class="mt-1">Right click for options</Lumeo.Text>
                    </Stack>
                </Flex>
            </ContextMenuTrigger>
            <ContextMenuContent>
                <ContextMenuItem>
                    <DynamicIcon Name="Eye" Class="mr-2 h-4 w-4" />
                    Open
                </ContextMenuItem>
                <ContextMenuItem>
                    <DynamicIcon Name="Copy" Class="mr-2 h-4 w-4" />
                    Duplicate
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="ArrowRight" Class="mr-2 h-4 w-4" />
                    Move to...
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="Star" Class="mr-2 h-4 w-4" />
                    Add to Favorites
                </ContextMenuItem>
                <ContextMenuSeparator />
                <ContextMenuItem>
                    <DynamicIcon Name="Trash" Class="mr-2 h-4 w-4" />
                    Delete
                </ContextMenuItem>
            </ContextMenuContent>
        </ContextMenu>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="contextmenu" Level="3" Class="mt-8 scroll-mt-20">ContextMenu</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Prop</TableHead>
                    <TableHead Class="w-[180px]">Type</TableHead>
                    <TableHead Class="w-[120px]">Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell Class="font-mono text-xs">ChildContent</TableCell><TableCell Class="font-mono text-xs">RenderFragment?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Trigger and content elements.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsOpen</TableCell><TableCell Class="font-mono text-xs">bool</TableCell><TableCell Class="font-mono text-xs">false</TableCell><TableCell>Controls whether the context menu is visible. Use with @@bind-IsOpen.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">IsOpenChanged</TableCell><TableCell Class="font-mono text-xs">EventCallback&lt;bool&gt;</TableCell><TableCell Class="font-mono text-xs">—</TableCell><TableCell>Callback invoked when the open state changes.</TableCell></TableRow>
                <TableRow><TableCell Class="font-mono text-xs">AdditionalAttributes</TableCell><TableCell Class="font-mono text-xs">Dictionary&lt;string, object&gt;?</TableCell><TableCell Class="font-mono text-xs">null</TableCell><TableCell>Additional HTML attributes.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>

