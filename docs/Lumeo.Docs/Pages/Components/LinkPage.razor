@page "/components/link"

<PageTitle>Link — Lumeo</PageTitle>

<PageHeader Title="Link" Description="A styled anchor component with variant support and external link handling." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Link Href="#">Default link style</Link>
    </ComponentDemo>

    <ComponentDemo Title="Variants" Code="@_variantsCode">
        <Flex Gap="6" Align="center">
            <Link Href="#" Variant="default">Default</Link>
            <Link Href="#" Variant="muted">Muted</Link>
            <Link Href="#" Variant="underline">Underline</Link>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="External Link" Code="@_externalCode">
        <Link Href="https://github.com" External="true">
            Visit GitHub
            <DynamicIcon Name="ExternalLink" Class="h-3 w-3 ml-1 inline" />
        </Link>
    </ComponentDemo>

    <ComponentDemo Title="With Size" Code="@_sizeCode">
        <Stack Gap="2">
            <Link Href="#" Size="xs">Extra small link</Link>
            <Link Href="#" Size="sm">Small link</Link>
            <Link Href="#">Default size link</Link>
            <Link Href="#" Size="lg">Large link</Link>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Href</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>The URL to link to.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Variant</TableCell>
                    <TableCell Class="font-mono text-xs">string</TableCell>
                    <TableCell Class="font-mono text-xs">"default"</TableCell>
                    <TableCell>Link style variant. "default" (primary color, hover underline), "muted" (muted color), or "underline" (always underlined).</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">External</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Opens link in a new tab with target="_blank" and rel="noopener noreferrer".</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Size</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Text size. Maps to text-{value}.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _defaultCode = @"<Link Href=""#"">Default link style</Link>";

    private string _variantsCode = @"<Link Href=""#"" Variant=""default"">Default</Link>
<Link Href=""#"" Variant=""muted"">Muted</Link>
<Link Href=""#"" Variant=""underline"">Underline</Link>";

    private string _externalCode = @"<Link Href=""https://github.com"" External=""true"">
    Visit GitHub
</Link>";

    private string _sizeCode = @"<Link Href=""#"" Size=""xs"">Extra small</Link>
<Link Href=""#"" Size=""sm"">Small</Link>
<Link Href=""#"">Default</Link>
<Link Href=""#"" Size=""lg"">Large</Link>";
}
