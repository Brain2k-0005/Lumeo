@page "/components/spacer"

<PageTitle>Spacer — Lumeo</PageTitle>

<PageHeader Title="Spacer" Description="A flexible spacer that expands to fill available space or renders at a fixed size." />

<Stack Gap="8">
    <ComponentDemo Title="Flex Spacer" Code="@_flexCode">
        <Flex Align="center" Class="w-full p-3 rounded-lg border border-border">
            <Text Weight="semibold">Brand</Text>
            <Spacer />
            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Login</Button>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Fixed Size" Code="@_fixedCode">
        <Stack Direction="Stack.StackDirection.Horizontal" Align="center">
            <div class="h-10 w-10 rounded-full bg-primary/20"></div>
            <Spacer Size="4" />
            <Stack Gap="0">
                <Text Weight="medium" Size="sm">Jane Doe</Text>
                <Text Color="muted" Size="xs">jane@example.com</Text>
            </Stack>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Size</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Fixed size as a Tailwind value. When null, expands with flex-1. When set, renders as w-{Size} h-{Size}.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _flexCode = @"<Flex Align=""center"">
    <Text Weight=""semibold"">Brand</Text>
    <Spacer />
    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Login</Button>
</Flex>";

    private string _fixedCode = @"<Stack Direction=""Stack.StackDirection.Horizontal"" Align=""center"">
    <Avatar />
    <Spacer Size=""4"" />
    <Stack Gap=""0"">
        <Text Weight=""medium"" Size=""sm"">Jane Doe</Text>
        <Text Color=""muted"" Size=""xs"">jane@example.com</Text>
    </Stack>
</Stack>";
}
