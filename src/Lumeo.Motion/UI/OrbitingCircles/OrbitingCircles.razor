@namespace Lumeo

@* OrbitingCircles — Magic UI port.
   Usage: nest <OrbitItem> children inside <OrbitingCircles>.
   Each OrbitItem registers itself and receives an auto-computed angular offset.
   A separate CenterContent slot renders in the middle. *@
<div class="@CssClass" style="@ContainerStyle" @attributes="AdditionalAttributes">
    @* Orbit path ring (optional) *@
    @if (ShowPath)
    {
        <svg class="lumeo-orbit-path-svg" aria-hidden="true"
             viewBox="0 0 @Size @Size" width="@Size" height="@Size">
            <circle class="lumeo-orbit-path-circle"
                    cx="@(Size / 2)" cy="@(Size / 2)"
                    r="@Radius" />
        </svg>
    }

    @* Center icon *@
    @if (CenterContent != null)
    {
        <div class="lumeo-orbiting-center">
            @CenterContent
        </div>
    }

    @* Child orbit items — each OrbitItem registers and gets an angle *@
    <CascadingValue Value="this" IsFixed="true">
        @ChildContent
    </CascadingValue>
</div>

@code {
    /// <summary>Content placed at the center of the orbit ring.</summary>
    [Parameter] public RenderFragment? CenterContent { get; set; }
    /// <summary>Orbit icons as nested <c>&lt;OrbitItem&gt;</c> children.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Orbit radius in pixels (center-to-icon distance).</summary>
    [Parameter] public int Radius { get; set; } = 80;
    /// <summary>Duration of one full revolution in milliseconds.</summary>
    [Parameter] public int DurationMs { get; set; } = 20000;
    /// <summary>Reverses the direction of orbit.</summary>
    [Parameter] public bool Reverse { get; set; } = false;
    /// <summary>Show the circular orbit path guide line.</summary>
    [Parameter] public bool ShowPath { get; set; } = true;
    /// <summary>Container diameter in pixels. Should be &gt;= (2 × Radius) + icon size.</summary>
    [Parameter] public int Size { get; set; } = 240;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly List<OrbitItem> _items = new();
    private bool _dirty;

    private string CssClass => string.Join(" ", new[] { "lumeo-orbiting-circles", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));
    private string ContainerStyle => $"width:{Size}px;height:{Size}px;";

    internal void RegisterItem(OrbitItem item)
    {
        if (!_items.Contains(item))
        {
            _items.Add(item);
            _dirty = true;
        }
    }

    internal void UnregisterItem(OrbitItem item)
    {
        if (_items.Remove(item))
        {
            _dirty = true;
        }
    }

    // Assign angles and re-render all items after the child tree renders
    protected override void OnAfterRender(bool firstRender)
    {
        if (_dirty)
        {
            _dirty = false;
            // Distribute angles evenly; notify each item of its new angle
            int count = _items.Count;
            for (int i = 0; i < count; i++)
            {
                _items[i].SetAngle((360.0 / Math.Max(1, count)) * i);
            }
        }
    }

    public int GetRadius() => Radius;
    public int GetDurationMs() => DurationMs;
    public bool GetReverse() => Reverse;
}
