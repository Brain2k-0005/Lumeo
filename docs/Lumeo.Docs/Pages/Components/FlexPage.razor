@page "/components/flex"

<PageTitle>Flex — Lumeo</PageTitle>

<PageHeader Title="Flex" Description="A low-level flexbox container with full control over direction, alignment, and wrapping." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Row" Code="@_basicCode">
        <Flex Gap="3">
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 1</div>
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 2</div>
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 3</div>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="With Spacer" Code="@_spacerCode">
        <Flex Align="center" Class="w-full">
            <Text Weight="semibold">Logo</Text>
            <Spacer />
            <Flex Gap="2">
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">About</Button>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">Blog</Button>
                <Button Size="Button.ButtonSize.Sm">Sign In</Button>
            </Flex>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Centered" Code="@_centeredCode">
        <Flex Align="center" Justify="center" Class="h-32 w-full rounded-lg border border-dashed border-border">
            <Text Color="muted">Centered content</Text>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Wrapping" Code="@_wrapCode">
        <Flex Gap="2" Wrap="true" Class="w-full max-w-sm">
            @for (var i = 1; i <= 8; i++)
            {
                <div class="h-10 w-20 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">@i</div>
            }
        </Flex>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Direction</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">"row"</TableCell>
                    <TableCell>Flex direction. Maps to flex-{value} (e.g. "row", "col", "row-reverse").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Gap</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Tailwind gap value (e.g. "2", "4", "8").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Align</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Cross-axis alignment. Maps to items-{value}.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Justify</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Main-axis alignment. Maps to justify-{value}.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Wrap</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Whether items should wrap.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Inline</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Use inline-flex instead of flex.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _basicCode = @"<Flex Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Flex>";

    private string _spacerCode = @"<Flex Align=""center"">
    <Text Weight=""semibold"">Logo</Text>
    <Spacer />
    <Flex Gap=""2"">
        <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"">About</Button>
        <Button Size=""Button.ButtonSize.Sm"">Sign In</Button>
    </Flex>
</Flex>";

    private string _centeredCode = @"<Flex Align=""center"" Justify=""center"" Class=""h-32 w-full"">
    <Text Color=""muted"">Centered content</Text>
</Flex>";

    private string _wrapCode = @"<Flex Gap=""2"" Wrap=""true"">
    <div>1</div>
    <div>2</div>
    <!-- ... more items -->
</Flex>";
}
