<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>false</IsPackable>
    <RootNamespace>Lumeo.Tests.ServerHost</RootNamespace>
    <!-- Minimal Blazor SERVER (interactive-server render mode, real SignalR
         circuit) host for the latency leg — everything else in this repo is
         Blazor WebAssembly (the docs app) or bUnit (component tests), neither
         of which exercises the circuit round-trip latency that Server mode
         is uniquely sensitive to (drag commits, toast bursts, dialog
         open/close all await a .NET round-trip through SignalR). -->
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Lumeo\Lumeo.csproj" />
    <ProjectReference Include="..\..\src\Lumeo.DataGrid\Lumeo.DataGrid.csproj" />
  </ItemGroup>

</Project>
