@inject NavConfigService NavConfig
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IDisposable
@using Lumeo.Docs.Services

@* Active-link highlight is applied to NavLink's auto-generated `.active` class via an
   arbitrary Tailwind variant on the <nav>. Active-item scroll-into-view happens on
   every render once we have the nav ref (see OnAfterRenderAsync). *@

@{
    RenderFragment navContent =
    @<text>
        @* Catalog promo — visual entry point to the /components catalog so users don't
           have to scroll the long sidebar to discover what's available. *@
        <a href="components"
           class="group flex items-center gap-3 rounded-lg border border-primary/30 bg-primary/5 hover:bg-primary/10 px-3 py-2.5 mb-2 transition-colors no-underline">
            <span class="flex h-8 w-8 items-center justify-center rounded-md bg-primary/15 text-primary shrink-0">
                <Blazicon Svg="Lucide.LayoutGrid" class="h-4 w-4" />
            </span>
            <span class="flex-1 min-w-0">
                <span class="block text-sm font-semibold text-foreground">Browse catalog</span>
                <span class="block text-[11px] text-muted-foreground">128 components, visual grid</span>
            </span>
            <Blazicon Svg="Lucide.ArrowRight" class="h-3.5 w-3.5 text-muted-foreground group-hover:text-primary group-hover:translate-x-0.5 transition-all shrink-0" />
        </a>

        @if (_config is null)
        {
            <Stack Gap="1" Class="px-2 py-4">
                <Skeleton Height="16" Width="60%" />
                <Skeleton Height="14" Width="80%" />
                <Skeleton Height="14" Width="70%" />
            </Stack>
        }
        else
        {
            @foreach (var group in _config.Groups)
            {
                <NavGroupSection Group="@group" />
            }
        }
    </text>;
}

@if (IsMobile)
{
    <nav class="lumeo-sidebar-nav p-4 space-y-6 text-sm" @ref="_navRef">@navContent</nav>
}
else
{
    <aside class="hidden lg:block w-64 shrink-0 m-3 rounded-[var(--radius-xl)] border border-border/60 bg-card shadow-lg overflow-y-auto sticky top-[84px]" style="max-height: calc(100vh - 100px)">
        <nav class="lumeo-sidebar-nav p-4 space-y-6 text-sm" @ref="_navRef">@navContent</nav>
    </aside>
}

@code {
    [Parameter] public bool IsMobile { get; set; }
    private NavConfig? _config;
    private ElementReference _navRef;
    private string? _lastLocation;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        _config = await NavConfig.GetAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Scroll the active nav item into view after each location change.
        if (Nav.Uri != _lastLocation)
        {
            _lastLocation = Nav.Uri;
            try
            {
                await JS.InvokeVoidAsync("lumeoNavScrollActiveIntoView", _navRef);
            }
            catch (JSDisconnectedException) { }
            catch (Microsoft.JSInterop.JSException) { /* nav ref not ready yet */ }
        }
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
