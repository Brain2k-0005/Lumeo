    private List<SearchItem> _searchResults = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                Nav.LocationChanged += OnLocationChanged;
                await ThemeService.InitializeAsync();
                _darkMode = ThemeService.IsDark;
                ThemeService.OnThemeChanged += OnThemeServiceChanged;
                StateHasChanged();

                await JS.InvokeVoidAsync("lumeo.setupSearch");

                _kbdShortcuts.Add(await Shortcuts.RegisterAsync("ctrl+b", () =>
                {
                    _customizerOpen = !_customizerOpen;
                    InvokeAsync(StateHasChanged);
                    return Task.CompletedTask;
                }));
                _kbdShortcuts.Add(await Shortcuts.RegisterAsync("ctrl+d", async () =>
                {
                    await ToggleDarkMode();
                    await InvokeAsync(StateHasChanged);
                }));
                _kbdShortcuts.Add(await Shortcuts.RegisterAsync("ctrl+/", () =>
                {
                    Nav.NavigateTo("docs/services/keyboard-shortcuts");
                    return Task.CompletedTask;
                }));
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Lumeo] Init error: {ex.Message}");
            }
        }
    }

    private async Task OpenSearch()
    {
        _searchOpen = true;
        _searchQuery = string.Empty;
        _searchResults = [];
        StateHasChanged();
        await Task.Delay(50);
        try { await _searchInput.FocusAsync(); } catch (Exception) { /* search input may not be rendered yet */ }
    }

    private void CloseSearch()
    {
        _searchOpen = false;
        _searchQuery = string.Empty;
        _searchResults = [];
    }

    private void HandleSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") CloseSearch();
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResults = [];
            return;
        }
        var q = _searchQuery.ToLowerInvariant();
        _searchResults = _allSearchItems
            .Where(x => x.Label.ToLowerInvariant().Contains(q) || x.Category.ToLowerInvariant().Contains(q))
            .Take(10)
            .ToList();
    }

    private void NavigateTo(SearchItem item)
    {
        CloseSearch();
        Nav.NavigateTo(item.Href);
    }

    private static string GetSearchIcon(string category) => category switch
    {
        "Blocks" => "LayoutGrid",
        "Charts" => "TrendingUp",
        "Services" => "Wrench",
        "Customization" => "Palette",
        _ => "Box"
    };

    private void OnThemeServiceChanged()
    {
        _darkMode = ThemeService.IsDark;
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _mobileNavOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        Nav.LocationChanged -= OnLocationChanged;
        ThemeService.OnThemeChanged -= OnThemeServiceChanged;
        foreach (var s in _kbdShortcuts) await s.DisposeAsync();
    }

    private async Task ToggleDarkMode()
    {
        await ThemeService.ToggleModeAsync();
        _darkMode = ThemeService.IsDark;
    }
}
