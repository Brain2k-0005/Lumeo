{
  "$schema": "http://json.schemastore.org/template",
  "author": "bemi",
  "classifications": ["Blazor", "Lumeo", "Form"],
  "identity": "Lumeo.Templates.Form",
  "name": "Lumeo Form",
  "shortName": "lumeo-form",
  "sourceName": "__ModelName__",
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "PageName": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "__PageName__",
      "fileRename": "__PageName__",
      "description": "Page class name (PascalCase)",
      "defaultValue": "ContactFormPage"
    },
    "route": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "__PageRoute__",
      "description": "Page route (without leading slash)",
      "defaultValue": "contact"
    }
  }
}
