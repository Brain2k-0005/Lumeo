@page "/components/calendar"

<PageTitle>Calendar — Lumeo</PageTitle>

<PageHeader Title="Calendar" Description="A date picker calendar component for selecting dates." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Justify="center">
            <div class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_selectedDate" />
            </div>
        </Flex>
        @if (_selectedDate.HasValue)
        {
            <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-4">Selected: @_selectedDate.Value.ToString("MMMM d, yyyy")</Lumeo.Text>
        }
    </ComponentDemo>

    <ComponentDemo Title="Date Range Display" Code="@_rangeCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Stack Direction="Stack.StackDirection.Horizontal" Gap="4" Class="flex-col sm:flex-row">
                <Stack Gap="1.5" Class="flex-1">
                    <Label>Check-in</Label>
                    <div class="rounded-md border bg-card p-1">
                        <Calendar @bind-Value="_checkIn" />
                    </div>
                </Stack>
            </Stack>
            @if (_checkIn.HasValue)
            {
                <Flex Align="center" Gap="2" Class="p-3 rounded-md bg-muted/50 text-sm">
                    <DynamicIcon Name="Calendar" Class="h-4 w-4 text-muted-foreground" />
                    <Lumeo.Text As="span" Size="sm">Check-in: <strong>@_checkIn.Value.ToString("MMM d, yyyy")</strong></Lumeo.Text>
                </Flex>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Pre-selected Date" Code="@_preselectedCode">
        <Flex Justify="center">
            <div class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_preselectedDate" />
            </div>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Min & Max Date" Code="@_minMaxCode">
        <Flex Justify="center">
            <div class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_constrainedDate" MinDate="@_minDate" MaxDate="@_maxDate" />
            </div>
        </Flex>
        <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-2">Selectable range: @_minDate.ToString("MMM d") — @_maxDate.ToString("MMM d, yyyy")</Lumeo.Text>
    </ComponentDemo>

    <ComponentDemo Title="Date Range" Code="@_dateRangeCode">
        <Stack Gap="2">
            <Flex Justify="center">
                <div class="rounded-md border bg-card p-1">
                    <Calendar IsRange="true" @bind-RangeStart="_rangeStart" @bind-RangeEnd="_rangeEnd" />
                </div>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Class="text-center">
                @if (_rangeStart.HasValue && _rangeEnd.HasValue)
                {
                    @($"Selected: {_rangeStart:MMM dd} — {_rangeEnd:MMM dd}")
                }
                else if (_rangeStart.HasValue)
                {
                    @($"Start: {_rangeStart:MMM dd} — pick end date")
                }
                else
                {
                    <Lumeo.Text As="span">Pick a start date</Lumeo.Text>
                }
            </Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Calendar</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The currently selected date. Use with @@bind-Value for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MinDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The earliest selectable date. Dates before this are disabled.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MaxDate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The latest selectable date. Dates after this are disabled.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsRange</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, enables date range selection mode.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RangeStart</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The start of the selected date range. Use with @@bind-RangeStart.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RangeEnd</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">DateOnly?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The end of the selected date range. Use with @@bind-RangeEnd.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private DateOnly? _selectedDate;
    private DateOnly? _preselectedDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _checkIn;
    private DateOnly? _constrainedDate;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;

    private string _defaultCode = @"<Calendar @bind-Value=""_selectedDate"" />";

    private string _rangeCode = @"<Stack Gap=""1.5"">
    <Label>Check-in</Label>
    <div class=""rounded-md border p-1"">
        <Calendar @bind-Value=""_checkIn"" />
    </div>
</Stack>
@if (_checkIn.HasValue)
{
    <Flex Align=""center"" Gap=""2"" Class=""p-3 rounded-md bg-muted/50 text-sm"">
        <DynamicIcon Name=""Calendar"" Class=""h-4 w-4 text-muted-foreground"" />
        <Lumeo.Text As=""span"" Size=""sm"">Check-in: <strong>@_checkIn.Value.ToString(""MMM d, yyyy"")</strong></Lumeo.Text>
    </Flex>
}";

    private string _preselectedCode = @"<Calendar @bind-Value=""_date"" />

@code {
    private DateOnly? _date = DateOnly.FromDateTime(DateTime.Today);
}";

    private string _minMaxCode = @"<Calendar @bind-Value=""_date"" MinDate=""@_minDate"" MaxDate=""@_maxDate"" />

@code {
    private DateOnly? _date;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
}";

    private string _dateRangeCode = @"<Calendar IsRange=""true"" @bind-RangeStart=""_rangeStart"" @bind-RangeEnd=""_rangeEnd"" />

@if (_rangeStart.HasValue && _rangeEnd.HasValue)
{
    <Lumeo.Text Size=""sm"" Color=""muted"">Selected: @($""{_rangeStart:MMM dd} — {_rangeEnd:MMM dd}"")</Lumeo.Text>
}

@code {
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
}";
}
