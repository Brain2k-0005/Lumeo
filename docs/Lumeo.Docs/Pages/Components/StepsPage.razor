@page "/components/steps"

<PageTitle>Steps — Lumeo</PageTitle>

<PageHeader Title="Steps" Description="A step tracker for multi-step workflows and wizards." />

<InstallUsage Component="Steps" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Multi-step processes such as forms, registrations, or checkout flows</li>
        <li>Setup wizards that guide users through sequential configuration</li>
        <li>Onboarding flows where users complete tasks in a defined order</li>
        <li>Checkout or payment workflows with clearly defined stages</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Steps" Code="@_codeBasic">
        <Steps CurrentStep="1" Class="w-full max-w-lg">
            <StepsItem Title="Account" Description="Create your account" />
            <StepsItem Title="Profile" Description="Set up your profile" />
            <StepsItem Title="Complete" Description="All done" />
        </Steps>
    </ComponentDemo>

    <ComponentDemo Title="Interactive Steps" Code="@_codeInteractive">
        <Container MaxWidth="lg" Center="false" Padding="">
            <Stack Gap="4">
                <Steps @bind-CurrentStep="_currentStep" Clickable="true" Class="w-full">
                    <StepsItem Title="Details" />
                    <StepsItem Title="Payment" />
                    <StepsItem Title="Review" />
                    <StepsItem Title="Confirm" />
                </Steps>
                <Lumeo.Text Size="sm" Color="muted" Align="center">Current step: @_currentStep</Lumeo.Text>
                <Flex Justify="center" Gap="2">
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="() => { if (_currentStep > 0) _currentStep--; }">Previous</Button>
                    <Button Size="Button.ButtonSize.Sm" OnClick="() => { if (_currentStep < 3) _currentStep++; }">Next</Button>
                </Flex>
            </Stack>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Vertical Steps" Code="@_codeVertical">
        <Steps CurrentStep="2" Orientation="Lumeo.Orientation.Vertical" Class="max-w-sm">
            <StepsItem Title="Sign Up" Description="Create an account" />
            <StepsItem Title="Verify Email" Description="Confirm your email address" />
            <StepsItem Title="Set Password" Description="Choose a secure password" />
            <StepsItem Title="Done" Description="Start using the app" />
        </Steps>
    </ComponentDemo>

    <ComponentDemo Title="Orientation (interactive)" Code="@_codeOrientationInteractive">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch orientation to compare horizontal and vertical layouts.</Lumeo.Text>
            <Segmented @bind-Value="_stepsOrientation">
                <SegmentedItem Value="Horizontal">Horizontal</SegmentedItem>
                <SegmentedItem Value="Vertical">Vertical</SegmentedItem>
            </Segmented>
            <Steps CurrentStep="1" Orientation="@_stepsOrientationEnum" Class="@(_stepsOrientation == "Vertical" ? "max-w-xs" : "w-full")">
                <StepsItem Title="Account" Description="Create your account" />
                <StepsItem Title="Profile" Description="Set up your profile" />
                <StepsItem Title="Payment" Description="Add billing info" />
                <StepsItem Title="Done" Description="All finished" />
            </Steps>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Error Status">
        <Steps CurrentStep="2" Class="w-full max-w-lg">
            <StepsItem Title="Account" Description="Create your account" />
            <StepsItem Title="Payment" Description="Card declined" Status="StepsItem.StepsItemStatus.Error" />
            <StepsItem Title="Review" Description="Confirm details" />
            <StepsItem Title="Done" Description="All finished" />
        </Steps>
    </ComponentDemo>

    <ComponentDemo Title="Custom Icon">
        <Steps CurrentStep="1" Class="w-full max-w-lg">
            <StepsItem Title="Account" Description="Create your account">
                <IconContent>
                    <DynamicIcon Name="User" Class="h-4 w-4" />
                </IconContent>
            </StepsItem>
            <StepsItem Title="Payment" Description="Add billing info">
                <IconContent>
                    <DynamicIcon Name="CreditCard" Class="h-4 w-4" />
                </IconContent>
            </StepsItem>
            <StepsItem Title="Done" Description="All finished">
                <IconContent>
                    <DynamicIcon Name="Check" Class="h-4 w-4" />
                </IconContent>
            </StepsItem>
        </Steps>
    </ComponentDemo>

    <ComponentDemo Title="Animated Steps" Code="@_codeAnimated">
        <Container MaxWidth="lg" Center="false" Padding="">
            <Stack Gap="4">
                <Steps @bind-CurrentStep="_animatedStep" Animated="true" Class="w-full">
                    <StepsItem Title="Account" Description="Create your account" />
                    <StepsItem Title="Profile" Description="Set up your profile" />
                    <StepsItem Title="Payment" Description="Add billing" />
                    <StepsItem Title="Complete" Description="All done" />
                </Steps>
                <Flex Justify="center" Gap="2">
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="() => { if (_animatedStep > 0) _animatedStep--; }">Previous</Button>
                    <Button Size="Button.ButtonSize.Sm" OnClick="() => { if (_animatedStep < 3) _animatedStep++; }">Next</Button>
                </Flex>
                <Lumeo.Text Size="xs" Color="muted" Align="center">
                    Active dot pulses; the connector draws in on Next and retracts on Previous.
                </Lumeo.Text>
            </Stack>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Steps</Heading>
            <PropsTable Slug="steps" />
        </Stack>
        <Stack>
            <Heading Level="3" Class="mb-3">StepsItem</Heading>
            <PropsTable Slug="steps" SubComponent="StepsItem" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/progress" class="text-primary hover:underline">Progress</a> — Show completion percentage instead of discrete steps</li>
        <li><a href="/components/tabs" class="text-primary hover:underline">Tabs</a> — Switch between views without implying sequential order</li>
        <li><a href="/components/timeline" class="text-primary hover:underline">Timeline</a> — Display events chronologically rather than as actionable steps</li>
    </ul>
</div>

@code {
    private string _stepsOrientation = "Horizontal";
    private Lumeo.Orientation _stepsOrientationEnum =>
        Enum.TryParse<Lumeo.Orientation>(_stepsOrientation, out var v) ? v : Lumeo.Orientation.Horizontal;
    private int _currentStep = 0;
    private int _animatedStep = 1;

    private string _codeBasic = @"<Steps CurrentStep=""1"">
    <StepsItem Title=""Account"" Description=""Create your account"" />
    <StepsItem Title=""Profile"" Description=""Set up your profile"" />
    <StepsItem Title=""Complete"" Description=""All done"" />
</Steps>";

    private string _codeInteractive = @"<Steps @bind-CurrentStep=""_step"" Clickable=""true"">
    <StepsItem Title=""Details"" />
    <StepsItem Title=""Payment"" />
    <StepsItem Title=""Review"" />
    <StepsItem Title=""Confirm"" />
</Steps>";

    private string _codeVertical = @"<Steps CurrentStep=""2"" Orientation=""Lumeo.Orientation.Vertical"">
    <StepsItem Title=""Sign Up"" Description=""Create an account"" />
    <StepsItem Title=""Verify Email"" Description=""Confirm your email"" />
    <StepsItem Title=""Set Password"" Description=""Choose a password"" />
    <StepsItem Title=""Done"" Description=""Start using the app"" />
</Steps>";

    private string _codeOrientationInteractive = @"<Segmented @bind-Value=""_orientation"">
    <SegmentedItem Value=""@Lumeo.Orientation.Horizontal"">Horizontal</SegmentedItem>
    <SegmentedItem Value=""@Lumeo.Orientation.Vertical"">Vertical</SegmentedItem>
</Segmented>
<Steps CurrentStep=""1"" Orientation=""@_orientation"">
    <StepsItem Title=""Account"" Description=""Create your account"" />
    <StepsItem Title=""Profile"" Description=""Set up your profile"" />
    <StepsItem Title=""Payment"" Description=""Add billing info"" />
    <StepsItem Title=""Done"" Description=""All finished"" />
</Steps>

@code { private Lumeo.Orientation _orientation = Lumeo.Orientation.Horizontal; }";

    private string _codeAnimated = @"<Steps @bind-CurrentStep=""_step"" Animated=""true"">
    <StepsItem Title=""Account"" Description=""Create your account"" />
    <StepsItem Title=""Profile"" Description=""Set up your profile"" />
    <StepsItem Title=""Payment"" Description=""Add billing"" />
    <StepsItem Title=""Complete"" Description=""All done"" />
</Steps>
<Flex Justify=""center"" Gap=""2"">
    <Button Variant=""Button.ButtonVariant.Outline"" OnClick=""() => { if (_step > 0) _step--; }"">Previous</Button>
    <Button OnClick=""() => { if (_step < 3) _step++; }"">Next</Button>
</Flex>";
}
