@page "/components/charts/polar-bar"

<PageTitle>Polar Bar Chart — Lumeo</PageTitle>

<PageHeader Title="Polar Bar Chart" Description="Display bar data in a polar coordinate system, where each bar extends radially. Great for cyclical data like days of the week or hours of the day." />

<Stack Gap="8">
    <ComponentDemo Title="Weekly Activity" Code="@_basicCode">
        <Container>
            <PolarBarChart Categories="_categories" Values="_values" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">PolarBarChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Angular axis category labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Values</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Values for each category.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Shows or hides the chart legend.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private List<double> _values = new() { 3240, 4180, 3870, 5120, 6340, 4980, 3650 };

    private string _basicCode = @"<PolarBarChart Categories=""_categories"" Values=""_values"" />";
}
