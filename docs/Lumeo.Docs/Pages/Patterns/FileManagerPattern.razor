@page "/blocks/file-manager"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>File Manager Pattern — Lumeo</PageTitle>

<PageHeader Title="File Manager" Description="A file browser interface with breadcrumb navigation, sortable data table, context menus, and drag-and-drop upload." />

<Stack Gap="6">

    <ComponentDemo Title="File Browser" Code="@_fileManagerCode">
        <Stack Gap="4" Class="w-full min-w-[700px]">

            <!-- Top Bar -->
            <Flex Class="flex-wrap items-center justify-between gap-3">
                <Breadcrumb>
                    <BreadcrumbList>
                        <BreadcrumbItem>
                            <BreadcrumbLink href="#">
                                <DynamicIcon Name="House" Class="h-4 w-4" />
                            </BreadcrumbLink>
                        </BreadcrumbItem>
                        <BreadcrumbSeparator />
                        @if (_currentPath.Count > 2)
                        {
                            <BreadcrumbEllipsis />
                            <BreadcrumbSeparator />
                        }
                        @for (int i = Math.Max(0, _currentPath.Count - 2); i < _currentPath.Count; i++)
                        {
                            var idx = i;
                            @if (idx < _currentPath.Count - 1)
                            {
                                <BreadcrumbItem>
                                    <BreadcrumbLink @onclick="@(() => NavigateTo(idx))" style="cursor:pointer">
                                        @_currentPath[idx]
                                    </BreadcrumbLink>
                                </BreadcrumbItem>
                                <BreadcrumbSeparator />
                            }
                            else
                            {
                                <BreadcrumbItem>
                                    <BreadcrumbPage>@_currentPath[idx]</BreadcrumbPage>
                                </BreadcrumbItem>
                            }
                        }
                    </BreadcrumbList>
                </Breadcrumb>

                <Flex Class="items-center gap-2">
                    <Flex Class="rounded-md border overflow-hidden">
                        <Button Variant="@(_viewMode == "grid" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Icon" Class="rounded-none h-8 w-9" @onclick="@(() => _viewMode = "grid")">
                            <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                        </Button>
                        <Button Variant="@(_viewMode == "list" ? Button.ButtonVariant.Default : Button.ButtonVariant.Ghost)"
                                Size="Button.ButtonSize.Icon" Class="rounded-none h-8 w-9" @onclick="@(() => _viewMode = "list")">
                            <DynamicIcon Name="List" Class="h-4 w-4" />
                        </Button>
                    </Flex>
                    <Button Size="Button.ButtonSize.Sm" @onclick="@(() => _showUpload = !_showUpload)">
                        <DynamicIcon Name="Upload" Class="h-4 w-4 mr-1" />
                        Upload
                    </Button>
                </Flex>
            </Flex>

            <!-- Selection info bar -->
            @if (_selectedFiles.Count > 0)
            {
                <Flex Class="items-center gap-3 rounded-md border bg-muted/50 px-3 py-2">
                    <Lumeo.Text As="span" Class="text-sm text-foreground font-medium">@_selectedFiles.Count selected</Lumeo.Text>
                    <Flex Class="items-center gap-2 ml-auto">
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Copy" Class="h-4 w-4 mr-1" />
                            Copy
                        </Button>
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Trash2" Class="h-4 w-4 mr-1" />
                            Delete
                        </Button>
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" @onclick="@(() => _selectedFiles.Clear())">
                            <DynamicIcon Name="X" Class="h-4 w-4 mr-1" />
                            Clear
                        </Button>
                    </Flex>
                </Flex>
            }

            <!-- File Table -->
            <Card>
                <CardContent Class="p-0">
                    <DataTable TItem="FileItem"
                               Items="@SortedFiles"
                               Selectable="true"
                               SelectedItems="@_selectedFiles"
                               SelectedItemsChanged="@(s => _selectedFiles = s)">
                        <HeaderTemplate>
                            <DataTableSortableHeader Column="Name" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Name</DataTableSortableHeader>
                            <DataTableSortableHeader Column="Type" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Type</DataTableSortableHeader>
                            <DataTableSortableHeader Column="Size" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Size</DataTableSortableHeader>
                            <DataTableSortableHeader Column="Modified" SortColumn="@_sortColumn" SortDirection="@_sortDir" OnSort="@HandleSort">Modified</DataTableSortableHeader>
                            <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground w-10"></th>
                        </HeaderTemplate>
                        <RowTemplate Context="file">
                            <ContextMenu>
                                <ContextMenuTrigger>
                                    <TableCell>
                                        <Flex Class="items-center gap-2 cursor-pointer" @ondblclick="@(() => OpenFile(file))">
                                            <DynamicIcon Name="@file.Icon" Class="h-4 w-4 text-muted-foreground shrink-0" />
                                            <Lumeo.Text As="span" Class="font-medium text-foreground">@file.Name</Lumeo.Text>
                                        </Flex>
                                    </TableCell>
                                </ContextMenuTrigger>
                                <TableCell><Badge Variant="Badge.BadgeVariant.Secondary">@file.Type</Badge></TableCell>
                                <TableCell Class="text-muted-foreground">@file.Size</TableCell>
                                <TableCell Class="text-muted-foreground">@file.Modified</TableCell>
                                <TableCell>
                                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                                        <DynamicIcon Name="Ellipsis" Class="h-4 w-4" />
                                    </Button>
                                </TableCell>
                                <ContextMenuContent>
                                    <ContextMenuItem @onclick="@(() => OpenFile(file))">
                                        <DynamicIcon Name="FolderOpen" Class="h-4 w-4" />
                                        Open
                                    </ContextMenuItem>
                                    <ContextMenuItem>
                                        <DynamicIcon Name="Pencil" Class="h-4 w-4" />
                                        Rename
                                    </ContextMenuItem>
                                    <ContextMenuItem>
                                        <DynamicIcon Name="Copy" Class="h-4 w-4" />
                                        Copy
                                    </ContextMenuItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuCheckboxItem @bind-Checked="_showHidden">
                                        Show hidden files
                                    </ContextMenuCheckboxItem>
                                    <ContextMenuSeparator />
                                    <ContextMenuLabel>Sort by</ContextMenuLabel>
                                    <ContextMenuRadioGroup Value="@_sortColumn" ValueChanged="@(v => _sortColumn = v)">
                                        <ContextMenuRadioItem Value="Name">Name</ContextMenuRadioItem>
                                        <ContextMenuRadioItem Value="Modified">Date modified</ContextMenuRadioItem>
                                        <ContextMenuRadioItem Value="Size">Size</ContextMenuRadioItem>
                                    </ContextMenuRadioGroup>
                                    <ContextMenuSeparator />
                                    <ContextMenuItem Class="text-destructive hover:text-destructive">
                                        <DynamicIcon Name="Trash2" Class="h-4 w-4" />
                                        Delete
                                    </ContextMenuItem>
                                </ContextMenuContent>
                            </ContextMenu>
                        </RowTemplate>
                    </DataTable>
                </CardContent>
            </Card>

            <!-- Upload Area -->
            @if (_showUpload)
            {
                <Card>
                    <CardHeader>
                        <Flex Class="items-center justify-between">
                            <Heading Level="3" Class="text-sm font-semibold text-foreground">Upload Files</Heading>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon" @onclick="@(() => _showUpload = false)">
                                <DynamicIcon Name="X" Class="h-4 w-4" />
                            </Button>
                        </Flex>
                    </CardHeader>
                    <CardContent>
                        <FileUpload
                            Multiple="true"
                            ShowProgress="@(_uploadProgress > 0)"
                            Progress="@_uploadProgress"
                            Description="PDF, DOCX, PNG, JPG up to 50MB"
                            OnFilesSelected="@HandleFilesSelected" />
                        @if (_uploadProgress > 0 && _uploadProgress < 100)
                        {
                            <Lumeo.Text Class="text-xs text-muted-foreground mt-2 text-center">Uploading... @_uploadProgress%</Lumeo.Text>
                        }
                        @if (_uploadProgress == 100)
                        {
                            <Flex Class="items-center gap-2 mt-2 text-sm text-success-text">
                                <DynamicIcon Name="CircleCheck" Class="h-4 w-4" />
                                Upload complete
                            </Flex>
                        }
                    </CardContent>
                </Card>
            }

        </Stack>
    </ComponentDemo>

</Stack>

@code {
    private record FileItem(string Name, string Type, string Size, string Modified, string Icon);

    private List<FileItem> _files = new()
    {
        new("Projects",         "Folder",  "—",         "Feb 28, 2026", "Folder"),
        new("Assets",           "Folder",  "—",         "Feb 25, 2026", "Folder"),
        new("Archive",          "Folder",  "—",         "Jan 12, 2026", "Folder"),
        new("Q1 Report.pdf",    "PDF",     "2.4 MB",    "Feb 28, 2026", "FileText"),
        new("Budget 2026.xlsx", "Excel",   "840 KB",    "Feb 26, 2026", "FileSpreadsheet"),
        new("Presentation.pptx","PowerPoint","18.2 MB", "Feb 22, 2026", "Presentation"),
        new("logo.png",         "Image",   "156 KB",    "Feb 20, 2026", "Image"),
        new("banner.jpg",       "Image",   "1.1 MB",    "Feb 18, 2026", "Image"),
        new("notes.txt",        "Text",    "12 KB",     "Feb 15, 2026", "FileText"),
        new("backup.zip",       "Archive", "95.3 MB",   "Feb 10, 2026", "FileArchive"),
        new("README.md",        "Markdown","8 KB",      "Feb 5, 2026",  "FileText"),
        new("data.csv",         "CSV",     "340 KB",    "Jan 30, 2026", "FileSpreadsheet"),
    };

    private HashSet<FileItem> _selectedFiles = new();
    private string _sortColumn = "Name";
    private DataTable<object>.SortDirection _sortDir = DataTable<object>.SortDirection.Ascending;
    private string _viewMode = "list";
    private bool _showHidden;
    private bool _showUpload;
    private int _uploadProgress;
    private List<string> _currentPath = new() { "Home", "Documents", "Projects" };

    private IEnumerable<FileItem> SortedFiles => (_sortColumn, _sortDir) switch
    {
        ("Name",     DataTable<object>.SortDirection.Ascending)  => _files.OrderBy(f => f.Name),
        ("Name",     DataTable<object>.SortDirection.Descending) => _files.OrderByDescending(f => f.Name),
        ("Type",     DataTable<object>.SortDirection.Ascending)  => _files.OrderBy(f => f.Type),
        ("Type",     DataTable<object>.SortDirection.Descending) => _files.OrderByDescending(f => f.Type),
        ("Size",     DataTable<object>.SortDirection.Ascending)  => _files.OrderBy(f => f.Size),
        ("Size",     DataTable<object>.SortDirection.Descending) => _files.OrderByDescending(f => f.Size),
        ("Modified", DataTable<object>.SortDirection.Ascending)  => _files.OrderBy(f => f.Modified),
        ("Modified", DataTable<object>.SortDirection.Descending) => _files.OrderByDescending(f => f.Modified),
        _                                                          => _files,
    };

    private void HandleSort((string Column, DataTable<object>.SortDirection Direction) args)
    {
        _sortColumn = args.Column;
        _sortDir = args.Direction;
    }

    private void OpenFile(FileItem file)
    {
        if (file.Type == "Folder")
            _currentPath.Add(file.Name);
    }

    private void NavigateTo(int index)
    {
        _currentPath = _currentPath.Take(index + 1).ToList();
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        _uploadProgress = 0;
        for (int i = 0; i <= 100; i += 10)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(150);
        }
    }

    private string _fileManagerCode = @"<!-- File Manager Layout -->
<Stack Gap=""4"">

    <!-- Top Bar with Breadcrumb + Upload -->
    <Flex Align=""center"" Justify=""between"" Class=""flex-wrap gap-3"">
        <Breadcrumb>
            <BreadcrumbList>
                <BreadcrumbItem>
                    <BreadcrumbLink href=""#"">
                        <DynamicIcon Name=""House"" Class=""h-4 w-4"" />
                    </BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbEllipsis />
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                    <BreadcrumbLink href=""#"">Documents</BreadcrumbLink>
                </BreadcrumbItem>
                <BreadcrumbSeparator />
                <BreadcrumbItem>
                    <BreadcrumbPage>Projects</BreadcrumbPage>
                </BreadcrumbItem>
            </BreadcrumbList>
        </Breadcrumb>

        <Flex Align=""center"" Gap=""2"">
            <Flex Class=""rounded-md border overflow-hidden"">
                <Button Variant=""Button.ButtonVariant.Default"" Size=""Button.ButtonSize.Icon"" Class=""rounded-none h-8 w-9"">
                    <DynamicIcon Name=""LayoutGrid"" Class=""h-4 w-4"" />
                </Button>
                <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon"" Class=""rounded-none h-8 w-9"">
                    <DynamicIcon Name=""List"" Class=""h-4 w-4"" />
                </Button>
            </Flex>
            <Button Variant=""Button.ButtonVariant.Default"" Size=""Button.ButtonSize.Sm"">
                <DynamicIcon Name=""Upload"" Class=""h-4 w-4 mr-1"" /> Upload
            </Button>
        </Flex>
    </Flex>

    <!-- Sortable Data Table with Context Menu -->
    <Card>
        <CardContent Class=""p-0"">
            <DataTable TItem=""FileItem""
                       Items=""@_files""
                       Selectable=""true""
                       @bind-SelectedItems=""_selectedFiles""
                       @bind-SortColumn=""_sortColumn""
                       @bind-SortDir=""_sortDir""
                       OnSort=""HandleSort"">
                <HeaderTemplate>
                    <DataTableSortableHeader Column=""Name"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""HandleSort"">Name</DataTableSortableHeader>
                    <DataTableSortableHeader Column=""Type"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""HandleSort"">Type</DataTableSortableHeader>
                    <DataTableSortableHeader Column=""Size"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""HandleSort"">Size</DataTableSortableHeader>
                    <DataTableSortableHeader Column=""Modified"" SortColumn=""@_sortColumn"" SortDirection=""@_sortDir"" OnSort=""HandleSort"">Modified</DataTableSortableHeader>
                </HeaderTemplate>
                <RowTemplate Context=""file"">
                    <ContextMenu>
                        <ContextMenuTrigger>
                            <TableCell>
                                <Flex Align=""center"" Gap=""2"">
                                    <DynamicIcon Name=""FileText"" Class=""h-4 w-4 text-muted-foreground"" />
                                    <Lumeo.Text As=""span"" Class=""font-medium"">@file.Name</Lumeo.Text>
                                </Flex>
                            </TableCell>
                        </ContextMenuTrigger>
                        <TableCell><Badge Variant=""Badge.BadgeVariant.Secondary"">@file.Type</Badge></TableCell>
                        <TableCell Class=""text-muted-foreground"">@file.Size</TableCell>
                        <TableCell Class=""text-muted-foreground"">@file.Modified</TableCell>
                        <ContextMenuContent>
                            <ContextMenuItem>
                                <DynamicIcon Name=""FolderOpen"" Class=""h-4 w-4"" /> Open
                            </ContextMenuItem>
                            <ContextMenuItem>
                                <DynamicIcon Name=""Pencil"" Class=""h-4 w-4"" /> Rename
                            </ContextMenuItem>
                            <ContextMenuItem>
                                <DynamicIcon Name=""Copy"" Class=""h-4 w-4"" /> Copy
                            </ContextMenuItem>
                            <ContextMenuSeparator />
                            <ContextMenuCheckboxItem @bind-Checked=""_showHidden"">
                                Show hidden files
                            </ContextMenuCheckboxItem>
                            <ContextMenuSeparator />
                            <ContextMenuLabel>Sort by</ContextMenuLabel>
                            <ContextMenuRadioGroup Value=""@_sortColumn"" ValueChanged=""@(v => _sortColumn = v)"">
                                <ContextMenuRadioItem Value=""Name"">Name</ContextMenuRadioItem>
                                <ContextMenuRadioItem Value=""Modified"">Date modified</ContextMenuRadioItem>
                                <ContextMenuRadioItem Value=""Size"">Size</ContextMenuRadioItem>
                            </ContextMenuRadioGroup>
                            <ContextMenuSeparator />
                            <ContextMenuItem Class=""text-destructive"">
                                <DynamicIcon Name=""Trash2"" Class=""h-4 w-4"" /> Delete
                            </ContextMenuItem>
                        </ContextMenuContent>
                    </ContextMenu>
                </RowTemplate>
            </DataTable>
        </CardContent>
    </Card>

    <!-- Upload Area -->
    <Card>
        <CardContent>
            <FileUpload
                Multiple=""true""
                ShowProgress=""true""
                Progress=""@_uploadProgress""
                Description=""PDF, DOCX, PNG, JPG up to 50MB""
                OnFilesSelected=""HandleFilesSelected"" />
        </CardContent>
    </Card>

</Stack>

@code {
    private record FileItem(string Name, string Type, string Size, string Modified, string Icon);

    private List<FileItem> _files = new() { /* ... 12 file records ... */ };
    private HashSet<FileItem> _selectedFiles = new();
    private string _sortColumn = ""Name"";
    private DataTable<object>.SortDirection _sortDir = DataTable<object>.SortDirection.Ascending;
    private bool _showHidden;
    private int _uploadProgress;

    private void HandleSort((string Column, DataTable<object>.SortDirection Direction) args)
    {
        _sortColumn = args.Column;
        _sortDir = args.Direction;
    }

    private async Task HandleFilesSelected(InputFileChangeEventArgs e)
    {
        for (int i = 0; i <= 100; i += 10)
        {
            _uploadProgress = i;
            StateHasChanged();
            await Task.Delay(150);
        }
    }
}";
}
