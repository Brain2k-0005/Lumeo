@namespace Lumeo

<button class="@CssClass" role="menuitem" data-inset="@(Inset ? "true" : null)" data-variant="@VariantAttr" @onclick="HandleClick" disabled="@Disabled" aria-disabled="@(Disabled ? "true" : null)" @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] public ContextMenu.ContextMenuContext? Context { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public bool Disabled { get; set; }

    /// <summary>
    /// Indents the item by a label's width so it lines up with checkbox/radio
    /// items (shadcn <c>inset</c>). Adds <c>ps-8</c> and emits <c>data-inset</c>.
    /// </summary>
    [Parameter] public bool Inset { get; set; }

    /// <summary>
    /// Visual variant. <see cref="MenuItemVariant.Destructive"/> renders the item
    /// in the destructive color and emits <c>data-variant="destructive"</c>.
    /// </summary>
    [Parameter] public MenuItemVariant Variant { get; set; } = MenuItemVariant.Default;

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string? VariantAttr => Variant == MenuItemVariant.Destructive ? "destructive" : null;

    private const string DestructiveClass = "text-destructive hover:bg-destructive/10 hover:text-destructive focus:bg-destructive/10 focus:text-destructive";

    private string CssClass => Cx.Merge("relative flex w-full cursor-pointer select-none items-center gap-2 rounded-sm px-2 py-1.5 min-h-11 sm:min-h-0 text-sm outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed", Cx.When(Inset, "ps-8"), Cx.When(Variant == MenuItemVariant.Destructive, DestructiveClass), Class);

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();
        if (Context is not null)
        {
            await Context.SetOpen.InvokeAsync(false);
        }
    }
}
