@page "/components/label"

<PageTitle>Label — Lumeo</PageTitle>

<PageHeader Title="Label" Description="A text label for form controls." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Label>Email address</Label>
            <Input Type="email" Placeholder="you@example.com" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Required Field" Code="@_requiredCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Stack Gap="2">
                <Flex Gap="1" Align="center">
                    <Label>Email address</Label>
                    <Lumeo.Text As="span" Size="sm" Color="destructive">*</Lumeo.Text>
                </Flex>
                <Input type="email" placeholder="you@example.com" />
                <Lumeo.Text Size="xs" Color="muted">We'll never share your email with anyone.</Lumeo.Text>
            </Stack>
            <Stack Gap="2">
                <Flex Align="center" Justify="between">
                    <Label>Password</Label>
                    <Lumeo.Link Href="#" Class="text-xs text-primary hover:underline no-underline">Forgot password?</Lumeo.Link>
                </Flex>
                <Input type="password" placeholder="••••••••" />
            </Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Fields" Code="@_multipleCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Stack Gap="2">
                <Label>First name</Label>
                <Input Placeholder="John" />
            </Stack>
            <Stack Gap="2">
                <Label>Last name</Label>
                <Input Placeholder="Doe" />
            </Stack>
            <Flex Gap="2" Align="center">
                <Checkbox @bind-Checked="_agreed" />
                <Label>I agree to the terms and conditions</Label>
            </Flex>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">Label</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ChildContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The label text content.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">For</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">The id of the form element the label is associated with.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes for the label element.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private bool _agreed;

    private string _defaultCode = @"<Label>Email address</Label>
<Input Type=""email"" Placeholder=""you@example.com"" />";

    private string _requiredCode = @"<Stack Gap=""2"">
    <Flex Gap=""1"" Align=""center"">
        <Label>Email address</Label>
        <Lumeo.Text As=""span"" Size=""sm"" Color=""destructive"">*</Lumeo.Text>
    </Flex>
    <Input type=""email"" placeholder=""you@example.com"" />
    <Lumeo.Text Size=""xs"" Color=""muted"">We'll never share your email.</Lumeo.Text>
</Stack>
<Stack Gap=""2"">
    <Flex Align=""center"" Justify=""between"">
        <Label>Password</Label>
        <a href=""#"" class=""text-xs text-primary hover:underline"">Forgot password?</a>
    </Flex>
    <Input type=""password"" placeholder=""••••••••"" />
</Stack>";

    private string _multipleCode = @"<Stack Gap=""2"">
    <Label>First name</Label>
    <Input Placeholder=""John"" />
</Stack>
<Flex Gap=""2"" Align=""center"">
    <Checkbox @bind-Checked=""_agreed"" />
    <Label>I agree to the terms and conditions</Label>
</Flex>";
}
