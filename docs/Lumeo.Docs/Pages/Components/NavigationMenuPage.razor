@page "/components/navigation-menu"

<PageTitle>Navigation Menu — Lumeo</PageTitle>

<PageHeader Title="Navigation Menu" Description="A collection of links for navigating websites, with support for flyout content panels." />

<InstallUsage Component="NavigationMenu" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Site-wide navigation in headers with links and flyout panels</li>
        <li>Header navigation bars with grouped link categories</li>
        <li>Mega menus displaying rich content like descriptions, badges, and icons</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <NavigationMenu>
            <NavigationMenuList>
                <NavigationMenuItem>
                    <NavigationMenuTrigger>Getting Started</NavigationMenuTrigger>
                    <NavigationMenuContent>
                        <Grid Class="gap-3 w-[400px] md:w-[500px] md:grid-cols-2">
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Introduction</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Learn the basics of building with Lumeo components.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Installation</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Add Lumeo to your Blazor project in minutes.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Typography</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Styles for headings, paragraphs, lists, and more.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Theming</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Customize colors, fonts, and spacing to match your brand.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                        </Grid>
                    </NavigationMenuContent>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuTrigger>Components</NavigationMenuTrigger>
                    <NavigationMenuContent>
                        <Grid Class="gap-3 w-[400px] md:w-[500px] md:grid-cols-2">
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Button</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Trigger actions or navigation events.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Card</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Group related content in a flexible container.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Dialog</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Display modal content that requires attention.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Table</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Display data in a structured tabular format.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                        </Grid>
                    </NavigationMenuContent>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium">
                        Documentation
                    </NavigationMenuLink>
                </NavigationMenuItem>
            </NavigationMenuList>
        </NavigationMenu>
    </ComponentDemo>
    <ComponentDemo Title="Simple Links" Code="@_linksCode">
        <NavigationMenu>
            <NavigationMenuList>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors">
                        Home
                    </NavigationMenuLink>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors">
                        About
                    </NavigationMenuLink>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors">
                        Blog
                    </NavigationMenuLink>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent hover:text-accent-foreground transition-colors">
                        Contact
                    </NavigationMenuLink>
                </NavigationMenuItem>
            </NavigationMenuList>
        </NavigationMenu>
    </ComponentDemo>

    <ComponentDemo Title="Active link (aria-current)">
        <NavigationMenu>
            <NavigationMenuList>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" IsActive="true" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                        Home
                    </NavigationMenuLink>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                        About
                    </NavigationMenuLink>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                        Contact
                    </NavigationMenuLink>
                </NavigationMenuItem>
            </NavigationMenuList>
        </NavigationMenu>
    </ComponentDemo>

    <ComponentDemo Title="Mobile menu (Hamburger + Sheet)">
        <div class="relative">
            <NavigationMenuHamburger @bind-Open="_mobileOpen" Class="!flex" />
            <NavigationMenuMobile @bind-Open="_mobileOpen">
                <NavigationMenuLink Href="#" Class="rounded-md p-2 text-sm font-medium hover:bg-accent">Home</NavigationMenuLink>
                <NavigationMenuLink Href="#" Class="rounded-md p-2 text-sm font-medium hover:bg-accent">Products</NavigationMenuLink>
                <NavigationMenuLink Href="#" Class="rounded-md p-2 text-sm font-medium hover:bg-accent">Pricing</NavigationMenuLink>
                <NavigationMenuLink Href="#" Class="rounded-md p-2 text-sm font-medium hover:bg-accent">Contact</NavigationMenuLink>
            </NavigationMenuMobile>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="With Badge" Code="@_badgeCode">
        <NavigationMenu>
            <NavigationMenuList>
                <NavigationMenuItem>
                    <NavigationMenuTrigger>Products</NavigationMenuTrigger>
                    <NavigationMenuContent>
                        <Grid Class="gap-3 w-[360px] p-2">
                            <NavigationMenuLink Href="#">
                                <Flex Align="center" Gap="2">
                                    <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Analytics</Lumeo.Text>
                                    <Badge>New</Badge>
                                </Flex>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Real-time data insights and dashboards.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Integrations</Lumeo.Text>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Connect with 200+ tools and services.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                            <NavigationMenuLink Href="#">
                                <Flex Align="center" Gap="2">
                                    <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">API</Lumeo.Text>
                                    <Badge Variant="Badge.BadgeVariant.Secondary">Beta</Badge>
                                </Flex>
                                <Lumeo.Text Size="sm" Color="muted" Class="line-clamp-2 leading-snug mt-1">
                                    Programmatic access to all platform features.
                                </Lumeo.Text>
                            </NavigationMenuLink>
                        </Grid>
                    </NavigationMenuContent>
                </NavigationMenuItem>
                <NavigationMenuItem>
                    <NavigationMenuLink Href="#" Class="group inline-flex h-9 w-max items-center justify-center rounded-md bg-background px-4 py-2 text-sm font-medium hover:bg-accent transition-colors">
                        Pricing
                    </NavigationMenuLink>
                </NavigationMenuItem>
            </NavigationMenuList>
        </NavigationMenu>
    </ComponentDemo>

    <ComponentDemo Title="Controlled (open a panel programmatically)" Code="@_controlledCode" Description="Bind Value (matching each NavigationMenuItem's Value) to drive which panel is open from outside. DelayDuration tunes the hover-forgiveness window in milliseconds; DefaultValue opens one panel on first render in uncontrolled mode.">
        <Stack Gap="3">
            <Flex Gap="2">
                <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="@(() => _navValue = "products")">Open Products</Button>
                <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="@(() => _navValue = "resources")">Open Resources</Button>
                <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Ghost" OnClick="@(() => _navValue = null)">Close</Button>
            </Flex>
            <NavigationMenu @bind-Value="_navValue" DelayDuration="100">
                <NavigationMenuList>
                    <NavigationMenuItem Value="products">
                        <NavigationMenuTrigger>Products</NavigationMenuTrigger>
                        <NavigationMenuContent>
                            <Grid Class="gap-3 w-[360px] p-2">
                                <NavigationMenuLink Href="#">
                                    <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Analytics</Lumeo.Text>
                                    <Lumeo.Text Size="sm" Color="muted" Class="leading-snug mt-1">Real-time dashboards and insights.</Lumeo.Text>
                                </NavigationMenuLink>
                            </Grid>
                        </NavigationMenuContent>
                    </NavigationMenuItem>
                    <NavigationMenuItem Value="resources">
                        <NavigationMenuTrigger>Resources</NavigationMenuTrigger>
                        <NavigationMenuContent>
                            <Grid Class="gap-3 w-[360px] p-2">
                                <NavigationMenuLink Href="#">
                                    <Lumeo.Text Size="sm" Weight="medium" Class="leading-none">Documentation</Lumeo.Text>
                                    <Lumeo.Text Size="sm" Color="muted" Class="leading-snug mt-1">Guides and full API reference.</Lumeo.Text>
                                </NavigationMenuLink>
                            </Grid>
                        </NavigationMenuContent>
                    </NavigationMenuItem>
                </NavigationMenuList>
            </NavigationMenu>
            <Lumeo.Text Size="sm" Color="muted">Open panel: @(_navValue ?? "none")</Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="navigationmenu" Level="3" Class="mt-8 scroll-mt-20">NavigationMenu</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" />
    </div>

    <Heading Id="navigationmenulist" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuList</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuList" />
    </div>

    <Heading Id="navigationmenuitem" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuItem</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuItem" />
    </div>

    <Heading Id="navigationmenutrigger" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuTrigger</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuTrigger" />
    </div>

    <Heading Id="navigationmenucontent" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuContent</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuContent" />
    </div>

    <Heading Id="navigationmenulink" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuLink</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuLink" />
    </div>

    <Heading Id="navigationmenuhamburger" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuHamburger</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuHamburger" />
    </div>

    <Heading Id="navigationmenumobile" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuMobile</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuMobile" />
    </div>

    <Heading Id="navigationmenuindicator" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuIndicator</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuIndicator" />
    </div>

    <Heading Id="navigationmenuviewport" Level="3" Class="mt-8 scroll-mt-20">NavigationMenuViewport</Heading>
    <div class="mt-4">
        <PropsTable Slug="navigation-menu" SubComponent="NavigationMenuViewport" />
    </div>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/menubar" class="text-primary hover:underline">Menubar</a> — For desktop-style application menu bars with keyboard shortcuts</li>
        <li><a href="/components/sidebar" class="text-primary hover:underline">Sidebar</a> — For vertical side navigation with collapsible sections</li>
        <li><a href="/components/breadcrumb" class="text-primary hover:underline">Breadcrumb</a> — For displaying the current page path within a navigation hierarchy</li>
    </ul>
</div>

