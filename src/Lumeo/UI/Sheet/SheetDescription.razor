@namespace Lumeo
@implements IDisposable

<p id="@Context.DescriptionId" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</p>

@code {
    [CascadingParameter] public Sheet.SheetContext Context { get; set; } = default!;
    /// <summary>The description text, exposed to assistive tech via <c>aria-describedby</c> on the panel once this component registers with the sheet.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the description <c>&lt;p&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures any unmatched attributes and applies them to the description <c>&lt;p&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("text-sm text-muted-foreground", Class);

    protected override void OnInitialized()
        // Signal the root so SheetContent wires aria-describedby to this <p>'s
        // id — without a registered description the IDREF would dangle.
        => Context.RegisterDescription();

    // Un-registers on removal — without this, removing the description while the
    // sheet stays mounted left aria-describedby pointing at an id no longer in the
    // DOM (Codex P2).
    public void Dispose() => Context.UnregisterDescription();
}
