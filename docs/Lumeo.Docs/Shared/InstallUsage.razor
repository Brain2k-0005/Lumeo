@namespace Lumeo.Docs.Shared

@* Per-component quick start: install the single Lumeo package, then import and
   drop the component in. Full app setup (AddLumeo, CSS & JS) lives in the
   installation guide and is linked rather than repeated on every page. *@
<div class="mt-8 space-y-6">
    <div class="space-y-3">
        <Heading Id="installation" Level="2" Size="xl" Class="scroll-mt-20">Installation</Heading>
        <Tabs ActiveValue="cli">
            <TabsList>
                <TabsTrigger Value="cli">.NET CLI</TabsTrigger>
                <TabsTrigger Value="pkg">PackageReference</TabsTrigger>
            </TabsList>
            <TabsContent Value="cli">
                <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_cli</pre>
            </TabsContent>
            <TabsContent Value="pkg">
                <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_pkg</pre>
            </TabsContent>
        </Tabs>
        <Lumeo.Text Size="sm" Color="muted">
            One-time app setup (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">AddLumeo()</code>, CSS &amp; JS) is covered in the
            <Lumeo.Link Href="docs/introduction">installation guide</Lumeo.Link>.
        </Lumeo.Text>
    </div>

    <div class="space-y-3">
        <Heading Id="usage" Level="2" Size="xl" Class="scroll-mt-20">Usage</Heading>
        <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_usage</pre>
    </div>
</div>

@code {
    /// <summary>The component's tag name, e.g. "Button" or "AlertDialog".</summary>
    [Parameter] public string Component { get; set; } = "";

    /// <summary>NuGet package the component ships in (satellites: Lumeo.Charts, etc.).</summary>
    [Parameter] public string Package { get; set; } = "Lumeo";

    /// <summary>Optional custom usage snippet; defaults to the import plus the tag.</summary>
    [Parameter] public string? Usage { get; set; }

    private const string _version = "3.6.1";
    private string _cli => $"dotnet add package {Package}";
    private string _pkg => $"<PackageReference Include=\"{Package}\" Version=\"{_version}\" />";
    private string _usage => Usage ?? $"@using Lumeo\n\n<{Component} />";
}
