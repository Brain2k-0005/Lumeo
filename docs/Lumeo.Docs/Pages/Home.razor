@code {
    private bool _switchOn = true;
    private double _sliderVal = 62;
    private bool _togglePressed;
    private bool _checkOn = true;
    private bool _installCopied;
    private bool _terminalCopied;
    private bool _showDialog;
    private DateOnly? _selectedDate = DateOnly.FromDateTime(DateTime.Today);

    private record FeatureItem(string Icon, string Title, string Body);
    private record BlockItem(string Title, string Description, string Icon, string Href);

    private readonly FeatureItem[] _features =
    {
        new("Palette", "Tailwind CSS v4", "Built on CSS custom properties. Theme with variables, not config files. Full v4 API."),
        new("Accessibility", "Accessible by default", "ARIA, keyboard navigation, and focus management built in. WCAG AA across the library."),
        new("Moon", "Dark mode", "Automatic dark mode via CSS variable swaps. No dark: prefixes. Instant theme switching."),
        new("Copy", "Copy & paste", "Every component ships with inline code examples. Copy into your project and done."),
        new("ChartBar", "ECharts integration", "30+ chart components powered by Apache ECharts. AOT-friendly and fully themeable."),
        new("Package", "Single NuGet package", "One install. No peer dependencies. Works with Blazor WASM and Server, .NET 10+."),
        new("Zap", "AI primitives", "Streaming messages, tool calls, markdown rendering — drop-in building blocks for AI chat UIs."),
        new("Globe", "14 locales", "Bundled translations for 14 languages plus ILumeoLocalizer for per-string overrides."),
        new("MousePointerClick", "Motion", "Built-in animation primitives — BlurFade, BorderBeam, and more — with zero JS config."),
        new("List", "RTL support", "Every component renders correctly in right-to-left locales out of the box."),
        new("Code", "Source generator", "Compile-time helpers for theme registration, registries, and zero-reflection setup."),
        new("Blocks", "Register your own", "Extend the component registry with your own components and keep the same API surface.")
    };

    private readonly BlockItem[] _blocks =
    {
        new("Dashboard", "Stats, charts, and activity feed", "LayoutDashboard", "blocks/dashboard-block"),
        new("Sign In", "Email + OAuth authentication", "LogIn", "blocks/sign-in"),
        new("Sign Up", "New account registration", "UserPlus", "blocks/sign-up"),
        new("Pricing", "Three-tier pricing table", "Tag", "blocks/pricing"),
        new("Hero Section", "Centered marketing hero", "LayoutTemplate", "blocks/hero"),
        new("Reset Password", "Forgot-password flow", "Lock", "blocks/reset-password"),
        new("OTP Verify", "6-digit verification input", "ShieldCheck", "blocks/otp-verify"),
        new("Settings Page", "Account and preferences", "Settings", "blocks/settings-page")
    };

    private async Task CopyInstall() => await CopyAndFlash("dotnet add package Lumeo", v => _installCopied = v);
    private async Task CopyTerminal() => await CopyAndFlash(
        "dotnet add package Lumeo\nbuilder.Services.AddLumeo();\n@using Lumeo",
        v => _terminalCopied = v);

    private async Task CopyAndFlash(string text, Action<bool> setFlag)
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", text); } catch (JSException) { /* clipboard may be unavailable */ }
        setFlag(true);
        StateHasChanged();
        await Task.Delay(2000);
        setFlag(false);
        StateHasChanged();
    }
}

@inject IJSRuntime JS
