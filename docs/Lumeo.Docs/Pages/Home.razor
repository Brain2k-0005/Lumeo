    private async Task CopyInstall()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", "dotnet add package Lumeo"); }
        catch (JSException) { }
        _installCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _installCopied = false;
        StateHasChanged();
    }

    // Kanban drag-and-drop: each card sets _draggingCard on dragstart; each column's
    // OnDrop calls MoveDraggingCard(targetList) to remove from its current list and
    // append to the dropped-into list. KanbanColumn already preventDefaults dragover.
    private void MoveDraggingCard(List<KanbanItem> target)
    {
        if (_draggingCard is null) return;
        if (_kanbanTodo.Remove(_draggingCard) || _kanbanDoing.Remove(_draggingCard) || _kanbanDone.Remove(_draggingCard))
        {
            if (!target.Contains(_draggingCard))
            {
                target.Add(_draggingCard);
            }
        }
        _draggingCard = null;
        StateHasChanged();
    }

    // Auto-cycling DropdownMenu submenu showcase — opens for ~2.5s, closes for ~2s,
    // repeats. Pauses while the user hovers the tile so manual interaction wins.
    private bool _dropdownAutoOpen;
    private bool _dropdownHovered;
    private System.Threading.Timer? _dropdownTimer;

    protected override void OnInitialized()
    {
        // First tick after 1.5s so the page settles, then alternate open/closed.
        _dropdownTimer = new System.Threading.Timer(_ =>
        {
            if (_dropdownHovered) return; // user is interacting — don't fight them
            _dropdownAutoOpen = !_dropdownAutoOpen;
            var nextDelay = _dropdownAutoOpen ? 2500 : 2000;
            _dropdownTimer?.Change(nextDelay, System.Threading.Timeout.Infinite);
            InvokeAsync(StateHasChanged);
        }, null, 1500, System.Threading.Timeout.Infinite);
    }

    public void Dispose()
    {
        _dropdownTimer?.Dispose();
        _dropdownTimer = null;
    }
}

