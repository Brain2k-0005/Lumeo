@namespace Lumeo
@implements IAsyncDisposable
@implements IOverlayExitCallback

@if (_exit.Present(Context.IsOpen))
{
    <div id="@_contentId" data-state="@(Context.IsOpen ? "open" : "closed")" class="@CssClass" inert="@ExitInert" @onmouseenter="HandleMouseEnter" @onmouseleave="HandleMouseLeave" @attributes="AdditionalAttributes">
        @ChildContent
        @if (ShowArrow)
        {
            <div class="@ArrowClasses"></div>
        }
    </div>
}

@inject IComponentInteropService Interop

@code {
    [CascadingParameter] public HoverCard.HoverCardContext Context { get; set; } = default!;
    /// <summary>The card's content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Alignment of the card along the trigger's edge. Default <see cref="Lumeo.Align.Center"/>.</summary>
    [Parameter] public Lumeo.Align Align { get; set; } = Lumeo.Align.Center;

    /// <summary>Which side of the trigger the card is anchored to. Default <see cref="Lumeo.Side.Bottom"/>.</summary>
    [Parameter] public Lumeo.Side Side { get; set; } = Lumeo.Side.Bottom;

    /// <summary>Renders a small pointer triangle on the edge facing the trigger. Default <c>false</c>.</summary>
    [Parameter] public bool ShowArrow { get; set; }

    /// <summary>Additional CSS classes merged onto the card's root element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the card's root element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _contentId = LumeoIds.New("hovercard-content");
    // battle-wave2 #80 (state-on-data-change) — track the last anchor we actually
    // positioned against instead of a one-shot bool. A Side/Align change while the
    // card is OPEN must re-run PositionFixed; the old `_positioned` latch pinned the
    // card to its first-open placement forever. null == not currently positioned.
    private (string Side, string Align)? _appliedAnchor;

    // B11 exit latch (shared infra). Enter keeps fade-in; exit uses zoom-out to
    // match shadcn/Radix hover-card's data-[state=closed]:zoom-out-95 + fade-out.
    private readonly OverlayExitAnimator _exit = new();
    private DotNetObjectReference<HoverCardContent>? _selfRef;
    private const int ExitDurationMs = 250;

    // pointer-events-none during the exit window makes the fading card inert so a
    // mouseenter on it can't cancel/reopen the close while it animates out (P2).
    private string AnimationClass => _exit.Exiting ? "animate-zoom-out pointer-events-none" : "animate-fade-in";

    // `inert` (exit window only) also drops any focusable content (links/buttons a
    // consumer put in the card) from the tab order so keyboard users can't Tab into the
    // closing card (round-2 P2).
    private string? ExitInert => _exit.Exiting ? "true" : null;

    // Gate the hover-open/close handlers so an EXITING card never schedules an open
    // or close: even if a stray mouseenter/leave reaches the fading surface (before
    // pointer-events-none takes hold, or in a non-CSS host), it is ignored rather
    // than resurrecting the card mid-exit (Codex/CodeRabbit P2).
    private Task HandleMouseEnter() => _exit.Exiting ? Task.CompletedTask : Context.RequestOpen.InvokeAsync();
    private Task HandleMouseLeave() => _exit.Exiting ? Task.CompletedTask : Context.RequestClose.InvokeAsync();

    private string CssClass => Cx.Merge(
        "fixed z-50 w-64 rounded-md border border-border/60 bg-popover p-4 text-popover-foreground shadow-lg outline-none",
        ShowArrow ? "overflow-visible" : "",
        AnimationClass,
        Class);

    private string ArrowClasses => Side switch
    {
        Lumeo.Side.Top => "absolute left-1/2 top-full -translate-x-1/2 -translate-y-1/2 rotate-45 h-2.5 w-2.5 bg-popover border-b border-r border-border/60",
        Lumeo.Side.Bottom => "absolute left-1/2 bottom-full -translate-x-1/2 translate-y-1/2 rotate-45 h-2.5 w-2.5 bg-popover border-t border-l border-border/60",
        Lumeo.Side.Left => "absolute top-1/2 left-full -translate-y-1/2 -translate-x-1/2 rotate-45 h-2.5 w-2.5 bg-popover border-t border-r border-border/60",
        Lumeo.Side.Right => "absolute top-1/2 right-full -translate-y-1/2 translate-x-1/2 rotate-45 h-2.5 w-2.5 bg-popover border-b border-l border-border/60",
        _ => "absolute left-1/2 bottom-full -translate-x-1/2 translate-y-1/2 rotate-45 h-2.5 w-2.5 bg-popover border-t border-l border-border/60"
    };

    private string AlignStr => Align switch
    {
        Lumeo.Align.Start => "start",
        Lumeo.Align.Center => "center",
        Lumeo.Align.End => "end",
        _ => "center"
    };

    private string SideStr => Side switch
    {
        Lumeo.Side.Top => "top",
        Lumeo.Side.Bottom => "bottom",
        Lumeo.Side.Left => "left",
        Lumeo.Side.Right => "right",
        _ => "bottom"
    };

    protected override void OnParametersSet()
        => _exit.OnParameters(Context.IsOpen, ExitDurationMs, () => InvokeAsync(FinishExit));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Context.IsOpen)
        {
            // Re-position whenever the anchor (Side/Align) differs from what we last
            // applied — covers both the first open AND a Side/Align change while the
            // card stays open. Equality on the tuple keeps a same-anchor re-render
            // from churning the floating-ui placement.
            var anchor = (SideStr, AlignStr);
            if (_appliedAnchor != anchor)
            {
                await Interop.PositionFixed(_contentId, Context.WrapperId, AlignStr, false, SideStr);
                _appliedAnchor = anchor;
            }
        }
        else if (_appliedAnchor is not null)
        {
            // Unposition immediately on close: stops the reposition rAF and leaves the
            // inline top/left so the box freezes in place while the zoom-out plays.
            // The element stays mounted for the exit via the _exit.Present gate.
            try { await Interop.UnpositionFixed(_contentId); } catch (JSDisconnectedException) { }
            _appliedAnchor = null;
        }

        await _exit.WireExitAsync(async () =>
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            try { await Interop.AttachOverlayExitEnd(_contentId, _selfRef); }
            catch (JSDisconnectedException) { }
        });
    }

    [JSInvokable]
    public Task OnExitAnimationEnd() => InvokeAsync(FinishExit);

    private void FinishExit()
    {
        if (_exit.Finish()) StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        _exit.Dispose();
        _selfRef?.Dispose();
        if (_appliedAnchor is not null)
        {
            try { await Interop.UnpositionFixed(_contentId); } catch (JSDisconnectedException) { }
            _appliedAnchor = null;
        }
    }

}
