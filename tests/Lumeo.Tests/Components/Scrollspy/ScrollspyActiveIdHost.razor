@namespace Lumeo.Tests.Components.Scrollspy

@* Test host for #246 — drives Scrollspy.ActiveId through a real parameter so a
   re-render exercises the two-way control input (external set scrolls). *@
<Lumeo.Scrollspy Offset="50" ActiveId="@ActiveId" ActiveIdChanged="OnActiveIdChanged">
    <Lumeo.ScrollspyLink Target="target">Target</Lumeo.ScrollspyLink>
    <Lumeo.ScrollspySection Id="target">Target body</Lumeo.ScrollspySection>
</Lumeo.Scrollspy>

@code {
    [Parameter] public string? ActiveId { get; set; }

    private void OnActiveIdChanged(string value) => ActiveId = value;
}
