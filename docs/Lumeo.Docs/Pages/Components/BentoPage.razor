@page "/components/bento"

<PageTitle>Bento — Lumeo</PageTitle>

<PageHeader Title="Bento" Description="CSS-grid dashboard layout with shorthand tiles for composing analytics and overview pages." />

<InstallUsage Component="Bento" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Compose dashboards from a grid of mixed-size KPI, chart, and list tiles</li>
        <li>Build marketing "bento" feature grids (shadcn-style block showcases)</li>
        <li>Mix tall cards, wide cards, and small tiles in a single responsive grid</li>
        <li>Anywhere you would reach for Tremor's Grid + Card shorthand</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic 4-column bento" Code="@_basicCode">
        <Bento Columns="4" Gap="Bento.BentoGap.Md">
            <BentoTile Span="2" Title="Revenue" Description="Last 30 days">
                <div class="text-3xl font-semibold text-foreground">$48,290</div>
            </BentoTile>
            <BentoTile Title="New users">
                <div class="text-2xl font-semibold text-foreground">1,204</div>
            </BentoTile>
            <BentoTile Title="Churn">
                <div class="text-2xl font-semibold text-foreground">2.1%</div>
            </BentoTile>
            <BentoTile Span="2" RowSpan="1" Title="Latest activity" Description="Feed">
                <div class="text-sm text-muted-foreground">No events in the last hour.</div>
            </BentoTile>
            <BentoTile Title="Sessions">
                <div class="text-2xl font-semibold text-foreground">8,492</div>
            </BentoTile>
            <BentoTile Title="Avg. duration">
                <div class="text-2xl font-semibold text-foreground">4m 12s</div>
            </BentoTile>
        </Bento>
    </ComponentDemo>

    <ComponentDemo Title="Gap (interactive)" Code="@_gapInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch gap to see spacing between tiles change.</Lumeo.Text>
            <Segmented @bind-Value="_bentoGap">
                <SegmentedItem Value="Sm">Sm</SegmentedItem>
                <SegmentedItem Value="Md">Md</SegmentedItem>
                <SegmentedItem Value="Lg">Lg</SegmentedItem>
            </Segmented>
            <Bento Columns="4" Gap="@_bentoGapEnum">
                <BentoTile Title="Revenue"><div class="text-2xl font-semibold text-foreground">$48,290</div></BentoTile>
                <BentoTile Title="Users"><div class="text-2xl font-semibold text-foreground">12,402</div></BentoTile>
                <BentoTile Title="Sessions"><div class="text-2xl font-semibold text-foreground">8,492</div></BentoTile>
                <BentoTile Title="Churn"><div class="text-2xl font-semibold text-foreground">2.1%</div></BentoTile>
            </Bento>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom header & footer slots">
        <Bento Columns="3" Gap="Bento.BentoGap.Md">
            <BentoTile RowSpan="2">
                <HeaderContent>
                    <Flex Align="center" Gap="2">
                        <DynamicIcon Name="TrendingUp" Class="h-4 w-4 text-primary" />
                        <span class="text-sm font-medium text-foreground">Revenue</span>
                    </Flex>
                </HeaderContent>
                <ChildContent>
                    <div class="text-3xl font-semibold text-foreground">$48,290</div>
                    <div class="text-xs text-muted-foreground">Last 30 days</div>
                </ChildContent>
                <FooterContent>
                    <span class="text-xs text-muted-foreground">Updated 2 min ago</span>
                </FooterContent>
            </BentoTile>
            <BentoTile Title="Users"><div class="text-2xl font-semibold text-foreground">12,402</div></BentoTile>
            <BentoTile Title="Sessions"><div class="text-2xl font-semibold text-foreground">8,492</div></BentoTile>
            <BentoTile Title="Churn"><div class="text-2xl font-semibold text-foreground">2.1%</div></BentoTile>
            <BentoTile Title="MRR"><div class="text-2xl font-semibold text-foreground">$9,820</div></BentoTile>
        </Bento>
    </ComponentDemo>

    <ComponentDemo Title="Dashboard — KPI row + spark + wide tile" Code="@_dashboardCode">
        <Stack Gap="4">
            <Bento Columns="3" Gap="Bento.BentoGap.Md">
                <KpiCard Label="Revenue" Value="$48,290" Delta="12.3" />
                <KpiCard Label="Active users" Value="12,402" Delta="4.8" />
                <KpiCard Label="MRR" Value="$9,820" Delta="-1.2" DeltaPositive="KpiCard.KpiDeltaDirection.Good" />
            </Bento>
            <Bento Columns="3" Gap="Bento.BentoGap.Md">
                <SparkCard Label="Page views" Value="184k" Data="@_sparkA" />
                <SparkCard Label="Signups" Value="421" Data="@_sparkB" />
                <BentoTile Title="Traffic" Description="Last 7 days">
                    <div class="flex h-24 items-center justify-center rounded-md border border-dashed border-border/60 text-xs text-muted-foreground">
                        Chart placeholder
                    </div>
                </BentoTile>
            </Bento>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Bento</Heading>
            <PropsTable Slug="bento" />
            <Lumeo.Text Size="sm" Color="muted" Class="mt-2"><code>Gap</code> values: Sm = 0.75rem, Md = 1rem, Lg = 1.5rem.</Lumeo.Text>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">BentoTile</Heading>
            <PropsTable Slug="bento" SubComponent="BentoTile" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">KpiCard</Heading>
            <PropsTable Slug="kpi-card" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">SparkCard</Heading>
            <PropsTable Slug="spark-card" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">Delta</Heading>
            <PropsTable Slug="delta" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/dashboard-tiles" class="text-primary hover:underline">Dashboard Tiles</a> — KpiCard, SparkCard, and Delta examples</li>
        <li><a href="/components/grid" class="text-primary hover:underline">Grid</a> — Lower-level CSS grid primitive</li>
        <li><a href="/components/card" class="text-primary hover:underline">Card</a> — Base container with header/content/footer</li>
    </ul>
</div>

