@namespace Lumeo.Docs.Layout

@* Docs sidebar shows the full nav (docs + components + patterns groups) so users
   browsing a guide can still find any component without navigating away. The
   group containing the current URL auto-expands; everything else is collapsed. *@
<NavMenu Collapsible="true" IsMobile="@IsMobile" />

@code {
    [Parameter] public bool IsMobile { get; set; }
}
