@namespace Lumeo
@implements IAsyncDisposable

<div class="@ContainerClass" @attributes="AdditionalAttributes" id="@(Zoomable ? _zoomContainerId : null)">
    @if (!_hasError)
    {
        <img src="@Src" alt="@Alt"
             width="@Width" height="@Height"
             loading="@(Lazy ? "lazy" : null)"
             class="@ImageClass"
             style="@ZoomStyle"
             @onclick="HandleClick"
             @onerror="HandleError" />
    }
    else if (Fallback is not null)
    {
        <img src="@Fallback" alt="@Alt"
             width="@Width" height="@Height"
             class="@ImageClass" />
    }
    else
    {
        <div class="@FallbackClass" style="@FallbackStyle">
            <SvgGlyph Svg="@(LumeoIcons.ImageOff)" class="h-8 w-8 text-muted-foreground" />
        </div>
    }

    @if (Preview)
    {
        <button type="button" aria-label="@PreviewLabel"
                class="absolute inset-0 flex items-center justify-center bg-black/0 hover:bg-black/20 focus-visible:bg-black/20 transition-colors cursor-pointer opacity-0 hover:opacity-100 focus-visible:opacity-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-white"
                @onclick="HandleClick">
            <SvgGlyph Svg="@(LumeoIcons.ZoomIn)" class="h-6 w-6 text-white drop-shadow-lg" aria-hidden="true" />
        </button>
    }
</div>

@if (_showPreview && Preview)
{
    <div class="fixed inset-0 z-50 bg-black/80 flex items-center justify-center animate-fade-in" role="dialog" aria-modal="true" aria-label="Image preview" @onclick="ClosePreview" @onkeydown="HandlePreviewKeyDown" tabindex="-1" id="@_previewId">
        <button type="button" aria-label="Close preview" class="absolute top-4 end-4 text-white/80 hover:text-white transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/80 rounded" @onclick="ClosePreview">
            <SvgGlyph Svg="@(LumeoIcons.X)" class="h-6 w-6" />
        </button>

        <div class="flex items-center gap-2 absolute bottom-4 left-1/2 -translate-x-1/2">
            <button type="button" aria-label="Zoom out" class="text-white/80 hover:text-white p-1.5 rounded-md bg-white/10 hover:bg-white/20 transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/80" @onclick="ZoomOut" @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.ZoomOut)" class="h-5 w-5" aria-hidden="true" />
            </button>
            <span class="text-white/80 text-sm min-w-[3rem] text-center" aria-live="polite" aria-label="@($"Zoom {_zoom} percent")">@($"{_zoom}%")</span>
            <button type="button" aria-label="Zoom in" class="text-white/80 hover:text-white p-1.5 rounded-md bg-white/10 hover:bg-white/20 transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-black/80" @onclick="ZoomIn" @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.ZoomIn)" class="h-5 w-5" aria-hidden="true" />
            </button>
        </div>

        <img src="@Src" alt="@Alt" class="max-h-[85vh] max-w-[90vw] object-contain transition-transform" style="@($"transform: scale({(_zoom / 100.0).ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)})")" @onclick:stopPropagation="true" />
    </div>
}

@inject IComponentInteropService Interop

@code {
    /// <summary>The image URL. When it fails to load, <see cref="Fallback"/> (or the
    /// built-in broken-image placeholder) is shown instead.</summary>
    [Parameter] public string? Src { get; set; }
    /// <summary>Alt text for the image, also used to build the preview trigger's
    /// accessible name.</summary>
    [Parameter] public string? Alt { get; set; }
    /// <summary>Width in pixels applied as the <c>&lt;img&gt;</c> <c>width</c> attribute.
    /// When both this and <see cref="Height"/> are unset, the image fills its parent.</summary>
    [Parameter] public string? Width { get; set; }
    /// <summary>Height in pixels applied as the <c>&lt;img&gt;</c> <c>height</c> attribute.
    /// When both this and <see cref="Width"/> are unset, the image fills its parent.</summary>
    [Parameter] public string? Height { get; set; }
    /// <summary>Sets <c>loading="lazy"</c> on the <c>&lt;img&gt;</c> so the browser defers
    /// loading until the image nears the viewport.</summary>
    [Parameter] public bool Lazy { get; set; }
    /// <summary>URL swapped in when <see cref="Src"/> fails to load. When null, a
    /// muted placeholder with a broken-image icon is shown instead.</summary>
    [Parameter] public string? Fallback { get; set; }
    /// <summary>Enables a click-to-zoom overlay: a hover/focus trigger opens the image
    /// fullscreen with zoom in/out controls and Escape-to-close.</summary>
    [Parameter] public bool Preview { get; set; }
    /// <summary>
    /// When true, registers a two-finger pinch-zoom gesture on the image container
    /// so touch users can zoom in/out on the image directly (independent of the
    /// fullscreen <see cref="Preview"/> overlay). Sets <c>touch-action: none</c>
    /// on the wrapper so the browser doesn't intercept the gesture for native page zoom.
    /// </summary>
    [Parameter] public bool Zoomable { get; set; } = false;
    /// <summary>Additional CSS classes merged onto the root <c>div</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _hasError;
    private bool _showPreview;
    private int _zoom = 100;
    private readonly string _previewId = LumeoIds.New("image-preview");

    // Pinch-zoom state (only used when Zoomable=true).
    private readonly string _zoomContainerId = LumeoIds.New("image-zoom");
    private bool _pinchRegistered;
    private double _zoomScale = 1.0;
    private const double MinZoomScale = 0.5;
    private const double MaxZoomScale = 5.0;
    private string? ZoomStyle => Zoomable && Math.Abs(_zoomScale - 1.0) > 0.0001
        ? $"transform: scale({_zoomScale.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}); transform-origin: center center;"
        : null;

    // Accessible name for the keyboard-reachable preview trigger button.
    private string PreviewLabel => string.IsNullOrWhiteSpace(Alt) ? "Open image preview" : $"Open preview: {Alt}";

    private string ContainerClass => Cx.Merge("relative inline-block overflow-hidden", Class);
    // When the consumer sized the wrapper via Class (e.g. "h-14 w-auto") but
    // didn't pass explicit Width / Height params, the <img> had no size
    // hints and collapsed to its natural dimensions inside an
    // inline-block parent — net visual: empty container. Default the
    // image to fill its parent in that case; explicit Width/Height still
    // win because they become attributes on the <img> directly.
    private string ImageClass => Cx.Join(
        "object-cover",
        Cx.When(Width is null && Height is null, "h-full w-full"),
        Cx.When(Preview, "cursor-pointer"));
    private string FallbackClass => "flex items-center justify-center bg-muted rounded-md";
    private string FallbackStyle
    {
        get
        {
            var w = Width is not null ? $"width:{Width}px;" : "width:100%;";
            var h = Height is not null ? $"height:{Height}px;" : "height:8rem;";
            return w + h;
        }
    }

    // Reset the error latch when the source genuinely changes so a new, valid
    // Src is given a fresh chance to load instead of staying hidden behind the
    // fallback because a *previous* Src had errored.
    private string? _lastSrc;
    protected override void OnParametersSet()
    {
        if (Src != _lastSrc)
        {
            _lastSrc = Src;
            _hasError = false;
        }
    }

    private void HandleError() => _hasError = true;

    private async Task HandleClick()
    {
        if (Preview && !_hasError)
        {
            _showPreview = true;
            _zoom = 100;
            await Interop.LockScroll();
            // Install the focus trap on next render once the overlay is in the
            // DOM. The trap also focuses the first focusable control (so Escape
            // / +/- work without a click) and restores focus to the trigger on
            // close, satisfying the aria-modal="true" contract.
            _shouldTrapPreview = true;
        }
    }

    private bool _shouldTrapPreview;
    private bool _previewTrapped;

    private async Task ClosePreview()
    {
        _showPreview = false;
        try
        {
            if (_previewTrapped)
            {
                _previewTrapped = false;
                await Interop.RemoveFocusTrap(_previewId);
            }
            await Interop.UnlockScroll();
        }
        catch (JSDisconnectedException) { }
    }

    private void ZoomIn()
    {
        if (_zoom < 300) _zoom += 25;
    }

    private void ZoomOut()
    {
        if (_zoom > 25) _zoom -= 25;
    }

    private async Task HandlePreviewKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape": await ClosePreview(); break;
            case "+":
            case "=": ZoomIn(); break;
            case "-": ZoomOut(); break;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_shouldTrapPreview && _showPreview)
        {
            _shouldTrapPreview = false;
            _previewTrapped = true;
            try { await Interop.SetupFocusTrap(_previewId); } catch (JSDisconnectedException) { }
        }

        if (firstRender && Zoomable && !_pinchRegistered)
        {
            _pinchRegistered = true;
            try
            {
                await Interop.RegisterPinchZoom(_zoomContainerId, HandlePinchZoom);
            }
            catch (JSDisconnectedException) { }
        }
    }

    private Task HandlePinchZoom(double scaleDelta)
    {
        // Multiply incremental delta into the running zoom, then clamp.
        var next = _zoomScale * scaleDelta;
        if (next < MinZoomScale) next = MinZoomScale;
        else if (next > MaxZoomScale) next = MaxZoomScale;
        if (Math.Abs(next - _zoomScale) < 0.0001) return Task.CompletedTask;
        _zoomScale = next;
        // The pointermove callbacks fire at high frequency; StateHasChanged is
        // cheap here because only the <img> inline style changes.
        StateHasChanged();
        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        if (_showPreview)
        {
            try
            {
                if (_previewTrapped)
                {
                    _previewTrapped = false;
                    await Interop.RemoveFocusTrap(_previewId);
                }
                await Interop.UnlockScroll();
            }
            catch (JSDisconnectedException) { }
        }
        if (_pinchRegistered)
        {
            try { await Interop.UnregisterPinchZoom(_zoomContainerId); } catch (JSDisconnectedException) { }
        }
    }
}
