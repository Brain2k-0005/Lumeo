                            <KanbanColumn Title="To do" Badge="@_kanbanTodo.Count" Class="flex flex-col w-full rounded-lg border border-border/40 bg-background min-h-[200px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanTodo))">
                                @foreach (var card in _kanbanTodo)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description"
                                                    Draggable="false"
                                                    Class="rounded-md border border-border/40 bg-card p-2.5 cursor-grab active:cursor-grabbing hover:border-primary/40 transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                            <KanbanColumn Title="In progress" Badge="@_kanbanDoing.Count" Class="flex flex-col w-full rounded-lg border border-border/40 bg-background min-h-[200px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanDoing))">
                                @foreach (var card in _kanbanDoing)
