@page "/components/checkbox"

<PageTitle>Checkbox — Lumeo</PageTitle>

<PageHeader Title="Checkbox" Description="A control that allows the user to toggle between checked and not checked." />

<InstallUsage Component="Checkbox" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Allow users to select multiple options from a list of choices.</li>
        <li>Present a single boolean toggle such as accepting terms and conditions.</li>
        <li>Implement "select all" patterns with indeterminate state for bulk actions.</li>
    </ul>
</div>

<div class="mt-6">
    <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
        <ChildContent>
            For validation, label, and helper text, wrap this input in <code class="font-mono text-xs">&lt;FormField&gt;</code>.
            See <a href="/components/form#validation-pattern" class="underline font-medium">Form &rsaquo; Validation Pattern</a>.
        </ChildContent>
    </Alert>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Gap="2" Align="center">
            <Checkbox @bind-Checked="_checked1" />
            <Label>Accept terms and conditions</Label>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="With Binding" Code="@_bindingCode">
        <Stack Gap="4">
            <Flex Gap="2" Align="center">
                <Checkbox @bind-Checked="_checked2" />
                <Label>Enable notifications</Label>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted">Checked: @_checked2</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Stack Gap="3">
            <Flex Gap="2" Align="center">
                <Checkbox Checked="false" Disabled="true" />
                <Label Class="text-muted-foreground">Disabled unchecked</Label>
            </Flex>
            <Flex Gap="2" Align="center">
                <Checkbox Checked="true" Disabled="true" />
                <Label Class="text-muted-foreground">Disabled checked</Label>
            </Flex>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Options" Code="@_multipleCode">
        <Stack Gap="3">
            <Flex Gap="2" Align="center">
                <Checkbox @bind-Checked="_optionA" />
                <Label>Option A</Label>
            </Flex>
            <Flex Gap="2" Align="center">
                <Checkbox @bind-Checked="_optionB" />
                <Label>Option B</Label>
            </Flex>
            <Flex Gap="2" Align="center">
                <Checkbox @bind-Checked="_optionC" />
                <Label>Option C</Label>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted">Selected: @string.Join(", ", GetSelected())</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Indeterminate (Select All)" Code="@_indeterminateCode">
        <Stack Gap="3">
            <Flex Gap="2" Align="center">
                <Checkbox Checked="@_selectAll" CheckedChanged="@HandleSelectAllChanged" IsIndeterminate="@_isIndeterminate" />
                <Label>Select All</Label>
            </Flex>
            <Stack Gap="2" Class="ml-6">
                <Flex Gap="2" Align="center">
                    <Checkbox @bind-Checked="_item1" />
                    <Label>Item 1</Label>
                </Flex>
                <Flex Gap="2" Align="center">
                    <Checkbox @bind-Checked="_item2" />
                    <Label>Item 2</Label>
                </Flex>
                <Flex Gap="2" Align="center">
                    <Checkbox @bind-Checked="_item3" />
                    <Label>Item 3</Label>
                </Flex>
            </Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Animated Check" Code="@_animatedCode">
        <Stack Gap="2">
            <Flex Gap="2" Align="center">
                <Checkbox Animated="true" @bind-Checked="_animatedChecked" />
                <Label>Draw-in check + box bounce</Label>
            </Flex>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Haptic Feedback (Mobile)" Code="@_hapticCode">
        <Stack Gap="3">
            <Lumeo.Text Size="sm" Color="muted">
                On supported mobile browsers, checking or unchecking this checkbox triggers a short vibration via <code class="font-mono text-xs">navigator.vibrate(10)</code>. Desktop browsers silently no-op.
            </Lumeo.Text>
            <Flex Gap="2" Align="center">
                <Checkbox HapticFeedback="true" @bind-Checked="_hapticChecked" />
                <Label>Haptic enabled — @(_hapticChecked ? "checked" : "unchecked")</Label>
            </Flex>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Form Participation (Name / Value)" Code="@_formCode" Description="With a Name set, the checkbox renders a hidden bubble input so it posts in a native form. Value is the string sent when checked (indeterminate posts as unchecked); an unchecked box posts nothing.">
        <form @onsubmit="HandleFormSubmit" @onsubmit:preventDefault="true">
            <Stack Gap="3" Class="max-w-sm">
                <Flex Gap="2" Align="center">
                    <Checkbox @bind-Checked="_termsChecked" Name="terms" Value="accepted" />
                    <Label>I accept the terms</Label>
                </Flex>
                <Flex Gap="2" Align="center">
                    <Checkbox @bind-Checked="_newsletterChecked" Name="newsletter" Value="yes" />
                    <Label>Subscribe to the newsletter</Label>
                </Flex>
                <Button Type="Button.ButtonType.Submit" Class="w-fit">Submit</Button>
                @if (_formResult != null)
                {
                    <Lumeo.Text Size="sm" Color="muted">Form data: <code class="font-mono text-xs">@_formResult</code></Lumeo.Text>
                }
            </Stack>
        </form>
    </ComponentDemo>
</Stack>

<div class="mt-12 space-y-3">
    <Heading Id="styling-hooks" Level="2" Class="scroll-mt-20">Styling hooks (data-state)</Heading>
    <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
        The checkbox exposes a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-state</code>
        attribute — <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">checked</code>,
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">unchecked</code>, or
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">indeterminate</code> — plus
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-disabled</code> when disabled, so you
        can target states from CSS without extra classes, e.g.
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">data-[state=checked]:border-primary</code>.
    </Lumeo.Text>
</div>

<div class="mt-12">
    <Heading Id="keyboard-interactions" Level="2" Class="scroll-mt-20">Keyboard Interactions</Heading>
    <div class="overflow-x-auto mt-4">
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead Class="w-[180px]">Key</TableHead>
                    <TableHead>Action</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow><TableCell><Kbd>Space</Kbd></TableCell><TableCell>Toggles the checkbox between checked and unchecked.</TableCell></TableRow>
                <TableRow><TableCell><Kbd>Tab</Kbd></TableCell><TableCell>Moves focus to the next focusable element.</TableCell></TableRow>
                <TableRow><TableCell><Kbd>Shift+Tab</Kbd></TableCell><TableCell>Moves focus to the previous focusable element.</TableCell></TableRow>
            </TableBody>
        </Table>
    </div>
</div>

<div class="mt-12 space-y-4">
    <Heading Id="parameter-coverage" Level="2" Class="scroll-mt-20">Parameter Coverage</Heading>
    <Lumeo.Text Size="sm" Color="muted">Boolean parameters demoed in both states.</Lumeo.Text>

    <AutoBoolMatrix ParameterName="Checked" Title="Checked">
        <OffContent><Checkbox Checked="false" Label="Unchecked" /></OffContent>
        <OnContent><Checkbox Checked="true" Label="Checked" /></OnContent>
    </AutoBoolMatrix>

    <AutoBoolMatrix ParameterName="Disabled" Title="Disabled">
        <OffContent><Checkbox Disabled="false" Label="Enabled" /></OffContent>
        <OnContent><Checkbox Disabled="true" Label="Disabled" Checked="true" /></OnContent>
    </AutoBoolMatrix>

    <AutoBoolMatrix ParameterName="IsIndeterminate" Title="IsIndeterminate">
        <OffContent><Checkbox IsIndeterminate="false" Checked="true" Label="Determinate" /></OffContent>
        <OnContent><Checkbox IsIndeterminate="true" Label="Indeterminate" /></OnContent>
    </AutoBoolMatrix>

    <AutoBoolMatrix ParameterName="Invalid" Title="Invalid">
        <OffContent><Checkbox Label="Accept terms" /></OffContent>
        <OnContent><Checkbox Label="Accept terms" Invalid="true" ErrorText="Required" /></OnContent>
    </AutoBoolMatrix>
</div>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">Checkbox</Heading>
            <PropsTable Slug="checkbox" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/switch" class="text-primary hover:underline">Switch</a> — A toggle for on/off settings with immediate effect, like enabling dark mode.</li>
        <li><a href="/components/radio-group" class="text-primary hover:underline">RadioGroup</a> — Use when only one option can be selected from a list.</li>
        <li><a href="/components/toggle" class="text-primary hover:underline">Toggle</a> — A pressable button-style control for toggling a single state.</li>
    </ul>
</div>

@code {
    private bool _checked1;
    private bool _checked2 = true;
    private bool _optionA = true;
    private bool _optionB;
    private bool _optionC = true;
    private bool _animatedChecked;

    private string _animatedCode = @"<Checkbox Animated=""true"" @bind-Checked=""_checked"" />";

    private bool _hapticChecked;
    private string _hapticCode = "<Checkbox HapticFeedback=\"true\" @bind-Checked=\"_checked\" />";

    private bool _termsChecked = true;
    private bool _newsletterChecked;
    private string? _formResult;
    private void HandleFormSubmit()
    {
        var parts = new List<string>();
        if (_termsChecked) parts.Add("terms=accepted");
        if (_newsletterChecked) parts.Add("newsletter=yes");
        _formResult = parts.Count > 0 ? string.Join("&", parts) : "(nothing submitted)";
    }
    private string _formCode = @"<form method=""post"">
    <Checkbox @bind-Checked=""_terms"" Name=""terms"" Value=""accepted"" />
    <Checkbox @bind-Checked=""_news"" Name=""newsletter"" Value=""yes"" />
    <Button Type=""Button.ButtonType.Submit"">Submit</Button>
</form>

@code {
    private bool _terms = true;
    private bool _news;
}";

    private IEnumerable<string> GetSelected()
    {
        if (_optionA) yield return "A";
        if (_optionB) yield return "B";
        if (_optionC) yield return "C";
    }

    private string _defaultCode = @"<Flex Gap=""2"" Align=""center"">
    <Checkbox @bind-Checked=""_checked"" />
    <Label>Accept terms and conditions</Label>
</Flex>";

    private string _bindingCode = @"<Flex Gap=""2"" Align=""center"">
    <Checkbox @bind-Checked=""_checked"" />
    <Label>Enable notifications</Label>
</Flex>
<Lumeo.Text Size=""sm"" Color=""muted"">Checked: @_checked</Lumeo.Text>

@code {
    private bool _checked = true;
}";

    private string _disabledCode = @"<Checkbox Checked=""false"" Disabled=""true"" />
<Checkbox Checked=""true"" Disabled=""true"" />";

    private string _multipleCode = @"<Checkbox @bind-Checked=""_optionA"" />
<Checkbox @bind-Checked=""_optionB"" />
<Checkbox @bind-Checked=""_optionC"" />";

    private bool _selectAll;
    private bool _item1 = true;
    private bool _item2;
    private bool _item3 = true;

    private bool _isIndeterminate => _item1 != _item2 || _item2 != _item3;

    private void HandleSelectAllChanged(bool value)
    {
        _selectAll = value;
        _item1 = value;
        _item2 = value;
        _item3 = value;
    }

    private string _indeterminateCode = @"<Flex Gap=""2"" Align=""center"">
    <Checkbox Checked=""@_selectAll"" CheckedChanged=""@HandleSelectAllChanged"" IsIndeterminate=""@_isIndeterminate"" />
    <Label>Select All</Label>
</Flex>
<Stack Gap=""2"" Class=""ml-6"">
    <Flex Gap=""2"" Align=""center"">
        <Checkbox @bind-Checked=""_item1"" />
        <Label>Item 1</Label>
    </Flex>
    <Flex Gap=""2"" Align=""center"">
        <Checkbox @bind-Checked=""_item2"" />
        <Label>Item 2</Label>
    </Flex>
    <Flex Gap=""2"" Align=""center"">
        <Checkbox @bind-Checked=""_item3"" />
        <Label>Item 3</Label>
    </Flex>
</Stack>

@code {
    private bool _selectAll;
    private bool _item1 = true;
    private bool _item2;
    private bool _item3 = true;
    private bool _isIndeterminate => _item1 != _item2 || _item2 != _item3;
    private void HandleSelectAllChanged(bool value)
    {
        _selectAll = value;
        _item1 = value;
        _item2 = value;
        _item3 = value;
    }
}";
}
