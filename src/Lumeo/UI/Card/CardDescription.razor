@namespace Lumeo

@* Muted secondary text under the CardTitle (shadcn Card composition). *@
<p class="@Cx.Merge("text-sm text-muted-foreground", Class)" @attributes="AdditionalAttributes">
    @ChildContent
</p>

@code {
    /// <summary>The description text (typically one or two sentences), rendered muted
    /// beneath the <see cref="CardTitle"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the root <c>p</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>p</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
