        <Flex Align="center" Justify="between" Wrap="true" Gap="4" Class="pt-6 border-t border-border/40">
            <Lumeo.Text Size="xs" Color="muted">© 2026 Lumeo · Built with .NET 10 and Tailwind CSS v4</Lumeo.Text>
            <Flex Align="center" Gap="3">
