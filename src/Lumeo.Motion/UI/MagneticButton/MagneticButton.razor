@namespace Lumeo
@implements IAsyncDisposable
@inject ComponentInteropService Interop

<div id="@_elementId" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>The radius (px) around the button center within which the magnet activates.</summary>
    [Parameter] public int Radius { get; set; } = 80;
    /// <summary>Maximum translation (px) — the button will not move more than this in any direction.</summary>
    [Parameter] public int MaxTranslate { get; set; } = 20;
    /// <summary>CSS transition duration for the settle-back animation.</summary>
    [Parameter] public string TransitionDuration { get; set; } = "300ms";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _elementId = $"lumeo-magnetic-{Guid.NewGuid():N}";
    private bool _registered;

    private string CssClass => string.Join(" ", new[] { "lumeo-magnetic-button", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_registered)
        {
            _registered = true;
            try
            {
                await Interop.MotionMagneticButton(_elementId, new
                {
                    radius = Radius,
                    maxTranslate = MaxTranslate,
                    transitionDuration = TransitionDuration
                });
            }
            catch (JSDisconnectedException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            await Interop.MotionDisposeMagneticButton(_elementId);
        }
    }
}
