@page "/"
@using Lumeo.Services
@using System.Net.Http.Json
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Lumeo - The Blazor component library you would actually want to ship</PageTitle>

<!-- ======================= LIVE ADMIN-APP ======================= -->
<section class="relative min-h-screen overflow-hidden border-b border-border/40">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_80%_60%_at_50%_0%,#000_60%,transparent_110%)] pointer-events-none opacity-30"></div>

    <Container MaxWidth="6xl" Class="relative px-4 pt-8 pb-6">

        <!-- Topbar -->
        <BlurFade DelayMs="0">
            <Flex Align="center" Justify="between" Wrap="true" Gap="3" Class="mb-6">
                <Flex Align="center" Gap="3">
                    <Lumeo.Link Href="docs/changelog" Class="no-underline group">
                        <Flex Inline="true" Align="center" Gap="2" Class="rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                            <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">v3.5</Badge>
                            <Lumeo.Text As="span" Class="hidden sm:inline">Density scale &middot; Splash Kit &middot; Theme.Customize &middot; OverlayForm</Lumeo.Text>
                            <Blazicon Svg="Lucide.ArrowRight" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                        </Flex>
                    </Lumeo.Link>
                    <Lumeo.Text Size="sm" Color="muted" Class="hidden md:inline">163 components &middot; MIT &middot; ~400 KB core</Lumeo.Text>
                </Flex>
                <Flex Gap="2" Align="center">
                    <Lumeo.Link Href="docs/introduction" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Sm" Class="rounded-lg">
                            Get Started
                            <Blazicon Svg="Lucide.ArrowRight" class="h-3.5 w-3.5" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="components/button" Class="inline-flex h-8 items-center gap-1.5 justify-center rounded-lg border border-border/60 bg-background px-4 text-xs font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <Blazicon Svg="Lucide.LayoutGrid" class="h-3.5 w-3.5" />
                        Components
                    </Lumeo.Link>
                </Flex>
            </Flex>
        </BlurFade>

        <!-- KPI strip -->
        <BlurFade DelayMs="80">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-4">
                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                    <Flex Align="center" Justify="between" Class="mb-1">
                        <Lumeo.Text Size="xs" Color="muted">Revenue</Lumeo.Text>
                        <Blazicon Svg="Lucide.DollarSign" class="h-3.5 w-3.5 text-primary" />
                    </Flex>
                    <div class="text-2xl font-bold tracking-tight text-foreground">
                        $<NumberTicker Value="1214" DurationMs="1600" />K
                    </div>
                    <Flex Align="center" Gap="1" Class="mt-1">
                        <Blazicon Svg="Lucide.TrendingUp" class="h-3 w-3 text-primary" />
                        <Lumeo.Text Size="xs" Color="muted">+12.4% vs last Q</Lumeo.Text>
                    </Flex>
                </div>
                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                    <Flex Align="center" Justify="between" Class="mb-1">
                        <Lumeo.Text Size="xs" Color="muted">Active users</Lumeo.Text>
                        <Blazicon Svg="Lucide.Users" class="h-3.5 w-3.5 text-primary" />
                    </Flex>
                    <div class="text-2xl font-bold tracking-tight text-foreground">
                        <NumberTicker Value="8421" DurationMs="1800" />
                    </div>
                    <Flex Align="center" Gap="1" Class="mt-1">
                        <Blazicon Svg="Lucide.TrendingUp" class="h-3 w-3 text-primary" />
                        <Lumeo.Text Size="xs" Color="muted">+841 this week</Lumeo.Text>
                    </Flex>
                </div>
                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                    <Flex Align="center" Justify="between" Class="mb-1">
                        <Lumeo.Text Size="xs" Color="muted">Conversion</Lumeo.Text>
                        <Blazicon Svg="Lucide.Percent" class="h-3.5 w-3.5 text-primary" />
                    </Flex>
                    <div class="text-2xl font-bold tracking-tight text-foreground">
                        <NumberTicker Value="12" DurationMs="1400" />.<NumberTicker Value="4" DurationMs="1400" />%
                    </div>
                    <Flex Align="center" Gap="1" Class="mt-1">
                        <Blazicon Svg="Lucide.TrendingDown" class="h-3 w-3 text-muted-foreground" />
                        <Lumeo.Text Size="xs" Color="muted">-0.3% vs last Q</Lumeo.Text>
                    </Flex>
                </div>
                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm p-4">
                    <Flex Align="center" Justify="between" Class="mb-1">
                        <Lumeo.Text Size="xs" Color="muted">Open tickets</Lumeo.Text>
                        <Blazicon Svg="Lucide.Ticket" class="h-3.5 w-3.5 text-primary" />
                    </Flex>
                    <div class="text-2xl font-bold tracking-tight text-foreground">
                        <NumberTicker Value="47" DurationMs="1200" />
                    </div>
                    <Flex Align="center" Gap="1" Class="mt-1">
                        <Blazicon Svg="Lucide.Clock" class="h-3 w-3 text-muted-foreground" />
                        <Lumeo.Text Size="xs" Color="muted">6 critical priority</Lumeo.Text>
                    </Flex>
                </div>
            </div>
        </BlurFade>
        <!-- Chart (60%) + Map (40%) -->
        <BlurFade DelayMs="160">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3 mb-4">

                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden"
                     @onmouseenter="@(() => _chartHovered = true)" @onmouseleave="@(() => _chartHovered = false)">
                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="semibold">Revenue by package</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">Quarterly, last 6 periods</Lumeo.Text>
                        </Stack>
                        <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-5">
                            <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary mr-1 animate-pulse"></span>
                            Live
                        </Badge>
                    </Flex>
                    <div class="h-56 sm:h-64 lg:h-80 px-2 pb-3">
                        <BarChart Categories="_barCategories" Series="_barSeries" Stacked="true" Height="100%" ShowLoadingSkeleton="false" />
                    </div>
                </div>

                <div class="rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="semibold">Global reach</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">5 cities, animated arcs</Lumeo.Text>
                        </Stack>
                        <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-5">MapLibre</Badge>
                    </Flex>
                    <div class="h-56 sm:h-64 lg:h-80 overflow-hidden">
                        <LazyRender Height="100%">
                            <Map @bind-Center="_mapCenter" @bind-Zoom="_mapZoom" Height="100%" TileLayer="DarkMatter" Projection="globe">
                                <ChildContent>
                                    <MapMarker Lat="51.5074"  Lon="-0.1278"   Title="London"    Variant="Dot" Color="teal" Label="London" />
                                    <MapMarker Lat="40.7128"  Lon="-74.0060"  Title="New York"  Variant="Dot" Color="teal" Label="New York" />
                                    <MapMarker Lat="35.6762"  Lon="139.6503"  Title="Tokyo"     Variant="Dot" Color="teal" Label="Tokyo" />
                                    <MapMarker Lat="-33.8688" Lon="151.2093"  Title="Sydney"    Variant="Dot" Color="teal" Label="Sydney" />
                                    <MapMarker Lat="-23.5505" Lon="-46.6333"  Title="Sao Paulo" Variant="Dot" Color="teal" Label="Sao Paulo" />
                                    <MapArc From="(51.5074, -0.1278)"  To="(40.7128, -74.0060)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                    <MapArc From="(51.5074, -0.1278)"  To="(35.6762, 139.6503)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                    <MapArc From="(40.7128, -74.0060)" To="(-23.5505, -46.6333)" Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                </ChildContent>
                            </Map>
                        </LazyRender>
                    </div>
                </div>
            </div>
        </BlurFade>

        <!-- DataGrid + Kanban -->
        <BlurFade DelayMs="240">
            <div class="grid grid-cols-1 lg:grid-cols-5 gap-3">

                <div class="lg:col-span-3 rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="semibold">Team roster</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">Grouped by department, salary aggregated</Lumeo.Text>
                        </Stack>
                        <Lumeo.Link Href="components/data-grid" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <Blazicon Svg="Lucide.ArrowRight" class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                    <div class="px-3 pb-3">
                        <DataGrid TItem="Employee" Items="@_employees" PageSize="10" ShowPagination="false"
                                  GroupBy="Department" GroupsExpandedByDefault="true">
                            <DataGridColumnDef TItem="Employee" Title="Name"   Field="Name"   Sortable="true" />
                            <DataGridColumnDef TItem="Employee" Title="Role"   Field="Role" />
                            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Aggregate="AggregateType.Sum" />
                        </DataGrid>
                    </div>
                </div>

                <div class="lg:col-span-2 rounded-xl border border-border/50 bg-card/80 backdrop-blur-sm overflow-hidden">
                    <Flex Align="center" Justify="between" Class="px-4 pt-4 pb-2">
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="semibold">Sprint board</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">Drag cards between columns</Lumeo.Text>
                        </Stack>
                        <Lumeo.Link Href="components/kanban" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <Blazicon Svg="Lucide.ArrowRight" class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                    <div class="px-3 pb-3 overflow-x-auto">
                        <Kanban Class="!p-0 !gap-2 min-w-[360px]">
                            <KanbanColumn Title="To do" Badge="@_kanbanTodo.Count"
                                          Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanTodo))">
                                @foreach (var card in _kanbanTodo)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                    Class="rounded-md border border-border/40 bg-card p-2 cursor-grab active:cursor-grabbing hover:border-primary/40 transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                            <KanbanColumn Title="Doing" Badge="@_kanbanDoing.Count"
                                          Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanDoing))">
                                @foreach (var card in _kanbanDoing)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                    Class="rounded-md border border-primary/40 bg-card p-2 ring-1 ring-primary/20 cursor-grab active:cursor-grabbing transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                            <KanbanColumn Title="Done" Badge="@_kanbanDone.Count"
                                          Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[130px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanDone))">
                                @foreach (var card in _kanbanDone)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description" Draggable="false"
                                                    Class="rounded-md border border-border/40 bg-card/60 p-2 opacity-70 cursor-grab active:cursor-grabbing transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                        </Kanban>
                    </div>
                </div>
            </div>
        </BlurFade>

        <!-- Attribution -->
        <BlurFade DelayMs="320">
            <Flex Align="center" Justify="center" Gap="3" Class="mt-5 pt-4 border-t border-border/30">
                <div class="flex items-center gap-1.5">
                    <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
                    <Lumeo.Text Size="xs" Color="muted">This entire dashboard is built with Lumeo &mdash; 154 components, MIT licensed.</Lumeo.Text>
                </div>
                <Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View source <Blazicon Svg="Lucide.ExternalLink" class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </BlurFade>

    </Container>
</section>

<!-- ======================= COMPONENT CONSTELLATION ======================= -->
<section class="py-20 border-b border-border/40">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-8">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">154 components</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Every component, at a glance.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A star-map of the full library. Hover to preview, click to open docs.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <BlurFade DelayMs="80">
            <div class="flex justify-center mb-6">
                <div class="relative w-full max-w-md">
                    <Blazicon Svg="Lucide.Search" class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none" />
                    <input type="search"
                           placeholder="Filter components..."
                           value="@_constellationFilter"
                           @oninput="OnConstellationSearchInput"
                           aria-label="Filter components by name"
                           class="w-full rounded-lg border border-border/60 bg-background pl-9 pr-4 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary/50 transition-colors" />
                </div>
            </div>
        </BlurFade>

        <BlurFade DelayMs="120">
            <Flex Wrap="true" Justify="center" Gap="3" Class="mb-4">
                @foreach (var cat in _categoryColors)
                {
                    <Flex Align="center" Gap="1" Class="text-xs text-muted-foreground">
                        <span class="inline-block h-2.5 w-2.5 rounded-full" style="background-color: @cat.Value;"></span>
                        @cat.Key
                    </Flex>
                }
            </Flex>
        </BlurFade>

        <BlurFade DelayMs="160">
            <div @ref="_constellationRoot"
                 class="lumeo-constellation-host relative w-full overflow-hidden rounded-2xl border border-border/40 bg-card/30 backdrop-blur-sm"
                 style="height: 560px;">

                @if (_constellationNodes.Count == 0)
                {
                    <div class="flex items-center justify-center h-full">
                        <Flex Align="center" Gap="2">
                            <Spinner Size="Lumeo.Size.Sm" />
                            <Lumeo.Text Size="sm" Color="muted">Building constellation...</Lumeo.Text>
                        </Flex>
                    </div>
                }
            </div>
        </BlurFade>

        <BlurFade DelayMs="200">
            <Flex Justify="center" Class="mt-4">
                <Lumeo.Text Size="xs" Color="muted">
                    @(_constellationFilter.Length > 0
                        ? $"{_constellationNodes.Count(n => n.Title.Contains(_constellationFilter, StringComparison.OrdinalIgnoreCase))} of {_constellationNodes.Count} components match"
                        : $"{_constellationNodes.Count} components across {_categoryColors.Count} categories")
                </Lumeo.Text>
            </Flex>
        </BlurFade>
    </Container>
</section>


<Separator Class="opacity-30" />


<!-- ======================= SIZE COMPARISON BENTO ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">The hook</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">A fraction of the size.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    Brotli-compressed assembly size &mdash; what an end user's browser actually downloads from your published app.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <div class="grid gap-4 lg:grid-cols-3">
            <BentoTile Class="lg:col-span-2 border-border/60 p-6">
                <Stack Gap="5">
                    <Stack Gap="1">
                        <Heading Level="3" Class="text-2xl font-semibold tracking-tight">
                            154 components across 7 packages. <Lumeo.Text As="span" Class="text-primary">~400 KB core</Lumeo.Text>.
                        </Heading>
                        <Lumeo.Text Size="sm" Color="muted">Per-package breakdown &mdash; install only the satellites you use.</Lumeo.Text>
                    </Stack>

                    <Stack Gap="4">
                        @foreach (var row in _sizeRows)
                        {
                            <Stack Gap="1.5">
                                <Flex Align="center" Justify="between" Class="text-sm">
                                    <Flex Align="center" Gap="2">
                                        <span class="h-2 w-2 rounded-full @(row.IsCore ? "bg-primary" : "bg-primary/50")"></span>
                                        <Lumeo.Text As="span" Weight="@(row.IsCore ? "semibold" : "medium")" Color="foreground">@row.Name</Lumeo.Text>
                                        <span class="hidden sm:inline-block w-16 opacity-70" aria-hidden="true">
                                            <Sparkline Values="row.Spark" Height="14" ShowArea="true" StrokeWidth="1" AriaLabel="@($"{row.Name} trend")" />
                                        </span>
                                        <Lumeo.Text As="span" Size="xs" Color="muted">@row.Components</Lumeo.Text>
                                    </Flex>
                                    <Lumeo.Text As="span" Size="xs" Class="@(row.IsCore ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground")">@row.Size</Lumeo.Text>
                                </Flex>
                                <div class="relative h-2 rounded-md bg-muted/40 overflow-hidden">
                                    <div class="@(row.IsCore ? "bg-primary" : "bg-primary/50") h-full rounded-md transition-all"
                                         style="width: @(row.Percent)%;"></div>
                                </div>
                            </Stack>
                        }
                    </Stack>

                    <Flex Align="center" Gap="2" Class="text-xs text-muted-foreground border-t border-border/40 pt-4">
                        <Blazicon Svg="Lucide.Info" class="h-3.5 w-3.5" />
                        <Lumeo.Text As="span">Brotli-compressed assembly bytes. Core brotli-compresses to ~400 KB in your published app.</Lumeo.Text>
                    </Flex>
                </Stack>
            </BentoTile>

            <div class="grid grid-cols-2 lg:grid-cols-1 gap-4 content-start">
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <Blazicon Svg="Lucide.TestTube" class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Tests</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">
                                <NumberTicker Value="2480" DurationMs="1800" />
                            </div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">CI green, every commit.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <Blazicon Svg="Lucide.Languages" class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Locales</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">
                                <NumberTicker Value="14" DurationMs="1600" />
                            </div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">Bundled ILumeoLocalizer.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <Blazicon Svg="Lucide.Palette" class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Themes</Lumeo.Text>
                            <div class="text-2xl font-semibold tracking-tight text-foreground leading-none">
                                <NumberTicker Value="8" DurationMs="1400" />
                            </div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">CSS-variable presets.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
                <BentoTile Class="border-border/60 p-4">
                    <Flex Align="center" Gap="3">
                        <div class="flex h-9 w-9 items-center justify-center rounded-md bg-accent/40 text-primary shrink-0">
                            <Blazicon Svg="Lucide.Accessibility" class="h-4 w-4" />
                        </div>
                        <Stack Gap="0" Class="min-w-0 flex-1">
                            <Lumeo.Text Size="xs" Color="muted">Compliance</Lumeo.Text>
                            <div class="text-xl font-semibold tracking-tight text-foreground leading-none">WCAG AA</div>
                            <Lumeo.Text Size="xs" Color="muted" Class="truncate">Keyboard + ARIA built in.</Lumeo.Text>
                        </Stack>
                    </Flex>
                </BentoTile>
            </div>
        </div>
    </Container>
</section>

<!-- ======================= WHAT'S NEW IN 3.0 ======================= -->
<section class="py-20 bg-muted/[0.03]">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">New in 3.0</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">The 3.0 highlights.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A unified enum surface across the library, plus six new primitives.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

