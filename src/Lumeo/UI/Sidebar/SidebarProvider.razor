@namespace Lumeo
@inject IComponentInteropService Interop
@inject Lumeo.Services.IResponsiveService Responsive
@inject Lumeo.Services.IKeyboardShortcutService Shortcuts
@implements IAsyncDisposable

@{
    var context = new SidebarState(
        EffectiveIsCollapsed,
        EventCallback.Factory.Create(this, Toggle),
        Variant)
    {
        EffectiveCollapsed = EffectiveCollapsed,
        SetHoverExpanded = EventCallback.Factory.Create<bool>(this, SetHoverExpanded),
        IsMobileSheet = IsMobileSheet,
    };
}

<CascadingValue Value="context" IsFixed="false">
    <div class="@CssClass"
         data-slot="sidebar-wrapper"
         data-state="@(EffectiveIsCollapsed ? "collapsed" : "expanded")"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    /// <summary>The sidebar layout (typically a <see cref="SidebarComponent"/> plus the main content area) that consumes the cascaded <see cref="SidebarState"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the sidebar is collapsed. Pair with <see cref="IsCollapsedChanged"/> for two-way binding; leave unbound for uncontrolled use (state is then self-managed and, with <see cref="PersistCollapsed"/>, persisted to localStorage).</summary>
    [Parameter] public bool IsCollapsed { get; set; }

    /// <summary>Raised when the collapsed state changes (via <see cref="Toggle"/> or the keyboard shortcut).</summary>
    [Parameter] public EventCallback<bool> IsCollapsedChanged { get; set; }

    /// <summary>Layout strategy for the sidebar when collapsed. Defaults to <see cref="SidebarVariant.Push"/>.</summary>
    [Parameter] public SidebarVariant Variant { get; set; } = SidebarVariant.Push;

    /// <summary>
    /// When true, the sidebar renders as an off-canvas sheet (slide-in over a
    /// dismissible scrim) on mobile viewports (&lt; <c>md</c>), regardless of
    /// <see cref="Variant"/>. On larger viewports it keeps its configured
    /// variant. Collapsed acts as the sheet's closed state; toggling opens it.
    /// Opt-in (default false) so existing layouts are unchanged. (#241)
    /// </summary>
    [Parameter] public bool MobileSheet { get; set; }

    /// <summary>
    /// Keyboard shortcut that toggles the sidebar, in the
    /// <see cref="Lumeo.Services.IKeyboardShortcutService"/> combo format
    /// (e.g. <c>"ctrl+b"</c>, <c>"meta+b"</c>). Registered on first render and
    /// released on dispose. Defaults to <c>"ctrl+b"</c> which — matching shadcn's
    /// <c>(metaKey || ctrlKey) &amp;&amp; key === "b"</c> — fires on both
    /// <kbd>Ctrl</kbd>+<kbd>B</kbd> and <kbd>Cmd</kbd>+<kbd>B</kbd>. Override with a
    /// different combo, or set to <c>null</c>/empty to disable the shortcut entirely.
    /// </summary>
    [Parameter] public string? ToggleShortcut { get; set; } = "ctrl+b";

    /// <summary>
    /// When true, the collapsed / expanded state survives page reloads — the provider
    /// reads <see cref="IsCollapsed"/> from <c>localStorage[PersistenceKey]</c> on first
    /// render and writes back on every change. Falls back to the parameter value when
    /// JS is unavailable (SSR, prerender, JSDisconnectedException). Opt-in to keep
    /// existing consumers' behaviour untouched.
    /// </summary>
    [Parameter] public bool PersistCollapsed { get; set; }

    /// <summary>
    /// LocalStorage key used when <see cref="PersistCollapsed"/> is true. Override to
    /// scope a per-route or per-tenant sidebar so multiple sidebars on the same origin
    /// don't clobber each other's state.
    /// </summary>
    [Parameter] public string PersistenceKey { get; set; } = "lumeo.sidebar.collapsed";

    /// <summary>Additional CSS classes merged onto the root wrapper <c>div</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the root wrapper <c>div</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // Transient hover/focus-driven expansion for the MiniRail variant. Lives on the
    // provider (not SidebarComponent) so descendants — most importantly
    // SidebarMenuButton — can react via the cascaded SidebarState and reveal their
    // LabelContent during hover-expansion, not just on pinned expand.
    private bool _hoverExpanded;
    private IAsyncDisposable? _shortcutHandle;
    private string? _registeredShortcut;
    private bool _viewportSubscribed;

    // Uncontrolled collapse state lives in a private backing field, NOT in the
    // [Parameter] IsCollapsed. Blazor re-applies [Parameter] values from the parent
    // on every render, so self-managing state (Toggle, the PersistCollapsed restore)
    // by writing back into IsCollapsed got silently clobbered whenever an unrelated
    // parent re-render pushed the original literal IsCollapsed value down again —
    // most damagingly wiping a value just restored from localStorage. Mirrors the
    // Collapsible fix (#246). (#11)
    private bool _isCollapsed;
    private bool _initialized;
    private bool _lastCollapsedParam;

    // Last value actually written to localStorage. Drives a single persistence path
    // (PersistIfChangedAsync, run every render) so EVERY effective-collapsed change is
    // saved — not just the Toggle() one. Parameter-/@bind-driven collapse changes used
    // to slip past persistence (only Toggle wrote), leaving localStorage stale. (#101)
    // Nullable so the first run can adopt the rendered state as the baseline without an
    // immediate redundant write.
    private bool? _lastPersisted;

    // State the cascade actually renders from. Controlled (IsCollapsedChanged bound):
    // the parent owns it, so mirror IsCollapsed verbatim. Uncontrolled: use our own
    // backing field so parent re-renders — and same-literal parameter pushes after a
    // localStorage restore — can't clobber it.
    private bool EffectiveIsCollapsed => IsCollapsedChanged.HasDelegate ? IsCollapsed : _isCollapsed;

    // True when the sidebar should render + behave as collapsed for descendants. For
    // MiniRail this is IsCollapsed unless the user is hovering / keyboard-focused on
    // the rail. Other variants ignore the hover state.
    private bool EffectiveCollapsed
        => EffectiveIsCollapsed && !(Variant == SidebarVariant.MiniRail && _hoverExpanded);

    protected override void OnParametersSet()
    {
        // Seed the uncontrolled backing field from IsCollapsed on first set (honours
        // an initial IsCollapsed="true") and whenever the bound IsCollapsed value
        // actually changes (lets callers still drive it imperatively), but never on
        // the no-op re-applications that caused the reset / localStorage clobber.
        if (!_initialized || IsCollapsed != _lastCollapsedParam)
        {
            _isCollapsed = IsCollapsed;
            _lastCollapsedParam = IsCollapsed;
            _initialized = true;
        }
    }

    // Off-canvas sheet behaviour only kicks in on mobile, and only when opted in.
    private bool IsMobileSheet => MobileSheet && Responsive.IsMobile;

    private string CssClass
    {
        get
        {
            // The mobile sheet (or the Overlay variant) needs a positioning
            // context for its absolutely-positioned panel + scrim.
            var positioned = (Variant == SidebarVariant.Overlay || IsMobileSheet) ? "relative overflow-hidden" : "";
            return Cx.Merge("flex h-full w-full", positioned, Class);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // React to viewport changes so the mobile-sheet treatment flips on the
        // md boundary without a manual refresh. NOT firstRender-gated: MobileSheet
        // can be toggled false→true after the first render, and the subscription
        // (and md-boundary flip) must still come alive then. _viewportSubscribed
        // keeps it idempotent across re-renders. Symmetrically unsubscribe when
        // MobileSheet flips back to false so we don't keep reacting to viewport
        // changes that no longer affect this provider. (#102)
        if (MobileSheet && !_viewportSubscribed)
        {
            _viewportSubscribed = true;
            Responsive.ViewportChanged += OnViewportChanged;
            try { await Responsive.EnsureInitialisedAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            StateHasChanged();
        }
        else if (!MobileSheet && _viewportSubscribed)
        {
            _viewportSubscribed = false;
            Responsive.ViewportChanged -= OnViewportChanged;
        }

        // Run every render (not just firstRender) so a changed ToggleShortcut
        // parameter re-registers; SyncShortcutAsync is a no-op when unchanged.
        await SyncShortcutAsync();

        if (firstRender && PersistCollapsed)
        {
            try
            {
                var stored = await Interop.LoadFromLocalStorage(PersistenceKey);
                // Only restore if storage actually held a value AND it differs from the
                // currently effective state — avoids a redundant cascade refresh on
                // every mount.
                if (stored is "true" or "false")
                {
                    var restored = stored == "true";
                    // The stored value IS the persisted baseline — record it so the
                    // central PersistIfChangedAsync below doesn't immediately re-write the
                    // same value we just read back.
                    _lastPersisted = restored;
                    if (restored != EffectiveIsCollapsed)
                    {
                        // Write the restored value into our backing field (the
                        // uncontrolled source of truth) so a later same-literal
                        // IsCollapsed parameter push can't clobber it — the whole point
                        // of the fix. Deliberately do NOT touch _lastCollapsedParam: it
                        // mirrors the *parameter*, which the consumer hasn't changed, so
                        // OnParametersSet must treat the re-applied literal as a no-op
                        // and leave the restored state intact. Also notify the parent so
                        // a controlled consumer can adopt the persisted value.
                        _isCollapsed = restored;
                        await IsCollapsedChanged.InvokeAsync(restored);
                        StateHasChanged();
                    }
                }
            }
            catch (Microsoft.JSInterop.JSDisconnectedException)
            {
                // Circuit dropped between firstRender scheduling and the storage call.
                // Fall through silently — the cascade keeps the parameter default.
            }
        }

        // Persist whenever the effective collapsed state has drifted from what's in
        // localStorage — covers parameter-/@bind-driven changes (which never went through
        // Toggle) as well as the Toggle path, so localStorage can't go stale. Runs after
        // the restore block so the just-read baseline isn't immediately re-written. (#101)
        await PersistIfChangedAsync(firstRender);
    }

    // Writes the current EffectiveIsCollapsed to localStorage iff it differs from the last
    // persisted value. Single source of persistence for every collapse change. No-op when
    // PersistCollapsed is off. On the first render we only ADOPT the rendered state as the
    // baseline (no write) unless the restore block already seeded one — mounting shouldn't
    // newly stamp localStorage; only genuine changes after mount do. (#101)
    private async Task PersistIfChangedAsync(bool firstRender)
    {
        if (!PersistCollapsed) return;
        var current = EffectiveIsCollapsed;
        if (firstRender && _lastPersisted is null)
        {
            // Empty storage on mount: take the current state as the baseline silently so
            // we don't write the initial (unchanged) value — preserves the original
            // restore-only-on-mount contract.
            _lastPersisted = current;
            return;
        }
        if (_lastPersisted == current) return;
        _lastPersisted = current;
        try { await Interop.SaveToLocalStorage(PersistenceKey, current ? "true" : "false"); }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
    }

    // (Re)registers the toggle shortcut when ToggleShortcut changes. Releases a
    // previous registration first so a changed combo doesn't leave a ghost.
    private async Task SyncShortcutAsync()
    {
        if (_registeredShortcut == ToggleShortcut) return;
        if (_shortcutHandle is not null)
        {
            try { await _shortcutHandle.DisposeAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            _shortcutHandle = null;
        }
        _registeredShortcut = ToggleShortcut;
        if (string.IsNullOrWhiteSpace(ToggleShortcut)) return;
        try
        {
            _shortcutHandle = await Shortcuts.RegisterAsync(ToggleShortcut!, Toggle);
        }
        catch (Microsoft.JSInterop.JSDisconnectedException) { }
        catch (InvalidOperationException) { } // JS unavailable during prerender
    }

    private void OnViewportChanged(Lumeo.Services.ViewportInfo _)
    {
        // A breakpoint crossing may flip IsMobileSheet — re-render the cascade.
        InvokeAsync(StateHasChanged);
    }

    private async Task Toggle()
    {
        var next = !EffectiveIsCollapsed;
        // Uncontrolled (IsCollapsedChanged not bound): self-manage via the backing
        // field so an unrelated parent re-render — which re-applies the original
        // literal IsCollapsed — can't revert the toggle. Deliberately do NOT touch
        // _lastCollapsedParam: the *parameter* hasn't changed, so OnParametersSet must
        // keep treating the re-applied literal as a no-op. Controlled: don't mutate our
        // own state — fire the callback and render from the value the parent pushes
        // back down (OnParametersSet re-seeds when it differs), so we never desync if
        // the parent rejects or transforms the change. Mirrors Collapsible (#246). (#11)
        if (!IsCollapsedChanged.HasDelegate)
            _isCollapsed = next;
        await IsCollapsedChanged.InvokeAsync(next);
        await InvokeAsync(StateHasChanged);
        // Persistence is centralised in PersistIfChangedAsync (run from OnAfterRenderAsync
        // after the StateHasChanged above re-renders), so a parameter-driven change is
        // persisted just like this toggle — no per-callsite write needed here. (#101)
    }

    // Called by SidebarComponent's @onmouseenter / @onmouseleave / focus handlers.
    // Only meaningful for MiniRail — other variants set this but their CSS / button
    // logic ignores it via the EffectiveCollapsed predicate.
    private void SetHoverExpanded(bool value)
    {
        if (_hoverExpanded == value) return;
        _hoverExpanded = value;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_viewportSubscribed)
            Responsive.ViewportChanged -= OnViewportChanged;
        if (_shortcutHandle is not null)
        {
            try { await _shortcutHandle.DisposeAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }

    // Kept as a 3-positional record so the v3.10.0 generated constructor + Deconstruct
    // signature still compiles for external callers (this record is meant for our own
    // cascade but is technically public). The new fields land as init-only props
    // with defaults — fully additive.
    public record SidebarState(
        bool IsCollapsed,
        EventCallback Toggle,
        SidebarVariant Variant)
    {
        /// <summary>True when descendants should render in their collapsed appearance.
        /// For MiniRail this is <see cref="IsCollapsed"/> unless the user is hovering
        /// the rail; other variants always match <see cref="IsCollapsed"/>.</summary>
        public bool EffectiveCollapsed { get; init; } = IsCollapsed;

        /// <summary>Called by <c>SidebarComponent</c> on hover / focus to flip the
        /// MiniRail hover-expansion. No-op for other variants.</summary>
        public EventCallback<bool> SetHoverExpanded { get; init; }

        /// <summary>True when the sidebar should render as a mobile off-canvas
        /// sheet (opted into via <c>MobileSheet</c> and currently on a mobile
        /// viewport). <c>SidebarComponent</c> swaps to the slide-in + scrim
        /// treatment when set.</summary>
        public bool IsMobileSheet { get; init; }
    }

    /// <summary>
    /// Layout strategy for the sidebar.
    /// <list type="bullet">
    /// <item><c>Push</c> — collapses to zero width, pushing main content to the edge.</item>
    /// <item><c>Overlay</c> — floats above content with a dismissible scrim.</item>
    /// <item><c>Icon</c> — collapses to a narrow icon rail that stays put until toggled back.</item>
    /// <item><c>MiniRail</c> — same icon-rail width when collapsed, but expands to full
    /// width on hover or keyboard focus and collapses again on leave. Material’s standard
    /// collapsed-sidebar pattern; uses <c>Toggle()</c> to pin open.</item>
    /// </list>
    /// </summary>
    public enum SidebarVariant { Push, Overlay, Icon, MiniRail }
}
