    private List<Transfer.TransferItem> _targetItems = new()
    {
        new("Item 5", "5"),
    };

    private string _codeBasic = @"<Transfer SourceItems=""@_source"" TargetItems=""@_target"" ShowSearch=""true"" />";
}
