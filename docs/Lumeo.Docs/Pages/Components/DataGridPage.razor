@code {
    // ---- Virtualised server mode demo ----------------------------------
    // Simulates a 50,000-row backend on top of the existing _employees seed.
    // Sort/filter/search context arrives in DataGridRangeRequest; we apply
    // it in-memory and slice the requested window.
    private List<Employee>? _virtualBackend;

    private List<Employee> VirtualBackend
    {
        get
        {
            if (_virtualBackend is not null) return _virtualBackend;
            _virtualBackend = new List<Employee>(50_000);
            for (var i = 0; i < 50_000; i++)
            {
                var seed = _employees[i % _employees.Count];
                _virtualBackend.Add(new Employee(
                    $"{seed.Name} #{i + 1}",
                    seed.Department,
                    seed.Salary + (i % 13) * 100,
                    seed.Status,
                    seed.StartDate));
            }
            return _virtualBackend;
        }
    }

    private ValueTask<DataGridRangeResponse<Employee>> FakeRangeRequest(DataGridRangeRequest req)
    {
        IEnumerable<Employee> q = VirtualBackend;
        if (!string.IsNullOrWhiteSpace(req.GlobalSearch))
        {
            var s = req.GlobalSearch.ToLowerInvariant();
            q = q.Where(e => e.Name.ToLowerInvariant().Contains(s)
                          || e.Department.ToLowerInvariant().Contains(s)
                          || e.Status.ToLowerInvariant().Contains(s));
        }
        if (req.Filters is not null)
        {
            foreach (var f in req.Filters)
            {
                if (string.IsNullOrEmpty(f.Field) || string.IsNullOrEmpty(f.Value?.ToString())) continue;
                var fieldVal = f.Value!.ToString()!.ToLowerInvariant();
                q = f.Field switch
                {
                    "Name"       => q.Where(e => e.Name.ToLowerInvariant().Contains(fieldVal)),
                    "Department" => q.Where(e => e.Department.ToLowerInvariant().Contains(fieldVal)),
                    "Status"     => q.Where(e => e.Status.ToLowerInvariant().Contains(fieldVal)),
                    _ => q
                };
            }
        }
        if (req.Sorts is not null && req.Sorts.Count > 0)
        {
            IOrderedEnumerable<Employee>? ordered = null;
            foreach (var s in req.Sorts)
            {
                Func<Employee, object?> key = s.Field switch
                {
                    "Name"       => e => e.Name,
                    "Department" => e => e.Department,
                    "Salary"     => e => e.Salary,
                    _ => e => e.Name
                };
                ordered = ordered is null
                    ? (s.Direction == SortDirection.Descending ? q.OrderByDescending(key) : q.OrderBy(key))
                    : (s.Direction == SortDirection.Descending ? ordered.ThenByDescending(key) : ordered.ThenBy(key));
            }
            q = ordered ?? q;
        }
        var materialised = q.ToList();
        var slice = materialised.Skip(req.StartIndex).Take(req.Count).ToList();
        return ValueTask.FromResult(new DataGridRangeResponse<Employee>(slice, materialised.Count));
    }

