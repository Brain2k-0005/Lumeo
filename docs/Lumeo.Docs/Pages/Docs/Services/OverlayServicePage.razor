                                <td class="p-3 text-muted-foreground">Slides in from the left edge.</td>
                            </tr>
                        </tbody>
                    </table>
                </Stack>
            </Stack>

            @* SheetSize Enum *@
            <Stack>
                <Heading Level="3" Class="mb-3">SheetSize Enum</Heading>
                <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                    <table class="w-full min-w-[600px] text-sm">
                        <thead>
                            <tr class="border-b border-border/40 bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Value</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Sm</td>
                                <td class="p-3 text-muted-foreground">Small — compact panel for simple content.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Default</td>
                                <td class="p-3 text-muted-foreground">Standard size — suitable for most forms and settings panels.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Lg</td>
                                <td class="p-3 text-muted-foreground">Large — for detail views and complex content.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Xl</td>
                                <td class="p-3 text-muted-foreground">Extra large — for data tables or wide layouts.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Full</td>
                                <td class="p-3 text-muted-foreground">Full width or height — covers the entire edge of the viewport.</td>
                            </tr>
                        </tbody>
                    </table>
                </Stack>
            </Stack>

        </Stack>
    </Stack>

</Stack>

@inject OverlayService OverlayService

@code {
    // Dialog state
    private string? _dialogResult;
    private bool _dialogCancelled;

    // Sheet state
    private string? _sheetResult;
    private bool _sheetCancelled;

    // Drawer state
    private string? _drawerResult;
    private bool _drawerCancelled;

    // Alert — confirm
    private string? _confirmResult;
    private bool _confirmCancelled;

    // Alert — destructive
    private string? _destructiveResult;
    private bool _destructiveCancelled;

    // PreventClose
    private string? _preventCloseResult;

    // ─── Dialog demos ───────────────────────────

    private async Task ShowDialog()
    {
        _dialogResult = null;
        var result = await OverlayService.ShowDialogAsync<OverlayDemoContent>("Edit Profile");
        _dialogCancelled = result.Cancelled;
        _dialogResult = result.Cancelled
            ? "User cancelled"
            : $"Result: {result.Data}";
    }

    private async Task ShowDialogWide()
    {
        _dialogResult = null;
        var result = await OverlayService.ShowDialogAsync<OverlayDemoContent>(
            "Edit Profile",
            options: new OverlayOptions { Class = "max-w-2xl" }
        );
        _dialogCancelled = result.Cancelled;
        _dialogResult = result.Cancelled
            ? "User cancelled"
            : $"Result: {result.Data}";
    }

    // ─── Sheet demos ────────────────────────────

    private async Task ShowSheet(SheetSide side)
    {
        _sheetResult = null;
        var result = await OverlayService.ShowSheetAsync<OverlayDemoContent>(
            "Settings",
            side: side,
            size: SheetSize.Default
        );
        _sheetCancelled = result.Cancelled;
        _sheetResult = result.Cancelled
            ? $"User cancelled (side: {side})"
            : $"Result from {side} sheet: {result.Data}";
    }

    // ─── Drawer demo ────────────────────────────

    private async Task ShowDrawer()
    {
        _drawerResult = null;
        var result = await OverlayService.ShowDrawerAsync<OverlayDemoContent>("Edit Profile");
        _drawerCancelled = result.Cancelled;
        _drawerResult = result.Cancelled
            ? "User cancelled"
            : $"Result: {result.Data}";
    }

    // ─── Alert confirm demo ─────────────────────

    private async Task ShowConfirm()
    {
        _confirmResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Save changes?",
            Description = "This will overwrite your existing data.",
            ConfirmText = "Save",
            CancelText = "Cancel"
        });
        _confirmCancelled = result.Cancelled;
        _confirmResult = result.Cancelled
            ? "User cancelled -- changes were not saved"
            : "User confirmed -- changes saved";
    }

    // ─── Alert destructive demo ─────────────────

    private async Task ShowDestructive()
    {
        _destructiveResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Delete your account?",
            Description = "This action cannot be undone. All of your data will be permanently removed.",
            ConfirmText = "Delete Account",
            CancelText = "Keep Account",
            IsDestructive = true
        });
        _destructiveCancelled = result.Cancelled;
        _destructiveResult = result.Cancelled
            ? "User cancelled -- account kept"
            : "User confirmed -- account deleted";
    }

    // ─── PreventClose demo ──────────────────────

    private async Task ShowPreventClose()
    {
        _preventCloseResult = null;
        var result = await OverlayService.ShowDialogAsync<OverlayDemoContent>(
            "Required Information",
            options: new OverlayOptions { PreventClose = true }
        );
        _preventCloseResult = result.Cancelled
            ? "User cancelled via button"
            : $"Result: {result.Data}";
    }
}


