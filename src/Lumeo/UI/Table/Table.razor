@namespace Lumeo

<div class="relative w-full overflow-auto">
    <table class="@CssClass" @attributes="AdditionalAttributes">
        @ChildContent
    </table>
</div>

@code {
    /// <summary>The table's content — typically <see cref="TableHeader"/>,
    /// <see cref="TableBody"/>, <see cref="TableFooter"/>, and/or a
    /// <see cref="TableCaption"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// When true, body rows alternate background (zebra striping) via a
    /// <c>tbody tr:nth-child(even)</c> rule so dense data tables are easier to
    /// scan. Applied with CSS variables only — no hardcoded colors.
    /// </summary>
    [Parameter] public bool Striped { get; set; }

    /// <summary>Additional CSS classes merged onto the <c>&lt;table&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the <c>&lt;table&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge(
        "w-full caption-bottom text-sm",
        Striped ? "[&_tbody_tr:nth-child(even)]:bg-muted/50" : null,
        Class);
}
