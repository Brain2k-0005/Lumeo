@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeDatePickerDefault">
    <DatePicker @bind-Value="_datePicker1" Class="w-64" />
</PatternCard>

<PatternCard Label="With Label" Code="@_codeDatePickerLabel">
    <Stack Gap="2" Class="w-64">
        <Label Class="text-xs text-muted-foreground">Date of birth</Label>
        <DatePicker @bind-Value="_datePicker2" Placeholder="Pick your birthday" Class="w-full" />
    </Stack>
</PatternCard>
</Stack>

@code {
    private DateOnly? _datePicker1;

    private DateOnly? _datePicker2;

        private string _codeDatePickerDefault = @"<DatePicker @bind-Value=""_date"" />";
        private string _codeDatePickerLabel = @"<Stack Gap=""2"">
        <Label Class=""text-xs text-muted-foreground"">Date of birth</Label>
        <DatePicker @bind-Value=""_date"" Placeholder=""Pick your birthday"" />
    </Stack>";
}
