@*#if (AuthEnabled)
<CascadingAuthenticationState>
##endif*@
<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        @*#if (AuthEnabled)
        <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
            <Authorizing>
                <div class="flex min-h-screen items-center justify-center text-sm text-muted-foreground">Loading…</div>
            </Authorizing>
        </AuthorizeRouteView>
        ##else
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        ##endif*@
        @* Focus the page heading on navigation (a11y) — outline suppressed via h1:focus-visible in app.css *@
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(MainLayout)">
            <Container MaxWidth="lg">
                <Stack Gap="3" Class="py-16">
                    <Heading Level="1" Size="2xl">Page not found</Heading>
                    <Lumeo.Text Color="muted">Sorry, there's nothing at this address.</Lumeo.Text>
                    <div>
                        <Button Variant="Button.ButtonVariant.Outline" OnClick="@(() => Nav.NavigateTo(""))">
                            Back to dashboard
                        </Button>
                    </div>
                </Stack>
            </Container>
        </LayoutView>
    </NotFound>
</Router>
@*#if (AuthEnabled)
</CascadingAuthenticationState>
##endif*@

@code {
    [Inject] private NavigationManager Nav { get; set; } = default!;
}
