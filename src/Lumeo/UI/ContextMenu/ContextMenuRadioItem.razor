@namespace Lumeo

<button type="button" role="menuitemradio" aria-checked="@IsSelected.ToString().ToLower()" class="@CssClass" @onclick="Select" disabled="@Disabled" aria-disabled="@(Disabled ? "true" : null)" @attributes="AdditionalAttributes">
    <span class="flex h-3.5 w-3.5 items-center justify-center">
        @if (IsSelected)
        {
            <SvgGlyph Svg="@(LumeoIcons.Circle)" class="h-2 w-2 fill-current" />
        }
    </span>
    @ChildContent
</button>

@code {
    [CascadingParameter] public ContextMenuRadioGroup.ContextMenuRadioGroupContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter, EditorRequired] public string Value { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsSelected => Context.Value == Value;

    // The native disabled attribute also makes the JS menu nav (getMenuItems uses
    // :not([disabled])) skip this item during arrow-key roving, consistent with the
    // other menu items.
    private string CssClass => Cx.Merge("relative flex w-full cursor-default select-none items-center gap-2 rounded-sm py-1.5 ps-8 pe-2 text-sm outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed", Class);

    private async Task Select()
    {
        if (Disabled) return;
        await Context.OnSelect.InvokeAsync(Value);
    }
}
