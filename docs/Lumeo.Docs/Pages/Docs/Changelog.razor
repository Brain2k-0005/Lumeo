        <Stack Gap="3">
            <Heading Level="3" Size="sm" Class="font-semibold">Fixed</Heading>
            <ul class="space-y-1.5 text-sm list-disc list-inside text-muted-foreground">
                <li>Overlay positioning inside ancestors with <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">transform</code> / <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">filter</code> (these create a containing block that breaks <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">position: fixed</code>)</li>
            </ul>
        </Stack>
    </Stack>

    <Separator Class="my-4" />

    <!-- v1.0.2 -->
    <Stack Gap="4">
        <div class="flex items-center gap-3">
            <Badge>v1.0.2</Badge>
            <Lumeo.Text Size="sm" Color="muted">March 2026</Lumeo.Text>
        </div>

        <Stack Gap="3">
            <Heading Level="3" Size="sm" Class="font-semibold">Fixed</Heading>
            <ul class="space-y-1.5 text-sm list-disc list-inside text-muted-foreground">
                <li>Textarea <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">@@bind-Value</code> two-way binding</li>
                <li>TreeSelect cleanup on dispose</li>
                <li>Tooltip disposal race on rapid mount/unmount</li>
                <li>DataGrid pagination alignment and UX polish</li>
            </ul>
        </Stack>
    </Stack>

    <Separator Class="my-4" />

    <!-- v1.0.1 -->
    <Stack Gap="4">
