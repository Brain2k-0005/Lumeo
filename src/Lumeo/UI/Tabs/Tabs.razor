@namespace Lumeo

@{
    var context = new TabsContext(ActiveValue, EventCallback.Factory.Create<string>(this, SetValue), Orientation, Variant, _tabIds, AnimatedIndicator);
}

<div class="@CssClass" @attributes="AdditionalAttributes">
    <CascadingValue Value="context" IsFixed="false">
        @ChildContent
    </CascadingValue>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string ActiveValue { get; set; } = "";
    [Parameter] public EventCallback<string> ActiveValueChanged { get; set; }
    [Parameter] public TabsOrientation Orientation { get; set; } = TabsOrientation.Horizontal;
    [Parameter] public string Variant { get; set; } = "Default";

    /// <summary>
    /// When true, renders a sliding underline that animates between active
    /// triggers inside each <see cref="TabsList"/>. Default is <c>false</c>
    /// (no underline, original behaviour).
    /// </summary>
    [Parameter] public bool AnimatedIndicator { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // Registry: value -> (tabId, panelId) — populated by TabsTrigger on first render
    private readonly Dictionary<string, (string TabId, string PanelId)> _tabIds = new();

    private string CssClass => Orientation == TabsOrientation.Vertical
        ? $"flex flex-row {Class}".Trim()
        : $"{Class}".Trim();

    private async Task SetValue(string value)
    {
        ActiveValue = value;
        await ActiveValueChanged.InvokeAsync(value);
    }

    public record TabsContext(
        string ActiveValue,
        EventCallback<string> SetValue,
        TabsOrientation Orientation,
        string Variant,
        Dictionary<string, (string TabId, string PanelId)> TabIds,
        bool AnimatedIndicator)
    {
        public TabsContext(string ActiveValue, EventCallback<string> SetValue, TabsOrientation Orientation = TabsOrientation.Horizontal, string Variant = "Default")
            : this(ActiveValue, SetValue, Orientation, Variant, new Dictionary<string, (string, string)>(), false) { }
    }

    public enum TabsOrientation { Horizontal, Vertical }
}
