@page "/blocks/social-feed"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>Social Feed Pattern — Lumeo</PageTitle>

<PageHeader Title="Social Feed" Description="A social media timeline with a compose area, post cards with avatars, tooltips, like/comment actions, avatar groups, and a detail sheet." />

<Stack Gap="6">

    <ComponentDemo Title="Social Media Timeline" Code="@_socialFeedCode">
        <Stack Gap="4" Class="w-full">

            <!-- Compose Card -->
            <Card>
                <CardContent Class="pt-4 pb-4">
                    <Flex Class="gap-3">
                        <Avatar>
                            <AvatarFallback>ME</AvatarFallback>
                        </Avatar>
                        <Stack Gap="3" Class="flex-1">
                            <Textarea AutoResize="true" MaxRows="6"
                                      Value="@_composeText"
                                      OnInput="@(e => _composeText = e.Value?.ToString() ?? "")"
                                      placeholder="What's on your mind?" />

                            <!-- Tag Combobox (Multiple) -->
                            <Combobox Multiple="true"
                                      @bind-Values="_selectedTags"
                                      Placeholder="Add tags..."
                                      Class="max-w-xs">
                                <ComboboxContent>
                                    <ComboboxItem Value="design">Design</ComboboxItem>
                                    <ComboboxItem Value="engineering">Engineering</ComboboxItem>
                                    <ComboboxItem Value="product">Product</ComboboxItem>
                                    <ComboboxItem Value="announcement">Announcement</ComboboxItem>
                                    <ComboboxItem Value="update">Update</ComboboxItem>
                                </ComboboxContent>
                            </Combobox>

                            <Flex Class="justify-end">
                                <Button IsLoading="@_isPosting" OnClick="HandlePost">
                                    <DynamicIcon Name="Send" Class="h-4 w-4 mr-2" />
                                    Post
                                </Button>
                            </Flex>
                        </Stack>
                    </Flex>
                </CardContent>
            </Card>

            <!-- Feed -->
            <Stack Gap="4">
                @foreach (var post in _posts)
                {
                    var p = post;
                    <Card>
                        <CardHeader>
                            <Flex Class="items-center justify-between">
                                <Flex Class="items-center gap-3">
                                    <Avatar>
                                        <AvatarFallback>@p.AuthorInitials</AvatarFallback>
                                    </Avatar>
                                    <Stack>
                                        <Flex Class="items-center gap-2">
                                            <Lumeo.Text Class="text-sm font-semibold text-foreground">@p.Author</Lumeo.Text>
                                            @if (p.IsNew)
                                            {
                                                <Badge IsDot="true" Variant="Badge.BadgeVariant.Default" />
                                                <Lumeo.Text As="span" Class="text-xs text-primary font-medium">New</Lumeo.Text>
                                            }
                                        </Flex>
                                        <Tooltip ShowDelay="400">
                                            <TooltipTrigger>
                                                <Lumeo.Text Class="text-xs text-muted-foreground cursor-default">@p.TimeAgo</Lumeo.Text>
                                            </TooltipTrigger>
                                            <TooltipContent Side="TooltipContent.TooltipSide.Bottom">
                                                Posted @p.TimeAgo
                                            </TooltipContent>
                                        </Tooltip>
                                    </Stack>
                                </Flex>
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon"
                                        OnClick="@(() => OpenSheet(p))">
                                    <DynamicIcon Name="ExternalLink" Class="h-4 w-4" />
                                </Button>
                            </Flex>
                        </CardHeader>

                        <CardContent Class="space-y-3">
                            <!-- Post Content -->
                            <Lumeo.Text Class="text-sm text-foreground leading-relaxed">@p.Content</Lumeo.Text>

                            <!-- Image Placeholder -->
                            @if (p.HasImage)
                            {
                                <Stack Class="relative bg-muted rounded-lg h-48 overflow-hidden">
                                    <Stack Class="absolute inset-0 bg-gradient-to-br from-muted to-muted-foreground/10" />
                                    <Flex Class="absolute inset-0 items-center justify-center">
                                        <DynamicIcon Name="Image" Class="h-12 w-12 text-muted-foreground/30" />
                                    </Flex>
                                </Stack>
                            }
                        </CardContent>

                        <CardFooter Class="flex items-center justify-between border-t pt-3">
                            <!-- Action Buttons -->
                            <Flex Class="items-center gap-1">
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm"
                                        Class="@(p.IsLiked ? "text-primary" : "")"
                                        OnClick="@(() => ToggleLike(p))">
                                    <DynamicIcon Name="Heart" Class="h-4 w-4 mr-1.5" />
                                    @p.LikeCount
                                </Button>
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                                    <DynamicIcon Name="MessageCircle" Class="h-4 w-4 mr-1.5" />
                                    @p.CommentCount
                                </Button>
                                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                                    <DynamicIcon Name="Share2" Class="h-4 w-4 mr-1.5" />
                                    Share
                                </Button>
                            </Flex>

                            <!-- Who Liked (AvatarGroup) -->
                            @if (p.LikeCount > 0)
                            {
                                <Flex Class="items-center gap-2">
                                    <AvatarGroup Max="3" Total="@p.LikeCount">
                                        @for (var i = 0; i < Math.Min(3, p.LikeCount); i++)
                                        {
                                            var idx = i;
                                            <Avatar Size="Avatar.AvatarSize.Sm" Class="border-2 border-background">
                                                <AvatarFallback Class="text-[10px]">@_likerInitials[idx % _likerInitials.Length]</AvatarFallback>
                                            </Avatar>
                                        }
                                    </AvatarGroup>
                                    <Lumeo.Text As="span" Class="text-xs text-muted-foreground">liked this</Lumeo.Text>
                                </Flex>
                            }
                        </CardFooter>
                    </Card>
                }
            </Stack>

            <!-- Post Detail Sheet -->
            <Sheet @bind-IsOpen="_sheetOpen">
                <SheetContent Size="SheetContent.SheetSize.Lg">
                    @if (_selectedPost is not null)
                    {
                        <SheetHeader>
                            <SheetTitle>Post by @_selectedPost.Author</SheetTitle>
                            <SheetDescription>@_selectedPost.TimeAgo</SheetDescription>
                        </SheetHeader>
                        <Stack Gap="4" Class="mt-4">
                            <Flex Class="items-center gap-3">
                                <Avatar>
                                    <AvatarFallback>@_selectedPost.AuthorInitials</AvatarFallback>
                                </Avatar>
                                <Stack>
                                    <Lumeo.Text Class="text-sm font-semibold text-foreground">@_selectedPost.Author</Lumeo.Text>
                                    <Lumeo.Text Class="text-xs text-muted-foreground">@_selectedPost.TimeAgo</Lumeo.Text>
                                </Stack>
                            </Flex>
                            <Lumeo.Text Class="text-sm text-foreground leading-relaxed">@_selectedPost.Content</Lumeo.Text>
                            <Separator />
                            <Stack Gap="3">
                                <Heading Level="4" Class="text-sm font-medium text-foreground">Comments (@_selectedPost.CommentCount)</Heading>
                                @foreach (var comment in _sampleComments)
                                {
                                    <Flex Class="gap-2">
                                        <Avatar Size="Avatar.AvatarSize.Sm">
                                            <AvatarFallback Class="text-[10px]">@comment.Initials</AvatarFallback>
                                        </Avatar>
                                        <Stack Class="flex-1 rounded-md bg-muted px-3 py-2">
                                            <Lumeo.Text Class="text-xs font-medium text-foreground">@comment.Author</Lumeo.Text>
                                            <Lumeo.Text Class="text-xs text-muted-foreground mt-0.5">@comment.Text</Lumeo.Text>
                                        </Stack>
                                    </Flex>
                                }
                            </Stack>
                        </Stack>
                    }
                </SheetContent>
            </Sheet>

        </Stack>
    </ComponentDemo>

</Stack>

@code {
    private string _composeText = "";
    private bool _isPosting;
    private HashSet<string>? _selectedTags = new();

    // Sheet state
    private bool _sheetOpen;
    private PostItem? _selectedPost;

    private readonly string[] _likerInitials = { "OL", "JK", "SD", "WK", "IN" };

    private class PostItem
    {
        public int Id { get; init; }
        public string Author { get; init; } = "";
        public string AuthorInitials { get; init; } = "";
        public string Content { get; init; } = "";
        public bool HasImage { get; init; }
        public int LikeCount { get; set; }
        public int CommentCount { get; init; }
        public string TimeAgo { get; init; } = "";
        public bool IsNew { get; init; }
        public bool IsLiked { get; set; }
    }

    private record CommentItem(string Author, string Initials, string Text);

    private readonly List<PostItem> _posts = new()
    {
        new() { Id = 1, Author = "Olivia Martin",   AuthorInitials = "OM", Content = "Just shipped our new design system! After 3 months of work, we've standardized colors, spacing, and typography across all products. Huge thanks to the team for pushing through.", HasImage = true,  LikeCount = 14, CommentCount = 8,  TimeAgo = "2 hours ago", IsNew = true  },
        new() { Id = 2, Author = "Jackson Lee",     AuthorInitials = "JL", Content = "Interesting findings from our latest user research session — turns out 70% of users never scroll past the fold on mobile. Time to rethink our information architecture.",         HasImage = false, LikeCount = 22, CommentCount = 12, TimeAgo = "5 hours ago", IsNew = false },
        new() { Id = 3, Author = "Sofia Davis",     AuthorInitials = "SD", Content = "Pro tip: use CSS container queries instead of media queries for truly component-level responsiveness. Game changer for library development.",                                     HasImage = true,  LikeCount = 9,  CommentCount = 4,  TimeAgo = "Yesterday",   IsNew = true  },
        new() { Id = 4, Author = "Isabella Nguyen", AuthorInitials = "IN", Content = "We crossed 10,000 GitHub stars today! Thank you to everyone who has contributed, filed issues, and spread the word. This milestone means everything to us.",                   HasImage = false, LikeCount = 47, CommentCount = 21, TimeAgo = "2 days ago",  IsNew = false },
    };

    private readonly List<CommentItem> _sampleComments = new()
    {
        new("William Kim",    "WK", "This is incredible work! Congrats to the whole team."),
        new("Liam Johnson",   "LJ", "How did you handle theming? Did you go with CSS variables?"),
        new("Emma Wilson",    "EW", "Looking forward to migrating our codebase to this."),
    };

    private async Task HandlePost()
    {
        if (string.IsNullOrWhiteSpace(_composeText)) return;
        _isPosting = true;
        await Task.Delay(1500);
        _composeText = "";
        _selectedTags = new();
        _isPosting = false;
    }

    private void ToggleLike(PostItem post)
    {
        if (post.IsLiked)
        {
            post.IsLiked = false;
            post.LikeCount--;
        }
        else
        {
            post.IsLiked = true;
            post.LikeCount++;
        }
    }

    private void OpenSheet(PostItem post)
    {
        _selectedPost = post;
        _sheetOpen = true;
    }

    private string _socialFeedCode = @"<!-- Compose Card -->
<Card>
    <CardContent>
        <Flex Gap=""3"">
            <Avatar><AvatarFallback>ME</AvatarFallback></Avatar>
            <Stack Gap=""3"" Class=""flex-1"">
                <Textarea AutoResize=""true"" MaxRows=""6""
                          Value=""@_composeText""
                          OnInput=""@(e => _composeText = e.Value?.ToString() ?? """")"" />

                <!-- Tag Combobox (Multiple) -->
                <Combobox Multiple=""true"" @bind-Values=""_selectedTags"" Placeholder=""Add tags..."" Class=""max-w-xs"">
                    <ComboboxContent>
                        <ComboboxItem Value=""design"">Design</ComboboxItem>
                        <ComboboxItem Value=""engineering"">Engineering</ComboboxItem>
                        <ComboboxItem Value=""product"">Product</ComboboxItem>
                        <ComboboxItem Value=""announcement"">Announcement</ComboboxItem>
                        <ComboboxItem Value=""update"">Update</ComboboxItem>
                    </ComboboxContent>
                </Combobox>

                <Button Variant=""Button.ButtonVariant.Default"" IsLoading=""@_isPosting"" OnClick=""HandlePost"">
                    <DynamicIcon Name=""Send"" Class=""h-4 w-4 mr-2"" />
                    Post
                </Button>
            </Stack>
        </Flex>
    </CardContent>
</Card>

<!-- Post Card -->
@foreach (var post in _posts)
{
    <Card>
        <CardHeader>
            <Flex Align=""center"" Justify=""between"">
                <Flex Align=""center"" Gap=""3"">
                    <Avatar><AvatarFallback>@post.AuthorInitials</AvatarFallback></Avatar>
                    <Stack Gap=""0"">
                        <Flex Align=""center"" Gap=""2"">
                            <Lumeo.Text Class=""text-sm font-semibold text-foreground"">@post.Author</Lumeo.Text>
                            @if (post.IsNew)
                            {
                                <Badge IsDot=""true"" />
                                <Lumeo.Text As=""span"" Class=""text-xs text-primary font-medium"">New</Lumeo.Text>
                            }
                        </Flex>
                        <!-- Tooltip with delay -->
                        <Tooltip ShowDelay=""400"">
                            <TooltipTrigger>
                                <Lumeo.Text Class=""text-xs text-muted-foreground cursor-default"">@post.TimeAgo</Lumeo.Text>
                            </TooltipTrigger>
                            <TooltipContent Side=""TooltipContent.TooltipSide.Bottom"">
                                Posted @post.TimeAgo
                            </TooltipContent>
                        </Tooltip>
                    </Stack>
                </Flex>
                <!-- Opens Sheet -->
                <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon"" OnClick=""@(() => OpenSheet(post))"">
                    <DynamicIcon Name=""ExternalLink"" Class=""h-4 w-4"" />
                </Button>
            </Flex>
        </CardHeader>
        <CardContent Class=""space-y-3"">
            <Lumeo.Text Class=""text-sm text-foreground leading-relaxed"">@post.Content</Lumeo.Text>
            <!-- Image placeholder -->
            <Stack Class=""relative bg-muted rounded-lg h-48 overflow-hidden"" Gap=""0"">
                <Stack Class=""absolute inset-0 bg-gradient-to-br from-muted to-muted-foreground/10"" />
                <Flex Class=""absolute inset-0 items-center justify-center"">
                    <DynamicIcon Name=""Image"" Class=""h-10 w-10 text-muted-foreground/40"" />
                </Flex>
            </Stack>
        </CardContent>
        <CardFooter Class=""flex items-center justify-between border-t pt-3"">
            <Flex Align=""center"" Gap=""1"">
                <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"" OnClick=""@(() => ToggleLike(post))"">
                    <DynamicIcon Name=""Heart"" Class=""h-4 w-4 mr-1.5"" />
                    @post.LikeCount
                </Button>
                <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"">
                    <DynamicIcon Name=""MessageCircle"" Class=""h-4 w-4 mr-1.5"" />
                    @post.CommentCount
                </Button>
                <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"">
                    <DynamicIcon Name=""Share2"" Class=""h-4 w-4 mr-1.5"" />
                    Share
                </Button>
            </Flex>
            <!-- AvatarGroup -->
            <AvatarGroup Max=""3"" Total=""@post.LikeCount"">
                <Avatar Size=""Avatar.AvatarSize.Sm"" Class=""border-2 border-background"">
                    <AvatarFallback Class=""text-[10px]"">OL</AvatarFallback>
                </Avatar>
                <!-- ... more avatars -->
            </AvatarGroup>
        </CardFooter>
    </Card>
}

<!-- Detail Sheet -->
<Sheet @bind-IsOpen=""_sheetOpen"">
    <SheetContent Size=""SheetContent.SheetSize.Lg"">
        <SheetHeader>
            <SheetTitle>Post Details</SheetTitle>
            <SheetDescription>@_selectedPost?.TimeAgo</SheetDescription>
        </SheetHeader>
        <Stack Gap=""4"" Class=""mt-4"">
            <Lumeo.Text Class=""text-sm text-foreground"">@_selectedPost?.Content</Lumeo.Text>
            <Separator />
            <Heading Level=""4"" Class=""text-sm font-medium"">Comments</Heading>
            <!-- comment items ... -->
        </Stack>
    </SheetContent>
</Sheet>";
}
