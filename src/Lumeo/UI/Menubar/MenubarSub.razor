@namespace Lumeo
@implements IDisposable

@{
    var subContext = new MenubarSubContext(
        _open,
        EventCallback.Factory.Create<bool>(this, SetOpen),
        _wrapperId,
        _triggerId,
        _contentId,
        EventCallback.Factory.Create(this, CloseTree),
        ScheduleClose,
        CancelClose);
}

<CascadingValue Value="subContext" IsFixed="false">
    <div id="@_wrapperId" class="relative" @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [CascadingParameter] public Menubar.MenubarContext? RootContext { get; set; }
    // The owning menu (IsFixed cascade from MenubarMenu). Comparing its MenuId to the
    // menubar's OpenMenuId tells us when THIS menu is no longer the open one.
    [CascadingParameter] public MenubarMenu.MenubarMenuContext? MenuContext { get; set; }
    [CascadingParameter] public MenubarSubContext? ParentSubContext { get; set; }
    /// <summary>The submenu's trigger and content, typically a <see cref="MenubarSubTrigger"/> and <see cref="MenubarSubContent"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the submenu's wrapper <c>&lt;div&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _open;
    private readonly string _wrapperId = LumeoIds.New("menubar-sub");
    internal readonly string _triggerId = LumeoIds.New("menubar-sub-trigger");
    internal readonly string _contentId = LumeoIds.New("menubar-sub-content");

    private CancellationTokenSource? _closeCts;

    // Submenu teardown on ancestor exit (Codex/CodeRabbit P2): when this menu stops
    // being the menubar's open menu (switched to another menu or the whole menubar
    // closed), or an enclosing submenu closes, its own _open stayed true — leaving the
    // submenu mounted with data-state="open" under a parent that is already exiting.
    // Reset our state so the submenu exits/unmounts with the tree. The MenubarContext
    // cascade (IsFixed=false) re-renders this component when OpenMenuId flips.
    protected override void OnParametersSet()
    {
        var menuClosed = RootContext is not null && MenuContext is not null
            && RootContext.OpenMenuId != MenuContext.MenuId;
        var ancestorClosed = menuClosed || ParentSubContext is { IsOpen: false };
        if (ancestorClosed && _open)
        {
            CancelClose();
            _open = false;
        }
    }

    private async Task SetOpen(bool value)
    {
        if (_open == value) return;
        _open = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseTree()
    {
        await SetOpen(false);
        if (ParentSubContext is not null)
        {
            await ParentSubContext.CloseTree.InvokeAsync();
        }
        else if (RootContext is not null)
        {
            await RootContext.SetOpenMenuId.InvokeAsync(null);
        }
    }

    private void CancelClose()
    {
        try { _closeCts?.Cancel(); } catch (ObjectDisposedException) { }
        _closeCts?.Dispose();
        _closeCts = null;
    }

    private void ScheduleClose()
    {
        CancelClose();
        _closeCts = new CancellationTokenSource();
        var token = _closeCts.Token;
        _ = Task.Run(async () =>
        {
            try { await Task.Delay(200, token); }
            catch (TaskCanceledException) { return; }
            if (token.IsCancellationRequested) return;
            // The component may have been disposed (and the dispatcher torn down)
            // between the delay elapsing and this continuation running. Swallow the
            // resulting ObjectDisposedException so the leaked timer cannot fault the
            // background task or call StateHasChanged on a dead component.
            try
            {
                await InvokeAsync(async () => await SetOpen(false));
            }
            catch (ObjectDisposedException) { }
        });
    }

    public void Dispose()
    {
        // Cancel + dispose any pending close timer so it cannot fire SetOpen
        // (StateHasChanged) after this component has been unmounted mid-delay.
        CancelClose();
    }

    public record MenubarSubContext(
        bool IsOpen,
        EventCallback<bool> SetOpen,
        string WrapperId,
        string TriggerId,
        string ContentId,
        EventCallback CloseTree,
        Action ScheduleClose,
        Action CancelClose);
}
