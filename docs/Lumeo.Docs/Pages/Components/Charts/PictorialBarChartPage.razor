                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MarkArea</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EChartMarkArea?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Optional shaded mark areas highlighting value bands.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Mon", "Tue", "Wed", "Thu", "Fri" };
    private List<PictorialBarChart.PictorialSeriesData> _series = new()
    {
        new() { Name = "Daily Steps", Values = new() { 8420, 6130, 9870, 7280, 11340 }, Symbol = "circle", SymbolSize = 25 }
    };

    private string _basicCode = @"<PictorialBarChart Categories=""_categories"" Series=""_series"" />";

    private bool _loading;
    private bool _keepLoading;
    private bool LoadingComputed => _loading || _keepLoading;
    private int _simulateDurationMs = 2000;
    private int _phantomCycleMs = 1400;

    private async Task SimulateLoadingAsync()
    {
        _loading = true;
        await Task.Delay(_simulateDurationMs);
        _loading = false;
    }
}
