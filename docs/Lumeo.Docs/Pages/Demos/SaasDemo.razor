        var state = active
            ? "bg-sidebar-accent text-sidebar-accent-foreground font-medium"
            : "text-muted-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground";
        return $"flex w-full items-center overflow-hidden rounded-lg text-sm transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1 {layout} {state}";
    }

    private void SetView(string key)
    {
        _view = key;
        _nameError = null;
        _emailError = null;
