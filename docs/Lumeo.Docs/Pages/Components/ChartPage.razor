@page "/components/chart"

<PageTitle>Chart — Lumeo</PageTitle>

<PageHeader Title="Charts" Description="Beautiful charts built on Apache ECharts. Lumeo includes 30 chart components for every visualization need, from basic bar charts to advanced geographic maps and word clouds." />

<Stack Gap="10">
    <!-- Cartesian Charts -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Cartesian Charts</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Standard X/Y axis charts for comparing categories, tracking trends, and analyzing distributions.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/bar" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Bar Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Compare discrete categories side-by-side.</p>
            </a>
            <a href="/components/charts/line" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Line Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Show trends over time with continuous lines.</p>
            </a>
            <a href="/components/charts/area" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Area Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Emphasize volume and magnitude of change.</p>
            </a>
            <a href="/components/charts/scatter" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Scatter Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Reveal correlations between two variables.</p>
            </a>
            <a href="/components/charts/effect-scatter" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Effect Scatter</h3>
                <p class="text-sm text-muted-foreground mt-1">Animated scatter with ripple effects.</p>
            </a>
            <a href="/components/charts/candlestick" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Candlestick Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Financial OHLC data visualization.</p>
            </a>
            <a href="/components/charts/boxplot" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">BoxPlot Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Statistical distribution through quartiles.</p>
            </a>
            <a href="/components/charts/waterfall" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Waterfall Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Sequential positive and negative changes.</p>
            </a>
            <a href="/components/charts/pictorial-bar" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Pictorial Bar</h3>
                <p class="text-sm text-muted-foreground mt-1">Bar chart with custom symbol shapes.</p>
            </a>
            <a href="/components/charts/mixed" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Mixed Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Combine bar and line in one view.</p>
            </a>
        </Grid>
    </div>

    <!-- Proportional / Distribution -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Proportional &amp; Distribution</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Charts for showing parts of a whole, proportions, and data distributions.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/pie" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Pie Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Proportional distribution across categories.</p>
            </a>
            <a href="/components/charts/donut" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Donut Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Pie chart with center cutout for labels.</p>
            </a>
            <a href="/components/charts/nightingale" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Nightingale Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Rose-type pie with varying radii.</p>
            </a>
            <a href="/components/charts/funnel" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Funnel Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Sequential stages with drop-off rates.</p>
            </a>
        </Grid>
    </div>

    <!-- Radial / Polar -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Radial &amp; Polar</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Charts using polar coordinate systems and circular layouts.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/radar" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Radar Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Compare multiple variables on a common scale.</p>
            </a>
            <a href="/components/charts/radial" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Radial Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Gauge arc for KPIs and progress.</p>
            </a>
            <a href="/components/charts/gauge" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Gauge Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Speedometer with pointer and color zones.</p>
            </a>
            <a href="/components/charts/polar-bar" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Polar Bar Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Bar data in polar coordinates.</p>
            </a>
            <a href="/components/charts/liquid-fill" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Liquid Fill</h3>
                <p class="text-sm text-muted-foreground mt-1">Animated liquid fill percentage display.</p>
            </a>
        </Grid>
    </div>

    <!-- Hierarchical -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Hierarchical</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Visualize nested and tree-structured data.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/treemap" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Treemap Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Nested rectangles proportional to values.</p>
            </a>
            <a href="/components/charts/sunburst" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Sunburst Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Concentric rings for hierarchical data.</p>
            </a>
            <a href="/components/charts/tree" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Tree Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Org charts and tree structures.</p>
            </a>
        </Grid>
    </div>

    <!-- Relationship / Flow -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Relationship &amp; Flow</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Visualize connections, networks, and flow between entities.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/graph" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Graph Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Network and relationship visualization.</p>
            </a>
            <a href="/components/charts/sankey" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Sankey Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Flow diagrams with proportional links.</p>
            </a>
            <a href="/components/charts/parallel" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Parallel Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Multi-dimensional data across parallel axes.</p>
            </a>
        </Grid>
    </div>

    <!-- Specialized -->
    <div>
        <Heading Level="2" Class="text-xl mb-1">Specialized</Heading>
        <Lumeo.Text Size="sm" Color="muted" Class="mb-4">Purpose-built charts for specific use cases.</Lumeo.Text>
        <Grid Columns="3" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <a href="/components/charts/heatmap" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Heatmap Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Density and intensity across two dimensions.</p>
            </a>
            <a href="/components/charts/calendar-heatmap" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Calendar Heatmap</h3>
                <p class="text-sm text-muted-foreground mt-1">GitHub-style contribution calendar.</p>
            </a>
            <a href="/components/charts/theme-river" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Theme River</h3>
                <p class="text-sm text-muted-foreground mt-1">Flowing streams showing thematic changes.</p>
            </a>
            <a href="/components/charts/geo-map" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Geo Map Chart</h3>
                <p class="text-sm text-muted-foreground mt-1">Data on geographic maps with GeoJSON.</p>
            </a>
            <a href="/components/charts/word-cloud" class="group rounded-lg border border-border/60 p-4 hover:border-primary/60 hover:bg-muted/30 transition-colors">
                <h3 class="font-medium text-foreground group-hover:text-primary">Word Cloud</h3>
                <p class="text-sm text-muted-foreground mt-1">Text weighted by frequency or importance.</p>
            </a>
        </Grid>
    </div>

    <!-- API Reference -->
    <Stack Gap="6" Class="mt-12">
        <Heading Level="2">API Reference</Heading>
        <Stack Gap="8">
            <div>
                <Heading Level="3" Class="mb-3">Chart</Heading>
                <div class="rounded-lg border border-border overflow-hidden">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b bg-muted/40">
                                <th class="text-left p-3 font-medium text-foreground">Property</th>
                                <th class="text-left p-3 font-medium text-foreground">Type</th>
                                <th class="text-left p-3 font-medium text-foreground">Default</th>
                                <th class="text-left p-3 font-medium text-foreground">Description</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border/40">
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Option</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EChartOption?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Strongly-typed ECharts option object. Use this or OptionJson.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OptionJson</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Raw ECharts option JSON string. Takes precedence over Option when set.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Width</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">"100%"</td>
                                <td class="p-3 text-muted-foreground">CSS width of the chart container.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Height</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">"350px"</td>
                                <td class="p-3 text-muted-foreground">CSS height of the chart container. Ignored when AspectRatio is set.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">AspectRatio</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">CSS aspect-ratio value (e.g. "16/9"). When set, Height is ignored.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Theme</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">ECharts theme name to apply (e.g. "dark").</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">ShowLoading</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                                <td class="p-3 text-muted-foreground">Shows a loading overlay over the chart.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">Group</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Group name for linking multiple charts so they synchronize tooltips and zooming.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">EChartsSource</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Custom CDN URL for the ECharts JS bundle. Defaults to the bundled version.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OnClick</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChartEventArgs&gt;</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Fired when a data point is clicked.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OnMouseOver</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChartEventArgs&gt;</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Fired when the pointer moves over a data point.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OnDoubleClick</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChartEventArgs&gt;</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Fired when a data point is double-clicked.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OnBrushSelected</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChartEventArgs&gt;</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Fired when a brush selection is completed.</td>
                            </tr>
                            <tr>
                                <td class="p-3 font-mono text-xs text-primary">OnDataZoom</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;ChartEventArgs&gt;</td>
                                <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                                <td class="p-3 text-muted-foreground">Fired when the chart is zoomed or panned via a dataZoom component.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </Stack>
    </Stack>
</Stack>
