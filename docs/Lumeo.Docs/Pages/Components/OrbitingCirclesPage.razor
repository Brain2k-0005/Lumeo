@page "/components/orbiting-circles"

<PageTitle>OrbitingCircles — Lumeo</PageTitle>

<PageHeader Title="OrbitingCircles"
            Description="Renders icons on circular orbital paths around a central element. Nest OrbitItem children inside the ChildContent slot — they auto-distribute evenly around the ring." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Hero sections showing an ecosystem of tools orbiting a central product logo.</li>
        <li>Feature spotlights where supporting icons rotate around a core concept.</li>
        <li>Loading spinners or animated decorative rings.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Three Icons — Single Ring" Code="@_basicCode">
        <div class="flex items-center justify-center py-12">
            <OrbitingCircles Radius="90" DurationMs="16000" Size="240">
                <CenterContent>
                    <div class="flex items-center justify-center w-14 h-14 rounded-full bg-primary/10 border border-primary/30 shadow-sm">
                        <Blazicon Svg="Lucide.Zap" class="h-7 w-7 text-primary" />
                    </div>
                </CenterContent>
                <ChildContent>
                    <OrbitItem>
                        <div class="flex items-center justify-center w-9 h-9 rounded-full bg-card border border-border/60 shadow-sm">
                            <Blazicon Svg="Lucide.Star" class="h-4 w-4 text-primary" />
                        </div>
                    </OrbitItem>
                    <OrbitItem>
                        <div class="flex items-center justify-center w-9 h-9 rounded-full bg-card border border-border/60 shadow-sm">
                            <Blazicon Svg="Lucide.Sparkles" class="h-4 w-4 text-primary" />
                        </div>
                    </OrbitItem>
                    <OrbitItem>
                        <div class="flex items-center justify-center w-9 h-9 rounded-full bg-card border border-border/60 shadow-sm">
                            <Blazicon Svg="Lucide.Globe" class="h-4 w-4 text-primary" />
                        </div>
                    </OrbitItem>
                </ChildContent>
            </OrbitingCircles>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Two Rings — Inner &amp; Outer" Code="@_twoRingCode">
        <div class="flex items-center justify-center py-12">
            <div class="relative" style="width:300px;height:300px;">
                @* Inner ring — 2 icons, faster *@
                <OrbitingCircles Radius="70" DurationMs="12000" Size="300" Class="absolute inset-0" ShowPath="false">
                    <CenterContent>
                        <div class="flex items-center justify-center w-16 h-16 rounded-2xl bg-primary shadow-md">
                            <Blazicon Svg="Lucide.Layers" class="h-8 w-8 text-primary-foreground" />
                        </div>
                    </CenterContent>
                    <ChildContent>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-9 h-9 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.Bell" class="h-4 w-4 text-amber-500" />
                            </div>
                        </OrbitItem>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-9 h-9 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.Shield" class="h-4 w-4 text-blue-500" />
                            </div>
                        </OrbitItem>
                    </ChildContent>
                </OrbitingCircles>
                @* Outer ring — 4 icons, slower, reversed *@
                <OrbitingCircles Radius="130" DurationMs="22000" Reverse="true" Size="300" Class="absolute inset-0">
                    <ChildContent>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.Globe" class="h-5 w-5 text-green-500" />
                            </div>
                        </OrbitItem>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.Star" class="h-5 w-5 text-violet-500" />
                            </div>
                        </OrbitItem>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.Mail" class="h-5 w-5 text-pink-500" />
                            </div>
                        </OrbitItem>
                        <OrbitItem>
                            <div class="flex items-center justify-center w-10 h-10 rounded-full bg-card border border-border/60 shadow-sm">
                                <Blazicon Svg="Lucide.FolderOpen" class="h-5 w-5 text-orange-500" />
                            </div>
                        </OrbitItem>
                    </ChildContent>
                </OrbitingCircles>
            </div>
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">OrbitingCircles</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">CenterContent</td><td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Content placed at the center (logo, icon).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ChildContent</td><td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Nest <code class="text-xs">&lt;OrbitItem&gt;</code> elements — they auto-distribute evenly.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Radius</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">80</td><td class="p-3 text-muted-foreground">Orbit radius in pixels (center-to-icon distance).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">DurationMs</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">20000</td><td class="p-3 text-muted-foreground">Duration of one full revolution in ms.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Reverse</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Reverses direction of orbit.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ShowPath</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Shows the circular orbit guide ring.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Size</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">240</td><td class="p-3 text-muted-foreground">Container diameter in pixels. Should be &gt;= 2×Radius + icon size.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">OrbitItem</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">ChildContent</td><td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">The icon or element to orbit.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/animated-beam" class="text-primary hover:underline">AnimatedBeam</a> — Animated SVG beam between two elements.</li>
        <li><a href="/components/ripple" class="text-primary hover:underline">Ripple</a> — Concentric expanding ring animation.</li>
    </ul>
</div>

@code {
    private const string _basicCode =
@"<OrbitingCircles Radius=""90"" DurationMs=""16000"" Size=""240"">
    <CenterContent>
        <div class=""w-14 h-14 rounded-full bg-primary/10 border border-primary/30 flex items-center justify-center"">
            <Blazicon Svg=""Lucide.Zap"" class=""h-7 w-7 text-primary"" />
        </div>
    </CenterContent>
    <ChildContent>
        <OrbitItem>
            <div class=""w-9 h-9 rounded-full bg-card border border-border/60 flex items-center justify-center"">
                <Blazicon Svg=""Lucide.Star"" class=""h-4 w-4 text-primary"" />
            </div>
        </OrbitItem>
        <OrbitItem>...</OrbitItem>
        <OrbitItem>...</OrbitItem>
    </ChildContent>
</OrbitingCircles>";

    private const string _twoRingCode =
@"@* Inner ring *@
<OrbitingCircles Radius=""70"" DurationMs=""12000"" Size=""300"">
    <CenterContent>...</CenterContent>
    <ChildContent>
        <OrbitItem>...</OrbitItem>
        <OrbitItem>...</OrbitItem>
    </ChildContent>
</OrbitingCircles>
@* Outer ring — reversed *@
<OrbitingCircles Radius=""130"" DurationMs=""22000"" Reverse=""true"" Size=""300"">
    <ChildContent>
        <OrbitItem>...</OrbitItem>
        <OrbitItem>...</OrbitItem>
        <OrbitItem>...</OrbitItem>
        <OrbitItem>...</OrbitItem>
    </ChildContent>
</OrbitingCircles>";
}
