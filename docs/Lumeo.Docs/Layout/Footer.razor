@namespace Lumeo.Docs.Layout
@inject Lumeo.Services.ConsentService Consent

@* Site-wide footer. Reachable from every non-playground route so the Privacy
   policy and a consent re-open surface are always one click away — GDPR requires
   consent to be as easy to withdraw/change as it was to give. The "Cookie
   settings" button calls ConsentService.RequestOpenPreferences(); the always-
   mounted <ConsentBanner> in MainLayout listens and pops its dialog, even after
   the banner itself was dismissed. Extra bottom padding on mobile clears the
   fixed BottomNav. *@
<footer class="border-t border-border/40 mt-16 pb-24 lg:pb-10">
    <div class="container mx-auto px-4 sm:px-6 py-10">
        <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="flex items-center gap-2 text-sm text-muted-foreground">
                <svg width="20" height="20" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="16" cy="16" r="9" fill="none" stroke="currentColor" stroke-width="2" opacity="0.55" />
                    <circle cx="16" cy="16" r="3" fill="currentColor" />
                </svg>
                <span>&copy; @DateTime.UtcNow.Year Lumeo &middot; MIT</span>
            </div>

            <nav class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm" aria-label="Footer">
                <Lumeo.Link Href="/docs/introduction" Class="text-muted-foreground hover:text-foreground no-underline transition-colors">Docs</Lumeo.Link>
                <Lumeo.Link Href="/components" Class="text-muted-foreground hover:text-foreground no-underline transition-colors">Components</Lumeo.Link>
                <Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo" Class="text-muted-foreground hover:text-foreground no-underline transition-colors">GitHub</Lumeo.Link>
                <Lumeo.Link Href="/privacy" Class="text-muted-foreground hover:text-foreground no-underline transition-colors">Privacy</Lumeo.Link>
                <button type="button"
                        data-testid="footer-cookie-settings"
                        class="text-muted-foreground hover:text-foreground transition-colors focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2 rounded-sm"
                        @onclick="() => Consent.RequestOpenPreferences()">
                    Cookie settings
                </button>
            </nav>
        </div>
    </div>
</footer>
