@page "/components/transfer"

<PageTitle>Transfer — Lumeo</PageTitle>

<PageHeader Title="Transfer" Description="A dual-panel list for moving items between source and target collections." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Transfer" Code="@_codeBasic">
        <Transfer @bind-SourceItems="_source" @bind-TargetItems="_target"
                  SourceTitle="Available" TargetTitle="Selected" />
    </ComponentDemo>

    <ComponentDemo Title="With Search" Code="@_codeSearch">
        <Transfer @bind-SourceItems="_source2" @bind-TargetItems="_target2"
                  SourceTitle="Users" TargetTitle="Team"
                  ShowSearch="true" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2" Class="text-2xl font-bold text-foreground">API Reference</Heading>
    <Stack Class="rounded-lg border border-border overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr><td class="p-3 font-mono text-xs text-primary">SourceItems</td><td class="p-3 font-mono text-xs text-muted-foreground">List&lt;TransferItem&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Items in the source panel.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">TargetItems</td><td class="p-3 font-mono text-xs text-muted-foreground">List&lt;TransferItem&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Items in the target panel.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">SourceTitle</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">"Source"</td><td class="p-3 text-muted-foreground">Source panel heading.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">TargetTitle</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">"Target"</td><td class="p-3 text-muted-foreground">Target panel heading.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">ShowSearch</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Show search input in both panels.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">OnChange</td><td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;TransferChangeEventArgs&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Fired when items are moved between panels.</td></tr>
            </tbody>
        </table>
    </Stack>
</Stack>

@code {
    private List<Transfer.TransferItem> _source = new()
    {
        new("HTML", "html"), new("CSS", "css"), new("JavaScript", "js"),
        new("TypeScript", "ts"), new("C#", "csharp"), new("Python", "python"),
    };
    private List<Transfer.TransferItem> _target = new()
    {
        new("Blazor", "blazor"), new("React", "react"),
    };

    private List<Transfer.TransferItem> _source2 = new()
    {
        new("Alice", "alice"), new("Bob", "bob"), new("Charlie", "charlie"),
        new("Diana", "diana"), new("Eve", "eve"),
    };
    private List<Transfer.TransferItem> _target2 = new()
    {
        new("Frank", "frank"),
    };

    private string _codeBasic = @"<Transfer @bind-SourceItems=""_source"" @bind-TargetItems=""_target""
          SourceTitle=""Available"" TargetTitle=""Selected"" />";

    private string _codeSearch = @"<Transfer @bind-SourceItems=""_source"" @bind-TargetItems=""_target""
          SourceTitle=""Users"" TargetTitle=""Team"" ShowSearch=""true"" />";
}
