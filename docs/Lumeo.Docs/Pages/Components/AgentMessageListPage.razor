@code {
    private string _agentRole = "Assistant";
    private AgentMessage.AgentMessageRole _agentRoleEnum =>
        Enum.TryParse<AgentMessage.AgentMessageRole>(_agentRole, out var r) ? r : AgentMessage.AgentMessageRole.Assistant;

    private const string _roleSwitcherCode = """
<Segmented @bind-Value="_role">
    <SegmentedItem Value="User">User</SegmentedItem>
    <SegmentedItem Value="Assistant">Assistant</SegmentedItem>
    <SegmentedItem Value="System">System</SegmentedItem>
    <SegmentedItem Value="Tool">Tool</SegmentedItem>
</Segmented>
<AgentMessageList>
    <AgentMessage Role="@Enum.Parse<AgentMessage.AgentMessageRole>(_role)"
                  Name="@(_role == "User" ? "You" : _role == "Assistant" ? "Copilot" : null)">
        This is a @_role message.
    </AgentMessage>
</AgentMessageList>

@code { private string _role = "Assistant"; }
""";

    private string? _promptValue;
    private string _streamedText = "The fastest grower was DACH at +18% YoY, driven mainly by…";
    private bool _isStreaming;

    private System.Threading.Timer? _timer;
    private static readonly string[] _chunks =
    {
        " enterprise licenses", " from two", " Fortune-500 accounts", ". UK grew +11%", ", Nordics held flat", ", and Iberia slipped", " -3% after a channel reshuffle."
    };
    private int _chunkIndex;

    protected override void OnInitialized()
    {
        _timer = new System.Threading.Timer(_ =>
        {
            if (!_isStreaming) return;
            if (_chunkIndex < _chunks.Length)
            {
                _streamedText += _chunks[_chunkIndex++];
                InvokeAsync(StateHasChanged);
            }
            else
            {
                _isStreaming = false;
                _chunkIndex = 0;
                InvokeAsync(StateHasChanged);
            }
        }, null, dueTime: System.Threading.Timeout.Infinite, period: 600);
    }

    private void HandleSend(string value)
    {
        if (string.IsNullOrWhiteSpace(value)) return;
        _promptValue = string.Empty;
        _streamedText = $"Received: \"{value}\". Let me pull the numbers…";
        _chunkIndex = 0;
        _isStreaming = true;
        _timer?.Change(0, 600);
    }

    // ── Actions / branches / export demo state ──────────────────────────────
    private int _branchIndex;
    private readonly string[] _branches =
    {
        "\"Do more, faster.\"",
        "\"Your day, organized.\"",
        "\"Focus on what matters.\"",
    };

    private void Regenerate() =>
        _branchIndex = (_branchIndex + 1) % _branches.Length;

    private async Task ExportMarkdown()
    {
        var md = AgentMessageList.ToMarkdown(new[]
        {
            new AgentMessageList.AgentMessageMarkdown(
                AgentMessage.AgentMessageRole.User, "Give me a tagline for a productivity app.", Name: "You"),
            new AgentMessageList.AgentMessageMarkdown(
                AgentMessage.AgentMessageRole.Assistant, _branches[_branchIndex], Name: "Copilot"),
        }, title: "Conversation");

        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(md));
        await Interop.DownloadFile("conversation.md", base64, "text/markdown");
    }

    private const string _actionsCode = """
<AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Copilot">
    <ChildContent>@_branches[_branchIndex]</ChildContent>
    <Actions>
        <AgentMessageBranchNav @bind-Index="_branchIndex" Count="_branches.Length" />
        <AgentMessageActions CopyText="@_branches[_branchIndex]" OnRegenerate="Regenerate" />
    </Actions>
</AgentMessage>

@code {
    // Export the thread to Markdown, then hand the bytes to the download helper.
    var md = AgentMessageList.ToMarkdown(messages, title: "Conversation");
    await Interop.DownloadFile("conversation.md",
        Convert.ToBase64String(Encoding.UTF8.GetBytes(md)), "text/markdown");
}
""";

    private const string _emptyCode = """
<AgentMessageList IsEmpty="@(_messages.Count == 0)">
    <EmptyState>
        <Icon Name="MessageCircle" Size="Lumeo.Size.Lg" Class="text-muted-foreground" />
        <p class="text-sm font-medium">No messages yet</p>
        <p class="text-sm text-muted-foreground">Ask a question to get started.</p>
    </EmptyState>
</AgentMessageList>
""";

    public void Dispose() => _timer?.Dispose();

    private const string _demoCode = """
<AgentMessageList Class="flex-1">
    <AgentMessage Role="AgentMessage.AgentMessageRole.User" Name="You">
        Summarise the quarterly revenue for EMEA.
    </AgentMessage>
    <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Copilot" IsStreaming="@_isStreaming">
        <StreamingText Text="@_streamedText" IsStreaming="@_isStreaming" />
    </AgentMessage>
</AgentMessageList>

<PromptInput @bind-Value="_prompt" OnSend="HandleSend" IsLoading="@_isStreaming" />
""";

    private const string _rolesCode = """
<AgentMessageList>
    <AgentMessage Role="AgentMessage.AgentMessageRole.System">
        System notice.
    </AgentMessage>
    <AgentMessage Role="AgentMessage.AgentMessageRole.User" Name="Alice">
        A user turn.
    </AgentMessage>
    <AgentMessage Role="AgentMessage.AgentMessageRole.Assistant" Name="Assistant">
        An assistant turn.
    </AgentMessage>
