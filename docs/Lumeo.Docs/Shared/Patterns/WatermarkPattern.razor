@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic Watermark" Code="@_codeBasic">
    <Watermark Text="Lumeo" Class="h-40 w-full rounded-lg border border-border bg-background flex items-center justify-center">
        <Lumeo.Text Color="muted">Content with watermark overlay</Lumeo.Text>
    </Watermark>
</PatternCard>

<PatternCard Label="Custom Rotation" Code="@_codeCustom">
    <Watermark Text="CONFIDENTIAL" Rotation="-30" FontSize="16" Opacity="0.08" Class="h-40 w-full rounded-lg border border-border bg-background flex items-center justify-center">
        <Lumeo.Text Color="muted">Confidential document</Lumeo.Text>
    </Watermark>
</PatternCard>
</Stack>

@code {
    private string _codeBasic = @"<Watermark Text=""Lumeo"">
    <p>Content with watermark overlay</Lumeo.Text>
</Watermark>";

    private string _codeCustom = @"<Watermark Text=""CONFIDENTIAL"" Rotation=""-30"" FontSize=""16"" Opacity=""0.08"">
    <p>Confidential document</Lumeo.Text>
</Watermark>";
}
