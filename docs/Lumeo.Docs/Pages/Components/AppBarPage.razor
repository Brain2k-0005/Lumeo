    private bool _appBarBordered = true;
    private string _appearanceInteractiveCode = @"<Switch @bind-Checked=""_elevated"" />
<Switch @bind-Checked=""_bordered"" />
<AppBar Elevated=""@_elevated"" Bordered=""@_bordered"">
