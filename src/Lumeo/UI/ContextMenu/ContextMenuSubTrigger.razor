@namespace Lumeo

<button id="@SubContext.TriggerId"
        type="button"
        role="menuitem"
        tabindex="-1"
        class="@CssClass"
        data-state="@(SubContext.IsOpen ? "open" : "closed")"
        aria-haspopup="menu"
        aria-expanded="@SubContext.IsOpen.ToString().ToLower()"
        aria-controls="@SubContext.ContentId"
        disabled="@Disabled"
        aria-disabled="@(Disabled ? "true" : null)"
        @onclick="HandleClick"
        @onmouseenter="HandleMouseEnter"
        @onmouseleave="HandleMouseLeave"
        @onkeydown="HandleKeyDown"
        @attributes="AdditionalAttributes">
    @ChildContent
    <SvgGlyph Svg="@(LumeoIcons.ChevronRight)" class="ms-auto h-4 w-4" />
</button>

@inject IComponentInteropService Interop

@code {
    [CascadingParameter] public ContextMenuSub.ContextMenuSubContext SubContext { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("relative flex w-full cursor-default select-none items-center gap-2 rounded-sm px-2 py-1.5 min-h-11 sm:min-h-0 text-sm outline-none transition-colors hover:bg-accent hover:text-accent-foreground focus:bg-accent focus:text-accent-foreground data-[state=open]:bg-accent data-[state=open]:text-accent-foreground disabled:pointer-events-none disabled:opacity-50 disabled:cursor-not-allowed", Class);

    private async Task HandleClick()
    {
        if (Disabled) return;
        SubContext.CancelClose();
        await SubContext.SetOpen.InvokeAsync(!SubContext.IsOpen);
    }

    private async Task HandleMouseEnter()
    {
        if (Disabled) return;
        SubContext.CancelClose();
        if (!SubContext.IsOpen)
        {
            await SubContext.SetOpen.InvokeAsync(true);
        }
    }

    private void HandleMouseLeave()
    {
        if (!SubContext.IsOpen) return;
        SubContext.ScheduleClose();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter and Space are deliberately NOT handled here: this is a native
        // <button>, so the browser synthesizes a click for them and HandleClick
        // performs the toggle. Opening from keydown as well made keyboard
        // activation a net no-op (keydown opened, the synthesized click
        // immediately toggled the submenu closed again).
        switch (e.Key)
        {
            case "ArrowRight":
                SubContext.CancelClose();
                if (SubContext.IsOpen)
                {
                    // Already open (e.g. via hover): content exists, focus now.
                    try { await Interop.FocusMenuItemByIndex(SubContext.ContentId, 0); }
                    catch (JSDisconnectedException) { }
                }
                else
                {
                    // Open from the keyboard; the content focuses its first item when
                    // it actually renders (race-free; replaces a fixed Task.Delay).
                    await SubContext.OpenByKeyboard.InvokeAsync();
                }
                break;
        }
    }
}
