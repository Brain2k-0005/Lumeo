@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic Calendar" Code="@_codeCalendarBasic">
    <Calendar />
</PatternCard>

<PatternCard Label="Date Selection" Code="@_codeCalendarSelection">
    <Stack Gap="2">
        <Calendar @bind-Value="_calendarDate" />
        <Lumeo.Text Size="sm" Color="muted" Align="center">
            Selected: @(_calendarDate?.ToString("MMMM d, yyyy") ?? "None")
        </Lumeo.Text>
    </Stack>
</PatternCard>
</Stack>

@code {
    private DateOnly? _calendarDate;

    private string _codeCalendarBasic = @"<Calendar />";
    private string _codeCalendarSelection = @"<Calendar @bind-Value=""_date"" />";
}
