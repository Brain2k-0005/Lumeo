@page "/e2e/gantt-v2"
@using System.Text.Json
@using Lumeo.Tests.ServerHost.E2E

@* Gantt v2/v3 parity harness (feat/gantt-v3, T4). Renders v2's Gantt against the
   SAME fixture GanttV3Page.razor renders through Gantt3, so the Lumeo.Tests.E2E
   Playwright suite can assert render-equivalence. ?fixture=today swaps in the
   DateTime.Today-anchored fixture for the today-marker test (see
   GanttParityFixtures.TodayMarkerTasks' remarks for why that one isn't
   hardcoded like the rest). ?viewMode=<GanttViewMode> seeds the initial zoom
   level so the header-label-run test can visit all 6 view modes directly —
   only Day/Week/Month/Year have a toolbar button, so QuarterDay/HalfDay are
   otherwise unreachable by clicking. ?readonly=1 disables in-chart editing
   (Phase 2, T4 drag parity suite — readonly-blocks-everything specs).

   Event sink (Phase 2, T4): the last OnTaskClick/OnDateChange/OnProgressChange
   payload is rendered as JSON into a hidden data-testid element per event, so
   the drag parity Playwright specs can assert payload equality against the v3
   route for the identical gesture (both routes render the SAME GanttTask type,
   so default System.Text.Json output is byte-identical shape). Hidden via
   inline style rather than omitted from the DOM — Playwright's TextContentAsync
   doesn't require visibility, and "hidden but present" is simpler than
   conditionally rendering. *@

<PageTitle>E2E - Gantt v2</PageTitle>

<div class="p-4" style="max-width: 1600px;">
    <h1 data-testid="gantt-e2e-title">Gantt v2 (parity fixture)</h1>
    <Gantt Tasks="@_tasks"
           ViewMode="@_viewMode"
           ViewModeChanged="@(m => _viewMode = m)"
           Height="900px"
           GroupBy="@(t => t.GroupLabel ?? "")"
           BarColor="@GanttParityFixtures.GetBarColor"
           Readonly="@_readonly"
           OnTaskClick="HandleTaskClick"
           OnDateChange="HandleDateChange"
           OnProgressChange="HandleProgressChange"
           data-testid="gantt-v2-root" />

    <pre data-testid="event-sink-click" style="display:none">@_lastClickJson</pre>
    <pre data-testid="event-sink-datechange" style="display:none">@_lastDateChangeJson</pre>
    <pre data-testid="event-sink-progresschange" style="display:none">@_lastProgressChangeJson</pre>
</div>

@code {
    [SupplyParameterFromQuery] public string? Fixture { get; set; }
    [SupplyParameterFromQuery] public string? ViewMode { get; set; }
    [SupplyParameterFromQuery] public string? Readonly { get; set; }

    private GanttViewMode _viewMode = GanttViewMode.Day;
    private List<GanttTask> _tasks = new();
    private bool _readonly;

    private string? _lastClickJson;
    private string? _lastDateChangeJson;
    private string? _lastProgressChangeJson;

    protected override void OnInitialized()
    {
        _tasks = Fixture == "today" ? GanttParityFixtures.TodayMarkerTasks() : GanttParityFixtures.SharedTasks();
        if (!string.IsNullOrEmpty(ViewMode) && Enum.TryParse<GanttViewMode>(ViewMode, out var parsed))
            _viewMode = parsed;
        _readonly = Readonly == "1";
    }

    private Task HandleTaskClick(GanttTask t)
    {
        _lastClickJson = JsonSerializer.Serialize(t);
        return Task.CompletedTask;
    }

    private Task HandleDateChange(GanttTask t)
    {
        _lastDateChangeJson = JsonSerializer.Serialize(t);
        return Task.CompletedTask;
    }

    private Task HandleProgressChange(GanttTask t)
    {
        _lastProgressChangeJson = JsonSerializer.Serialize(t);
        return Task.CompletedTask;
    }
}
