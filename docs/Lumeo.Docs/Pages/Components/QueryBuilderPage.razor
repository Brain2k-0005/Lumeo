@code {
    private readonly IReadOnlyList<QueryField> _fields = new List<QueryField>
    {
        new() { Name = "name", Label = "Name", Type = QueryFieldType.Text },
        new() { Name = "email", Label = "Email", Type = QueryFieldType.Text },
        new() { Name = "age", Label = "Age", Type = QueryFieldType.Number },
        new() { Name = "signupDate", Label = "Signup date", Type = QueryFieldType.Date },
        new() { Name = "isActive", Label = "Active", Type = QueryFieldType.Boolean },
        new()
        {
            Name = "plan", Label = "Plan", Type = QueryFieldType.Select,
            Options = new[] { ("free", "Free"), ("pro", "Pro"), ("enterprise", "Enterprise") }
        }
    };

    private QueryGroup _basicQuery = new()
    {
        Combinator = QueryCombinator.And,
        Rules =
        {
            new QueryRule { Field = "name", Operator = "contains", Value = "an" },
            new QueryRule { Field = "age", Operator = ">=", Value = 18d }
        }
    };

    private QueryGroup _jsonQuery = new()
    {
        Combinator = QueryCombinator.And,
        Rules =
        {
            new QueryRule { Field = "plan", Operator = "=", Value = "pro" },
            new QueryRule { Field = "isActive", Operator = "=", Value = true }
        }
    };

    private QueryGroup _nestedQuery = new()
    {
        Combinator = QueryCombinator.And,
        Rules =
        {
            new QueryRule { Field = "isActive", Operator = "=", Value = true },
            new QueryGroup
            {
                Combinator = QueryCombinator.Or,
                Rules =
                {
                    new QueryRule { Field = "plan", Operator = "=", Value = "pro" },
                    new QueryRule { Field = "plan", Operator = "=", Value = "enterprise" }
                }
            },
            new QueryGroup
            {
                Combinator = QueryCombinator.And,
                Rules =
                {
                    new QueryRule { Field = "age", Operator = "between", Value = 25d, Value2 = 40d }
                }
            }
        }
    };

    private QueryGroup _noEmptyQuery = new()
    {
        Combinator = QueryCombinator.And,
        Rules =
        {
            new QueryRule { Field = "name", Operator = "contains", Value = "a" }
        }
    };

    private string _basicCode = @"<QueryBuilder Fields=""_fields"" @bind-Query=""_query"" />

@code {
    private readonly IReadOnlyList<QueryField> _fields = new List<QueryField>
    {
        new() { Name = ""name"", Label = ""Name"", Type = QueryFieldType.Text },
        new() { Name = ""age"", Label = ""Age"", Type = QueryFieldType.Number },
        new() { Name = ""isActive"", Label = ""Active"", Type = QueryFieldType.Boolean },
        new() { Name = ""plan"", Label = ""Plan"", Type = QueryFieldType.Select,
                Options = new[] { (""free"", ""Free""), (""pro"", ""Pro"") } }
    };

    private QueryGroup _query = QueryGroup.CreateEmpty();
}";

    private string _jsonCode = @"<QueryBuilder Fields=""_fields"" @bind-Query=""_query"" ShowJsonPreview=""true"" />

@code {
    // ShowJsonPreview renders the live System.Text.Json shape — handy for
    // showing the consumer exactly what would be sent to a backend, or for debugging.
    // Programmatically: var json = QueryBuilder.ToJson(_query);
    //                   var back = QueryBuilder.FromJson(json);
}";

    private string _nestedCode = @"<QueryBuilder Fields=""_fields"" @bind-Query=""_query"" MaxDepth=""3"" />

@code {
    private QueryGroup _query = new()
    {
        Combinator = QueryCombinator.And,
        Rules =
        {
            new QueryRule { Field = ""isActive"", Operator = ""="", Value = true },
            new QueryGroup
            {
                Combinator = QueryCombinator.Or,
                Rules =
                {
                    new QueryRule { Field = ""plan"", Operator = ""="", Value = ""pro"" },
                    new QueryRule { Field = ""plan"", Operator = ""="", Value = ""enterprise"" }
                }
            }
        }
    };

    // Run it client-side:
    // var predicate = QueryBuilder.ToExpression<Customer>(_query);
    // var matches = customers.Where(predicate.Compile());
}";
}
