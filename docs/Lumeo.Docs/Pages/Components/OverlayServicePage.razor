@page "/components/overlay-service"

@using Lumeo.Services
@using Lumeo.Docs.Shared

<PageTitle>Overlay Service — Lumeo</PageTitle>

<PageHeader Title="Overlay Service" Description="A programmatic service for opening dialogs, sheets, drawers, and alert dialogs imperatively from code." />

<InstallUsage Component="OverlayService" ShowUsage="false" />

<Stack Gap="8">

    <!-- Dialog demo -->
    <ComponentDemo Title="Dialog" Description="Open a dialog containing a dynamic component and await its result." Code="@_dialogCode">
        <Stack Gap="3">
            <Button OnClick="ShowDialog">Open Dialog</Button>
            @if (_dialogResult is not null)
            {
                <Alert>Result: @_dialogResult</Alert>
            }
        </Stack>
    </ComponentDemo>

    <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
        <ChildContent>
            <strong>Authoring components for the service.</strong> When a component is opened via
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">OverlayService.Show*Async&lt;T&gt;</code>,
            the provider already wraps it in <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Dialog&gt;&lt;DialogContent&gt;</code>
            (or the Sheet / Drawer equivalent). Your component renders as the children of that shell — put
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;DialogHeader&gt;</code>,
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;DialogFooter&gt;</code>
            (or the Sheet / Drawer equivalents) and your body content directly at the root.
            Inline-declarative usage (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Sheet&gt;&lt;SheetContent&gt;...&lt;/SheetContent&gt;&lt;/Sheet&gt;</code>)
            inside a service-opened component is detected and passes through — but the cleaner pattern is
            to skip the outer wrappers entirely.
        </ChildContent>
    </Alert>

    <!-- Sheet demo -->
    <ComponentDemo Title="Sheet" Description="Open a sheet panel from any side with a dynamic component." Code="@_sheetCode">
        <Stack Gap="3">
            <Flex Gap="2" Wrap="true">
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(Lumeo.Side.Right)">Right</Button>
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(Lumeo.Side.Left)">Left</Button>
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => ShowSheet(Lumeo.Side.Bottom)">Bottom</Button>
            </Flex>
            @if (_sheetResult is not null)
            {
                <Alert>Result: @_sheetResult</Alert>
            }
        </Stack>
    </ComponentDemo>

    <!-- Drawer demo -->
    <ComponentDemo Title="Drawer" Description="Open a bottom drawer with a dynamic component." Code="@_drawerCode">
        <Stack Gap="3">
            <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowDrawer">Open Drawer</Button>
            @if (_drawerResult is not null)
            {
                <Alert>Result: @_drawerResult</Alert>
            }
        </Stack>
    </ComponentDemo>

    <!-- Alert Dialog demo -->
    <ComponentDemo Title="Alert Dialog" Description="Show a confirmation dialog and await the user's choice." Code="@_alertCode">
        <Stack Gap="3">
            <Flex Gap="2" Wrap="true">
                <Button Variant="Button.ButtonVariant.Outline" OnClick="ShowConfirm">Confirm Action</Button>
                <Button Variant="Button.ButtonVariant.Destructive" OnClick="ShowDestructive">Delete Item</Button>
            </Flex>
            @if (_alertResult is not null)
            {
                <Alert Variant="@(_alertCancelled ? Alert.AlertVariant.Destructive : Alert.AlertVariant.Default)">@_alertResult</Alert>
            }
        </Stack>
    </ComponentDemo>

</Stack>

