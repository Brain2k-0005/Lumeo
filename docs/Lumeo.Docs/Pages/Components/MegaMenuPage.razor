@page "/components/mega-menu"

<PageTitle>Mega Menu — Lumeo</PageTitle>

<PageHeader Title="Mega Menu" Description="A navigation bar with expandable mega panel dropdowns — supports multi-column layouts, grouped links, and horizontal or vertical orientations." />

<InstallUsage Component="MegaMenu" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Large navigation panels with grouped links for complex site structures</li>
        <li>E-commerce category menus with multi-column product groupings</li>
        <li>Feature-rich headers that need to display many links organized by section</li>
        <li>Marketing sites or documentation portals with deep navigation hierarchies</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Mega Menu" Code="@_basicCode" OverflowVisible="true">
        <MegaMenu>
            <MegaMenuItem Label="Products">
                <MegaMenuPanel Columns="3">
                    <MegaMenuGroup Title="Design">
                        <MegaMenuLink Href="#" Title="Components" Description="Pre-built UI components" />
                        <MegaMenuLink Href="#" Title="Templates" Description="Starter page templates" />
                        <MegaMenuLink Href="#" Title="Icons" Description="Icon library browser" />
                    </MegaMenuGroup>
                    <MegaMenuGroup Title="Development">
                        <MegaMenuLink Href="#" Title="CLI" Description="Command-line tooling" />
                        <MegaMenuLink Href="#" Title="API Reference" Description="Complete API docs" />
                        <MegaMenuLink Href="#" Title="Changelog" Description="What's new in each version" />
                    </MegaMenuGroup>
                    <MegaMenuGroup Title="Resources">
                        <MegaMenuLink Href="#" Title="Tutorials" Description="Step-by-step guides" />
                        <MegaMenuLink Href="#" Title="Blog" Description="News and updates" />
                        <MegaMenuLink Href="#" Title="Community" Description="Forums and Discord" />
                    </MegaMenuGroup>
                </MegaMenuPanel>
            </MegaMenuItem>
            <MegaMenuItem Label="Solutions">
                <MegaMenuPanel Columns="2">
                    <MegaMenuGroup Title="By Role">
                        <MegaMenuLink Href="#" Title="Developers" Description="Tools for building fast" />
                        <MegaMenuLink Href="#" Title="Designers" Description="Design system resources" />
                        <MegaMenuLink Href="#" Title="Teams" Description="Collaboration features" />
                    </MegaMenuGroup>
                    <MegaMenuGroup Title="By Industry">
                        <MegaMenuLink Href="#" Title="Enterprise" Description="Large-scale deployments" />
                        <MegaMenuLink Href="#" Title="Startups" Description="Ship faster" />
                        <MegaMenuLink Href="#" Title="Agencies" Description="Client project tooling" />
                    </MegaMenuGroup>
                </MegaMenuPanel>
            </MegaMenuItem>
            <MegaMenuItem Label="Pricing" Href="#" />
            <MegaMenuItem Label="Blog" Href="#" />
        </MegaMenu>
    </ComponentDemo>

    <ComponentDemo Title="Single Column Panel" Code="@_singleCode" OverflowVisible="true">
        <MegaMenu>
            <MegaMenuItem Label="Company">
                <MegaMenuPanel Columns="1" FullWidth="false">
                    <MegaMenuGroup>
                        <MegaMenuLink Href="#" Title="About Us" Description="Our story and mission" />
                        <MegaMenuLink Href="#" Title="Careers" Description="Open positions" />
                        <MegaMenuLink Href="#" Title="Press" Description="Media kit and news" />
                        <MegaMenuLink Href="#" Title="Contact" Description="Get in touch" />
                    </MegaMenuGroup>
                </MegaMenuPanel>
            </MegaMenuItem>
            <MegaMenuItem Label="Docs" Href="#" />
        </MegaMenu>
    </ComponentDemo>

    <ComponentDemo Title="Icons and Disabled Item" Code="@_iconDisabledCode" OverflowVisible="true">
        <MegaMenu>
            <MegaMenuItem Label="Products" Icon="LumeoIcons.Box">
                <MegaMenuPanel Columns="2">
                    <MegaMenuGroup Title="Design">
                        <MegaMenuLink Href="#" Icon="LumeoIcons.Component" Title="Components" Description="Pre-built UI components" />
                        <MegaMenuLink Href="#" Icon="LumeoIcons.LayoutTemplate" Title="Templates" Description="Starter page templates" />
                    </MegaMenuGroup>
                    <MegaMenuGroup Title="Development">
                        <MegaMenuLink Href="#" Icon="LumeoIcons.Terminal" Title="CLI" Description="Command-line tooling" />
                        <MegaMenuLink Href="#" Icon="LumeoIcons.BookOpen" Title="API Reference" Description="Complete API docs" Disabled="true" />
                    </MegaMenuGroup>
                </MegaMenuPanel>
            </MegaMenuItem>
            <MegaMenuItem Label="Docs" Icon="LumeoIcons.FileText" Href="#" />
            <MegaMenuItem Label="Archived" Disabled="true" />
        </MegaMenu>
    </ComponentDemo>

    <ComponentDemo Title="Orientation — interactive" Code="@_orientationInteractiveCode" OverflowVisible="true">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Pick a value to see it applied live. <strong>Horizontal</strong> arranges items in a row; <strong>Vertical</strong> stacks them in a column sidebar style.</Lumeo.Text>
            <Segmented @bind-Value="_megaMenuOrientationSel" Options="_megaMenuOrientationOptions" />
            <MegaMenu Orientation="@_activeOrientation">
                <MegaMenuItem Label="Products">
                    <MegaMenuPanel Columns="2">
                        <MegaMenuGroup Title="Design">
                            <MegaMenuLink Href="#" Title="Components" Description="Pre-built UI components" />
                            <MegaMenuLink Href="#" Title="Templates" Description="Starter page templates" />
                        </MegaMenuGroup>
                        <MegaMenuGroup Title="Development">
                            <MegaMenuLink Href="#" Title="CLI" Description="Command-line tooling" />
                            <MegaMenuLink Href="#" Title="API Reference" Description="Complete API docs" />
                        </MegaMenuGroup>
                    </MegaMenuPanel>
                </MegaMenuItem>
                <MegaMenuItem Label="Docs" Href="#" />
                <MegaMenuItem Label="Blog" Href="#" />
            </MegaMenu>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">MegaMenu</Heading>
            <PropsTable Slug="mega-menu" />
        </Stack>
        <Stack>
            <Heading Level="3" Class="mb-3">MegaMenuItem</Heading>
            <PropsTable Slug="mega-menu" SubComponent="MegaMenuItem" />
        </Stack>
        <Stack>
            <Heading Level="3" Class="mb-3">MegaMenuPanel</Heading>
            <PropsTable Slug="mega-menu" SubComponent="MegaMenuPanel" />
        </Stack>
        <Stack>
            <Heading Level="3" Class="mb-3">MegaMenuLink</Heading>
            <PropsTable Slug="mega-menu" SubComponent="MegaMenuLink" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/navigation-menu" class="text-primary hover:underline">NavigationMenu</a> — Simpler navigation menu for standard site navigation</li>
        <li><a href="/components/menubar" class="text-primary hover:underline">Menubar</a> — Horizontal menu bar for application-style menus</li>
        <li><a href="/components/dropdown-menu" class="text-primary hover:underline">DropdownMenu</a> — Single-column dropdown for simpler menu needs</li>
    </ul>
</div>

@code {
    // Interactive: Orientation
    private string _megaMenuOrientationSel = "Horizontal";
    private Lumeo.Orientation _activeOrientation => Enum.Parse<Lumeo.Orientation>(_megaMenuOrientationSel);
    private List<Segmented.SegmentedOption> _megaMenuOrientationOptions = new()
    {
        new() { Label = "Horizontal", Value = "Horizontal" },
        new() { Label = "Vertical", Value = "Vertical" },
    };
    private string _orientationInteractiveCode = @"<Segmented @bind-Value=""_orientationSel"" Options=""_orientationOptions"" />
<MegaMenu Orientation=""@_activeOrientation"">
    <MegaMenuItem Label=""Products"">
        <MegaMenuPanel Columns=""2"">
            <MegaMenuGroup Title=""Design"">
                <MegaMenuLink Href=""#"" Title=""Components"" Description=""Pre-built UI components"" />
            </MegaMenuGroup>
            <MegaMenuGroup Title=""Development"">
                <MegaMenuLink Href=""#"" Title=""CLI"" Description=""Command-line tooling"" />
            </MegaMenuGroup>
        </MegaMenuPanel>
    </MegaMenuItem>
    <MegaMenuItem Label=""Docs"" Href=""#"" />
</MegaMenu>

