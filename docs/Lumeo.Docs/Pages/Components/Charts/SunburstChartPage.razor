@page "/components/charts/sunburst"

<PageTitle>Sunburst Chart — Lumeo</PageTitle>

<PageHeader Title="Sunburst Chart" Description="Visualize hierarchical data in concentric rings. Each ring represents a level in the hierarchy, radiating outward from the center." />

<Stack Gap="8">
    <ComponentDemo Title="Regional Revenue Sunburst" Code="@_basicCode">
        <Container>
            <SunburstChart Data="_data" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">SunburstChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;SunburstData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Hierarchical data with Name, Value, and optional Children.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows or hides the chart legend.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color palette.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<SunburstChart.SunburstData> _data = new()
    {
        new() { Name = "North America", Value = 420, Children = new()
        {
            new() { Name = "USA", Value = 310, Children = new()
            {
                new() { Name = "Enterprise", Value = 190 },
                new() { Name = "SMB",        Value = 120 }
            }},
            new() { Name = "Canada", Value = 110 }
        }},
        new() { Name = "Europe", Value = 290, Children = new()
        {
            new() { Name = "UK",    Value = 140 },
            new() { Name = "DACH",  Value = 100 },
            new() { Name = "Other", Value = 50  }
        }},
        new() { Name = "APAC", Value = 190 }
    };

    private string _basicCode = @"<SunburstChart Data=""_data"" />";
}
