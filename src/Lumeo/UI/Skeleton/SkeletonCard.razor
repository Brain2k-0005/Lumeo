@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    <Skeleton Animation="Animation" Class="h-32 w-full rounded-t-lg" />
    <div class="p-4 space-y-3">
        <Skeleton Animation="Animation" Class="h-5 w-3/4" />
        <Skeleton Animation="Animation" Class="h-4 w-full" />
        <Skeleton Animation="Animation" Class="h-4 w-1/2" />
    </div>
</div>

@code {
    /// <summary>Loading animation applied to every skeleton bar in the card. Defaults to
    /// <see cref="Skeleton.SkeletonAnimation.Pulse"/>.</summary>
    [Parameter] public Skeleton.SkeletonAnimation Animation { get; set; } = Skeleton.SkeletonAnimation.Pulse;
    /// <summary>Additional CSS classes merged onto the root <c>div</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("rounded-lg border border-border/40 overflow-hidden", Class);
}
