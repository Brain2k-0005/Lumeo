                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">FocusElement(elementId)</td>
                            <td class="p-3 text-xs text-muted-foreground">Focus</td>
                            <td class="p-3 text-muted-foreground">Focus a specific element by ID.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">FocusMenuItemByIndex(containerId, index)</td>
                            <td class="p-3 text-xs text-muted-foreground">Focus</td>
                            <td class="p-3 text-muted-foreground">Focus the nth menu item in a container.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">GetMenuItemCount(containerId)</td>
