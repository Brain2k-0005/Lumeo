<section class="py-20">
    <Container MaxWidth="[1400px]" Class="px-4">
        <Stack Gap="3" Class="text-center mb-12">
            <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Included</Badge>
