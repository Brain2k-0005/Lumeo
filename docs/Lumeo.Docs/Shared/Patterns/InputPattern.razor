@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeInputDefault">
    <Input placeholder="Email" Class="w-full max-w-sm" />
</PatternCard>

<PatternCard Label="With Label" Code="@_codeInputLabel">
    <Stack Gap="2" Class="w-full max-w-sm">
        <Label>Email</Label>
        <Input placeholder="Enter your email" />
    </Stack>
</PatternCard>
<PatternCard Label="Disabled" Code="@_codeInputDisabled">
    <Input placeholder="Disabled input" disabled Class="w-full max-w-sm" />
</PatternCard>
</Stack>

@code {
        private string _codeInputDefault = @"<Input placeholder=""Email"" />";
        private string _codeInputLabel = @"<Stack Gap=""2"">
        <Label>Email</Label>
        <Input placeholder=""Enter your email"" />
    </Stack>";

        private string _codeInputDisabled = @"<Input placeholder=""Disabled input"" disabled />";
    
        // Select
        private string _codeSelectBasic = @"<Select @bind-Value=""_value"" @bind-Open=""_open"">
        <SelectTrigger>
            <Lumeo.Text As=""span"">Select a fruit</Lumeo.Text>
        </SelectTrigger>
        <SelectContent>
            <SelectItem Value=""Apple"">Apple</SelectItem>
            <SelectItem Value=""Banana"">Banana</SelectItem>
            <SelectItem Value=""Cherry"">Cherry</SelectItem>
        </SelectContent>
    </Select>";
}
