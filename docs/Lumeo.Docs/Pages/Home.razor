@page "/"

<PageTitle>Lumeo — The Blazor component library you'd actually want to ship</PageTitle>

<!-- ======================= HERO ======================= -->
<section class="relative overflow-hidden">
    <!-- Subtle grid pattern background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)] pointer-events-none opacity-50"></div>

    <Container MaxWidth="6xl" Class="relative px-4 py-24">
        <BlurFade DelayMs="0">
            <Stack Gap="6" Class="items-center text-center">
                <!-- Version badge -->
                <Lumeo.Link Href="docs/changelog" Class="no-underline group">
                    <Flex Inline="true" Align="center" Gap="2" Class="rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                        <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">New</Badge>
                        <Lumeo.Text As="span">v2.0 — AI primitives, motion, full DataGrid</Lumeo.Text>
                        <DynamicIcon Name="ArrowRight" Class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                    </Flex>
                </Lumeo.Link>

                <!-- Giant headline -->
                <Heading Level="1" Class="text-5xl sm:text-6xl md:text-7xl font-bold tracking-tight leading-[1.02] max-w-4xl">
                    The Blazor library<br />
                    you'd actually want to <Lumeo.Text As="span" Class="text-primary">ship</Lumeo.Text>.
                </Heading>

                <!-- Subtitle with TextReveal on the size claim -->
                <div class="max-w-2xl">
                    <Lumeo.Text Size="lg" Color="muted" Class="leading-relaxed">
                        130+ components in a single
                        <Lumeo.Text As="span" Weight="semibold" Color="foreground">868 KB</Lumeo.Text>
                        package.
                    </Lumeo.Text>
                    <TextReveal Text="Roughly 9x smaller than MudBlazor (7.59 MB), Radzen (7.90 MB), and AntDesign (9.35 MB)."
                                Class="block mt-2 text-base text-muted-foreground leading-relaxed" />
                </div>

                <!-- CTA row -->
                <Flex Gap="3" Wrap="true" Justify="center" Class="pt-2">
                    <Lumeo.Link Href="docs/introduction" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Lg" Class="rounded-lg">
                            Get Started
                            <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="components/button" Class="inline-flex h-10 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background px-6 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                        Browse Components
                    </Lumeo.Link>
                </Flex>

                <!-- Install command wrapped in BorderBeam -->
                <Stack Align="center" Gap="2" Class="pt-4">
                    <BorderBeam DurationMs="6000" Class="inline-block">
                        <Flex Align="center" Gap="0" Class="rounded-lg border border-border/40 bg-muted/30 pl-4 pr-2 py-2 font-mono text-xs text-foreground backdrop-blur-sm">
                            <Lumeo.Text As="span" Color="muted" Class="mr-2 select-none">$</Lumeo.Text>
                            <Lumeo.Text As="span" Class="whitespace-nowrap">dotnet add package Lumeo</Lumeo.Text>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="ml-3 inline-flex items-center justify-center h-8 w-8 p-0 rounded-md text-muted-foreground hover:text-foreground" OnClick="CopyInstall" aria-label="Copy install command">
                                @if (_installCopied)
                                {
                                    <DynamicIcon Name="Check" Class="h-4 w-4 text-primary" />
                                }
                                else
                                {
                                    <DynamicIcon Name="Copy" Class="h-4 w-4" />
                                }
                            </Button>
                        </Flex>
                    </BorderBeam>
                    <Lumeo.Text Size="xs" Color="muted">No peer dependencies. Works with Blazor WASM and Server.</Lumeo.Text>
                </Stack>
            </Stack>
        </BlurFade>
    </Container>
</section>

<Separator Class="opacity-30" />


<!-- ======================= SIZE COMPARISON BENTO ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">The hook</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">A fraction of the size.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    Measured against the latest public NuGet packages on the day this page was built.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="4" Gap="Bento.BentoGap.Md">
            <!-- Central tile spans 2 cols and 2 rows — the size chart -->
            <BentoTile Span="2" RowSpan="2" Class="border-border/60 p-6">
                <Stack Gap="5" Class="h-full">
                    <Stack Gap="1">
                        <Flex Align="center" Gap="2">
                            <Heading Level="3" Class="text-2xl font-semibold tracking-tight">
                                130+ components. <Lumeo.Text As="span" Class="text-primary">868 KB</Lumeo.Text>.
                            </Heading>
                        </Flex>
                        <Lumeo.Text Size="sm" Color="muted">Package size comparison (smaller is better).</Lumeo.Text>
                    </Stack>

                    <Stack Gap="4" Class="flex-1 justify-center">
                        @foreach (var row in _sizeRows)
                        {
                            <Stack Gap="1.5">
                                <Flex Align="center" Justify="between" Class="text-sm">
                                    <Flex Align="center" Gap="2">
                                        @if (row.IsUs)
                                        {
                                            <span class="h-2 w-2 rounded-full bg-primary"></span>
                                        }
                                        else
                                        {
                                            <span class="h-2 w-2 rounded-full bg-muted-foreground/40"></span>
                                        }
                                        <Lumeo.Text As="span" Weight="@(row.IsUs ? "semibold" : "medium")" Color="foreground">@row.Name</Lumeo.Text>
                                    </Flex>
                                    <Lumeo.Text As="span" Size="xs" Class="@(row.IsUs ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground")">@row.Size</Lumeo.Text>
                                </Flex>
                                <div class="relative h-2 rounded-full bg-muted/40 overflow-hidden">
                                    <div class="@(row.IsUs ? "bg-primary" : "bg-muted-foreground/40") h-full rounded-full transition-all"
                                         style="width: @(row.Percent)%;"></div>
                                </div>
                            </Stack>
                        }
                    </Stack>

                    <Flex Align="center" Gap="2" Class="pt-1 text-xs text-muted-foreground border-t border-border/40 pt-4">
                        <DynamicIcon Name="Info" Class="h-3.5 w-3.5" />
                        <Lumeo.Text As="span">NuGet .nupkg sizes, verified 2026-04-22.</Lumeo.Text>
                    </Flex>
                </Stack>
            </BentoTile>

            <!-- 4 KPI tiles stacked on the right -->
            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="TestTube" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Tests</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="1727" DurationMs="1800" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">CI green, every commit.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Languages" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Locales</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="14" DurationMs="1600" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">Bundled ILumeoLocalizer.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Palette" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Themes</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="8" DurationMs="1400" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">CSS-variable presets.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Accessibility" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Compliance</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">WCAG AA</div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">Keyboard + ARIA built in.</Lumeo.Text>
                </Stack>
            </BentoTile>
        </Bento>
    </Container>
</section>


<!-- ======================= MARQUEE WALL (two rows, opposite directions) ======================= -->
<section class="py-14 border-y border-border/40 bg-gradient-to-b from-muted/30 via-muted/10 to-muted/30 overflow-hidden relative">
    @* Edge fades so pills dissolve in/out instead of hard-cutting at the container. *@
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-background to-transparent z-10"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-background to-transparent z-10"></div>

    <BlurFade DelayMs="0">
        <Stack Gap="4">
            <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Class="[--gap:1rem]">
                @foreach (var p in _marqueeRowA)
                {
                    <span class="mx-2 inline-flex items-center gap-2 rounded-full border border-border/40 bg-card px-4 py-2 text-sm font-medium text-foreground whitespace-nowrap shadow-sm hover:border-primary/40 hover:shadow-md transition-all">
                        <DynamicIcon Name="@p.Icon" Class="h-4 w-4 text-primary shrink-0" />
                        @p.Label
                    </span>
                }
            </Marquee>

            <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Reverse="true" Class="[--gap:1rem]">
                @foreach (var p in _marqueeRowB)
                {
                    <span class="mx-2 inline-flex items-center gap-2 rounded-full bg-primary/10 text-primary px-4 py-2 text-sm font-semibold whitespace-nowrap hover:bg-primary/15 transition-colors">
                        <DynamicIcon Name="@p.Icon" Class="h-4 w-4 shrink-0" />
                        @p.Label
                    </span>
                }
            </Marquee>
        </Stack>
    </BlurFade>
</section>


<!-- ======================= LIVE COMPONENT SHOWCASE ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Live</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Real components. No screenshots.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    Every tile below is the actual Lumeo component rendered in your browser.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="4" Gap="Bento.BentoGap.Md">

            <!-- DataGrid — wide tile -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 p-5 bg-muted/10">
                        <DataGrid TItem="Employee" Items="@_employees" PageSize="4" ShowPagination="false">
                            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
                            <DataGridColumnDef TItem="Employee" Title="Team" Field="Department" />
                            <DataGridColumnDef TItem="Employee" Title="Role" Field="Role" />
                            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
                        </DataGrid>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Table2" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">DataGrid</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/datagrid" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- BarChart — wide tile -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 p-4 bg-muted/10 min-h-[260px]">
                        <BarChart Categories="_chartCategories" Series="_chartSeries" Height="240px" />
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="BarChart3" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Charts · powered by ECharts</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/charts/bar" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Form controls — spans 1 col, 2 rows -->
            <BentoTile RowSpan="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <Stack Gap="4" Class="flex-1 justify-center p-6 bg-muted/10">
                        <Flex Align="center" Gap="3">
                            <Switch @bind-Checked="_switchOn" />
                            <Lumeo.Text Size="sm" Color="muted">@(_switchOn ? "Notifications on" : "Off")</Lumeo.Text>
                        </Flex>
                        <Stack Gap="2">
                            <Lumeo.Text Size="xs" Color="muted">Volume · @((int)_sliderVal)%</Lumeo.Text>
                            <Slider @bind-Value="_sliderVal" />
                        </Stack>
                        <Flex Gap="3" Align="center">
                            <Checkbox @bind-Checked="_checkOn" />
                            <Lumeo.Text Size="sm" Color="muted">Subscribe</Lumeo.Text>
                        </Flex>
                        <Flex Gap="2" Align="center">
                            <Toggle @bind-Pressed="_togglePressed">
                                <DynamicIcon Name="Bold" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle>
                                <DynamicIcon Name="Italic" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle>
                                <DynamicIcon Name="Underline" Class="h-4 w-4" />
                            </Toggle>
                        </Flex>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="SlidersHorizontal" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Form controls</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/switch" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Kanban -->
            <BentoTile Span="3" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 p-4 bg-muted/10">
                        <div class="grid grid-cols-3 gap-3">
                            <div class="rounded-lg border border-border/40 bg-background p-3">
                                <Flex Align="center" Justify="between" Class="mb-3">
                                    <Lumeo.Text Size="xs" Weight="semibold">To do</Lumeo.Text>
                                    <Badge Variant="Badge.BadgeVariant.Secondary" Class="h-5 px-1.5 text-[10px]">2</Badge>
                                </Flex>
                                <Stack Gap="2">
                                    <div class="rounded-md border border-border/40 bg-card p-2.5 text-xs">
                                        <Lumeo.Text Size="xs" Weight="medium">Design audit</Lumeo.Text>
                                        <Lumeo.Text Size="xs" Color="muted" Class="mt-0.5">Review spacing scale</Lumeo.Text>
                                    </div>
                                    <div class="rounded-md border border-border/40 bg-card p-2.5 text-xs">
                                        <Lumeo.Text Size="xs" Weight="medium">Write docs</Lumeo.Text>
                                    </div>
                                </Stack>
                            </div>
                            <div class="rounded-lg border border-border/40 bg-background p-3">
                                <Flex Align="center" Justify="between" Class="mb-3">
                                    <Lumeo.Text Size="xs" Weight="semibold">In progress</Lumeo.Text>
                                    <Badge Class="h-5 px-1.5 text-[10px]">1</Badge>
                                </Flex>
                                <Stack Gap="2">
                                    <div class="rounded-md border border-primary/40 bg-card p-2.5 text-xs ring-1 ring-primary/20">
                                        <Lumeo.Text Size="xs" Weight="medium">DataGrid export</Lumeo.Text>
                                        <Lumeo.Text Size="xs" Color="muted" Class="mt-0.5">CSV + Excel</Lumeo.Text>
                                    </div>
                                </Stack>
                            </div>
                            <div class="rounded-lg border border-border/40 bg-background p-3">
                                <Flex Align="center" Justify="between" Class="mb-3">
                                    <Lumeo.Text Size="xs" Weight="semibold">Done</Lumeo.Text>
                                    <Badge Variant="Badge.BadgeVariant.Success" Class="h-5 px-1.5 text-[10px]">3</Badge>
                                </Flex>
                                <Stack Gap="2">
                                    <div class="rounded-md border border-border/40 bg-card/60 p-2.5 text-xs opacity-75">
                                        <Lumeo.Text Size="xs" Weight="medium">Theme presets</Lumeo.Text>
                                    </div>
                                </Stack>
                            </div>
                        </div>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="LayoutList" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Kanban</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/kanban" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Buttons -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <Stack Gap="3" Class="flex-1 items-center justify-center p-5 min-h-[160px] bg-muted/10">
                        <Flex Gap="2" Wrap="true" Justify="center">
                            <Button Size="Button.ButtonSize.Sm">Primary</Button>
                            <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Sm">Secondary</Button>
                            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Outline</Button>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">Ghost</Button>
                            <Button Variant="Button.ButtonVariant.Destructive" Size="Button.ButtonSize.Sm">Destructive</Button>
                        </Flex>
                        <Flex Gap="2" Wrap="true" Align="center" Justify="center">
                            <Badge>Default</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
                            <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
                            <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
                            <Badge Variant="Badge.BadgeVariant.Destructive">Error</Badge>
                        </Flex>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="SquareMousePointer" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Button &amp; Badge</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/button" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- DatePicker + Dialog -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <Stack Gap="3" Class="flex-1 items-center justify-center p-5 min-h-[160px] bg-muted/10">
                        <div class="w-full max-w-[240px]">
                            <DatePicker @bind-Value="_selectedDate" Placeholder="Pick a date" />
                        </div>
                        <Dialog @bind-IsOpen="_showDialog">
                            <DialogTrigger>
                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">
                                    <DynamicIcon Name="MousePointerClick" Class="h-4 w-4" />
                                    Open dialog
                                </Button>
                            </DialogTrigger>
                            <DialogContent>
                                <DialogHeader>
                                    <DialogTitle>Welcome to Lumeo</DialogTitle>
                                    <DialogDescription>
                                        Fully accessible, keyboard-navigable, and rendered by the real Lumeo Dialog.
                                    </DialogDescription>
                                </DialogHeader>
                                <DialogFooter>
                                    <DialogClose>
                                        <Button Variant="Button.ButtonVariant.Outline">Cancel</Button>
                                    </DialogClose>
                                    <DialogClose>
                                        <Button>Got it</Button>
                                    </DialogClose>
                                </DialogFooter>
                            </DialogContent>
                        </Dialog>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Calendar" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">DatePicker &amp; Dialog</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/date-picker" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

        </Bento>
    </Container>
</section>

<Separator Class="opacity-30" />


<!-- ======================= WHY LUMEO ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Built-in</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Everything you'd otherwise build.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A complete kit for modern Blazor apps — batteries included, DX-obsessed.
                </Lumeo.Text>
            </Stack>
