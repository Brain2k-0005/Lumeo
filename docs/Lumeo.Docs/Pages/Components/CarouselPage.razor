</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/tabs" class="text-primary hover:underline">Tabs</a> — For switching between distinct content panels without sliding</li>
        <li><a href="/components/scroll-area" class="text-primary hover:underline">ScrollArea</a> — For scrollable content areas with custom scrollbars</li>
    </ul>
</div>

@code {
    private string _defaultCode = @"<Carousel>
    <CarouselContent>
        @for (var i = 1; i <= 5; i++)
        {
            var index = i;
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <CardContent Class=""flex aspect-square items-center justify-center p-6"">
                            <span class=""text-4xl font-semibold"">@index</span>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private string _loopCode = @"<Carousel Loop=""true"">
    <CarouselContent>
        @for (var i = 1; i <= 5; i++)
        {
            var index = i;
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <CardContent Class=""flex aspect-square items-center justify-center p-6"">
                            <span class=""text-4xl font-semibold"">@index</span>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private string _galleryCode = @"<Carousel>
    <CarouselContent>
        @foreach (var product in _products)
        {
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <AspectRatio Ratio=""4.0 / 3.0"" Class=""rounded-t-lg overflow-hidden bg-muted"">
                            <div class=""flex items-center justify-center h-full text-sm text-muted-foreground"">@product.Category</div>
                        </AspectRatio>
                        <CardContent Class=""p-4"">
                            <Lumeo.Text Size=""sm"" Weight=""semibold"">@product.Name</Lumeo.Text>
                            <Lumeo.Text Size=""sm"" Color=""muted"">@product.Price</Lumeo.Text>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private record ProductItem(string Name, string Category, string Price);

    private readonly ProductItem[] _products =
    [
        new("Wireless Headphones", "Electronics", "$79.99"),
        new("Leather Wallet", "Accessories", "$34.99"),
        new("Running Shoes", "Footwear", "$119.99"),
        new("Coffee Mug", "Kitchen", "$14.99"),
    ];
}
