<!-- ======================= COMPARISON TABLE ======================= -->
<section class="py-24 bg-muted/10">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Compared</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">How it stacks up.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-2xl mx-auto">
                    A factual snapshot against the popular Blazor UI options — each is strong in different ways.
                    Lumeo is newer and has a smaller community; the commercial libraries have decades of polish and dedicated support teams.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <div class="rounded-xl border border-border/40 bg-card overflow-x-auto">
            <table class="w-full min-w-[900px] text-sm">
                <thead>
                    <tr class="border-b border-border/40 bg-muted/30">
                        <th class="text-left px-4 py-3 font-semibold text-foreground">Feature</th>
                        <th class="text-center px-4 py-3 font-semibold text-primary">Lumeo</th>
                        <th class="text-center px-4 py-3 font-semibold text-muted-foreground">MudBlazor</th>
                        <th class="text-center px-4 py-3 font-semibold text-muted-foreground">Radzen</th>
                        <th class="text-center px-4 py-3 font-semibold text-muted-foreground">Syncfusion</th>
                        <th class="text-center px-4 py-3 font-semibold text-muted-foreground">Telerik</th>
                        <th class="text-center px-4 py-3 font-semibold text-muted-foreground">DevExpress</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/40">
                    @foreach (var row in _comparisonRows)
                    {
                        <tr class="hover:bg-muted/20 transition-colors">
                            <td class="px-4 py-3 font-medium text-foreground">@row.Feature</td>
                            <td class="px-4 py-3 text-center">
                                @if (row.LumeoText is not null)
                                {
                                    <Lumeo.Text As="span" Size="xs" Weight="semibold" Class="text-primary font-mono">@row.LumeoText</Lumeo.Text>
                                }
                                else if (row.Lumeo)
                                {
                                    <DynamicIcon Name="Check" Class="h-4 w-4 text-primary inline-block" />
                                }
                                else
                                {
                                    <DynamicIcon Name="X" Class="h-4 w-4 text-destructive/60 inline-block" />
                                }
                            </td>
                            @foreach (var cell in new[] { row.Mud, row.Radzen, row.Sync, row.Telerik, row.Devex })
                            {
                                <td class="px-4 py-3 text-center">
                                    @if (cell.Text is not null)
                                    {
                                        <Lumeo.Text As="span" Size="xs" Class="text-muted-foreground font-mono">@cell.Text</Lumeo.Text>
                                    }
                                    else if (cell.Value == true)
                                    {
                                        <DynamicIcon Name="Check" Class="h-4 w-4 text-muted-foreground inline-block" />
                                    }
                                    else
                                    {
                                        <DynamicIcon Name="X" Class="h-4 w-4 text-destructive/60 inline-block" />
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <Lumeo.Text Size="xs" Color="muted" Class="mt-3 text-center">
            Verified 2026-04-25. Component counts are approximate and vary by how each project counts sub-components.
            Commercial licenses vary — check each vendor's current pricing.
        </Lumeo.Text>
    </Container>
</section>


