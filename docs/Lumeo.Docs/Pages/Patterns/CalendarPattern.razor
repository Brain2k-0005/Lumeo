@page "/blocks/calendar"
@namespace Lumeo.Docs.Pages.Blocks

<PageTitle>Calendar — Lumeo Patterns</PageTitle>

<PageHeader Title="Calendar / Scheduling" Description="A full-featured calendar view with day/week/month toggle, event dots, and a side panel for event details and creation." />

<Stack Gap="12">

    <ComponentDemo Title="Calendar View" Code="@_calendarCode">
        <Flex Direction="col" Gap="4" Class="w-full min-w-[700px] lg:flex-row">

            <!-- Main Calendar -->
            <Stack Class="flex-1">
                <Card>
                    <!-- Calendar Header -->
                    <CardHeader>
                        <Flex Align="center" Justify="between">
                            <Flex Align="center" Gap="2">
                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Icon"
                                        OnClick="@PrevMonth">
                                    <DynamicIcon Name="ChevronLeft" Class="h-4 w-4" />
                                </Button>
                                <Heading Level="3" Size="base" Class="min-w-[140px] text-center">
                                    @_currentMonth.ToString("MMMM yyyy")
                                </Heading>
                                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Icon"
                                        OnClick="@NextMonth">
                                    <DynamicIcon Name="ChevronRight" Class="h-4 w-4" />
                                </Button>
                            </Flex>
                            <Flex Align="center" Gap="1">
                                <Button Variant="@(_view == "day" ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                                        Size="Button.ButtonSize.Sm"
                                        OnClick="@(() => _view = "day")">Day</Button>
                                <Button Variant="@(_view == "week" ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                                        Size="Button.ButtonSize.Sm"
                                        OnClick="@(() => _view = "week")">Week</Button>
                                <Button Variant="@(_view == "month" ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                                        Size="Button.ButtonSize.Sm"
                                        OnClick="@(() => _view = "month")">Month</Button>
                            </Flex>
                        </Flex>
                    </CardHeader>

                    <CardContent>
                        <!-- Day Headers -->
                        <Grid Columns="7" Gap="0" Class="mb-2">
                            @foreach (var day in new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" })
                            {
                                <Lumeo.Text Size="xs" Weight="medium" Color="muted" Align="center" Class="py-1">@day</Lumeo.Text>
                            }
                        </Grid>

                        <!-- Calendar Grid -->
                        <Grid Class="grid-cols-7 gap-px bg-border rounded-lg overflow-hidden">
                            @{
                                var firstDay = new DateTime(_currentMonth.Year, _currentMonth.Month, 1);
                                var startOffset = (int)firstDay.DayOfWeek;
                                var daysInMonth = DateTime.DaysInMonth(_currentMonth.Year, _currentMonth.Month);
                                var today = DateTime.Today;
                                var totalCells = ((startOffset + daysInMonth + 6) / 7) * 7;
                            }
                            @for (int i = 0; i < totalCells; i++)
                            {
                                var dayNum = i - startOffset + 1;
                                var isCurrentMonth = dayNum >= 1 && dayNum <= daysInMonth;
                                var date = isCurrentMonth ? new DateTime(_currentMonth.Year, _currentMonth.Month, dayNum) : (DateTime?)null;
                                var isToday = date.HasValue && date.Value.Date == today;
                                var isSelected = date.HasValue && date.Value.Date == _selectedDate.Date;
                                var hasEvents = date.HasValue && _events.Any(e => e.Date.Date == date.Value.Date);
                                var dayEvents = date.HasValue ? _events.Where(e => e.Date.Date == date.Value.Date).ToList() : new();
                                var cellDay = dayNum;
                                var cellDate = date;

                                <Stack Class="@($"bg-background p-1.5 min-h-[72px] cursor-pointer hover:bg-accent transition-colors {(isSelected ? "bg-accent" : "")}")"
                                     @onclick="@(() => { if (cellDate.HasValue) _selectedDate = cellDate.Value; })">
                                    <Flex Direction="col" Class="h-full">
                                        <Lumeo.Text As="span" Class="@($"text-xs font-medium w-6 h-6 flex items-center justify-center rounded-full mb-1 {(isToday ? "bg-primary text-primary-foreground" : isCurrentMonth ? "text-foreground" : "text-muted-foreground/40")}")">
                                            @(isCurrentMonth ? dayNum.ToString() : "")
                                        </Lumeo.Text>
                                        @if (hasEvents)
                                        {
                                            <Flex Class="flex-wrap gap-0.5">
                                                @foreach (var ev in dayEvents.Take(3))
                                                {
                                                    <Lumeo.Text As="span" Class="@($"inline-block w-1.5 h-1.5 rounded-full {ev.ColorClass}")"></Lumeo.Text>
                                                }
                                            </Flex>
                                        }
                                    </Flex>
                                </Stack>
                            }
                        </Grid>

                        <!-- Color Legend -->
                        <Flex Class="items-center gap-4 flex-wrap mt-4 pt-3 border-t border-border/40">
                            <Flex Class="items-center gap-1.5">
                                <Stack Class="h-2.5 w-2.5 rounded-full bg-primary" />
                                <Lumeo.Text Class="text-xs text-muted-foreground">Work</Lumeo.Text>
                            </Flex>
                            <Flex Class="items-center gap-1.5">
                                <Stack Class="h-2.5 w-2.5 rounded-full bg-chart-1" />
                                <Lumeo.Text Class="text-xs text-muted-foreground">Health</Lumeo.Text>
                            </Flex>
                            <Flex Class="items-center gap-1.5">
                                <Stack Class="h-2.5 w-2.5 rounded-full bg-destructive" />
                                <Lumeo.Text Class="text-xs text-muted-foreground">Urgent</Lumeo.Text>
                            </Flex>
                            <Flex Class="items-center gap-1.5">
                                <Stack Class="h-2.5 w-2.5 rounded-full bg-chart-2" />
                                <Lumeo.Text Class="text-xs text-muted-foreground">Personal</Lumeo.Text>
                            </Flex>
                            <Flex Class="items-center gap-1.5">
                                <Stack Class="h-2.5 w-2.5 rounded-full bg-chart-3" />
                                <Lumeo.Text Class="text-xs text-muted-foreground">Meeting</Lumeo.Text>
                            </Flex>
                        </Flex>
                    </CardContent>
                </Card>
            </Stack>

            <!-- Side Panel -->
            <Stack Gap="4" Class="w-full lg:w-72">

                <!-- Selected Day Events -->
                <Card>
                    <CardHeader>
                        <Heading Level="3" Size="sm">
                            @_selectedDate.ToString("dddd, MMMM d")
                        </Heading>
                    </CardHeader>
                    <CardContent Class="p-0">
                        @{
                            var selectedEvents = _events.Where(e => e.Date.Date == _selectedDate.Date).ToList();
                        }
                        @if (!selectedEvents.Any())
                        {
                            <Lumeo.Text Size="sm" Color="muted" Class="px-4 pb-4">No events scheduled.</Lumeo.Text>
                        }
                        else
                        {
                            <Stack Class="divide-y divide-border">
                                @foreach (var ev in selectedEvents)
                                {
                                    <Stack Class="px-4 py-3 cursor-pointer hover:bg-accent/50 transition-colors"
                                           @onclick="@(() => _selectedEvent = ev)">
                                        <Flex Align="start" Gap="3">
                                            <Lumeo.Text As="span" Class="@($"mt-1 w-2 h-2 rounded-full shrink-0 {ev.ColorClass}")"></Lumeo.Text>
                                            <Stack Gap="0" Class="min-w-0">
                                                <Lumeo.Text Size="sm" Weight="medium" Color="foreground" Truncate="true">@ev.Title</Lumeo.Text>
                                                <Lumeo.Text Size="xs" Color="muted">@ev.Time</Lumeo.Text>
                                                <Badge Variant="Badge.BadgeVariant.Secondary" Class="mt-1 w-fit text-xs">@ev.Category</Badge>
                                            </Stack>
                                        </Flex>
                                    </Stack>
                                }
                            </Stack>
                        }
                    </CardContent>
                </Card>

                <!-- New Event Form -->
                <Card>
                    <CardHeader>
                        <Heading Level="3" Size="sm">New Event</Heading>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="3">
                            <Stack Gap="1.5">
                                <Label Class="text-xs">Title</Label>
                                <Input @bind-Value="_newEventTitle" placeholder="Event title" />
                            </Stack>
                            <Grid Columns="2" Gap="2">
                                <Stack Gap="1.5">
                                    <Label Class="text-xs">Start</Label>
                                    <Input type="time" Value="09:00" />
                                </Stack>
                                <Stack Gap="1.5">
                                    <Label Class="text-xs">End</Label>
                                    <Input type="time" Value="10:00" />
                                </Stack>
                            </Grid>
                            <Stack Gap="1.5">
                                <Label Class="text-xs">Description</Label>
                                <Textarea placeholder="Add a description..." />
                            </Stack>
                            <Stack Gap="1.5">
                                <Label Class="text-xs">Category</Label>
                                <Select @bind-Value="_newEventCategory">
                                    <SelectTrigger>
                                        <SelectValue Placeholder="Select category" />
                                    </SelectTrigger>
                                    <SelectContent>
                                        <SelectItem Value="@("Work")">Work</SelectItem>
                                        <SelectItem Value="@("Meeting")">Meeting</SelectItem>
                                        <SelectItem Value="@("Personal")">Personal</SelectItem>
                                        <SelectItem Value="@("Urgent")">Urgent</SelectItem>
                                        <SelectItem Value="@("Health")">Health</SelectItem>
                                    </SelectContent>
                                </Select>
                            </Stack>
                            <Stack Gap="1.5">
                                <Label Class="text-xs">Color</Label>
                                <Flex Gap="2">
                                    @foreach (var color in _colorOptions)
                                    {
                                        var c = color;
                                        <Button Variant="Button.ButtonVariant.Ghost"
                                                Class="@($"w-6 h-6 p-0 rounded-full {c.Value} ring-offset-2 ring-offset-background transition-all {(_selectedColor == c.Key ? "ring-2 ring-foreground" : "")}")"
                                                @onclick="@(() => _selectedColor = c.Key)">
                                        </Button>
                                    }
                                </Flex>
                            </Stack>
                            <Button Variant="Button.ButtonVariant.Default" Class="w-full" OnClick="@AddEvent">
                                <DynamicIcon Name="Plus" Class="h-4 w-4" />
                                Create Event
                            </Button>
                        </Stack>
                    </CardContent>
                </Card>

            </Stack>
        </Flex>
    </ComponentDemo>

</Stack>

@code {
    private DateTime _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _selectedDate = DateTime.Today;
    private string _view = "month";
    private string _newEventTitle = "";
    private string _selectedColor = "blue";
    private string _newEventCategory = "Work";
    private CalendarEvent? _selectedEvent;

    private Dictionary<string, string> _colorOptions = new()
    {
        { "blue", "bg-primary" },
        { "green", "bg-chart-1" },
        { "red", "bg-destructive" },
        { "purple", "bg-chart-2" },
        { "orange", "bg-chart-3" },
    };

    private List<CalendarEvent> _events = new()
    {
        new(DateTime.Today, "Team standup", "9:00 AM", "bg-primary", "Work"),
        new(DateTime.Today, "Design review", "2:00 PM", "bg-chart-2", "Meeting"),
        new(DateTime.Today, "Sprint planning", "4:00 PM", "bg-chart-1", "Health"),
        new(DateTime.Today.AddDays(2), "Client call", "10:00 AM", "bg-chart-3", "Personal"),
        new(DateTime.Today.AddDays(2), "Lunch with Sarah", "12:30 PM", "bg-destructive", "Urgent"),
        new(DateTime.Today.AddDays(5), "Product demo", "3:00 PM", "bg-primary", "Work"),
        new(DateTime.Today.AddDays(-2), "Release v2.0", "11:00 AM", "bg-chart-1", "Health"),
    };

    private void PrevMonth() => _currentMonth = _currentMonth.AddMonths(-1);
    private void NextMonth() => _currentMonth = _currentMonth.AddMonths(1);

    private void AddEvent()
    {
        if (!string.IsNullOrWhiteSpace(_newEventTitle))
        {
            var colorClass = _colorOptions.GetValueOrDefault(_selectedColor, "bg-primary");
            _events.Add(new CalendarEvent(_selectedDate, _newEventTitle, "12:00 PM", colorClass, _newEventCategory));
            _newEventTitle = "";
        }
    }

    private record CalendarEvent(DateTime Date, string Title, string Time, string ColorClass, string Category);

    private string _calendarCode = @"<!-- Calendar with month grid, event dots, side panel, and new event form -->
<Flex Gap=""4"">
    <!-- Main Calendar -->
    <Card Class=""flex-1"">
        <CardHeader>
            <Flex Align=""center"" Justify=""between"">
                <Flex Align=""center"" Gap=""2"">
                    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Icon"" OnClick=""PrevMonth"">
                        <DynamicIcon Name=""ChevronLeft"" Class=""h-4 w-4"" />
                    </Button>
                    <Heading Level=""3"" Class=""font-semibold"">@_currentMonth.ToString(""MMMM yyyy"")</Heading>
                    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Icon"" OnClick=""NextMonth"">
                        <DynamicIcon Name=""ChevronRight"" Class=""h-4 w-4"" />
                    </Button>
                </Flex>
                <Flex Gap=""1"">
                    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Day</Button>
                    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Week</Button>
                    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Month</Button>
                </Flex>
            </Flex>
        </CardHeader>
        <CardContent>
            <!-- 7-column day grid -->
            <Grid Class=""grid-cols-7 gap-px bg-border rounded-lg overflow-hidden"">
                @for (int i = 0; i < totalCells; i++)
                {
                    <Stack Class=""bg-background p-1.5 min-h-[72px] cursor-pointer hover:bg-accent"" Gap=""0"">
                        <Lumeo.Text As=""span"" Class=""text-xs font-medium"">@dayNum</Lumeo.Text>
                        <!-- Event dots -->
                        <Flex Class=""gap-0.5 mt-1"">
                            <Stack Class=""w-1.5 h-1.5 rounded-full bg-primary"" />
                            <Stack Class=""w-1.5 h-1.5 rounded-full bg-chart-1"" />
                        </Flex>
                    </Stack>
                }
            </Grid>
        </CardContent>
    </Card>

    <!-- Side Panel -->
    <Stack Gap=""4"" Class=""w-72"">
        <!-- Day Events -->
        <Card>
            <CardHeader>
                <Heading Level=""3"" Class=""text-sm font-semibold"">@_selectedDate.ToString(""dddd, MMMM d"")</Heading>
            </CardHeader>
            <CardContent>
                <Flex Align=""center"" Gap=""3"" Class=""py-2"">
                    <Stack Class=""w-2 h-2 rounded-full bg-primary"" />
                    <Stack Gap=""0"">
                        <Lumeo.Text Class=""text-sm font-medium"">Team standup</Lumeo.Text>
                        <Lumeo.Text Class=""text-xs text-muted-foreground"">9:00 AM</Lumeo.Text>
                    </Stack>
                </Flex>
            </CardContent>
        </Card>

        <!-- New Event -->
        <Card>
            <CardHeader><Heading Level=""3"" Class=""text-sm font-semibold"">New Event</Heading></CardHeader>
            <CardContent>
                <Stack Gap=""3"">
                    <Input placeholder=""Event title"" />
                    <Grid Class=""grid-cols-2 gap-2"">
                        <Input type=""time"" Value=""09:00"" />
                        <Input type=""time"" Value=""10:00"" />
                    </Grid>
                    <Textarea placeholder=""Description..."" />
                    <Select>
                        <SelectTrigger><SelectValue Placeholder=""Category"" /></SelectTrigger>
                        <SelectContent>
                            <SelectItem Value=""Work"">Work</SelectItem>
                            <SelectItem Value=""Meeting"">Meeting</SelectItem>
                            <SelectItem Value=""Personal"">Personal</SelectItem>
                        </SelectContent>
                    </Select>
                    <Button Variant=""Button.ButtonVariant.Default"" Class=""w-full"">
                        <DynamicIcon Name=""Plus"" Class=""h-4 w-4"" />
                        Create Event
                    </Button>
                </Stack>
            </CardContent>
        </Card>
    </Stack>
</Flex>

@code {
    private DateTime _currentMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime _selectedDate = DateTime.Today;

    private record CalendarEvent(DateTime Date, string Title, string Time, string ColorClass, string Category);

    private void PrevMonth() => _currentMonth = _currentMonth.AddMonths(-1);
    private void NextMonth() => _currentMonth = _currentMonth.AddMonths(1);
}";
}
