    private async Task CopyInstall()
    {
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", "dotnet add package Lumeo"); }
        catch (JSException) { }
        _installCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _installCopied = false;
        StateHasChanged();
    }

    // Kanban drag-and-drop: each card sets _draggingCard on dragstart; each column's
    // OnDrop calls MoveDraggingCard(targetList) to remove from its current list and
    // append to the dropped-into list. KanbanColumn already preventDefaults dragover.
    private void MoveDraggingCard(List<KanbanItem> target)
    {
        if (_draggingCard is null) return;
        if (_kanbanTodo.Remove(_draggingCard) || _kanbanDoing.Remove(_draggingCard) || _kanbanDone.Remove(_draggingCard))
        {
            if (!target.Contains(_draggingCard))
            {
                target.Add(_draggingCard);
            }
        }
        _draggingCard = null;
        StateHasChanged();
    }

    // ------------------------------------------------------------------------------------
    // Living-demo timers — all kept in a single list so Dispose() can blanket-clean them up.
    // Each timer:
    //   * guards on its tile-local hovered bool so user interaction wins
    //   * mutates state inside InvokeAsync + StateHasChanged for thread-safety
    // ------------------------------------------------------------------------------------
    private readonly List<System.Threading.Timer> _timers = new();

    // DropdownMenu submenu showcase — opens ~2.5s, closes ~2s, repeats.

    // Auto-cycling Tabs — advances through 4 values every 3s.
    private string _tabsActive = "overview";
    private bool _tabsHovered;
    private static readonly string[] _tabsValues = { "overview", "activity", "reports", "settings" };

    // Auto-advancing Steps — wraps 0→3→0 every 2.5s.
    private int _stepIndex;
    private bool _stepsHovered;

    // Chart cycling — hover pauses.
    private bool _chartHovered;

    // Page-visibility gate. When the user switches to another tab, all timer
    // callbacks short-circuit so we don't queue work that bursts on return
    // (was: dozens of stale toasts + rapid chart reshuffles when refocusing).
    // The flag is flipped from JS via the `visibilitychange` listener wired
    // up in OnAfterRenderAsync.
    private bool _pageVisible = true;
    private IJSObjectReference? _visibilityHandle;
    private DotNetObjectReference<Home>? _selfRef;

    [JSInvokable]
    public void SetPageVisibility(bool visible)
    {
        _pageVisible = visible;
    }

    // Toast bank — cycled every 11s. Realistic dev-experience copy so the demo feels
    // like a working app, not a test harness.
    private int _toastIndex;
    private static readonly (string Title, string? Desc, ToastVariant Variant)[] _toastBank =
    {
        ("Build succeeded",   "2.4s · 0 warnings",                ToastVariant.Default),
        ("Saved to draft",    "Auto-saved 12 seconds ago",        ToastVariant.Success),
        ("Cloudflare deploy", "ready · pages.dev",                ToastVariant.Info),
        ("Approaching quota", "87% used · upgrade or prune",      ToastVariant.Warning),
    };

    protected override void OnInitialized()
    {
        // DropdownMenu auto-cycle removed — fixed-position menu rendered free of
        // its trigger when opened programmatically without a user click. Visitors
        // open it manually via hover/click, which fires the proper positioning.

        // 2. Tabs — fixed 3s rotation.
        _timers.Add(new System.Threading.Timer(_ =>
        {
            if (_tabsHovered || !_pageVisible) return;
            var nextIx = (Array.IndexOf(_tabsValues, _tabsActive) + 1) % _tabsValues.Length;
            _tabsActive = _tabsValues[nextIx];
            InvokeAsync(StateHasChanged);
        }, null, 3000, 3000));

        // 3. Steps — 2.5s rotation, wraps 0→3→0.
        _timers.Add(new System.Threading.Timer(_ =>
        {
            if (_stepsHovered || !_pageVisible) return;
            _stepIndex = (_stepIndex + 1) % 4;
            InvokeAsync(StateHasChanged);
        }, null, 2500, 2500));

        // 4. Charts — three live ECharts (Bar/Line/Area) all reshuffle their
        //    series values every 2s so the showcase pulses with motion. The
        //    chart types stay fixed (user wanted no Pie/Donut, no cycling).
        _timers.Add(new System.Threading.Timer(_ =>
        {
            if (_chartHovered || !_pageVisible) return;
            _chartSnapshot = (_chartSnapshot + 1) % _chartSnapshots.Length;
            var snap = _chartSnapshots[_chartSnapshot];
            InvokeAsync(() =>
            {
                // Bar — stacked, 3-series quarterly.
                for (int i = 0; i < _barSeries.Count && i < snap.Length; i++)
                    _barSeries[i].Values = new List<double>(snap[i]);
                // Line — first stripe of the snapshot, scaled down so the axis stays readable.
                _lineSeries[0].Values = snap[0].Select(v => v / 12d).ToList();
                // Radar — second stripe normalised into 0–100 range per axis so
                // the polygon morphs visibly without collapsing.
                var raw = snap[1];
                var maxv = raw.Max();
                _radarSeries[0].Values = raw.Select(v => Math.Round(v / maxv * 95d, 1)).ToList();
                StateHasChanged();
            });
        }, null, 1500, 2000));

        // 5. Toasts — fire every 11s with short Duration so they come and go cleanly.
        // No hover guard: toasts already render bottom-right via the global viewport,
        // they're not bound to a specific tile. Page-visibility guard prevents the
        // toast queue from spamming on tab refocus.
        _timers.Add(new System.Threading.Timer(_ =>
        {
            if (!_pageVisible) return;
            var t = _toastBank[_toastIndex];
            _toastIndex = (_toastIndex + 1) % _toastBank.Length;
            InvokeAsync(() =>
            {
                ToastService.Show(new ToastOptions
                {
                    Title = t.Title,
                    Description = t.Desc,
                    Variant = t.Variant,
                    Duration = 4500,
                });
            });
        }, null, 6000, 11000));
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _selfRef = DotNetObjectReference.Create(this);
            _visibilityHandle = await JS.InvokeAsync<IJSObjectReference>(
                "lumeo.onPageVisibility", _selfRef, nameof(SetPageVisibility));
        }
        catch (JSException) { /* SSR / bUnit / prerender — visibility hook is a nice-to-have */ }
        catch (JSDisconnectedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        foreach (var t in _timers) t.Dispose();
        _timers.Clear();
        try
        {
            if (_visibilityHandle is not null)
            {
                await _visibilityHandle.InvokeVoidAsync("dispose");
                await _visibilityHandle.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { /* circuit dropped */ }
        catch { /* swallow on teardown */ }
        _selfRef?.Dispose();
    }
}
