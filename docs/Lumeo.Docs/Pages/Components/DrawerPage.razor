@page "/components/drawer"

<PageTitle>Drawer — Lumeo</PageTitle>

<PageHeader Title="Drawer" Description="A panel that slides up from the bottom of the screen on mobile devices." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Drawer @bind-IsOpen="_isOpen">
            <DrawerTrigger>
                <Button Variant="Button.ButtonVariant.Outline">Open Drawer</Button>
            </DrawerTrigger>
            <DrawerContent>
                <DrawerHeader>
                    <DrawerTitle>Move Goal</DrawerTitle>
                    <DrawerDescription>Set your daily activity goal.</DrawerDescription>
                </DrawerHeader>
                <Flex Align="center" Justify="center" Gap="4" Class="p-4 pb-0">
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Icon" OnClick="Decrease">
                        <DynamicIcon Name="Minus" Class="h-4 w-4" />
                    </Button>
                    <Stack Gap="0" Class="text-center">
                        <Lumeo.Text Size="5xl" Weight="bold" Class="tracking-tighter">@_goal</Lumeo.Text>
                        <Lumeo.Text Size="sm" Color="muted" Class="mt-1">calories/day</Lumeo.Text>
                    </Stack>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Icon" OnClick="Increase">
                        <DynamicIcon Name="Plus" Class="h-4 w-4" />
                    </Button>
                </Flex>
                <DrawerFooter>
                    <DrawerClose>
                        <Button Class="w-full">Submit</Button>
                    </DrawerClose>
                    <DrawerClose>
                        <Button Variant="Button.ButtonVariant.Outline" Class="w-full">Cancel</Button>
                    </DrawerClose>
                </DrawerFooter>
            </DrawerContent>
        </Drawer>
    </ComponentDemo>

    <ComponentDemo Title="Filters Drawer" Code="@_filtersCode">
        <Drawer @bind-IsOpen="_isFiltersOpen">
            <DrawerTrigger>
                <Button Variant="Button.ButtonVariant.Outline">
                    <DynamicIcon Name="Settings" Class="h-4 w-4" /> Filters
                </Button>
            </DrawerTrigger>
            <DrawerContent>
                <DrawerHeader>
                    <DrawerTitle>Filter Results</DrawerTitle>
                    <DrawerDescription>Narrow down your search with these options.</DrawerDescription>
                </DrawerHeader>
                <Stack Gap="4" Class="p-4">
                    <Stack Gap="2">
                        <Label>Category</Label>
                        <Select @bind-Value="_filterCategory">
                            <SelectTrigger>
                                <span class="@(_filterCategory == null ? "text-muted-foreground" : "")">@(_filterCategory ?? "All categories")</span>
                            </SelectTrigger>
                            <SelectContent>
                                <SelectItem Value="electronics">Electronics</SelectItem>
                                <SelectItem Value="clothing">Clothing</SelectItem>
                                <SelectItem Value="books">Books</SelectItem>
                                <SelectItem Value="home">Home & Garden</SelectItem>
                            </SelectContent>
                        </Select>
                    </Stack>
                    <Stack Gap="2">
                        <Label>Sort by</Label>
                        <RadioGroup @bind-Value="_filterSort">
                            <Flex Align="center" Gap="2">
                                <RadioGroupItem Value="popular" />
                                <Label>Most popular</Label>
                            </Flex>
                            <Flex Align="center" Gap="2">
                                <RadioGroupItem Value="newest" />
                                <Label>Newest first</Label>
                            </Flex>
                            <Flex Align="center" Gap="2">
                                <RadioGroupItem Value="price-asc" />
                                <Label>Price: low to high</Label>
                            </Flex>
                        </RadioGroup>
                    </Stack>
                </Stack>
                <DrawerFooter>
                    <DrawerClose>
                        <Button Class="w-full">Apply Filters</Button>
                    </DrawerClose>
                    <DrawerClose>
                        <Button Variant="Button.ButtonVariant.Outline" Class="w-full">Reset</Button>
                    </DrawerClose>
                </DrawerFooter>
            </DrawerContent>
        </Drawer>
    </ComponentDemo>

    <ComponentDemo Title="Prevent Close" Code="@_preventCloseCode">
        <Drawer @bind-IsOpen="_preventDrawerOpen">
            <DrawerTrigger>
                <Button Variant="Button.ButtonVariant.Outline">Open Protected Drawer</Button>
            </DrawerTrigger>
            <DrawerContent PreventClose="true">
                <DrawerHeader>
                    <DrawerTitle>Confirm Action</DrawerTitle>
                    <DrawerDescription>You must choose an option to continue.</DrawerDescription>
                </DrawerHeader>
                <Stack Gap="2" Class="p-4">
                    <Button Class="w-full" OnClick="@(() => _preventDrawerOpen = false)">Confirm</Button>
                    <Button Variant="Button.ButtonVariant.Outline" Class="w-full" OnClick="@(() => _preventDrawerOpen = false)">Cancel</Button>
                </Stack>
            </DrawerContent>
        </Drawer>
    </ComponentDemo>

    <ComponentDemo Title="Simple Drawer" Code="@_simpleCode">
        <Drawer @bind-IsOpen="_isSimpleOpen">
            <DrawerTrigger>
                <Button>View Details</Button>
            </DrawerTrigger>
            <DrawerContent>
                <DrawerHeader>
                    <DrawerTitle>Order Details</DrawerTitle>
                    <DrawerDescription>Review your recent order information.</DrawerDescription>
                </DrawerHeader>
                <Stack Gap="2" Class="p-4">
                    <Flex Justify="between" Class="text-sm">
                        <Lumeo.Text As="span" Size="sm" Color="muted">Order ID</Lumeo.Text>
                        <Lumeo.Text As="span" Size="sm" Weight="medium">#12345</Lumeo.Text>
                    </Flex>
                    <Flex Justify="between" Class="text-sm">
                        <Lumeo.Text As="span" Size="sm" Color="muted">Status</Lumeo.Text>
                        <Lumeo.Text As="span" Size="sm" Weight="medium">Shipped</Lumeo.Text>
                    </Flex>
                    <Flex Justify="between" Class="text-sm">
                        <Lumeo.Text As="span" Size="sm" Color="muted">Total</Lumeo.Text>
                        <Lumeo.Text As="span" Size="sm" Weight="medium">$49.99</Lumeo.Text>
                    </Flex>
                </Stack>
                <DrawerFooter>
                    <DrawerClose>
                        <Button Class="w-full">Close</Button>
                    </DrawerClose>
                </DrawerFooter>
            </DrawerContent>
        </Drawer>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">Drawer</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpen</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Controls whether the drawer is open. Use with @@bind-IsOpen for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpenChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;bool&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the open state changes.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div>
            <Heading Level="3" Class="mb-3">DrawerContent</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">PreventClose</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Prevents closing via swipe or backdrop click.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">The panel that slides up from the bottom of the screen. Includes focus trap, scroll lock, and swipe-to-dismiss gesture. Sub-components DrawerTrigger, DrawerClose, DrawerHeader, DrawerFooter, DrawerTitle, DrawerDescription mirror the Dialog/Sheet API.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private bool _isOpen;
    private bool _isSimpleOpen;
    private bool _isFiltersOpen;
    private bool _preventDrawerOpen;
    private string? _filterCategory;
    private string? _filterSort = "popular";
    private int _goal = 350;

    private void Increase() => _goal = Math.Min(1000, _goal + 10);
    private void Decrease() => _goal = Math.Max(100, _goal - 10);

    private string _preventCloseCode = @"<Drawer @bind-IsOpen=""_preventDrawerOpen"">
    <DrawerTrigger>
        <Button Variant=""Button.ButtonVariant.Outline"">Open Protected Drawer</Button>
    </DrawerTrigger>
    <DrawerContent PreventClose=""true"">
        <DrawerHeader>
            <DrawerTitle>Confirm Action</DrawerTitle>
            <DrawerDescription>You must choose an option to continue.</DrawerDescription>
        </DrawerHeader>
        <Stack Gap=""2"" Class=""p-4"">
            <Button Class=""w-full"" OnClick=""@(() => _preventDrawerOpen = false)"">Confirm</Button>
            <Button Variant=""Button.ButtonVariant.Outline"" Class=""w-full"" OnClick=""@(() => _preventDrawerOpen = false)"">Cancel</Button>
        </Stack>
    </DrawerContent>
</Drawer>

@code {
    private bool _preventDrawerOpen;
}";

