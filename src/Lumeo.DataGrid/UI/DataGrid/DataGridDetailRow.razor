@namespace Lumeo
@typeparam TItem

<tr class="@CssClass" @attributes="AdditionalAttributes">
    <td colspan="@ColSpan" class="p-4">
        @if (DetailTemplate is not null)
        {
            @DetailTemplate(Item)
        }
    </td>
</tr>

@code {
    /// <summary>The row data whose detail content is being expanded, passed to
    /// <see cref="DetailTemplate"/>.</summary>
    [Parameter] public TItem Item { get; set; } = default!;

    /// <summary>Template rendered inside the spanning detail cell. Renders nothing
    /// when unset.</summary>
    [Parameter] public RenderFragment<TItem>? DetailTemplate { get; set; }

    /// <summary>Number of columns the detail cell spans, matching the parent row's
    /// total column count. Defaults to 1.</summary>
    [Parameter] public int ColSpan { get; set; } = 1;

    /// <summary>Additional CSS classes merged onto the <c>&lt;tr&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures unmatched attributes and applies them to the <c>&lt;tr&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"bg-muted/20 {Class}".Trim();
}
