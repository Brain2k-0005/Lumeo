@page "/components/result"

<PageTitle>Result — Lumeo</PageTitle>

<PageHeader Title="Result" Description="Displays the outcome of an operation with status icon, title, description, and action buttons." />

<InstallUsage Component="Result" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Success or error pages after a form submission or payment</li>
        <li>Operation outcomes such as completed actions or failed processes</li>
        <li>Confirmation screens showing the result of a user action</li>
        <li>HTTP error pages like 404 Not Found or 403 Forbidden</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Success" Code="@_codeSuccess">
        <Result Status="Result.ResultStatus.Success" Title="Payment Successful" SubTitle="Order #2024-0127 has been confirmed.">
            <Extra>
                <Button>Go to Dashboard</Button>
                <Button Variant="Button.ButtonVariant.Outline">View Order</Button>
            </Extra>
        </Result>
    </ComponentDemo>

    <ComponentDemo Title="Error" Code="@_codeError">
        <Result Status="Result.ResultStatus.Error" Title="Submission Failed" SubTitle="Please check your form and try again.">
            <Extra>
                <Button Variant="Button.ButtonVariant.Destructive">Retry</Button>
            </Extra>
        </Result>
    </ComponentDemo>

    <ComponentDemo Title="All Statuses" Code="@_codeStatuses">
        <Grid Columns="2" Gap="4">
            <Result Status="Result.ResultStatus.Warning" Title="Warning" SubTitle="Proceed with caution." />
            <Result Status="Result.ResultStatus.Info" Title="Information" SubTitle="Here is some useful info." />
            <Result Status="Result.ResultStatus.NotFound" Title="404 Not Found" SubTitle="The page you are looking for does not exist." />
            <Result Status="Result.ResultStatus.Forbidden" Title="403 Forbidden" SubTitle="You do not have permission to access this." />
        </Grid>
    </ComponentDemo>

    <ComponentDemo Title="Sizes">
        <Grid Columns="3" Gap="4">
            <Result Status="Result.ResultStatus.Success" Size="Lumeo.Size.Sm" Title="Small" SubTitle="Compact result." />
            <Result Status="Result.ResultStatus.Success" Size="Lumeo.Size.Md" Title="Medium" SubTitle="Default result." />
            <Result Status="Result.ResultStatus.Success" Size="Lumeo.Size.Lg" Title="Large" SubTitle="Prominent result." />
        </Grid>
    </ComponentDemo>

    <ComponentDemo Title="Server Error">
        <Result Status="Result.ResultStatus.ServerError" Title="500 Internal Server Error" SubTitle="Something went wrong on our end. Please try again later.">
            <Extra>
                <Button>Reload</Button>
            </Extra>
        </Result>
    </ComponentDemo>

    <ComponentDemo Title="Custom Icon">
        <Result Status="Result.ResultStatus.Info" Title="Email Sent" SubTitle="We've sent a confirmation link to your inbox.">
            <IconContent>
                <DynamicIcon Name="Mail" Class="h-8 w-8" />
            </IconContent>
            <Extra>
                <Button Variant="Button.ButtonVariant.Outline">Resend</Button>
            </Extra>
        </Result>
    </ComponentDemo>

    <ComponentDemo Title="Status — interactive" Code="@_codeStatusInteractive">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Pick a status to see it applied live.</Lumeo.Text>
            <Flex Wrap="true" Gap="2">
                @foreach (var s in _statusOptions)
                {
                    var status = s;
                    <Button Size="Button.ButtonSize.Sm"
                            Variant="@(_selectedStatus == status ? Button.ButtonVariant.Default : Button.ButtonVariant.Outline)"
                            OnClick="@(() => _selectedStatus = status)">@status</Button>
                }
            </Flex>
            <Result Status="@ParseResultStatus(_selectedStatus)"
                    Title="@($"{_selectedStatus} Result")"
                    SubTitle="@($"This is a {_selectedStatus.ToLower()} result page.")" />
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Lumeo.Text Size="sm" Color="muted">
        <code>Status</code> accepts one of <code>ResultStatus.Success</code>, <code>Error</code>, <code>Warning</code>, <code>Info</code>, <code>NotFound</code>, <code>Forbidden</code>, <code>ServerError</code>.
    </Lumeo.Text>
    <PropsTable Slug="result" />
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/alert" class="text-primary hover:underline">Alert</a> — Inline status messages within a page rather than full-page outcomes</li>
        <li><a href="/components/empty-state" class="text-primary hover:underline">EmptyState</a> — Placeholder when there is no data, rather than an operation result</li>
        <li><a href="/components/card" class="text-primary hover:underline">Card</a> — Container for embedding result content within a layout</li>
    </ul>
</div>

@code {
    private string[] _statusOptions = ["Success", "Error", "Warning", "Info", "NotFound", "Forbidden", "ServerError"];
    private string _selectedStatus = "Success";

    private Result.ResultStatus ParseResultStatus(string s) => s switch
    {
        "Error"       => Result.ResultStatus.Error,
        "Warning"     => Result.ResultStatus.Warning,
        "Info"        => Result.ResultStatus.Info,
        "NotFound"    => Result.ResultStatus.NotFound,
        "Forbidden"   => Result.ResultStatus.Forbidden,
        "ServerError" => Result.ResultStatus.ServerError,
        _             => Result.ResultStatus.Success,
    };

    private string _codeStatusInteractive = @"<Result Status=""Result.ResultStatus.Success"" Title=""Success Result"" SubTitle=""This is a success result page."" />";

    private string _codeSuccess = @"<Result Status=""Result.ResultStatus.Success"" Title=""Payment Successful"" SubTitle=""Order confirmed."">
    <Extra>
        <Button>Go to Dashboard</Button>
        <Button Variant=""Button.ButtonVariant.Outline"">View Order</Button>
    </Extra>
</Result>";

    private string _codeError = @"<Result Status=""Result.ResultStatus.Error"" Title=""Submission Failed"" SubTitle=""Please check and try again."">
    <Extra>
        <Button Variant=""Button.ButtonVariant.Destructive"">Retry</Button>
    </Extra>
</Result>";

    private string _codeStatuses = @"<Result Status=""Result.ResultStatus.Warning"" Title=""Warning"" SubTitle=""Proceed with caution."" />
<Result Status=""Result.ResultStatus.Info"" Title=""Information"" SubTitle=""Useful info."" />
<Result Status=""Result.ResultStatus.NotFound"" Title=""404 Not Found"" SubTitle=""Page does not exist."" />
<Result Status=""Result.ResultStatus.Forbidden"" Title=""403 Forbidden"" SubTitle=""No permission."" />";
}
