@page "/components/stack"

<PageTitle>Stack — Lumeo</PageTitle>

<PageHeader Title="Stack" Description="A flex-based layout component for stacking elements vertically or horizontally with consistent spacing." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Vertical" Code="@_basicCode">
        <Stack Gap="3" Class="w-full max-w-xs">
            <div class="h-10 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 1</div>
            <div class="h-10 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 2</div>
            <div class="h-10 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 3</div>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Horizontal" Code="@_horizontalCode">
        <Stack Direction="Stack.StackDirection.Horizontal" Gap="3">
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 1</div>
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 2</div>
            <div class="h-10 w-24 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">Item 3</div>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Gap Sizes" Code="@_gapCode">
        <Stack Gap="6" Class="w-full">
            <div>
                <Text Size="sm" Color="muted" Class="mb-2">Gap 1</Text>
                <Stack Direction="Stack.StackDirection.Horizontal" Gap="1">
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                </Stack>
            </div>
            <div>
                <Text Size="sm" Color="muted" Class="mb-2">Gap 4</Text>
                <Stack Direction="Stack.StackDirection.Horizontal" Gap="4">
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                </Stack>
            </div>
            <div>
                <Text Size="sm" Color="muted" Class="mb-2">Gap 8</Text>
                <Stack Direction="Stack.StackDirection.Horizontal" Gap="8">
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                    <div class="h-8 w-16 rounded bg-primary/20"></div>
                </Stack>
            </div>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Alignment" Code="@_alignCode">
        <Stack Direction="Stack.StackDirection.Horizontal" Gap="4" Align="center" Justify="between" Class="w-full">
            <div class="h-8 w-20 rounded bg-primary/20"></div>
            <div class="h-12 w-20 rounded bg-primary/20"></div>
            <div class="h-6 w-20 rounded bg-primary/20"></div>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Direction</TableCell>
                    <TableCell Class="font-mono text-xs">StackDirection</TableCell>
                    <TableCell Class="font-mono text-xs">Vertical</TableCell>
                    <TableCell>Stack direction. Vertical or Horizontal.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Gap</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">"4"</TableCell>
                    <TableCell>Tailwind gap value (e.g. "2", "4", "8").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Align</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Cross-axis alignment. Maps to items-{value} (e.g. "center", "start", "end").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Justify</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Main-axis alignment. Maps to justify-{value} (e.g. "center", "between", "end").</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Wrap</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Whether items should wrap to the next line.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _basicCode = @"<Stack Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";

    private string _horizontalCode = @"<Stack Direction=""Stack.StackDirection.Horizontal"" Gap=""3"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";

    private string _gapCode = @"<Stack Direction=""Stack.StackDirection.Horizontal"" Gap=""1"">...</Stack>
<Stack Direction=""Stack.StackDirection.Horizontal"" Gap=""4"">...</Stack>
<Stack Direction=""Stack.StackDirection.Horizontal"" Gap=""8"">...</Stack>";

    private string _alignCode = @"<Stack Direction=""Stack.StackDirection.Horizontal"" Gap=""4"" Align=""center"" Justify=""between"" Class=""w-full"">
    <div>Item 1</div>
    <div>Item 2</div>
    <div>Item 3</div>
</Stack>";
}
