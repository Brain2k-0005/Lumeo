@page "/components/charts/area"

<PageTitle>Area Chart — Lumeo</PageTitle>

<PageHeader Title="Area Chart" Description="Emphasize the magnitude of change over time. The filled area makes it easy to visualize volume or cumulative data." />

<Stack Gap="8">
    <ComponentDemo Title="Gradient Area" Code="@_basicCode">
        <Container>
            <AreaChart Categories="_categories" Series="_series" Smooth="true" Gradient="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Stacked Area" Code="@_stackedCode">
        <Container>
            <AreaChart Categories="_categories" Series="_series" Smooth="true" Stacked="true" Gradient="false" />
        </Container>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">AreaChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis labels for each data point.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Series</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;ChartSeriesData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Data series with filled areas.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Smooth</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Uses bezier curves for smooth edges.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Gradient</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Applies a gradient fade to the filled area.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Stacked</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Stacks series areas cumulatively.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowDots</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows dot markers on the line.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color palette.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" };
    private List<AreaChart.ChartSeriesData> _series = new()
    {
        new() { Name = "Unique Visitors", Values = new() { 3240, 4180, 3870, 5120, 6340, 4980, 3650 } },
        new() { Name = "Page Views",      Values = new() { 9810, 12540, 11200, 15870, 19420, 14730, 10900 } }
    };

    private string _basicCode = @"<AreaChart Categories=""_categories"" Series=""_series"" Smooth=""true"" Gradient=""true"" />";
    private string _stackedCode = @"<AreaChart Categories=""_categories"" Series=""_series"" Smooth=""true"" Stacked=""true"" Gradient=""false"" />";
}
