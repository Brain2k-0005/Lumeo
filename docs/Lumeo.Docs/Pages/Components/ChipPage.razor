@page "/components/chip"

<PageTitle>Chip — Lumeo</PageTitle>

<PageHeader Title="Chip" Description="A compact element representing an input, attribute, or action — used for tags, filters, status labels, and selected items in multi-select fields." />

<InstallUsage Component="Chip" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Status tags indicating state such as active, pending, or archived</li>
        <li>Filter chips that users can toggle to narrow down content</li>
        <li>Removable labels for selected items in multi-select or tag inputs</li>
        <li>Category or topic indicators in lists and cards</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Variants" Code="@_variantsCode">
        <ChipGroup>
            <Chip>Default</Chip>
            <Chip Variant="Chip.ChipVariant.Outline">Outline</Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="primary">Primary</Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="destructive">Destructive</Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="success">Success</Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="warning">Warning</Chip>
        </ChipGroup>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Code="@_sizesCode">
        <Flex Class="items-center gap-2 flex-wrap">
            <Chip Size="Lumeo.Size.Sm">Small</Chip>
            <Chip>Default</Chip>
            <Chip Size="Lumeo.Size.Lg">Large</Chip>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Closable" Code="@_closableCode">
        <Stack Gap="3">
            <ChipGroup>
                @foreach (var tag in _tags)
                {
                    var t = tag;
                    <Chip Closable="true" OnClose="@(() => _tags.Remove(t))">@t</Chip>
                }
            </ChipGroup>
            @if (!_tags.Any())
            {
                <Lumeo.Text Class="text-sm text-muted-foreground">All chips removed.</Lumeo.Text>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Clickable" Code="@_clickableCode">
        <Stack Gap="3">
            <ChipGroup>
                @foreach (var filter in _filters)
                {
                    var f = filter;
                    <Chip Clickable="true"
                          Variant="@(_activeFilter == f ? Chip.ChipVariant.Solid : Chip.ChipVariant.Outline)"
                          Color="@(_activeFilter == f ? "primary" : null)"
                          OnClick="@(() => _activeFilter = f)">
                        @f
                    </Chip>
                }
            </ChipGroup>
            <Lumeo.Text Class="text-sm text-muted-foreground">Active: @_activeFilter</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Variant (interactive)" Code="@_variantInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch variant to compare Default, Outline, and Solid styling.</Lumeo.Text>
            <Segmented @bind-Value="_chipVariant">
                <SegmentedItem Value="Default">Default</SegmentedItem>
                <SegmentedItem Value="Outline">Outline</SegmentedItem>
                <SegmentedItem Value="Solid">Solid</SegmentedItem>
            </Segmented>
            <ChipGroup>
                <Chip Variant="@_chipVariantEnum" Color="@(_chipVariant == "Solid" ? "primary" : null)">React</Chip>
                <Chip Variant="@_chipVariantEnum" Color="@(_chipVariant == "Solid" ? "success" : null)">TypeScript</Chip>
                <Chip Variant="@_chipVariantEnum" Color="@(_chipVariant == "Solid" ? "warning" : null)">Blazor</Chip>
            </ChipGroup>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="With Icon Slot" Code="@_iconSlotCode">
        <ChipGroup>
            <Chip>
                <IconContent><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e;"></span></IconContent>
                <ChildContent>Online</ChildContent>
            </Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="primary">
                <IconContent><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:currentColor;"></span></IconContent>
                <ChildContent>Primary</ChildContent>
            </Chip>
            <Chip Closable="true">
                <IconContent><span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;"></span></IconContent>
                <ChildContent>Pending</ChildContent>
            </Chip>
        </ChipGroup>
    </ComponentDemo>

    <ComponentDemo Title="With Icon" Code="@_iconCode">
        <ChipGroup>
            <Chip Icon="🔥">Hot</Chip>
            <Chip Icon="⭐">Featured</Chip>
            <Chip Icon="✅" Variant="Chip.ChipVariant.Solid" Color="success">Verified</Chip>
            <Chip Icon="⚠️" Variant="Chip.ChipVariant.Solid" Color="warning">Warning</Chip>
        </ChipGroup>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <ChipGroup>
            <Chip Clickable="true" Disabled="true">Disabled clickable</Chip>
            <Chip Closable="true" Disabled="true">Disabled closable</Chip>
            <Chip Variant="Chip.ChipVariant.Solid" Color="primary" Disabled="true">Disabled solid</Chip>
        </ChipGroup>
    </ComponentDemo>

    <ComponentDemo Title="Press Effect" Code="@_pressEffectCode">
        <ChipGroup>
            <Chip Clickable="true" PressEffect="Button.ButtonPressEffect.Scale">Scale</Chip>
            <Chip Clickable="true" PressEffect="Button.ButtonPressEffect.Brightness">Brightness</Chip>
            <Chip Clickable="true" PressEffect="Button.ButtonPressEffect.Ripple">Ripple</Chip>
        </ChipGroup>
    </ComponentDemo>
</Stack>

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-6">
    <strong>Mobile (rc.49).</strong> The close button on closable chips is now a 44×44 px touch target on small screens, meeting the WCAG minimum for touch affordances.
</Alert>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Chip</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="mb-3">Density falls back to an ancestor <a href="/docs/density" class="text-primary hover:underline">DensityScope</a> when unset — see the <a href="/docs/density" class="text-primary hover:underline">Density guide</a>.</Lumeo.Text>
            <PropsTable Slug="chip" />
        </Stack>
        <Stack>
            <Heading Level="3" Class="mb-3">ChipGroup</Heading>
            <PropsTable Slug="chip" SubComponent="ChipGroup" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/badge" class="text-primary hover:underline">Badge</a> — Simpler status indicators without close or click actions</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — Actionable elements when a chip is not the right fit</li>
    </ul>
</div>

@code {
    private string _chipVariant = "Default";
    private Chip.ChipVariant _chipVariantEnum =>
        Enum.TryParse<Chip.ChipVariant>(_chipVariant, out var v) ? v : Chip.ChipVariant.Default;
    private List<string> _tags = new() { "React", "TypeScript", "Tailwind", "Blazor", "C#" };
    private string _activeFilter = "All";
    private List<string> _filters = new() { "All", "Active", "Paused", "Completed" };

    private string _variantsCode = @"<ChipGroup>
    <Chip>Default</Chip>
    <Chip Variant=""Chip.ChipVariant.Outline"">Outline</Chip>
    <Chip Variant=""Chip.ChipVariant.Solid"" Color=""primary"">Primary</Chip>
    <Chip Variant=""Chip.ChipVariant.Solid"" Color=""destructive"">Destructive</Chip>
    <Chip Variant=""Chip.ChipVariant.Solid"" Color=""success"">Success</Chip>
</ChipGroup>";

    private string _sizesCode = @"<Flex Class=""items-center gap-2"">
    <Chip Size=""Lumeo.Size.Sm"">Small</Chip>
    <Chip>Default</Chip>
    <Chip Size=""Lumeo.Size.Lg"">Large</Chip>
</Flex>";

    private string _closableCode = @"<ChipGroup>
    @foreach (var tag in _tags)
    {
        var t = tag;
        <Chip Closable=""true"" OnClose=""@(() => _tags.Remove(t))"">@t</Chip>
    }
</ChipGroup>";

    private string _clickableCode = @"<ChipGroup>
    @foreach (var filter in _filters)
    {
        var f = filter;
        <Chip Clickable=""true""
              Variant=""@(_active == f ? Chip.ChipVariant.Solid : Chip.ChipVariant.Outline)""
              Color=""@(_active == f ? ""primary"" : null)""
              OnClick=""@(() => _active = f)"">
            @f
        </Chip>
    }
</ChipGroup>";

    private string _variantInteractiveCode = @"<Segmented @bind-Value=""_variant"">
    <SegmentedItem Value=""@Chip.ChipVariant.Default"">Default</SegmentedItem>
    <SegmentedItem Value=""@Chip.ChipVariant.Outline"">Outline</SegmentedItem>
    <SegmentedItem Value=""@Chip.ChipVariant.Solid"">Solid</SegmentedItem>
</Segmented>
<ChipGroup>
    <Chip Variant=""@_variant"">React</Chip>
    <Chip Variant=""@_variant"">TypeScript</Chip>
    <Chip Variant=""@_variant"">Blazor</Chip>
</ChipGroup>

@code { private Chip.ChipVariant _variant = Chip.ChipVariant.Default; }";

    private string _iconSlotCode = @"<ChipGroup>
    <Chip>
        <IconContent>
            <span style=""display:inline-block;width:8px;height:8px;border-radius:50%;background:#22c55e;""></span>
        </IconContent>
        Online
    </Chip>
    <Chip Variant=""Chip.ChipVariant.Solid"" Color=""primary"">
        <IconContent>
            <span style=""display:inline-block;width:8px;height:8px;border-radius:50%;background:currentColor;""></span>
        </IconContent>
        Primary
    </Chip>
    <Chip Closable=""true"">
        <IconContent>
            <span style=""display:inline-block;width:8px;height:8px;border-radius:50%;background:#f59e0b;""></span>
        </IconContent>
        Pending
    </Chip>
</ChipGroup>";

    private string _iconCode = @"<ChipGroup>
    <Chip Icon=""🔥"">Hot</Chip>
    <Chip Icon=""⭐"">Featured</Chip>
    <Chip Icon=""✅"" Variant=""Chip.ChipVariant.Solid"" Color=""success"">Verified</Chip>
</ChipGroup>";

    private string _disabledCode = @"<ChipGroup>
    <Chip Clickable=""true"" Disabled=""true"">Disabled clickable</Chip>
    <Chip Closable=""true"" Disabled=""true"">Disabled closable</Chip>
    <Chip Variant=""Chip.ChipVariant.Solid"" Color=""primary"" Disabled=""true"">Disabled solid</Chip>
</ChipGroup>";

    private string _pressEffectCode = @"<ChipGroup>
    <Chip Clickable=""true"" PressEffect=""Button.ButtonPressEffect.Scale"">Scale</Chip>
    <Chip Clickable=""true"" PressEffect=""Button.ButtonPressEffect.Brightness"">Brightness</Chip>
    <Chip Clickable=""true"" PressEffect=""Button.ButtonPressEffect.Ripple"">Ripple</Chip>
</ChipGroup>";
}
