    private int _selectedRoute;

    protected override async Task OnInitializedAsync()
    {
        const string osrmUrl =
            "https://router.project-osrm.org/route/v1/driving/" +
            "4.9041,52.3676;4.4777,51.9244" +
            "?overview=full&geometries=geojson&alternatives=true";
        try
        {
            var resp = await Http.GetFromJsonAsync<OsrmResponse>(osrmUrl);
            _routes = (resp?.Routes ?? []).Select((r, i) =>
            {
                var mins = (int)Math.Round(r.Duration / 60.0);
                var km   = Math.Round(r.Distance / 1000.0, 1);
                var label = i == 0
                    ? $"{mins / 60}h {mins % 60}m · {km} km · Fastest"
                    : $"{mins / 60}h {mins % 60}m · {km} km";
                var pts = r.Geometry.Coordinates
                    .Select(c => (Lat: c[1], Lon: c[0])).ToList();
                return new RouteOption(label, pts);
            }).ToList();
        }
        catch { /* CORS blocked — use hardcoded fallback */ }
    }
}
""";

