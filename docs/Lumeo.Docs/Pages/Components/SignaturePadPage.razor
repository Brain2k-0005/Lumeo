@page "/components/signature-pad"

<PageTitle>SignaturePad — Lumeo</PageTitle>

<PageHeader Title="SignaturePad" Description="A canvas-backed component for capturing handwritten signatures via mouse, touch, or stylus." />

<InstallUsage Component="SignaturePad" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Capture handwritten signatures for contracts, releases, delivery confirmations, or consent forms</li>
        <li>Collect freehand annotations as raster images (PNG / JPEG data URLs)</li>
        <li>Display a previously captured signature in read-only mode for audit or review</li>
        <li>Offer instant clear + optional download from inside the pad itself</li>
        <li>Use as a lightweight drawing primitive when a full canvas editor would be overkill</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <Stack Gap="4">
            <SignaturePad @bind-Value="_signature" />
            @if (!string.IsNullOrEmpty(_signature))
            {
                <Stack Gap="2">
                    <Lumeo.Text Size="sm" Weight="medium">Captured signature</Lumeo.Text>
                    <Image Src="@_signature" Alt="Captured signature" Class="border border-border/40 rounded-md max-w-xs" />
                </Stack>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom stroke" Code="@_strokeCode">
        <SignaturePad StrokeColor="#dc2626" StrokeWidth="4" BackgroundColor="white" />
    </ComponentDemo>

    <ComponentDemo Title="With download" Code="@_downloadCode">
        <SignaturePad ShowDownloadButton="true" Placeholder="Sign and click download" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled / read-only" Code="@_disabledCode">
        <SignaturePad Disabled="true" Value="@_savedSignature" />
    </ComponentDemo>

    <ComponentDemo Title="JPEG output + custom size">
        <SignaturePad Width="300" Height="140" Format="jpeg" BackgroundColor="white" Placeholder="Sign (JPEG export)" />
    </ComponentDemo>

    <ComponentDemo Title="No Clear Button">
        <SignaturePad ShowClearButton="false" Placeholder="Clear button hidden" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">SignaturePad</Heading>
            <PropsTable Slug="signature-pad" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/file-upload" class="text-primary hover:underline">FileUpload</a> — Pair to also accept a pre-scanned signature image</li>
        <li><a href="/components/image" class="text-primary hover:underline">Image</a> — Display the captured data URL in read-only contexts</li>
        <li><a href="/components/rich-text-editor" class="text-primary hover:underline">RichTextEditor</a> — Use when you need a full document-style annotation surface instead of a fixed-size pad</li>
    </ul>
</div>

@code {
    private string? _signature;
    private string _savedSignature = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 500 200'><path d='M30 130 C 80 60, 130 60, 170 130 S 260 200, 300 130 S 400 60, 470 130' stroke='%2360a5fa' stroke-width='3' fill='none' stroke-linecap='round'/></svg>";

    private string _basicCode = @"<SignaturePad @bind-Value=""_signature"" />

@@if (!string.IsNullOrEmpty(_signature))
{
    <Image Src=""@_signature"" Alt=""Captured signature"" />
}

@@code {
    private string? _signature;
}";

    private string _strokeCode = @"<SignaturePad StrokeColor=""#dc2626""
              StrokeWidth=""4""
              BackgroundColor=""white"" />";

    private string _downloadCode = @"<SignaturePad ShowDownloadButton=""true""
              Placeholder=""Sign and click download"" />";

    private string _disabledCode = @"<SignaturePad Disabled=""true"" Value=""@_savedSignature"" />

@@code {
    private string _savedSignature = ""data:image/png;base64,..."";
}";
}
