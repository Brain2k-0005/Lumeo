@namespace Lumeo
@implements IDisposable

@if (Popup is not null)
{
    @* Hidden host that holds the rendered RenderFragment. JS reads
       this element's innerHTML and feeds it to Leaflet's bindPopup, so
       any Razor markup (including child components) can appear in a
       marker popup. Kept display:none so it doesn't leak into the page. *@
    <div id="@_popupHostId" style="display:none">
        @Popup
    </div>
}

@if (Icon is not null)
{
    @* Same trick for the inner marker icon — we render the RenderFragment
       to a hidden host so JS can splice its innerHTML into the DivIcon. This
       lets consumers drop a <Blazicon Svg="..." /> straight inside the marker. *@
    <div id="@_iconHostId" style="display:none">
        @Icon
    </div>
}

@code {
    [Parameter] public double Lat { get; set; }
    [Parameter] public double Lon { get; set; }
    [Parameter] public string? Title { get; set; }

    /// <summary>Bitmap icon URL. When set, takes precedence over <see cref="Variant"/>
    /// — we hand Leaflet a plain L.icon and skip the DivIcon path entirely.
    /// Anchored bottom-center at 32×32, matching the pre-3.1 default.</summary>
    [Parameter] public string? IconUrl { get; set; }

    /// <summary>Visual variant for the auto-generated DivIcon. Ignored when
    /// <see cref="IconUrl"/> is set. Defaults to <c>"Default"</c> (filled circle).
    /// Valid values: <c>"Default"</c>, <c>"Outline"</c>, <c>"Pin"</c>, <c>"Dot"</c>.</summary>
    [Parameter] public string Variant { get; set; } = "Default";

    /// <summary>Override the marker's theme color. Accepts a friendly name
    /// (<c>"red"</c>, <c>"green"</c>, <c>"yellow"</c>, …) or a raw CSS color
    /// (<c>"#ff0000"</c>, <c>"hsl(...)"</c>). Null = theme primary.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>Marks this marker as "highlighted" (e.g. a recommendation). The pin
    /// itself is unchanged, but with <see cref="Map.Cluster"/> on, any cluster bubble
    /// that contains at least one highlighted marker is tinted with the cluster-highlight
    /// color (the <c>--lumeo-map-cluster-highlight</c> CSS variable, default amber) — so
    /// a recommendation stays discoverable even while its marker is clustered away.</summary>
    [Parameter] public bool Highlighted { get; set; }

    /// <summary>Permanent label rendered above the marker. Use for waypoints
    /// or numbered tours. Different from <see cref="Title"/> (hover tooltip).</summary>
    [Parameter] public string? Label { get; set; }

    /// <summary>When <c>true</c>, the <see cref="Label"/> is hidden by default and
    /// only appears on hover. Useful for dense maps where always-on labels create
    /// visual noise. Default is <c>false</c> (label always visible).</summary>
    [Parameter] public bool LabelHoverOnly { get; set; }

    /// <summary>Optional inline content inside the marker circle — a single
    /// letter, a number, or a small <c>&lt;Blazicon&gt;</c> SVG. The fragment
    /// is rendered to a hidden host and its innerHTML is spliced into the
    /// DivIcon. Ignored when <see cref="IconUrl"/> is set.</summary>
    [Parameter] public RenderFragment? Icon { get; set; }

    /// <summary>Optional rich popup body. When present, it overrides the plain
    /// <see cref="Title"/> as the marker's popup content. The fragment renders
    /// into a hidden host div and Leaflet uses the host's innerHTML.</summary>
    [Parameter] public RenderFragment? Popup { get; set; }

    [Parameter] public EventCallback OnClick { get; set; }

    /// <summary>Allow the user to drag the marker to a new position.</summary>
    [Parameter] public bool Draggable { get; set; }

    /// <summary>Fires with the new <c>(lat, lon)</c> after the user finishes
    /// dragging the marker. Use with two-way binding or to update your own state.
    /// Only fires when <see cref="Draggable"/> is <c>true</c>.</summary>
    [Parameter] public EventCallback<(double Lat, double Lon)> OnDragEnd { get; set; }

    [CascadingParameter] internal Map.MapContext? MapCtx { get; set; }

    private Map? _registeredOwner;
    private (double Lat, double Lon, string? Title, string? IconUrl, string Variant, string? Color, string? Label, bool LabelHoverOnly, bool HasIcon, bool Draggable, bool Highlighted)? _lastState;
    private readonly string _popupHostId = $"lumeo-map-popup-{Guid.NewGuid():N}";
    private readonly string _iconHostId = $"lumeo-map-icon-{Guid.NewGuid():N}";

    protected override void OnParametersSet()
    {
        if (MapCtx is null) return;
        var owner = MapCtx.Owner;

        if (_registeredOwner is null)
        {
            _registeredOwner = owner;
            owner.RegisterMarker(this);
        }
        else
        {
            var snapshot = (Lat, Lon, Title, IconUrl, Variant, Color, Label, LabelHoverOnly, Icon is not null, Draggable, Highlighted);
            if (_lastState is { } prev && prev != snapshot)
                owner.NotifyMarkerChanged(this);
        }
        _lastState = (Lat, Lon, Title, IconUrl, Variant, Color, Label, LabelHoverOnly, Icon is not null, Draggable, Highlighted);
    }

    internal string? GetPopupHtml() => Title;
    internal string PopupHostId => _popupHostId;
    internal string IconHostId => _iconHostId;
    internal bool HasRichPopup => Popup is not null;
    internal bool HasIcon => Icon is not null;

    public void Dispose()
    {
        _registeredOwner?.UnregisterMarker(this);
    }
}
