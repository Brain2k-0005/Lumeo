@namespace Lumeo

<Chart Option="@_option" Width="@Width" Height="@Height" Theme="@Theme" Class="@Class" @attributes="AdditionalAttributes" />

@code {
    [Parameter] public List<string> Categories { get; set; } = new();
    [Parameter] public List<ChartSeriesData> Series { get; set; } = new();
    [Parameter] public bool Horizontal { get; set; }
    [Parameter] public bool Stacked { get; set; }
    [Parameter] public bool ShowLegend { get; set; } = true;
    [Parameter] public bool ShowTooltip { get; set; } = true;
    [Parameter] public List<string>? Colors { get; set; }
    [Parameter] public string Width { get; set; } = "100%";
    [Parameter] public string Height { get; set; } = "350px";
    [Parameter] public string? Theme { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    [Parameter] public bool ShowDataLabels { get; set; }
    [Parameter] public string LabelPosition { get; set; } = "top";
    [Parameter] public string? LabelFormat { get; set; }

    /// <summary>Controls how category-axis labels are rendered.
    /// <list type="bullet">
    ///   <item><c>Smart</c> (default): show every label; auto-rotate -30° at 11–20 categories and -45° above 20 so every label stays visible and readable.</item>
    ///   <item><c>ShowAll</c>: force every label with no rotation (may overlap on dense datasets).</item>
    ///   <item><c>Auto</c>: let ECharts auto-thin labels that would overlap (original ECharts default — hides every second label when crowded).</item>
    /// </list>
    /// </summary>
    [Parameter] public BarLabelStrategy LabelStrategy { get; set; } = BarLabelStrategy.Smart;

    /// <summary>Manual override for category-label rotation in degrees (e.g. -30, -45). When set,
    /// takes precedence over the rotation implied by <see cref="LabelStrategy"/>.</summary>
    [Parameter] public int? LabelRotate { get; set; }

    public enum BarLabelStrategy
    {
        /// <summary>Show every label; auto-rotate when density grows so text doesn't overlap.</summary>
        Smart,
        /// <summary>Force every label with no rotation.</summary>
        ShowAll,
        /// <summary>Let ECharts auto-thin overlapping labels.</summary>
        Auto,
    }
    [Parameter] public bool DataZoom { get; set; }
    [Parameter] public bool Toolbox { get; set; }
    [Parameter] public List<string>? ColorPalette { get; set; }
    [Parameter] public int? AnimationDuration { get; set; }
    [Parameter] public string? AnimationEasing { get; set; }
    [Parameter] public EChartMarkLine? MarkLine { get; set; }
    [Parameter] public EChartMarkPoint? MarkPoint { get; set; }
    [Parameter] public EChartMarkArea? MarkArea { get; set; }
    [Parameter] public Dictionary<string, object>? OptionOverride { get; set; }

    private EChartOption _option = new();

    protected override void OnParametersSet()
    {
        var categoryAxis = new EChartAxis { Type = "category", Data = Categories };

        // Label strategy → interval + rotation.
        int? interval = null;
        int? autoRotate = null;
        switch (LabelStrategy)
        {
            case BarLabelStrategy.Smart:
                interval = 0; // show all
                autoRotate = Categories.Count switch
                {
                    <= 10 => null,   // fits horizontally
                    <= 20 => -30,    // starting to crowd
                    _     => -45,    // dense
                };
                break;
            case BarLabelStrategy.ShowAll:
                interval = 0;
                break;
            case BarLabelStrategy.Auto:
                // leave interval null — ECharts auto-thins
                break;
        }

        var effectiveRotate = LabelRotate ?? autoRotate;
        if (interval.HasValue || effectiveRotate.HasValue)
        {
            categoryAxis.AxisLabel = new EChartAxisLabel
            {
                Interval = interval,
                Rotate = effectiveRotate
            };
        }
        var valueAxis = new EChartAxis { Type = "value" };

        var seriesList = Series.Select(s => new EChartSeries
        {
            Name = s.Name,
            Type = "bar",
            Data = s.Values,
            Stack = Stacked ? "total" : null
        }).ToList();

        // When stacked, the theme's rounded corners on every segment make
        // the stack look like floating pills (each segment rounds its own
        // 4 corners, so adjacent segments meet at the arc). We flatten
        // the inner segments and round only the outermost end of the stack:
        //
        //   Vertical stacked   → last series (top) rounds top corners
        //   Horizontal stacked → last series (right) rounds right corners
        //
        // Radius is derived from --radius (fallback 6 px if unavailable
        // from the CSS side since we're in C#). Consumers who want a
        // different value can override via OptionOverride on the series.
        if (Stacked && seriesList.Count > 0)
        {
            const int r = 6;
            int[] outerCorners = Horizontal
                ? new[] { 0, r, r, 0 }   // round right side
                : new[] { r, r, 0, 0 };  // round top side
            int[] flat = { 0, 0, 0, 0 };

            // Use the array form everywhere — ECharts merges theme + series
            // itemStyle and a scalar `borderRadius: 0` doesn't reliably replace
            // the theme's array default; an all-zero array always wins.
            for (int i = 0; i < seriesList.Count; i++)
            {
                var isOuter = i == seriesList.Count - 1;
                seriesList[i].ItemStyle = new EChartItemStyle
                {
                    BorderRadiusCorners = isOuter ? outerCorners : flat
                };
            }
        }
        else if (Horizontal)
        {
            // Non-stacked horizontal: theme default `[r, r, 0, 0]` rounds the
            // TOP edge (rectangle corners), which looks wrong for a horizontal
            // bar. Override so every bar's right end is rounded instead.
            const int r = 6;
            foreach (var s in seriesList)
                s.ItemStyle = new EChartItemStyle { BorderRadiusCorners = new[] { 0, r, r, 0 } };
        }

        if (ShowDataLabels)
            foreach (var s in seriesList)
                s.Label = new EChartLabel { Show = true, Position = LabelPosition, Formatter = LabelFormat };

        if (seriesList.Count > 0)
        {
            if (MarkLine is not null) seriesList[0].MarkLine = MarkLine;
            if (MarkPoint is not null) seriesList[0].MarkPoint = MarkPoint;
            if (MarkArea is not null) seriesList[0].MarkArea = MarkArea;
        }

        _option = new EChartOption
        {
            XAxis = new List<EChartAxis> { Horizontal ? valueAxis : categoryAxis },
            YAxis = new List<EChartAxis> { Horizontal ? categoryAxis : valueAxis },
            Series = seriesList,
            Grid = new EChartGrid
            {
                Left = "3%", Right = "4%",
                Top = ShowLegend ? "14%" : "5%",
                Bottom = DataZoom ? "15%" : "3%",
                ContainLabel = true
            },
            Color = ColorPalette ?? Colors
        };

        if (ShowTooltip)
            _option.Tooltip = new EChartTooltip { Trigger = "axis", AxisPointer = new EChartAxisPointer { Type = "shadow" } };

        if (ShowLegend && Series.Count > 0)
            _option.Legend = new EChartLegend { Data = Series.Select(s => s.Name).ToList() };

        if (DataZoom)
            _option.DataZoom = new List<EChartDataZoom> { new() { Type = "slider", Show = true }, new() { Type = "inside" } };

        if (Toolbox)
            _option.Toolbox = new EChartToolbox { Show = true, Feature = new EChartToolboxFeature { SaveAsImage = new() { Show = true }, Restore = new() { Show = true }, DataZoom = new() { Show = true } } };

        if (AnimationDuration.HasValue) _option.AnimationDuration = AnimationDuration;
        if (!string.IsNullOrEmpty(AnimationEasing)) _option.AnimationEasing = AnimationEasing;

        ChartHelper.ApplyOptionOverride(_option, OptionOverride);
    }

    public class ChartSeriesData
    {
        public string Name { get; set; } = "";
        public List<double> Values { get; set; } = new();
    }
}
