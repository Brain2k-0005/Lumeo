@page "/components/command"

<PageTitle>Command — Lumeo</PageTitle>

<PageHeader Title="Command" Description="A command palette for searching and executing actions." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="md" Class="rounded-lg border shadow-md">
            <Command>
                <CommandInput Placeholder="Type a command or search..." />
                <CommandList>
                    <CommandEmpty />
                    <CommandGroup Heading="Suggestions">
                        <CommandItem FilterValue="Calendar">
                            <DynamicIcon Name="Calendar" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Calendar</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Search">
                            <DynamicIcon Name="Search" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Search</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Settings">
                            <DynamicIcon Name="Settings" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Settings</Lumeo.Text>
                        </CommandItem>
                    </CommandGroup>
                    <CommandSeparator />
                    <CommandGroup Heading="Actions">
                        <CommandItem FilterValue="Profile">
                            <DynamicIcon Name="User" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Profile</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Mail">
                            <DynamicIcon Name="Mail" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Mail</Lumeo.Text>
                        </CommandItem>
                    </CommandGroup>
                </CommandList>
            </Command>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Compact" Code="@_compactCode">
        <Container MaxWidth="sm" Class="rounded-lg border shadow-md">
            <Command>
                <CommandInput Placeholder="Search..." />
                <CommandList>
                    <CommandEmpty />
                    <CommandGroup>
                        <CommandItem FilterValue="New File">New File</CommandItem>
                        <CommandItem FilterValue="Open File">Open File</CommandItem>
                        <CommandItem FilterValue="Save">Save</CommandItem>
                    </CommandGroup>
                </CommandList>
            </Command>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Navigation" Code="@_navCode">
        <Container MaxWidth="sm" Class="rounded-lg border shadow-md">
            <Command>
                <CommandInput Placeholder="Go to..." />
                <CommandList>
                    <CommandEmpty />
                    <CommandGroup Heading="Pages">
                        <CommandItem FilterValue="Dashboard">
                            <DynamicIcon Name="House" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Dashboard</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Profile">
                            <DynamicIcon Name="User" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Profile</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Settings">
                            <DynamicIcon Name="Settings" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Settings</Lumeo.Text>
                        </CommandItem>
                    </CommandGroup>
                    <CommandSeparator />
                    <CommandGroup Heading="Recent">
                        <CommandItem FilterValue="Notifications">
                            <DynamicIcon Name="Bell" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Notifications</Lumeo.Text>
                        </CommandItem>
                        <CommandItem FilterValue="Messages">
                            <DynamicIcon Name="Mail" Class="mr-2 h-4 w-4" />
                            <Lumeo.Text As="span">Messages</Lumeo.Text>
                        </CommandItem>
                    </CommandGroup>
                </CommandList>
            </Command>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Shortcuts" Code="@_shortcutCode">
        <Command Class="rounded-lg border shadow-md w-full max-w-md">
            <CommandInput Placeholder="Type a command..." />
            <CommandList>
                <CommandEmpty />
                <CommandGroup Heading="Actions">
                    <CommandItem Shortcut="Ctrl+N" FilterValue="New File">New File</CommandItem>
                    <CommandItem Shortcut="Ctrl+S" FilterValue="Save">Save</CommandItem>
                    <CommandItem Shortcut="Ctrl+Shift+P" FilterValue="Command Palette">Command Palette</CommandItem>
                </CommandGroup>
                <CommandGroup Heading="Navigation">
                    <CommandItem Shortcut="Ctrl+1" FilterValue="Go to Dashboard">Go to Dashboard</CommandItem>
                    <CommandItem Shortcut="Ctrl+2" FilterValue="Go to Settings">Go to Settings</CommandItem>
                </CommandGroup>
            </CommandList>
        </Command>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">CommandItem</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Shortcut</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Keyboard shortcut displayed as a badge on the right side of the item.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">FilterValue</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Text used for filtering when the user types in the CommandInput. Items without a FilterValue are always visible.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

