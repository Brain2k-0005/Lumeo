{
  "name": "lumeo-blazor-css",
  "private": true,
  "description": "Internal Tailwind build for Lumeo's pre-compiled utility stylesheet shipped in the NuGet package.",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./Styles/lumeo-utilities.src.css -o ./wwwroot/css/lumeo-utilities.css --minify",
    "watch:css": "npx @tailwindcss/cli -i ./Styles/lumeo-utilities.src.css -o ./wwwroot/css/lumeo-utilities.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0"
  }
}
