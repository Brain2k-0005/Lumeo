@namespace Lumeo.Docs.Shared
@using System.Reflection

@* Per-component quick start: install the single Lumeo package, then import and
   drop the component in. Full app setup (AddLumeo, CSS & JS) lives in the
   installation guide and is linked rather than repeated on every page. *@
<div class="mt-8 mb-10 space-y-6">
    <div class="space-y-3">
        <Heading Id="installation" Level="2" Size="xl" Class="scroll-mt-20">Installation</Heading>
        <Tabs ActiveValue="cli">
            <TabsList>
                <TabsTrigger Value="cli">.NET CLI</TabsTrigger>
                <TabsTrigger Value="pkg">PackageReference</TabsTrigger>
                <TabsTrigger Value="lumeo">Lumeo CLI</TabsTrigger>
            </TabsList>
            <TabsContent Value="cli">
                <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_cli</pre>
            </TabsContent>
            <TabsContent Value="pkg">
                <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_pkg</pre>
            </TabsContent>
            <TabsContent Value="lumeo">
                <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_lumeoCli</pre>
                <Lumeo.Text Size="xs" Color="muted" Class="mt-1.5">
                    Copies the component source straight into your project — you own the code, no package dependency. See the <Lumeo.Link Href="docs/registry">registry guide</Lumeo.Link>.
                </Lumeo.Text>
            </TabsContent>
        </Tabs>
        <Lumeo.Text Size="sm" Color="muted">
            One-time app setup (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">AddLumeo()</code>, CSS &amp; JS) is covered in the
            <Lumeo.Link Href="docs/introduction">installation guide</Lumeo.Link>.
        </Lumeo.Text>
    </div>

    @if (ShowUsage)
    {
        <div class="space-y-3">
            <Heading Id="usage" Level="2" Size="xl" Class="scroll-mt-20">Usage</Heading>
            <pre class="rounded-[var(--radius-lg)] border border-border bg-muted/30 px-4 py-3 text-sm font-mono overflow-x-auto whitespace-pre m-0">@_usage</pre>
        </div>
    }
</div>

@code {
    /// <summary>The component's tag name, e.g. "Button" or "AlertDialog".</summary>
    [Parameter] public string Component { get; set; } = "";

    /// <summary>NuGet package the component ships in (satellites: Lumeo.Charts, etc.).</summary>
    [Parameter] public string Package { get; set; } = "Lumeo";

    /// <summary>Optional custom usage snippet; defaults to the import plus the tag.</summary>
    [Parameter] public string? Usage { get; set; }

    /// <summary>
    /// Whether to render the Usage block. Set <c>false</c> on pages that document a service
    /// or a family of primitives (e.g. Ai, Motion, OverlayService) where <c>&lt;{Component} /&gt;</c>
    /// is not a real renderable tag — the Installation block still applies, but a single
    /// auto-generated tag would be misleading.
    /// </summary>
    [Parameter] public bool ShowUsage { get; set; } = true;

    /// <summary>Registry slug for the Lumeo CLI (<c>lumeo add &lt;slug&gt;</c>).
    /// Defaults to the kebab-cased component name, which matches the registry
    /// for all but a couple of acronym names — override when it differs.</summary>
    [Parameter] public string? Slug { get; set; }

    // Read from the assembly's InformationalVersion attribute (auto-generated from
    // Directory.Build.props <Version> on build), strip any +commit suffix SourceLink
    // appends. This used to be a hand-maintained const that silently drifted across
    // releases — the docs preview still showed 3.8.0 NuGet snippets at 3.10.x.
    private static readonly string _version = ExtractVersion();
    private static string ExtractVersion()
    {
        var attr = typeof(InstallUsage).Assembly
            .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>();
        var raw = attr?.InformationalVersion ?? typeof(InstallUsage).Assembly.GetName().Version?.ToString(3) ?? "";
        // Strip "+gitsha" build metadata SourceLink appends so the snippet stays clean.
        var plus = raw.IndexOf('+');
        return plus >= 0 ? raw[..plus] : raw;
    }
    private string _cli => $"dotnet add package {Package}";
    private string _pkg => $"<PackageReference Include=\"{Package}\" Version=\"{_version}\" />";
    private string _lumeoCli => $"lumeo add {Slug ?? Kebab(Component)}";
    private string _usage => Usage ?? $"@using Lumeo\n\n<{Component} />";

    // Acronym-aware kebab-case: a dash is inserted before an uppercase letter
    // only when it borders a lowercase letter, so "AlertDialog" → "alert-dialog"
    // while "QRCode" → "qr-code" and "CTASection" → "cta-section".
    private static string Kebab(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length + 4);
        for (var i = 0; i < s.Length; i++)
        {
            var c = s[i];
            if (char.IsUpper(c))
            {
                var prevLower = i > 0 && !char.IsUpper(s[i - 1]);
                var nextLower = i + 1 < s.Length && char.IsLower(s[i + 1]);
                if (i > 0 && (prevLower || nextLower)) sb.Append('-');
                sb.Append(char.ToLowerInvariant(c));
            }
            else
            {
                sb.Append(c);
            }
        }
        return sb.ToString();
    }
}
