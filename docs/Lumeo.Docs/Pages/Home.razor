<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Built-in</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Everything you'd otherwise build.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A complete kit for modern Blazor apps — batteries included, DX-obsessed.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @for (var i = 0; i < _features.Length; i++)
            {
                var f = _features[i];
                var delay = 40 * i;
                <BlurFade DelayMs="@delay">
                    <Stack Gap="3" Class="group h-full rounded-xl border border-border/40 bg-card p-5 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-accent/40 text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                            <DynamicIcon Name="@f.Icon" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">@f.Title</Heading>
                        <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">@f.Body</Lumeo.Text>
                    </Stack>
                </BlurFade>
            }
        </div>
    </Container>
</section>

