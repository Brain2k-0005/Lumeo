@namespace Lumeo
@typeparam TItem
@implements IAsyncDisposable
@inject Lumeo.Services.Localization.ILumeoLocalizer L

<th data-slot="datagrid-header-cell" class="@CssClass" style="@StyleString"
    id="@CellId"
    data-col-id="@Column.Id"
    data-col-pin="@Column.Pin"
    data-reorderable="@(EffectiveReorderable ? "true" : null)"
    role="columnheader"
    aria-colindex="@AriaColIndex"
    aria-sort="@AriaSort"
    tabindex="@TabIndexValue"
    @onkeydown="HandleKeyDown"
    draggable="@(IsDraggable ? "true" : "false")"
    @ondragstart="HandleDragStart"
    @ondragend="HandleDragEnd"
    @ondragover:preventDefault="true"
    @attributes="AdditionalAttributes">
    <div class="flex items-center gap-1">
        @* Dedicated reorder grip (ReUI drag-handle affordance). Discoverable cue
           for both drag paths: it's the initiator for touch/pen (a JS pointer
           listener registered on the grid delegates from [data-reorder-grip] and
           drives a translate-in-place reorder — native HTML5 DnD never fires on
           touch), while on desktop the whole draggable <th> still starts the
           native drag. Only shown when the column is actually reorderable. *@
        @if (EffectiveReorderable)
        {
            <span data-reorder-grip
                  class="-ms-1 inline-flex items-center justify-center h-5 w-4 shrink-0 rounded text-muted-foreground opacity-60 hover:opacity-100 cursor-grab active:cursor-grabbing touch-none"
                  style="touch-action: none;"
                  aria-label="@L["DataGrid.DragToReorder"]"
                  title="@L["DataGrid.DragToReorder"]">
                <SvgGlyph Svg="@(LumeoIcons.GripVertical)" class="h-3.5 w-3.5" />
            </span>
        }
        @if (Column.HeaderTemplate is not null)
        {
            @Column.HeaderTemplate
        }
        else
        {
            <button type="button"
                    class="flex items-center gap-1 select-none rounded focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-2 @(Column.Sortable ? "cursor-pointer hover:text-foreground" : "cursor-default")"
                    @onclick="HandleSort"
                    disabled="@(!Column.Sortable)">
                <span>@(Column.Title ?? Column.Field ?? "")</span>
                @if (Column.Sortable && SortDirection != SortDirection.None)
                {
                    @if (SortDirection == SortDirection.Ascending)
                    {
                        <SvgGlyph Svg="@(LumeoIcons.ArrowUp)" class="h-3.5 w-3.5" />
                    }
                    else
                    {
                        <SvgGlyph Svg="@(LumeoIcons.ArrowDown)" class="h-3.5 w-3.5" />
                    }
                    @if (TotalSortCount > 1 && SortPriority > 0)
                    {
                        <span class="flex items-center justify-center h-3.5 w-3.5 rounded-[calc(var(--radius)*2)] bg-primary text-primary-foreground text-[9px] font-bold leading-none">@SortPriority</span>
                    }
                }
                else if (Column.Sortable)
                {
                    <SvgGlyph Svg="@(LumeoIcons.ArrowUpDown)" class="h-3.5 w-3.5 opacity-30" />
                }
            </button>
        }

        @* 2.2.2: visible drag-to-group affordance on columns that can be
           grouped. Without this, users had to try each column header to
           discover which ones supported drag-into-panel — draggable="true"
           on its own gave no visual cue. Mirrors the filter button's
           opacity-on-hover pattern; hidden when ShowGroupPanel is off (no
           point advertising drag-to-group when there's nowhere to drop). *@
        @if (Context?.ShowGroupPanel == true && Column.Groupable)
        {
            <Tooltip>
                <TooltipTrigger AsChild>
                    <ChildContentSlot Context="slot">
                        <span class="inline-flex items-center justify-center h-5 w-5 rounded text-muted-foreground opacity-0 group-hover/th:opacity-100 transition-opacity cursor-grab"
                              aria-label="@L["DataGrid.DragToGroup"]"
                              @attributes="slot.Attributes">
                            <SvgGlyph Svg="@(LumeoIcons.Group)" class="h-3 w-3" />
                        </span>
                    </ChildContentSlot>
                </TooltipTrigger>
                <TooltipContent>@L["DataGrid.DragToGroup"]</TooltipContent>
            </Tooltip>
        }
        @if (Column.Filterable)
        {
            <button type="button"
                    id="@_filterTriggerId"
                    class="inline-flex items-center justify-center h-5 w-5 rounded hover:bg-muted/60 focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1 @(HasActiveFilter ? "text-primary" : "text-muted-foreground opacity-0 group-hover/th:opacity-100")"
                    @onclick="ToggleFilter"
                    @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.ListFilter)" class="h-3 w-3" />
            </button>
        }

        @* Header-level pin control: a discoverable, keyboard-accessible affordance
           so a column can be pinned/unpinned directly from its header — pinning was
           previously reachable only via the Columns popover. Rendered for Pinnable
           columns; always visible while the column is pinned, otherwise revealed on
           hover/focus like the filter button. Opens a small menu (Pin left / Pin
           right / Unpin) that raises the exact same pin change as the column
           chooser through ParentGrid.ApplyColumnPin, so both entry points share one
           state transition (partition + sticky offsets). *@
        @if (Column.Pinnable)
        {
            <button type="button"
                    id="@_pinTriggerId"
                    class="inline-flex items-center justify-center h-5 w-5 rounded hover:bg-muted/60 focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1 @(Column.Pin != PinDirection.None ? "text-primary" : "text-muted-foreground opacity-0 group-hover/th:opacity-100 focus-visible:opacity-100")"
                    aria-label="@L["DataGrid.PinColumn"]"
                    aria-haspopup="menu"
                    aria-expanded="@(_pinMenuOpen ? "true" : "false")"
                    @onclick="TogglePinMenu"
                    @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.Pin)" class="@(Column.Pin != PinDirection.None ? "h-3 w-3 rotate-45" : "h-3 w-3")" />
            </button>
        }
    </div>

    @if (IsFilterOpen && Column.Filterable)
    {
        @* Rendered with position:fixed and pinned to the trigger via
           Interop.PositionFixed (JS reads the trigger's getBoundingClientRect
           on open + on scroll/resize). Was previously position:absolute relative
           to the <th> which extended the grid's overflow:auto scrollWidth on the
           rightmost columns and made a phantom horizontal scrollbar appear when
           opening the filter. Floating-UI-style positioning sidesteps that
           entirely: the popover lives in the same DOM subtree but its layout
           box doesn't touch the scroll container. *@
        <div id="@_filterContentId" style="position: fixed; z-index: 50;">
            <DataGridColumnFilter TItem="TItem"
                                  Column="Column"
                                  FilterOptions="Column.FilterOptions"
                                  CurrentFilter="@CurrentFilter"
                                  OnApply="HandleFilterApply" />
        </div>
    }

    @if (_pinMenuOpen && Column.Pinnable)
    {
        @* Positioned with position:fixed and pinned to the trigger via
           Interop.PositionFixed (same Floating-UI-style approach as the filter
           popover) so the menu never extends the grid's horizontal scrollWidth
           on the rightmost columns. Aligned to the trigger's end edge. *@
        <div id="@_pinMenuId" role="menu" style="position: fixed; z-index: 50;"
             class="min-w-[150px] rounded-md border border-border/40 bg-popover text-popover-foreground shadow-md p-1"
             @onkeydown="HandlePinMenuKeyDown">
            <button type="button" role="menuitem"
                    class="w-full flex items-center gap-2 px-2 py-1.5 rounded text-sm text-start hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:bg-accent disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled="@(Column.Pin == PinDirection.Left)"
                    @onclick="@(() => PinFromHeader(PinDirection.Left))"
                    @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.ChevronsLeft)" class="h-3.5 w-3.5" />
                <span>@L["DataGrid.PinLeft"]</span>
            </button>
            <button type="button" role="menuitem"
                    class="w-full flex items-center gap-2 px-2 py-1.5 rounded text-sm text-start hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:bg-accent disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled="@(Column.Pin == PinDirection.Right)"
                    @onclick="@(() => PinFromHeader(PinDirection.Right))"
                    @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.ChevronsRight)" class="h-3.5 w-3.5" />
                <span>@L["DataGrid.PinRight"]</span>
            </button>
            <button type="button" role="menuitem"
                    class="w-full flex items-center gap-2 px-2 py-1.5 rounded text-sm text-start hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:bg-accent disabled:opacity-50 disabled:cursor-not-allowed"
                    disabled="@(Column.Pin == PinDirection.None)"
                    @onclick="@(() => PinFromHeader(PinDirection.None))"
                    @onclick:stopPropagation="true">
                <SvgGlyph Svg="@(LumeoIcons.X)" class="h-3.5 w-3.5" />
                <span>@L["DataGrid.Unpin"]</span>
            </button>
        </div>
    }

    @if (Column.Resizable)
    {
        @* ReUI-grade resize handle: a wide (~16px) invisible hit area straddling
           the column's inline-end edge, with a CSS-authored ::before divider that
           idles as a 1px border line and turns 2px primary on hover / focus /
           active drag (data-resizing set by JS). Positioned with the logical `end`
           edge so it lands on the LEFT in RTL automatically.

           Pointer drag: the JS listener attached via RegisterColumnResize() owns
           pointerdown→up end to end (capture, rAF-coalesced DOM writes, commit
           once on pointerup) — no Blazor round-trip per move. Double-click =
           auto-fit to content (also JS).

           tabindex=-1: a role="separator" widget with valuenow semantics for AT, but
           NOT a Tab stop — a data grid keeps a single roving tab stop for cell nav, so
           N tabbable handles would shatter that. Keyboard resize is reached through the
           roving-focused header cell (Ctrl+Arrow); clicking a handle also focuses it,
           after which plain Arrow keys resize (the @onkeydown below, stopPropagation'd
           so the arrows don't also drive header nav). *@
        <div id="@_resizeHandleId"
             data-slot="datagrid-resize-handle"
             class="lumeo-dg-resize-handle"
             role="separator"
             aria-orientation="vertical"
             aria-label="@L["DataGrid.ResizeColumn"]"
             tabindex="-1"
             aria-valuemin="@((int)(Column.MinWidth ?? 50))"
             aria-valuemax="@(Column.MaxWidth.HasValue ? (int)Column.MaxWidth.Value : (int?)null)"
             aria-valuenow="@(Column.Width.HasValue ? (int)Column.Width.Value : (int?)null)"
             @onkeydown="HandleResizeKeyDown"
             @onkeydown:stopPropagation="true"></div>
    }
</th>

@code {
    [CascadingParameter] private DataGridContext<TItem>? Context { get; set; }
    [CascadingParameter] private DataGrid<TItem>? ParentGrid { get; set; }
    [CascadingParameter] private DataGridDragState? DragState { get; set; }
    @* Inject the interface, not the concrete service, so tests can substitute
       a TrackingInteropService for the interop surface — every method used by
       this component (PositionFixed, RegisterClickOutside, RegisterColumnResize,
       …) is on the interface, so the switch is a pure DI tidy-up. *@
    [Inject] private IComponentInteropService Interop { get; set; } = default!;

    /// <summary>The column this header cell represents — supplies title, sort/filter/
    /// resize/pin/reorder eligibility, and CSS.</summary>
    [Parameter] public DataGridColumn<TItem> Column { get; set; } = default!;

    /// <summary>0-based index of this column within the visible columns.</summary>
    [Parameter] public int ColumnIndex { get; set; }
    /// <summary>1-based ARIA column index (includes any leading non-data columns).</summary>
    [Parameter] public int AriaColIndex { get; set; }

    /// <summary>Current sort direction applied to this column, driving the sort
    /// icon and <c>aria-sort</c>. Defaults to None.</summary>
    [Parameter] public SortDirection SortDirection { get; set; } = SortDirection.None;

    /// <summary>Whether this column currently has an applied filter — shows the
    /// filter icon in its "active" state.</summary>
    [Parameter] public bool HasActiveFilter { get; set; }

    /// <summary>Whether this column's filter popover is currently open.</summary>
    [Parameter] public bool IsFilterOpen { get; set; }

    /// <summary>Enables drag-to-reorder on this header cell (still gated per-column
    /// by <c>Column.Reorderable</c>).</summary>
    [Parameter] public bool Reorderable { get; set; }

    /// <summary>Fires when this column's filter icon is clicked, to open/close its
    /// filter popover.</summary>
    [Parameter] public EventCallback OnFilterToggle { get; set; }

    /// <summary>Fires when this column's filter popover is applied or cleared,
    /// carrying the new (or null) <see cref="FilterDescriptor"/>.</summary>
    [Parameter] public EventCallback<FilterApplyEventArgs> OnFilterApply { get; set; }

    /// <summary>Fires when this column is dragged to a new position, carrying its
    /// id and the old/new index.</summary>
    [Parameter] public EventCallback<ColumnReorderEventArgs> OnColumnReorder { get; set; }

    /// <summary>1-based multi-sort priority (the order this column was added to the
    /// sort, via shift-click). 0 when not sorted.</summary>
    [Parameter] public int SortPriority { get; set; }

    /// <summary>Total number of columns currently participating in a multi-sort.
    /// Used to decide whether to show the priority badge (hidden when only one
    /// column is sorted).</summary>
    [Parameter] public int TotalSortCount { get; set; }

    /// <summary>Additional CSS classes merged onto the <c>&lt;th&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures unmatched attributes and applies them to the <c>&lt;th&gt;</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    // --- Keyboard navigation / ARIA (rc.32) ---
    private string? CellId => Context is null ? null : $"{Context.GridId}-cell-h-{ColumnIndex}";

    private string? AriaSort => Column.Sortable
        ? SortDirection switch
        {
            SortDirection.Ascending => "ascending",
            SortDirection.Descending => "descending",
            _ => "none"
        }
        : null;

    // Roving tabindex: exactly one header/body cell carries tabindex="0".
    private int TabIndexValue =>
        Context is not null && Context.FocusedRow == -1 && Context.FocusedCol == ColumnIndex ? 0 : -1;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Note: we don't preventDefault on the <th> here. A per-key
        // @onkeydown:preventDefault directive's value is fixed at render time and
        // would also swallow Tab (which must stay live to leave the grid). The
        // page-scroll default of the nav keys (Arrow/Home/End/PageUp/PageDown/Space)
        // is instead suppressed by a key-selective native listener registered on
        // the table in DataGrid.OnAfterRenderAsync (RegisterPreventDefaultKeys) —
        // these header keydowns bubble to it. (battle-test n=8)
        if (Context is null) return;

        // Keyboard resize via the roving-focused header cell: Ctrl+Arrow nudges the
        // column width (Ctrl+Shift+Arrow = fine 1px). This is the primary keyboard
        // resize path — it flows through the grid's single tab stop instead of adding
        // a tabbable handle per column. ArrowRight always grows toward the visual
        // right; the JS nudge flips the sign for RTL. Handled before header nav so the
        // modified arrows don't also move column focus.
        if (Column.Resizable && e.CtrlKey && (e.Key == "ArrowLeft" || e.Key == "ArrowRight"))
        {
            var step = e.ShiftKey ? 1.0 : 10.0;
            await Interop.NudgeColumnResize(_resizeHandleId, e.Key == "ArrowRight" ? step : -step);
            return;
        }

        if ((e.Key == "Enter" || e.Key == " " || e.Key == "Spacebar") && Column.Sortable)
        {
            await HandleSort();
            return;
        }

        await Context.OnHeaderKeyDown(ColumnIndex, e);
    }

    private FilterDescriptor? CurrentFilter =>
        Column?.Field is null || Context is null
            ? null
            : Context.Filters.FirstOrDefault(f => f.Field == Column.Field);

    private string _resizeHandleId = $"dg-resize-{Guid.NewGuid():N}";
    private bool _resizeRegistered;

    // Filter popover positioning (2.1.2): the filter content is rendered with
    // position:fixed and pinned to the trigger via JS-computed coords from
    // getBoundingClientRect, matching the pattern in PopoverContent. Stable IDs
    // are needed so the JS positioner can find both elements and so click-outside
    // can exclude the trigger from its dismiss target list.
    private readonly string _filterTriggerId = $"dg-filter-trigger-{Guid.NewGuid():N}";
    private readonly string _filterContentId = $"dg-filter-content-{Guid.NewGuid():N}";
    private bool _filterPositionRegistered;

    // Header-level pin menu (mirrors the filter popover's fixed-position +
    // click-outside plumbing). Stable ids let the JS positioner find the trigger
    // and let click-outside exclude the trigger from its dismiss targets.
    private readonly string _pinTriggerId = $"dg-pin-trigger-{Guid.NewGuid():N}";
    private readonly string _pinMenuId = $"dg-pin-menu-{Guid.NewGuid():N}";
    private bool _pinMenuOpen;
    private bool _pinPositionRegistered;

    /// <summary>
    /// Drag-reorder is only active when both the grid-level <c>Reorderable</c>
    /// flag and the per-column <c>Reorderable</c> flag are true.
    /// </summary>
    private bool EffectiveReorderable => Reorderable && Column.Reorderable;

    /// <summary>True when this header is the source of an in-flight column
    /// drag (the dragstart fired here and dragend / drop hasn't yet). Used
    /// to dim the source th so the user can see which column is moving.</summary>
    private bool IsDragSource =>
        DragState?.SourceColumnId is { } src && src == Column.Id;

    /// <summary>True when this header is HTML5-draggable. Native HTML5 DnD is now
    /// used for exactly one gesture: dragging a column into the group panel to add
    /// a grouping level (Groupable, drop on the group panel — rc.41). Column
    /// REORDER no longer uses native DnD at all — it went through this same
    /// draggable="true" + dragstart/drop-on-header pairing until the ReUI-parity
    /// pass, which replaced it with the unified pointer-based path (grip/header
    /// pointerdown, live sibling shift, no ghost/indicator) registered via
    /// Interop.RegisterColumnReorder — see components.js. Keeping native DnD
    /// scoped to grouping-only means a Reorderable+Groupable column still starts
    /// a native drag from most of the header (for the group-panel gesture) while
    /// the dedicated grip owns the reorder gesture (its pointerdown handler calls
    /// preventDefault/stopPropagation so native dragstart never arms from the
    /// grip).</summary>
    private bool IsDraggable =>
        Context?.ShowGroupPanel == true && Column.Groupable;

    private string CssClass
    {
        get
        {
            var pinClass = Column.Pin switch
            {
                PinDirection.Left => "sticky z-20 bg-muted",
                PinDirection.Right => "sticky z-20 bg-muted",
                _ => "bg-muted/30"
            };
            return string.Join(" ", new[]
            {
                // Padding tightens under Compact (px-2 py-1) so header height tracks
                // the compacted body cells instead of staying at the default px-3 py-2.
                $"group/th relative {(Context?.Compact == true ? "px-2 py-1" : "px-3 py-2")} text-left text-xs font-medium text-muted-foreground uppercase tracking-wider",
                "outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-inset",
                pinClass,
                // cursor-grab signals drag-affordance for reorder (grip/header pointer
                // path) AND drag-to-group (native DnD, Groupable + ShowGroupPanel) —
                // either capability lights it up so the cue isn't missed (2.2.2).
                (EffectiveReorderable || IsDraggable) ? "cursor-grab" : null,
                // Dim the dragged source header so users see at a glance which column
                // is moving. The reorder path now shows this via IsDragSource too (the
                // pointer JS doesn't set DragState — only native drag-to-group does —
                // so this class currently lights up for group-drags; the pointer path's
                // own opacity-0.8 is applied directly to the cell inline by JS).
                IsDragSource ? "opacity-40 transition-opacity" : null,
                Column.HeaderCssClass,
                Class
            }.Where(s => !string.IsNullOrWhiteSpace(s)));
        }
    }

    private string? StyleString
    {
        get
        {
            var parts = new List<string>();
            if (Column.Width.HasValue)
            {
                parts.Add($"width: {Column.Width.Value}px");
                parts.Add($"min-width: {Column.Width.Value}px");
            }
            if (Column.Pin == PinDirection.Left && Context?.PinnedLeftOffsets.TryGetValue(Column.Id, out var leftOff) == true)
                parts.Add($"left: {leftOff}px");
            else if (Column.Pin == PinDirection.Right && Context?.PinnedRightOffsets.TryGetValue(Column.Id, out var rightOff) == true)
                parts.Add($"right: {rightOff}px");
            return parts.Count > 0 ? string.Join("; ", parts) + ";" : null;
        }
    }

    private async Task HandleSort()
    {
        if (!Column.Sortable || Context is null || Column.Field is null) return;

        var newDirection = SortDirection switch
        {
            SortDirection.None => SortDirection.Ascending,
            SortDirection.Ascending => SortDirection.Descending,
            SortDirection.Descending => SortDirection.None,
            _ => SortDirection.None
        };

        await Context.OnSort.InvokeAsync(new SortDescriptor(Column.Field, newDirection));
    }

    private async Task ToggleFilter()
    {
        await OnFilterToggle.InvokeAsync();
    }

    private void TogglePinMenu()
    {
        _pinMenuOpen = !_pinMenuOpen;
        // Registration / teardown of the fixed positioner + click-outside runs
        // in OnAfterRenderAsync once the menu element is (or is no longer) in the DOM.
    }

    private void HandlePinMenuKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") _pinMenuOpen = false;
    }

    /// <summary>Raises a pin change from the header control. Routes through the
    /// owning grid's <see cref="DataGrid{TItem}.ApplyColumnPin"/> so it shares the
    /// exact partition + sticky-offset path the column chooser uses.</summary>
    private void PinFromHeader(PinDirection direction)
    {
        _pinMenuOpen = false;
        ParentGrid?.ApplyColumnPin(Column.Id, direction);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Resize: register the JS pointer listeners ON the resize handle the
        // moment it's in the DOM. Lazy-registering inside OnResizeStart meant
        // the FIRST pointerdown ran the Blazor handler (which then asked JS to
        // wire up its own pointerdown listener) — but that listener wasn't
        // attached yet at the time of the originating event, so the first
        // drag attempt was a no-op. Users had to release and press again
        // before resize actually started. Registering on firstRender flips
        // that: by the time the user's first pointerdown lands, the JS
        // handler is already listening.
        // Re-check on every render — not just firstRender — so columns whose
        // Resizable flag flips on after mount (e.g. parent unlocks edit mode)
        // still pick up the listener. _resizeRegistered short-circuits when
        // the handler is already attached, so the cost is one bool check per
        // render.
        if (Column.Resizable && !_resizeRegistered)
        {
            await EnsureResizeRegistered();
        }
        else if (!Column.Resizable && _resizeRegistered)
        {
            // Column flipped Resizable true → false. The resize-handle div is
            // gone from the DOM (the @if (Column.Resizable) gate above) but
            // the JS pointer listener it was tied to stays attached to a
            // detached element until we unregister it. More importantly,
            // _resizeRegistered would otherwise stay true and a later
            // false → true flip wouldn't re-call EnsureResizeRegistered —
            // the newly-rendered handle would never receive a listener and
            // resizing would silently stop working (Codex review on #46).
            try { await Interop.UnregisterColumnResize(_resizeHandleId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            // Mirrors the resize listener teardown above — round-13 #3's key-selective
            // preventDefault listener is tied to the same now-detached handle element.
            try { await Interop.UnregisterPreventDefaultKeys(_resizeHandleId); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
            _resizeRegistered = false;
        }

        // Header pin menu: pin the fixed-position menu to its trigger and register
        // click-outside dismissal. Handled BEFORE the non-filterable early-return
        // below so pinnable-but-not-filterable columns still get their menu wired.
        if (Column.Pinnable)
        {
            if (_pinMenuOpen && !_pinPositionRegistered)
            {
                await Interop.PositionFixed(_pinMenuId, _pinTriggerId, align: "end", matchWidth: false, side: "bottom");
                await Interop.RegisterClickOutside(_pinMenuId, _pinTriggerId, async () =>
                {
                    _pinMenuOpen = false;
                    await CleanupPinMenu();
                    await InvokeAsync(StateHasChanged);
                });
                _pinPositionRegistered = true;
            }
            else if (!_pinMenuOpen && _pinPositionRegistered)
            {
                await CleanupPinMenu();
            }
        }

        if (!Column.Filterable) return;

        if (IsFilterOpen && !_filterPositionRegistered)
        {
            // Pin the filter content (position:fixed) to the trigger button's
            // viewport rect. The "start" align + "bottom" side mirror the
            // previous absolute top-full left-0 layout. JS handles flip if the
            // popover would overflow the viewport (e.g. last row on a tall
            // grid) and follows the trigger on scroll/resize.
            await Interop.PositionFixed(_filterContentId, _filterTriggerId, align: "start", matchWidth: false, side: "bottom");
            // Click-outside dismiss — explicitly exclude the trigger so the
            // toggle button doesn't immediately close-then-reopen on click.
            // Closing routes through OnFilterToggle (the same callback the
            // button uses) so parent state stays consistent.
            await Interop.RegisterClickOutside(_filterContentId, _filterTriggerId, async () =>
            {
                await OnFilterToggle.InvokeAsync();
                await InvokeAsync(StateHasChanged);
            });
            _filterPositionRegistered = true;
        }
        else if (!IsFilterOpen && _filterPositionRegistered)
        {
            await CleanupFilterPosition();
        }
    }

    private async Task CleanupFilterPosition()
    {
        try { await Interop.UnpositionFixed(_filterContentId); } catch (JSDisconnectedException) { }
        try { await Interop.UnregisterClickOutside(_filterContentId); } catch (JSDisconnectedException) { }
        _filterPositionRegistered = false;
    }

    private async Task CleanupPinMenu()
    {
        try { await Interop.UnpositionFixed(_pinMenuId); } catch (JSDisconnectedException) { }
        try { await Interop.UnregisterClickOutside(_pinMenuId); } catch (JSDisconnectedException) { }
        _pinPositionRegistered = false;
    }

    private async Task HandleFilterApply(FilterDescriptor? descriptor)
    {
        var args = new FilterApplyEventArgs(Column.Field, descriptor);
        await OnFilterApply.InvokeAsync(args);
    }

    // Register-once helper. Called from OnAfterRenderAsync(firstRender) so the
    // JS pointerdown listener is live before the user's first drag attempt.
    // The previous lazy-on-first-pointerdown path is gone — that handler's
    // sole job was registration, and it lost the originating pointerdown.
    private async Task EnsureResizeRegistered()
    {
        if (_resizeRegistered) return;
        // JS drags the header + body cells in the DOM directly (smooth, no
        // Blazor round-trips per pixel) and invokes the commit callback with
        // the final width on pointerup.
        await Interop.RegisterColumnResize(
            _resizeHandleId,
            Column.MinWidth ?? 50,
            Column.MaxWidth,
            async (finalWidth, autoFit) =>
            {
                // Awaited internal commit, NOT the public fire-and-forget UpdateColumnWidth
                // (PR-353 round-13 #1) — this lambda is itself awaited end-to-end from JS's
                // registerColumnResize invokeMethodAsync call for EVERY entry point (pointer
                // drag, dblclick auto-fit, keyboard nudge all funnel through this ONE
                // commitHandler), which holds the cross-engine drag arbiter token open until
                // the returned promise settles. See DataGrid.CommitColumnWidthAsync's remarks.
                if (ParentGrid is not null)
                    await ParentGrid.CommitColumnWidthAsync(Column.Id, finalWidth, autoFit);
                await InvokeAsync(StateHasChanged);
            });

        // Key-selective preventDefault for the handle's OWN resize keys (round-13 #3):
        // the handle's @onkeydown:stopPropagation below keeps ArrowLeft/ArrowRight from
        // ever reaching the table-level RegisterPreventDefaultKeys listener (registered
        // on the table by DataGrid.OnAfterRenderAsync for header/cell keyboard nav), so
        // without this the browser's default page/grid scroll still fires on every
        // keyboard resize step. Registered directly on the handle — not the header
        // <th> — so it only ever suppresses the two keys THIS element's own
        // HandleResizeKeyDown consumes; plain header keyboard navigation (Tab, Enter,
        // Ctrl+Arrow on the <th> itself, etc.) is untouched. Mirrors the table-level
        // registration's idiom (a static @onkeydown:preventDefault can't be scoped to
        // just Arrow keys — it's fixed at render time and would also swallow Tab).
        await Interop.RegisterPreventDefaultKeys(_resizeHandleId, new[]
        {
            new PreventDefaultKeyRule("ArrowLeft"),
            new PreventDefaultKeyRule("ArrowRight"),
        });
        _resizeRegistered = true;
    }

    // Keyboard resize (a11y): Arrow Left/Right nudge the focused handle's column
    // by a step (Shift = fine 1px). The delta is applied in JS (NudgeColumnResize)
    // which reads the live width, clamps to min/max, flips sign for RTL, writes the
    // DOM directly, and re-commits through the same handler — so a keyboard resize
    // persists exactly like a drag. ArrowRight always means "toward the visual
    // right" regardless of writing direction.
    private async Task HandleResizeKeyDown(KeyboardEventArgs e)
    {
        if (!Column.Resizable) return;
        var step = e.ShiftKey ? 1.0 : 10.0;
        var delta = e.Key switch
        {
            "ArrowRight" => step,
            "ArrowLeft" => -step,
            _ => 0.0
        };
        if (delta == 0.0) return;
        await Interop.NudgeColumnResize(_resizeHandleId, delta);
    }

    // --- Column Drag & Drop: group-panel gesture only ---
    //
    // Native HTML5 DnD used to ALSO drive column reorder (dragstart on a header,
    // dragenter/drop on a sibling header, a glow drop-indicator). The ReUI-parity
    // pass replaced that entirely with the unified pointer-based path (mouse +
    // touch + pen, live sibling shift, no ghost/indicator) registered via
    // Interop.RegisterColumnReorder — see components.js `registerColumnReorder`.
    // What's left here is native DnD's one remaining job: dragging a Groupable
    // header into the group panel to add a grouping level (rc.41). Drag state is
    // held by an instance-bound DataGridDragState cascaded from the owning
    // DataGrid<TItem> — replaces the previous static-class holder which was
    // process-global and cross-talked between grid instances on the same page.

    private void HandleDragStart(DragEventArgs e)
    {
        if (!IsDraggable || DragState is null) return;
        DragState.StartColumnDrag(ColumnIndex, Column.Id);
    }

    private void HandleDragEnd(DragEventArgs e)
    {
        // Fires on the SOURCE element regardless of whether the drop
        // succeeded (drop target → ResetColumn already called) or was
        // cancelled (Esc, drop outside any target). The handler itself is
        // intentionally a no-op when there's no leftover state — but its
        // presence triggers a Blazor re-render of the source cell, which
        // clears the opacity-40 source-dim that IsDragSource toggled on.
        // Defensive ResetColumn covers the cancel path where no drop ran.
        if (DragState is not null && DragState.SourceColumnId == Column.Id)
        {
            DragState.ResetColumn();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_resizeRegistered)
        {
            try
            {
                await Interop.UnregisterColumnResize(_resizeHandleId);
            }
            catch (JSDisconnectedException) { }
            // Mirrors the resize listener teardown — round-13 #3's key-selective
            // preventDefault listener must not outlive the handle it's attached to.
            try
            {
                await Interop.UnregisterPreventDefaultKeys(_resizeHandleId);
            }
            catch (JSDisconnectedException) { }
        }
        if (_filterPositionRegistered)
        {
            await CleanupFilterPosition();
        }
        if (_pinPositionRegistered)
        {
            await CleanupPinMenu();
        }
    }
}
