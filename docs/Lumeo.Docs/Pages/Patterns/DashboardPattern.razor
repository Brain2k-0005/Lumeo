@page "/blocks/dashboard"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>Dashboard Pattern — Lumeo</PageTitle>

<PageHeader Title="Dashboard" Description="A complete analytics dashboard built with Lumeo components. Includes a top bar, stats cards, revenue chart, activity feed, data table, and mini charts." />

<Stack Gap="6">

    <ComponentDemo Title="Analytics Dashboard" Code="@_dashboardCode">
        <Stack Gap="4" Class="w-full">

            <!-- Top Bar -->
            <Flex Class="items-center justify-between gap-4 rounded-lg border bg-card px-4 py-3">
                <Flex Class="items-center gap-3">
                    <Flex Class="h-8 w-8 items-center justify-center rounded-md bg-primary">
                        <DynamicIcon Name="Star" Class="h-4 w-4 text-primary-foreground" />
                    </Flex>
                    <Lumeo.Text As="span" Class="text-base font-semibold text-foreground">Acme Dashboard</Lumeo.Text>
                </Flex>
                <Flex Class="flex-1 max-w-sm items-center gap-2 rounded-md border bg-background px-3">
                    <DynamicIcon Name="Search" Class="h-4 w-4 text-muted-foreground shrink-0" />
                    <Input type="text" placeholder="Search..." Class="flex h-8 w-full bg-transparent text-sm text-foreground placeholder:text-muted-foreground outline-none border-0 shadow-none p-0 focus-visible:ring-0" />
                </Flex>
                <Flex Class="items-center gap-2">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                        <DynamicIcon Name="Bell" Class="h-4 w-4" />
                    </Button>
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                        <DynamicIcon Name="Settings" Class="h-4 w-4" />
                    </Button>
                    <Flex Class="items-center gap-2 ml-1">
                        <Avatar Size="Avatar.AvatarSize.Sm">
                            <AvatarFallback>JD</AvatarFallback>
                        </Avatar>
                        <Stack Class="hidden sm:block">
                            <Lumeo.Text Class="text-sm font-medium text-foreground leading-none">Jane Doe</Lumeo.Text>
                            <Lumeo.Text Class="text-xs text-muted-foreground">Admin</Lumeo.Text>
                        </Stack>
                        <DynamicIcon Name="ChevronDown" Class="h-4 w-4 text-muted-foreground" />
                    </Flex>
                </Flex>
            </Flex>

            <!-- Stats Row -->
            <Grid Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                @foreach (var stat in _stats)
                {
                    <Card>
                        <CardHeader>
                            <Flex Class="items-center justify-between">
                                <Lumeo.Text Class="text-sm font-medium text-muted-foreground">@stat.Label</Lumeo.Text>
                                <DynamicIcon Name="@stat.IconName" Class="h-4 w-4 text-muted-foreground" />
                            </Flex>
                        </CardHeader>
                        <CardContent>
                            <Lumeo.Text Class="text-2xl font-bold text-foreground">@stat.Value</Lumeo.Text>
                            <Flex Class="mt-1 items-center gap-1">
                                <Badge Variant="@stat.BadgeVariant">@stat.Trend</Badge>
                                <Lumeo.Text As="span" Class="text-xs text-muted-foreground">from last month</Lumeo.Text>
                            </Flex>
                            <Progress Value="@stat.ProgressValue" Class="mt-3 h-1" Variant="@stat.ProgressVariant" />
                        </CardContent>
                    </Card>
                }
            </Grid>

            <!-- Main Chart + Activity Feed -->
            <Grid Class="grid-cols-1 lg:grid-cols-7 gap-4">
                <!-- Area Chart -->
                <Card Class="lg:col-span-5">
                    <CardHeader>
                        <Flex Class="items-center justify-between">
                            <Stack>
                                <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Revenue Overview</Heading>
                                <Lumeo.Text Class="text-sm text-muted-foreground mt-1">12-month revenue and expenses</Lumeo.Text>
                            </Stack>
                            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">
                                <DynamicIcon Name="ChevronDown" Class="h-4 w-4 mr-1" />
                                This Year
                            </Button>
                        </Flex>
                    </CardHeader>
                    <CardContent>
                        <AreaChart
                            Categories="@_areaCategories"
                            Series="@_areaSeries"
                            Smooth="true"
                            Height="280px" />
                    </CardContent>
                </Card>

                <!-- Recent Activity -->
                <Card Class="lg:col-span-2">
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Activity</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Recent events</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <Stack Gap="0">
                            @foreach (var activity in _activities)
                            {
                                <Flex Class="gap-3 py-3 border-b last:border-0 items-center">
                                    <Avatar Class="h-6 w-6">
                                        <AvatarFallback Class="text-[10px]">@activity.Initials</AvatarFallback>
                                    </Avatar>
                                    <Stack Class="@($"mt-0.5 h-2 w-2 shrink-0 rounded-full {activity.DotClass}")"></Stack>
                                    <Stack Class="flex-1 min-w-0">
                                        <Lumeo.Text Class="text-sm text-foreground leading-snug">@activity.Text</Lumeo.Text>
                                        <Lumeo.Text Class="text-xs text-muted-foreground mt-0.5">@activity.Time</Lumeo.Text>
                                    </Stack>
                                </Flex>
                            }
                        </Stack>
                    </CardContent>
                </Card>
            </Grid>

            <!-- Data Table -->
            <Card>
                <CardHeader>
                    <Flex Class="items-center justify-between">
                        <Stack>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Transactions</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground mt-1">8 most recent transactions</Lumeo.Text>
                        </Stack>
                        <Flex Class="items-center gap-2">
                            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">
                                <DynamicIcon Name="Copy" Class="h-4 w-4 mr-1" />
                                Export
                            </Button>
                            <Button Size="Button.ButtonSize.Sm">
                                <DynamicIcon Name="Plus" Class="h-4 w-4 mr-1" />
                                Add New
                            </Button>
                        </Flex>
                    </Flex>
                </CardHeader>
                <CardContent>
                    <Table>
                        <TableHeader>
                            <TableRow>
                                <TableHead Class="w-10"></TableHead>
                                <TableHead>Customer</TableHead>
                                <TableHead>Status</TableHead>
                                <TableHead>Date</TableHead>
                                <TableHead Class="text-right">Amount</TableHead>
                            </TableRow>
                        </TableHeader>
                        <TableBody>
                            @foreach (var tx in _transactions)
                            {
                                <TableRow>
                                    <TableCell>
                                        <Avatar Class="h-6 w-6">
                                            <AvatarFallback Class="text-[10px]">@tx.Initials</AvatarFallback>
                                        </Avatar>
                                    </TableCell>
                                    <TableCell Class="font-medium">@tx.Customer</TableCell>
                                    <TableCell>
                                        <Badge Variant="@tx.BadgeVariant">@tx.Status</Badge>
                                    </TableCell>
                                    <TableCell Class="text-muted-foreground">@tx.Date</TableCell>
                                    <TableCell Class="text-right font-medium">@tx.Amount</TableCell>
                                </TableRow>
                            }
                        </TableBody>
                    </Table>
                </CardContent>
            </Card>

            <!-- Bottom Mini Charts -->
            <Grid Class="grid-cols-1 lg:grid-cols-2 gap-4">
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Monthly Sales</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Units sold per month</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <BarChart
                            Categories="@_barCategories"
                            Series="@_barSeries"
                            Height="220px" />
                    </CardContent>
                </Card>
                <Card>
                    <CardHeader>
                        <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Revenue by Channel</Heading>
                        <Lumeo.Text Class="text-sm text-muted-foreground">Breakdown of revenue sources</Lumeo.Text>
                    </CardHeader>
                    <CardContent>
                        <PieChart
                            Data="@_pieData"
                            Height="220px" />
                    </CardContent>
                </Card>
            </Grid>

        </Stack>
    </ComponentDemo>

</Stack>

@code {
    private record StatItem(string Label, string Value, string Trend, Badge.BadgeVariant BadgeVariant, string IconName, int ProgressValue, Progress.ProgressVariant ProgressVariant);
    private List<StatItem> _stats = new()
    {
        new StatItem("Total Revenue",    "$45,231.89", "+12.5%", Badge.BadgeVariant.Success,     "TrendingUp",    73, Progress.ProgressVariant.Success),
        new StatItem("Subscriptions",    "+2,350",     "+18.1%", Badge.BadgeVariant.Success,     "Users",         81, Progress.ProgressVariant.Success),
        new StatItem("Total Sales",      "+12,234",    "+19.0%", Badge.BadgeVariant.Success,     "ShoppingCart",  65, Progress.ProgressVariant.Success),
        new StatItem("Active Users",     "+573",       "-4.2%",  Badge.BadgeVariant.Destructive, "Eye",           38, Progress.ProgressVariant.Destructive),
    };

    // Area chart — 12 months
    private List<string> _areaCategories = new()
    {
        "Jan", "Feb", "Mar", "Apr", "May", "Jun",
        "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"
    };
    private List<AreaChart.ChartSeriesData> _areaSeries = new()
    {
        new AreaChart.ChartSeriesData
        {
            Name   = "Revenue",
            Values = new List<double> { 18000, 22000, 19500, 28000, 32000, 45000, 41000, 38000, 43000, 49000, 52000, 61000 }
        },
        new AreaChart.ChartSeriesData
        {
            Name   = "Expenses",
            Values = new List<double> { 12000, 14000, 13500, 16000, 18000, 21000, 19500, 17000, 20000, 22000, 24000, 27000 }
        }
    };

    // Recent activity feed
    private record ActivityItem(string Text, string Time, string DotClass, string Initials);
    private List<ActivityItem> _activities = new()
    {
        new ActivityItem("New subscription from Olivia M.",  "2 min ago",   "bg-primary",            "OM"),
        new ActivityItem("Payment of $1,999 completed",      "18 min ago",  "bg-primary",            "JL"),
        new ActivityItem("Server CPU spiked to 94%",         "1 hour ago",  "bg-destructive",        "WK"),
        new ActivityItem("Isabella N. upgraded to Pro plan", "3 hours ago", "bg-primary",            "IN"),
        new ActivityItem("Monthly report generated",         "Yesterday",   "bg-muted-foreground",   "SD"),
    };

    // Transaction table — Completed / Pending / Failed
    private record TransactionItem(string Customer, string Status, Badge.BadgeVariant BadgeVariant, string Date, string Amount, string Initials);
    private List<TransactionItem> _transactions = new()
    {
        new TransactionItem("Olivia Martin",   "Completed", Badge.BadgeVariant.Success,     "Feb 15, 2026", "$1,999.00",  "OM"),
        new TransactionItem("Jackson Lee",      "Completed", Badge.BadgeVariant.Success,     "Feb 14, 2026", "$39.00",     "JL"),
        new TransactionItem("Isabella Nguyen",  "Pending",   Badge.BadgeVariant.Warning,     "Feb 13, 2026", "$299.00",    "IN"),
        new TransactionItem("William Kim",      "Failed",    Badge.BadgeVariant.Destructive,  "Feb 12, 2026", "$99.00",    "WK"),
        new TransactionItem("Sofia Davis",      "Completed", Badge.BadgeVariant.Success,     "Feb 11, 2026", "$2,500.00",  "SD"),
        new TransactionItem("Liam Johnson",     "Pending",   Badge.BadgeVariant.Warning,     "Feb 10, 2026", "$750.00",    "LJ"),
        new TransactionItem("Emma Wilson",      "Completed", Badge.BadgeVariant.Success,     "Feb 9, 2026",  "$1,200.00",  "EW"),
        new TransactionItem("Noah Brown",       "Failed",    Badge.BadgeVariant.Destructive,  "Feb 8, 2026",  "$450.00",   "NB"),
    };

    // Bar chart
    private List<string> _barCategories = new() { "Jan", "Feb", "Mar", "Apr", "May", "Jun" };
    private List<BarChart.ChartSeriesData> _barSeries = new()
    {
        new BarChart.ChartSeriesData
        {
            Name   = "Units Sold",
            Values = new List<double> { 4200, 3800, 5100, 4700, 6300, 7200 }
        }
    };

    // Pie chart
    private List<PieChart.PieChartData> _pieData = new()
    {
        new PieChart.PieChartData { Name = "Direct",   Value = 38 },
        new PieChart.PieChartData { Name = "Organic",  Value = 27 },
        new PieChart.PieChartData { Name = "Referral", Value = 20 },
        new PieChart.PieChartData { Name = "Social",   Value = 15 },
    };

    private string _dashboardCode = @"<!-- Top Bar -->
<Flex Align=""center"" Justify=""between"" Class=""gap-4 rounded-lg border bg-card px-4 py-3"">
    <Flex Align=""center"" Gap=""3"">
        <Flex Class=""h-8 w-8 items-center justify-center rounded-md bg-primary"">
            <DynamicIcon Name=""Star"" Class=""h-4 w-4 text-primary-foreground"" />
        </Flex>
        <Lumeo.Text As=""span"" Class=""text-base font-semibold text-foreground"">Acme Dashboard</Lumeo.Text>
    </Flex>
    <Flex Align=""center"" Class=""flex-1 max-w-sm gap-2 rounded-md border bg-background px-3"">
        <DynamicIcon Name=""Search"" Class=""h-4 w-4 text-muted-foreground"" />
        <Input Placeholder=""Search..."" Class=""h-8 flex-1 bg-transparent"" />
    </Flex>
    <Flex Align=""center"" Gap=""2"">
        <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon"">
            <DynamicIcon Name=""Bell"" Class=""h-4 w-4"" />
        </Button>
        <Avatar Size=""Avatar.AvatarSize.Sm"">
            <AvatarFallback>JD</AvatarFallback>
        </Avatar>
        <DynamicIcon Name=""ChevronDown"" Class=""h-4 w-4 text-muted-foreground"" />
    </Flex>
</Flex>

<!-- Stats Row -->
<Grid Class=""grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4"">
    <Card>
        <CardHeader>
            <Lumeo.Text Class=""text-sm font-medium text-muted-foreground"">Total Revenue</Lumeo.Text>
        </CardHeader>
        <CardContent>
            <Lumeo.Text Class=""text-2xl font-bold text-foreground"">$45,231.89</Lumeo.Text>
            <Badge Variant=""Badge.BadgeVariant.Success"">+12.5%</Badge>
            <Lumeo.Text As=""span"" Class=""text-xs text-muted-foreground"">from last month</Lumeo.Text>
        </CardContent>
    </Card>
    <!-- ... repeat for other stats ... -->
</Grid>

<!-- Main Chart + Activity -->
<Grid Class=""grid-cols-1 lg:grid-cols-7 gap-4"">
    <Card Class=""lg:col-span-5"">
        <CardHeader><Heading Level=""3"">Revenue Overview</Heading></CardHeader>
        <CardContent>
            <AreaChart Categories=""@_areaCategories"" Series=""@_areaSeries"" Smooth=""true"" Height=""280px"" />
        </CardContent>
    </Card>
    <Card Class=""lg:col-span-2"">
        <CardHeader><Heading Level=""3"">Activity</Heading></CardHeader>
        <CardContent>
            @foreach (var a in _activities)
            {
                <Flex Gap=""3"" Class=""py-3 border-b last:border-0"">
                    <Stack Class=""mt-0.5 h-2 w-2 rounded-full bg-primary"" />
                    <Stack Gap=""0"">
                        <Lumeo.Text Class=""text-sm text-foreground"">@a.Text</Lumeo.Text>
                        <Lumeo.Text Class=""text-xs text-muted-foreground"">@a.Time</Lumeo.Text>
                    </Stack>
                </Flex>
            }
        </CardContent>
    </Card>
</Grid>

<!-- Transactions Table -->
<Table>
    <TableHeader>
        <TableRow>
            <TableHead>Customer</TableHead>
            <TableHead>Status</TableHead>
            <TableHead>Date</TableHead>
            <TableHead Class=""text-right"">Amount</TableHead>
        </TableRow>
    </TableHeader>
    <TableBody>
        @foreach (var tx in _transactions)
        {
            <TableRow>
                <TableCell Class=""font-medium"">@tx.Customer</TableCell>
                <TableCell><Badge Variant=""@tx.BadgeVariant"">@tx.Status</Badge></TableCell>
                <TableCell Class=""text-muted-foreground"">@tx.Date</TableCell>
                <TableCell Class=""text-right font-medium"">@tx.Amount</TableCell>
            </TableRow>
        }
    </TableBody>
</Table>

<!-- Mini Charts -->
<Grid Class=""grid-cols-1 lg:grid-cols-2 gap-4"">
    <Card>
        <CardHeader><Heading Level=""3"">Monthly Sales</Heading></CardHeader>
        <CardContent>
            <BarChart Categories=""@_barCategories"" Series=""@_barSeries"" Height=""220px"" />
        </CardContent>
    </Card>
    <Card>
        <CardHeader><Heading Level=""3"">Revenue by Channel</Heading></CardHeader>
        <CardContent>
            <PieChart Data=""@_pieData"" Height=""220px"" />
        </CardContent>
    </Card>
</Grid>";
}
