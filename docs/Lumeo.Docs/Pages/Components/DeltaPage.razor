@page "/components/delta"

<PageTitle>Delta — Lumeo</PageTitle>

<PageHeader Title="Delta" Description="Trend indicator showing delta value with up/down arrow and color." />

<InstallUsage Component="Delta" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Show percentage or absolute change next to a KPI metric.</li>
        <li>Indicate revenue growth, churn delta, or inventory variance at a glance.</li>
        <li>Use <code class="text-xs bg-muted px-1 py-0.5 rounded">Positive="DeltaDirection.Bad"</code> for metrics where lower is better (e.g. error rate).</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Percent Delta" Code="@_percentCode">
        <Flex Gap="2" Wrap="true" Align="center">
            <Delta Value="12.5" />
            <Delta Value="-3.2" />
            <Delta Value="0" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Absolute Delta" Code="@_absoluteCode">
        <Flex Gap="2" Wrap="true" Align="center">
            <Delta Value="420" Format="Delta.DeltaFormat.Absolute" />
            <Delta Value="-88" Format="Delta.DeltaFormat.Absolute" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Inverted Positive (Lower is Better)" Code="@_invertedCode">
        <Flex Gap="2" Wrap="true" Align="center">
            <Delta Value="-5.1" Positive="Delta.DeltaDirection.Bad" />
            <Delta Value="2.3" Positive="Delta.DeltaDirection.Bad" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="No Arrow" Code="@_noArrowCode">
        <Flex Gap="2" Wrap="true" Align="center">
            <Delta Value="7.4" ShowArrow="false" />
            <Delta Value="-1.9" ShowArrow="false" />
        </Flex>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Delta</Heading>
            <PropsTable Slug="delta" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/kpi-card" class="text-primary hover:underline">KpiCard</a> — Dashboard KPI tile that embeds a Delta for trend display.</li>
        <li><a href="/components/spark-card" class="text-primary hover:underline">SparkCard</a> — Small card with an inline sparkline chart.</li>
        <li><a href="/components/statistic" class="text-primary hover:underline">Statistic</a> — Big-number statistic display with label and unit.</li>
    </ul>
</div>

@code {
    private string _percentCode = @"<Delta Value=""12.5"" />
<Delta Value=""-3.2"" />
<Delta Value=""0"" />";

    private string _absoluteCode = @"<Delta Value=""420"" Format=""Delta.DeltaFormat.Absolute"" />
<Delta Value=""-88"" Format=""Delta.DeltaFormat.Absolute"" />";

    private string _invertedCode = @"<Delta Value=""-5.1"" Positive=""Delta.DeltaDirection.Bad"" />
<Delta Value=""2.3"" Positive=""Delta.DeltaDirection.Bad"" />";

    private string _noArrowCode = @"<Delta Value=""7.4"" ShowArrow=""false"" />
<Delta Value=""-1.9"" ShowArrow=""false"" />";
}
