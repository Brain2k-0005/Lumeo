@page "/components/center"

<PageTitle>Center — Lumeo</PageTitle>

<PageHeader Title="Center" Description="A utility component that centers its children both horizontally and vertically." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Centering" Code="@_basicCode">
        <Center Class="h-32 w-full rounded-lg border border-dashed border-border">
            <Text Color="muted">Centered content</Text>
        </Center>
    </ComponentDemo>

    <ComponentDemo Title="With Fixed Height" Code="@_heightCode">
        <Center Height="200px" Class="w-full rounded-lg border border-dashed border-border">
            <Stack Align="center" Gap="2">
                <DynamicIcon Name="Image" Class="h-8 w-8 text-muted-foreground" />
                <Text Color="muted" Size="sm">No image selected</Text>
            </Stack>
        </Center>
    </ComponentDemo>

    <ComponentDemo Title="Inline Center" Code="@_inlineCode">
        <Text>
            Click the
            <Center Inline="true" Class="h-6 w-6 rounded bg-primary/20 mx-1">
                <DynamicIcon Name="Plus" Class="h-3 w-3 text-primary" />
            </Center>
            icon to add an item.
        </Text>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Height</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Fixed height as CSS value (e.g. "200px", "10rem"). Defaults to h-full if unset.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Inline</TableCell>
                    <TableCell Class="font-mono text-xs">bool</TableCell>
                    <TableCell Class="font-mono text-xs">false</TableCell>
                    <TableCell>Use inline-flex instead of flex for inline centering.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _basicCode = @"<Center Class=""h-32 w-full"">
    <Text Color=""muted"">Centered content</Text>
</Center>";

    private string _heightCode = @"<Center Height=""200px"">
    <Stack Align=""center"" Gap=""2"">
        <DynamicIcon Name=""Image"" Class=""h-8 w-8 text-muted-foreground"" />
        <Text Color=""muted"" Size=""sm"">No image selected</Text>
    </Stack>
</Center>";

    private string _inlineCode = @"<Text>
    Click the
    <Center Inline=""true"" Class=""h-6 w-6 rounded bg-primary/20 mx-1"">
        <DynamicIcon Name=""Plus"" Class=""h-3 w-3 text-primary"" />
    </Center>
    icon to add an item.
</Text>";
}
