@namespace Lumeo.Tests.Components.Sidebar

@* Test host for #241 — exposes SidebarProvider params (MobileSheet, ToggleShortcut,
   Variant, IsCollapsed) so tests can drive them and observe the toggle round-trip. *@
<Lumeo.SidebarProvider MobileSheet="MobileSheet"
                       ToggleShortcut="@ToggleShortcut"
                       Variant="Variant"
                       IsCollapsed="Collapsed"
                       IsCollapsedChanged="OnCollapsedChanged">
    <Lumeo.SidebarComponent>Nav</Lumeo.SidebarComponent>
</Lumeo.SidebarProvider>

@code {
    [Parameter] public bool MobileSheet { get; set; }
    [Parameter] public string? ToggleShortcut { get; set; }
    [Parameter] public Lumeo.SidebarProvider.SidebarVariant Variant { get; set; } = Lumeo.SidebarProvider.SidebarVariant.Push;
    [Parameter] public bool Collapsed { get; set; }

    public bool LastCollapsed { get; private set; }

    private void OnCollapsedChanged(bool value)
    {
        Collapsed = value;
        LastCollapsed = value;
    }
}
