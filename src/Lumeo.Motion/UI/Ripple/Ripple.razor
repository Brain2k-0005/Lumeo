@namespace Lumeo

<div class="@CssClass" style="@StyleString" aria-hidden="true" @attributes="AdditionalAttributes">
    @for (int i = 0; i < RingCount; i++)
    {
        var delay = $"{(i * DelayStep).ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}s";
        var sizeRem = (BaseSize + i * SizeStep).ToString("F2", System.Globalization.CultureInfo.InvariantCulture);
        <div class="lumeo-ripple-ring" style="width:@(sizeRem)rem;height:@(sizeRem)rem;animation-delay:@delay;border-color:@Color;" />
    }
</div>

@code {
    /// <summary>Number of concentric ripple rings.</summary>
    [Parameter] public int RingCount { get; set; } = 5;
    /// <summary>Base diameter (rem) of the innermost ring.</summary>
    [Parameter] public double BaseSize { get; set; } = 4.0;
    /// <summary>Additional size (rem) added per ring outward.</summary>
    [Parameter] public double SizeStep { get; set; } = 3.0;
    /// <summary>Animation delay (seconds) between consecutive rings.</summary>
    [Parameter] public double DelayStep { get; set; } = 0.4;
    /// <summary>Duration of one ripple expansion cycle.</summary>
    [Parameter] public string Duration { get; set; } = "2.5s";
    /// <summary>Color of the ring borders. Defaults to primary.</summary>
    [Parameter] public string Color { get; set; } = "var(--color-primary)";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[] { "lumeo-ripple", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));
    private string StyleString => $"--lumeo-ripple-duration: {Duration};";
}
