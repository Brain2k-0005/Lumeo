                        </tr>
                    </tbody>
                </table>
            </div>

        </Stack>
    </section>

    <Separator />

    <!-- Scroll to Top Demo -->
    <section>
        <Stack Gap="4">
            <Heading Level="2">Scroll to Top</Heading>
            <Lumeo.Text Size="sm" Color="muted">Smooth-scroll the page back to the top.</Lumeo.Text>
            <div class="code-block rounded-lg border border-border bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">await Interop.ScrollToTop();</div>
            <div>
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => Interop.ScrollToTop()">
                    <Blazicon Svg="Lucide.ArrowUp" class="h-4 w-4 mr-2" />
                    Scroll to Top
                </Button>
            </div>
        </Stack>
    </section>

</Stack>

@code {
    private string _clipboardText = "Hello from Lumeo!";
    private bool _copied;

    private async Task CopyToClipboard()
    {
        await Interop.CopyToClipboard(_clipboardText);
        _copied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _copied = false;
    }

    private async Task DownloadSample()
    {
        var content = "This file was generated by Lumeo's ComponentInteropService.\nTimestamp: " + DateTime.Now;
        var base64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(content));
        await Interop.DownloadFile("sample.txt", base64, "text/plain");
    }
}
