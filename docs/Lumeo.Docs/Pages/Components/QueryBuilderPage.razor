                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">QueryBuilderGroup</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="mb-3">The recursive per-group renderer used internally by <code>QueryBuilder</code>. Exposed for advanced composition; most consumers never render it directly.</Lumeo.Text>
            <PropsTable Slug="query-builder" SubComponent="QueryBuilderGroup" />
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">Default operator sets</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
