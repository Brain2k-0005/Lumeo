@page "/docs/bundle-facts"
@namespace Lumeo.Docs.Pages.Docs

<PageTitle>Bundle Facts — Lumeo</PageTitle>

<Container MaxWidth="4xl" Padding="0" Center="false">
<Stack Gap="16">

    <!-- ====================================================
         1. HERO — Giant brotli number
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="5" Class="py-10 text-center items-center">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Performance</Badge>

                <Heading Level="1" Class="text-4xl sm:text-5xl font-bold tracking-tight leading-tight">
                    How Lumeo stays at
                    <Sparkles Count="6" Class="inline-flex items-baseline">
                        <NumberTicker Value="672"
                                      Suffix=" KB"
                                      DurationMs="2000"
                                      Class="text-primary font-mono" />
                    </Sparkles>
                </Heading>

                <Lumeo.Text Size="base" Color="muted" Class="max-w-xl leading-relaxed">
                    What the browser actually downloads — brotli-compressed assembly size, measured
                    <Lumeo.Text As="span" Weight="medium" Color="foreground">2026-07-11 (4.2.0)</Lumeo.Text>.
                </Lumeo.Text>
            </Stack>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         2. BREAKDOWN — 7 package size bars
         ==================================================== -->
    <section>
        <BlurFade DelayMs="80">
            <Stack Gap="3" Class="mb-8">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">Per-package breakdown</Heading>
                <Lumeo.Text Size="sm" Color="muted">
                    Install only the satellites you use. Each row shows the brotli-compressed size that package adds to your published WASM app.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Stack Gap="3">
            @{ int _i = 0; }
            @foreach (var pkg in _packages)
            {
                var delay = 80 + (_i * 80);
                _i++;
                <BlurFade DelayMs="@delay" ForceHidden="true">
                    <div class="rounded-xl border border-border/40 bg-card p-4 hover:border-primary/40 transition-colors">
                        <Flex Align="center" Justify="between" Class="mb-2.5">
                            <Flex Align="center" Gap="2">
                                <span class="h-2 w-2 rounded-full @(pkg.IsCore ? "bg-primary" : "bg-primary/50")"></span>
                                <Lumeo.Text As="span" Weight="@(pkg.IsCore ? "semibold" : "medium")" Color="foreground" Size="sm">@pkg.Name</Lumeo.Text>
                                @if (!string.IsNullOrEmpty(pkg.Note))
                                {
                                    <Lumeo.Text As="span" Size="xs" Color="muted">@pkg.Note</Lumeo.Text>
                                }
                            </Flex>
                            <Lumeo.Text As="span" Size="xs" Class="@(pkg.IsCore ? "font-mono font-semibold text-primary" : "font-mono text-muted-foreground")">@pkg.SizeLabel</Lumeo.Text>
                        </Flex>
                        <div class="relative h-2 rounded-full bg-muted/40 overflow-hidden">
                            <div class="@(pkg.IsCore ? "bg-primary" : "bg-primary/50") h-full rounded-full transition-all duration-700"
                                 style="width: @(pkg.Percent)%;"></div>
                        </div>
                    </div>
                </BlurFade>
            }
        </Stack>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         3. WHAT'S IN THE .nupkg — animated breakdown
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-8">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">What's actually in the core .nupkg</Heading>
                <Lumeo.Text Size="sm" Color="muted">
                    The .nupkg contains more than what reaches the browser. Here's the full inventory.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Stack Gap="3">
            @{ int _j = 0; }
            @foreach (var asset in _nupkgAssets)
            {
                var assetDelay = _j * 80;
                _j++;
                <BlurFade DelayMs="@assetDelay" ForceHidden="true">
                    <Card Class="p-4">
                        <Flex Align="start" Gap="3">
                            <Flex Align="center" Justify="center" Class="h-9 w-9 shrink-0 rounded-md bg-accent/40 text-primary">
                                <DynamicIcon Name="@asset.IconName" Class="h-5 w-5" />
                            </Flex>
                            <Stack Gap="1" Class="flex-1 min-w-0">
                                <Flex Align="center" Justify="between" Gap="2">
                                    <Lumeo.Text As="span" Weight="semibold" Size="sm" Color="foreground">@asset.Title</Lumeo.Text>
                                    <Chip Class="shrink-0 font-mono text-xs">@asset.Size</Chip>
                                </Flex>
                                <Lumeo.Text Size="xs" Color="muted" Leading="relaxed">@asset.Description</Lumeo.Text>
                            </Stack>
                        </Flex>
                    </Card>
                </BlurFade>
            }
        </Stack>

        <BlurFade DelayMs="320" ForceHidden="true">
            <div class="mt-4 rounded-lg border border-border/40 bg-muted/20 px-4 py-3">
                <Lumeo.Text Size="xs" Color="muted">
                    Total: <Lumeo.Text As="span" Weight="semibold" Color="foreground">~1,180 KB</Lumeo.Text> in the .nupkg —
                    matches the NuGet "Download package" badge (~1.18 MB). The <Lumeo.Text As="span" Weight="semibold" Color="foreground">672 KB brotli number</Lumeo.Text>
                    is just the DLL, which is the only thing the WASM linker ships to the browser.
                </Lumeo.Text>
            </div>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         4. WHAT'S NOT IN CORE — Marquee strip
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-6">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">What's not in core</Heading>
                <Lumeo.Text Size="sm" Color="muted">The dependencies we said no to.</Lumeo.Text>
            </Stack>
        </BlurFade>

        <BlurFade DelayMs="80" ForceHidden="true">
            <div class="relative overflow-hidden rounded-xl border border-border/40 bg-muted/10 py-6">
                <!-- fade edges -->
                <div class="pointer-events-none absolute inset-y-0 left-0 w-24 z-10"
                     style="background: linear-gradient(to right, hsl(var(--background)), transparent)"></div>
                <div class="pointer-events-none absolute inset-y-0 right-0 w-24 z-10"
                     style="background: linear-gradient(to left, hsl(var(--background)), transparent)"></div>

                <Marquee Speed="Marquee.MarqueeSpeed.Normal" PauseOnHover="true" Class="gap-3">
                    @foreach (var dep in _excludedDeps)
                    {
                        <Chip Class="mx-2 shrink-0 text-xs whitespace-nowrap">@dep</Chip>
                    }
                </Marquee>
            </div>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         5. COMPARISON TABLE — Lumeo vs alternatives
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-6">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">How it compares</Heading>
                <Lumeo.Text Size="sm" Color="muted">
                    Brotli-compressed size of each library's core component DLL — managed code only (see note).
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <BlurFade DelayMs="80" ForceHidden="true">
            <div class="overflow-hidden rounded-xl border border-border/40">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/20">
                            <th class="py-3 px-4 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide">Library</th>
                            <th class="py-3 px-4 text-right text-xs font-semibold text-muted-foreground uppercase tracking-wide">Core brotli size</th>
                            <th class="py-3 px-4 text-left text-xs font-semibold text-muted-foreground uppercase tracking-wide hidden sm:table-cell">Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _comparisonRows)
                        {
                            var trClass = row.IsUs ? "border-b border-border/40 last:border-0 bg-primary/5 transition-colors" : "border-b border-border/40 last:border-0 hover:bg-muted/10 transition-colors";
                            var sizeClass = row.IsUs ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground";
                            var nameWeight = row.IsUs ? "semibold" : "normal";
                            var nameColor = row.IsUs ? "foreground" : "muted";
                            <tr class="@trClass">
                                <td class="py-3 px-4">
                                    <Flex Align="center" Gap="2">
                                        @if (row.IsUs)
                                        {
                                            <Badge Variant="Badge.BadgeVariant.Default" Class="px-1.5 py-0 text-[10px] leading-none h-4">You</Badge>
                                        }
                                        <Lumeo.Text As="span" Weight="@nameWeight" Color="@nameColor">@row.Name</Lumeo.Text>
                                    </Flex>
                                </td>
                                <td class="py-3 px-4 text-right">
                                    <Lumeo.Text As="span" Class="@sizeClass">@row.Size</Lumeo.Text>
                                </td>
                                <td class="py-3 px-4 hidden sm:table-cell">
                                    <Lumeo.Text As="span" Size="xs" Color="muted">@row.Note</Lumeo.Text>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <Lumeo.Text Size="xs" Color="muted" Class="mt-3 italic leading-relaxed">
                * Brotli (quality 11) of each library's core component DLL — latest stable as of June 2026,
                .NET 10 target (Telerik: .NET 8, its latest published build). Measured 2026-06-29 and
                reproducible by brotli-compressing the DLL inside each public .nupkg. This counts the managed
                assembly only: it excludes app-specific IL trimming (which shrinks every library in a real
                published app) and the JS/CSS static web assets each library ships separately — some
                substantial (e.g. Telerik's ~4.8&nbsp;MB JS bundle, Radzen's multi-theme CSS, and Lumeo's own
                components.js&nbsp;+&nbsp;lumeo.css). DLL size reflects managed footprint, not features or final shipped size.
                Only the Lumeo row was re-measured on 2026-07-11 against 4.2.0 — 671.6&nbsp;KiB
                (687,723&nbsp;bytes) brotli of <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">lib/net10.0/Lumeo.dll</code>,
                rounded to 672&nbsp;KB above; every other row remains the 2026-06-29 measurement.
            </Lumeo.Text>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         6. HEAVY FEATURES ARE OPT-IN — explainer bento
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-8">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">Heavy features are opt-in</Heading>
                <Lumeo.Text Size="sm" Color="muted">
                    Don't need charts? ECharts never touches your build. Don't need a data grid? ClosedXML and QuestPDF aren't downloaded.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="3" Gap="Bento.BentoGap.Md">
            <BentoTile Span="1" Class="border-border/60 p-6">
                <BlurFade DelayMs="80" ForceHidden="true">
                    <Stack Gap="3">
                        <Flex Align="center" Gap="2">
                            <Flex Align="center" Justify="center" Class="h-8 w-8 rounded-md bg-accent/40 text-primary">
                                <DynamicIcon Name="BarChart3" Class="h-4 w-4" />
                            </Flex>
                            <Chip Class="font-mono text-xs">128 KB</Chip>
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">Charts</Heading>
                        <Lumeo.Text Size="xs" Weight="medium" Color="muted" Class="font-mono">Lumeo.Charts</Lumeo.Text>
                        <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                            ECharts lazy-loaded only when a chart component mounts — never included
                            unless you reference the package.
                        </Lumeo.Text>
                    </Stack>
                </BlurFade>
            </BentoTile>

            <BentoTile Span="1" Class="border-border/60 p-6">
                <BlurFade DelayMs="160" ForceHidden="true">
                    <Stack Gap="3">
                        <Flex Align="center" Gap="2">
                            <Flex Align="center" Justify="center" Class="h-8 w-8 rounded-md bg-accent/40 text-primary">
                                <DynamicIcon Name="Table2" Class="h-4 w-4" />
                            </Flex>
                            <Chip Class="font-mono text-xs">120 KB</Chip>
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">DataGrid</Heading>
                        <Lumeo.Text Size="xs" Weight="medium" Color="muted" Class="font-mono">Lumeo.DataGrid</Lumeo.Text>
                        <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                            Full virtualization, group-by, and export. Since <strong>v3.7.0</strong>
                            the export backend (ClosedXML + QuestPDF, ~1.65&nbsp;MB brotli) ships in
                            a separate bundled DLL — opt-in lazy-load on WASM keeps it out of the
                            first paint. <a href="/docs/services/datagrid-export#lazy-loading" class="text-primary underline-offset-4 hover:underline">Lazy setup →</a>
                        </Lumeo.Text>
                    </Stack>
                </BlurFade>
            </BentoTile>

            <BentoTile Span="1" Class="border-border/60 p-6">
                <BlurFade DelayMs="240" ForceHidden="true">
                    <Stack Gap="3">
                        <Flex Align="center" Gap="2">
                            <Flex Align="center" Justify="center" Class="h-8 w-8 rounded-md bg-accent/40 text-primary">
                                <DynamicIcon Name="PenLine" Class="h-4 w-4" />
                            </Flex>
                            <Chip Class="font-mono text-xs">29 KB</Chip>
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">Rich Text Editor</Heading>
                        <Lumeo.Text Size="xs" Weight="medium" Color="muted" Class="font-mono">Lumeo.Editor</Lumeo.Text>
                        <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                            TipTap JS lazy-loaded at component mount time. The DLL
                            is only 26 KB — the heavy JS only streams when the editor renders.
                        </Lumeo.Text>
                    </Stack>
                </BlurFade>
            </BentoTile>
        </Bento>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         7. WHY BROTLI, NOT .nupkg — accordion
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-6">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">Why brotli, not .nupkg?</Heading>
                <Lumeo.Text Size="sm" Color="muted">
                    NuGet shows ~1.18 MB for the core .nupkg — here's what that actually means.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <BlurFade DelayMs="80" ForceHidden="true">
            <Accordion Class="border border-border/40 rounded-xl overflow-hidden divide-y divide-border/40">
                <AccordionItem Value="why-nupkg">
                    <AccordionTrigger Class="px-5">Why isn't .nupkg size the right number?</AccordionTrigger>
                    <AccordionContent Class="px-5">
                        <Stack Gap="3">
                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                The .nupkg bundles everything the package author ships: the compiled DLL, XML documentation,
                                static web assets (CSS + JS files), a Roslyn source generator, MSBuild integration props, and —
                                until rc.40 — a full shadcn-style CLI source registry (~700 KB of JSON). That registry now lives
                                on a CDN as of 3.0.0. Debug symbols ship separately as a
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">.snupkg</code>
                                symbol package, keeping the .nupkg leaner than older builds. None of the above reaches the
                                browser; it only exists so
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">lumeo add</code>
                                and the MCP server can resolve component source offline.
                            </Lumeo.Text>

                            <div class="rounded-lg border border-border/40 bg-muted/20 p-3">
                                <Stack Gap="1.5">
                                    <Flex Align="center" Justify="between">
                                        <Lumeo.Text Size="xs" Color="muted">.nupkg size before rc.40 (with bundled CLI registry)</Lumeo.Text>
                                        <Lumeo.Text As="span" Size="xs" Class="font-mono text-muted-foreground line-through">~1.35 MB</Lumeo.Text>
                                    </Flex>
                                    <Flex Align="center" Justify="between">
                                        <Lumeo.Text Size="xs" Weight="medium" Color="foreground">.nupkg size as of 4.2.0 (registry on CDN, PDB ships as .snupkg)</Lumeo.Text>
                                        <Lumeo.Text As="span" Size="xs" Class="font-mono font-semibold text-primary">~1.18 MB</Lumeo.Text>
                                    </Flex>
                                    <Flex Align="center" Justify="between">
                                        <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Brotli DLL actually shipped to browser</Lumeo.Text>
                                        <Lumeo.Text As="span" Size="xs" Class="font-mono font-semibold text-primary">672 KB</Lumeo.Text>
                                    </Flex>
                                </Stack>
                            </div>

                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                Even the 4.2.0 ~1.18 MB overstates the browser cost because XML docs (96 KB), static web
                                assets (components.js, lumeo-utilities.css, lumeo.css, and smaller JS files totalling ~127 KB),
                                the Roslyn source generator (14 KB), and MSBuild props (~4 KB) never reach the browser — they
                                only matter at development time. And PDB symbols no longer inflate the .nupkg at all: they now
                                ship separately as a
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">.snupkg</code>
                                symbol package. You can verify on
                                <Lumeo.Link Href="https://www.nuget.org/packages/Lumeo" Target="_blank" Class="underline">nuget.org/packages/Lumeo</Lumeo.Link>:
                                the "Download package" badge shows the current .nupkg size.
                            </Lumeo.Text>
                        </Stack>
                    </AccordionContent>
                </AccordionItem>

                <AccordionItem Value="wasm-linker">
                    <AccordionTrigger Class="px-5">What does WASM linker trimming do?</AccordionTrigger>
                    <AccordionContent Class="px-5">
                        <Stack Gap="3">
                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                When you publish a Blazor WebAssembly app with
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">dotnet publish -c Release</code>,
                                the .NET IL linker (trimmer) can remove types, methods, and fields that are unreachable from
                                your entry points — but only for assemblies that opt in with an
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">IsTrimmable</code>
                                marker. As of <strong>4.3.0</strong> (<Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo/issues/354" Target="_blank" Class="underline">#354</Lumeo.Link>),
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.dll</code>
                                sets that flag: a published app that uses one core component now ships a genuinely smaller
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.dll.br</code>
                                than one that uses many. The library's own reflection/dynamic-typing call sites (DataAnnotations
                                validation, the QueryBuilder JSON tree, <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">DynamicComponent</code>-based
                                overlays, JS-interop callback targets) are annotated
                                (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">[DynamicallyAccessedMembers]</code> /
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">[RequiresUnreferencedCode]</code>) or replaced with
                                source-generated JSON (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">JsonSerializerContext</code>),
                                so the shrink is real trimming, not a broken build — see "How was this measured?" below.
                            </Lumeo.Text>
                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                Trimming also still removes whole satellite assemblies you never reference: skip
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.Charts</code>,
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.DataGrid</code>,
                                or any other satellite package and the linker drops that assembly entirely — it costs you
                                0&nbsp;KB. "Install only what you use" is now accurate both at the package level and, for
                                the core, at the per-component level.
                            </Lumeo.Text>
                        </Stack>
                    </AccordionContent>
                </AccordionItem>

                <AccordionItem Value="how-measured">
                    <AccordionTrigger Class="px-5">How was this measured?</AccordionTrigger>
                    <AccordionContent Class="px-5">
                        <Stack Gap="3">
                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                <strong>Pre-#354 baseline (2026-07-11, 4.2.0):</strong> a reference Blazor WASM app
                                referencing every core component, and a second app referencing only
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">&lt;Button /&gt;</code>,
                                were each published with
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">dotnet publish -c Release</code>
                                against .NET 10. Both produced a byte-identical (SHA-256-verified)
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.dll.br</code>
                                of 687,723 bytes (671.6 KiB) — the core assembly wasn't trimmable yet, so usage didn't
                                matter.
                            </Lumeo.Text>
                            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                                <strong>Post-#354 measurement (2026-07-12, 4.3.0):</strong> the same
                                one-component (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">&lt;Button /&gt;</code>-only,
                                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">samples/CoreTrimDemo</code>
                                in the repo) reference app was rebuilt against the now-<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">IsTrimmable</code>
                                core and republished the same way. Its <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">Lumeo.dll.br</code>
                                measured 116,338 bytes (113.6 KiB) — an 83% reduction from the pre-#354 baseline for
                                this usage shape. A headless-browser load check confirmed the trimmed publish still
                                renders correctly (no console or page errors). An app using most or all 144 core
                                components will still approach the pre-#354 ceiling, since that shape genuinely
                                reaches most of the assembly — trimming reduces cost with usage, it doesn't create free
                                capacity. .NET runtime DLLs (~3–4&nbsp;MB brotli total) are excluded from every figure
                                above; they're shared across all Blazor apps and cached aggressively by the browser.
                            </Lumeo.Text>
                        </Stack>
                    </AccordionContent>
                </AccordionItem>
            </Accordion>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         8. HOT RELOAD — concrete architectural reasons
         ==================================================== -->
    <section>
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="mb-8">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="w-fit">Developer experience</Badge>
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">Hot Reload that actually works</Heading>
                <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                    Six architectural choices that keep <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">dotnet watch</code>
                    fast and reliable on Lumeo apps — the same choices most Blazor UI libs make differently and pay for in
                    slow rebuilds, stale styles, or forced full-restart loops.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Stack Gap="3">
            @{ int _h = 0; }
            @foreach (var fact in _hotReloadFacts)
            {
                var hrDelay = _h * 80;
                _h++;
                <BlurFade DelayMs="@hrDelay" ForceHidden="true">
                    <Card Class="p-5 hover:border-primary/40 transition-colors">
                        <Flex Align="start" Gap="4">
                            <Flex Align="center" Justify="center" Class="h-10 w-10 shrink-0 rounded-md bg-accent/40 text-primary">
                                <DynamicIcon Name="@fact.IconName" Class="h-5 w-5" />
                            </Flex>
                            <Stack Gap="2" Class="flex-1 min-w-0">
                                <Heading Level="3" Class="text-base font-semibold">@fact.Title</Heading>
                                <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">@fact.Body</Lumeo.Text>
                                @if (!string.IsNullOrEmpty(fact.OthersDo))
                                {
                                    <div class="mt-1 rounded-lg border border-destructive/20 bg-destructive/5 px-3 py-2">
                                        <Lumeo.Text As="div" Size="xs" Weight="medium" Color="foreground">What other libs do</Lumeo.Text>
                                        <Lumeo.Text As="div" Size="xs" Color="muted" Leading="relaxed" Class="mt-0.5">@fact.OthersDo</Lumeo.Text>
                                    </div>
                                }
                            </Stack>
                        </Flex>
                    </Card>
                </BlurFade>
            }
        </Stack>

        <BlurFade DelayMs="560" ForceHidden="true">
            <div class="mt-6 rounded-xl border border-primary/20 bg-primary/5 p-5">
                <Stack Gap="2">
                    <Lumeo.Text As="div" Size="sm" Weight="semibold" Color="foreground">The net effect</Lumeo.Text>
                    <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                        Edit a Razor component → DOM patches in ~120 ms. Edit
                        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">lumeo.css</code>
                        or a theme variable → CSS swaps in ~50 ms with zero C# rebuild. Edit a Lumeo source-of-truth
                        record (e.g. <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">DataGridColumn&lt;T&gt;</code>) →
                        delta build + DOM patch in under a second. No "Hot Reload not supported, restarting"
                        spinner on the inner loop.
                    </Lumeo.Text>
                </Stack>
            </div>
        </BlurFade>
    </section>

    <Separator Class="opacity-30" />

    <!-- ====================================================
         9. CTA FOOTER
         ==================================================== -->
    <section class="pb-10">
        <BlurFade DelayMs="0">
            <Stack Gap="5" Class="items-center text-center">
                <Heading Level="2" Class="text-2xl font-semibold tracking-tight">See it for yourself</Heading>
                <Lumeo.Text Size="sm" Color="muted" Class="max-w-sm">
                    Add Lumeo to a project, publish it, and measure. We believe the numbers.
                </Lumeo.Text>
                <Flex Gap="3" Wrap="true" Justify="center">
                    <Lumeo.Link Href="/docs/installation" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Lg" Class="rounded-lg">
                            Get Started
                            <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="https://github.com/mberger/lumeo/releases"
                                Class="inline-flex h-10 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background px-6 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <DynamicIcon Name="Github" Class="h-4 w-4" />
                        GitHub Releases
                    </Lumeo.Link>
                </Flex>
            </Stack>
        </BlurFade>
    </section>

</Stack>
</Container>

@code {
    private record PackageRow(string Name, string SizeLabel, int Percent, bool IsCore, string Note = "");
    private record NupkgAsset(string IconName, string Title, string Size, string Description);
    private record ComparisonRow(string Name, string Size, string Note, bool IsUs = false);
    private record HotReloadFact(string IconName, string Title, string Body, string? OthersDo = null);

    private readonly List<HotReloadFact> _hotReloadFacts =
    [
        new("Palette", "No Blazor CSS isolation",
            "Lumeo styles every component via Tailwind utility classes composed directly in markup. Tailwind v4 watch mode regenerates the single utility bundle in under 100 ms; the browser swaps it without losing state.",
            "Libraries that rely on Blazor's per-component .razor.css isolation generate a new scoped-class hash on every change, force the SDK to re-emit the static-web-assets manifest, and often invalidate browser caches mid-session."),

        new("Moon", "Theme is CSS variables — not a C# object",
            "Switching themes in Lumeo means swapping --color-primary, --color-background, etc. in lumeo.css. No C# rebuild needed. dotnet watch picks up the CSS change and the browser re-paints with the new tokens.",
            "MudThemeProvider passes a C# MudTheme record via CascadingValue. Editing colors requires recompiling C#, which triggers a delta-rebuild and re-render of every consuming component — Hot Reload often falls back to full restart."),

        new("Zap", "No source generators in the runtime hot path",
            "Lumeo.SourceGenerators only emits code for the opt-in [LumeoForm] attribute. Normal component edits never re-run a generator, so the dotnet watch inner loop is just Roslyn incremental compile + DOM patch.",
            "Libraries that wrap every component in a base-class source generator (or AOT-style codegen) re-run the generator on every keystroke — multi-second incremental builds, and Hot Reload often gives up entirely."),

        new("Aperture", "No reflection in the render path",
            "DataGridColumn<T>.GetValue is a compiled Expression<Func<TItem,object?>> cached per field (rc.44). Component parameters are strongly typed records. Hot Reload can swap method bodies without invalidating any cached type-handle metadata.",
            "Reflection-heavy libs (PropertyInfo.GetValue, Activator.CreateInstance in render) cache Type instances that don't refresh on Hot Reload — you get \"works after restart\" bugs because old reflection caches are still alive."),

        new("Puzzle", "CascadingValue composition, not inheritance",
            "Compound components like Select / SelectTrigger / SelectContent share state via a record passed through CascadingValue. Each Razor file is independent and Hot Reload swaps it in isolation.",
            "Libs with deep inheritance (MyButton : MudFormComponent<T,U> : MudComponentBase) force the runtime to rebuild the whole class table when a base changes. Hot Reload prints \"unable to apply edits\" and you lose state."),

        new("Wind", "Razor SDK + Tailwind watch — one CSS bundle",
            "lumeo.css + lumeo-utilities.css are two files generated by Tailwind from your source. dotnet watch + npm run watch:css run in parallel; CSS swaps don't go through Blazor at all. No virtual-DOM diff for visual-only changes.",
            "CSS-in-JS libs (or libs shipping a JS theme runtime) need to re-execute JS to recompute styles on every component touch — slower, and sometimes blocked by Blazor's circuit lifecycle."),
    ];

    private readonly List<PackageRow> _packages =
