@page "/components/hero"

<PageTitle>Hero — Lumeo</PageTitle>

<PageHeader Title="Hero" Description="A landing-page hero band with a centered, max-width content rail: optional eyebrow, title, subtitle, actions, and a side media slot. Part of the Splash Kit." />

<InstallUsage Component="Hero" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>The opening band of a marketing or landing page</li>
        <li>Product announcement headers with a primary call to action</li>
        <li>Split layouts pairing a headline with an illustration or screenshot</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Hero" Code="@_basicCode">
        <Hero Title="Build faster with Lumeo"
              Subtitle="A complete Blazor component library with theming, accessibility, and density built in.">
            <Actions>
                <Button>Get started</Button>
                <Button Variant="Button.ButtonVariant.Outline">View components</Button>
            </Actions>
        </Hero>
    </ComponentDemo>

    <ComponentDemo Title="With Eyebrow" Code="@_eyebrowCode">
        <Hero Title="Version 3.5 is here"
              Subtitle="Marketing blocks, density scopes, and a smaller bundle.">
            <Eyebrow>
                <Badge Variant="Badge.BadgeVariant.Secondary">New</Badge>
            </Eyebrow>
            <Actions>
                <Button>Read the changelog</Button>
            </Actions>
        </Hero>
    </ComponentDemo>

    <ComponentDemo Title="Centered Alignment" Code="@_centeredCode">
        <Hero Alignment="Hero.HeroAlignment.Center"
              Title="Everything you need to ship"
              Subtitle="Forms, overlays, data display, charts, and motion — all in one package.">
            <Actions>
                <Button>Install</Button>
                <Button Variant="Button.ButtonVariant.Ghost">Docs</Button>
            </Actions>
        </Hero>
    </ComponentDemo>

    <ComponentDemo Title="End Alignment">
        <Hero Alignment="Hero.HeroAlignment.End"
              Title="Right-aligned hero"
              Subtitle="Content, actions, and title all align to the end of the rail.">
            <Actions>
                <Button>Get started</Button>
                <Button Variant="Button.ButtonVariant.Outline">Learn more</Button>
            </Actions>
        </Hero>
    </ComponentDemo>

    <ComponentDemo Title="With Media" Code="@_mediaCode">
        <Hero Title="See it in action"
              Subtitle="A two-column layout that collapses to a single column on small screens.">
            <Actions>
                <Button>Try the playground</Button>
            </Actions>
            <Media>
                <div class="aspect-video w-full rounded-xl border border-border/40 bg-muted/40 flex items-center justify-center text-muted-foreground">
                    <SvgGlyph Svg="@(Lucide.Image)" class="h-10 w-10" />
                </div>
            </Media>
        </Hero>
    </ComponentDemo>

    <ComponentDemo Title="Custom Title Slot" Code="@_slotCode">
        <Hero Alignment="Hero.HeroAlignment.Center">
            <TitleSlot>
                <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-foreground">
                    Ship with <span class="text-primary">confidence</span>
                </h1>
            </TitleSlot>
            <SubtitleSlot>
                <p class="mt-4 text-lg text-muted-foreground max-w-2xl">
                    Use TitleSlot and SubtitleSlot for full control over markup.
                </p>
            </SubtitleSlot>
            <Actions>
                <Button>Get started</Button>
            </Actions>
        </Hero>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">Hero</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="mb-3">
                Setting Media switches the band to a two-column grid, with the text and media columns collapsing to a single column under the <code class="text-xs font-mono">lg:</code> breakpoint.
            </Lumeo.Text>
            <PropsTable Slug="hero" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/feature-grid" class="text-primary hover:underline">Feature Grid</a> — Pairs with Hero for the feature section of a landing page</li>
        <li><a href="/components/cta-section" class="text-primary hover:underline">CTA Section</a> — Closing call-to-action band</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — Used inside the Actions slot</li>
    </ul>
</div>

