@page "/docs/services/keyboard-shortcuts"
@namespace Lumeo.Docs.Pages.Docs.Services

@using Lumeo.Services
@implements IAsyncDisposable
@inject KeyboardShortcutService Shortcuts

<PageTitle>Keyboard Shortcuts — Lumeo</PageTitle>

<PageHeader Title="Keyboard Shortcut Service" Description="Register global keyboard shortcuts from C# code with automatic cleanup." />

<Stack Gap="10">

    <!-- Quick Start -->
    <Stack>
        <Stack Gap="4">
            <Heading Level="2">Quick Start</Heading>
            <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
                The <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">KeyboardShortcutService</code> lets you register
                keyboard shortcuts that work globally across the page. Inject it, register shortcuts in
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OnAfterRenderAsync</code>, and dispose them when the component unmounts.
            </Lumeo.Text>
            <Stack Class="code-block rounded-lg border border-border/40 bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">@@implements IAsyncDisposable
@@inject KeyboardShortcutService Shortcuts

@@code {
    private IAsyncDisposable? _shortcut;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _shortcut = await Shortcuts.RegisterAsync("ctrl+k", async () =>
            {
                // Open search, show command palette, etc.
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_shortcut is not null) await _shortcut.DisposeAsync();
    }
}</Stack>
            <Alert ShowIcon="false">
                Always register shortcuts inside <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OnAfterRenderAsync(firstRender)</code>
                because JS interop is not available during server-side prerendering. The returned
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">IAsyncDisposable</code> handle automatically unregisters the shortcut when disposed.
            </Alert>
        </Stack>
    </Stack>

    <Separator Class="my-4" />

    <!-- Live Demo -->
    <Stack>
        <Stack Gap="4">
            <Heading Level="2">Live Demo</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                A keyboard shortcut is registered on this page right now. Try pressing the key combination below to see it in action.
            </Lumeo.Text>

            <Card Class="p-6">
                <Stack Gap="5">
                    <Flex Align="center" Gap="3">
                        <Lumeo.Text Size="sm" Color="muted">Press</Lumeo.Text>
                        <Flex Align="center" Gap="1">
                            <Kbd>Ctrl</Kbd>
                            <Lumeo.Text Size="xs" Color="muted">+</Lumeo.Text>
                            <Kbd>M</Kbd>
                        </Flex>
                        <Lumeo.Text Size="sm" Color="muted">to trigger the shortcut</Lumeo.Text>
                    </Flex>

                    <Separator Class="my-4" />

                    <Stack Class="grid grid-cols-2 gap-4">
                        <Stack Gap="1">
                            <Lumeo.Text Size="xs" Color="muted" Class="uppercase tracking-wide">Hit count</Lumeo.Text>
                            <Flex Align="center" Gap="2">
                                <Lumeo.Text As="span" Class="text-2xl font-bold text-foreground tabular-nums">@_hitCount</Lumeo.Text>
                                @if (_hitCount > 0)
                                {
                                    <Badge Variant="Badge.BadgeVariant.Secondary">active</Badge>
                                }
                            </Flex>
                        </Stack>
                        <Stack Gap="1">
                            <Lumeo.Text Size="xs" Color="muted" Class="uppercase tracking-wide">Last triggered</Lumeo.Text>
                            <Lumeo.Text Size="sm" Class="tabular-nums">
                                @if (_lastTriggered is not null)
                                {
                                    @_lastTriggered.Value.ToString("HH:mm:ss.fff")
                                }
                                else
                                {
                                    <Lumeo.Text As="span" Class="text-muted-foreground">Never</Lumeo.Text>
                                }
                            </Lumeo.Text>
                        </Stack>
                    </Stack>

                    @if (_hitCount > 0)
                    {
                        <Alert Variant="Alert.AlertVariant.Success">
                            Shortcut triggered! The handler ran and updated the UI via <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">StateHasChanged</code>.
                        </Alert>
                    }

                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="ResetDemo">Reset counter</Button>
                </Stack>
            </Card>

            <Lumeo.Text Size="xs" Color="muted">
                The code behind this demo registers <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">ctrl+m</code> in
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">OnAfterRenderAsync</code> and disposes it when you navigate away.
            </Lumeo.Text>

            <Stack Class="code-block rounded-lg border border-border/40 bg-muted px-4 py-3 font-mono text-sm text-foreground whitespace-pre">@@implements IAsyncDisposable
@@inject KeyboardShortcutService Shortcuts

&lt;Lumeo.Text&gt;Hit count: @@_hitCount&lt;/Lumeo.Text&gt;
&lt;Lumeo.Text&gt;Last triggered: @@_lastTriggered&lt;/Lumeo.Text&gt;

@@code {
    private IAsyncDisposable? _shortcut;
    private int _hitCount;
    private DateTime? _lastTriggered;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _shortcut = await Shortcuts.RegisterAsync("ctrl+m", async () =>
            {
                _hitCount++;
                _lastTriggered = DateTime.Now;
                await InvokeAsync(StateHasChanged);
            });
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_shortcut is not null) await _shortcut.DisposeAsync();
    }
}</Stack>
        </Stack>
    </Stack>

