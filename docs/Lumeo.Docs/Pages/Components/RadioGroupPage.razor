@page "/components/radio-group"

<PageTitle>Radio Group — Lumeo</PageTitle>

<PageHeader Title="Radio Group" Description="A set of mutually exclusive radio buttons for single-option selection." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <RadioGroup @bind-Value="_selected">
                <Flex Gap="2" Align="center">
                    <RadioGroupItem Value="default" />
                    <Label>Default</Label>
                </Flex>
                <Flex Gap="2" Align="center">
                    <RadioGroupItem Value="comfortable" />
                    <Label>Comfortable</Label>
                </Flex>
                <Flex Gap="2" Align="center">
                    <RadioGroupItem Value="compact" />
                    <Label>Compact</Label>
                </Flex>
            </RadioGroup>
            @if (!string.IsNullOrEmpty(_selected))
            {
                <Lumeo.Text Size="sm" Color="muted" Class="mt-4">Selected: @_selected</Lumeo.Text>
            }
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Pricing Plan" Code="@_planCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <RadioGroup @bind-Value="_plan" Class="grid grid-cols-3 gap-2">
                @foreach (var p in new[] { ("free", "Free", "$0"), ("pro", "Pro", "$15"), ("enterprise", "Team", "$49") })
                {
                    var planVal = p.Item1;
                    <label class="@($"flex flex-col items-center justify-center rounded-md border p-3 cursor-pointer transition-colors {(_plan == planVal ? "border-primary bg-primary/5" : "border-muted")}")">
                        <RadioGroupItem Value="@planVal" Class="sr-only" />
                        <Lumeo.Text As="span" Size="sm" Weight="semibold" Color="foreground">@p.Item2</Lumeo.Text>
                        <Lumeo.Text As="span" Size="xs" Color="muted">@p.Item3/mo</Lumeo.Text>
                    </label>
                }
            </RadioGroup>
            <Lumeo.Text Size="sm" Color="muted" Class="mt-3">Selected plan: @(_plan ?? "none")</Lumeo.Text>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Form Field" Code="@_formCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <FormField Name="plan">
                <FormItem>
                    <FormLabel>Notification preference</FormLabel>
                    <RadioGroup @bind-Value="_notification">
                        <Flex Gap="2" Align="center">
                            <RadioGroupItem Value="all" />
                            <Label>All notifications</Label>
                        </Flex>
                        <Flex Gap="2" Align="center">
                            <RadioGroupItem Value="mentions" />
                            <Label>Mentions only</Label>
                        </Flex>
                        <Flex Gap="2" Align="center">
                            <RadioGroupItem Value="none" />
                            <Label>None</Label>
                        </Flex>
                    </RadioGroup>
                    <FormDescription>Choose how you want to be notified.</FormDescription>
                </FormItem>
            </FormField>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">RadioGroup</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Currently selected value. Use with @@bind-Value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the selected value changes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack Gap="3">
            <Heading Level="3">RadioGroupItem</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">The value this radio item represents. Required.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Disables the radio item.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack Gap="3">
            <Heading Level="3">RadioGroupCard</Heading>
            <Stack Class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">The value this card represents. Required. Renders as a selectable card-style radio option.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string? _selected = "default";
    private string? _notification = "all";
    private string? _plan = "pro";

    private string _defaultCode = @"<RadioGroup @bind-Value=""_selected"">
    <Flex Gap=""2"" Align=""center"">
        <RadioGroupItem Value=""default"" />
        <Label>Default</Label>
    </Flex>
    <Flex Gap=""2"" Align=""center"">
        <RadioGroupItem Value=""comfortable"" />
        <Label>Comfortable</Label>
    </Flex>
    <Flex Gap=""2"" Align=""center"">
        <RadioGroupItem Value=""compact"" />
        <Label>Compact</Label>
    </Flex>
</RadioGroup>";

    private string _planCode = @"<RadioGroup @bind-Value=""_plan"" Class=""grid grid-cols-3 gap-2"">
    @foreach (var p in new[] { (""free"", ""Free"", ""$0""), (""pro"", ""Pro"", ""$15""), (""team"", ""Team"", ""$49"") })
    {
        <label class=""@($""flex flex-col items-center rounded-md border p-3 cursor-pointer {(_plan == p.Item1 ? \""border-primary\"" : \""border-muted\"")}"")>
            <RadioGroupItem Value=""@p.Item1"" Class=""sr-only"" />
            <Lumeo.Text As=""span"" Size=""sm"" Weight=""semibold"">@p.Item2</Lumeo.Text>
            <Lumeo.Text As=""span"" Size=""xs"" Color=""muted"">@p.Item3/mo</Lumeo.Text>
        </label>
    }
</RadioGroup>";

    private string _formCode = @"<FormField Name=""plan"">
    <FormItem>
        <FormLabel>Notification preference</FormLabel>
        <RadioGroup @bind-Value=""_notification"">
            <Flex Gap=""2"" Align=""center"">
                <RadioGroupItem Value=""all"" />
                <Label>All notifications</Label>
            </Flex>
            <Flex Gap=""2"" Align=""center"">
                <RadioGroupItem Value=""mentions"" />
                <Label>Mentions only</Label>
            </Flex>
        </RadioGroup>
        <FormDescription>Choose how you want to be notified.</FormDescription>
    </FormItem>
</FormField>";
}
