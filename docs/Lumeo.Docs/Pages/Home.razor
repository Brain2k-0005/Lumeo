                    <Lumeo.Link Href="https://www.nuget.org/packages/Lumeo" Class="text-sm text-muted-foreground hover:text-foreground no-underline">NuGet</Lumeo.Link>
                    <Lumeo.Link Href="docs/contributing" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Contributing</Lumeo.Link>
