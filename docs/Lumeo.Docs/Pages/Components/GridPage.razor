@page "/components/grid"

<PageTitle>Grid — Lumeo</PageTitle>

<PageHeader Title="Grid" Description="A CSS grid layout component for creating multi-column layouts with consistent spacing." />

<Stack Gap="8">
    <ComponentDemo Title="Basic 3-Column" Code="@_basicCode">
        <Grid Columns="3" Gap="4" Class="w-full">
            @for (var i = 1; i <= 6; i++)
            {
                <div class="h-20 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">@i</div>
            }
        </Grid>
    </ComponentDemo>

    <ComponentDemo Title="Responsive Columns" Code="@_responsiveCode">
        <Grid Columns="2" Gap="4" Class="w-full md:grid-cols-4">
            @for (var i = 1; i <= 8; i++)
            {
                <div class="h-16 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">@i</div>
            }
        </Grid>
    </ComponentDemo>

    <ComponentDemo Title="Different Gaps" Code="@_gapCode">
        <Grid Columns="3" RowGap="6" ColGap="2" Class="w-full">
            @for (var i = 1; i <= 9; i++)
            {
                <div class="h-16 rounded-md bg-primary/20 flex items-center justify-center text-sm text-primary">@i</div>
            }
        </Grid>
    </ComponentDemo>

    <!-- API Reference -->
    <div>
        <Heading Level="2" Class="mb-4">API Reference</Heading>
        <Table>
            <TableHeader>
                <TableRow>
                    <TableHead>Prop</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Default</TableHead>
                    <TableHead>Description</TableHead>
                </TableRow>
            </TableHeader>
            <TableBody>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Columns</TableCell>
                    <TableCell Class="font-mono text-xs">int</TableCell>
                    <TableCell Class="font-mono text-xs">1</TableCell>
                    <TableCell>Number of grid columns.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">Gap</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">"4"</TableCell>
                    <TableCell>Uniform gap between rows and columns.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">RowGap</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Gap between rows only. Maps to gap-y-{value}.</TableCell>
                </TableRow>
                <TableRow>
                    <TableCell Class="font-mono text-xs">ColGap</TableCell>
                    <TableCell Class="font-mono text-xs">string?</TableCell>
                    <TableCell Class="font-mono text-xs">null</TableCell>
                    <TableCell>Gap between columns only. Maps to gap-x-{value}.</TableCell>
                </TableRow>
            </TableBody>
        </Table>
    </div>
</Stack>

@code {
    private string _basicCode = @"<Grid Columns=""3"" Gap=""4"">
    <div>1</div>
    <div>2</div>
    <div>3</div>
    <div>4</div>
    <div>5</div>
    <div>6</div>
</Grid>";

    private string _responsiveCode = @"<Grid Columns=""2"" Gap=""4"" Class=""md:grid-cols-4"">
    <div>1</div>
    <div>2</div>
    <!-- ... -->
</Grid>";

    private string _gapCode = @"<Grid Columns=""3"" RowGap=""6"" ColGap=""2"">
    <div>1</div>
    <div>2</div>
    <!-- ... -->
</Grid>";
}
