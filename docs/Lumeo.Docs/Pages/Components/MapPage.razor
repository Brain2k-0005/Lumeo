    protected override async Task OnInitializedAsync()
    {
        await LoadRoutesAsync();
    }

    private async Task LoadRoutesAsync()
    {
        // Amsterdam (52.3676, 4.9041) → Rotterdam (51.9244, 4.4777)
        const string osrmUrl = "https://router.project-osrm.org/route/v1/driving/4.9041,52.3676;4.4777,51.9244?overview=full&geometries=geojson&alternatives=true";
        try
        {
            var response = await Http.GetFromJsonAsync<OsrmResponse>(osrmUrl);
            if (response?.Routes is { Length: > 0 })
            {
                _routes = response.Routes.Select((r, i) =>
                {
                    var mins = (int)Math.Round(r.Duration / 60.0);
                    var km = Math.Round(r.Distance / 1000.0, 1);
                    var label = i == 0
                        ? $"{mins / 60}h {mins % 60}m · {km} km · Fastest"
                        : $"{mins / 60}h {mins % 60}m · {km} km";
                    var pts = r.Geometry.Coordinates
                        .Select(c => (Lat: c[1], Lon: c[0]))
                        .ToList();
                    return new RouteOption(label, pts);
                }).ToList();
                _routeNote = "Live data from OSRM";
            }
            else
            {
                LoadFallbackRoutes();
            }
        }
        catch
        {
            LoadFallbackRoutes();
        }
        _routesLoading = false;
    }

    private void LoadFallbackRoutes()
    {
        _routes =
        [
            new RouteOption("1h 10m · 80.2 km · Fastest", _fallbackRoute1),
            new RouteOption("1h 16m · 80.9 km", _fallbackRoute2),
        ];
        _routeNote = "Hardcoded fallback (OSRM CORS blocked in browser)";
    }

