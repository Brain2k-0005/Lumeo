@using Lumeo.Docs.Services
@inject RegistryService Registry

@* Per-component "what has been battle-tested" panel. Data comes from the registry's
   testCoverage block (generated by Lumeo.RegistryGen from the real test sources), so
   it can never drift from reality. Rendered on every component page via InstallUsage. *@
@if (_cov is { } cov)
{
    <div class="mt-6 rounded-[var(--radius-lg)] border border-border bg-muted/20 p-4">
        <div class="mb-3 flex items-center justify-between gap-3">
            <div class="flex items-center gap-2">
                <span class="text-sm font-semibold text-foreground">Tested</span>
                <span class="rounded-full px-2 py-0.5 text-xs font-medium @TierClass(cov.Tier)">@($"Tier {cov.Tier} · {cov.TierLabel}")</span>
            </div>
            <a href="test-coverage" class="text-xs text-muted-foreground underline hover:text-foreground">all components →</a>
        </div>

        <div class="flex flex-wrap gap-1.5">
            @foreach (var (label, on) in Capabilities(cov))
            {
                <span class="inline-flex items-center gap-1 rounded-md px-2 py-1 text-xs font-medium @(on ? "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400" : "bg-muted text-muted-foreground/50")">
                    <span aria-hidden="true">@(on ? "✓" : "—")</span> @label
                </span>
            }
        </div>

        <p class="mt-3 text-xs text-muted-foreground">
            @cov.Tests test@(cov.Tests == 1 ? "" : "s") across @cov.Files file@(cov.Files == 1 ? "" : "s")@ContractNote(cov.Contract). Auto-generated from the test suite.
        </p>
    </div>
}

@code {
    [Parameter] public string Component { get; set; } = "";

    private TestCoverageInfo? _cov;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var reg = await Registry.GetAsync();
            if (reg.Components.TryGetValue(Kebab(Component), out var c))
                _cov = c.TestCoverage;
        }
        catch
        {
            // Registry unavailable (e.g. offline prerender): render nothing.
        }
    }

    private static IEnumerable<(string Label, bool On)> Capabilities(TestCoverageInfo c) =>
        new[]
        {
            ("Render", c.Render),
            ("Behavior", c.Behavior),
            ("A11y", c.A11y),
            ("Keyboard", c.Keyboard),
            ("Scale", c.Scale),
            ("E2E", c.E2e),
        };

    private static string TierClass(int tier) => tier switch
    {
        4 => "bg-emerald-500/15 text-emerald-600 dark:text-emerald-400",
        3 => "bg-sky-500/15 text-sky-600 dark:text-sky-400",
        2 => "bg-amber-500/15 text-amber-600 dark:text-amber-400",
        1 => "bg-muted text-muted-foreground",
        _ => "bg-muted text-muted-foreground",
    };

    private static string ContractNote(string contract) => contract switch
    {
        "excluded" or "skipped" => " (no render-contract smoke — covered by its own tests)",
        _ => "",
    };

    private static string Kebab(string s)
    {
        var sb = new System.Text.StringBuilder(s.Length + 4);
        for (var i = 0; i < s.Length; i++)
        {
            var ch = s[i];
            if (char.IsUpper(ch))
            {
                var prevLower = i > 0 && !char.IsUpper(s[i - 1]);
                var nextLower = i + 1 < s.Length && char.IsLower(s[i + 1]);
                if (i > 0 && (prevLower || nextLower)) sb.Append('-');
                sb.Append(char.ToLowerInvariant(ch));
            }
            else
            {
                sb.Append(ch);
            }
        }
        return sb.ToString();
    }
}
