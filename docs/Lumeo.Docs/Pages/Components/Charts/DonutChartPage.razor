@page "/components/charts/donut"

<PageTitle>Donut Chart — Lumeo</PageTitle>

<PageHeader Title="Donut Chart" Description="A variant of the pie chart with a center cutout, which can display a summary value or label in the middle." />

<Stack Gap="8">
    <ComponentDemo Title="Donut with Center Label" Description="Display a KPI value in the center hole — total ARR, completion percentage, or any single summary figure." Code="@_basicCode">
        <Container>
            <DonutChart Data="_data" CenterLabel="$128K" InnerRadius="55%" OuterRadius="75%" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Simple Donut" Description="Without a center label the donut reads as a clean ring chart — the open center draws focus to the overall proportion." Code="@_simpleCode">
        <Container>
            <DonutChart Data="_data" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Thin Ring" Description="A narrow ring (high inner radius) emphasises the segmentation rather than the fill area — a modern dashboard style." Code="@_thinCode">
        <Container>
            <DonutChart Data="_data" InnerRadius="68%" OuterRadius="80%" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Support Ticket Status" Description="Visualise operational data like ticket resolution status. The center label shows the total count at a glance." Code="@_ticketsCode">
        <Container>
            <DonutChart Data="_ticketData" CenterLabel="1 247" InnerRadius="50%" OuterRadius="70%" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Custom Colors, No Labels" Description="Override the palette to match your brand and hide per-slice labels when the legend alone is sufficient." Code="@_customCode">
        <Container>
            <DonutChart Data="_data" Colors="_brandColors" ShowLabels="false" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Storage Breakdown" Description="Storage usage split across five categories. The center label shows total provisioned capacity for immediate context." Code="@_storageCode">
        <Container>
            <DonutChart Data="_storageData" CenterLabel="4 TB" InnerRadius="52%" OuterRadius="72%" />
        </Container>
    </ComponentDemo>
    <ComponentDemo Title="Loading state" Description="Shape-aware skeleton with reserved space for legend and axes — no layout shift when real data arrives.">
        <Container>
            <Stack Gap="4">
                <Stack Direction="Stack.StackDirection.Horizontal" Gap="4" Align="center" Wrap="true">
                    <Button OnClick="SimulateLoadingAsync" Disabled="@_loading">Simulate loading</Button>
                    <Stack Direction="Stack.StackDirection.Horizontal" Gap="2" Align="center">
                        <Switch @bind-Value="_keepLoading" Id="keep-loading" />
                        <label for="keep-loading" class="text-sm text-muted-foreground cursor-pointer">Hold skeleton open</label>
                    </Stack>
                </Stack>
                <DonutChart Data="_data" CenterLabel="$128K" InnerRadius="55%" OuterRadius="75%" IsLoading="@LoadingComputed" Height="320px" />
            </Stack>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">DonutChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;DonutChartData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">List of slices with Name and Value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">InnerRadius</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"50%"</td>
                            <td class="p-3 text-muted-foreground">Inner radius of the donut hole.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OuterRadius</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"70%"</td>
                            <td class="p-3 text-muted-foreground">Outer radius of the donut ring.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CenterLabel</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Text displayed in the center of the donut.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLabels</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows name and percentage labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Renders the legend below the chart.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color palette for slices.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsLoading</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, renders a shape-matched loading skeleton in place of the chart. Bind to your async fetch state.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLoadingSkeleton</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Set to false to opt out of the skeleton (chart area stays empty while IsLoading is true).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SkeletonKind</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">ChartSkeletonKind</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">(chart default)</td>
                            <td class="p-3 text-muted-foreground">Override the skeleton silhouette (Bars, Line, Area, Pie, Scatter, Grid, Generic).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SkeletonStyle</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">ChartSkeletonStyle</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Phantom</td>
                            <td class="p-3 text-muted-foreground">Phantom renders the real chart with placeholder data and morphs to real data via ECharts animation. Silhouette falls back to the legacy SVG skeleton overlay.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<DonutChart.DonutChartData> _data = new()
    {
        new() { Name = "Enterprise", Value = 62400 },
        new() { Name = "Pro",        Value = 41800 },
        new() { Name = "Starter",    Value = 18300 },
        new() { Name = "Free",       Value = 5500  }
    };

    private List<DonutChart.DonutChartData> _ticketData = new()
    {
        new() { Name = "Resolved",    Value = 843 },
        new() { Name = "In Progress", Value = 214 },
        new() { Name = "Open",        Value = 131 },
        new() { Name = "Escalated",   Value = 59  }
    };

    private List<DonutChart.DonutChartData> _storageData = new()
    {
        new() { Name = "Media Assets",  Value = 1480 },
        new() { Name = "Database",      Value = 892  },
        new() { Name = "Backups",       Value = 742  },
        new() { Name = "Logs",          Value = 534  },
        new() { Name = "Other",         Value = 352  }
    };

    private List<string> _brandColors = new() { "#6366f1", "#8b5cf6", "#a78bfa", "#c4b5fd" };

    private string _basicCode = @"<DonutChart Data=""_data"" CenterLabel=""$128K"" InnerRadius=""55%"" OuterRadius=""75%"" />";
    private string _simpleCode = @"<DonutChart Data=""_data"" />";
    private string _thinCode = @"<DonutChart Data=""_data"" InnerRadius=""68%"" OuterRadius=""80%"" />";
    private string _ticketsCode = @"<DonutChart Data=""_ticketData"" CenterLabel=""1 247"" InnerRadius=""50%"" OuterRadius=""70%"" />";
    private string _customCode = @"<DonutChart Data=""_data"" Colors=""_brandColors"" ShowLabels=""false"" />";
    private string _storageCode = @"<DonutChart Data=""_storageData"" CenterLabel=""4 TB"" InnerRadius=""52%"" OuterRadius=""72%"" />";

    private bool _loading;
    private bool _keepLoading;
    private bool LoadingComputed => _loading || _keepLoading;

    private async Task SimulateLoadingAsync()
    {
        _loading = true;
        await Task.Delay(2000);
        _loading = false;
    }
}
