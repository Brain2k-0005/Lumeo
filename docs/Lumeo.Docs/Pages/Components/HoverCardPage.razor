@page "/components/hover-card"

<PageTitle>Hover Card — Lumeo</PageTitle>

<PageHeader Title="Hover Card" Description="A card that appears when hovering over an element, showing additional information." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <HoverCard>
            <HoverCardTrigger>
                <Button Variant="Button.ButtonVariant.Link">@@blazor</Button>
            </HoverCardTrigger>
            <HoverCardContent>
                <Stack Gap="1">
                    <Heading Level="4" Size="sm" Weight="semibold">@@blazor</Heading>
                    <Lumeo.Text Size="sm" Color="muted">
                        A free and open-source web framework for building interactive web UIs using C#.
                    </Lumeo.Text>
                    <Lumeo.Text Size="xs" Color="muted" Class="pt-2">Joined December 2018</Lumeo.Text>
                </Stack>
            </HoverCardContent>
        </HoverCard>
    </ComponentDemo>

    <ComponentDemo Title="Alignment" Code="@_alignCode">
        <Flex Gap="8">
            <HoverCard>
                <HoverCardTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Start</Button>
                </HoverCardTrigger>
                <HoverCardContent Align="HoverCardContent.HoverCardAlign.Start">
                    <Lumeo.Text Size="sm">This hover card is aligned to the start.</Lumeo.Text>
                </HoverCardContent>
            </HoverCard>
            <HoverCard>
                <HoverCardTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Center</Button>
                </HoverCardTrigger>
                <HoverCardContent Align="HoverCardContent.HoverCardAlign.Center">
                    <Lumeo.Text Size="sm">This hover card is centered.</Lumeo.Text>
                </HoverCardContent>
            </HoverCard>
            <HoverCard>
                <HoverCardTrigger>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">End</Button>
                </HoverCardTrigger>
                <HoverCardContent Align="HoverCardContent.HoverCardAlign.End">
                    <Lumeo.Text Size="sm">This hover card is aligned to the end.</Lumeo.Text>
                </HoverCardContent>
            </HoverCard>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="User Profile" Code="@_profileCode">
        <Lumeo.Text Size="sm" Color="muted">
            Created by
            <HoverCard>
                <HoverCardTrigger>
                    <Lumeo.Text As="span" Class="font-medium text-foreground underline underline-offset-4 cursor-pointer">Jane Smith</Lumeo.Text>
                </HoverCardTrigger>
                <HoverCardContent>
                    <Stack Gap="2">
                        <Heading Level="4" Size="sm" Weight="semibold">Jane Smith</Heading>
                        <Lumeo.Text Size="sm" Color="muted">Senior Developer at Acme Inc.</Lumeo.Text>
                        <Flex Align="center" Gap="2">
                            <Lumeo.Text As="span" Size="xs" Color="muted">42 repositories</Lumeo.Text>
                            <Lumeo.Text As="span" Size="xs" Color="muted">128 followers</Lumeo.Text>
                        </Flex>
                    </Stack>
                </HoverCardContent>
            </HoverCard>
            on March 15, 2024.
        </Lumeo.Text>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">HoverCard</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsOpen</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Controls whether the hover card is visible.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OpenDelay</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">200</td>
                            <td class="p-3 text-muted-foreground">Delay in milliseconds before opening on hover.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">CloseDelay</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">300</td>
                            <td class="p-3 text-muted-foreground">Delay in milliseconds before closing on mouse leave.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">HoverCardContent</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Align</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">HoverCardAlign</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Center</td>
                            <td class="p-3 text-muted-foreground">Horizontal alignment. Values: Start, Center, End.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<HoverCard>
    <HoverCardTrigger>
        <Button Variant=""Button.ButtonVariant.Link"">@@blazor</Button>
    </HoverCardTrigger>
    <HoverCardContent>
        <Stack Gap=""1"">
            <Heading Level=""4"" Size=""sm"" Weight=""semibold"">@@blazor</Heading>
            <Lumeo.Text Size=""sm"" Color=""muted"">
                A free and open-source web framework.
            </Lumeo.Text>
            <Lumeo.Text As=""span"" Size=""xs"" Color=""muted"">Joined December 2018</Lumeo.Text>
        </Stack>
    </HoverCardContent>
</HoverCard>";

    private string _alignCode = @"<HoverCard>
    <HoverCardTrigger>
        <Button Variant=""Button.ButtonVariant.Outline"">Start</Button>
    </HoverCardTrigger>
    <HoverCardContent Align=""HoverCardContent.HoverCardAlign.Start"">
        <Lumeo.Text Size=""sm"">Aligned to start.</Lumeo.Text>
    </HoverCardContent>
</HoverCard>

<HoverCard>
    <HoverCardTrigger>
        <Button Variant=""Button.ButtonVariant.Outline"">End</Button>
    </HoverCardTrigger>
    <HoverCardContent Align=""HoverCardContent.HoverCardAlign.End"">
        <Lumeo.Text Size=""sm"">Aligned to end.</Lumeo.Text>
    </HoverCardContent>
</HoverCard>";

    private string _profileCode = @"<HoverCard>
    <HoverCardTrigger>
        <span class=""font-medium underline cursor-pointer"">Jane Smith</span>
    </HoverCardTrigger>
    <HoverCardContent>
        <Stack Gap=""2"">
            <Heading Level=""4"" Size=""sm"" Weight=""semibold"">Jane Smith</Heading>
            <Lumeo.Text Size=""sm"" Color=""muted"">Senior Developer at Acme Inc.</Lumeo.Text>
            <Flex Align=""center"" Gap=""2"">
                <Lumeo.Text As=""span"" Size=""xs"" Color=""muted"">42 repositories</Lumeo.Text>
                <Lumeo.Text As=""span"" Size=""xs"" Color=""muted"">128 followers</Lumeo.Text>
            </Flex>
        </Stack>
    </HoverCardContent>
</HoverCard>";
}
