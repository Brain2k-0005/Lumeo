@namespace Lumeo

<button type="button" role="switch" aria-checked="@Checked.ToString().ToLower()" class="@CssClass" @onclick="Toggle" disabled="@Disabled" @attributes="AdditionalAttributes">
    <span class="@ThumbClasses"></span>
</button>

@code {
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public SwitchSize Size { get; set; } = SwitchSize.Default;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string TrackSizeClasses => Size switch
    {
        SwitchSize.Sm => "h-4 w-7",
        SwitchSize.Lg => "h-6 w-11",
        _ => "h-5 w-9"
    };

    private string ThumbSizeClasses => Size switch
    {
        SwitchSize.Sm => "h-3 w-3",
        SwitchSize.Lg => "h-5 w-5",
        _ => "h-4 w-4"
    };

    private string ThumbTranslateClass => Size switch
    {
        SwitchSize.Sm => Checked ? "translate-x-3" : "translate-x-0",
        SwitchSize.Lg => Checked ? "translate-x-5" : "translate-x-0",
        _ => Checked ? "translate-x-4" : "translate-x-0"
    };

    private string CssClass => $"peer inline-flex {TrackSizeClasses} shrink-0 cursor-pointer items-center rounded-full border-2 border-transparent shadow-sm transition-colors focus-visible:outline-none disabled:cursor-not-allowed disabled:opacity-50 {(Checked ? "bg-primary" : "bg-input")} {Class}".Trim();

    private string ThumbClasses => $"pointer-events-none block {ThumbSizeClasses} rounded-full bg-background shadow-sm ring-0 transition-transform {ThumbTranslateClass}";

    private async Task Toggle()
    {
        if (!Disabled)
        {
            Checked = !Checked;
            await CheckedChanged.InvokeAsync(Checked);
        }
    }

    public enum SwitchSize { Sm, Default, Lg }
}
