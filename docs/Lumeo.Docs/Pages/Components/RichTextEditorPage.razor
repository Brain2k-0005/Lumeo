@page "/components/rich-text-editor"

@using Lumeo.Services
@inject ToastService Toast

<PageTitle>Rich Text Editor — Lumeo</PageTitle>

<PageHeader Title="Rich Text Editor"
            Description="A fully-featured WYSIWYG editor built on TipTap/ProseMirror. Supports mentions, slash commands, tables, code blocks, task lists, AI actions, image upload, and Word import — all wired through Blazor parameters." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Content authoring surfaces — blog posts, knowledge-base articles, product descriptions</li>
        <li>Long-form fields that benefit from headings, lists, quotes, links, and tables</li>
        <li>Comment or reply surfaces where users expect bold, italic, mentions, and emoji</li>
        <li>Document editors that need Word import, AI writing assistance, or collaborative slash commands</li>
        <li>Anywhere you currently use a Textarea but want structured HTML output</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">

    <!-- 1. Basic -->
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <RichTextEditor @bind-Value="_basicHtml" Placeholder="Start writing…" />
    </ComponentDemo>

    <!-- 2. Toolbar presets -->
    <ComponentDemo Title="Toolbar presets" Code="@_presetsCode">
        <Stack Gap="6">
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Minimal — Bold, Italic, Link</Lumeo.Text>
                <RichTextEditor @bind-Value="_minimalHtml" Toolbar="EditorToolbarPreset.Minimal" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Standard (default) — Headings, marks, lists, link, undo/redo</Lumeo.Text>
                <RichTextEditor @bind-Value="_standardHtml" Toolbar="EditorToolbarPreset.Standard" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Full — Standard + tables, image, code block, AI menu, Word import</Lumeo.Text>
                <RichTextEditor @bind-Value="_fullHtml" Toolbar="EditorToolbarPreset.Full" MinHeight="120" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">None — Toolbar hidden; bubble menu and keyboard shortcuts still active</Lumeo.Text>
                <RichTextEditor @bind-Value="_noneHtml" Toolbar="EditorToolbarPreset.None" MinHeight="100"
                                Placeholder="No toolbar — select text to see the bubble menu." />
            </div>
        </Stack>
    </ComponentDemo>

    <!-- 3. mentions -->
    <ComponentDemo Title="@("@-mentions")" Code="@_mentionsCode">
        <RichTextEditor @bind-Value="_mentionsHtml"
                        Triggers="_mentionTriggers"
                        Placeholder="@("Type @ to mention a team member…")" />
    </ComponentDemo>

    <!-- 4. Multiple triggers -->
    <ComponentDemo Title="@("Multiple triggers (@, #, $)")" Code="@_multiTriggerCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Type <code class="font-mono text-xs">@@</code> for users, <code class="font-mono text-xs">#</code> for tags, <code class="font-mono text-xs">$</code> for template variables.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_multiHtml" Triggers="_multiTriggers" />
        </Stack>
    </ComponentDemo>

    <!-- 5. Slash command -->
    <ComponentDemo Title="Slash command" Code="@_slashCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Type <code class="font-mono text-xs">/</code> on a new line to open the command palette. Built-in commands: Heading 1-3, Bullet list, Numbered list, Task list, Quote, Code block, Table, Image, Divider.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_slashHtml" EnableSlashCommand="true" />
        </Stack>
    </ComponentDemo>

    <!-- 6. Tables, code blocks, task lists -->
    <ComponentDemo Title="Tables, code, and task lists" Code="@_richBlocksCode">
        <RichTextEditor @bind-Value="_blocksHtml"
                        Toolbar="EditorToolbarPreset.Full"
                        EnableTables="true"
                        EnableCodeBlock="true"
                        EnableTaskList="true"
                        Placeholder="Use the Full toolbar or slash commands to insert a table, code block, or task list." />
    </ComponentDemo>

    <!-- 7. Image upload -->
    <ComponentDemo Title="Image upload" Code="@_imagesCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Click the image button in the toolbar (or type <code class="font-mono text-xs">/image</code>). The <code class="font-mono text-xs">OnImageRequested</code> callback returns the final URL; the demo returns a placeholder after a simulated upload delay.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_imageHtml"
                            Toolbar="EditorToolbarPreset.Full"
                            OnImageRequested="HandleImageUpload" />
        </Stack>
    </ComponentDemo>

    <!-- 8. AI actions -->
    <ComponentDemo Title="AI actions" Code="@_aiCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>Select some text in the editor below to see the bubble menu's AI button. Actions: Improve, Shorten, Expand, Fix Grammar, Summarize, Translate.</ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_aiHtml"
                            EnableAiActions="true"
                            OnAiAction="HandleAiAction"
                            Placeholder="Write something here, select it, and try an AI action…" />
        </Stack>
    </ComponentDemo>

    <!-- 9. Word (.docx) import -->
    <ComponentDemo Title="Word (.docx) import" Code="@_wordCode">
        <Stack Gap="2">
            <Alert Variant="Alert.AlertVariant.Info" ShowIcon="true">
                <ChildContent>
                    Setting <code class="font-mono text-xs">AllowWordImport="true"</code> adds an <em>Import .docx</em> button to the Full toolbar.
                    Wire <code class="font-mono text-xs">OnWordImportRequested</code> to your server endpoint that calls
                    <code class="font-mono text-xs">WordImporter.ToHtmlAsync</code> and then calls <code class="font-mono text-xs">editor.SetHtmlAsync(result.Html)</code>.
                    See the server-side snippet at the bottom of this page.
                </ChildContent>
            </Alert>
            <RichTextEditor @bind-Value="_wordHtml"
                            Toolbar="EditorToolbarPreset.Full"
                            AllowWordImport="true"
                            OnWordImportRequested="HandleWordImport" />
        </Stack>
    </ComponentDemo>

    <!-- 10. FormField validation -->
    <ComponentDemo Title="With FormField validation" Code="@_formFieldCode">
        <Stack Gap="3" Class="max-w-2xl">
            <FormField Label="Description"
                       Required="true"
                       HelpText="Markdown shortcuts work too — try '**bold**' or '# Heading'."
                       Error="@_formError">
                <RichTextEditor @bind-Value="_formHtml"
                                Required="true"
                                Invalid="@(_formError is not null)"
                                MinHeight="160" />
            </FormField>
            <Flex Gap="2">
                <Button OnClick="ValidateForm">Validate</Button>
                <Button Variant="Button.ButtonVariant.Ghost" OnClick="ResetForm">Reset</Button>
            </Flex>
        </Stack>
    </ComponentDemo>

    <!-- 11. Read-only & disabled -->
    <ComponentDemo Title="Read-only and disabled" Code="@_statesCode">
        <Stack Gap="4">
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Read-only — content is selectable but not editable</Lumeo.Text>
                <RichTextEditor Value="@_readOnlySample"
                                ReadOnly="true"
                                Toolbar="EditorToolbarPreset.None"
                                MinHeight="100" />
            </div>
            <div>
                <Lumeo.Text Size="sm" Color="muted" Class="mb-2 font-medium">Disabled — dimmed and non-interactive</Lumeo.Text>
                <RichTextEditor Value="@_disabledSample"
                                Disabled="true"
                                MinHeight="100" />
            </div>
        </Stack>
    </ComponentDemo>

    <!-- 12. Max-length & constrained height -->
    <ComponentDemo Title="Max length + bounded height" Code="@_constraintsCode">
        <RichTextEditor @bind-Value="_constrainedHtml"
                        MaxLength="500"
                        MinHeight="140"
                        MaxHeight="260"
                        HelperText="Plain-text character limit: 500. The editor scrolls internally when content overflows 260 px." />
    </ComponentDemo>

</Stack>

<!-- Keyboard shortcuts -->
<div class="mt-16">
    <Heading Id="keyboard" Level="2" Class="scroll-mt-20">Keyboard Shortcuts</Heading>
    <div class="overflow-x-auto mt-4">
        <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
            <table class="w-full min-w-[500px] text-sm">
                <thead>
                    <tr class="border-b border-border/40 bg-muted/40">
                        <th class="text-left p-3 font-medium text-foreground w-[220px]">Shortcut</th>
                        <th class="text-left p-3 font-medium text-foreground">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border/40">
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + B</td><td class="p-3 text-muted-foreground">Bold</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + I</td><td class="p-3 text-muted-foreground">Italic</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + U</td><td class="p-3 text-muted-foreground">Underline</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Shift + X</td><td class="p-3 text-muted-foreground">Strikethrough</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Z</td><td class="p-3 text-muted-foreground">Undo</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Shift + Z</td><td class="p-3 text-muted-foreground">Redo</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">Ctrl / ⌘ + Alt + 1 – 3</td><td class="p-3 text-muted-foreground">Heading 1 / 2 / 3</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">/ (on a new line)</td><td class="p-3 text-muted-foreground">Open slash-command palette</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">@@ # $</td><td class="p-3 text-muted-foreground">Open the corresponding trigger dropdown</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">**text**</td><td class="p-3 text-muted-foreground">Bold (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground"># text (space)</td><td class="p-3 text-muted-foreground">Heading 1 (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">- or * (space)</td><td class="p-3 text-muted-foreground">Bullet list (markdown shortcut)</td></tr>
                    <tr><td class="p-3 font-mono text-xs text-muted-foreground">[ ] (space)</td><td class="p-3 text-muted-foreground">Task list item (markdown shortcut)</td></tr>
                </tbody>
            </table>
        </Stack>
    </div>
</div>

<!-- API Reference -->
<Stack Gap="6" Class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Stack Gap="8" Class="mt-4">

        <!-- RichTextEditor parameters -->
        <Stack Gap="3">
            <Heading Level="3">RichTextEditor</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground w-[200px]">Property</th>
                            <th class="text-left p-3 font-medium text-foreground w-[230px]">Type</th>
                            <th class="text-left p-3 font-medium text-foreground w-[130px]">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr><td class="p-3 font-mono text-xs text-primary">Value</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Current HTML content. Two-way bindable via <code class="font-mono text-xs">@@bind-Value</code>.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ValueChanged</td><td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string?&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Fired on every document change. Carries the serialised HTML.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Placeholder</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 font-mono text-xs text-muted-foreground">"Start writing…"</td><td class="p-3 text-muted-foreground">Placeholder shown when the editor is empty.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Toolbar</td><td class="p-3 font-mono text-xs text-muted-foreground">EditorToolbarPreset</td><td class="p-3 font-mono text-xs text-muted-foreground">Standard</td><td class="p-3 text-muted-foreground">Toolbar density. <code class="font-mono text-xs">None</code> hides it; <code class="font-mono text-xs">Minimal</code> = Bold/Italic/Link; <code class="font-mono text-xs">Standard</code> = headings + marks + lists + undo/redo; <code class="font-mono text-xs">Full</code> adds tables, image, code block, AI menu, Word import.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">MinHeight</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">180</td><td class="p-3 text-muted-foreground">Minimum editor height in pixels.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">MaxHeight</td><td class="p-3 font-mono text-xs text-muted-foreground">int?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Optional maximum height in pixels. When set, the content area scrolls internally beyond this height.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Disabled</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Disables editing and dims the toolbar.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ReadOnly</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Prevents edits but keeps content selectable (no dimming).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Required</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Marks the field as required; sets <code class="font-mono text-xs">aria-required</code> on the root element.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Invalid</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Shows a destructive ring and sets <code class="font-mono text-xs">aria-invalid</code>. Also driven automatically when nested inside a <code class="font-mono text-xs">&lt;FormField&gt;</code> with an error.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">ErrorText</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Error message rendered below the editor when <code class="font-mono text-xs">Invalid</code> is true (only when not inside a FormField).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">HelperText</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Helper text rendered below the editor when there is no error (only when not inside a FormField).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Label</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Inline label rendered above the editor (only when not inside a FormField).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Name</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">HTML name attribute, useful for form identification.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Triggers</td><td class="p-3 font-mono text-xs text-muted-foreground">IReadOnlyList&lt;EditorTrigger&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">One or more trigger characters (e.g. <code class="font-mono text-xs">@@</code>, <code class="font-mono text-xs">#</code>, <code class="font-mono text-xs">$</code>). Each trigger provides an async <code class="font-mono text-xs">ItemSource</code> callback.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableSlashCommand</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables the built-in <code class="font-mono text-xs">/</code> command palette (Notion-style). Supply a custom <code class="font-mono text-xs">/</code> trigger to override the default commands.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableTables</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables the TipTap Table extension.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableCodeBlock</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables syntax-highlighted code blocks.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableImages</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables image upload/paste. Falls back to base64 when <code class="font-mono text-xs">OnImageRequested</code> is null.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableTaskList</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables checkable task-list items.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableMarkdownShortcuts</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Enables Markdown input shortcuts (e.g. <code class="font-mono text-xs">**bold**</code>, <code class="font-mono text-xs"># Heading</code>).</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableAiActions</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Shows an AI button in the bubble menu when text is selected. Requires <code class="font-mono text-xs">OnAiAction</code> to be wired.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableBubbleMenu</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Shows the floating bubble menu (Bold, Italic, Link, etc.) when text is selected.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">EnableDragHandle</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">true</td><td class="p-3 text-muted-foreground">Shows the drag handle on the left of each block node for drag-and-drop reordering.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">MaxLength</td><td class="p-3 font-mono text-xs text-muted-foreground">int?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Optional plain-text character limit enforced by the editor.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">AllowWordImport</td><td class="p-3 font-mono text-xs text-muted-foreground">bool</td><td class="p-3 font-mono text-xs text-muted-foreground">false</td><td class="p-3 text-muted-foreground">Adds an <em>Import .docx</em> button to the Full toolbar. Wire <code class="font-mono text-xs">OnWordImportRequested</code> to handle the upload.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">OnImageRequested</td><td class="p-3 font-mono text-xs text-muted-foreground">Func&lt;EditorImageRequest, ValueTask&lt;string?&gt;&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Async callback that receives file metadata and returns the final image URL. When null, images are inlined as base64.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">OnAiAction</td><td class="p-3 font-mono text-xs text-muted-foreground">Func&lt;string, string, ValueTask&lt;string?&gt;&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Async callback receiving <code class="font-mono text-xs">(actionId, selectedText)</code>; returns replacement HTML. Action IDs: <code class="font-mono text-xs">improve</code>, <code class="font-mono text-xs">shorten</code>, <code class="font-mono text-xs">expand</code>, <code class="font-mono text-xs">fix-grammar</code>, <code class="font-mono text-xs">summarize</code>, <code class="font-mono text-xs">translate</code>.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">OnWordImportRequested</td><td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;string&gt;</td><td class="p-3 font-mono text-xs text-muted-foreground">—</td><td class="p-3 text-muted-foreground">Fires when the toolbar's Import .docx button is clicked; the argument is the chosen filename. Consumer is expected to handle the upload and call <code class="font-mono text-xs">SetHtmlAsync</code>.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">Class</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Additional CSS classes applied to the root wrapper element.</td></tr>
                        <tr><td class="p-3 font-mono text-xs text-primary">AdditionalAttributes</td><td class="p-3 font-mono text-xs text-muted-foreground">Dictionary&lt;string, object&gt;?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Splatted onto the root element. Useful for <code class="font-mono text-xs">data-*</code> or ARIA attributes.</td></tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <!-- EditorTrigger -->
        <Stack Gap="3">
            <Heading Level="3">EditorTrigger</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[700px] text-sm">
                    <thead>
