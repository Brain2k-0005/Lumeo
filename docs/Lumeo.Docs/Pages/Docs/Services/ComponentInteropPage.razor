                            <td class="p-3 text-xs text-muted-foreground">Scroll</td>
                            <td class="p-3 text-muted-foreground">Prevent page scrolling.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">UnlockScroll()</td>
                            <td class="p-3 text-xs text-muted-foreground">Scroll</td>
