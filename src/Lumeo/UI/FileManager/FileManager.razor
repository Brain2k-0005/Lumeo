            builder.AddAttribute(34, "tabindex", idx == _activeItemIndex ? 0 : -1);
            builder.AddAttribute(35, "id", FileItemId(idx));
            builder.AddAttribute(36, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, _ => SelectRow(n, idx)));
            builder.AddAttribute(37, "ondblclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, _ => HandleNodeDoubleClick(n)));
            builder.AddAttribute(38, "oncontextmenu", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, e => OpenContextMenu(n, e)));
            builder.AddAttribute(39, "oncontextmenu:preventDefault", true);
            builder.AddAttribute(391, "onkeydown", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.KeyboardEventArgs>(this, e => HandleRowKeyDown(n, idx, e)));

            // Name cell
            builder.OpenElement(40, "td");
            builder.AddAttribute(41, "class", "p-2");
            builder.OpenElement(42, "div");
            builder.AddAttribute(43, "class", "flex items-center gap-2");

            // File icon
            builder.OpenComponent<Blazicon>(50);
            builder.AddAttribute(51, "Svg", GetNodeIcon(n));
            builder.AddAttribute(52, "class", "h-4 w-4 shrink-0 text-muted-foreground");
            builder.CloseComponent();

            // Inline rename or plain text
            if (_renamingNode?.Id == n.Id)
            {
                builder.OpenElement(60, "input");
                builder.AddAttribute(61, "type", "text");
                builder.AddAttribute(62, "class", "flex-1 px-1 py-0 text-sm border border-ring rounded bg-background focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring");
                builder.AddAttribute(63, "value", _renameValue);
                builder.AddAttribute(64, "oninput", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.ChangeEventArgs>(this, e => _renameValue = e.Value?.ToString() ?? ""));
                builder.AddAttribute(65, "onblur", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.FocusEventArgs>(this, _ => CommitRename()));
                builder.AddAttribute(66, "onkeydown", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.KeyboardEventArgs>(this, async e =>
                {
                    if (e.Key == "Enter") await CommitRename();
                    else if (e.Key == "Escape") CancelRename();
                }));
                // Keep typing (Space / Enter) inside the rename box from bubbling
                // to the row's keyboard handler.
                builder.AddAttribute(67, "onkeydown:stopPropagation", true);
                builder.AddAttribute(68, "onclick:stopPropagation", true);
                // Stable id so OnAfterRenderAsync can focus the field by id when a
                // rename begins (keyboard a11y — #325).
                builder.AddAttribute(69, "id", _renameInputId);
                builder.CloseElement();
            }
            else
            {
                builder.OpenElement(70, "span");
                builder.AddAttribute(71, "class", "truncate");
                builder.AddContent(72, n.Name);
                builder.CloseElement();
            }

            builder.CloseElement(); // inner div
            builder.CloseElement(); // td name

            // Size cell
            builder.OpenElement(80, "td");
            builder.AddAttribute(81, "class", "p-2 text-end text-muted-foreground whitespace-nowrap");
            builder.AddContent(82, n.IsFolder ? "—" : FormatSize(n.Size ?? 0));
            builder.CloseElement();

            // Modified cell
            builder.OpenElement(90, "td");
            builder.AddAttribute(91, "class", "p-2 text-end text-muted-foreground whitespace-nowrap");
            builder.AddContent(92, n.Modified.HasValue ? n.Modified.Value.ToString("yyyy-MM-dd HH:mm") : "—");
            builder.CloseElement();

            // Context menu cell
            builder.OpenElement(100, "td");
            builder.AddAttribute(101, "class", "p-2");
            // Dogfood the Lumeo <Tooltip> instead of the native title (the button keeps
            // its per-item aria-label as the accessible name; AsChild puts describedby
            // on the button, lazy content keeps the row cheap).
            builder.OpenComponent<Tooltip>(102);
            builder.AddAttribute(103, "ChildContent", (RenderFragment)(tip =>
            {
                tip.OpenComponent<TooltipTrigger>(0);
                tip.AddAttribute(1, "AsChild", true);
                tip.AddAttribute(2, "ChildContentSlot", (RenderFragment<Lumeo.TriggerSlot>)(slot => sb =>
                {
                    sb.OpenElement(0, "button");
                    sb.AddAttribute(1, "type", "button");
                    sb.AddAttribute(2, "class", "inline-flex items-center justify-center h-6 w-6 rounded opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity hover:bg-accent text-muted-foreground hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1");
                    sb.AddAttribute(3, "aria-label", L["FileManager.MoreActionsForName", n.Name]);
                    sb.AddAttribute(4, "onclick", Microsoft.AspNetCore.Components.EventCallback.Factory.Create<Microsoft.AspNetCore.Components.Web.MouseEventArgs>(this, e => OpenContextMenu(n, e)));
                    sb.AddAttribute(5, "onclick:stopPropagation", true);
                    // Enter on the focused actions button natively triggers its onclick
                    // (opens the menu); stop the keydown so it doesn't also bubble up to
                    // the row handler and open/navigate the file or folder.
                    sb.AddAttribute(6, "onkeydown:stopPropagation", true);
                    sb.AddMultipleAttributes(7, slot.Attributes);
                    sb.OpenComponent<Blazicon>(8);
                    sb.AddAttribute(9, "Svg", Lucide.EllipsisVertical);
                    sb.AddAttribute(10, "class", "h-3.5 w-3.5");
                    sb.CloseComponent();
                    sb.CloseElement();
                }));
                tip.CloseComponent();

                tip.OpenComponent<TooltipContent>(3);
                tip.AddAttribute(4, "ChildContent", (RenderFragment)(cb => cb.AddContent(0, L["FileManager.MoreActions"])));
                tip.CloseComponent();
            }));
            builder.CloseComponent();
            builder.CloseElement(); // td

            builder.CloseElement(); // tr
        }
        builder.CloseElement(); // tbody
        builder.CloseElement(); // table
    };

