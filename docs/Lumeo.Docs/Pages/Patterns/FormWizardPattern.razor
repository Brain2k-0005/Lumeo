                <Flex Align=""center"" Class=""flex-1"">
                    <Flex Class=""w-8 h-8 rounded-full items-center justify-center
                        @(_currentStep > step ? ""bg-primary text-primary-foreground"" :
                          _currentStep == step ? ""bg-primary text-primary-foreground"" :
                          ""bg-muted text-muted-foreground"")"">
                        @if (_currentStep > step)
                        {
                            <DynamicIcon Name=""Check"" Class=""h-4 w-4"" />
                        }
                        else { @step }
                    </Flex>
                    @if (step < 4)
                    {
                        <Stack Class=""flex-1 h-px @(_currentStep > step ? ""bg-primary"" : ""bg-border"") mx-2"" />
                    }
                </Flex>
            }
        </Flex>
    </CardHeader>
    <CardContent>
        @if (_currentStep == 1)
        {
            <!-- Step 1: Personal Info (First/Last name, Email, Phone) -->
        }
        @if (_currentStep == 2)
        {
            <!-- Step 2: Address (Street, City, State Select, Zip) -->
        }
        @if (_currentStep == 3)
        {
            <!-- Step 3: Notification Switches, Interest Checkboxes, Communication RadioGroup -->
        }
        @if (_currentStep == 4)
        {
            <!-- Step 4: Summary Card, confirm Checkbox, Submit Button -->
        }
    </CardContent>
    <CardFooter>
        <Flex Justify=""between"" Class=""w-full"">
            <Button Variant=""Button.ButtonVariant.Outline"" OnClick=""PreviousStep""
                    Disabled=""@(_currentStep == 1)"">
                <DynamicIcon Name=""ChevronLeft"" Class=""h-4 w-4"" /> Previous
            </Button>
            @if (_currentStep < 4)
            {
                <Button Variant=""Button.ButtonVariant.Default"" OnClick=""NextStep"">
                    Next <DynamicIcon Name=""ChevronRight"" Class=""h-4 w-4"" />
                </Button>
            }
            else
            {
                <Button Variant=""Button.ButtonVariant.Default"" OnClick=""Submit"" Disabled=""@(!_confirmed)"">
                    <DynamicIcon Name=""Check"" Class=""h-4 w-4"" /> Submit
                </Button>
            }
        </Flex>
