@page "/components/spacer"

<PageTitle>Spacer — Lumeo</PageTitle>

<PageHeader Title="Spacer" Description="A flexible spacer that expands to fill available space or renders at a fixed size." />

<InstallUsage Component="Spacer" />

<Stack Gap="8">
    <ComponentDemo Title="Flex Spacer" Code="@_flexCode">
        <Flex Align="center" Class="w-full p-3 rounded-lg border border-border/40">
            <Lumeo.Text Weight="semibold">Brand</Lumeo.Text>
            <Spacer />
            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Login</Button>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Fixed Size" Code="@_fixedCode">
        <Stack Direction="Lumeo.Orientation.Horizontal" Align="center">
            <Stack Class="h-10 w-10 rounded-full bg-primary/20"></Stack>
            <Spacer Size="4" />
            <Stack Gap="0">
                <Lumeo.Text Weight="medium" Size="sm">Jane Doe</Lumeo.Text>
                <Lumeo.Text Color="muted" Size="xs">jane@example.com</Lumeo.Text>
            </Stack>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Vertical Grow Spacer" Code="@_verticalCode">
        <Stack Direction="Lumeo.Orientation.Vertical" Class="h-48 w-56 p-3 rounded-lg border border-border/40">
            <Lumeo.Text Weight="semibold">Header</Lumeo.Text>
            <Spacer Orientation="Lumeo.Orientation.Vertical" />
            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" Class="w-full">Footer action</Button>
        </Stack>
    </ComponentDemo>

    <!-- API Reference -->
    <Stack Gap="6" Class="mt-12">
        <Heading Level="2">API Reference</Heading>
        <Stack Gap="8">
            <Stack>
                <Heading Level="3" Class="mb-3">Spacer</Heading>
                <PropsTable Slug="spacer" />
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _flexCode = @"<Flex Align=""center"">
    <Text Weight=""semibold"">Brand</Text>
    <Spacer />
    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Login</Button>
</Flex>";

    private string _verticalCode = @"<Stack Direction=""Lumeo.Orientation.Vertical"" Class=""h-48"">
    <Text Weight=""semibold"">Header</Text>
    <Spacer Orientation=""Lumeo.Orientation.Vertical"" />
    <Button Variant=""Button.ButtonVariant.Outline"" Size=""Button.ButtonSize.Sm"">Footer action</Button>
</Stack>";

    private string _fixedCode = @"<Stack Direction=""Lumeo.Orientation.Horizontal"" Align=""center"">
    <Avatar />
    <Spacer Size=""4"" />
    <Stack Gap=""0"">
        <Text Weight=""medium"" Size=""sm"">Jane Doe</Text>
        <Text Color=""muted"" Size=""xs"">jane@example.com</Text>
    </Stack>
</Stack>";
}
