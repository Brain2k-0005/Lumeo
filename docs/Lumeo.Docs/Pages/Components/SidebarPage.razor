@page "/components/sidebar"

<PageTitle>Sidebar — Lumeo</PageTitle>

<PageHeader Title="Sidebar" Description="A collapsible sidebar layout with groups, menus, header, and footer. Supports Push, Overlay, and Icon variants." />

<div class="space-y-8">
    <ComponentDemo Title="Push (Default)" Code="@_pushCode">
        <div class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_pushCollapsed">
                <SidebarComponent>
                    <SidebarHeader>
                        <div class="flex items-center gap-2 px-2">
                            <div class="h-6 w-6 rounded bg-primary"></div>
                            <span class="font-semibold text-sm text-foreground">Acme Inc</span>
                        </div>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Platform</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><span>Dashboard</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Users" Class="h-4 w-4" /></Icon>
                                        <Label><span>Team</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><span>Settings</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                    <SidebarFooter>
                        <div class="flex items-center gap-2 px-2">
                            <Avatar Src="" Fallback="CN" />
                            <span class="text-sm text-foreground">User</span>
                        </div>
                    </SidebarFooter>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <p class="text-sm text-muted-foreground mt-4">Sidebar pushes the main content. Fully hidden when collapsed.</p>
                </main>
            </SidebarProvider>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Overlay" Code="@_overlayCode">
        <div class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_overlayCollapsed" Variant="SidebarProvider.SidebarVariant.Overlay">
                <SidebarComponent>
                    <SidebarHeader>
                        <div class="flex items-center gap-2 px-2">
                            <div class="h-6 w-6 rounded bg-primary"></div>
                            <span class="font-semibold text-sm text-foreground">Workspace</span>
                        </div>
                    </SidebarHeader>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarGroupLabel>Navigation</SidebarGroupLabel>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><span>Home</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><span>Search</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><span>Notifications</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><span>Settings</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <p class="text-sm text-muted-foreground mt-4">Sidebar slides over the main content. Click the backdrop to dismiss.</p>
                </main>
            </SidebarProvider>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Icon" Code="@_iconCode">
        <div class="h-[400px] w-full rounded-lg border overflow-hidden">
            <SidebarProvider @bind-IsCollapsed="_iconCollapsed" Variant="SidebarProvider.SidebarVariant.Icon">
                <SidebarComponent>
                    <SidebarContent>
                        <SidebarGroup>
                            <SidebarMenu>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" IsActive="true" Tooltip="Home">
                                        <Icon><DynamicIcon Name="House" Class="h-4 w-4" /></Icon>
                                        <Label><span>Home</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Search">
                                        <Icon><DynamicIcon Name="Search" Class="h-4 w-4" /></Icon>
                                        <Label><span>Search</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Notifications">
                                        <Icon><DynamicIcon Name="Bell" Class="h-4 w-4" /></Icon>
                                        <Label><span>Notifications</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                                <SidebarMenuItem>
                                    <SidebarMenuButton Href="#" Tooltip="Settings">
                                        <Icon><DynamicIcon Name="Settings" Class="h-4 w-4" /></Icon>
                                        <Label><span>Settings</span></Label>
                                    </SidebarMenuButton>
                                </SidebarMenuItem>
                            </SidebarMenu>
                        </SidebarGroup>
                    </SidebarContent>
                </SidebarComponent>
                <main class="flex-1 p-6">
                    <SidebarTrigger />
                    <p class="text-sm text-muted-foreground mt-4">Compact icon-only sidebar. Toggle to expand with labels.</p>
                </main>
            </SidebarProvider>
        </div>
    </ComponentDemo>
</div>

