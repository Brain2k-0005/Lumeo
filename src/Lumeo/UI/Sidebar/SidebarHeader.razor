@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The content pinned to the top of the sidebar (e.g. a logo or workspace switcher).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Render the bottom divider. Default true. Set false for a
    /// seamless header that flows into the content without a rule — replaces
    /// the consumer-side <c>!border-b-0</c> override.</summary>
    [Parameter] public bool Bordered { get; set; } = true;

    /// <summary>Additional CSS classes merged onto the root <c>div</c> element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the root <c>div</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("flex flex-col gap-2", Cx.When(Bordered, "border-b border-border/40"), "p-4", Class);
}
