@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic NumberInput" Code="@_codeBasic">
    <NumberInput @bind-Value="_value1" />
</PatternCard>

<PatternCard Label="Min/Max with Precision" Code="@_codeMinMax">
    <Stack Gap="2">
        <NumberInput @bind-Value="_value2" Min="0" Max="100" Step="0.5" Precision="1" />
        <Lumeo.Text Size="sm" Color="muted" Align="center">Value: @_value2</Lumeo.Text>
    </Stack>
</PatternCard>
</Stack>

@code {
    private double? _value1 = 5;
    private double? _value2 = 10.0;

    private string _codeBasic = @"<NumberInput @bind-Value=""_value"" />";

    private string _codeMinMax = @"<NumberInput @bind-Value=""_value"" Min=""0"" Max=""100"" Step=""0.5"" Precision=""1"" />";
}
