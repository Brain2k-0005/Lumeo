@namespace Lumeo.Tests.Components.NavigationMenu

@* Test host for #60 — toggles the SECOND NavigationMenuItem (the one whose
   submenu the test opens) via a real parameter so the conditional is re-evaluated
   on re-render. The cascade is provided internally by NavigationMenu, so
   re-rendering this host never re-provides a cascading value through cut.Render.
   Validates that the Viewport (which gates purely on Context.ActiveItemId is not
   null) closes when the active item is removed, instead of staying stuck open. *@
<Lumeo.NavigationMenu>
    <Lumeo.NavigationMenuList>
        <Lumeo.NavigationMenuItem>
            <Lumeo.NavigationMenuTrigger>Products</Lumeo.NavigationMenuTrigger>
            <Lumeo.NavigationMenuContent>Products content</Lumeo.NavigationMenuContent>
        </Lumeo.NavigationMenuItem>
        @if (ShowSecond)
        {
            <Lumeo.NavigationMenuItem>
                <Lumeo.NavigationMenuTrigger>Services</Lumeo.NavigationMenuTrigger>
                <Lumeo.NavigationMenuContent>Services content</Lumeo.NavigationMenuContent>
            </Lumeo.NavigationMenuItem>
        }
    </Lumeo.NavigationMenuList>
    <Lumeo.NavigationMenuViewport>
        <span>viewport-open</span>
    </Lumeo.NavigationMenuViewport>
</Lumeo.NavigationMenu>

@code {
    [Parameter] public bool ShowSecond { get; set; } = true;
}
