@namespace Lumeo
@implements IDisposable

<p id="@Context.DescriptionId" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</p>

@code {
    [CascadingParameter] public Drawer.DrawerContext Context { get; set; } = default!;
    /// <summary>The description text, wired to the panel's <c>aria-describedby</c>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the description element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the description element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("text-sm text-muted-foreground", Class);

    protected override void OnInitialized()
        // Signal the root so DrawerContent wires aria-describedby to this <p>'s
        // id — without a registered description the IDREF would dangle.
        => Context.RegisterDescription();

    // Un-registers on removal — without this, removing the description while the
    // drawer stays mounted left aria-describedby pointing at an id no longer in the
    // DOM (Codex P2).
    public void Dispose() => Context.UnregisterDescription();
}
