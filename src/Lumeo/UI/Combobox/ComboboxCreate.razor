@namespace Lumeo
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@if (!string.IsNullOrWhiteSpace(Context.SearchText) && ShowCreate)
{
    <button type="button" class="@CssClass" @onclick="HandleCreate" @attributes="AdditionalAttributes">
        <SvgGlyph Svg="@(LumeoIcons.Plus)" class="h-3.5 w-3.5 me-2" />
        @string.Format(L["Combobox.Create"], Context.SearchText)
    </button>
}

@code {
    [CascadingParameter] public Combobox.ComboboxContext Context { get; set; } = default!;
    /// <summary>Invoked with the current search text when the create affordance is clicked.</summary>
    [Parameter] public EventCallback<string> OnCreate { get; set; }
    /// <summary>When <c>true</c> (default), the create affordance renders whenever there's non-empty search text. Set <c>false</c> to suppress it (e.g. once you've determined the term isn't creatable).</summary>
    [Parameter] public bool ShowCreate { get; set; } = true;
    /// <summary>Additional CSS classes merged onto the create button.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the create button.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("relative flex w-full cursor-default select-none items-center gap-2 rounded-sm py-1.5 px-2 text-sm outline-none hover:bg-accent hover:text-accent-foreground border-t border-border/40 mt-1 pt-2", Class);

    private async Task HandleCreate()
    {
        await OnCreate.InvokeAsync(Context.SearchText);
    }
}
