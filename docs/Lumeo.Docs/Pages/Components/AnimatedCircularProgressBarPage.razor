@page "/components/animated-circular-progress-bar"

<PageTitle>AnimatedCircularProgressBar — Lumeo</PageTitle>

<PageHeader Title="AnimatedCircularProgressBar"
            Description="SVG ring that animates stroke-dashoffset to a target percentage. Numeric label centered. Ideal for dashboards, onboarding, and skill meters." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Progress indicators for file uploads, form completion, or profile setup.</li>
        <li>Skill meters or proficiency gauges in portfolio and resume layouts.</li>
        <li>Dashboard KPI rings that animate in on first render.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Click to Animate (0 → target)" Code="@_interactiveCode">
        <div class="flex flex-col items-center gap-6 py-6">
            <div class="flex items-center justify-center gap-8">
                <div class="text-center">
                    <AnimatedCircularProgressBar Value="@_p1" Size="100" DurationMs="1200" />
                    <p class="text-xs text-muted-foreground mt-2">75%</p>
                </div>
                <div class="text-center">
                    <AnimatedCircularProgressBar Value="@_p2" Size="100" DurationMs="1600" />
                    <p class="text-xs text-muted-foreground mt-2">50%</p>
                </div>
                <div class="text-center">
                    <AnimatedCircularProgressBar Value="@_p3" Size="100" DurationMs="2000" />
                    <p class="text-xs text-muted-foreground mt-2">90%</p>
                </div>
            </div>
            <Button Variant="Button.ButtonVariant.Outline" OnClick="ReplayAnimation">
                Replay Animation
            </Button>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Preset Values" Code="@_basicCode">
        <div class="flex items-center justify-center gap-8 py-4">
            <AnimatedCircularProgressBar Value="25" />
            <AnimatedCircularProgressBar Value="50" />
            <AnimatedCircularProgressBar Value="75" />
            <AnimatedCircularProgressBar Value="100" />
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Custom Size & Stroke" Code="@_customCode">
        <div class="flex items-center justify-center py-4">
            <AnimatedCircularProgressBar Value="68" Size="160" StrokeWidth="12" DurationMs="1200" />
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">AnimatedCircularProgressBar</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Progress value 0–100.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Size</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">120</td>
                            <td class="p-3 text-muted-foreground">Overall size in pixels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">StrokeWidth</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">8</td>
                            <td class="p-3 text-muted-foreground">Ring stroke width in pixels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">DurationMs</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">800</td>
                            <td class="p-3 text-muted-foreground">CSS transition duration in milliseconds.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">LabelContent</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom label rendered inside the circle. Defaults to percentage text.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-4 p-3 rounded-lg border border-border/40 bg-muted/20 text-sm text-muted-foreground">
    <strong class="text-foreground">vs Progress (Circular):</strong>
    <a href="/components/progress" class="text-primary hover:underline mx-1">Progress</a> with
    <code class="text-xs bg-muted px-1 rounded">Shape=Circular</code> is the general-purpose ring indicator
    (supports indeterminate, striped, and multiple sizes). AnimatedCircularProgressBar is optimized for the
    "count-up" entrance animation with a configurable CSS transition duration — ideal for hero stats and KPI reveals.
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/progress" class="text-primary hover:underline">Progress</a> — General-purpose progress bar with circular, linear, and indeterminate modes.</li>
        <li><a href="/components/number-ticker" class="text-primary hover:underline">NumberTicker</a> — Animated number ticker with prefix, suffix, and thousands separator.</li>
    </ul>
</div>

@code {
    private double _p1 = 75;
    private double _p2 = 50;
    private double _p3 = 90;

    protected override void OnAfterRender(bool firstRender) { }

    private async Task ReplayAnimation()
    {
        // Reset to 0 then back to target so the CSS transition re-fires
        _p1 = _p2 = _p3 = 0;
        StateHasChanged();
        await Task.Delay(50);
        _p1 = 75; _p2 = 50; _p3 = 90;
        StateHasChanged();
    }

    private const string _interactiveCode = @"<AnimatedCircularProgressBar Value=""@_value"" Size=""100"" DurationMs=""1200"" />
<Button OnClick=""Replay"">Replay Animation</Button>

@code {
    double _value = 75;
    async Task Replay() { _value = 0; StateHasChanged(); await Task.Delay(50); _value = 75; }
}";

    private const string _basicCode = @"<AnimatedCircularProgressBar Value=""25"" />
<AnimatedCircularProgressBar Value=""50"" />
<AnimatedCircularProgressBar Value=""75"" />
<AnimatedCircularProgressBar Value=""100"" />";
    private const string _customCode = @"<AnimatedCircularProgressBar Value=""68"" Size=""160"" StrokeWidth=""12"" DurationMs=""1200"" />";
}
