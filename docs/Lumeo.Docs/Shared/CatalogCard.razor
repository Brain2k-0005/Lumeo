@namespace Lumeo.Docs.Shared
@using Lumeo.Docs.Services

<a href="components/@Component.Slug"
   class="group flex flex-col rounded-xl border border-border/40 bg-card overflow-hidden hover:border-primary/40 hover:shadow-sm transition-all">
    @if (!string.IsNullOrEmpty(Component.Thumbnail))
    {
        <div class="aspect-[16/9] w-full bg-muted/30 overflow-hidden">
            <img src="@Component.Thumbnail" alt="@Component.Name preview"
                 loading="lazy"
                 class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300" />
        </div>
    }
    else
    {
        <div class="catalog-card-icon-fallback aspect-[16/9] w-full bg-muted/30 flex items-center justify-center text-muted-foreground/40">
            <DynamicIcon Name="Box" Class="h-12 w-12" />
        </div>
    }
    <div class="p-4 space-y-1">
        <h3 class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors">
            @Component.Name
        </h3>
        <p class="text-xs text-muted-foreground line-clamp-2">
            @Component.Description
        </p>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public RegistryComponent Component { get; set; } = null!;
}
