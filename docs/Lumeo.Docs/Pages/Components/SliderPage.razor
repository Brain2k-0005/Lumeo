@page "/components/slider"

<PageTitle>Slider — Lumeo</PageTitle>

<PageHeader Title="Slider" Description="An input where the user selects a value from within a given range." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Slider @bind-Value="_value1" />
            <Lumeo.Text Size="sm" Color="muted">Value: @_value1</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom Range" Code="@_rangeCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Slider @bind-Value="_value2" Min="0" Max="1000" Step="50" />
            <Lumeo.Text Size="sm" Color="muted">Value: @_value2 / 1000</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Step Values" Code="@_stepCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Slider @bind-Value="_value3" Min="0" Max="10" Step="1" />
            <Lumeo.Text Size="sm" Color="muted">Value: @_value3</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Container MaxWidth="sm" Center="false" Padding="">
            <Slider Value="40" Disabled="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Volume Control Example" Code="@_volumeCode">
        <Stack Gap="2" Class="w-full max-w-sm">
            <Flex Gap="3" Align="center">
                <DynamicIcon Name="Volume1" Class="h-4 w-4 text-muted-foreground" />
                <Slider @bind-Value="_volume" Min="0" Max="100" Step="1" Class="flex-1" />
                <DynamicIcon Name="Volume2" Class="h-4 w-4 text-muted-foreground" />
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Align="center">Volume: @_volume%</Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Range Slider" Code="@_rangeSliderCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Slider IsRange="true" @bind-Value="_rangeStart" @bind-ValueEnd="_rangeEnd" Min="0" Max="100" />
            <Lumeo.Text Size="sm" Color="muted">Range: @_rangeStart — @_rangeEnd</Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">Slider</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Current value of the slider. Use with @@bind-Value for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the value changes.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Min</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Minimum value of the range.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Max</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">100</td>
                            <td class="p-3 text-muted-foreground">Maximum value of the range.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Step</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">1</td>
                            <td class="p-3 text-muted-foreground">Increment step size between values.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, prevents user interaction and dims the slider.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsRange</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Enables dual-thumb range mode.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueEnd</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">75</td>
                            <td class="p-3 text-muted-foreground">End value for range slider. Use with @@bind-ValueEnd for two-way binding.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueEndChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback when end value changes.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private double _value1 = 50;
    private double _value2 = 500;
    private double _value3 = 5;
    private double _volume = 75;

    private string _defaultCode = @"<Slider @bind-Value=""_value"" />
<Lumeo.Text Size=""sm"" Color=""muted"">Value: @_value</Lumeo.Text>

@code {
    private double _value = 50;
}";

    private string _rangeCode = @"<Slider @bind-Value=""_value"" Min=""0"" Max=""1000"" Step=""50"" />

@code {
    private double _value = 500;
}";

    private string _stepCode = @"<Slider @bind-Value=""_value"" Min=""0"" Max=""10"" Step=""1"" />

@code {
    private double _value = 5;
}";

    private string _disabledCode = @"<Slider Value=""40"" Disabled=""true"" />";

    private string _volumeCode = @"<Flex Gap=""3"" Align=""center"">
    <Blazicon Svg=""Lucide.Volume1"" class=""h-4 w-4"" />
    <Slider @bind-Value=""_volume"" Min=""0"" Max=""100"" Step=""1"" />
    <Blazicon Svg=""Lucide.Volume2"" class=""h-4 w-4"" />
</Flex>

@code {
    private double _volume = 75;
}";

    private double _rangeStart = 25;
    private double _rangeEnd = 75;

    private string _rangeSliderCode = @"<Slider IsRange=""true"" @bind-Value=""_rangeStart"" @bind-ValueEnd=""_rangeEnd"" Min=""0"" Max=""100"" />
<Lumeo.Text Size=""sm"" Color=""muted"">Range: @_rangeStart — @_rangeEnd</Lumeo.Text>

@code {
    private double _rangeStart = 25;
    private double _rangeEnd = 75;
}";
}
