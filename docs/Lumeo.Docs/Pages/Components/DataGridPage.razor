@page "/components/datagrid"

<PageTitle>DataGrid — Lumeo</PageTitle>

<PageHeader Title="DataGrid" Description="A powerful data grid with sorting, filtering, pagination, selection, inline editing, column pinning, resizable columns, row editing, layout persistence, context menus, and CSV/Excel/JSON export." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Complex data grids with advanced features like sorting, filtering, and grouping</li>
        <li>Enterprise table views with inline editing and cell-level validation</li>
        <li>Column pinning and resizable columns for wide data sets</li>
        <li>Scenarios requiring row selection, context menus, and data export (CSV/Excel/JSON)</li>
    </ul>
</div>

<Stack Gap="8">
    <ComponentDemo Title="Basic DataGrid" Description="A simple data grid with sortable columns and pagination." Code="@_basicCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Toolbar, Search & Filtering" Description="Enable the toolbar for global search, column visibility, and CSV export. Column filters appear as inline popovers." Code="@_toolbarCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true" ShowToolbar="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" Filterable="true" FilterType="DataGridFilterType.Number" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" Filterable="true" FilterType="DataGridFilterType.Date" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Multi-Select with Checkboxes" Description="Select multiple rows with checkboxes. The header checkbox toggles select all." Code="@_multiSelectCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  SelectionMode="DataGridSelectionMode.Multiple"
                  SelectedItemsChanged="@OnMultiSelectionChanged">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_multiSelectedCount > 0)
        {
            <Alert Class="mt-4">
                <AlertTitle>Selection</AlertTitle>
                <AlertDescription>@_multiSelectedCount row(s) selected.</AlertDescription>
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Single Row Selection" Description="Click a row to select it. Useful for master-detail views." Code="@_singleSelectCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  SelectionMode="DataGridSelectionMode.Single"
                  SelectedItemsChanged="@OnSelectionChanged">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
        </DataGrid>
        @if (_selectedEmployee is not null)
        {
            <Alert Class="mt-4">
                <AlertTitle>Selected</AlertTitle>
                <AlertDescription>@_selectedEmployee.Name — @_selectedEmployee.Department — @_selectedEmployee.Salary.ToString("C0")</AlertDescription>
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Striped, Bordered & Compact" Description="Visual variants for different density needs." Code="@_styledCode">
        <DataGrid TItem="Employee" Items="@_employees" Striped="true" Bordered="true" Compact="true" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Custom Cell Templates" Description="Use CellTemplate to render custom content like avatars, badges, and action buttons." Code="@_templateCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Employee" Field="Name" Sortable="true">
                <CellTemplate>
                    <Flex Align="center" Gap="2">
                        <Avatar Size="Avatar.AvatarSize.Sm">
                            <AvatarFallback>@context.Name[..2].ToUpper()</AvatarFallback>
                        </Avatar>
                        <Stack Gap="0">
                            <Lumeo.Text As="span" Weight="medium">@context.Name</Lumeo.Text>
                            <Lumeo.Text As="div" Size="xs" Color="muted">@context.Department</Lumeo.Text>
                        </Stack>
                    </Flex>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status">
                <CellTemplate>
                    <Badge Variant="@(context.Status == "Active" ? Badge.BadgeVariant.Default : Badge.BadgeVariant.Secondary)">
                        @context.Status
                    </Badge>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Actions" Field="Name">
                <CellTemplate>
                    <Flex Align="center" Gap="1">
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Pencil" Class="h-3.5 w-3.5" />
                        </Button>
                        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                            <DynamicIcon Name="Trash2" Class="h-3.5 w-3.5 text-destructive" />
                        </Button>
                    </Flex>
                </CellTemplate>
            </DataGridColumnDef>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Expandable Detail Rows" Description="Use DetailTemplate to show additional information when a row is expanded." Code="@_detailCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DetailTemplate>
                <Stack Gap="2" Class="p-4">
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Full Name:</Lumeo.Text> @context.Name</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Department:</Lumeo.Text> @context.Department</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Annual Salary:</Lumeo.Text> @context.Salary.ToString("C0")</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Start Date:</Lumeo.Text> @context.StartDate.ToString("MMMM dd, yyyy")</Lumeo.Text>
                    <Lumeo.Text Size="sm"><Lumeo.Text As="span" Weight="medium">Status:</Lumeo.Text> @context.Status</Lumeo.Text>
                </Stack>
            </DetailTemplate>
            <ChildContent>
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            </ChildContent>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Column Pinning" Description="Pin columns to the left or right edge so they stay visible while scrolling horizontally." Code="@_pinCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Pin="PinDirection.Left" Width="180" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Width="150" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Width="120" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Width="120" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" Width="150" />
            <DataGridColumnDef TItem="Employee" Title="Actions" Field="Name" Pin="PinDirection.Right" Width="100">
                <CellTemplate>
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">
                        <DynamicIcon Name="Ellipsis" Class="h-4 w-4" />
                    </Button>
                </CellTemplate>
            </DataGridColumnDef>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Resizable Columns" Description="Drag the column border to resize. All columns are resizable by default. Use MinWidth and MaxWidth to constrain sizing." Code="@_resizeCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Width="200" MinWidth="100" MaxWidth="400" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Width="150" MinWidth="80" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Width="120" MinWidth="80" MaxWidth="200" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Width="100" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Inline Cell Editing" Description="Click a cell to edit it inline. Press Enter to commit, Escape to cancel." Code="@_editCode">
        <DataGrid TItem="Employee" Items="@_editableEmployees" PageSize="5" ShowPagination="true"
                  EditMode="DataGridEditMode.Cell" OnCellEdit="@HandleCellEdit">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_lastEditInfo is not null)
        {
            <Alert Class="mt-4">
                <AlertTitle>Cell Edited</AlertTitle>
                <AlertDescription>@_lastEditInfo</AlertDescription>
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Row Editing" Description="Edit an entire row at once. Click the edit button to enter edit mode, then save or cancel." Code="@_rowEditCode">
        <DataGrid TItem="Employee" Items="@_rowEditEmployees" PageSize="5" ShowPagination="true"
                  EditMode="DataGridEditMode.Row" OnRowEdit="@HandleRowEdit">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
        @if (_lastRowEditInfo is not null)
        {
            <Alert Class="mt-4">
                <AlertTitle>Row Edited</AlertTitle>
                <AlertDescription>@_lastRowEditInfo</AlertDescription>
            </Alert>
        }
    </ComponentDemo>

    <ComponentDemo Title="Footer Aggregation" Description="Show computed summaries (Sum, Average, Count, Min, Max) in the table footer." Code="@_aggregateCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="20">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Aggregate="AggregateType.Count" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Aggregate="AggregateType.Average" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Column Reordering" Description="Drag column headers to reorder them. Enable with the Reorderable property on the grid." Code="@_reorderCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true" Reorderable="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Conditional Row Styling" Description="Apply dynamic CSS classes or inline styles to rows based on data. Useful for highlighting specific records." Code="@_rowStyleCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  RowClass="@(e => e.Status == "Inactive" ? "opacity-50" : "")"
                  RowStyle="@(e => e.Salary > 100000 ? "font-weight: 600;" : "")">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status">
                <CellTemplate>
                    <Badge Variant="@(context.Status == "Active" ? Badge.BadgeVariant.Default : Badge.BadgeVariant.Secondary)">
                        @context.Status
                    </Badge>
                </CellTemplate>
            </DataGridColumnDef>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Context Menu" Description="Right-click a row to open a custom context menu with actions." Code="@_contextMenuCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <RowContextMenu>
                <Stack Gap="0">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="w-full justify-start gap-2 px-2">
                        <DynamicIcon Name="Pencil" Class="h-3.5 w-3.5" />
                        Edit
                    </Button>
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="w-full justify-start gap-2 px-2">
                        <DynamicIcon Name="Copy" Class="h-3.5 w-3.5" />
                        Duplicate
                    </Button>
                    <Separator Class="my-1" />
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="w-full justify-start gap-2 px-2 text-destructive">
                        <DynamicIcon Name="Trash2" Class="h-3.5 w-3.5" />
                        Delete
                    </Button>
                </Stack>
            </RowContextMenu>
            <ChildContent>
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
                <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            </ChildContent>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Layout Persistence" Description="Save and restore column widths, order, visibility, sorts, and filters to localStorage. The layout survives page refreshes. Use the Layouts dropdown in the toolbar to save named layouts under Personal, Global, or System Default scopes." Code="@_layoutPersistenceCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  ShowToolbar="true" Reorderable="true"
                  EnableLayoutPersistence="true" LayoutStorageKey="demo-datagrid-layout">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" Width="200" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" Width="150" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Width="120" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Filterable="true" Width="100" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Named Layout Manager" Description="Pass GlobalLayouts to surface pre-built layouts in the Layouts dropdown. Users can also save their own Personal layouts which are stored in localStorage. The panel shows Personal / Global / System Default scopes." Code="@_namedLayoutCode">
        <Stack Gap="3">
            @if (_savedLayoutNotice is not null)
            {
                <Alert>
                    <AlertTitle>Layout Event</AlertTitle>
                    <AlertDescription>@_savedLayoutNotice</AlertDescription>
                </Alert>
            }
            <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                      ShowToolbar="true" Reorderable="true"
                      EnableLayoutPersistence="true" LayoutStorageKey="demo-named-layout"
                      GlobalLayouts="@_globalLayouts"
                      OnSaveNamedLayout="@(nl => { _savedLayoutNotice = $"Saved named layout: \"{nl.Name}\" (scope: {nl.Scope})"; StateHasChanged(); })"
                      OnDeleteNamedLayout="@(id => { _savedLayoutNotice = $"Deleted layout: {id}"; StateHasChanged(); })">
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" Width="200" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" Width="150" />
                <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Width="120" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Filterable="true" Width="100" />
            </DataGrid>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom Toolbar Content" Description="Add custom buttons and controls to the toolbar using the ToolbarContent slot." Code="@_toolbarContentCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true" ShowToolbar="true">
            <ToolbarContent>
                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" Class="gap-1.5">
                    <DynamicIcon Name="Plus" Class="h-3.5 w-3.5" />
                    Add Employee
                </Button>
            </ToolbarContent>
            <ChildContent>
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            </ChildContent>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Server-Side Mode" Description="For large datasets, use ServerMode to handle sorting, filtering, and pagination on the server. Sorting, filtering, search, and pagination all trigger OnServerRequest. Loading state and request cancellation are managed automatically." Code="@_serverModeCode">
        <DataGrid TItem="Employee" Items="@_serverItems"
                  ServerMode="true"
                  TotalCount="@_serverTotalCount"
                  PageSize="5"
                  ShowPagination="true"
                  ShowToolbar="true"
                  OnServerRequest="@LoadServerData">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Server-Side Error Handling" Description="Toggle the simulate error button to trigger a server failure. OnError receives the exception so you can display a message outside the grid." Code="@_errorHandlingCode">
        <Stack Gap="3">
            <Flex Gap="2" Align="center">
                <Button Variant="@(_simulateError ? Button.ButtonVariant.Destructive : Button.ButtonVariant.Outline)"
                        Size="Button.ButtonSize.Sm"
                        OnClick="@(() => { _simulateError = !_simulateError; _serverErrorDisplay = null; })">
                    @(_simulateError ? "Simulating failure — click to recover" : "Simulate server error")
                </Button>
            </Flex>
            <DataGrid TItem="Employee" Items="@_errorItems"
                      ServerMode="true"
                      TotalCount="@_errorTotalCount"
                      PageSize="5"
                      ShowPagination="true"
                      OnServerRequest="@LoadErrorData"
                      OnError="@(ex => _serverErrorDisplay = ex.Message)">
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
                <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
                <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            </DataGrid>
            @if (!string.IsNullOrEmpty(_serverErrorDisplay))
            {
                <Alert>
                    <AlertTitle>Server Error</AlertTitle>
                    <AlertDescription>@_serverErrorDisplay</AlertDescription>
                </Alert>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Multi-Sort" Description="Click multiple column headers to sort by multiple fields. The grid applies sorts in the order they were added. Click a column again to cycle through ascending, descending, and unsorted." Code="@_multiSortCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true">
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Fixed Height with Scroll" Description="Set a fixed height on the grid to enable vertical scrolling for long lists." Code="@_fixedHeightCode">
        <DataGrid TItem="Employee" Items="@_employees" Height="250px" ShowPagination="false">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Format="yyyy-MM-dd" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Loading State" Description="Show skeleton rows while data is loading." Code="@_loadingCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" IsLoading="true">
            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" />
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Empty State" Description="Custom content when the grid has no data." Code="@_emptyCode">
        <DataGrid TItem="Employee" Items="@(new List<Employee>())" PageSize="5">
            <EmptyContent>
                <Stack Gap="3" Align="center" Class="py-4">
                    <DynamicIcon Name="SearchX" Class="h-10 w-10 text-muted-foreground/40" />
                    <Lumeo.Text Size="sm" Color="muted">No employees found. Try adjusting your filters.</Lumeo.Text>
                </Stack>
            </EmptyContent>
            <ChildContent>
                <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" />
                <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" />
            </ChildContent>
        </DataGrid>
    </ComponentDemo>

    <ComponentDemo Title="Full-Featured DataGrid" Description="All features combined: toolbar, search, filtering, sorting, selection, column visibility, export, conditional styling, and aggregation." Code="@_fullCode">
        <DataGrid TItem="Employee" Items="@_employees" PageSize="5" ShowPagination="true"
                  ShowToolbar="true" SelectionMode="DataGridSelectionMode.Multiple"
                  Striped="true" Hoverable="true" Reorderable="true"
                  RowClass="@(e => e.Status == "Inactive" ? "opacity-50" : "")">
            <DataGridColumnDef TItem="Employee" Title="Employee" Field="Name" Sortable="true" Filterable="true" Pin="PinDirection.Left" Width="200">
                <CellTemplate>
                    <Flex Align="center" Gap="2">
                        <Avatar Size="Avatar.AvatarSize.Sm">
                            <AvatarFallback>@context.Name[..2].ToUpper()</AvatarFallback>
                        </Avatar>
                        <Lumeo.Text As="span" Weight="medium">@context.Name</Lumeo.Text>
                    </Flex>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Department" Field="Department" Sortable="true" Filterable="true" Width="140" />
            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Sortable="true" Filterable="true" FilterType="DataGridFilterType.Number" Format="C0" Width="120" Aggregate="AggregateType.Average" />
            <DataGridColumnDef TItem="Employee" Title="Status" Field="Status" Filterable="true" Width="100">
                <CellTemplate>
                    <Badge Variant="@(context.Status == "Active" ? Badge.BadgeVariant.Default : Badge.BadgeVariant.Secondary)">
                        @context.Status
                    </Badge>
                </CellTemplate>
            </DataGridColumnDef>
            <DataGridColumnDef TItem="Employee" Title="Start Date" Field="StartDate" Sortable="true" Format="yyyy-MM-dd" Width="130" />
        </DataGrid>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">DataGrid&lt;TItem&gt;</Heading>
            <Stack Class="overflow-x-auto rounded-lg border border-border/40">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/30">
