@page "/showcase"
@namespace Lumeo.Docs.Pages.Docs
@using System.Reflection
@using Microsoft.AspNetCore.Components

<PageTitle>Showcase — Lumeo</PageTitle>

<Container MaxWidth="3xl" Padding="0" Center="false">
<Stack Gap="10">

    <!-- Header -->
    <Stack Gap="4">
        <Heading Level="1" Size="3xl">Built with Lumeo</Heading>
        <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
            Honest entries only. Every project listed here is real and maintained by the Lumeo team.
            No invented logos, no fake testimonials.
        </Lumeo.Text>
    </Stack>

    <Separator Class="my-4" />

    <!-- Cards: items-start lets each card size to its own content (masonry-ish) instead
         of every card stretching to the tallest in its row, which left dead whitespace
         above the bottom-pinned CTAs. -->
    <div class="grid grid-cols-1 sm:grid-cols-2 items-start gap-6">

        <!-- Entry 1: This documentation site -->
        <Stack Gap="4" Class="rounded-xl border border-border/40 bg-card p-5">
            <Flex Align="center" Gap="2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
                    <DynamicIcon Name="BookOpen" Class="h-4 w-4" />
                </div>
                <Heading Level="3" Size="base">This documentation site</Heading>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                @_routeCount routes, every component live, the theme customiser, and the /icons gallery —
                this site is itself a Lumeo Blazor WASM application.
            </Lumeo.Text>
            <Lumeo.Text Size="xs" Color="muted">
                Proves: full-scale real-world usage, WASM delivery, dark/light theming.
            </Lumeo.Text>
            <Lumeo.Link Href="/" Class="mt-auto text-sm text-primary underline underline-offset-4 hover:text-foreground transition-colors">
                You're already here →
            </Lumeo.Link>
        </Stack>

        <!-- Entry 2: Northlight SaaS demo -->
        <Stack Gap="4" Class="rounded-xl border border-border/40 bg-card p-5">
            <Flex Align="center" Gap="2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
                    <DynamicIcon Name="Zap" Class="h-4 w-4" />
                </div>
                <Heading Level="3" Size="base">Northlight</Heading>
            </Flex>
            <Badge Variant="Badge.BadgeVariant.Secondary" Class="self-start">SaaS demo</Badge>
            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                Product-analytics SaaS shell: KPI dashboard with live charts, a drag-enabled
                Kanban board, a 640-row virtualized customers DataGrid, and settings forms
                with validation — ~28 Lumeo component families, zero custom CSS.
            </Lumeo.Text>
            <Lumeo.Text Size="xs" Color="muted">
                Proves: component breadth, app-shell composition (Sidebar + Command palette), form validation.
            </Lumeo.Text>
            <Lumeo.Link Href="/demos/saas" Class="mt-auto text-sm text-primary underline underline-offset-4 hover:text-foreground transition-colors">
                View demo →
            </Lumeo.Link>
        </Stack>

        <!-- Entry 3: Meridian Ops enterprise demo -->
        <Stack Gap="4" Class="rounded-xl border border-border/40 bg-card p-5">
            <Flex Align="center" Gap="2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary/10 text-primary shrink-0">
                    <DynamicIcon Name="Building2" Class="h-4 w-4" />
                </div>
                <Heading Level="3" Size="base">Meridian Ops</Heading>
            </Flex>
            <Badge Variant="Badge.BadgeVariant.Secondary" Class="self-start">Enterprise demo</Badge>
            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                High-density ops console: a virtualized DataGrid with column filters, bulk
                actions, aggregates and CSV/Excel export, a lazy-loaded Gantt schedule, an
                approvals workflow (Steps + Dialog), an audit timeline, and a form-heavy
                record editor.
            </Lumeo.Text>
            <Lumeo.Text Size="xs" Color="muted">
                Proves: data density, DataGrid + Export + Gantt satellites together, on-demand assembly loading.
            </Lumeo.Text>
            <Lumeo.Link Href="/demos/enterprise" Class="mt-auto text-sm text-primary underline underline-offset-4 hover:text-foreground transition-colors">
                View demo →
            </Lumeo.Link>
        </Stack>

        <!-- Your product here -->
        <Stack Gap="4" Class="rounded-xl border border-dashed border-border/60 bg-card/50 p-5">
            <Flex Align="center" Gap="2">
                <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-muted text-muted-foreground shrink-0">
                    <DynamicIcon Name="PlusCircle" Class="h-4 w-4" />
                </div>
                <Heading Level="3" Size="base" Class="text-muted-foreground">Your product here</Heading>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
                Built something with Lumeo? Open a GitHub issue to submit it for listing.
                Real, shipped products only — no mockups or unreleased demos.
            </Lumeo.Text>
            <a href="https://github.com/Brain2k-0005/Lumeo/issues/new?labels=showcase&amp;title=Showcase+submission"
               target="_blank" rel="noopener noreferrer"
               class="mt-auto text-sm text-primary underline underline-offset-4 hover:text-foreground transition-colors">
                Submit on GitHub →
            </a>
        </Stack>

    </div>

</Stack>
</Container>

@code {
    private int _routeCount;

    protected override void OnInitialized()
    {
        _routeCount = typeof(Showcase).Assembly
            .GetTypes()
            .Where(t => !t.IsAbstract && typeof(IComponent).IsAssignableFrom(t))
            .SelectMany(t => t.GetCustomAttributes<RouteAttribute>(false))
            .Count();
    }
}
