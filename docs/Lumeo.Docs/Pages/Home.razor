    private List<string> _barCategories = new() { "Q1", "Q2", "Q3", "Q4", "Q1 '26", "Q2 '26" };
    private List<BarChart.ChartSeriesData> _barSeries = new()
    {
        new() { Name = "Core",     Values = new() { 28400, 31200, 36800, 42100, 48700, 55300 } },
        new() { Name = "Charts",   Values = new() {  8700, 10400, 13100, 15800, 19200, 22700 } },
