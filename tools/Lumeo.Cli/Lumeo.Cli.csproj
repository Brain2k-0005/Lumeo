<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Lumeo.Cli</RootNamespace>
    <AssemblyName>lumeo</AssemblyName>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>lumeo</ToolCommandName>
    <PackageId>Lumeo.Cli</PackageId>
    <!-- Version intentionally inherited from /Directory.Build.props (lockstep with
         all Lumeo packages). The publish workflow always overrides with the git-tag
         version via /p:Version anyway; inheriting keeps local packs correct too. -->
    <Description>Vendorize Lumeo components directly into your project. Detects satellite packages (Lumeo.Charts, Lumeo.DataGrid, Lumeo.Editor, Lumeo.Scheduler, Lumeo.Gantt) and prompts to install via dotnet add package when a referenced component lives outside core Lumeo.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Authors>nativ.sh</Authors>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.CommandLine" Version="2.0.0-beta4.22272.1" />
  </ItemGroup>

  <!-- Bundle the generated cdn-deps.json into the CLI binary so `lumeo deps
       install` works offline when installed as a global tool. Falls back to
       a local repo path / remote URL only if this resource is missing. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\src\Lumeo\registry\cdn-deps.json" LogicalName="Lumeo.Cli.cdn-deps.json" Link="Resources\cdn-deps.json" />
  </ItemGroup>
</Project>
