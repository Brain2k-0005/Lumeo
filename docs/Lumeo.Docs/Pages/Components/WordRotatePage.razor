@page "/components/word-rotate"

<PageTitle>WordRotate — Lumeo</PageTitle>

<PageHeader Title="WordRotate"
            Description="Cycles through a list of words with a slide-fade transition. Use in hero headings to highlight multiple value propositions." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Landing page hero headings: "Build <WordRotate Words="@(new[]{"faster","smarter","together"})" /> with Lumeo."</li>
        <li>Rotating taglines, rotating features, or rotating audience segments.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Hero Tagline" Code="@_basicCode">
        <div class="flex items-center justify-center py-8">
            <h2 class="text-2xl font-bold">
                Build&nbsp;<WordRotate Words="@_words" Class="text-primary" />&nbsp;with Lumeo.
            </h2>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Slow Rotation (3s)" Code="@_slowCode">
        <div class="flex items-center justify-center py-4">
            <WordRotate Words="@(new[]{"Design","Develop","Deploy"})" IntervalMs="3000" Class="text-xl font-semibold text-primary" />
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">WordRotate</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Words</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">IReadOnlyList&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">List of words to cycle through.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IntervalMs</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">2000</td>
                            <td class="p-3 text-muted-foreground">How long each word is shown in milliseconds.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/typing-animation" class="text-primary hover:underline">TypingAnimation</a> — Character-by-character typing effect.</li>
        <li><a href="/components/morphing-text" class="text-primary hover:underline">MorphingText</a> — SVG filter morph between two strings.</li>
    </ul>
</div>

@code {
    private readonly string[] _words = ["faster", "smarter", "together"];
    private const string _basicCode = @"<h2 class=""text-2xl font-bold"">
    Build&nbsp;<WordRotate Words=""@(new[]{""faster"",""smarter"",""together""})"" Class=""text-primary"" />&nbsp;with Lumeo.
</h2>";
    private const string _slowCode = @"<WordRotate Words=""@(new[]{""Design"",""Develop"",""Deploy""})"" IntervalMs=""3000"" />";
}
