@namespace Lumeo

@* Right-aligned keyboard-shortcut hint for a ContextMenuItem (shadcn
   ContextMenuShortcut). Mirrors MenubarShortcut 1:1 — pushed to the inline-end
   with ms-auto and rendered in the muted color. Decorative: put the real
   accessible name on the item itself. *@
<span class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("ms-auto text-xs tracking-widest text-muted-foreground", Class);
}
