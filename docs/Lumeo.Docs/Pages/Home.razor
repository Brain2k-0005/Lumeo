@page "/"

<PageTitle>Lumeo — Blazor Component Library</PageTitle>

<!-- Hero Section -->
<div class="relative overflow-hidden">
    <!-- Subtle grid pattern background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)] pointer-events-none opacity-50"></div>

    <Stack Gap="6" Class="relative items-center text-center py-20 px-4">
        <Flex Inline="true" Align="center" Gap="2" Class="rounded-full border border-border bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm">
            <span class="flex h-1.5 w-1.5 rounded-full bg-primary"></span>
            .NET 10 &bull; Tailwind CSS v4 &bull; Open Source
        </Flex>

        <Stack Gap="4" Class="max-w-3xl">
            <Heading Level="1" Class="text-5xl sm:text-6xl font-bold tracking-tight leading-tight">
                Build beautiful<br />
                Blazor UIs with <span class="text-primary">Lumeo</span>
            </Heading>
            <Lumeo.Text Size="xl" Color="muted" Class="max-w-2xl mx-auto">
                Accessible, customizable components for Blazor inspired by shadcn/ui. Copy, adapt, and ship.
            </Lumeo.Text>
        </Stack>

        <Flex Gap="3" Wrap="true" Justify="center">
            <a href="components/button" class="inline-flex items-center gap-2 justify-center rounded-lg bg-primary text-primary-foreground px-6 py-2.5 text-sm font-semibold shadow hover:bg-primary/90 transition-colors no-underline">
                <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                Browse Components
            </a>
            <a href="patterns" class="inline-flex items-center gap-2 justify-center rounded-lg border border-border bg-background px-6 py-2.5 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                <DynamicIcon Name="Blocks" Class="h-4 w-4" />
                View Patterns
            </a>
            <Link Href="https://github.com/Brain2k-0005/Lumeo" External="true" Class="inline-flex items-center gap-2 justify-center rounded-lg border border-border bg-background px-6 py-2.5 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
                GitHub
            </a>
        </Flex>

        <!-- Stats row -->
        <Flex Gap="8" Wrap="true" Align="center" Justify="center" Class="pt-6 text-center">
            <Stack Align="center">
                <Lumeo.Text Size="3xl" Weight="bold" Color="foreground">75+</Lumeo.Text>
                <Lumeo.Text Size="sm" Color="muted" Class="mt-0.5">Components</Lumeo.Text>
            </Stack>
            <div class="h-10 border-r hidden sm:block"></div>
            <Stack Align="center">
                <Lumeo.Text Size="3xl" Weight="bold" Color="foreground">16</Lumeo.Text>
                <Lumeo.Text Size="sm" Color="muted" Class="mt-0.5">Blocks</Lumeo.Text>
            </Stack>
            <div class="h-10 border-r hidden sm:block"></div>
            <Stack Align="center">
                <Lumeo.Text Size="3xl" Weight="bold" Color="foreground">7</Lumeo.Text>
                <Lumeo.Text Size="sm" Color="muted" Class="mt-0.5">Color Themes</Lumeo.Text>
            </Stack>
            <div class="h-10 border-r hidden sm:block"></div>
            <Stack Align="center">
                <Lumeo.Text Size="3xl" Weight="bold" Color="foreground">.NET 10</Lumeo.Text>
                <Lumeo.Text Size="sm" Color="muted" Class="mt-0.5">Target Framework</Lumeo.Text>
            </Stack>
        </Flex>
    </Stack>
</div>

<Separator Class="my-4" />

<!-- Quick install snippet -->
<Container MaxWidth="3xl" Class="py-10 px-4">
<Stack Gap="5">
    <Stack Gap="2" Class="text-center">
        <Heading Level="2" Class="text-2xl">Get Started in Seconds</Heading>
        <Lumeo.Text Size="sm" Color="muted">Add Lumeo to your Blazor project with a single command.</Lumeo.Text>
    </Stack>

    <div class="rounded-lg border border-border bg-card overflow-hidden">
        <Flex Align="center" Justify="between" Class="px-4 py-2.5 border-b border-border bg-muted/30">
            <Flex Align="center" Gap="1.5">
                <div class="h-3 w-3 rounded-full bg-destructive/50"></div>
                <div class="h-3 w-3 rounded-full bg-yellow-500/50"></div>
                <div class="h-3 w-3 rounded-full bg-primary/50"></div>
            </Flex>
            <Lumeo.Text As="span" Size="xs" Color="muted" Class="font-mono">terminal</Lumeo.Text>
            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="text-xs text-muted-foreground hover:text-foreground h-auto p-0" OnClick="CopyInstall">
                @if (_installCopied)
                {
                    <DynamicIcon Name="Check" Class="h-3.5 w-3.5 text-primary" />
                }
                else
                {
                    <DynamicIcon Name="Clipboard" Class="h-3.5 w-3.5" />
                }
            </Button>
        </Flex>
        <div class="code-block !rounded-none !border-0 px-5 py-4">
<span class="cm"># Install the NuGet package</span>
<span class="kw">dotnet</span> add package Lumeo

<span class="cm"># Add to Program.cs</span>
builder.Services.<span class="type">AddLumeo</span>();

<span class="cm"># Import in _Imports.razor</span>
<span class="tag">@@</span><span class="kw">using</span> <span class="type">Lumeo</span></div>
    </div>
</Stack>
</Container>

<Separator Class="my-4" />

<!-- Feature highlights -->
<Container MaxWidth="5xl" Class="py-12 px-4">
    <Stack Gap="2" Class="text-center mb-10">
        <Heading Level="2" Class="text-2xl">Everything you need</Heading>
        <Lumeo.Text Color="muted">Built for modern Blazor development with a focus on DX.</Lumeo.Text>
    </Stack>

    <Grid Columns="3" Gap="5" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="Paintbrush" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">Tailwind CSS v4</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">Built on CSS custom properties. Theme with variables, not config files. Full v4 API support.</Lumeo.Text>
        </Stack>
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="Accessibility" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">Accessible</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">ARIA attributes, keyboard navigation, and focus management built in. WCAG 2.1 compliant.</Lumeo.Text>
        </Stack>
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="Moon" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">Dark Mode</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">Automatic dark mode via CSS variable swaps. No extra classes. Instant theme switching.</Lumeo.Text>
        </Stack>
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="Copy" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">Copy &amp; Paste</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">Every component has inline code examples. Copy, paste into your project, done.</Lumeo.Text>
        </Stack>
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="ChartBar" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">ECharts Integration</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">9 chart types powered by Apache ECharts. AOT compatible. Fully themeable.</Lumeo.Text>
        </Stack>
        <Stack Gap="3" Class="rounded-lg border border-border bg-card p-5 hover:border-border transition-colors">
            <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                <DynamicIcon Name="Package" Class="h-5 w-5" />
            </Flex>
            <Heading Level="3" Class="text-base font-semibold">NuGet Package</Heading>
            <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">Single package install. No peer dependencies. Works with Blazor WASM and Server.</Lumeo.Text>
        </Stack>
    </Grid>
</Container>

<Separator Class="my-4" />

<!-- Live preview section -->
<Container MaxWidth="4xl" Class="py-12 px-4">
<Stack Gap="6">
    <Stack Gap="2" Class="text-center mb-8">
        <Heading Level="2" Class="text-2xl">Components at a Glance</Heading>
        <Lumeo.Text Color="muted">A quick look at some of the available components.</Lumeo.Text>
    </Stack>

    <div class="rounded-lg border border-border bg-card overflow-hidden">
        <Stack Gap="6" Class="p-6">
            <!-- Buttons -->
            <Stack Gap="2">
                <Lumeo.Text Size="xs" Color="muted" Class="font-medium uppercase tracking-wide">Buttons</Lumeo.Text>
                <Flex Gap="2" Wrap="true">
                    <Button>Primary</Button>
                    <Button Variant="Button.ButtonVariant.Secondary">Secondary</Button>
                    <Button Variant="Button.ButtonVariant.Destructive">Destructive</Button>
                    <Button Variant="Button.ButtonVariant.Outline">Outline</Button>
                    <Button Variant="Button.ButtonVariant.Ghost">Ghost</Button>
                </Flex>
            </Stack>

            <Separator />

            <!-- Badges -->
            <Stack Gap="2">
                <Lumeo.Text Size="xs" Color="muted" Class="font-medium uppercase tracking-wide">Badges</Lumeo.Text>
                <Flex Gap="2" Wrap="true" Align="center">
                    <Badge>Default</Badge>
                    <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
                    <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
                    <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
                    <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
                </Flex>
            </Stack>

            <Separator />

            <!-- Controls -->
            <Stack Gap="2">
                <Lumeo.Text Size="xs" Color="muted" Class="font-medium uppercase tracking-wide">Controls</Lumeo.Text>
                <Flex Gap="6" Wrap="true" Align="center">
                    <Flex Align="center" Gap="2">
                        <Switch @bind-Checked="_switchOn" />
                        <Lumeo.Text As="span" Size="sm" Color="muted">@(_switchOn ? "On" : "Off")</Lumeo.Text>
                    </Flex>
                    <div class="w-48">
                        <Slider @bind-Value="_sliderVal" />
                    </div>
                    <Toggle @bind-Pressed="_togglePressed">
                        <DynamicIcon Name="Bold" Class="h-4 w-4" />
                    </Toggle>
                    <Checkbox @bind-Checked="_checkOn" />
                </Flex>
            </Stack>

            <Separator />

            <!-- Alert -->
            <Stack Gap="2">
                <Lumeo.Text Size="xs" Color="muted" Class="font-medium uppercase tracking-wide">Alerts</Lumeo.Text>
                <Alert>
                    <Lumeo.Text Class="font-medium">Heads up!</Lumeo.Text>
                    <Lumeo.Text Color="muted" Class="mt-1">You can add components to your app using the NuGet package.</Lumeo.Text>
                </Alert>
            </Stack>
        </Stack>

        <Flex Align="center" Justify="between" Class="border-t border-border px-6 py-3 bg-muted/20">
            <Lumeo.Text As="span" Size="xs" Color="muted">Live interactive preview</Lumeo.Text>
            <a href="components/button" class="text-xs text-primary hover:underline no-underline flex items-center gap-1">
                See all 75+ components
                <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
            </a>
        </Flex>
    </div>
</Stack>
</Container>

@code {
    private bool _switchOn = true;
    private double _sliderVal = 50;
    private bool _togglePressed;
    private bool _checkOn = true;
    private bool _installCopied;

    private async Task CopyInstall()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "dotnet add package Lumeo");
        _installCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        _installCopied = false;
        StateHasChanged();
    }
}

@inject IJSRuntime JS
