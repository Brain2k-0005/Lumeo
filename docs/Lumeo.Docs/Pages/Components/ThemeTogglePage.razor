@page "/components/theme-toggle"

<PageTitle>Theme Toggle — Lumeo</PageTitle>

<PageHeader Title="Theme Toggle" Description="A simple button to toggle between light and dark mode." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Align="center" Gap="4">
            <ThemeToggle />
            <Lumeo.Text As="span" Size="sm" Color="muted">Click to toggle theme</Lumeo.Text>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="In a Navbar" Code="@_navbarCode">
        <Flex Align="center" Justify="between" Class="rounded-lg border bg-card px-4 py-2 w-full max-w-lg">
            <Lumeo.Text As="span" Weight="semibold" Color="foreground">My App</Lumeo.Text>
            <Flex Align="center" Gap="2">
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">About</Button>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">Docs</Button>
                <ThemeToggle />
            </Flex>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="With Label" Code="@_labelCode">
        <Flex Align="center" Gap="3" Class="rounded-lg border bg-card px-4 py-3 w-full max-w-xs">
            <ThemeToggle />
            <Stack Gap="0">
                <Lumeo.Text Size="sm" Weight="medium" Color="foreground">Dark Mode</Lumeo.Text>
                <Lumeo.Text Size="xs" Color="muted">Toggle light and dark theme</Lumeo.Text>
            </Stack>
        </Flex>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">ThemeToggle</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Self-contained button component that toggles between light and dark mode using ThemeService. Displays a sun or moon icon based on the current mode. No configurable parameters beyond standard HTML attributes.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<ThemeToggle />";

    private string _navbarCode = @"<Flex Align=""center"" Justify=""between"" Class=""rounded-lg border bg-card px-4 py-2"">
    <Lumeo.Text As=""span"" Weight=""semibold"">My App</Lumeo.Text>
    <Flex Align=""center"" Gap=""2"">
        <Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Sm"">About</Button>
        <ThemeToggle />
    </Flex>
</Flex>";

    private string _labelCode = @"<Flex Align=""center"" Gap=""3"" Class=""rounded-lg border bg-card px-4 py-3"">
    <ThemeToggle />
    <Stack Gap=""0"">
        <Lumeo.Text Size=""sm"" Weight=""medium"">Dark Mode</Lumeo.Text>
        <Lumeo.Text Size=""xs"" Color=""muted"">Toggle light and dark theme</Lumeo.Text>
    </Stack>
</Flex>";
}
