@namespace Lumeo

<h2 id="@Context.TitleId" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</h2>

@code {
    [CascadingParameter] public AlertDialog.AlertDialogContext Context { get; set; } = default!;

    /// <summary>The title text, referenced by the dialog panel's <c>aria-labelledby</c>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the <c>&lt;h2&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the <c>&lt;h2&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("text-lg font-semibold", Class);
}
