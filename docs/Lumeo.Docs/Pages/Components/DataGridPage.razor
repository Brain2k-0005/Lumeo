                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">OnCellEdit</td><td class="px-4 py-2 font-mono text-xs">EventCallback&lt;CellEditEventArgs&lt;TItem&gt;&gt;</td><td class="px-4 py-2 text-xs">--</td><td class="px-4 py-2 text-muted-foreground">Callback when a cell edit is committed.</td></tr>
                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">OnRowEdit</td><td class="px-4 py-2 font-mono text-xs">EventCallback&lt;RowEditEventArgs&lt;TItem&gt;&gt;</td><td class="px-4 py-2 text-xs">--</td><td class="px-4 py-2 text-muted-foreground">Callback when a row edit is committed with all changed values.</td></tr>
