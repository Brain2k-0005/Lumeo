    private record FeatureItem(string Icon, string Title, string Body);
    private record UseCaseItem(string Icon, string Title, string Body, string[] Components);
    private record SizeRow(string Name, string Components, string Size, double Percent, bool IsCore, double[] Spark);
    private record Employee(string Name, string Department, string Role, double Salary);
    // Per-package breakdown (verified 2026-05-13, brotli-compressed assembly bytes from rc.38).
    // Brotli is what a Blazor WASM browser actually downloads — matches what Bundlephobia and
    // the .NET framework loader report. Bars normalize against Lumeo core (~400 KB → 100%).
    // Spark = synthetic 30-point "downloads-over-time" curve to make the row feel alive —
    // each package has a roughly-monotonic-rising shape with package-specific noise.
    private readonly SizeRow[] _sizeRows =
    {
        new("Lumeo",           "85 components", "~400 KB", 100.0, true,  Spark(  240,    9, 0.92)),
        new("Lumeo.Charts",    "30 components", "120 KB",   30.0, false, Spark(   90,    5, 0.85)),
        new("Lumeo.DataGrid",  "5 components",  "100 KB",   25.0, false, Spark(   75,    4, 0.80)),
        new("Lumeo.Editor",    "2 components",  "26 KB",     6.5, false, Spark(   34,    2, 0.78)),
        new("Lumeo.Motion",    "10 components", "18 KB",     4.5, false, Spark(   48,    3, 0.90)),
        new("Lumeo.Scheduler", "1 component",   "16 KB",     4.0, false, Spark(   22,    2, 0.72)),
        new("Lumeo.Gantt",     "1 component",   "12 KB",     3.0, false, Spark(   18,  1.5, 0.70)),
    };

    // Synthetic sparkline generator — 30 points rising roughly linearly with seeded noise so
    // the curves look like real download counts (jittery but trending up) and are stable
    // across renders. Salt picks a deterministic noise pattern per row.
    private static double[] Spark(double start, double slope, double salt)
    {
        var pts = new double[30];
        for (int i = 0; i < pts.Length; i++)
        {
            // Pseudo-random ±20% wobble keyed off (i, salt) so each row has its own shape.
            var phase = Math.Sin(i * 0.7 + salt * 11) * 0.12;
            var bump  = Math.Cos(i * 0.31 + salt * 17) * 0.08;
            pts[i] = Math.Max(0, start + slope * i + (start + slope * i) * (phase + bump));
        }
        return pts;
    }

