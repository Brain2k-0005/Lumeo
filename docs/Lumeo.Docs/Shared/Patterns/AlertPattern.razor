@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default" Code="@_codeAlertDefault">
    <Alert Class="w-full max-w-md">
        <Lumeo.Text Weight="medium" Color="foreground">Heads up!</Lumeo.Text>
        <Lumeo.Text Size="sm" Color="muted" Class="mt-1">You can add components using the NuGet package.</Lumeo.Text>
    </Alert>
</PatternCard>

<PatternCard Label="Destructive" Code="@_codeAlertDestructive">
    <Alert Variant="Alert.AlertVariant.Destructive" Class="w-full max-w-md">
        <Lumeo.Text Weight="medium">Error</Lumeo.Text>
        <Lumeo.Text Size="sm" Class="mt-1">Your session has expired. Please sign in again.</Lumeo.Text>
    </Alert>
</PatternCard>
</Stack>

@code {
        private string _codeAlertDefault = @"<Alert>
        <p class=""font-medium text-foreground"">Heads up!</p>
        <p class=""text-sm text-muted-foreground mt-1"">You can add components using the NuGet package.</p>
    </Alert>";

        private string _codeAlertDestructive = @"<Alert Variant=""Alert.AlertVariant.Destructive"">
        <p class=""font-medium"">Error</p>
        <p class=""text-sm mt-1"">Your session has expired. Please sign in again.</p>
    </Alert>";

        private string _codeAlertDialogDelete = @"<AlertDialog @bind-IsOpen=""_open"">
        <AlertDialogTrigger>
            <Button Variant=""Button.ButtonVariant.Destructive"">Delete Account</Button>
        </AlertDialogTrigger>
        <AlertDialogContent>
            <AlertDialogHeader>
                <AlertDialogTitle>Are you absolutely sure?</AlertDialogTitle>
                <AlertDialogDescription>This action cannot be undone.</AlertDialogDescription>
            </AlertDialogHeader>
            <AlertDialogFooter>
                <AlertDialogCancel>Cancel</AlertDialogCancel>
                <AlertDialogAction>Delete</AlertDialogAction>
            </AlertDialogFooter>
        </AlertDialogContent>
    </AlertDialog>";

        private string _codeAlertDialogConfirm = @"<AlertDialog @bind-IsOpen=""_open"">
        <AlertDialogTrigger>
            <Button Variant=""Button.ButtonVariant.Outline"">Publish Changes</Button>
        </AlertDialogTrigger>
        <AlertDialogContent>
            <AlertDialogHeader>
                <AlertDialogTitle>Publish changes?</AlertDialogTitle>
                <AlertDialogDescription>Your changes will be visible to all users.</AlertDialogDescription>
            </AlertDialogHeader>
            <AlertDialogFooter>
                <AlertDialogCancel>Cancel</AlertDialogCancel>
                <AlertDialogAction>Publish</AlertDialogAction>
            </AlertDialogFooter>
        </AlertDialogContent>
    </AlertDialog>";
}
