@page "/components/gauge"

<PageTitle>Gauge — Lumeo</PageTitle>

<PageHeader Title="Gauge" Description="Displays a single metric value within a defined range using radial, arc, or linear visual styles." />

<InstallUsage Component="Gauge" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Visualize capacity, utilisation, or performance metrics at a glance.</li>
        <li>Show a single KPI (CPU usage, battery level, score) within a min/max range.</li>
        <li>Use Radial for dashboards, Arc for compact metric cards, Linear for inline progress.</li>
        <li>Apply thresholds to automatically shift colour from green → amber → red as values rise.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Radial (default)" Code="@_radialCode">
        <Flex Gap="6" Wrap="true">
            <Gauge Value="25" />
            <Gauge Value="60" />
            <Gauge Value="90" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Arc (semicircle)" Code="@_arcCode">
        <Flex Gap="6" Wrap="true">
            <Gauge Value="30" Variant="Gauge.GaugeVariant.Arc" />
            <Gauge Value="65" Variant="Gauge.GaugeVariant.Arc" />
            <Gauge Value="95" Variant="Gauge.GaugeVariant.Arc" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Linear" Code="@_linearCode">
        <Stack Gap="4" Class="max-w-sm">
            <Gauge Value="40" Variant="Gauge.GaugeVariant.Linear" Size="200" />
            <Gauge Value="70" Variant="Gauge.GaugeVariant.Linear" Size="200" Color="success" />
            <Gauge Value="90" Variant="Gauge.GaugeVariant.Linear" Size="200" Color="destructive" />
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Custom Label" Code="@_labelCode">
        <Flex Gap="6" Wrap="true">
            <Gauge Value="72" Label="CPU" Size="120" />
            <Gauge Value="48" Label="RAM" Size="120" />
            <Gauge Value="33" Label="Disk" Size="120" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Thresholds" Code="@_thresholdCode">
        <Flex Gap="6" Wrap="true">
            <Gauge Value="@_gaugeValue"
                   Thresholds="@_thresholds"
                   Size="140" />
            <Flex Align="center" Gap="2">
                <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="DecreaseGauge">-10</Button>
                <Lumeo.Text As="span" Size="sm" Weight="medium">@_gaugeValue</Lumeo.Text>
                <Button Size="Button.ButtonSize.Sm" Variant="Button.ButtonVariant.Outline" OnClick="IncreaseGauge">+10</Button>
            </Flex>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Code="@_sizesCode">
        <Flex Gap="6" Align="end" Wrap="true">
            <Gauge Value="65" Size="80" />
            <Gauge Value="65" Size="120" />
            <Gauge Value="65" Size="160" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Variant (interactive)" Code="@_variantInteractiveCode">
        <Stack Gap="4">
            <Lumeo.Text Size="sm" Color="muted">Switch variant to compare Radial, Arc, and Linear shapes.</Lumeo.Text>
            <Segmented @bind-Value="_gaugeVariant">
                <SegmentedItem Value="Radial">Radial</SegmentedItem>
                <SegmentedItem Value="Arc">Arc</SegmentedItem>
                <SegmentedItem Value="Linear">Linear</SegmentedItem>
            </Segmented>
            <Flex Gap="6" Wrap="true" Align="end">
                <Gauge Value="35" Variant="@_gaugeVariantEnum" Size="@(_gaugeVariant == "Linear" ? 200 : 120)" Label="Low" />
                <Gauge Value="68" Variant="@_gaugeVariantEnum" Size="@(_gaugeVariant == "Linear" ? 200 : 120)" Label="Med" Color="warning" />
                <Gauge Value="92" Variant="@_gaugeVariantEnum" Size="@(_gaugeVariant == "Linear" ? 200 : 120)" Label="High" Color="destructive" />
            </Flex>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack>
        <Heading Level="3" Class="mb-3">Gauge</Heading>
        <PropsTable Slug="gauge" />
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/progress" class="text-primary hover:underline">Progress</a> — Linear and circular progress bars with indeterminate support.</li>
        <li><a href="/components/ring-progress" class="text-primary hover:underline">RingProgress</a> — A clean determinate progress ring optimised for inline use.</li>
        <li><a href="/components/statistic" class="text-primary hover:underline">Statistic</a> — Display a single numeric KPI with label and trend.</li>
    </ul>
</div>

@code {
    private string _gaugeVariant = "Radial";
    private Gauge.GaugeVariant _gaugeVariantEnum =>
        Enum.TryParse<Gauge.GaugeVariant>(_gaugeVariant, out var v) ? v : Gauge.GaugeVariant.Radial;
    private double _gaugeValue = 30;

    private void IncreaseGauge() => _gaugeValue = Math.Min(100, _gaugeValue + 10);
    private void DecreaseGauge() => _gaugeValue = Math.Max(0, _gaugeValue - 10);

    private IReadOnlyList<Gauge.GaugeThreshold> _thresholds = new List<Gauge.GaugeThreshold>
    {
        new(0,  "var(--color-success)"),
        new(60, "var(--color-warning)"),
        new(80, "var(--color-destructive)")
    };

    private string _radialCode = @"<Gauge Value=""25"" />
<Gauge Value=""60"" />
<Gauge Value=""90"" />";

    private string _arcCode = @"<Gauge Value=""30"" Variant=""Gauge.GaugeVariant.Arc"" />
<Gauge Value=""65"" Variant=""Gauge.GaugeVariant.Arc"" />
<Gauge Value=""95"" Variant=""Gauge.GaugeVariant.Arc"" />";

    private string _linearCode = @"<Gauge Value=""40"" Variant=""Gauge.GaugeVariant.Linear"" Size=""200"" />
<Gauge Value=""70"" Variant=""Gauge.GaugeVariant.Linear"" Size=""200"" Color=""success"" />
<Gauge Value=""90"" Variant=""Gauge.GaugeVariant.Linear"" Size=""200"" Color=""destructive"" />";

    private string _labelCode = @"<Gauge Value=""72"" Label=""CPU"" Size=""120"" />
<Gauge Value=""48"" Label=""RAM"" Size=""120"" />
<Gauge Value=""33"" Label=""Disk"" Size=""120"" />";

    private string _thresholdCode = @"var thresholds = new List<Gauge.GaugeThreshold>
{
    new(0,  ""var(--color-success)""),
    new(60, ""var(--color-warning)""),
    new(80, ""var(--color-destructive)"")
};

<Gauge Value=""@value"" Thresholds=""@thresholds"" Size=""140"" />";

    private string _sizesCode = @"<Gauge Value=""65"" Size=""80"" />
<Gauge Value=""65"" Size=""120"" />
<Gauge Value=""65"" Size=""160"" />";

    private string _variantInteractiveCode = @"<Segmented @bind-Value=""_variant"">
    <SegmentedItem Value=""@Gauge.GaugeVariant.Radial"">Radial</SegmentedItem>
    <SegmentedItem Value=""@Gauge.GaugeVariant.Arc"">Arc</SegmentedItem>
    <SegmentedItem Value=""@Gauge.GaugeVariant.Linear"">Linear</SegmentedItem>
</Segmented>
<Gauge Value=""35"" Variant=""@_variant"" Label=""Low"" />
<Gauge Value=""68"" Variant=""@_variant"" Label=""Med"" Color=""warning"" />
<Gauge Value=""92"" Variant=""@_variant"" Label=""High"" Color=""destructive"" />

@code { private Gauge.GaugeVariant _variant = Gauge.GaugeVariant.Radial; }";
}
