@namespace Lumeo
@implements IAsyncDisposable
@implements IOverlayExitCallback

@if (_exit.Present(Context.IsOpen))
{
    @* Kept mounted through the exit window (Context.IsOpen == false but
       _exit.Exiting) so the zoom-out keyframe plays — B11 Radix-Presence parity
       via the shared attachOverlayExitEnd infra, matching DropdownMenu. The menu
       positions through the inline style + JS PositionAtPoint clamp; neither is
       stripped on close, so the box stays pinned while it animates out. *@
    <div id="@_contentId"
         role="menu"
         aria-orientation="vertical"
         data-state="@(Context.IsOpen ? "open" : "closed")"
         class="@CssClass"
         style="@PositionStyle"
         @onkeydown="HandleKeyDown"
         tabindex="-1"
         @attributes="AdditionalAttributes">
        @ChildContent
    </div>
}

@inject IComponentInteropService Interop

@code {
    [CascadingParameter] public ContextMenu.ContextMenuContext Context { get; set; } = default!;
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _contentId = LumeoIds.New("context-menu-content");
    private readonly Lumeo.Services.MenuTypeahead _typeahead = new();
    private bool _registered;
    private int _focusedIndex = -1;
    private double _positionedX = double.NaN;
    private double _positionedY = double.NaN;

    // B11 exit latch (shared infra). Enter keeps the fade-in; exit uses zoom-out
    // (the shadcn/Radix menu dismiss: data-[state=closed]:zoom-out-95 + fade-out).
    private readonly OverlayExitAnimator _exit = new();
    private DotNetObjectReference<ContextMenuContent>? _selfRef;
    private const int ExitDurationMs = 250;

    private string AnimationClass => _exit.Exiting ? "animate-zoom-out" : "animate-fade-in";

    private string CssClass => Cx.Merge("fixed z-50 min-w-[8rem] overflow-hidden rounded-md border border-border/40 bg-popover p-1 text-popover-foreground shadow-lg", AnimationClass, Class);

    // Initial inline placement at the raw click point; OnAfterRenderAsync then
    // clamps the menu inside the viewport. The root menu previously rendered
    // partly off-screen near the bottom/right edges (submenus already flip).
    private string PositionStyle => string.Create(System.Globalization.CultureInfo.InvariantCulture, $"position: fixed; left: {Context.X}px; top: {Context.Y}px");

    // Latch the exit on the open->closed transition so the panel stays mounted for
    // the zoom-out. The click-outside/focus cleanup still runs immediately on close.
    protected override void OnParametersSet()
        => _exit.OnParameters(Context.IsOpen, ExitDurationMs, () => InvokeAsync(FinishExit));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Context.IsOpen && !_registered)
        {
            await Interop.RegisterClickOutside(_contentId, null, async () =>
            {
                await Context.SetOpen.InvokeAsync(false);
                await InvokeAsync(StateHasChanged);
            });
            _registered = true;
            _focusedIndex = -1;

            await ClampToViewport();

            // Save where focus was before opening so it returns there on close
            // (WCAG 2.4.3), then move focus to the menu container so Escape/Arrow
            // keys reach the @onkeydown handler. saveFocus installs no Tab trap.
            try { await Interop.SaveFocus(_contentId); } catch (JSDisconnectedException) { }
            try { await Interop.FocusElement(_contentId); } catch (JSDisconnectedException) { }
        }
        else if (Context.IsOpen && _registered && (Context.X != _positionedX || Context.Y != _positionedY))
        {
            // Re-opened at new coordinates (right-click elsewhere while still open).
            await ClampToViewport();
        }
        else if (!Context.IsOpen && _registered)
        {
            await Cleanup();
        }

        // Once the exit render has committed the zoom-out class, hand the unmount
        // to the panel's own animationend (attachOverlayExitEnd); the fallback
        // timer covers the JS-dead case. Wires once per exit.
        await _exit.WireExitAsync(async () =>
        {
            _selfRef ??= DotNetObjectReference.Create(this);
            try { await Interop.AttachOverlayExitEnd(_contentId, _selfRef); }
            catch (JSDisconnectedException) { }
        });
    }

    [JSInvokable]
    public Task OnExitAnimationEnd() => InvokeAsync(FinishExit);

    private void FinishExit()
    {
        if (_exit.Finish()) StateHasChanged();
    }

    private async Task ClampToViewport()
    {
        _positionedX = Context.X;
        _positionedY = Context.Y;
        try { await Interop.PositionAtPoint(_contentId, Context.X, Context.Y); }
        catch (JSDisconnectedException) { }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Escape":
                await Context.SetOpen.InvokeAsync(false);
                break;
            case "ArrowDown":
                {
                    var count = await Interop.GetMenuItemCount(_contentId);
                    if (count > 0)
                    {
                        _focusedIndex = (_focusedIndex + 1) % count;
                        await Interop.FocusMenuItemByIndex(_contentId, _focusedIndex);
                    }
                    break;
                }
            case "ArrowUp":
                {
                    var count = await Interop.GetMenuItemCount(_contentId);
                    if (count > 0)
                    {
                        _focusedIndex = _focusedIndex <= 0 ? count - 1 : _focusedIndex - 1;
                        await Interop.FocusMenuItemByIndex(_contentId, _focusedIndex);
                    }
                    break;
                }
            case "Home":
                {
                    var count = await Interop.GetMenuItemCount(_contentId);
                    if (count > 0)
                    {
                        _focusedIndex = 0;
                        await Interop.FocusMenuItemByIndex(_contentId, _focusedIndex);
                    }
                    break;
                }
            case "End":
                {
                    var count = await Interop.GetMenuItemCount(_contentId);
                    if (count > 0)
                    {
                        _focusedIndex = count - 1;
                        await Interop.FocusMenuItemByIndex(_contentId, _focusedIndex);
                    }
                    break;
                }
            default:
                // Typeahead parity with DropdownMenu (Radix type-to-focus). Printable
                // single chars (not modifier combos) accumulate a query that jumps
                // focus to the first matching item; everything else falls through so
                // Tab/Enter/Space keep native behaviour.
                if (!e.CtrlKey && !e.AltKey && !e.MetaKey && Lumeo.Services.MenuTypeahead.IsTypeaheadKey(e.Key))
                {
                    var query = _typeahead.Push(e.Key);
                    var matched = await Interop.FocusMenuItemByTypeahead(_contentId, query, _focusedIndex);
                    if (matched >= 0) _focusedIndex = matched;
                }
                break;
        }
    }

    private async Task Cleanup()
    {
        try
        {
            await Interop.UnregisterClickOutside(_contentId);
        }
        catch (JSDisconnectedException) { }
        // Return focus to where it was before the menu opened (WCAG 2.4.3).
        try { await Interop.RestoreFocus(_contentId); } catch (JSDisconnectedException) { }
        _typeahead.Reset();
        _registered = false;
        _positionedX = double.NaN;
        _positionedY = double.NaN;
    }

    public async ValueTask DisposeAsync()
    {
        _exit.Dispose();
        _selfRef?.Dispose();
        if (_registered) await Cleanup();
    }
}
