@code {
    private string _clipboardText = "Hello from Lumeo!";
    private bool _copySuccess;
    private System.Timers.Timer? _copyTimer;

    private async Task CopyToClipboard()
    {
        try
        {
            await Interop.CopyToClipboard(_clipboardText);
            _copySuccess = true;
            StateHasChanged();

            _copyTimer?.Dispose();
            _copyTimer = new System.Timers.Timer(2000);
            _copyTimer.Elapsed += (_, _) =>
            {
                _copySuccess = false;
                InvokeAsync(StateHasChanged);
                _copyTimer?.Dispose();
            };
            _copyTimer.AutoReset = false;
            _copyTimer.Start();
        }
        catch (JSDisconnectedException) { }
    }

    private async Task ScrollToTop()
    {
        try
        {
            await Interop.ScrollToTop();
        }
        catch (JSDisconnectedException) { }
    }

    private async Task DownloadTextFile()
    {
        try
        {
            var bytes = System.Text.Encoding.UTF8.GetBytes("Hello from Lumeo!\nThis file was generated by ComponentInteropService.DownloadFile().");
            var base64 = Convert.ToBase64String(bytes);
            await Interop.DownloadFile("lumeo-demo.txt", base64, "text/plain");
        }
        catch (JSDisconnectedException) { }
    }

    private async Task DownloadCsvFile()
    {
        try
        {
            var csv = "Name,Role,Status\nAlice,Developer,Active\nBob,Designer,Active\nCarol,PM,On Leave";
            var bytes = System.Text.Encoding.UTF8.GetBytes(csv);
            var base64 = Convert.ToBase64String(bytes);
            await Interop.DownloadFile("lumeo-demo.csv", base64, "text/csv");
        }
        catch (JSDisconnectedException) { }
    }

    private async Task DownloadJsonFile()
    {
        try
        {
            var json = "{\n  \"framework\": \"Blazor\",\n  \"library\": \"Lumeo\",\n  \"version\": \"0.1.0\",\n  \"features\": [\"components\", \"interop\", \"themes\"]\n}";
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var base64 = Convert.ToBase64String(bytes);
            await Interop.DownloadFile("lumeo-demo.json", base64, "application/json");
        }
        catch (JSDisconnectedException) { }
    }

    public async ValueTask DisposeAsync()
    {
        _copyTimer?.Dispose();
    }
}
