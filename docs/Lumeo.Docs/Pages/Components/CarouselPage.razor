@page "/components/carousel"

<PageTitle>Carousel — Lumeo</PageTitle>

<PageHeader Title="Carousel" Description="A carousel with motion and swipe built using scroll snapping." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Container MaxWidth="xs">
            <Carousel>
                <CarouselContent>
                    @for (var i = 1; i <= 5; i++)
                    {
                        var index = i;
                        <CarouselItem>
                            <Stack Class="p-1">
                                <Card>
                                    <CardContent Class="flex aspect-square items-center justify-center p-6">
                                        <Lumeo.Text As="span" Class="text-4xl font-semibold">@index</Lumeo.Text>
                                    </CardContent>
                                </Card>
                            </Stack>
                        </CarouselItem>
                    }
                </CarouselContent>
                <CarouselPrevious />
                <CarouselNext />
            </Carousel>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="With Loop" Code="@_loopCode">
        <Container MaxWidth="xs">
            <Carousel Loop="true">
                <CarouselContent>
                    @for (var i = 1; i <= 5; i++)
                    {
                        var index = i;
                        <CarouselItem>
                            <Stack Class="p-1">
                                <Card>
                                    <CardContent Class="flex aspect-square items-center justify-center p-6">
                                        <Lumeo.Text As="span" Class="text-4xl font-semibold">@index</Lumeo.Text>
                                    </CardContent>
                                </Card>
                            </Stack>
                        </CarouselItem>
                    }
                </CarouselContent>
                <CarouselPrevious />
                <CarouselNext />
            </Carousel>
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Product Gallery" Code="@_galleryCode">
        <Container MaxWidth="sm">
            <Carousel>
                <CarouselContent>
                    @foreach (var product in _products)
                    {
                        <CarouselItem>
                            <Stack Class="p-1">
                                <Card>
                                    <AspectRatio Ratio="4.0 / 3.0" Class="rounded-t-lg overflow-hidden bg-muted">
                                        <Flex Class="items-center justify-center h-full text-muted-foreground text-sm">@product.Category</Flex>
                                    </AspectRatio>
                                    <CardContent Class="p-4">
                                        <Lumeo.Text Size="sm" Weight="semibold">@product.Name</Lumeo.Text>
                                        <Lumeo.Text Size="sm" Color="muted">@product.Price</Lumeo.Text>
                                    </CardContent>
                                </Card>
                            </Stack>
                        </CarouselItem>
                    }
                </CarouselContent>
                <CarouselPrevious />
                <CarouselNext />
            </Carousel>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Carousel</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Orientation</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">CarouselOrientation</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Horizontal</td>
                            <td class="p-3 text-muted-foreground">Scroll direction. Values: Horizontal, Vertical.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Loop</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Whether the carousel wraps around at the ends.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>

        <Stack>
            <Heading Level="3" Class="mb-3">CarouselContent / CarouselItem / CarouselPrevious / CarouselNext</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Layout sub-components that accept ChildContent and Class. CarouselPrevious/CarouselNext are navigation buttons that automatically disable when at the start/end.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<Carousel>
    <CarouselContent>
        @for (var i = 1; i <= 5; i++)
        {
            var index = i;
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <CardContent Class=""flex aspect-square items-center justify-center p-6"">
                            <span class=""text-4xl font-semibold"">@index</span>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private string _loopCode = @"<Carousel Loop=""true"">
    <CarouselContent>
        @for (var i = 1; i <= 5; i++)
        {
            var index = i;
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <CardContent Class=""flex aspect-square items-center justify-center p-6"">
                            <span class=""text-4xl font-semibold"">@index</span>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private string _galleryCode = @"<Carousel>
    <CarouselContent>
        @foreach (var product in _products)
        {
            <CarouselItem>
                <div class=""p-1"">
                    <Card>
                        <AspectRatio Ratio=""4.0 / 3.0"" Class=""rounded-t-lg overflow-hidden bg-muted"">
                            <div class=""flex items-center justify-center h-full text-sm text-muted-foreground"">@product.Category</div>
                        </AspectRatio>
                        <CardContent Class=""p-4"">
                            <Lumeo.Text Size=""sm"" Weight=""semibold"">@product.Name</Lumeo.Text>
                            <Lumeo.Text Size=""sm"" Color=""muted"">@product.Price</Lumeo.Text>
                        </CardContent>
                    </Card>
                </div>
            </CarouselItem>
        }
    </CarouselContent>
    <CarouselPrevious />
    <CarouselNext />
</Carousel>";

    private record ProductItem(string Name, string Category, string Price);

    private readonly ProductItem[] _products =
    [
        new("Wireless Headphones", "Electronics", "$79.99"),
        new("Leather Wallet", "Accessories", "$34.99"),
        new("Running Shoes", "Footwear", "$119.99"),
        new("Coffee Mug", "Kitchen", "$14.99"),
    ];
}
