@page "/"

<h1>Lumeo icon trim proof</h1>

<p>Exactly three Tabler icons are referenced as concrete properties. The published
   Lumeo.Icons.Tabler assembly must therefore trim to near-nothing.</p>

<div style="display:flex; gap:1rem; align-items:center;">
    <SvgGlyph Svg="@(Tabler.Home)" class="h-6 w-6" aria-label="Home" />
    <SvgGlyph Svg="@(Tabler.Search)" class="h-6 w-6" aria-label="Search" />
    <SvgGlyph Svg="@(Tabler.Settings)" class="h-6 w-6" aria-label="Settings" />
</div>

@code {
    // CONCRETE property references only — no reflection, no name→icon lookup table.
    // A reflective lookup (e.g. typeof(Tabler).GetProperty(name)) would force the trimmer
    // to keep every icon, defeating the exact property this sample is built to prove.
}
