@namespace Lumeo

@* The image hides itself once it has errored (or when Src is blank) so the
   sibling AvatarFallback can take over — the Radix image→fallback chain.
   Rendering is suppressed rather than just visually hidden so a broken-image
   glyph never flashes. When used standalone (no Avatar parent) there's no
   context and the image always renders, preserving the old behaviour. *@
@if (ShowImage)
{
    <img class="@CssClass" src="@Src" alt="@(Alt ?? string.Empty)" @attributes="AdditionalAttributes"
         @onload="HandleLoad" @onerror="HandleError" />
}

@code {
    [CascadingParameter] private Avatar.AvatarImageContext? ImageContext { get; set; }

    /// <summary>Image URL. A blank or whitespace-only value is treated as an immediate error, skipping the request and showing the sibling <see cref="AvatarFallback"/> right away.</summary>
    [Parameter] public string? Src { get; set; }
    /// <summary>Alt text for the <c>&lt;img&gt;</c>; defaults to an empty string (decorative) when unset.</summary>
    [Parameter] public string? Alt { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>&lt;img&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Invoked when the image fails to load (browser <c>onerror</c>), after the fallback has been switched in.</summary>
    [Parameter] public EventCallback OnError { get; set; }
    /// <summary>Unmatched attributes splatted onto the <c>&lt;img&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _errored;
    private string? _lastSrc;

    private string CssClass => Cx.Merge("aspect-square h-full w-full object-cover", Class);

    // Render unless we've errored. A blank Src counts as an immediate error so
    // the fallback shows without waiting for the browser to fire onerror.
    private bool ShowImage => !_errored;

    protected override void OnParametersSet()
    {
        // Whitespace-only Src is treated like a blank Src: skip the wasted
        // request to the current page and show the fallback immediately.
        if (string.IsNullOrWhiteSpace(Src))
        {
            _errored = true;
            ImageContext?.SetLoaded(false);
        }
        else if (Src != _lastSrc)
        {
            // Src genuinely changed to a real value — give it another chance to
            // load. A broken image stays hidden across unrelated re-renders
            // (same Src) so it never un-hides itself without a real change.
            _errored = false;
        }

        _lastSrc = Src;
    }

    private void HandleLoad()
    {
        _errored = false;
        ImageContext?.SetLoaded(true);
    }

    private async Task HandleError()
    {
        _errored = true;
        ImageContext?.SetLoaded(false);
        await OnError.InvokeAsync();
    }
}
