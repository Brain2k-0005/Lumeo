@page "/components/mention"

<PageTitle>Mention — Lumeo</PageTitle>

<PageHeader Title="Mention" Description="A textarea with mention support that shows a dropdown when a trigger character is typed." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>@@user mentions in comments, messages, or chat interfaces</li>
        <li>Tagging team members in collaborative editing tools</li>
        <li>Referencing channels, issues, or documents with custom trigger characters</li>
        <li>Social features that require inline user or entity tagging</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Mention" Code="@_basicCode">
        <Mention @bind-Value="_text1" Options="@_people" Placeholder="Type to mention someone..." Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Custom Trigger" Code="@_triggerCode">
        <Mention @bind-Value="_text2" Options="@_channels" Trigger="@('#')" Placeholder="Type # to reference a channel..." Class="max-w-md" />
    </ComponentDemo>

    <ComponentDemo Title="Trigger Character" Description="Switch the trigger character to see different completion lists." Code="@_triggerSwitchCode">
        <Stack Gap="3">
            <Flex Align="center" Gap="3" Wrap="true">
                <Lumeo.Text Size="sm" Weight="medium">Trigger:</Lumeo.Text>
                <Segmented @bind-Value="_mentionTriggerStr">
                    <SegmentedItem Value="@_atTrigger">@_atTrigger</SegmentedItem>
                    <SegmentedItem Value="#">#</SegmentedItem>
                    <SegmentedItem Value="/">/</SegmentedItem>
                </Segmented>
            </Flex>
            <Mention @bind-Value="_text3"
                     Options="@GetOptionsForTrigger(_mentionTriggerStr)"
                     Trigger="@(_mentionTriggerStr[0])"
                     Placeholder="@($"Type {_mentionTriggerStr} to trigger suggestions...")"
                     Class="max-w-md" />
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">Mention</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">The textarea content.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Trigger</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">char</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">@@</td>
                            <td class="p-3 text-muted-foreground">Character that triggers the dropdown.</td>
