@page "/components/animated-subscribe-button"

<PageTitle>AnimatedSubscribeButton — Lumeo</PageTitle>

<PageHeader Title="AnimatedSubscribeButton"
            Description="Multi-state button: idle → loading → success. Each state morphs in via slide + fade. Supports two-way binding via bind-State." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Newsletter sign-up forms.</li>
        <li>Waitlist or early-access registration flows.</li>
        <li>Any async action where showing progress + success state matters.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default Subscribe" Code="@_basicCode">
        <div class="flex justify-center py-4">
            <AnimatedSubscribeButton @bind-State="_state1" OnSubscribe="@HandleSubscribe1" />
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Custom Labels" Code="@_customCode">
        <div class="flex justify-center py-4">
            <AnimatedSubscribeButton @bind-State="_state2"
                                     OnSubscribe="@HandleSubscribe2"
                                     IdleLabel="Join Waitlist"
                                     LoadingLabel="Adding you…"
                                     SuccessLabel="You're in!" />
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">AnimatedSubscribeButton</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">State</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">SubscribeState</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Idle</td>
                            <td class="p-3 text-muted-foreground">Current button state: Idle, Loading, or Success.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">StateChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;SubscribeState&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Two-way binding callback for State.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnSubscribe</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Invoked when the idle button is clicked. Set State to Success when done.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IdleLabel</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Subscribe"</td>
                            <td class="p-3 text-muted-foreground">Label shown in the idle state.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">LoadingLabel</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Subscribing…"</td>
                            <td class="p-3 text-muted-foreground">Label shown with spinner during loading.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">SuccessLabel</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Subscribed!"</td>
                            <td class="p-3 text-muted-foreground">Label shown in the success state.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/shimmer-button" class="text-primary hover:underline">ShimmerButton</a> — Button with animated shimmer border effect.</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — Core button component.</li>
    </ul>
</div>

@code {
    private AnimatedSubscribeButton.SubscribeState _state1 = AnimatedSubscribeButton.SubscribeState.Idle;
    private AnimatedSubscribeButton.SubscribeState _state2 = AnimatedSubscribeButton.SubscribeState.Idle;

    private async Task HandleSubscribe1()
    {
        await Task.Delay(1500);
        _state1 = AnimatedSubscribeButton.SubscribeState.Success;
    }

    private async Task HandleSubscribe2()
    {
        await Task.Delay(1200);
        _state2 = AnimatedSubscribeButton.SubscribeState.Success;
    }

    private const string _basicCode = @"<AnimatedSubscribeButton @bind-State=""_state"" OnSubscribe=""@HandleSubscribe"" />";
    private const string _customCode = @"<AnimatedSubscribeButton @bind-State=""_state""
    OnSubscribe=""@HandleSubscribe""
    IdleLabel=""Join Waitlist""
    LoadingLabel=""Adding you…""
    SuccessLabel=""You're in!"" />";
}
