@namespace Lumeo

<button type="button" class="@CssClass" aria-label="@AriaLabel" @onclick="OnClose" @attributes="AdditionalAttributes">
    <Blazicon Svg="Lucide.X" class="h-4 w-4" />
    <span class="sr-only">@AriaLabel</span>
</button>

@code {
    [Parameter] public EventCallback OnClose { get; set; }
    /// <summary>Accessible name for the close button. Override for i18n.</summary>
    [Parameter] public string AriaLabel { get; set; } = "Close";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"absolute right-1 top-1 rounded-md p-1 opacity-0 transition-opacity group-hover:opacity-100 hover:opacity-100 focus:outline-none focus:ring-1 {Class}".Trim();
}
