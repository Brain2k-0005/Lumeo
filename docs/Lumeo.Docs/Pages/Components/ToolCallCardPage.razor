@page "/components/tool-call-card"

<PageTitle>ToolCallCard — Lumeo</PageTitle>

<PageHeader Title="ToolCallCard" Description="AI tool-invocation card showing call and result." />

<InstallUsage Component="ToolCallCard" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Display tool calls and their results inside an AI chat interface.</li>
        <li>Show the status lifecycle — pending, running, success, or error — as the tool executes.</li>
        <li>Use <code class="text-xs bg-muted px-1 py-0.5 rounded">DefaultOpen</code> to pre-expand cards for debugging or first-time viewing.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Status Variants" Code="@_statusCode">
        <div class="w-full max-w-xl h-[360px] overflow-y-auto pr-1">
            <Stack Gap="2" Class="max-w-lg">
                <ToolCallCard ToolName="search_web" Status="ToolCallCard.ToolCallStatus.Pending" Input='{"query": "latest Blazor news"}' />
                <ToolCallCard ToolName="read_file" Status="ToolCallCard.ToolCallStatus.Running" Input='{"path": "/src/app.razor"}' />
                <ToolCallCard ToolName="execute_code" Status="ToolCallCard.ToolCallStatus.Success"
                              Input='{"language": "csharp", "code": "Console.WriteLine(\"Hello\");"}' Output="Hello" DurationMs="342" />
                <ToolCallCard ToolName="fetch_url" Status="ToolCallCard.ToolCallStatus.Error"
                              Input='{"url": "https://example.com/api/data"}' ErrorMessage="Connection timeout after 5000ms" DurationMs="5001" />
            </Stack>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Expanded by Default" Code="@_openCode">
        <div class="w-full max-w-xl h-[200px] overflow-y-auto pr-1">
            <Stack Gap="2" Class="max-w-lg">
                <ToolCallCard ToolName="analyze_sentiment" Status="ToolCallCard.ToolCallStatus.Success"
                              Input='{"text": "Lumeo makes Blazor development a joy!"}' Output='{"sentiment": "positive", "score": 0.96}'
                              DurationMs="128" DefaultOpen="true" />
            </Stack>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Status (interactive)" Code="@_statusInteractiveCode">
        <div class="w-full max-w-xl h-[280px] overflow-y-auto pr-1">
            <Stack Gap="4">
                <Lumeo.Text Size="sm" Color="muted">Switch status to see the icon, color, and available sections change.</Lumeo.Text>
                <Segmented @bind-Value="_tcStatus">
                    <SegmentedItem Value="Pending">Pending</SegmentedItem>
                    <SegmentedItem Value="Running">Running</SegmentedItem>
                    <SegmentedItem Value="Success">Success</SegmentedItem>
                    <SegmentedItem Value="Error">Error</SegmentedItem>
                </Segmented>
                <Stack Class="max-w-lg">
                    <ToolCallCard ToolName="run_query"
                                  Status="@_tcStatusEnum"
                                  Input='{"sql": "SELECT * FROM users LIMIT 10"}'
                                  Output="@(_tcStatus == "Success" ? "10 rows returned" : null)"
                                  ErrorMessage="@(_tcStatus == "Error" ? "Query timeout after 30s" : null)"
                                  DurationMs="@(_tcStatus == "Success" || _tcStatus == "Error" ? (long?)342 : null)"
                                  DefaultOpen="@(_tcStatus == "Success" || _tcStatus == "Error")" />
                </Stack>
            </Stack>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Tool Calls" Code="@_multipleCode">
        <div class="w-full max-w-xl h-[320px] overflow-y-auto pr-1">
            <Stack Gap="2" Class="max-w-lg">
                <ToolCallCard ToolName="list_files" Status="ToolCallCard.ToolCallStatus.Success"
                              Input='{"directory": "/src"}' Output="Program.cs&#10;App.razor&#10;_Imports.razor" DurationMs="18" />
                <ToolCallCard ToolName="read_file" Status="ToolCallCard.ToolCallStatus.Success"
                              Input='{"path": "/src/Program.cs"}' Output="var builder = WebApplication.CreateBuilder(args);&#10;// ..." DurationMs="24" />
                <ToolCallCard ToolName="write_file" Status="ToolCallCard.ToolCallStatus.Running"
                              Input='{"path": "/src/NewComponent.razor", "content": "..."}' />
            </Stack>
        </div>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">ToolCallCard</Heading>
            <PropsTable Slug="tool-call-card" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/reasoning-display" class="text-primary hover:underline">ReasoningDisplay</a> — Collapsible chain-of-thought block for AI reasoning traces.</li>
        <li><a href="/components/streaming-text" class="text-primary hover:underline">StreamingText</a> — Token-by-token streaming text renderer for AI responses.</li>
    </ul>
</div>

@code {
    private string _tcStatus = "Pending";
    private ToolCallCard.ToolCallStatus _tcStatusEnum =>
        Enum.TryParse<ToolCallCard.ToolCallStatus>(_tcStatus, out var v) ? v : ToolCallCard.ToolCallStatus.Pending;

    private string _statusInteractiveCode = @"<Segmented @bind-Value=""_status"">
    <SegmentedItem Value=""@ToolCallCard.ToolCallStatus.Pending"">Pending</SegmentedItem>
    <SegmentedItem Value=""@ToolCallCard.ToolCallStatus.Running"">Running</SegmentedItem>
    <SegmentedItem Value=""@ToolCallCard.ToolCallStatus.Success"">Success</SegmentedItem>
    <SegmentedItem Value=""@ToolCallCard.ToolCallStatus.Error"">Error</SegmentedItem>
</Segmented>
<ToolCallCard ToolName=""run_query"" Status=""@_status""
              Input=""{&quot;sql&quot;: &quot;SELECT * FROM users&quot;}""
              Output=""@(_status == Success ? ""10 rows"" : null)""
              ErrorMessage=""@(_status == Error ? ""Timeout"" : null)"" />

@code { private ToolCallCard.ToolCallStatus _status = ToolCallCard.ToolCallStatus.Pending; }";

    private string _statusCode = @"<ToolCallCard ToolName=""search_web"" Status=""ToolCallCard.ToolCallStatus.Pending""
              Input=""{&quot;query&quot;: &quot;latest Blazor news&quot;}"" />

<ToolCallCard ToolName=""read_file"" Status=""ToolCallCard.ToolCallStatus.Running""
              Input=""{&quot;path&quot;: &quot;/src/app.razor&quot;}"" />

<ToolCallCard ToolName=""execute_code"" Status=""ToolCallCard.ToolCallStatus.Success""
              Input=""{&quot;language&quot;: &quot;csharp&quot;}"" Output=""Hello"" DurationMs=""342"" />

<ToolCallCard ToolName=""fetch_url"" Status=""ToolCallCard.ToolCallStatus.Error""
              ErrorMessage=""Connection timeout after 5000ms"" DurationMs=""5001"" />";

    private string _openCode = @"<ToolCallCard ToolName=""analyze_sentiment""
              Status=""ToolCallCard.ToolCallStatus.Success""
              Input=""{&quot;text&quot;: &quot;Lumeo makes Blazor development a joy!&quot;}""
              Output=""{&quot;sentiment&quot;: &quot;positive&quot;, &quot;score&quot;: 0.96}""
              DurationMs=""128""
              DefaultOpen=""true"" />";

    private string _multipleCode = @"@foreach (var call in _toolCalls)
{
    <ToolCallCard ToolName=""@call.Name""
                  Status=""@call.Status""
                  Input=""@call.Input""
                  Output=""@call.Output""
                  DurationMs=""@call.DurationMs"" />
}";
}
