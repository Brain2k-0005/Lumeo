<ToggleGroup Type=""ToggleGroup.ToggleGroupType.Multiple"">
    <ToggleGroupItem Value=""bold"" PressEffect=""@Enum.Parse<Button.ButtonPressEffect>(_pressEffect)"">
        <SvgGlyph Svg=""@(Lucide.Bold)"" class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""italic"" PressEffect=""@Enum.Parse<Button.ButtonPressEffect>(_pressEffect)"">
        <SvgGlyph Svg=""@(Lucide.Italic)"" class=""h-4 w-4"" />
    </ToggleGroupItem>
    <ToggleGroupItem Value=""underline"" PressEffect=""@Enum.Parse<Button.ButtonPressEffect>(_pressEffect)"">
