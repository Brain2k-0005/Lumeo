        new("ORD-8466", "Takeshi Yamamoto", "TY", "Delivered",  Badge.BadgeVariant.Success,     "Web",      "Globe",         "Apr 13, 2026", "$154.40"),
        new("ORD-8465", "Saoirse Murphy",   "SM", "Processing", Badge.BadgeVariant.Warning,     "Retail",   "Store",         "Apr 13, 2026", "$82.30"),
