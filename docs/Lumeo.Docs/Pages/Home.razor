@page "/"

<PageTitle>Lumeo — The Blazor Component Library</PageTitle>

<!-- ======================= HERO ======================= -->
<Stack Class="relative overflow-hidden">
    <!-- Subtle grid pattern background -->
    <Stack Class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)] pointer-events-none opacity-50"></Stack>

    <Stack Gap="6" Class="relative items-center text-center py-20 px-4">
        <!-- Version badge -->
        <Lumeo.Link Href="docs/changelog" Class="no-underline group">
            <Flex Inline="true" Align="center" Gap="2" Class="rounded-full border border-border bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">New</Badge>
                <Lumeo.Text As="span">v2.0 — AI primitives, motion, full DataGrid</Lumeo.Text>
                <DynamicIcon Name="ArrowRight" Class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
            </Flex>
        </Lumeo.Link>

        <Stack Gap="4" Class="max-w-3xl">
            <Heading Level="1" Class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.05]">
                The Blazor component library<br />
                you'd actually want to <Lumeo.Text As="span" Class="text-primary">ship</Lumeo.Text>.
            </Heading>
            <Lumeo.Text Size="lg" Color="muted" Class="max-w-2xl mx-auto leading-relaxed">
                130+ components, 8 themes, AI primitives, motion, full DataGrid — production-ready
                and MIT-licensed. Copy, adapt, and ship.
            </Lumeo.Text>
        </Stack>

        <Flex Gap="3" Wrap="true" Justify="center" Class="pt-2">
            <Lumeo.Link Href="docs/introduction" Class="inline-flex items-center gap-2 justify-center rounded-lg bg-primary text-primary-foreground px-6 py-2.5 text-sm font-semibold shadow hover:bg-primary/90 transition-colors no-underline">
                Get Started
                <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
            </Lumeo.Link>
            <Lumeo.Link Href="components/button" Class="inline-flex items-center gap-2 justify-center rounded-lg border border-border bg-background px-6 py-2.5 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                Browse Components
            </Lumeo.Link>
        </Flex>

        <!-- Inline install command -->
        <Stack Align="center" Gap="2" Class="pt-3">
            <Flex Align="center" Gap="0" Class="rounded-lg border border-border bg-muted/40 pl-4 pr-1.5 py-1.5 font-mono text-xs text-foreground backdrop-blur-sm">
                <Lumeo.Text As="span" Color="muted" Class="mr-2 select-none">$</Lumeo.Text>
                <Lumeo.Text As="span" Class="whitespace-nowrap">dotnet add package Lumeo</Lumeo.Text>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="ml-3 h-7 w-7 p-0 text-muted-foreground hover:text-foreground" OnClick="CopyInstall" aria-label="Copy install command">
                    @if (_installCopied)
                    {
                        <DynamicIcon Name="Check" Class="h-3.5 w-3.5 text-primary" />
                    }
                    else
                    {
                        <DynamicIcon Name="Copy" Class="h-3.5 w-3.5" />
                    }
                </Button>
            </Flex>
            <Lumeo.Text Size="xs" Color="muted">No peer dependencies. Works with Blazor WASM and Server.</Lumeo.Text>
        </Stack>

        <!-- Stats row -->
        <Flex Gap="6" Wrap="true" Align="center" Justify="center" Class="pt-10 text-center text-xs">
            <Flex Align="center" Gap="1.5">
                <Lumeo.Text As="span" Weight="semibold" Color="foreground">135+</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">components</Lumeo.Text>
            </Flex>
            <Lumeo.Text As="span" Color="muted" Class="opacity-40">·</Lumeo.Text>
            <Flex Align="center" Gap="1.5">
                <Lumeo.Text As="span" Weight="semibold" Color="foreground">1,680</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">tests</Lumeo.Text>
            </Flex>
            <Lumeo.Text As="span" Color="muted" Class="opacity-40">·</Lumeo.Text>
            <Flex Align="center" Gap="1.5">
                <Lumeo.Text As="span" Weight="semibold" Color="foreground">14</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">locales</Lumeo.Text>
            </Flex>
            <Lumeo.Text As="span" Color="muted" Class="opacity-40">·</Lumeo.Text>
            <Flex Align="center" Gap="1.5">
                <Lumeo.Text As="span" Weight="semibold" Color="foreground">MIT</Lumeo.Text>
            </Flex>
            <Lumeo.Text As="span" Color="muted" Class="opacity-40">·</Lumeo.Text>
            <Flex Align="center" Gap="1.5">
                <Lumeo.Text As="span" Weight="semibold" Color="foreground">WCAG AA</Lumeo.Text>
            </Flex>
        </Flex>
    </Stack>
</Stack>

<Separator Class="my-2" />

<!-- ======================= FEATURE GRID ======================= -->
<Container MaxWidth="6xl" Class="py-16 px-4">
    <Stack Gap="2" Class="text-center mb-12">
        <Heading Level="2" Class="text-3xl font-bold tracking-tight">Everything you need</Heading>
        <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
            A complete UI kit for modern Blazor apps — batteries included, DX-obsessed.
        </Lumeo.Text>
    </Stack>

    <Grid Columns="3" Gap="5" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var f in _features)
        {
            <Stack Gap="3" Class="rounded-lg border border-border/60 bg-card p-5 hover:border-border hover:shadow-sm transition-all">
                <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-lg bg-primary/10 text-primary">
                    <DynamicIcon Name="@f.Icon" Class="h-5 w-5" />
                </Flex>
                <Heading Level="3" Class="text-base font-semibold">@f.Title</Heading>
                <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">@f.Body</Lumeo.Text>
            </Stack>
        }
    </Grid>
</Container>

<Separator Class="my-2" />

<!-- ======================= COMPONENT SHOWCASE ======================= -->
<Container MaxWidth="6xl" Class="py-16 px-4">
    <Stack Gap="2" Class="text-center mb-12">
        <Heading Level="2" Class="text-3xl font-bold tracking-tight">Real components. Live demos.</Heading>
        <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
            Everything you see below is rendered by the actual Lumeo components — not screenshots.
        </Lumeo.Text>
    </Stack>

    <Grid Columns="3" Gap="5" Class="grid-cols-1 md:grid-cols-2 lg:grid-cols-3">

        <!-- Buttons showcase -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Gap="3" Class="p-5 min-h-[140px] bg-muted/20">
                <Flex Gap="2" Wrap="true">
                    <Button Size="Button.ButtonSize.Sm">Primary</Button>
                    <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Sm">Secondary</Button>
                    <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Outline</Button>
                </Flex>
                <Flex Gap="2" Wrap="true">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">Ghost</Button>
                    <Button Variant="Button.ButtonVariant.Destructive" Size="Button.ButtonSize.Sm">Destructive</Button>
                </Flex>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Button</Lumeo.Text>
                <Lumeo.Link Href="components/button" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

        <!-- Badges showcase -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Gap="3" Class="p-5 min-h-[140px] bg-muted/20 justify-center">
                <Flex Gap="2" Wrap="true" Align="center">
                    <Badge>Default</Badge>
                    <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                    <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
                </Flex>
                <Flex Gap="2" Wrap="true" Align="center">
                    <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
                    <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
                    <Badge Variant="Badge.BadgeVariant.Destructive">Error</Badge>
                </Flex>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Badge</Lumeo.Text>
                <Lumeo.Link Href="components/badge" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

        <!-- Form controls -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Gap="4" Class="p-5 min-h-[140px] bg-muted/20 justify-center">
                <Flex Align="center" Gap="3">
                    <Switch @bind-Checked="_switchOn" />
                    <Lumeo.Text Size="sm" Color="muted">@(_switchOn ? "Enabled" : "Disabled")</Lumeo.Text>
                </Flex>
                <Stack Class="w-full">
                    <Slider @bind-Value="_sliderVal" />
                </Stack>
                <Flex Gap="3" Align="center">
                    <Checkbox @bind-Checked="_checkOn" />
                    <Toggle @bind-Pressed="_togglePressed">
                        <DynamicIcon Name="Bold" Class="h-4 w-4" />
                    </Toggle>
                </Flex>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Form controls</Lumeo.Text>
                <Lumeo.Link Href="components/switch" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

        <!-- Card preview -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Class="p-5 min-h-[140px] bg-muted/20 items-center justify-center">
                <Stack Class="w-full max-w-[240px] rounded-lg border border-border bg-background p-4 shadow-sm">
                    <Flex Align="center" Gap="3" Class="mb-3">
                        <Stack Class="h-8 w-8 rounded-full bg-primary/15 flex items-center justify-center text-primary">
                            <DynamicIcon Name="Bell" Class="h-4 w-4" />
                        </Stack>
                        <Stack Gap="0">
                            <Lumeo.Text Size="sm" Weight="semibold">Notifications</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">3 unread messages</Lumeo.Text>
                        </Stack>
                    </Flex>
                    <Button Size="Button.ButtonSize.Sm" Class="w-full">Mark all as read</Button>
                </Stack>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Card</Lumeo.Text>
                <Lumeo.Link Href="components/card" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

        <!-- Dialog demo -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Class="p-5 min-h-[140px] bg-muted/20 items-center justify-center">
                <Dialog @bind-IsOpen="_showDialog">
                    <DialogTrigger>
                        <Button Variant="Button.ButtonVariant.Outline">
                            <DynamicIcon Name="MousePointerClick" Class="h-4 w-4" />
                            Open dialog
                        </Button>
                    </DialogTrigger>
                    <DialogContent>
                        <DialogHeader>
                            <DialogTitle>Welcome to Lumeo</DialogTitle>
                            <DialogDescription>
                                This is a fully accessible, keyboard-navigable dialog rendered by the Lumeo Dialog component.
                            </DialogDescription>
                        </DialogHeader>
                        <DialogFooter>
                            <DialogClose>
                                <Button Variant="Button.ButtonVariant.Outline">Cancel</Button>
                            </DialogClose>
                            <DialogClose>
                                <Button>Got it</Button>
                            </DialogClose>
                        </DialogFooter>
                    </DialogContent>
                </Dialog>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">Dialog</Lumeo.Text>
                <Lumeo.Link Href="components/dialog" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

        <!-- Date Picker -->
        <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Stack Class="p-5 min-h-[140px] bg-muted/20 items-center justify-center">
                <Stack Class="w-full max-w-[260px]">
                    <DatePicker @bind-Value="_selectedDate" Placeholder="Pick a date" />
                    @if (_selectedDate.HasValue)
                    {
                        <Lumeo.Text Size="xs" Color="muted" Class="mt-2">Selected: @_selectedDate.Value.ToString("MMM d, yyyy")</Lumeo.Text>
                    }
                </Stack>
            </Stack>
            <Flex Align="center" Justify="between" Class="border-t border-border/60 px-4 py-2.5">
                <Lumeo.Text Size="xs" Weight="medium" Color="foreground">DatePicker</Lumeo.Text>
                <Lumeo.Link Href="components/date-picker" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                    View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                </Lumeo.Link>
            </Flex>
        </Stack>

    </Grid>

    <!-- Alert demo below -->
    <Stack Class="mt-8">
        <Alert>
            <DynamicIcon Name="Info" Class="h-4 w-4" />
            <Lumeo.Text Weight="medium">Heads up!</Lumeo.Text>
            <Lumeo.Text Color="muted" Class="mt-1">Every component above is fully themeable, accessible, and ships with inline code examples.</Lumeo.Text>
        </Alert>
    </Stack>
</Container>

<Separator Class="my-2" />

<!-- ======================= QUICK START TERMINAL ======================= -->
<Container MaxWidth="4xl" Class="py-16 px-4">
<Stack Gap="6">
    <Stack Gap="2" Class="text-center">
        <Heading Level="2" Class="text-3xl font-bold tracking-tight">Get started in seconds</Heading>
        <Lumeo.Text Color="muted">Three commands and you're ready to ship.</Lumeo.Text>
    </Stack>

    <Grid Columns="2" Gap="5" Class="grid-cols-1 md:grid-cols-2">

        <!-- Terminal mockup -->
        <Stack Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Flex Align="center" Justify="between" Class="px-4 py-2.5 border-b border-border/60 bg-muted/30">
                <Flex Align="center" Gap="1.5">
                    <Stack Class="h-3 w-3 rounded-full bg-destructive/60"></Stack>
                    <Stack Class="h-3 w-3 rounded-full bg-yellow-500/60"></Stack>
                    <Stack Class="h-3 w-3 rounded-full bg-primary/60"></Stack>
                </Flex>
                <Lumeo.Text As="span" Size="xs" Color="muted" Class="font-mono">terminal</Lumeo.Text>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="text-xs text-muted-foreground hover:text-foreground h-6 w-6 p-0" OnClick="CopyTerminal" aria-label="Copy snippet">
                    @if (_terminalCopied)
                    {
                        <DynamicIcon Name="Check" Class="h-3.5 w-3.5 text-primary" />
                    }
                    else
                    {
                        <DynamicIcon Name="Clipboard" Class="h-3.5 w-3.5" />
                    }
                </Button>
            </Flex>
<pre class="font-mono text-xs leading-relaxed text-foreground whitespace-pre overflow-x-auto px-5 py-4 m-0"><span class="text-muted-foreground"># Install the NuGet package</span>
dotnet add package Lumeo

<span class="text-muted-foreground"># Add to Program.cs</span>
builder.Services.AddLumeo();

<span class="text-muted-foreground"># Import in _Imports.razor</span>
@@using Lumeo</pre>
        </Stack>

        <!-- Sample Razor usage -->
        <Stack Class="rounded-lg border border-border/60 bg-card overflow-hidden">
            <Flex Align="center" Justify="between" Class="px-4 py-2.5 border-b border-border/60 bg-muted/30">
                <Lumeo.Text As="span" Size="xs" Weight="medium" Color="foreground" Class="font-mono">Home.razor</Lumeo.Text>
                <Lumeo.Text As="span" Size="xs" Color="muted" Class="font-mono">Blazor</Lumeo.Text>
            </Flex>
<pre class="font-mono text-xs leading-relaxed text-foreground whitespace-pre overflow-x-auto px-5 py-4 m-0">@@page "/"

&lt;Card&gt;
    &lt;CardHeader&gt;
        &lt;Heading Level="2"&gt;Welcome&lt;/Heading&gt;
    &lt;/CardHeader&gt;
    &lt;CardContent&gt;
        &lt;Button&gt;Ship it&lt;/Button&gt;
    &lt;/CardContent&gt;
&lt;/Card&gt;</pre>
        </Stack>

    </Grid>
</Stack>
</Container>

<Separator Class="my-2" />

<!-- ======================= BLOCKS SHOWCASE ======================= -->
<Container MaxWidth="6xl" Class="py-16 px-4">
    <Stack Gap="2" Class="text-center mb-12">
        <Heading Level="2" Class="text-3xl font-bold tracking-tight">Copy-paste blocks</Heading>
        <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
            Production-ready patterns you can drop into your app. One click to view, one copy to ship.
        </Lumeo.Text>
    </Stack>

    <Grid Columns="4" Gap="4" Class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        @foreach (var b in _blocks)
        {
            <Lumeo.Link Href="@b.Href" Class="no-underline group">
                <Stack Gap="0" Class="rounded-lg border border-border/60 bg-card overflow-hidden transition-all hover:border-border hover:shadow-md h-full">
                    <Stack Class="relative aspect-[4/3] bg-muted/40 items-center justify-center overflow-hidden">
                        <Stack Class="absolute inset-0 flex items-center justify-center text-muted-foreground/60 group-hover:text-primary transition-colors">
                            <DynamicIcon Name="@b.Icon" Class="h-10 w-10" />
                        </Stack>
                        <!-- Fake browser chrome hint -->
                        <Flex Align="center" Gap="1" Class="absolute top-2 left-2">
                            <Stack Class="h-1.5 w-1.5 rounded-full bg-border"></Stack>
                            <Stack Class="h-1.5 w-1.5 rounded-full bg-border"></Stack>
                            <Stack Class="h-1.5 w-1.5 rounded-full bg-border"></Stack>
                        </Flex>
                    </Stack>
                    <Stack Gap="1" Class="px-4 py-3 border-t border-border/60">
                        <Lumeo.Text Size="sm" Weight="semibold" Color="foreground" Class="group-hover:text-primary transition-colors">@b.Title</Lumeo.Text>
                        <Lumeo.Text Size="xs" Color="muted">@b.Description</Lumeo.Text>
                    </Stack>
                </Stack>
            </Lumeo.Link>
        }
    </Grid>
</Container>

<Separator Class="my-2" />

<!-- ======================= FOOTER / CTA ======================= -->
<Container MaxWidth="6xl" Class="py-16 px-4">
    <Stack Gap="10">
        <!-- Big CTA -->
        <Stack Gap="4" Class="text-center items-center rounded-xl border border-border/60 bg-gradient-to-b from-muted/40 to-transparent px-6 py-14">
            <Heading Level="2" Class="text-3xl font-bold tracking-tight max-w-xl">Ready to ship beautiful Blazor apps?</Heading>
            <Lumeo.Text Color="muted" Class="max-w-lg">
                Star the repo, install the package, and start shipping in minutes. MIT-licensed — build commercial products for free.
            </Lumeo.Text>
            <Flex Gap="3" Wrap="true" Justify="center" Class="pt-2">
                <Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo" Class="inline-flex items-center gap-2 justify-center rounded-lg bg-foreground text-background px-6 py-2.5 text-sm font-semibold shadow hover:opacity-90 transition-opacity no-underline">
                    <DynamicIcon Name="Github" Class="h-4 w-4" />
                    Star on GitHub
                </Lumeo.Link>
                <Lumeo.Link Href="docs/introduction" Class="inline-flex items-center gap-2 justify-center rounded-lg border border-border bg-background px-6 py-2.5 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                    Read the docs
                    <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                </Lumeo.Link>
            </Flex>
            <Flex Align="center" Gap="3" Class="pt-4 text-xs">
                <Badge Variant="Badge.BadgeVariant.Outline">MIT</Badge>
                <Lumeo.Text As="span" Color="muted">·</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">.NET 10</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">·</Lumeo.Text>
                <Lumeo.Text As="span" Color="muted">Tailwind CSS v4</Lumeo.Text>
            </Flex>
        </Stack>

        <!-- Footer link columns -->
        <Grid Columns="4" Gap="6" Class="grid-cols-2 md:grid-cols-4 pt-4 border-t border-border/40">
            <Stack Gap="3">
                <Lumeo.Text Size="xs" Weight="semibold" Color="foreground" Class="uppercase tracking-wide">Documentation</Lumeo.Text>
                <Stack Gap="2">
                    <Lumeo.Link Href="docs/introduction" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Introduction</Lumeo.Link>
                    <Lumeo.Link Href="docs/templates" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Templates</Lumeo.Link>
                    <Lumeo.Link Href="themes" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Themes</Lumeo.Link>
                    <Lumeo.Link Href="docs/changelog" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Changelog</Lumeo.Link>
                </Stack>
            </Stack>
            <Stack Gap="3">
                <Lumeo.Text Size="xs" Weight="semibold" Color="foreground" Class="uppercase tracking-wide">Components</Lumeo.Text>
                <Stack Gap="2">
                    <Lumeo.Link Href="components/button" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Button</Lumeo.Link>
                    <Lumeo.Link Href="components/data-grid" Class="text-sm text-muted-foreground hover:text-foreground no-underline">DataGrid</Lumeo.Link>
                    <Lumeo.Link Href="components/chart" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Charts</Lumeo.Link>
                    <Lumeo.Link Href="components/dialog" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Dialog</Lumeo.Link>
                </Stack>
            </Stack>
            <Stack Gap="3">
                <Lumeo.Text Size="xs" Weight="semibold" Color="foreground" Class="uppercase tracking-wide">Resources</Lumeo.Text>
                <Stack Gap="2">
                    <Lumeo.Link Href="patterns" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Patterns</Lumeo.Link>
                    <Lumeo.Link Href="docs/cli" Class="text-sm text-muted-foreground hover:text-foreground no-underline">CLI</Lumeo.Link>
                    <Lumeo.Link Href="docs/mcp-server" Class="text-sm text-muted-foreground hover:text-foreground no-underline">MCP server</Lumeo.Link>
                    <Lumeo.Link Href="docs/accessibility" Class="text-sm text-muted-foreground hover:text-foreground no-underline">Accessibility</Lumeo.Link>
                </Stack>
            </Stack>
            <Stack Gap="3">
