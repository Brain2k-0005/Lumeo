@page "/components/theme-switcher"

<PageTitle>Theme Switcher — Lumeo</PageTitle>

<PageHeader Title="Theme Switcher" Description="A complete theme control with color scheme swatches and light/dark/system mode toggle." />

<Stack Gap="8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <div class="w-full max-w-sm rounded-lg border bg-card p-6">
            <ThemeSwitcher />
        </div>
    </ComponentDemo>

    <ComponentDemo Title="In a Card" Code="@_cardCode">
        <Card Class="w-full max-w-sm">
            <CardHeader>
                <Heading Level="3">Appearance</Heading>
                <Lumeo.Text Size="sm" Color="muted">Customize the look and feel of your application.</Lumeo.Text>
            </CardHeader>
            <CardContent>
                <ThemeSwitcher />
            </CardContent>
        </Card>
    </ComponentDemo>

    <ComponentDemo Title="Settings Row" Code="@_settingsCode">
        <Stack Gap="1" Class="w-full max-w-md rounded-lg border bg-card p-1">
            <Flex Align="center" Justify="between" Class="rounded-md px-3 py-2 hover:bg-accent transition-colors">
                <Stack Gap="0">
                    <Lumeo.Text Size="sm" Weight="medium" Color="foreground">Appearance</Lumeo.Text>
                    <Lumeo.Text Size="xs" Color="muted">Choose your color scheme and mode</Lumeo.Text>
                </Stack>
            </Flex>
            <Separator />
            <div class="px-3 py-3">
                <ThemeSwitcher />
            </div>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">ThemeSwitcher</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes for the container.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary italic text-muted-foreground" colspan="4">Self-contained component that uses ThemeService to display color scheme swatches and light/dark/system mode toggle. No additional parameters needed.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _defaultCode = @"<ThemeSwitcher />";

    private string _cardCode = @"<Card>
    <CardHeader>
        <Heading Level=""3"">Appearance</Heading>
        <Lumeo.Text Size=""sm"" Color=""muted"">Customize the look and feel.</Lumeo.Text>
    </CardHeader>
    <CardContent>
        <ThemeSwitcher />
    </CardContent>
</Card>";

    private string _settingsCode = @"<Stack Gap=""1"" Class=""rounded-lg border bg-card p-1"">
    <Flex Align=""center"" Justify=""between"" Class=""rounded-md px-3 py-2"">
        <Stack Gap=""0"">
            <Lumeo.Text Size=""sm"" Weight=""medium"">Appearance</Lumeo.Text>
            <Lumeo.Text Size=""xs"" Color=""muted"">Choose your color scheme and mode</Lumeo.Text>
        </Stack>
    </Flex>
    <Separator />
    <Stack Class=""px-3 py-3"">
        <ThemeSwitcher />
    </Stack>
</Stack>";
}
