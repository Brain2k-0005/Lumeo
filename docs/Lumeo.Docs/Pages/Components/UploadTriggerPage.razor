@page "/components/upload-trigger"

<PageTitle>Upload Trigger — Lumeo</PageTitle>

<PageHeader Title="Upload Trigger" Description="A Button-styled InputFile trigger for file-pick-only flows — the look and feel of a Lumeo Button that opens the native file picker, without FileUpload's progress and file-list UI." />

<InstallUsage Component="UploadTrigger" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>A "Replace document" or "Upload logo" action where the file list lives elsewhere</li>
        <li>Composer toolbars that add attachments inline</li>
        <li>Any minimal pick affordance that should match surrounding Lumeo buttons</li>
    </ul>
    <Lumeo.Text Class="text-sm text-muted-foreground">
        For full upload UI with progress, drag-and-drop, and validation use
        <Lumeo.Link Href="/components/file-upload" Class="text-primary hover:underline">FileUpload</Lumeo.Link>.
        UploadTrigger is intentionally the minimal pick-trigger primitive.
    </Lumeo.Text>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Trigger" Code="@_basicCode">
        <Flex Class="items-center gap-3 flex-wrap">
            <UploadTrigger Text="Upload file" OnFilesSelected="HandleFiles" />
            @if (!string.IsNullOrEmpty(_picked))
            {
                <Lumeo.Text Class="text-sm text-muted-foreground">@_picked</Lumeo.Text>
            }
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Variants" Code="@_variantCode">
        <Flex Gap="2" Wrap="true">
            <UploadTrigger Variant="Button.ButtonVariant.Default" Text="Default" OnFilesSelected="HandleFiles" />
            <UploadTrigger Variant="Button.ButtonVariant.Secondary" Text="Secondary" OnFilesSelected="HandleFiles" />
            <UploadTrigger Variant="Button.ButtonVariant.Outline" Text="Outline" OnFilesSelected="HandleFiles" />
            <UploadTrigger Variant="Button.ButtonVariant.Ghost" Text="Ghost" OnFilesSelected="HandleFiles" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Accept Filter and Multiple" Code="@_acceptCode">
        <Flex Gap="2" Wrap="true">
            <UploadTrigger Text="Pick images" Accept="image/*" Multiple="true" OnFilesSelected="HandleFiles" />
            <UploadTrigger Text="Pick a PDF" Accept=".pdf,.docx" OnFilesSelected="HandleFiles" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Custom Label and Icon" Code="@_customCode">
        <Flex Gap="2" Wrap="true">
            <UploadTrigger Variant="Button.ButtonVariant.Outline" OnFilesSelected="HandleFiles">
                <Icon>
                    <SvgGlyph Svg="@(Lucide.Image)" class="h-4 w-4" />
                </Icon>
                <ChildContent>
                    <span>Replace photo</span>
                </ChildContent>
            </UploadTrigger>
            <UploadTrigger Size="Button.ButtonSize.Icon" Variant="Button.ButtonVariant.Ghost" OnFilesSelected="HandleFiles" aria-label="Attach file">
                <Icon>
                    <SvgGlyph Svg="@(Lucide.Paperclip)" class="h-4 w-4" />
                </Icon>
                @* Empty ChildContent suppresses the default text label so the
                   icon-size button shows only the glyph. *@
                <ChildContent></ChildContent>
            </UploadTrigger>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <UploadTrigger Text="Upload file" Disabled="true" OnFilesSelected="HandleFiles" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack>
            <Heading Level="3" Class="mb-3">UploadTrigger</Heading>
            <PropsTable Slug="upload-trigger" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/file-upload" class="text-primary hover:underline">File Upload</a> — Full upload UI with progress, drag-and-drop, and validation</li>
        <li><a href="/components/button" class="text-primary hover:underline">Button</a> — The visual style UploadTrigger mirrors</li>
    </ul>
</div>

@code {
    private string _picked = "";

    private void HandleFiles(Microsoft.AspNetCore.Components.Forms.InputFileChangeEventArgs e)
    {
        _picked = e.FileCount == 1 ? $"Picked: {e.File.Name}" : $"Picked {e.FileCount} files";
    }

    private string _basicCode = @"<UploadTrigger Text=""Upload file"" OnFilesSelected=""@HandleFiles"" />

@code {
    private void HandleFiles(InputFileChangeEventArgs e)
    {
        // read e.File / e.GetMultipleFiles() and upload
    }
}";

    private string _variantCode = @"<UploadTrigger Variant=""Button.ButtonVariant.Default"" Text=""Default"" OnFilesSelected=""@HandleFiles"" />
<UploadTrigger Variant=""Button.ButtonVariant.Secondary"" Text=""Secondary"" OnFilesSelected=""@HandleFiles"" />
<UploadTrigger Variant=""Button.ButtonVariant.Outline"" Text=""Outline"" OnFilesSelected=""@HandleFiles"" />
<UploadTrigger Variant=""Button.ButtonVariant.Ghost"" Text=""Ghost"" OnFilesSelected=""@HandleFiles"" />";

    private string _acceptCode = @"<UploadTrigger Text=""Pick images"" Accept=""image/*"" Multiple=""true"" OnFilesSelected=""@HandleFiles"" />
<UploadTrigger Text=""Pick a PDF"" Accept="".pdf,.docx"" OnFilesSelected=""@HandleFiles"" />";

    private string _customCode = @"<UploadTrigger Variant=""Button.ButtonVariant.Outline"" OnFilesSelected=""@HandleFiles"">
    <Icon>
        <SvgGlyph Svg=""@(Lucide.Image)"" class=""h-4 w-4"" />
    </Icon>
    <ChildContent>
        <span>Replace photo</span>
    </ChildContent>
</UploadTrigger>

<UploadTrigger Size=""Button.ButtonSize.Icon"" Variant=""Button.ButtonVariant.Ghost"" OnFilesSelected=""@HandleFiles"" aria-label=""Attach file"">
    <Icon>
        <SvgGlyph Svg=""@(Lucide.Paperclip)"" class=""h-4 w-4"" />
    </Icon>
    @* Empty ChildContent suppresses the default text label *@
    <ChildContent></ChildContent>
</UploadTrigger>";

    private string _disabledCode = @"<UploadTrigger Text=""Upload file"" Disabled=""true"" OnFilesSelected=""@HandleFiles"" />";
}
