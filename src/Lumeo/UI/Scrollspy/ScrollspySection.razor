@namespace Lumeo

<div id="@Id" data-scrollspy-section class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The section's DOM id, matched against a <see cref="Scrollspy"/>'s <c>ActiveId</c> and a <see cref="ScrollspyLink.Target"/>. Required.</summary>
    [Parameter, EditorRequired] public string Id { get; set; } = "";
    /// <summary>The section's content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the section's <c>&lt;div&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the section's <c>&lt;div&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge(Class);
}
