@namespace Lumeo.Docs.Layout

@* Docs sidebar shows ONLY the docs-section groups (Getting Started, Theming, Guides,
   Services, …). Components / Patterns / Blocks live behind their own top-nav tabs and
   their own scoped sidebars — mixing all sections into one tree was the "too much /
   badly structured" wall. Cross-section jumps go through the ⌘K palette. The group
   containing the current URL auto-expands; everything else is collapsed. *@
<NavMenu Section="docs" Collapsible="true" IsMobile="@IsMobile" />

@code {
    [Parameter] public bool IsMobile { get; set; }
}
