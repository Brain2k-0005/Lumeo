                            <td class="p-3 text-muted-foreground">Trap Tab focus within element.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">RemoveFocusTrap(elementId)</td>
                            <td class="p-3 text-xs text-muted-foreground">Focus</td>
