@namespace Lumeo
@using System.Reflection
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="@RootClass" @attributes="AdditionalAttributes">
    @if (ShowToolbar)
    {
        <div class="flex items-center justify-between gap-2 border-b border-border/40 bg-background/60 px-3 py-2">
            @if (ShowPageNav)
            {
                <div class="flex items-center gap-1">
                    <button type="button"
                            class="@NavBtnClass"
                            aria-label="Previous page"
                            disabled="@(!CanGoPrev)"
                            @onclick="GoPrev">
                        <Blazicon Svg="Lucide.ChevronLeft" class="h-4 w-4" />
                    </button>
                    <div class="flex items-center gap-1 text-xs text-muted-foreground">
                        <input type="number"
                               min="1"
                               max="@_totalPages"
                               value="@Page"
                               class="h-7 w-12 rounded-md border border-border/60 bg-background px-1 text-center text-xs text-foreground focus:outline-none focus:ring-2 focus:ring-ring"
                               @onchange="HandlePageInput"
                               aria-label="Page number" />
                        <span>/ @_totalPages</span>
                    </div>
                    <button type="button"
                            class="@NavBtnClass"
                            aria-label="Next page"
                            disabled="@(!CanGoNext)"
                            @onclick="GoNext">
                        <Blazicon Svg="Lucide.ChevronRight" class="h-4 w-4" />
                    </button>
                </div>
            }
            else
            {
                <div></div>
            }

            <div class="flex items-center gap-1">
                @if (ShowSearch)
                {
                    <div class="flex items-center gap-1">
                        <input type="search"
                               placeholder="Search…"
                               value="@_searchQuery"
                               class="h-7 w-40 rounded-md border border-border/60 bg-background px-2 text-xs text-foreground focus:outline-none focus:ring-2 focus:ring-ring"
                               @onchange="HandleSearchInput"
                               aria-label="Search PDF" />
                        @if (_searchResult is not null)
                        {
                            @if (_searchResult.TotalCount == 0)
                            {
                                <span class="text-xs text-muted-foreground" aria-live="polite">No matches</span>
                            }
                            else
                            {
                                <button type="button" class="@NavBtnClass" aria-label="Previous match" disabled="@(_searchResult.TotalCount == 0)" @onclick="GoPrevMatch">
                                    <Blazicon Svg="Lucide.ChevronUp" class="h-4 w-4" />
                                </button>
                                <span class="min-w-[52px] text-center text-xs text-muted-foreground" aria-live="polite">
                                    @(_activeMatchIndex + 1) / @_searchResult.TotalCount
                                </span>
                                <button type="button" class="@NavBtnClass" aria-label="Next match" disabled="@(_searchResult.TotalCount == 0)" @onclick="GoNextMatch">
                                    <Blazicon Svg="Lucide.ChevronDown" class="h-4 w-4" />
                                </button>
                            }
                        }
                    </div>
                }
                @if (ShowZoomControls)
                {
                    <button type="button" class="@NavBtnClass" aria-label="Zoom out" @onclick="ZoomOut">
                        <Blazicon Svg="Lucide.Minus" class="h-4 w-4" />
                    </button>
                    <span class="min-w-[44px] text-center text-xs text-muted-foreground">
                        @($"{(int)Math.Round(Zoom * 100)}%")
                    </span>
                    <button type="button" class="@NavBtnClass" aria-label="Zoom in" @onclick="ZoomIn">
                        <Blazicon Svg="Lucide.Plus" class="h-4 w-4" />
                    </button>
                }
                @if (ShowDownload && !string.IsNullOrEmpty(Src))
                {
                    <a href="@Src"
                       download
                       target="_blank"
                       rel="noopener"
                       class="@NavBtnClass"
                       aria-label="Download PDF">
                        <Blazicon Svg="Lucide.Download" class="h-4 w-4" />
                    </a>
                }
            </div>
        </div>
    }

    <div class="relative flex-1 overflow-auto bg-muted/30"
         role="document"
         aria-label="PDF document"
         tabindex="0"
         @onkeydown="HandleKeyDown">
        @if (_loadError is not null)
        {
            <EmptyState Class="py-16"
                        Title="Could not load PDF"
                        Description="@_loadErrorShort">
                <IconContent>
                    <Blazicon Svg="Lucide.FileX" class="h-10 w-10" />
                </IconContent>
            </EmptyState>
        }
        else if (string.IsNullOrWhiteSpace(Src))
        {
            @* No Src yet — render a quiet placeholder rather than a blank canvas. *@
            <EmptyState Class="py-16"
                        Title="No PDF loaded"
                        Description="Set the Src parameter to a PDF URL to display a document.">
                <IconContent>
                    <Blazicon Svg="Lucide.FileText" class="h-10 w-10" />
                </IconContent>
            </EmptyState>
        }
        else
        {
            @* Centering via `mx-auto` on the inner block, not `justify-center`
               on the parent. When the zoomed canvas overflows the scroll
               container, `justify-content: center` would keep centering it,
               which clips the left half against the parent's content-start
               edge and makes that half un-scrollable (the scroll origin is
               the content box, not the centered child). Auto-margins
               absorb free space when there's room (canvas centered) and
               collapse to zero when there isn't (canvas pinned to start,
               full overflow scrolls into view both directions). *@
            <div class="flex min-h-full items-start p-4">
                <div class="relative inline-block mx-auto">
                    <canvas id="@_canvasId" class="@CanvasVisibilityClass shadow-md"></canvas>
                    @* pdf.js text layer — transparent, selectable spans aligned over
                       the canvas so the rendered page is copyable and screen-reader
                       readable. Populated by renderPage in pdf-viewer.js. *@
                    <div id="@_textLayerId"
                         class="lumeo-pdf-text-layer @CanvasVisibilityClass"
                         aria-label="Page text"></div>
                    @if (_highlights.Count > 0 && !string.IsNullOrWhiteSpace(_searchQuery))
                    {
                        <div class="lumeo-pdf-highlights pointer-events-none absolute inset-0" aria-hidden="true">
                            @for (var i = 0; i < _highlights.Count; i++)
                            {
                                var h = _highlights[i];
                                var isActive = i == _activeMatchOnPage;
                                var bg = isActive ? $"color-mix(in srgb, {HighlightColor} 70%, transparent)" : $"color-mix(in srgb, {HighlightColor} 45%, transparent)";
                                <div style="position:absolute;left:@(h.X.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;top:@(h.Y.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;width:@(h.Width.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;height:@(h.Height.ToString("F1", System.Globalization.CultureInfo.InvariantCulture))px;background:@bg;border-radius:2px;"></div>
                            }
                        </div>
                    }
                </div>
            </div>
            @if (_loading)
            {
                <div class="absolute inset-0 flex items-center justify-center bg-background/40 backdrop-blur-[2px]"
                     role="status"
                     aria-live="polite">
                    <Spinner />
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string? Src { get; set; }
    [Parameter] public int Page { get; set; } = 1;
    [Parameter] public EventCallback<int> PageChanged { get; set; }
    [Parameter] public double Zoom { get; set; } = 1.0;
    [Parameter] public EventCallback<double> ZoomChanged { get; set; }
    /// <summary>Fit-to-container mode that overrides <see cref="Zoom"/> when
    /// set to a non-Custom value. <c>FitWidth</c> scales the page so its
    /// width matches the scroll-parent's <c>clientWidth</c> (minus a 16px
    /// padding for breathing room before the scrollbar). <c>FitPage</c>
    /// scales so the whole page fits within the scroll-parent's box. JS
    /// computes the ratio on each render, so a container resize that
    /// triggers <c>OnParametersSet</c> re-renders the page at the new fit.
    /// Set back to <c>Custom</c> to return control to the numeric
    /// <see cref="Zoom"/> value.</summary>
    [Parameter] public PdfFitMode FitMode { get; set; } = PdfFitMode.Custom;

    public enum PdfFitMode { Custom, FitWidth, FitPage }
    [Parameter] public bool ShowToolbar { get; set; } = true;
    [Parameter] public bool ShowPageNav { get; set; } = true;
    [Parameter] public bool ShowZoomControls { get; set; } = true;
    [Parameter] public bool ShowDownload { get; set; } = true;
    [Parameter] public bool ShowSearch { get; set; }
    [Parameter] public string HighlightColor { get; set; } = "yellow";
    [Parameter] public EventCallback<int> OnLoaded { get; set; }
    [Parameter] public EventCallback<int> OnPageChanged { get; set; }
    /// <summary>
    /// Fires when the underlying JS load/render fails (CDN unreachable, malformed
    /// PDF, worker init failure, …).  Receives the exception message.  Consumers
    /// can use this to surface their own error UI; the built-in EmptyState fallback
    /// renders regardless.
    /// </summary>
    [Parameter] public EventCallback<string> OnError { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private const double MinZoom = 0.5;
    private const double MaxZoom = 4.0;
    private const double ZoomStep = 0.25;

    private readonly string _canvasId = $"lumeo-pdf-{Guid.NewGuid():N}";
    // Text layer id is derived from the canvas id by convention so renderPage can
    // locate it without changing the JS call signature.
    private string _textLayerId => $"{_canvasId}-text";
    private IJSObjectReference? _module;
    private string? _lastSrc;
    private int _lastPage;
    private double _lastZoom;
    // Track FitMode explicitly so we can detect Custom↔FitWidth/FitPage
    // transitions in the OnParametersSet dirty check. The previous design
    // used double.NaN as a sentinel on _lastZoom, but Math.Abs(zoom - NaN) > ε
    // is always false (NaN comparisons), so a parent rerender after a fit
    // render never re-triggered a refit even when the container had resized.
    private PdfFitMode _lastFitMode = PdfFitMode.Custom;
    private int _totalPages;
    private bool _loading = true;
    private string? _loadError;
    private string? _loadErrorShort;
    private string _searchQuery = string.Empty;
    private SearchResult? _searchResult;          // null = no query yet
    private int _activeMatchIndex;                // 0-based global match index
    private List<MatchRect> _highlights = [];     // rects for current page
    private int _activeMatchOnPage = -1;          // index within _highlights that is "active"

    // Strip the long pdf.js stack trace (everything after the first " at ")
    // so the in-component EmptyState shows a short, human-readable message.
    // The full message still flows to OnError for consumers that want it.
    private static string ShortenError(string msg)
    {
        var firstLine = msg.Split('\n')[0];
        var idx = firstLine.IndexOf(" at ", StringComparison.Ordinal);
        if (idx > 0) firstLine = firstLine[..idx];
        return firstLine.Length > 120 ? firstLine[..120] + "…" : firstLine;
    }

    // Re-entrancy guard. OnAfterRenderAsync calls StateHasChanged() to flip the
    // loading spinner, which queues another render → another OnAfterRenderAsync
    // before this one finishes awaiting load/renderPage. Without the guard the
    // second pass also enters the load branch (because _lastSrc hasn't been
    // updated yet), and the cascading StateHasChanged calls eventually overflow
    // the render diff stack.
    private bool _busy;
    // Set to true whenever Src/Page/Zoom changed during a render — drives the
    // post-work re-check so we don't strand a pending update.
    private bool _dirty;

    // Driven off the satellite assembly's informational version so the cached
    // module URL changes whenever Lumeo.PdfViewer is republished — same trick
    // ComponentInteropService uses for core components.js.
    private static readonly string _moduleVersion =
        typeof(PdfViewer).Assembly.GetCustomAttribute<AssemblyInformationalVersionAttribute>()?.InformationalVersion
        ?? typeof(PdfViewer).Assembly.GetName().Version?.ToString()
        ?? "0";

    private string RootClass => $"flex flex-col rounded-xl border border-border/40 bg-card overflow-hidden min-h-[400px] {Class}".Trim();
    private string NavBtnClass => "inline-flex h-7 w-7 items-center justify-center rounded-md text-muted-foreground hover:bg-accent hover:text-accent-foreground disabled:opacity-40 disabled:pointer-events-none focus:outline-none focus:ring-2 focus:ring-ring transition-colors";
    private string CanvasVisibilityClass => _loading || _loadError is not null ? "opacity-0" : "opacity-100 transition-opacity duration-150";

    private bool CanGoPrev => _totalPages > 0 && Page > 1;
    private bool CanGoNext => _totalPages > 0 && Page < _totalPages;

    protected override void OnParametersSet()
    {
        // Mark anything that needs JS work; OnAfterRenderAsync picks it up.
        if (!string.Equals(_lastSrc, Src, StringComparison.Ordinal)) _dirty = true;
        var cp = Math.Clamp(Page, 1, Math.Max(1, _totalPages == 0 ? int.MaxValue : _totalPages));
        var cz = Math.Clamp(Zoom, MinZoom, MaxZoom);
        if (cp != _lastPage || Math.Abs(cz - _lastZoom) > 0.0001) _dirty = true;
        // Custom↔Fit transition forces a refit. Staying in a fit mode also
        // refits on every parent rerender because container size can change
        // without any tracked param moving — JS recomputes the ratio.
        if (FitMode != _lastFitMode) _dirty = true;
        else if (FitMode != PdfFitMode.Custom) _dirty = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Re-entrancy guard: avoid stacking concurrent load/renderPage passes,
        // which is what produced the StackOverflowException — every nested
        // StateHasChanged enqueued another render whose OnAfterRenderAsync
        // re-entered this method before the prior await returned.
        if (_busy) return;

        if (string.IsNullOrWhiteSpace(Src))
        {
            if (_loading) { _loading = false; StateHasChanged(); }
            return;
        }

        if (!_dirty && _module is not null) return;

        _busy = true;
        try
        {
            do
            {
                _dirty = false;

                _module ??= await JS.InvokeAsync<IJSObjectReference>(
                    "import",
                    $"./_content/Lumeo.PdfViewer/js/pdf-viewer.js?v={_moduleVersion}");

                // Claim the in-flight target BEFORE awaiting so re-entrant
                // checks see "already handled" even though the await hasn't
                // returned yet.
                var targetSrc = Src;
                if (!string.Equals(_lastSrc, targetSrc, StringComparison.Ordinal))
                {
                    _lastSrc = targetSrc;
                    _lastPage = 0;
                    _lastZoom = 0;
                    _loading = true;
                    _loadError = null;
                    // A new document invalidates the search session: clear the
                    // query text too, not just the results/highlights. Leaving
                    // _searchQuery set stranded stale text in the search input
                    // (value="@_searchQuery") while the results panel and
                    // highlight overlays were already gone — a mismatched state.
                    _searchQuery = string.Empty;
                    _searchResult = null;
                    _highlights = [];
                    _activeMatchIndex = 0;
                    _activeMatchOnPage = -1;
                    StateHasChanged();

                    try
                    {
                        var info = await _module.InvokeAsync<LoadResult>("load", _canvasId, targetSrc);
                        _totalPages = info.TotalPages;
                        if (OnLoaded.HasDelegate) await OnLoaded.InvokeAsync(_totalPages);
                    }
                    catch (Exception ex)
                    {
                        _lastSrc = null;
                        _loadError = ex.Message;
                        _loadErrorShort = ShortenError(ex.Message);
                        _loading = false;
                        StateHasChanged();
                        if (OnError.HasDelegate) await OnError.InvokeAsync(ex.Message);
                        return;
                    }
                }

                var clampedPage = Math.Clamp(Page, 1, Math.Max(1, _totalPages));
                var clampedZoom = Math.Clamp(Zoom, MinZoom, MaxZoom);

                // FitMode wins over the numeric Zoom: when set, the JS side
                // computes the actual ratio from the scroll-parent's
                // clientWidth / clientHeight against the page's natural
                // dimensions. _lastFitMode tracks the active mode so
                // OnParametersSet can correctly mark dirty across Custom↔Fit
                // transitions and on every parent rerender while in a fit mode.
                var useFit = FitMode != PdfFitMode.Custom;
                var fitChanged = FitMode != _lastFitMode;
                if (useFit || fitChanged || clampedPage != _lastPage || Math.Abs(clampedZoom - _lastZoom) > 0.0001)
                {
                    var targetPage = clampedPage;
                    var targetZoom = clampedZoom;
                    _lastPage = targetPage;
                    _lastZoom = targetZoom;
                    _lastFitMode = FitMode;
                    _loading = true;
                    StateHasChanged();

                    object zoomArg = FitMode switch
                    {
                        PdfFitMode.FitWidth => "fit-width",
                        PdfFitMode.FitPage => "fit-page",
                        _ => (object)targetZoom
                    };
                    await _module.InvokeVoidAsync("renderPage", _canvasId, targetPage, zoomArg);

                    _loading = false;
                    await RefreshHighlightsAsync();
                    StateHasChanged();
                }
                else if (_loading)
                {
                    _loading = false;
                    StateHasChanged();
                }
            }
            while (_dirty);
        }
        catch (JSDisconnectedException) { }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            _loadErrorShort = ShortenError(ex.Message);
            _loading = false;
            StateHasChanged();
            if (OnError.HasDelegate) await OnError.InvokeAsync(ex.Message);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SetPageAsync(int next)
    {
        if (_totalPages == 0) return;
        var clamped = Math.Clamp(next, 1, _totalPages);
        if (clamped == Page) return;
        Page = clamped;
        _dirty = true;
        if (PageChanged.HasDelegate) await PageChanged.InvokeAsync(Page);
        if (OnPageChanged.HasDelegate) await OnPageChanged.InvokeAsync(Page);
    }

    private async Task SetZoomAsync(double next)
    {
        var clamped = Math.Clamp(next, MinZoom, MaxZoom);
        if (Math.Abs(clamped - Zoom) < 0.0001) return;
        Zoom = clamped;
        _dirty = true;
        if (ZoomChanged.HasDelegate) await ZoomChanged.InvokeAsync(Zoom);
    }

    private Task GoPrev() => SetPageAsync(Page - 1);
    private Task GoNext() => SetPageAsync(Page + 1);
    private Task ZoomIn() => SetZoomAsync(Zoom + ZoomStep);
    private Task ZoomOut() => SetZoomAsync(Zoom - ZoomStep);

    private Task HandlePageInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var parsed))
        {
            return SetPageAsync(parsed);
        }
        return Task.CompletedTask;
    }

    private async Task HandleSearchInput(ChangeEventArgs e)
    {
        _searchQuery = e.Value?.ToString() ?? string.Empty;
        if (_module is null) return;

        if (string.IsNullOrWhiteSpace(_searchQuery))
        {
            _searchResult = null;
            _highlights = [];
            _activeMatchIndex = 0;
            _activeMatchOnPage = -1;
            StateHasChanged();
            return;
        }

        try
        {
            _searchResult = await _module.InvokeAsync<SearchResult>("search", _canvasId, _searchQuery);
        }
        catch
        {
            _searchResult = new SearchResult { TotalCount = 0, Pages = [] };
        }

        _activeMatchIndex = 0;

        // Jump to first match page, then load overlays.
        if (_searchResult is { TotalCount: > 0 } && _searchResult.Pages.Count > 0)
        {
            var firstPage = _searchResult.Pages[0].PageNum;
            if (firstPage != Page)
            {
                await SetPageAsync(firstPage);
                // SetPageAsync sets _dirty = true and invokes PageChanged;
                // OnAfterRenderAsync will re-render the page and call RefreshHighlightsAsync.
                // We still need the counter displayed, so call StateHasChanged for the toolbar.
                StateHasChanged();
                return;
            }
        }

        await RefreshHighlightsAsync();
        StateHasChanged();
    }

    // Fetch pixel-space rects for the current page and current query from JS,
    // then figure out which rect corresponds to _activeMatchIndex.
    private async Task RefreshHighlightsAsync()
    {
        if (_module is null || string.IsNullOrWhiteSpace(_searchQuery) || _searchResult is null || _searchResult.TotalCount == 0)
        {
            _highlights = [];
            _activeMatchOnPage = -1;
            return;
        }

        try
        {
            var rects = await _module.InvokeAsync<List<MatchRect>>("getMatchOverlays", _canvasId, Page, _searchQuery);
            _highlights = rects ?? [];
        }
        catch
        {
            _highlights = [];
        }

        // Determine which highlight on this page corresponds to the global _activeMatchIndex.
        _activeMatchOnPage = -1;
        if (_highlights.Count > 0 && _searchResult.Pages.Count > 0)
        {
            // Count how many global matches appear before the current page.
            var matchesBefore = 0;
            foreach (var pg in _searchResult.Pages)
            {
                if (pg.PageNum < Page)
                    matchesBefore += pg.Matches.Count;
                else
                    break;
            }
            var localIndex = _activeMatchIndex - matchesBefore;
            if (localIndex >= 0 && localIndex < _highlights.Count)
                _activeMatchOnPage = localIndex;
        }
    }

    // Build a flat ordered list of (pageNum, localMatchIndex) pairs so we can
    // step through all matches across pages sequentially.
    private List<(int PageNum, int LocalIndex)> BuildMatchList()
    {
        if (_searchResult is null) return [];
        var list = new List<(int, int)>();
        foreach (var pg in _searchResult.Pages)
            for (var i = 0; i < pg.Matches.Count; i++)
                list.Add((pg.PageNum, i));
        return list;
    }

    private async Task GoNextMatch()
    {
        if (_searchResult is null || _searchResult.TotalCount == 0) return;
        _activeMatchIndex = (_activeMatchIndex + 1) % _searchResult.TotalCount;
        await NavigateToActiveMatchAsync();
    }

    private async Task GoPrevMatch()
    {
        if (_searchResult is null || _searchResult.TotalCount == 0) return;
        _activeMatchIndex = (_activeMatchIndex - 1 + _searchResult.TotalCount) % _searchResult.TotalCount;
        await NavigateToActiveMatchAsync();
    }

    private async Task NavigateToActiveMatchAsync()
    {
        if (_searchResult is null) return;
        var matches = BuildMatchList();
        if (_activeMatchIndex >= matches.Count) return;
        var (targetPage, _) = matches[_activeMatchIndex];
        if (targetPage != Page)
        {
            await SetPageAsync(targetPage);
            // OnAfterRenderAsync → RefreshHighlightsAsync will update highlights.
        }
        else
        {
            await RefreshHighlightsAsync();
        }
        StateHasChanged();
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "PageDown":
            case "ArrowRight":
                await SetPageAsync(Page + 1);
                break;
            case "PageUp":
            case "ArrowLeft":
                await SetPageAsync(Page - 1);
                break;
            case "+":
            case "=":
                await SetZoomAsync(Zoom + ZoomStep);
                break;
            case "-":
            case "_":
                await SetZoomAsync(Zoom - ZoomStep);
                break;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is null) return;
        try
        {
            await _module.InvokeVoidAsync("destroy", _canvasId);
            await _module.DisposeAsync();
        }
        catch (JSDisconnectedException) { /* circuit dropped */ }
        catch { /* swallow */ }
    }

    // Matches the { totalPages } object returned by pdf-viewer.js#load.
    // JS-side keys are camelCase; System.Text.Json (used by JSInterop) matches
    // case-insensitively by default, so the PascalCase property name here lines up.
    private class LoadResult
    {
        public int TotalPages { get; set; }
    }

    // Matches { totalCount, pages: [{ pageNum, matches: [{x,y,width,height}] }] }
    private class SearchResult
    {
        public int TotalCount { get; set; }
        public List<SearchPageResult> Pages { get; set; } = [];
    }

    private class SearchPageResult
    {
        public int PageNum { get; set; }
        public List<MatchRect> Matches { get; set; } = [];
    }

    // Matches { x, y, width, height } — CSS pixel coords for the current zoom.
    private class MatchRect
    {
        public double X { get; set; }
        public double Y { get; set; }
        public double Width { get; set; }
        public double Height { get; set; }
    }
}
