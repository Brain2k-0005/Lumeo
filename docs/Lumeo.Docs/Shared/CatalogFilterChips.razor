@namespace Lumeo.Docs.Shared

<div class="flex flex-wrap gap-2">
    <button type="button" data-chip="All"
            class="@ChipClass(null)"
            aria-pressed="@(IsActive(null) ? "true" : "false")"
            @onclick="ClearAll">
        All
    </button>
    @foreach (var c in Categories)
    {
        <button type="button" data-chip="@c"
                class="@ChipClass(c)"
                aria-pressed="@(IsActive(c) ? "true" : "false")"
                @onclick="() => Toggle(c)">
            @c
        </button>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<string> Categories { get; set; } = [];

    /// <summary>
    /// Currently selected categories. Empty (or null) means "no filter — show everything",
    /// which lights up the "All" chip. Multiple values mean union (any-of) filter.
    /// </summary>
    [Parameter] public IReadOnlyCollection<string>? Selected { get; set; }
    [Parameter] public EventCallback<IReadOnlyCollection<string>> SelectedChanged { get; set; }

    private async Task Toggle(string value)
    {
        var next = new HashSet<string>(Selected ?? Array.Empty<string>(), StringComparer.OrdinalIgnoreCase);
        if (!next.Add(value)) next.Remove(value);
        Selected = next;
        await SelectedChanged.InvokeAsync(next);
    }

    private async Task ClearAll()
    {
        Selected = Array.Empty<string>();
        await SelectedChanged.InvokeAsync(Selected);
    }

    private bool IsActive(string? c)
    {
        if (c is null) return Selected is null || Selected.Count == 0;
        return Selected is not null && Selected.Contains(c, StringComparer.OrdinalIgnoreCase);
    }

    private string ChipClass(string? c) => IsActive(c)
        ? "rounded-full px-3 py-1 text-xs font-medium bg-primary text-primary-foreground"
        : "rounded-full px-3 py-1 text-xs font-medium bg-muted/40 text-muted-foreground hover:bg-muted/60 transition-colors";
}
