@namespace Lumeo
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@*
    Floating list rendered above/below a trigger caret. Driven by Items + a
    selected index. Keyboard navigation (Up/Down/Enter/Escape) is handled by
    the parent (the JS suggestion plugin already does this in the live editor;
    this Razor primitive exists for consumers who want to render their own
    trigger UI server-side, e.g. in a Mention input).
*@

<div class="@RootClass" role="listbox" aria-label="@EffectiveAriaLabel" id="@Id" @attributes="AdditionalAttributes">
    @if (Items is null || Items.Count == 0)
    {
        <div class="px-2.5 py-2 text-xs text-muted-foreground">@L["Editor.NoResults"]</div>
    }
    else
    {
        @for (var i = 0; i < Items.Count; i++)
        {
            var idx = i;
            var item = Items[idx];
            var selected = idx == SelectedIndex;
            var rowClass = selected
                ? "flex items-start gap-2 px-2.5 py-1.5 rounded-md cursor-pointer bg-accent text-accent-foreground"
                : "flex items-start gap-2 px-2.5 py-1.5 rounded-md cursor-pointer hover:bg-accent/60";

            <div role="option"
                 aria-selected="@(selected ? "true" : "false")"
                 class="@rowClass"
                 @onpointerdown:preventDefault="true"
                 @onclick="() => OnPick.InvokeAsync(item)"
                 @onmouseenter="() => OnHover.InvokeAsync(idx)">
                @if (ItemTemplate is not null)
                {
                    @ItemTemplate(item)
                }
                else
                {
                    @if (!string.IsNullOrEmpty(item.IconName))
                    {
                        <span class="mt-0.5 text-muted-foreground">
                            <Icon Name="@item.IconName" Size="Lumeo.Size.Sm" />
                        </span>
                    }
                    <div class="min-w-0 flex-1">
                        <div class="text-sm font-medium leading-tight">@item.Label</div>
                        @if (!string.IsNullOrEmpty(item.Subtitle))
                        {
                            <div class="text-xs text-muted-foreground leading-tight">@item.Subtitle</div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    /// <summary>Element id for the listbox root, so an owning trigger input can point
    /// <c>aria-controls</c>/<c>aria-activedescendant</c> at it.</summary>
    [Parameter] public string? Id { get; set; }
    /// <summary>The suggestion items to list. An empty or null list renders a
    /// localized "no results" message instead.</summary>
    [Parameter] public IReadOnlyList<TriggerItem>? Items { get; set; }
    /// <summary>0-based index of the currently highlighted item. Keyboard navigation
    /// (Up/Down/Enter/Escape) is the caller's responsibility — this component only
    /// renders the highlight and reacts to pointer interaction.</summary>
    [Parameter] public int SelectedIndex { get; set; }
    /// <summary>Custom render fragment for a row's content, receiving the item. When
    /// null, renders the item's icon, label, and subtitle.</summary>
    [Parameter] public RenderFragment<TriggerItem>? ItemTemplate { get; set; }
    /// <summary>Raised with the item the user clicked (or activated).</summary>
    [Parameter] public EventCallback<TriggerItem> OnPick { get; set; }
    /// <summary>Raised with the item's index when the pointer hovers a row, so a
    /// caller can sync <see cref="SelectedIndex"/> to mouse movement.</summary>
    [Parameter] public EventCallback<int> OnHover { get; set; }
    /// <summary>Accessible label for the listbox. Falls back to the localized
    /// "Editor.Suggestions" string when null.</summary>
    [Parameter] public string? AriaLabel { get; set; }
    /// <summary>Additional CSS classes merged onto the root <c>div</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string EffectiveAriaLabel => AriaLabel ?? L["Editor.Suggestions"];

    private string RootClass =>
        $"min-w-[200px] max-w-[340px] max-h-[280px] overflow-y-auto rounded-lg border border-border/60 bg-popover text-popover-foreground shadow-lg p-1 {Class}".Trim();
}
