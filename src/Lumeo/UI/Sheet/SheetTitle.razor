@namespace Lumeo

<h2 id="@Context.TitleId" class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</h2>

@code {
    [CascadingParameter] public Sheet.SheetContext Context { get; set; } = default!;
    /// <summary>The title text, exposed to assistive tech via <c>aria-labelledby</c> on the panel (the accessible name of the <c>role="dialog"</c> sheet).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Additional CSS classes merged onto the title <c>&lt;h2&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Captures any unmatched attributes and applies them to the title <c>&lt;h2&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("text-lg font-semibold text-foreground", Class);
}
