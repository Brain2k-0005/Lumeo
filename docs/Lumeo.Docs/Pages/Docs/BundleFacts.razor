        new("Paintbrush", "lumeo.css",
            "16 KB",
            "Theme tokens and dark-mode variable swaps. CSS-only — switching themes is a variable swap, not a C# rebuild."),
        new("Cpu", "Lumeo.SourceGenerators.dll",
