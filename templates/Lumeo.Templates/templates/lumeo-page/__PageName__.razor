@page "/__PageRoute__"

<PageTitle>__PageName__</PageTitle>

@*
    Lumeo page scaffold.
    Patterns shown:
      - Container + Stack for the document grid.
      - Heading + Lumeo.Text for the page title + description (theme typography).
      - Card with header + content for the primary surface.
      - Button + EventCallback for the action wiring.
*@

<Container MaxWidth="5xl">
    <Stack Gap="6" Class="py-8">
        <Stack Gap="2">
            <Heading Level="1" Size="3xl">__PageName__</Heading>
            <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
                Replace this with your page description.
            </Lumeo.Text>
        </Stack>

        <Card>
            <CardHeader>
                <Stack Gap="1">
                    <Heading Level="3" Size="lg">Get started</Heading>
                    <Lumeo.Text Size="sm" Color="muted">
                        Edit <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">__PageName__.razor</code>
                        to build your page. The Lumeo templates scaffolded this file with conventions —
                        keep using <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Container</code>,
                        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Stack</code>, and
                        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Card</code> for new sections.
                    </Lumeo.Text>
                </Stack>
            </CardHeader>
            <CardContent>
                <Flex Gap="2">
                    <Button Variant="Button.ButtonVariant.Default" OnClick="HandleClick">
                        Click me
                    </Button>
                    <Button Variant="Button.ButtonVariant.Outline" OnClick="HandleSecondary">
                        Secondary
                    </Button>
                </Flex>
            </CardContent>
        </Card>
    </Stack>
</Container>

@code {
    private async Task HandleClick()
    {
        // TODO: primary action.
        await Task.CompletedTask;
    }

    private async Task HandleSecondary()
    {
        // TODO: secondary action.
        await Task.CompletedTask;
    }
}
