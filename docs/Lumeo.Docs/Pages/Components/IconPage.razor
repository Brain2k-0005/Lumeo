@page "/components/icon"
@inject Lumeo.Docs.Services.IconService IconService
@inject IJSRuntime JS
@implements IDisposable
@using Lumeo.Docs.Shared

<PageTitle>Icon — Lumeo</PageTitle>

<PageHeader Title="Icon" Description="A thin wrapper around Blazicons that gives Lumeo a native icon API. Pick from ~100 common icons by name, size via presets, or pass any Blazicons SvgIcon through the Svg parameter." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Any place you'd otherwise write <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Blazicon Svg="Lucide.X"&gt;</code> — use <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;Icon Name="X"&gt;</code> instead.</li>
        <li>Hides the Blazicons dependency from your component code.</li>
        <li>Consistent <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Class</code> convention (rather than lowercase <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">class</code>).</li>
        <li>Lets Lumeo swap the icon provider in a future release without breaking consumer code.</li>
    </ul>
</div>

<Stack Gap="8">

    <ComponentDemo Title="Basic" Description="Pass a Lucide icon name in PascalCase." Code="@_basicCode">
        <Flex Gap="3" Align="center">
            <Icon Name="Search" />
            <Icon Name="Heart" />
            <Icon Name="Star" />
            <Icon Name="Bell" />
            <Icon Name="Settings" />
            <Icon Name="ChevronDown" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Sizes" Description="Presets via the Size parameter: Xs (h-3), Sm (h-3.5), Md (h-4, default), Lg (h-5), Xl (h-6)." Code="@_sizesCode">
        <Flex Gap="4" Align="center">
            <Icon Name="Heart" Size="Icon.IconSize.Xs" />
            <Icon Name="Heart" Size="Icon.IconSize.Sm" />
            <Icon Name="Heart" />
            <Icon Name="Heart" Size="Icon.IconSize.Lg" />
            <Icon Name="Heart" Size="Icon.IconSize.Xl" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Color via Class" Description="Icons inherit currentColor, so any Tailwind text-* class tints them." Code="@_colorCode">
        <Flex Gap="4" Align="center">
            <Icon Name="CircleCheck" Class="text-success" />
            <Icon Name="CircleAlert" Class="text-destructive" />
            <Icon Name="TriangleAlert" Class="text-warning" />
            <Icon Name="Info" Class="text-info" />
            <Icon Name="Star" Class="text-primary" />
            <Icon Name="BadgeCheck" Class="text-muted-foreground" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Inside buttons" Description="Drop into any Lumeo component that takes a RenderFragment — Button, Badge, Alert, Card, etc." Code="@_buttonCode">
        <Flex Gap="3" Align="center" Class="flex-wrap">
            <Button>
                <Icon Name="Plus" Class="mr-2" />
                New project
            </Button>
            <Button Variant="Button.ButtonVariant.Outline">
                <Icon Name="Download" Class="mr-2" />
                Download
            </Button>
            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                <Icon Name="Settings" />
            </Button>
            <Button Variant="Button.ButtonVariant.Destructive">
                <Icon Name="Trash" Class="mr-2" />
                Delete
            </Button>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Direct Svg escape hatch" Description="Pass any Blazicons SvgIcon through the Svg parameter — works across Lucide, Bootstrap, FluentUI, Material, FontAwesome, Ionicons, and MDI." Code="@_svgCode">
        <Flex Gap="4" Align="center">
            <Icon Svg="Blazicons.Lucide.Search" />
            <Icon Svg="Blazicons.BootstrapIcon.Archive" />
            <Icon Svg="Blazicons.FluentUiIcon.Alert" />
            <Icon Svg="Blazicons.GoogleMaterialOutlinedIcon.Home" />
            <Icon Svg="Blazicons.FontAwesomeSolidIcon.Heart" />
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Browse &amp; search" Description="Find an icon by name, preview it across every Blazicons library, and copy a ready-to-paste snippet for your code." OverflowVisible="true">
        <Stack Gap="4" Class="w-full">

            @* Search + library selector *@
            <Flex Gap="2" Align="center" Class="flex-wrap">
                <div class="flex-1 min-w-[220px] relative">
                    <div class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground">
                        <DynamicIcon Name="Search" Class="h-4 w-4" />
                    </div>
                    <Input Value="@_query"
                           ValueChanged="@((string v) => { _query = v; _selected = null; })"
                           Placeholder="Search 130+ icons — try 'chevron', 'chart', 'user'…"
                           Class="pl-9" />
                </div>
                <Select Value="@IconService.ActiveLibrary" ValueChanged="@((string v) => IconService.SetLibrary(v))">
                    <SelectTrigger Class="w-[180px]">
                        <span class="text-sm">@LibraryDisplayName(IconService.ActiveLibrary)</span>
                    </SelectTrigger>
                    <SelectContent>
                        <SelectItem Value="lucide">Lucide (default)</SelectItem>
                        <SelectItem Value="bootstrap">Bootstrap Icons</SelectItem>
                        <SelectItem Value="fluentui">Fluent UI</SelectItem>
                        <SelectItem Value="google-material">Google Material</SelectItem>
                        <SelectItem Value="font-awesome">Font Awesome</SelectItem>
                        <SelectItem Value="ionicons">Ionicons</SelectItem>
                        <SelectItem Value="material-design">Material Design</SelectItem>
                    </SelectContent>
                </Select>
            </Flex>

            <Lumeo.Text Size="xs" Color="muted">
                Showing @Filtered.Count of @_fullCatalog.Length icons via @LibraryDisplayName(IconService.ActiveLibrary).
                @if (IconService.ActiveLibrary != "lucide")
                {
                    <span>Non-Lucide icons use the <code class="font-mono text-[11px]">Svg</code> escape hatch.</span>
                }
            </Lumeo.Text>

            @* Icon grid *@
            <div class="rounded-md border border-border/40 p-3 max-h-[360px] overflow-y-auto">
                @if (Filtered.Count == 0)
                {
                    <div class="flex flex-col items-center gap-2 py-8 text-muted-foreground">
                        <DynamicIcon Name="SearchX" Class="h-8 w-8 text-muted-foreground/50" />
                        <Lumeo.Text Size="sm">No icons match "<span class="text-foreground">@_query</span>"</Lumeo.Text>
                    </div>
                }
                else
                {
                    <div class="grid grid-cols-4 sm:grid-cols-6 md:grid-cols-8 lg:grid-cols-10 gap-1">
                        @foreach (var name in Filtered)
                        {
                            var n = name;
                            var isActive = _selected == n;
                            <button type="button"
                                    @onclick="@(() => _selected = n)"
                                    class="@($"flex flex-col items-center gap-1 p-2 rounded-md transition-colors text-xs {(isActive ? "bg-accent text-foreground" : "hover:bg-accent/60 text-muted-foreground hover:text-foreground")}")">
                                <DynamicIcon Name="@n" Class="h-5 w-5" />
                                <span class="truncate max-w-full">@n</span>
                            </button>
                        }
                    </div>
                }
            </div>

            @* Selected icon detail + copy-paste snippet *@
            @if (_selected is not null)
            {
                <div class="rounded-md border border-border/40 bg-muted/30 p-4">
                    <Flex Align="center" Justify="between" Gap="3" Class="mb-3 flex-wrap">
                        <Flex Align="center" Gap="3">
                            <div class="flex h-12 w-12 items-center justify-center rounded-md bg-background border border-border/40">
                                <DynamicIcon Name="@_selected" Class="h-6 w-6" />
                            </div>
                            <Stack Gap="0">
                                <Lumeo.Text Weight="medium">@_selected</Lumeo.Text>
                                <Lumeo.Text Size="xs" Color="muted">via @LibraryDisplayName(IconService.ActiveLibrary)</Lumeo.Text>
                            </Stack>
                        </Flex>
                        <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="CopySnippet">
                            @if (_copied)
                            {
                                <Icon Name="Check" Class="mr-2" /> <text>Copied</text>
                            }
                            else
                            {
                                <Icon Name="Copy" Class="mr-2" /> <text>Copy</text>
                            }
                        </Button>
                    </Flex>
                    <pre class="rounded bg-background border border-border/40 p-3 text-xs font-mono overflow-x-auto whitespace-pre">@SnippetForSelected</pre>
                </div>
            }
        </Stack>
    </ComponentDemo>

</Stack>

<div class="mt-12">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>
    <div class="mt-4 rounded-lg border border-border/40 overflow-hidden">
        <table class="w-full text-sm">
            <thead>
                <tr class="border-b border-border/40 bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Name</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">PascalCase Lucide icon name. Unknown names fall back to <code class="font-mono text-xs">Circle</code>.</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Svg</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">SvgIcon?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">Direct Blazicons icon. Takes precedence over <code class="font-mono text-xs">Name</code>.</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Size</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">Icon.IconSize</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">Md</td>
                    <td class="p-3 text-muted-foreground">Xs (h-3) · Sm (h-3.5) · Md (h-4) · Lg (h-5) · Xl (h-6).</td>
                </tr>
                <tr>
                    <td class="p-3 font-mono text-xs text-primary">Class</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                    <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                    <td class="p-3 text-muted-foreground">Extra CSS classes appended after the size class.</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/dynamic-icon" class="text-primary hover:underline">DynamicIcon</a> — docs-only multi-library variant used by the theme customizer.</li>
        <li><a href="https://github.com/AlenToma/Blazicons" class="text-primary hover:underline" target="_blank">Blazicons</a> — the underlying icon library Lumeo wraps.</li>
    </ul>
</div>

@code {
    // ── Icon browser state ────────────────────────────────────────────────────
    private string _query = "";
    private string? _selected;
    private bool _copied;

    private List<string> Filtered => string.IsNullOrWhiteSpace(_query)
        ? _fullCatalog.ToList()
        : _fullCatalog.Where(n => n.Contains(_query, StringComparison.OrdinalIgnoreCase)).ToList();

    private string SnippetForSelected
    {
        get
        {
            if (_selected is null) return "";
            return IconService.ActiveLibrary switch
            {
                "lucide"          => $"<Icon Name=\"{_selected}\" />",
                "bootstrap"       => $"<Icon Svg=\"BootstrapIcon.{_selected}\" />          @* via Svg escape hatch *@",
                "fluentui"        => $"<Icon Svg=\"FluentUiIcon.{_selected}\" />",
                "google-material" => $"<Icon Svg=\"GoogleMaterialOutlinedIcon.{_selected}\" />",
                "font-awesome"    => $"<Icon Svg=\"FontAwesomeSolidIcon.{_selected}\" />",
                "ionicons"        => $"<Icon Svg=\"Ionicon.{_selected}\" />",
                "material-design" => $"<Icon Svg=\"MdiIcon.{_selected}\" />",
                _ => $"<Icon Name=\"{_selected}\" />",
            };
        }
    }

    private static string LibraryDisplayName(string key) => key switch
    {
        "lucide"          => "Lucide",
        "bootstrap"       => "Bootstrap Icons",
        "fluentui"        => "Fluent UI",
        "google-material" => "Google Material",
        "font-awesome"    => "Font Awesome",
        "ionicons"        => "Ionicons",
        "material-design" => "Material Design",
        _ => key,
    };

    private async Task CopySnippet()
    {
        if (_selected is null) return;
        try { await JS.InvokeVoidAsync("navigator.clipboard.writeText", SnippetForSelected); } catch { }
        _copied = true;
        StateHasChanged();
        await Task.Delay(1500);
        _copied = false;
        StateHasChanged();
    }

    protected override void OnInitialized()
    {
        IconService.OnChange += OnLibChanged;
    }

    private void OnLibChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        IconService.OnChange -= OnLibChanged;
    }

    // Full icon catalog — the complete set of names supported by DynamicIcon
    // across all 7 Blazicons libraries. These are the names the browser surfaces.
    private static readonly string[] _fullCatalog =
    {
        "Accessibility", "AlignCenter", "AlignLeft", "AlignRight", "Archive",
        "ArrowDown", "ArrowLeft", "ArrowRight", "ArrowUp", "BarChart3", "Bell",
        "BellOff", "Blocks", "Bold", "Box", "Calendar", "CalendarDays", "Camera",
        "ChartBar", "Check", "CheckCheck", "CheckSquare", "ChevronDown",
        "ChevronLeft", "ChevronRight", "ChevronUp", "ChevronsUpDown", "Chrome",
        "CircleAlert", "CircleCheck", "CircleDot", "Clipboard", "ClipboardList",
        "Code", "Columns3", "Copy", "Disc", "Download", "Ellipsis", "ExternalLink",
        "Eye", "FileText", "Flag", "FolderOpen", "Github", "Globe", "Heart",
        "Home", "House", "Image", "Inbox", "Info", "Italic", "LayoutDashboard",
        "LayoutGrid", "LayoutTemplate", "List", "ListMusic", "Loader",
        "LoaderCircle", "Lock", "LogIn", "LogOut", "Mail", "Menu", "MessageCircle",
        "MessageSquare", "Mic", "Minus", "Moon", "MousePointerClick", "Music",
        "Package", "Paintbrush", "Palette", "PanelRightClose", "PanelRightOpen",
        "Pause", "Pencil", "Phone", "Pin", "Play", "Plus", "Radio", "RefreshCw",
        "RotateCcw", "Search", "SearchX", "Send", "Settings", "Share", "Share2",
        "Shield", "ShieldCheck", "ShoppingCart", "SkipBack", "SkipForward",
        "Slash", "SlidersHorizontal", "Smartphone", "Star", "Sun", "Tag", "Trash",
        "Trash2", "TrendingUp", "TriangleAlert", "Underline", "Upload", "User",
        "UserPlus", "Users", "Volume", "Volume1", "Volume2", "X", "Zap",
    };

    private string _basicCode = @"<Icon Name=""Search"" />
<Icon Name=""Heart"" />
<Icon Name=""Star"" />
<Icon Name=""Bell"" />
<Icon Name=""Settings"" />
<Icon Name=""ChevronDown"" />";

    private string _sizesCode = @"<Icon Name=""Heart"" Size=""Icon.IconSize.Xs"" />
<Icon Name=""Heart"" Size=""Icon.IconSize.Sm"" />
<Icon Name=""Heart"" />                      @* Md (default) *@
<Icon Name=""Heart"" Size=""Icon.IconSize.Lg"" />
<Icon Name=""Heart"" Size=""Icon.IconSize.Xl"" />";

    private string _colorCode = @"<Icon Name=""CircleCheck""   Class=""text-success"" />
<Icon Name=""CircleAlert""   Class=""text-destructive"" />
<Icon Name=""TriangleAlert"" Class=""text-warning"" />
<Icon Name=""Info""          Class=""text-info"" />
<Icon Name=""Star""          Class=""text-primary"" />";

    private string _buttonCode = @"<Button>
    <Icon Name=""Plus"" Class=""mr-2"" />
    New project
</Button>

<Button Variant=""Button.ButtonVariant.Ghost"" Size=""Button.ButtonSize.Icon"">
    <Icon Name=""Settings"" />
</Button>";

    private string _svgCode = @"@using Blazicons

<Icon Svg=""Lucide.Search"" />
<Icon Svg=""BootstrapIcon.Archive"" />
<Icon Svg=""FluentUiIcon.Alert"" />
<Icon Svg=""GoogleMaterialOutlinedIcon.Home"" />
<Icon Svg=""FontAwesomeSolidIcon.Heart"" />";

}
