@code {
    record TabModel(string Id, string Label, string Body);

    string _active = ""overview"";
    List<TabModel> _tabs = new()
    {
        new(""overview"",  ""Overview"",  ""Welcome page.""),
        new(""metrics"",   ""Metrics"",   ""Numbers and graphs.""),
        new(""settings"",  ""Settings"",  ""Configuration.""),
    };

    Task HandleReorder(TabsReorderEventArgs e)
    {
        // The library has *not* changed anything yet — we own the collection.
        var moved = _tabs[e.FromIndex];
        _tabs.RemoveAt(e.FromIndex);
        _tabs.Insert(e.ToIndex, moved);
        // Optional: PersistAsync(_tabs.Select(t => t.Id));
        return Task.CompletedTask;
    }
}";

