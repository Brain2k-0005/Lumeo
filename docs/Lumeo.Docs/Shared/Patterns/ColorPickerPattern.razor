@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic ColorPicker" Code="@_codeBasic">
    <ColorPicker @bind-Value="_color1" />
</PatternCard>

<PatternCard Label="With Presets" Code="@_codePresets">
    <ColorPicker @bind-Value="_color2" Presets="@_presets" />
</PatternCard>
</Stack>

@code {
    private string _color1 = "#3b82f6";
    private string _color2 = "#10b981";

    private List<string> _presets = new()
    {
        "#ef4444", "#f97316", "#eab308", "#22c55e", "#3b82f6", "#8b5cf6", "#ec4899"
    };

    private string _codeBasic = @"<ColorPicker @bind-Value=""_color"" />";

    private string _codePresets = @"<ColorPicker @bind-Value=""_color"" Presets=""@_presets"" />";
}
