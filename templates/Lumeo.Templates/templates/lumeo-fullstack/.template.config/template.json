{
  "$schema": "http://json.schemastore.org/template",
  "author": "nativ.sh",
  "classifications": ["Blazor", "Lumeo", "Web", "WebAssembly", "API", "Identity", "Full-stack"],
  "identity": "Lumeo.Templates.FullStack",
  "name": "Lumeo Full-Stack App (API + Auth + Email)",
  "shortName": "lumeo-fullstack",
  "sourceName": "MyApp",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/*.user"
          ]
        }
      ]
    }
  ],
  "primaryOutputs": [
    { "path": "MyApp.sln" },
    { "path": "src/MyApp.Api/MyApp.Api.csproj" },
    { "path": "src/MyApp.Client/MyApp.Client.csproj" }
  ]
}
