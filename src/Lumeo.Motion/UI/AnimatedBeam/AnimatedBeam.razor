@namespace Lumeo
@implements IAsyncDisposable
@inject ComponentInteropService Interop

<svg id="@_elementId"
     class="@CssClass"
     aria-hidden="true"
     style="position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;overflow:visible;"
     @attributes="AdditionalAttributes">
    <defs>
        <linearGradient id="@_gradientId" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="@Color" stop-opacity="0" />
            <stop offset="50%" stop-color="@Color" stop-opacity="@Opacity.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)" />
            <stop offset="100%" stop-color="@Color" stop-opacity="0" />
        </linearGradient>
    </defs>
    @* Path drawn by JS after measuring DOM positions *@
    <path id="@(_elementId + "-path")" stroke="var(--color-border)" stroke-width="@PathWidth" fill="none" stroke-opacity="0.4" />
    <path id="@(_elementId + "-beam")" stroke="url(#@_gradientId)" stroke-width="@BeamWidth" fill="none" />
</svg>

@code {
    /// <summary>The element id of the "from" node. Use <c>id="..."</c> on the source element.</summary>
    [Parameter] public string? FromId { get; set; }
    /// <summary>The element id of the "to" node.</summary>
    [Parameter] public string? ToId { get; set; }
    /// <summary>Duration of one full beam traversal in milliseconds.</summary>
    [Parameter] public int DurationMs { get; set; } = 3000;
    /// <summary>Delay before the first animation cycle starts.</summary>
    [Parameter] public int DelayMs { get; set; } = 0;
    /// <summary>Curvature of the bezier path (0 = straight line).</summary>
    [Parameter] public double Curvature { get; set; } = 0.3;
    /// <summary>CSS color of the animated beam gradient.</summary>
    [Parameter] public string Color { get; set; } = "var(--color-primary)";
    /// <summary>Opacity of the beam gradient peak (0–1).</summary>
    [Parameter] public double Opacity { get; set; } = 0.85;
    /// <summary>Width of the background guide path in px.</summary>
    [Parameter] public double PathWidth { get; set; } = 1;
    /// <summary>Width of the animated beam stroke in px.</summary>
    [Parameter] public double BeamWidth { get; set; } = 2;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _elementId = $"lumeo-animated-beam-{Guid.NewGuid():N}";
    private readonly string _gradientId = $"lumeo-beam-grad-{Guid.NewGuid():N}";
    private bool _registered;

    private string CssClass => string.Join(" ", new[] { "lumeo-animated-beam", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_registered && !string.IsNullOrEmpty(FromId) && !string.IsNullOrEmpty(ToId))
        {
            _registered = true;
            try
            {
                await Interop.MotionAnimatedBeam(_elementId, FromId, ToId, new
                {
                    durationMs = DurationMs,
                    delayMs = DelayMs,
                    curvature = Curvature
                });
            }
            catch (JSDisconnectedException) { }
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_registered)
        {
            await Interop.MotionDisposeAnimatedBeam(_elementId);
        }
    }
}
