@page "/weather"
@implements IDisposable

<PageTitle>Weather — MyApp</PageTitle>

@* The weather forecast you know from the standard Blazor template — rebuilt with Lumeo.
   Vanilla → Lumeo mapping:
     <table class="table">…</table>   →  a sortable <DataGrid>
     "Loading…" while data streams    →  IsLoading drives a skeleton on a simulated fetch
     plain <td>@temp</td>             →  a coloured temperature <Badge>
   The sample data is seeded from a FIXED Random seed, so the forecast is identical
   on every run — no runtime nondeterminism. *@

<Stack Gap="6">
    <Stack Gap="1">
        <Heading Level="1" Size="2xl">Weather</Heading>
        <Lumeo.Text Color="muted">
            The classic forecast, rebuilt with Lumeo — the raw
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">&lt;table&gt;</code> becomes a sortable
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">DataGrid</code> that shows a skeleton while the (simulated) fetch runs.
        </Lumeo.Text>
    </Stack>

    <Card>
        <CardHeader>
            <Flex Align="center" Justify="between" Gap="3">
                <Stack Gap="1">
                    <Heading Level="2" Size="lg">5-day forecast</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Click a column header to sort.</Lumeo.Text>
                </Stack>
                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="Reload" Disabled="_loading">
                    @if (_loading)
                    {
                        <Spinner Size="Lumeo.Size.Sm" Class="mr-2" />
                        <span>Loading…</span>
                    }
                    else
                    {
                        <SvgGlyph Svg="@(LumeoIcons.RefreshCw)" class="mr-2 h-3.5 w-3.5" />
                        <span>Reload</span>
                    }
                </Button>
            </Flex>
        </CardHeader>
        <CardContent>
            <DataGrid TItem="Forecast" Items="_forecasts" IsLoading="_loading"
                      PageSize="5" ShowPagination="false" Striped="true" Hoverable="true">
                <DataGridColumnDef TItem="Forecast" Title="Date" Field="Date" Sortable="true" Format="ddd, MMM d" />
                <DataGridColumnDef TItem="Forecast" Title="Temp. (°C)" Field="TempC" Sortable="true">
                    <CellTemplate Context="f">
                        <Badge Variant="@TempVariant(f.TempC)" Class="tabular-nums">@f.TempC °C</Badge>
                    </CellTemplate>
                </DataGridColumnDef>
                <DataGridColumnDef TItem="Forecast" Title="Temp. (°F)" Field="TempF" Sortable="true" />
                <DataGridColumnDef TItem="Forecast" Title="Summary" Field="Summary" Sortable="true" />
            </DataGrid>
        </CardContent>
    </Card>
</Stack>

@code {
    private sealed record Forecast(DateTime Date, int TempC, string Summary)
    {
        // Same conversion the vanilla WeatherForecast sample uses.
        public int TempF => 32 + (int)(TempC / 0.5556);
    }

    private static readonly string[] _summaries =
        ["Freezing", "Bracing", "Chilly", "Cool", "Mild", "Warm", "Balmy", "Hot", "Sweltering", "Scorching"];

    private bool _loading = true;
    private List<Forecast> _forecasts = new();
    private System.Threading.Timer? _timer;

    protected override void OnInitialized()
    {
        _forecasts = BuildForecasts();
        StartFetch();
    }

    // Fixed-seed Random ⇒ the same five rows every run (deterministic template output).
    private static List<Forecast> BuildForecasts()
    {
        var rng = new Random(1234);
        var start = new DateTime(2026, 1, 1);
        return Enumerable.Range(1, 5)
            .Select(i => new Forecast(start.AddDays(i), rng.Next(-6, 35), _summaries[rng.Next(_summaries.Length)]))
            .ToList();
    }

    private void StartFetch()
    {
        _loading = true;
        _timer?.Dispose();
        // Simulate a network round-trip; IsLoading shows the DataGrid skeleton meanwhile.
        _timer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            _loading = false;
            StateHasChanged();
        }), null, 900, System.Threading.Timeout.Infinite);
    }

    private void Reload()
    {
        StartFetch();
        StateHasChanged();
    }

    private static Badge.BadgeVariant TempVariant(int c) => c switch
    {
        < 0 => Badge.BadgeVariant.Secondary,
        < 12 => Badge.BadgeVariant.Default,
        < 25 => Badge.BadgeVariant.Success,
        _ => Badge.BadgeVariant.Destructive,
    };

    public void Dispose() => _timer?.Dispose();
}
