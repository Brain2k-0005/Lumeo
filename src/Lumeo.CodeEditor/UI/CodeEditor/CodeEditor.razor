@namespace Lumeo
@inject Services.ComponentInteropService Interop
@implements IAsyncDisposable

@*
    CodeEditor — CodeMirror 6 wrapper.

    Why CodeMirror over Monaco:
      - Monaco's WASM/worker bundle is 5MB+; awkward on Cloudflare Pages
        (25MB asset ceiling) and slow to first-paint on Blazor WASM.
      - CodeMirror 6 is modular: ~150KB core + tiny language packs imported
        on demand from esm.sh, so a JSON-only page only pays for JSON.

    Language packs are loaded lazily via `import('https://esm.sh/@codemirror/lang-X')`
    from inside the JS module. Switching languages re-imports only the new pack.
*@

<div class="@RootClass"
     role="@(ReadOnly ? "document" : "textbox")"
     aria-label="@(Placeholder ?? "Code editor")"
     @attributes="AdditionalAttributes">
    <div id="@_editorId" style="height: @Height" class="lumeo-code-editor h-full w-full"></div>
</div>

@code {
    /// <summary>The document text. Two-way bindable via <see cref="ValueChanged"/>; when
    /// bound, an incoming change that doesn't match the last value this editor pushed is
    /// treated as authoritative and rolls CodeMirror back via <c>setValue</c>. Unbound
    /// (uncontrolled) usage only re-syncs on a genuine parameter change, so the caret and
    /// in-flight typing survive unrelated re-renders.</summary>
    [Parameter] public string? Value { get; set; }
    /// <summary>Raised on every edit with the document's current text.</summary>
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    /// <summary>
    /// Source language. Currently supported: csharp, javascript, typescript, html,
    /// css, json, markdown, xml, sql, python, plaintext. Unknown values fall back
    /// to plaintext.
    /// </summary>
    [Parameter] public string Language { get; set; } = "plaintext";

    /// <summary>light | dark | auto (follows page theme via the `dark` class on &lt;html&gt;).</summary>
    [Parameter] public string Theme { get; set; } = "auto";

    /// <summary>CSS height of the editor viewport (e.g. <c>400px</c>, <c>100%</c>).
    /// Applied as an inline <c>style</c> on the CodeMirror host element.</summary>
    [Parameter] public string Height { get; set; } = "400px";
    /// <summary>Shows the gutter line-number column. Default <c>true</c>.</summary>
    [Parameter] public bool LineNumbers { get; set; } = true;
    /// <summary>Makes the document non-editable (CodeMirror's read-only mode) and sets
    /// <c>role="document"</c> instead of <c>role="textbox"</c> for assistive tech.</summary>
    [Parameter] public bool ReadOnly { get; set; }

    /// <summary>
    /// Shows a scrollbar-side minimap of the document. CodeMirror 6 has no
    /// built-in minimap, so this lazily loads the <c>@@replit/codemirror-minimap</c>
    /// extension from <see cref="EsmBase"/> on first enable. If that import fails
    /// (e.g. offline with no self-hosted copy of the package) the editor degrades
    /// gracefully — the rest of the editor keeps working, just without a minimap.
    /// Toggling at runtime adds/removes the extension without losing selection
    /// or scroll position.
    /// </summary>
    [Parameter] public bool ShowMinimap { get; set; }

    /// <summary>
    /// Base URL the CodeMirror core, language packs, theme, and minimap are
    /// imported from. Defaults to the public esm.sh CDN. Point this at a
    /// self-hosted ESM mirror (or a path served by your own app) for
    /// air-gapped / offline / strict-CSP deployments — e.g.
    /// <c>EsmBase="/_content/MyApp/esm"</c> or <c>EsmBase="https://esm.myco.internal"</c>.
    /// A trailing slash is optional. When null, falls back to the global
    /// <c>window.lumeoCdn.codeMirrorBase</c> override (if set) and then esm.sh.
    /// </summary>
    [Parameter] public string? EsmBase { get; set; }

    /// <summary>Number of columns a tab/indent level occupies. Default <c>4</c>.</summary>
    [Parameter] public int TabSize { get; set; } = 4;
    /// <summary>Inserts literal tab characters on Tab instead of spaces sized to
    /// <see cref="TabSize"/>. Default <c>false</c> (spaces).</summary>
    [Parameter] public bool UseTabs { get; set; }

    /// <summary>"off" | "on"</summary>
    [Parameter] public string WordWrap { get; set; } = "off";

    /// <summary>Placeholder text shown when the document is empty; also used as the
    /// element's <c>aria-label</c> when set.</summary>
    [Parameter] public string? Placeholder { get; set; }

    /// <summary>Fires alongside ValueChanged; provided for symmetry with Monaco-style APIs.</summary>
    [Parameter] public EventCallback<string> OnChange { get; set; }

    /// <summary>Additional CSS classes merged onto the root wrapper <c>div</c>.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the root wrapper <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _editorId = $"lumeo-code-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<CodeEditor>? _selfRef;
    private bool _initialized;
    private string? _lastSyncedValue;
    // The last Value the PARENT actually supplied via the parameter. Tracked
    // separately from _lastSyncedValue (which our own OnEditorChange echo
    // mutates) so an unrelated parent re-render that re-supplies the SAME
    // Value never pushes a destructive full-doc setValue back into CodeMirror
    // and reverts the user's in-progress edit. Only a genuine parameter change
    // arms the JS push. Used for the UNCONTROLLED path only.
    private string? _lastValueParam;
    // CONTROLLED discriminator: the last value we pushed UP to the parent via
    // ValueChanged. When ValueChanged is bound (controlled), OnParametersSet
    // compares the incoming Value against this — not _lastValueParam — so that
    // a rejection (parent keeps its OLD value, which equals _lastValueParam but
    // differs from what we just pushed) is correctly detected and setValue is
    // called to roll CodeMirror back. The echo of our own accepted edit
    // (Value == _lastPushed) suppresses setValue so the caret is preserved.
    private string? _lastPushed;
    private bool _valueParamChanged;
    private bool _firstParametersSet = true;
    private string? _lastLanguage;
    private string? _lastTheme;
    private bool? _lastReadOnly;
    private bool? _lastShowMinimap;

    private string RootClass
        => $"rounded-lg border border-border/40 overflow-hidden bg-card {Class}".Trim();

    protected override void OnParametersSet()
    {
        // Detect whether the PARENT changed the Value parameter since the last
        // set. The very first set seeds the baseline (the editor is created with
        // this value in OnAfterRenderAsync's firstRender path) and must not arm a
        // redundant push. After that, only a real parameter change arms the JS
        // setValue — an unrelated re-render that re-supplies the same Value (or
        // echoes back our own OnEditorChange value) leaves _valueParamChanged
        // false, so the user's in-progress edit and caret survive.
        if (_firstParametersSet)
        {
            _firstParametersSet = false;
            _lastValueParam = Value;
            _lastPushed = Value;
            return;
        }

        if (ValueChanged.HasDelegate)
        {
            // CONTROLLED: compare incoming Value against _lastPushed (the value we
            // last emitted via ValueChanged) rather than _lastValueParam. When they
            // differ, the parent asserted authority — a rejection that kept the old
            // value, a normalization, or a programmatic reset — so arm setValue to
            // roll CodeMirror back to the authoritative value. When they match it's
            // the echo of our own accepted edit; suppress setValue to preserve the
            // caret and in-flight typing.
            if (!string.Equals(Value, _lastPushed, StringComparison.Ordinal))
            {
                _valueParamChanged = true;
                _lastPushed = Value;
            }
        }
        else if (!string.Equals(_lastValueParam ?? string.Empty, Value ?? string.Empty, StringComparison.Ordinal))
        {
            // UNCONTROLLED: no ValueChanged binding — keep the existing discriminator.
            // Only adopt a genuine external Value change; an unrelated re-render that
            // re-supplies the same (or stale) Value must not clobber the user's edit.
            _valueParamChanged = true;
            _lastValueParam = Value;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);

            // Trim safety: anonymous types crossing JS interop lose their constructor
            // parameter names under a trimmed publish, and JSRuntime's reflection-based
            // serializer throws NotSupportedException("ConstructorContainsNullParameterNames")
            // at runtime (same class of bug as BlurFade/PreventDefaultKeyRule). Use a
            // Dictionary instead — identical JSON, no constructor metadata involved.
            var options = new Dictionary<string, object?>
            {
                ["value"] = Value ?? string.Empty,
                ["language"] = Language,
                ["theme"] = Theme,
                ["lineNumbers"] = LineNumbers,
                ["readOnly"] = ReadOnly,
                ["tabSize"] = TabSize,
                ["useTabs"] = UseTabs,
                ["wordWrap"] = WordWrap,
                ["placeholder"] = Placeholder,
                ["minimap"] = ShowMinimap,
                ["esmBase"] = EsmBase,
            };

            // Guard the whole init path: if the module import or the JS init
            // throws (offline with no self-hosted ESM mirror, CSP block, circuit
            // drop mid-init), we must not leave a half-built instance behind —
            // dispose the DotNetObjectReference and the partially-loaded module
            // so there's no managed/JS object leak. _initialized stays false so
            // later parameter syncs and DisposeAsync short-circuit cleanly.
            try
            {
                _module = await Interop.ImportModuleAsync("./_content/Lumeo.CodeEditor/js/code-editor.js");
                await _module.InvokeVoidAsync("init", _editorId, options, _selfRef);
                _initialized = true;
                _lastSyncedValue = Value;
                _lastLanguage = Language;
                _lastTheme = Theme;
                _lastReadOnly = ReadOnly;
                _lastShowMinimap = ShowMinimap;
            }
            catch (JSDisconnectedException)
            {
                await CleanupAfterFailedInitAsync();
            }
            catch (ObjectDisposedException)
            {
                await CleanupAfterFailedInitAsync();
            }
            catch (JSException)
            {
                // Init genuinely failed (bad bundle URL, ESM import error). Tear
                // down so we don't leak, then rethrow so a host that wants to
                // surface the failure still can — Blazor logs it as an unhandled
                // OnAfterRenderAsync task otherwise, which is the desired signal.
                await CleanupAfterFailedInitAsync();
                throw;
            }
            return;
        }

        if (!_initialized || _module is null) return;

        try
        {
            // Only push the Value into CodeMirror when the PARENT genuinely
            // changed the parameter (_valueParamChanged), not when our own
            // OnEditorChange echo made _lastSyncedValue diverge from a stale
            // uncontrolled Value. Pushing on echo-divergence would revert the
            // user's typing and snap the caret on the next unrelated re-render.
            if (_valueParamChanged &&
                !string.Equals(_lastSyncedValue ?? string.Empty, Value ?? string.Empty, StringComparison.Ordinal))
            {
                _lastSyncedValue = Value;
                await _module.InvokeVoidAsync("setValue", _editorId, Value ?? string.Empty);
            }
            _valueParamChanged = false;

            if (!string.Equals(_lastLanguage, Language, StringComparison.OrdinalIgnoreCase))
            {
                _lastLanguage = Language;
                await _module.InvokeVoidAsync("setLanguage", _editorId, Language);
            }

            if (!string.Equals(_lastTheme, Theme, StringComparison.OrdinalIgnoreCase))
            {
                _lastTheme = Theme;
                await _module.InvokeVoidAsync("setTheme", _editorId, Theme);
            }

            if (_lastReadOnly != ReadOnly)
            {
                _lastReadOnly = ReadOnly;
                await _module.InvokeVoidAsync("setReadOnly", _editorId, ReadOnly);
            }

            if (_lastShowMinimap != ShowMinimap)
            {
                _lastShowMinimap = ShowMinimap;
                await _module.InvokeVoidAsync("setMinimap", _editorId, ShowMinimap);
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
    }

    // Best-effort teardown for a failed first-render init. Disposes whatever was
    // allocated before the failure (module ref + DotNetObjectReference) and never
    // throws — it runs from inside catch blocks.
    private async Task CleanupAfterFailedInitAsync()
    {
        _initialized = false;
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
            catch (Exception) { /* never throw from cleanup */ }
            _module = null;
        }
        _selfRef?.Dispose();
        _selfRef = null;
    }

    [JSInvokable]
    public async Task OnEditorChange(string value)
    {
        // Track the latest text so OnAfterRenderAsync doesn't push it straight
        // back into CodeMirror after the bound field updates — a self-induced
        // re-set would move the caret to position 0 on every keystroke.
        _lastSyncedValue = value;
        // Record what we are about to push BEFORE raising ValueChanged. A
        // controlled parent may re-render synchronously inside InvokeAsync, so
        // OnParametersSet must already see this as "the value we pushed" when
        // it runs — otherwise the echo comparison misfires and arms a spurious
        // setValue that would roll back an accepted edit.
        _lastPushed = value;

        if (ValueChanged.HasDelegate)
            await ValueChanged.InvokeAsync(value);
        if (OnChange.HasDelegate)
            await OnChange.InvokeAsync(value);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            if (_module is not null)
            {
                await _module.InvokeVoidAsync("destroy", _editorId);
                await _module.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        catch (ObjectDisposedException) { }
        catch (Exception) { /* never throw from disposer */ }

        _selfRef?.Dispose();
    }
}
