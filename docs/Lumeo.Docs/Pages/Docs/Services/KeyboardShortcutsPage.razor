    <!-- Key Combo Format -->
    <Stack>
        <Stack Gap="4">
            <Heading Level="2">Key Combo Format</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                Key combos use <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">modifier+key</code> format, separated by
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">+</code>. Key names use
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">KeyboardEvent.key</code> values.
            </Lumeo.Text>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Combo</th>
                            <th class="text-left p-3 font-medium text-foreground">Keys</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ctrl+k</td>
                            <td class="p-3"><Flex Gap="1" Align="center"><Kbd>Ctrl</Kbd><Kbd>K</Kbd></Flex></td>
                            <td class="p-3 text-muted-foreground">Common for search / command palette</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ctrl+shift+p</td>
                            <td class="p-3"><Flex Gap="1" Align="center"><Kbd>Ctrl</Kbd><Kbd>Shift</Kbd><Kbd>P</Kbd></Flex></td>
                            <td class="p-3 text-muted-foreground">Multi-modifier combo</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">alt+n</td>
                            <td class="p-3"><Flex Gap="1" Align="center"><Kbd>Alt</Kbd><Kbd>N</Kbd></Flex></td>
                            <td class="p-3 text-muted-foreground">Alt modifier</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">meta+enter</td>
                            <td class="p-3"><Flex Gap="1" Align="center"><Kbd>Cmd</Kbd><Kbd>Enter</Kbd></Flex></td>
                            <td class="p-3 text-muted-foreground">Cmd (Mac) or Win (Windows)</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">escape</td>
                            <td class="p-3"><Kbd>Esc</Kbd></td>
                            <td class="p-3 text-muted-foreground">No modifier needed</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">f1</td>
                            <td class="p-3"><Kbd>F1</Kbd></td>
                            <td class="p-3 text-muted-foreground">Function keys</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
            <Lumeo.Text Size="sm" Color="muted">
                Available modifiers: <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">ctrl</code>,
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">shift</code>,
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">alt</code>,
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">meta</code>.
                Order does not matter -- <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">shift+ctrl+k</code> and
                <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">ctrl+shift+k</code> are identical. The service normalizes
                the combo internally.
            </Lumeo.Text>
