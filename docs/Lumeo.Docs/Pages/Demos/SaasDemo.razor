    // KPIs
    private readonly Kpi[] _kpis =
    {
        new("MRR", "DollarSign", "$", 48231, "", "+8.2% MoM"),
        new("Active projects", "LayoutDashboard", "", 128, "", "+11 this week"),
        new("Weekly active users", "Users", "", 9318, "", "+4.6% WoW"),
