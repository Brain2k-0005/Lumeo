                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">SavedLayout</td><td class="px-4 py-2 font-mono text-xs">DataGridLayout?</td><td class="px-4 py-2 text-xs">--</td><td class="px-4 py-2 text-muted-foreground">Externally provided layout to apply on load.</td></tr>
