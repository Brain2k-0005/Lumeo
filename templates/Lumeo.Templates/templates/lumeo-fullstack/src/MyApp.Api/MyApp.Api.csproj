<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MyApp.Api</RootNamespace>
    <!-- The OpenAPI document is generated at build time so Scalar has something to read. -->
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <!-- ASP.NET Core Identity + the MapIdentityApi endpoint set, stored in EF Core. -->
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="10.0.6" />

    <!-- EF Core provider for PostgreSQL (Npgsql). -->
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="10.0.0" />
    <!-- Design-time services for `dotnet ef migrations`. Not shipped to runtime. -->
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.6">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <!-- Built-in OpenAPI document generation (AddOpenApi / MapOpenApi). -->
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.6" />
    <!-- Pin the Microsoft.OpenApi transitive above the 2.0.0 that AspNetCore.OpenApi
         10.0.6 resolves, which carries advisory GHSA-v5pm-xwqc-g5wc (fixed in 2.9.0). -->
    <PackageReference Include="Microsoft.OpenApi" Version="2.9.0" />
    <!-- Scalar renders the OpenAPI document as an interactive API reference at /scalar. -->
    <PackageReference Include="Scalar.AspNetCore" Version="2.10.0" />
  </ItemGroup>

</Project>
