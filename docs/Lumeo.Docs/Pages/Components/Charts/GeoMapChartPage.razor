@page "/components/charts/geo-map"

<PageTitle>Geo Map Chart — Lumeo</PageTitle>

<PageHeader Title="Geo Map Chart" Description="Display data on a geographic map with color-coded regions. Requires GeoJSON map data to be provided. Supports pan, zoom, and tooltips." />

<Stack Gap="8">
    <ComponentDemo Title="Geographic Data Visualization" Code="@_basicCode">
        <Container>
            <Lumeo.Text Size="sm" Color="muted" Class="mb-3">The GeoMapChart requires GeoJSON map data to render. Provide your map data via the MapJson parameter and region values via the Data parameter.</Lumeo.Text>
            <Flex Align="center" Justify="center" Class="rounded-lg border border-border/40 p-8 bg-muted/20">
                <Lumeo.Text Size="sm" Color="muted">Supply MapJson to render a geographic visualization.</Lumeo.Text>
            </Flex>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">GeoMapChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MapName</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"world"</td>
                            <td class="p-3 text-muted-foreground">Name to register the map under in ECharts.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">MapJson</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">GeoJSON string for the map geometry.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">object?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Data points with region name and value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">VisualMapMin</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Minimum value for color mapping.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">VisualMapMax</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">100</td>
                            <td class="p-3 text-muted-foreground">Maximum value for color mapping.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Roam</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Enables pan and zoom on the map.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private string _basicCode = @"<GeoMapChart MapName=""usa"" MapJson=""@_geoJson"" Data=""_data""
            VisualMapMin=""0"" VisualMapMax=""100"" />";
}
