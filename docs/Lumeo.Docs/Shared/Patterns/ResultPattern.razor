@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Success Result" Code="@_codeSuccess">
    <Result Status="Result.ResultStatus.Success"
            Title="Payment Successful"
            SubTitle="Your order #12345 has been confirmed.">
        <Extra>
            <Button>Go to Dashboard</Button>
            <Button Variant="Button.ButtonVariant.Outline">View Order</Button>
        </Extra>
    </Result>
</PatternCard>

<PatternCard Label="Error Result" Code="@_codeError">
    <Result Status="Result.ResultStatus.Error"
            Title="Submission Failed"
            SubTitle="Please check your input and try again.">
        <Extra>
            <Button Variant="Button.ButtonVariant.Destructive">Retry</Button>
        </Extra>
    </Result>
</PatternCard>
</Stack>

@code {
    private string _codeSuccess = @"<Result Status=""Result.ResultStatus.Success""
    Title=""Payment Successful""
    SubTitle=""Your order has been confirmed."">
    <Extra>
        <Button>Go to Dashboard</Button>
    </Extra>
</Result>";

    private string _codeError = @"<Result Status=""Result.ResultStatus.Error""
    Title=""Submission Failed""
    SubTitle=""Please check your input and try again."" />";
}
