@page "/components/meteors"

<PageTitle>Meteors — Lumeo</PageTitle>

<PageHeader Title="Meteors" Description="Falling angled meteor streaks across a container — a dramatic decorative background effect." />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Add atmosphere to hero sections, pricing cards, or dark-mode landing pages.</li>
        <li>Create a "space" or "fast" feel behind feature spotlights.</li>
        <li>Pair with a dark background card for maximum visual impact.</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default (20 meteors)" Code="@_defaultCode">
        <div class="relative overflow-hidden rounded-xl bg-zinc-950 p-12 min-h-[200px] flex items-center justify-center">
            <Meteors />
            <span class="relative z-10 text-white text-2xl font-bold">Shooting Stars</span>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Custom count and color" Code="@_customCode">
        <div class="relative overflow-hidden rounded-xl bg-slate-900 p-12 min-h-[160px] flex items-center justify-center">
            <Meteors Number="8" Color="oklch(0.7 0.2 200)" />
            <span class="relative z-10 text-sky-200 text-xl font-semibold">Blue Meteors</span>
        </div>
    </ComponentDemo>
</Stack>

<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
        <table class="w-full min-w-[600px] text-sm">
            <thead>
                <tr class="border-b border-border/40 bg-muted/40">
                    <th class="text-left p-3 font-medium text-foreground">Property</th>
                    <th class="text-left p-3 font-medium text-foreground">Type</th>
                    <th class="text-left p-3 font-medium text-foreground">Default</th>
                    <th class="text-left p-3 font-medium text-foreground">Description</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border/40">
                <tr><td class="p-3 font-mono text-xs text-primary">Number</td><td class="p-3 font-mono text-xs text-muted-foreground">int</td><td class="p-3 font-mono text-xs text-muted-foreground">20</td><td class="p-3 text-muted-foreground">Number of meteor streaks to render.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">Color</td><td class="p-3 font-mono text-xs text-muted-foreground">string</td><td class="p-3 font-mono text-xs text-muted-foreground">"var(--color-primary)"</td><td class="p-3 text-muted-foreground">CSS color of the meteor head and tail gradient.</td></tr>
                <tr><td class="p-3 font-mono text-xs text-primary">Class</td><td class="p-3 font-mono text-xs text-muted-foreground">string?</td><td class="p-3 font-mono text-xs text-muted-foreground">null</td><td class="p-3 text-muted-foreground">Additional CSS classes on the container div.</td></tr>
            </tbody>
        </table>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/sparkles" class="text-primary hover:underline">Sparkles</a> — Decorative sparkle particles around content.</li>
        <li><a href="/components/animated-gradient-text" class="text-primary hover:underline">AnimatedGradientText</a> — Shifting gradient text animation.</li>
    </ul>
</div>

@code {
    private string _defaultCode = @"<div class=""relative overflow-hidden rounded-xl bg-zinc-950 p-12 min-h-[200px]"">
    <Meteors />
    <span class=""relative z-10 text-white text-2xl font-bold"">Shooting Stars</span>
</div>";

    private string _customCode = @"<Meteors Number=""8"" Color=""oklch(0.7 0.2 200)"" />";
}
