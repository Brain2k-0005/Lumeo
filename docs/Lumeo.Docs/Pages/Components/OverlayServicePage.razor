@inject OverlayService OverlayService

@code {
    private string? _dialogResult;
    private string? _sheetResult;
    private string? _drawerResult;
    private string? _alertResult;
    private bool _alertCancelled;

    private async Task ShowDialog()
    {
        _dialogResult = null;
        var result = await OverlayService.ShowDialogAsync<OverlayDemoContent>("Edit Profile");
        _dialogResult = result.Cancelled ? "Cancelled" : (result.Data?.ToString() ?? "Submitted");
    }

    private async Task ShowSheet(SheetSide side)
    {
        _sheetResult = null;
        var result = await OverlayService.ShowSheetAsync<OverlayDemoContent>("Edit Profile", side);
        _sheetResult = result.Cancelled ? "Cancelled" : (result.Data?.ToString() ?? "Submitted");
    }

    private async Task ShowDrawer()
    {
        _drawerResult = null;
        var result = await OverlayService.ShowDrawerAsync<OverlayDemoContent>("Edit Profile");
        _drawerResult = result.Cancelled ? "Cancelled" : (result.Data?.ToString() ?? "Submitted");
    }

    private async Task ShowConfirm()
    {
        _alertResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Save changes?",
            Description = "This will overwrite your existing data.",
            ConfirmText = "Save",
            CancelText = "Cancel"
        });
        _alertCancelled = result.Cancelled;
        _alertResult = result.Cancelled ? "Cancelled" : "Confirmed";
    }

    private async Task ShowDestructive()
    {
        _alertResult = null;
        var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
        {
            Title = "Delete item?",
            Description = "This action cannot be undone.",
            ConfirmText = "Delete",
            CancelText = "Cancel",
            IsDestructive = true
        });
        _alertCancelled = result.Cancelled;
        _alertResult = result.Cancelled ? "Cancelled" : "Deleted";
    }

    private string _dialogCode =
        """
        @inject OverlayService OverlayService

        <Stack Gap="3">
            <Button OnClick="OpenDialog">Open Dialog</Button>
            @if (_result is not null)
            {
                <Alert>Result: @_result</Alert>
            }
        </Stack>

        @code {
            private string? _result;

            private async Task OpenDialog()
            {
                _result = null;
                var overlayResult = await OverlayService.ShowDialogAsync<ProfileFormContent>("Edit Profile");
                _result = overlayResult.Cancelled ? "Cancelled" : $"Submitted: {overlayResult.Data}";
            }
        }

        // ProfileFormContent.razor — receives OverlayReference as a CascadingParameter
        @namespace YourApp

        <Stack Gap="4" Class="py-4">
            <Stack Gap="2">
                <Label>Name</Label>
                <Input @bind-Value="_name" Placeholder="Enter your name..." />
            </Stack>
            <Stack Gap="2">
                <Label>Email</Label>
                <Input @bind-Value="_email" Placeholder="Enter your email..." />
            </Stack>
            <Flex Justify="end" Gap="2" Class="pt-2">
                <Button Variant="Button.ButtonVariant.Outline" OnClick="() => Overlay.Cancel()">Cancel</Button>
                <Button OnClick="Submit">Submit</Button>
            </Flex>
        </Stack>

        @code {
            [CascadingParameter] public OverlayReference Overlay { get; set; } = default!;

            private string _name = "";
            private string _email = "";

            private void Submit() => Overlay.Close(new { Name = _name, Email = _email });
        }
        """;

    private string _sheetCode =
        """
        @inject OverlayService OverlayService

        <Flex Gap="2" Wrap="true">
            <Button Variant="Button.ButtonVariant.Outline" OnClick="() => OpenSheet(SheetSide.Right)">Right</Button>
            <Button Variant="Button.ButtonVariant.Outline" OnClick="() => OpenSheet(SheetSide.Left)">Left</Button>
            <Button Variant="Button.ButtonVariant.Outline" OnClick="() => OpenSheet(SheetSide.Bottom)">Bottom</Button>
        </Flex>
        @if (_result is not null)
        {
            <Alert>Result: @_result</Alert>
        }

        @code {
            private string? _result;

            private async Task OpenSheet(SheetSide side)
            {
                _result = null;
                var overlayResult = await OverlayService.ShowSheetAsync<ProfileFormContent>(
                    title: "Edit Profile",
                    side: side,
                    size: SheetSize.Default);
                _result = overlayResult.Cancelled ? "Cancelled" : $"Submitted: {overlayResult.Data}";
            }
        }
        """;

    private string _drawerCode =
        """
        @inject OverlayService OverlayService

        <Stack Gap="3">
            <Button Variant="Button.ButtonVariant.Outline" OnClick="OpenDrawer">Open Drawer</Button>
            @if (_result is not null)
            {
                <Alert>Result: @_result</Alert>
            }
        </Stack>

        @code {
            private string? _result;

            private async Task OpenDrawer()
            {
                _result = null;
                var overlayResult = await OverlayService.ShowDrawerAsync<ProfileFormContent>("Edit Profile");
                _result = overlayResult.Cancelled ? "Cancelled" : $"Submitted: {overlayResult.Data}";
            }
        }
        """;

    private string _alertCode =
        """
        @inject OverlayService OverlayService

        <Button OnClick="DeleteItem">Delete Item</Button>

        @code {
            private async Task DeleteItem()
            {
                var result = await OverlayService.ShowAlertDialogAsync(new AlertDialogOptions
                {
                    Title = "Delete item?",
                    Description = "This action cannot be undone.",
                    ConfirmText = "Delete",
                    IsDestructive = true
                });

                if (!result.Cancelled)
                {
                    // proceed with deletion
                }
            }
        }
        """;
}
