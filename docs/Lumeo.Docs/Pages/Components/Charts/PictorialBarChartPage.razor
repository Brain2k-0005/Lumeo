@page "/components/charts/pictorial-bar"

<PageTitle>Pictorial Bar Chart — Lumeo</PageTitle>

<PageHeader Title="Pictorial Bar Chart" Description="A bar chart that uses symbols instead of rectangular bars. Each symbol represents a data point, making the visualization more expressive and engaging." />

<Stack Gap="8">
    <ComponentDemo Title="Daily Steps" Code="@_basicCode">
        <Container>
            <PictorialBarChart Categories="_categories" Series="_series" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">PictorialBarChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis category labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Series</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;PictorialSeriesData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Data series with Name, Values, Symbol, and SymbolSize.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows or hides the chart legend.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<string> _categories = new() { "Mon", "Tue", "Wed", "Thu", "Fri" };
    private List<PictorialBarChart.PictorialSeriesData> _series = new()
    {
        new() { Name = "Daily Steps", Values = new() { 8420, 6130, 9870, 7280, 11340 }, Symbol = "circle", SymbolSize = 25 }
    };

    private string _basicCode = @"<PictorialBarChart Categories=""_categories"" Series=""_series"" />";
}
