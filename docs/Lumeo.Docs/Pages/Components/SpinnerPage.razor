@page "/components/spinner"

<PageTitle>Spinner — Lumeo</PageTitle>

<PageHeader Title="Spinner" Description="A loading spinner indicator with multiple sizes." />

<Stack Gap="8">
    <ComponentDemo Title="Sizes" Code="@_sizesCode">
        <Flex Align="center" Gap="6">
            <Stack Gap="2" Align="center">
                <Spinner Size="Spinner.SpinnerSize.Sm" />
                <Lumeo.Text As="span" Size="xs" Color="muted">Small</Lumeo.Text>
            </Stack>
            <Stack Gap="2" Align="center">
                <Spinner />
                <Lumeo.Text As="span" Size="xs" Color="muted">Default</Lumeo.Text>
            </Stack>
            <Stack Gap="2" Align="center">
                <Spinner Size="Spinner.SpinnerSize.Lg" />
                <Lumeo.Text As="span" Size="xs" Color="muted">Large</Lumeo.Text>
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="With Text" Code="@_textCode">
        <Flex Align="center" Gap="2">
            <Spinner Size="Spinner.SpinnerSize.Sm" />
            <Lumeo.Text As="span" Size="sm" Color="muted">Loading...</Lumeo.Text>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="In a Button" Code="@_buttonCode">
        <Button Disabled="true">
            <Spinner Size="Spinner.SpinnerSize.Sm" Class="mr-2" />
            Please wait
        </Button>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">Spinner</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Size</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">SpinnerSize</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Default</td>
                            <td class="p-3 text-muted-foreground">Size of the spinner. Values: Sm (16px), Default (24px), Lg (32px).</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private string _sizesCode = @"<Spinner Size=""Spinner.SpinnerSize.Sm"" />
<Spinner />
<Spinner Size=""Spinner.SpinnerSize.Lg"" />";

    private string _textCode = @"<Flex Align=""center"" Gap=""2"">
    <Spinner Size=""Spinner.SpinnerSize.Sm"" />
    <Lumeo.Text As=""span"" Size=""sm"" Color=""muted"">Loading...</Lumeo.Text>
</Flex>";

    private string _buttonCode = @"<Button Disabled=""true"">
    <Spinner Size=""Spinner.SpinnerSize.Sm"" Class=""mr-2"" />
    Please wait
</Button>";
}
