<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.6" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.6" PrivateAssets="all" />

    <!--#if (AuthDemo) -->
    <!-- Demo auth uses the Blazor authorization primitives (AuthenticationStateProvider,
         AuthorizeView, AuthorizeRouteView, [Authorize]) with an in-browser provider — no
         server package required. -->
    <PackageReference Include="Microsoft.AspNetCore.Components.Authorization" Version="10.0.6" />
    <!--#endif -->
    <!--#if (AuthOidc) -->
    <!-- Real OIDC/OAuth. Pulls in Microsoft.AspNetCore.Components.Authorization transitively. -->
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Authentication" Version="10.0.6" />
    <!--#endif -->

    <!-- Lumeo component library. Version is kept in lockstep with Lumeo.DataGrid;
         the [LumeoForm] source generator + all prebuilt CSS/JS assets ship inside
         this package (served at _content/Lumeo/... — see wwwroot/index.html). -->
    <PackageReference Include="Lumeo" Version="4.3.2" />
    <PackageReference Include="Lumeo.DataGrid" Version="4.3.2" />
  </ItemGroup>

</Project>
