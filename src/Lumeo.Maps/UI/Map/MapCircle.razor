@namespace Lumeo
@implements IDisposable

@code {
    /// <summary>Circle center as <c>(lat, lon)</c>.</summary>
    [Parameter] public (double Lat, double Lon) Center { get; set; }
    /// <summary>Radius in meters. Leaflet draws the circle in real-world units,
    /// so its pixel size grows/shrinks with zoom.</summary>
    [Parameter] public double RadiusMeters { get; set; } = 100;

    /// <summary>Stroke color (any CSS color value). Null uses the layer's default.</summary>
    [Parameter] public string? Color { get; set; }

    /// <summary>Fill color (any CSS color value). Null uses the layer's default.</summary>
    [Parameter] public string? FillColor { get; set; }

    /// <summary>Stroke width in pixels. Default <c>2</c>.</summary>
    [Parameter] public double Weight { get; set; } = 2;

    /// <summary>Stroke opacity, 0–1. Default <c>0.9</c>.</summary>
    [Parameter] public double Opacity { get; set; } = 0.9;

    /// <summary>Fill opacity, 0–1. Default <c>0.2</c>.</summary>
    [Parameter] public double FillOpacity { get; set; } = 0.2;

    /// <summary>Plain-text tooltip shown on hover.</summary>
    [Parameter] public string? Tooltip { get; set; }

    /// <summary>Raw HTML shown in a popup when the circle is clicked.</summary>
    [Parameter] public string? PopupHtml { get; set; }

    [CascadingParameter] internal Map.MapContext? MapCtx { get; set; }

    private Map? _owner;
    private MapShape? _shape;

    protected override void OnParametersSet()
    {
        if (MapCtx is null) return;
        var owner = MapCtx.Owner;
        var snapshot = new MapShape
        {
            Type = "circle",
            Center = new MapShape.LatLon { Lat = Center.Lat, Lon = Center.Lon },
            RadiusMeters = RadiusMeters,
            Color = Color,
            FillColor = FillColor,
            Weight = Weight,
            Opacity = Opacity,
            FillOpacity = FillOpacity,
            Tooltip = Tooltip,
            PopupHtml = PopupHtml,
        };
        if (_owner is null)
        {
            _owner = owner;
            _shape = snapshot;
            owner.RegisterShape(this, snapshot);
        }
        else
        {
            _shape = snapshot;
            owner.NotifyShapeChanged(this, snapshot);
        }
    }

    internal MapShape? GetSnapshot() => _shape;

    public void Dispose() => _owner?.UnregisterShape(this);
}
