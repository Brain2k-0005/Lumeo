@page "/components/charts/waterfall"

<PageTitle>Waterfall Chart — Lumeo</PageTitle>

<PageHeader Title="Waterfall Chart" Description="Show how an initial value is affected by successive positive and negative changes. Commonly used for financial statements, budget analysis, and variance breakdowns." />

<Stack Gap="8">
    <ComponentDemo Title="Income Statement Waterfall" Description="Revenue walks down to Operating Income through Cost of Goods Sold and operating expenses. Positive bars use primary color, negative bars use destructive red." Code="@_basicCode">
        <Container>
            <WaterfallChart Categories="_categories" Values="_values" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Quarterly Bridge" Description="Q3 to Q4 revenue bridge showing upsell gains, churn losses, and new-logo additions. Data labels make each delta immediately readable." Code="@_bridgeCode">
        <Container>
            <WaterfallChart Categories="_bridgeCategories" Values="_bridgeValues" ShowDataLabels="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Project Budget Variance" Description="Approved budget vs actual spend breakdown per workstream. Custom green/red colors replace the default palette. Toolbox enabled." Code="@_varianceCode">
        <Container>
            <WaterfallChart Categories="_varianceCategories" Values="_varianceValues"
                            IncreaseColor="#10b981" DecreaseColor="#f97316" Toolbox="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="P&amp;L Summary with DataZoom" Description="Full P&amp;L walkthrough from Gross Revenue to Net Profit across twelve line items. DataZoom enabled for scrolling on smaller screens." Code="@_plCode">
        <Container>
            <WaterfallChart Categories="_plCategories" Values="_plValues" DataZoom="true" />
        </Container>
    </ComponentDemo>
    <ComponentDemo Title="Loading state" Description="Shape-aware skeleton with reserved space for legend and axes — no layout shift when real data arrives.">
        <Container>
            <Stack Gap="4">
                <Stack Direction="Stack.StackDirection.Horizontal" Gap="4" Align="center" Wrap="true">
                    <Button OnClick="SimulateLoadingAsync" Disabled="@_loading">Simulate loading</Button>
                    <Stack Direction="Stack.StackDirection.Horizontal" Gap="2" Align="center">
                        <Switch @bind-Value="_keepLoading" Id="keep-loading" />
                        <label for="keep-loading" class="text-sm text-muted-foreground cursor-pointer">Hold skeleton open</label>
                    </Stack>
                </Stack>
                <WaterfallChart Categories="_categories" Values="_values" IsLoading="@LoadingComputed" Height="320px" />
            </Stack>
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack>
            <Heading Level="3" Class="mb-3">WaterfallChart</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Categories</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">X-axis labels for each step.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Values</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Positive or negative values for each step.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IncreaseColor</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">var(--color-primary)</td>
                            <td class="p-3 text-muted-foreground">Color for positive values.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">DecreaseColor</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">var(--color-destructive)</td>
                            <td class="p-3 text-muted-foreground">Color for negative values.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">LabelStrategy</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">ChartLabelStrategy</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Smart</td>
                            <td class="p-3 text-muted-foreground">How category-axis labels are rendered. Smart auto-rotates at higher densities; ShowAll forces all horizontal; Auto thins overlapping labels.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">LabelRotate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">int?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Manual rotation override in degrees on top of LabelStrategy.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    // Demo 1 — income statement
    private List<string> _categories = new() { "Revenue", "COGS", "Gross Profit", "R&D", "Sales & Mktg", "G&A", "Operating Income" };
    private List<double> _values = new() { 12400, -4800, 7600, -1200, -2100, -800, 3500 };

    // Demo 2 — quarterly revenue bridge
    private List<string> _bridgeCategories = new() { "Q3 ARR", "New Logos", "Upsell", "Churn", "Contraction", "Q4 ARR" };
    private List<double> _bridgeValues = new() { 8200, 1450, 680, -540, -210, 9580 };

    // Demo 3 — project budget variance
    private List<string> _varianceCategories = new() { "Approved Budget", "Design", "Engineering", "QA", "DevOps", "Marketing", "Final Spend" };
    private List<double> _varianceValues = new() { 500000, -42000, -185000, -28000, 8000, -35000, 218000 };

    // Demo 4 — detailed P&L
    private List<string> _plCategories = new()
    {
        "Gross Revenue", "Discounts", "Net Revenue", "COGS", "Gross Profit",
        "R&D", "Sales", "Marketing", "G&A", "EBITDA", "D&A", "EBIT"
    };
    private List<double> _plValues = new()
    {
        18500, -1200, 17300, -5100, 12200,
        -2400, -3100, -1800, -1100, 3800, -420, 3380
    };

    private string _basicCode    = @"<WaterfallChart Categories=""_categories"" Values=""_values"" />";
    private string _bridgeCode   = @"<WaterfallChart Categories=""_bridgeCategories"" Values=""_bridgeValues"" ShowDataLabels=""true"" />";
    private string _varianceCode = @"<WaterfallChart Categories=""_varianceCategories"" Values=""_varianceValues"" IncreaseColor=""#10b981"" DecreaseColor=""#f97316"" Toolbox=""true"" />";
    private string _plCode       = @"<WaterfallChart Categories=""_plCategories"" Values=""_plValues"" DataZoom=""true"" />";

    private bool _loading;
    private bool _keepLoading;
    private bool LoadingComputed => _loading || _keepLoading;

    private async Task SimulateLoadingAsync()
    {
        _loading = true;
        await Task.Delay(2000);
        _loading = false;
    }
}
