@namespace Lumeo

<Sheet @bind-Open="Open">
    <SheetContent Side="Lumeo.Side.Left" Class="@(Cx.Merge("w-72 p-0", Class))">
        <div class="flex flex-col gap-2 p-4" @attributes="AdditionalAttributes">
            @ChildContent
        </div>
    </SheetContent>
</Sheet>

@code {
    /// <summary>The menu content rendered inside the slide-out sheet.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Whether the mobile menu sheet is open. Pair with <see cref="OpenChanged"/> for two-way binding.</summary>
    [Parameter] public bool Open { get; set; }

    /// <summary>Raised when the sheet's open state changes (e.g. dismissed by outside click or Escape).</summary>
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }

    /// <summary>Obsolete alias for <see cref="Open"/>.</summary>
    [Obsolete("Use Open instead. IsOpen will be removed in a future release.")]
    [Parameter] public bool IsOpen { get => Open; set => Open = value; }

    /// <summary>Obsolete alias for <see cref="OpenChanged"/>.</summary>
    [Obsolete("Use OpenChanged instead. IsOpenChanged will be removed in a future release.")]
    [Parameter] public EventCallback<bool> IsOpenChanged { get => OpenChanged; set => OpenChanged = value; }

    /// <summary>Additional CSS classes merged onto the sheet content panel.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the inner content wrapper.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
