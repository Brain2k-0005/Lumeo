@namespace Lumeo

<span class="@CssClass" style="@StyleString" @attributes="AdditionalAttributes">@ChildContent</span>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Comma-separated list of CSS colors forming the gradient stops.</summary>
    [Parameter] public string Gradient { get; set; } = "var(--color-primary), oklch(0.7 0.2 200), var(--color-primary)";
    /// <summary>Duration of one full gradient cycle.</summary>
    [Parameter] public string AnimationDuration { get; set; } = "4s";
    /// <summary>Background-size percentage for the gradient sweep (200% = 2x for smooth loop).</summary>
    [Parameter] public int BackgroundSize { get; set; } = 200;
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[] { "lumeo-animated-gradient-text", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    private string StyleString =>
        $"--lumeo-agt-gradient: {Gradient}; --lumeo-agt-duration: {AnimationDuration}; --lumeo-agt-size: {BackgroundSize}%;";
}
