@page "/themes"

<PageTitle>Themes — Lumeo</PageTitle>

<Flex Class="min-h-[calc(100vh-3.5rem)]">
    <!-- Preview Area -->
    <Stack Class="flex-1 p-6 lg:p-8">
        <Stack Gap="6" Class="max-w-4xl mx-auto">
            <Stack>
                <Heading Level="1" Class="text-3xl font-bold tracking-tight text-foreground">Themes</Heading>
                <Lumeo.Text Class="text-muted-foreground mt-1">Customize the look and feel of your components.</Lumeo.Text>
            </Stack>

            <!-- Card Example -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Create project</Heading>
                    <Lumeo.Text Class="text-sm text-muted-foreground">Deploy your new project in one-click.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <Stack Gap="2">
                            <Label>Name</Label>
                            <Input placeholder="My awesome project" />
                        </Stack>
                        <Stack Gap="2">
                            <Label>Description</Label>
                            <Textarea placeholder="Describe your project..." />
                        </Stack>
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Flex Class="justify-between w-full">
                        <Button Variant="Button.ButtonVariant.Outline">Cancel</Button>
                        <Button>Deploy</Button>
                    </Flex>
                </CardFooter>
            </Card>

            <!-- Buttons -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Buttons</Heading>
                </CardHeader>
                <CardContent>
                    <Flex Class="flex-wrap gap-2">
                        <Button>Primary</Button>
                        <Button Variant="Button.ButtonVariant.Secondary">Secondary</Button>
                        <Button Variant="Button.ButtonVariant.Destructive">Destructive</Button>
                        <Button Variant="Button.ButtonVariant.Outline">Outline</Button>
                        <Button Variant="Button.ButtonVariant.Ghost">Ghost</Button>
                        <Button Variant="Button.ButtonVariant.Link">Link</Button>
                    </Flex>
                </CardContent>
            </Card>

            <!-- Form Controls -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Form Controls</Heading>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <Flex Class="items-center gap-6">
                            <Flex Class="items-center gap-2">
                                <Switch @bind-Checked="_switch1" />
                                <Label>Airplane Mode</Label>
                            </Flex>
                            <Flex Class="items-center gap-2">
                                <Checkbox @bind-Checked="_check1" />
                                <Label>Accept terms</Label>
                            </Flex>
                        </Flex>
                        <Stack Class="w-full max-w-sm">
                            <Slider @bind-Value="_slider1" />
                        </Stack>
                        <Flex Class="items-center gap-2">
                            <Toggle @bind-Pressed="_bold">
                                <DynamicIcon Name="Bold" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle @bind-Pressed="_italic">
                                <DynamicIcon Name="Italic" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle @bind-Pressed="_underline" Variant="Toggle.ToggleVariant.Outline">
                                <DynamicIcon Name="Underline" Class="h-4 w-4" />
                            </Toggle>
                        </Flex>
                    </Stack>
                </CardContent>
            </Card>

            <!-- Badges & Progress -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Badges & Progress</Heading>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <Flex Class="flex-wrap gap-2">
                            <Badge>Default</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                            <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
                            <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
                        </Flex>
                        <Progress Value="65" />
                    </Stack>
                </CardContent>
            </Card>

            <!-- Dialog Preview -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Dialog</Heading>
                </CardHeader>
                <CardContent>
                    <Dialog @bind-IsOpen="_dialogOpen">
                        <DialogTrigger>
                            <Button Variant="Button.ButtonVariant.Outline">Open Dialog</Button>
                        </DialogTrigger>
                        <DialogContent>
                            <DialogHeader>
                                <DialogTitle>Edit profile</DialogTitle>
                                <DialogDescription>Make changes to your profile here. Click save when you're done.</DialogDescription>
                            </DialogHeader>
                            <Stack Gap="4" Class="py-4">
                                <Stack Gap="2">
                                    <Label>Name</Label>
                                    <Input placeholder="Enter your name" />
                                </Stack>
                                <Stack Gap="2">
                                    <Label>Email</Label>
                                    <Input type="email" placeholder="Enter your email" />
                                </Stack>
                            </Stack>
                            <DialogFooter>
                                <DialogClose>
                                    <Button Variant="Button.ButtonVariant.Outline">Cancel</Button>
                                </DialogClose>
                                <Button>Save changes</Button>
                            </DialogFooter>
                        </DialogContent>
                    </Dialog>
                </CardContent>
            </Card>

            <!-- Accordion -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Accordion</Heading>
                </CardHeader>
                <CardContent>
                    <Accordion>
                        <AccordionItem Value="item-1">
                            <AccordionTrigger>Is it accessible?</AccordionTrigger>
                            <AccordionContent>
                                <Lumeo.Text As="span" Class="text-sm text-muted-foreground">Yes. It adheres to the WAI-ARIA design pattern and supports keyboard navigation.</Lumeo.Text>
                            </AccordionContent>
                        </AccordionItem>
                        <AccordionItem Value="item-2">
                            <AccordionTrigger>Is it styled?</AccordionTrigger>
                            <AccordionContent>
                                <Lumeo.Text As="span" Class="text-sm text-muted-foreground">Yes. It comes with default styles that match the other components' aesthetic.</Lumeo.Text>
                            </AccordionContent>
                        </AccordionItem>
                        <AccordionItem Value="item-3">
                            <AccordionTrigger>Is it animated?</AccordionTrigger>
                            <AccordionContent>
                                <Lumeo.Text As="span" Class="text-sm text-muted-foreground">Yes. It uses CSS animations for smooth open and close transitions.</Lumeo.Text>
                            </AccordionContent>
                        </AccordionItem>
                    </Accordion>
                </CardContent>
            </Card>

            <!-- Avatars -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Avatars</Heading>
                </CardHeader>
                <CardContent>
                    <Flex Class="items-center gap-3">
                        <Avatar><AvatarFallback>JD</AvatarFallback></Avatar>
                        <Avatar><AvatarFallback>AB</AvatarFallback></Avatar>
                        <Avatar><AvatarFallback>MK</AvatarFallback></Avatar>
                        <Avatar Size="Avatar.AvatarSize.Sm"><AvatarFallback><DynamicIcon Name="User" Class="h-4 w-4" /></AvatarFallback></Avatar>
                        <Avatar Size="Avatar.AvatarSize.Lg"><AvatarFallback>LG</AvatarFallback></Avatar>
                    </Flex>
                </CardContent>
            </Card>

            <!-- Alerts -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Alerts</Heading>
                </CardHeader>
                <CardContent>
                    <Stack Gap="3">
                        <Alert>
                            <Flex Class="items-start gap-3">
                                <DynamicIcon Name="Bell" Class="h-4 w-4 mt-0.5" />
                                <Stack>
                                    <Lumeo.Text Class="font-medium leading-none tracking-tight mb-1">Heads up!</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm text-muted-foreground">You can add components to your app using the CLI.</Lumeo.Text>
                                </Stack>
                            </Flex>
                        </Alert>
                        <Alert Variant="Alert.AlertVariant.Destructive">
                            <Flex Class="items-start gap-3">
                                <DynamicIcon Name="X" Class="h-4 w-4 mt-0.5" />
                                <Stack>
                                    <Lumeo.Text Class="font-medium leading-none tracking-tight mb-1">Error</Lumeo.Text>
                                    <Lumeo.Text Class="text-sm">Your session has expired. Please log in again.</Lumeo.Text>
                                </Stack>
                            </Flex>
                        </Alert>
                    </Stack>
                </CardContent>
            </Card>

            <!-- Skeleton -->
            <Card>
                <CardHeader>
                    <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Skeleton</Heading>
                </CardHeader>
                <CardContent>
                    <Flex Class="items-center space-x-4">
                        <Skeleton Class="h-12 w-12 rounded-full" />
                        <Stack Gap="2">
                            <Skeleton Class="h-4 w-[250px]" />
                            <Skeleton Class="h-4 w-[200px]" />
                        </Stack>
                    </Flex>
                </CardContent>
            </Card>

            <!-- Tabs -->
            <Tabs ActiveValue="tab1">
                <TabsList>
                    <TabsTrigger Value="tab1">Account</TabsTrigger>
                    <TabsTrigger Value="tab2">Password</TabsTrigger>
                    <TabsTrigger Value="tab3">Settings</TabsTrigger>
                </TabsList>
                <TabsContent Value="tab1">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Account</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Make changes to your account here.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="2">
                                <Label>Username</Label>
                                <Input Value="@("@@lumeo")" />
                            </Stack>
                        </CardContent>
                        <CardFooter>
                            <Button>Save changes</Button>
                        </CardFooter>
                    </Card>
                </TabsContent>
                <TabsContent Value="tab2">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Password</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Change your password here.</Lumeo.Text>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="2">
                                <Label>Current password</Label>
                                <Input type="password" />
                            </Stack>
                        </CardContent>
                        <CardFooter>
                            <Button>Update password</Button>
                        </CardFooter>
                    </Card>
                </TabsContent>
                <TabsContent Value="tab3">
                    <Card>
                        <CardHeader>
                            <Heading Level="3" Class="text-lg font-semibold leading-none tracking-tight">Settings</Heading>
                            <Lumeo.Text Class="text-sm text-muted-foreground">Configure your preferences.</Lumeo.Text>
                        </CardHeader>
                    </Card>
                </TabsContent>
            </Tabs>
        </Stack>
    </Stack>

    <CustomizerSidebar />
</Flex>

@code {
    private bool _switch1 = true;
    private bool _check1 = true;
    private double _slider1 = 50;
    private bool _bold, _italic, _underline;
    private bool _dialogOpen;
}
