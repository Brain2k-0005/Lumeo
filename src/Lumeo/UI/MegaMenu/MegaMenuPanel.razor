@namespace Lumeo

<div class="@CssClass" role="menu" @attributes="AdditionalAttributes">
    <div class="@GridCssClass">
        @ChildContent
    </div>
</div>

@code {
    /// <summary>The <see cref="MegaMenuGroup"/> or <see cref="MegaMenuLink"/> elements laid out in the panel's grid.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>When true (default), the panel spans the full width of its positioning container instead of sizing to content.</summary>
    [Parameter] public bool FullWidth { get; set; } = true;

    /// <summary>Number of grid columns (1–5). Defaults to <c>4</c>; values outside that range fall back to a single column.</summary>
    [Parameter] public int Columns { get; set; } = 4;

    /// <summary>Additional CSS classes merged onto the root panel element.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes are splatted onto the root panel element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string WidthCssClass => FullWidth ? "start-0 end-0" : "w-auto min-w-[600px]";

    private string CssClass => Cx.Merge("absolute top-full z-50", WidthCssClass, "bg-popover border border-border/40 rounded-lg shadow-lg p-6", Class);

    private string GridCssClass => Columns switch {
        1 => "grid grid-cols-1 gap-6",
        2 => "grid grid-cols-2 gap-6",
        3 => "grid grid-cols-3 gap-6",
        4 => "grid grid-cols-4 gap-6",
        5 => "grid grid-cols-5 gap-6",
        _ => "grid grid-cols-1 gap-6"
    };
}
