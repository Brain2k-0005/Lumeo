@page "/components/audio-player"

<PageTitle>AudioPlayer — Lumeo</PageTitle>

<PageHeader Title="AudioPlayer" Description="A themed audio player with play/pause, scrub bar, time display, volume, optional cover art, and download." />

<InstallUsage Component="AudioPlayer" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Embed a single audio track inline with metadata (title, artist, cover) instead of the unstyled native <code class="font-mono text-xs">&lt;audio&gt;</code> element</li>
        <li>Provide consistent playback controls in podcast, music, or voice-memo features</li>
        <li>Offer a download affordance for hosted media when licensing allows</li>
        <li>Auto-loop short ambient or ringtone-style clips</li>
        <li>React to playback events (play / pause / ended / timeupdate) from C# code</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <AudioPlayer Src="https://www.kozco.com/tech/piano2-CoolEdit.mp3"
                     Title="Piano sample"
                     Artist="Cool Edit demo" />
    </ComponentDemo>

    <ComponentDemo Title="With cover art" Code="@_coverCode">
        <AudioPlayer Src="https://www.kozco.com/tech/piano2-CoolEdit.mp3"
                     Title="Piano sample"
                     Artist="Cool Edit demo">
            <Cover>
                <Image Src="https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=160&amp;h=160&amp;fit=crop"
                       Alt="Album cover"
                       Class="h-16 w-16 rounded-md object-cover" />
            </Cover>
        </AudioPlayer>
    </ComponentDemo>

    <ComponentDemo Title="Looping + download" Code="@_loopingCode">
        <AudioPlayer Src="https://www.kozco.com/tech/piano2-CoolEdit.mp3"
                     Title="Looping piano sample"
                     Artist="Cool Edit demo"
                     Loop="true"
                     Autoplay="false"
                     ShowDownload="true" />
    </ComponentDemo>

    <ComponentDemo Title="Playback events" Code="@_eventsCode">
        <Stack Gap="3">
            <AudioPlayer Src="https://www.kozco.com/tech/piano2-CoolEdit.mp3"
                         Title="Tracked sample"
                         Artist="Cool Edit demo"
                         OnPlay="HandlePlay"
                         OnPause="HandlePause"
                         OnEnded="HandleEnded" />
            <Lumeo.Text Size="sm" Color="muted">Last event: <code class="font-mono text-xs">@_lastEvent</code></Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>

    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">AudioPlayer</Heading>
            <Stack Class="rounded-lg border border-border/40 overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b border-border/40 bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Src</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Required. URL of the audio file to play.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Title</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Track title rendered next to the playback controls.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Artist</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Secondary artist / source label rendered beneath the title.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Cover</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">RenderFragment?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Optional cover art slot. Use an <code class="font-mono text-xs">Avatar</code> or <code class="font-mono text-xs">Image</code> to display album art.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Autoplay</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Starts playback automatically when the component mounts. Browsers may block autoplay for non-muted audio.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Loop</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, the track restarts from the beginning after it ends.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowDownload</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Renders a download button that lets the user save the source file.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">PreloadMode</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"metadata"</td>
                            <td class="p-3 text-muted-foreground">Mirrors the HTML5 <code class="font-mono text-xs">preload</code> attribute. Values: "none", "metadata", "auto".</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnTimeUpdate</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;double&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fires while playback progresses with the current time in seconds.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnPlay</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fires when playback starts.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnPause</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fires when playback pauses.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnEnded</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Fires when the track reaches the end (does not fire on looped tracks).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Class</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Additional CSS classes appended to the root element.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">AdditionalAttributes</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Dictionary&lt;string, object&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Splatted onto the root element for arbitrary HTML attributes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/file-upload" class="text-primary hover:underline">FileUpload</a> — Capture an audio file from the user before playing it back</li>
        <li><a href="/components/image" class="text-primary hover:underline">Image</a> — Pair with AudioPlayer's <code class="font-mono text-xs">Cover</code> slot for static album art</li>
        <li><a href="/components/avatar" class="text-primary hover:underline">Avatar</a> — Compact cover-art fallback for podcast hosts or speakers</li>
    </ul>
</div>

@code {
    private string _lastEvent = "(none)";

    private void HandlePlay() => _lastEvent = "play";
    private void HandlePause() => _lastEvent = "pause";
    private void HandleEnded() => _lastEvent = "ended";

    private string _basicCode = @"<AudioPlayer Src=""https://www.kozco.com/tech/piano2-CoolEdit.mp3""
             Title=""Piano sample""
             Artist=""Cool Edit demo"" />";

    private string _coverCode = @"<AudioPlayer Src=""https://www.kozco.com/tech/piano2-CoolEdit.mp3""
             Title=""Piano sample""
             Artist=""Cool Edit demo"">
    <Cover>
        <Image Src=""https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=160&h=160&fit=crop""
               Alt=""Album cover""
               Class=""h-16 w-16 rounded-md object-cover"" />
    </Cover>
</AudioPlayer>";

    private string _loopingCode = @"<AudioPlayer Src=""https://www.kozco.com/tech/piano2-CoolEdit.mp3""
             Title=""Looping piano sample""
             Artist=""Cool Edit demo""
             Loop=""true""
             Autoplay=""false""
             ShowDownload=""true"" />";

    private string _eventsCode = @"<AudioPlayer Src=""https://www.kozco.com/tech/piano2-CoolEdit.mp3""
             Title=""Tracked sample""
             Artist=""Cool Edit demo""
             OnPlay=""HandlePlay""
             OnPause=""HandlePause""
             OnEnded=""HandleEnded"" />

@@code {
    private string _lastEvent = ""(none)"";
    private void HandlePlay() => _lastEvent = ""play"";
    private void HandlePause() => _lastEvent = ""pause"";
    private void HandleEnded() => _lastEvent = ""ended"";
}";
}
