@page "/components/cascader"

<PageTitle>Cascader — Lumeo</PageTitle>

<PageHeader Title="Cascader" Description="A multi-level dropdown for selecting hierarchical data like categories or locations." />

<Stack Gap="8">
    <ComponentDemo Title="Basic Cascader" Code="@_basicCode">
        <Cascader Options="@_options" Placeholder="Select location..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Clearable" Code="@_clearableCode">
        <Cascader Options="@_options" Clearable="true" Placeholder="Select..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Cascader Options="@_options" Disabled="true" Placeholder="Disabled" Class="max-w-sm" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <Stack Gap="3">
            <Heading Level="3">Cascader</Heading>
            <Stack Class="rounded-lg border border-border overflow-x-auto">
                <table class="w-full min-w-[600px] text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Options</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;CascaderOption&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Hierarchical options tree.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Selected value path (root to leaf).</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Clearable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Show clear button.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Placeholder</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">"Select..."</td>
                            <td class="p-3 text-muted-foreground">Placeholder text.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Disabled</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Disable the cascader.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowSearch</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">Show a search input to filter options.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ValueChanged</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback&lt;List&lt;string&gt;&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback for two-way binding when the selected path changes.</td>
                        </tr>
                    </tbody>
                </table>
            </Stack>
        </Stack>
    </Stack>
</Stack>

@code {
    private List<Cascader.CascaderOption> _options = new()
    {
        new()
        {
            Label = "North America", Value = "na",
            Children = new()
            {
                new()
                {
                    Label = "United States", Value = "us",
                    Children = new()
                    {
                        new() { Label = "California", Value = "ca" },
                        new() { Label = "New York", Value = "ny" },
                        new() { Label = "Texas", Value = "tx" },
                    }
                },
                new()
                {
                    Label = "Canada", Value = "can",
                    Children = new()
                    {
                        new() { Label = "Ontario", Value = "on" },
                        new() { Label = "British Columbia", Value = "bc" },
                    }
                },
            }
        },
        new()
        {
            Label = "Europe", Value = "eu",
            Children = new()
            {
                new() { Label = "United Kingdom", Value = "uk" },
                new() { Label = "Germany", Value = "de" },
                new() { Label = "France", Value = "fr" },
            }
        },
    };

    private string _basicCode = @"<Cascader Options=""@_options"" Placeholder=""Select location..."" />";
    private string _clearableCode = @"<Cascader Options=""@_options"" Clearable=""true"" />";
    private string _disabledCode = @"<Cascader Options=""@_options"" Disabled=""true"" />";
}
