@page "/create"

<PageTitle>Create — Lumeo</PageTitle>

<div class="flex flex-col lg:flex-row min-h-[calc(100dvh-76px)]">

    @* ---------- Customizer rail (left) ---------- *@
    <div class="shrink-0 flex justify-center lg:block">
        <CustomizerSidebar IsOpen="true" ShowClose="false" PopoverSide="right" />
    </div>

    @* ---------- Live preview canvas (right) ----------
       Uses DynamicIcon on purpose so switching the icon library in the rail is
       visible here. Every change in the rail also re-themes these real Lumeo
       components live (color, radius, font, mode). *@
    <div class="flex-1 min-w-0 px-4 sm:px-6 lg:px-8 py-6">
        <Stack Gap="1" Class="mb-6">
            <Heading Level="1" Size="2xl">Create</Heading>
            <Lumeo.Text Size="sm" Color="muted">
                Tune the rail on the left and watch these components re-theme live. Use <span class="font-medium text-foreground">Share preset</span> to keep your look.
            </Lumeo.Text>
        </Stack>

        <div class="columns-1 md:columns-2 xl:columns-3 gap-4 [&>*]:mb-4 [&>*]:break-inside-avoid">

            @* Components showcase — makes color/radius changes obvious *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Components</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Buttons, badges and inputs.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <Flex Gap="2" Wrap="true">
                            <Button Size="Button.ButtonSize.Sm">Primary</Button>
                            <Button Variant="Button.ButtonVariant.Secondary" Size="Button.ButtonSize.Sm">Secondary</Button>
                            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Outline</Button>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm">Ghost</Button>
                        </Flex>
                        <Flex Gap="2" Wrap="true" Align="center">
                            <Badge>Default</Badge>
                            <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
                            <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
                            <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
                            <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
                        </Flex>
                        <Input placeholder="you@example.com" />
                    </Stack>
                </CardContent>
            </Card>

            @* Contribution history with a mini bar chart *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Contribution History</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Last 6 months of activity</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Flex Align="end" Gap="2" Class="h-32 mb-3">
                        @foreach (var b in _bars)
                        {
                            <div class="flex-1 flex flex-col items-center gap-1.5">
                                <div class="w-full rounded-t-[var(--radius-sm)] bg-primary/80" style="height: @(b.H)%"></div>
                                <Lumeo.Text As="span" Size="xs" Color="muted">@b.Month</Lumeo.Text>
                            </div>
                        }
                    </Flex>
                </CardContent>
                <CardFooter>
                    <Button Variant="Button.ButtonVariant.Outline" Class="w-full">View Full Report</Button>
                </CardFooter>
            </Card>

            @* New milestone form *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Set a new milestone</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Define a financial target and pace your savings.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <FormField Label="Goal Name">
                            <Input placeholder="e.g. New Car, Home Downpayment" />
                        </FormField>
                        <FormField Label="Target Amount">
                            <Input Value="$15,000" />
                        </FormField>
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Flex Gap="2" Class="w-full">
                        <Button Class="flex-1">
                            <DynamicIcon Name="Check" Class="h-4 w-4" />
                            Create Goal
                        </Button>
                        <Button Variant="Button.ButtonVariant.Ghost">Cancel</Button>
                    </Flex>
                </CardFooter>
            </Card>

            @* Payout threshold with select + slider *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Payout Threshold</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Minimum balance before a payout triggers.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <FormField Label="Preferred Currency">
                            <Select @bind-Value="_currency">
                                <SelectTrigger Class="w-full">
                                    <Lumeo.Text As="span">@(_currency == "eur" ? "EUR — Euro" : "USD — United States Dollar")</Lumeo.Text>
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectItem Value="usd">USD — United States Dollar</SelectItem>
                                    <SelectItem Value="eur">EUR — Euro</SelectItem>
                                </SelectContent>
                            </Select>
                        </FormField>
                        <Stack Gap="2">
                            <Flex Justify="between" Align="center">
                                <Label>Threshold</Label>
                                <Lumeo.Text Size="sm" Weight="semibold">@($"{_threshold:0}%")</Lumeo.Text>
                            </Flex>
                            <Slider @bind-Value="_threshold" />
                        </Stack>
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Button Class="w-full">Save Threshold</Button>
                </CardFooter>
            </Card>

            @* Savings targets with progress bars *@
            <Card>
                <CardHeader>
                    <Flex Justify="between" Align="center">
                        <div>
                            <Heading Level="3" Size="base" Class="leading-none tracking-tight">Savings Targets</Heading>
                            <Lumeo.Text Size="sm" Color="muted">Active milestones</Lumeo.Text>
                        </div>
                        <Badge Variant="Badge.BadgeVariant.Secondary">New Goal</Badge>
                    </Flex>
                </CardHeader>
                <CardContent>
                    <Stack Gap="5">
                        <Stack Gap="2">
                            <Flex Justify="between"><Lumeo.Text Size="sm" Weight="medium">Retirement</Lumeo.Text><Lumeo.Text Size="sm" Color="muted">65%</Lumeo.Text></Flex>
                            <Progress Value="65" />
                        </Stack>
                        <Stack Gap="2">
                            <Flex Justify="between"><Lumeo.Text Size="sm" Weight="medium">Real Estate</Lumeo.Text><Lumeo.Text Size="sm" Color="muted">32%</Lumeo.Text></Flex>
                            <Progress Value="32" />
                        </Stack>
                    </Stack>
                </CardContent>
            </Card>

            @* Recent transactions list (data-driven icons) *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Recent Transactions</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Your latest account activity.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="1">
                        @foreach (var t in _txns)
                        {
                            <Flex Align="center" Gap="3" Class="py-2">
                                <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-muted">
                                    <DynamicIcon Name="@t.Icon" Class="h-4 w-4 text-muted-foreground" />
                                </span>
                                <Stack Gap="0" Class="flex-1 min-w-0">
                                    <Lumeo.Text Size="sm" Weight="medium">@t.Name</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">@t.Cat</Lumeo.Text>
                                </Stack>
                                <Lumeo.Text Size="sm" Weight="semibold" Class="@(t.Positive ? "text-success-text" : "")">@t.Amount</Lumeo.Text>
                            </Flex>
                        }
                    </Stack>
                </CardContent>
            </Card>

            @* Notifications toggles *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Notifications</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Choose what you get notified about.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <Flex Align="center" Justify="between">
                            <Flex Align="center" Gap="2.5">
                                <DynamicIcon Name="Bell" Class="h-4 w-4 text-muted-foreground" />
                                <Label>Push notifications</Label>
                            </Flex>
                            <Switch @bind-Checked="_push" />
                        </Flex>
                        <Flex Align="center" Justify="between">
                            <Flex Align="center" Gap="2.5">
                                <DynamicIcon Name="Mail" Class="h-4 w-4 text-muted-foreground" />
                                <Label>Email digest</Label>
                            </Flex>
                            <Switch @bind-Checked="_email" />
                        </Flex>
                    </Stack>
                </CardContent>
            </Card>

            @* Buy investment form *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Buy Investment</Heading>
                    <Lumeo.Text Size="sm" Color="muted">Place an order at the current price.</Lumeo.Text>
                </CardHeader>
                <CardContent>
                    <Stack Gap="4">
                        <FormField Label="Amount to Invest">
                            <Input Value="$1,000.00" />
                        </FormField>
                        <FormField Label="Order Type">
                            <Select @bind-Value="_orderType">
                                <SelectTrigger Class="w-full">
                                    <Lumeo.Text As="span">@(_orderType == "limit" ? "Limit Order" : "Market Order")</Lumeo.Text>
                                </SelectTrigger>
                                <SelectContent>
                                    <SelectItem Value="market">Market Order</SelectItem>
                                    <SelectItem Value="limit">Limit Order</SelectItem>
                                </SelectContent>
                            </Select>
                        </FormField>
                    </Stack>
                </CardContent>
                <CardFooter>
                    <Button Class="w-full">Review Order</Button>
                </CardFooter>
            </Card>

            @* Profile card *@
            <Card>
                <CardHeader>
                    <Heading Level="3" Size="base" Class="leading-none tracking-tight">Team Member</Heading>
                </CardHeader>
                <CardContent>
                    <Flex Align="center" Gap="3">
                        <Avatar>
                            <AvatarImage Src="https://github.com/shadcn.png" Alt="Avatar" />
                            <AvatarFallback>CN</AvatarFallback>
                        </Avatar>
                        <Stack Gap="0" Class="flex-1 min-w-0">
                            <Lumeo.Text Size="sm" Weight="medium">Pedro Duarte</Lumeo.Text>
                            <Lumeo.Text Size="xs" Color="muted">@("@peduarte")</Lumeo.Text>
                        </Stack>
                        <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm">Invite</Button>
                    </Flex>
                </CardContent>
            </Card>
        </div>
    </div>
</div>

@code {
    private bool _push = true;
    private bool _email;
    private string? _currency = "usd";
    private string? _orderType = "market";
    private double _threshold = 35;

    private readonly (string Month, int H)[] _bars =
    [
        ("Dec", 55), ("Jan", 70), ("Feb", 60), ("Mar", 85), ("Apr", 65), ("May", 95)
    ];

    private readonly (string Icon, string Name, string Cat, string Amount, bool Positive)[] _txns =
    [
        ("ShoppingBag", "Blue Bottle Coffee", "Food & Drink", "-$6.50", false),
        ("ShoppingCart", "Whole Foods Market", "Groceries", "-$142.30", false),
        ("TrendingUp", "Stripe Payout", "Income", "+$4,200.00", true),
        ("Music", "Netflix Subscription", "Entertainment", "-$19.99", false),
    ];
}
