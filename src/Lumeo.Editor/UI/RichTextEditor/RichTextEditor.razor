@namespace Lumeo
@using Lumeo.Internal
@inject Services.ComponentInteropService Interop
@inject Lumeo.Services.Localization.ILumeoLocalizer L
@implements IAsyncDisposable

@* Init-failure banner renders ABOVE the editor, never INSTEAD of it: keeping the
   content host (@ref="_contentRef") mounted means a retry has a valid ElementReference
   to re-init against. Replacing the whole tree with an error div would orphan the ref
   and make recovery impossible. *@
@if (_initError is not null)
{
    <div role="alert" class="rounded-lg border border-destructive/30 bg-destructive/10 p-4 text-sm text-destructive mb-2 flex items-center justify-between gap-3">
        <span>Editor failed to initialize: @_initError</span>
        <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm" OnClick="RetryInitAsync">@L["Editor.Retry"]</Button>
    </div>
}

@if (Label is not null && !InsideFormField)
{
    <label id="@_labelId" class="block text-sm font-medium text-foreground mb-1.5">
        @Label
        @if (Required)
        {
            <span class="text-destructive ml-0.5">*</span>
        }
    </label>
}

<div class="@RootClass" @attributes="AdditionalAttributes">
    @if (EffectiveToolbar != EditorToolbarPreset.None)
    {
        <EditorToolbar Preset="EffectiveToolbar"
                       Active="_active"
                       Disabled="Disabled || ReadOnly"
                       AllowWordImport="AllowWordImport"
                       EnableAiActions="EnableAiActions"
                       OnCommand="HandleToolbarCommand" />
    }

    @* role/aria live on the editable surface itself (not the presentational
       wrapper) so assistive tech announces it as a multi-line textbox tied to
       its label, helper and error text. TipTap mounts the contenteditable into
       this host and also receives a mirrored set via editorProps.attributes. *@
    <div @ref="_contentRef"
         style="@ContentStyle"
         class="lumeo-rte-content bg-card"
         role="textbox"
         aria-multiline="true"
         aria-required="@(Required ? "true" : "false")"
         aria-invalid="@(EffectiveInvalid ? "true" : "false")"
         aria-labelledby="@EditorLabelledBy"
         aria-describedby="@EditorDescribedBy"></div>
</div>

@if (!InsideFormField)
{
    @if (_wordImportError is not null)
    {
        <p class="text-xs text-destructive mt-1.5" role="alert">@_wordImportError</p>
    }
    else if (EffectiveInvalid && ErrorText is not null)
    {
        <p id="@_errorId" class="text-xs text-destructive mt-1.5">@ErrorText</p>
    }
    else if (HelperText is not null)
    {
        <p id="@_helperId" class="text-xs text-muted-foreground mt-1.5">@HelperText</p>
    }
}

<Dialog @bind-Open="_linkDialogOpen">
    <DialogContent Class="max-w-md">
        <DialogHeader>
            <DialogTitle>@L["Editor.InsertLinkTitle"]</DialogTitle>
            <DialogDescription>@L["Editor.InsertLinkDescription"]</DialogDescription>
        </DialogHeader>
        <div class="py-2">
            <Input @bind-Value="_linkDialogUrl"
                   Placeholder="https://"
                   @onkeydown="HandleLinkDialogKey" />
        </div>
        <DialogFooter>
            <Button Variant="Button.ButtonVariant.Outline" OnClick="CancelLinkDialog">@L["Editor.Cancel"]</Button>
            <Button Variant="Button.ButtonVariant.Default" OnClick="ApplyLinkDialog" Disabled="@string.IsNullOrWhiteSpace(_linkDialogUrl)">
                @L["Editor.Apply"]
            </Button>
        </DialogFooter>
    </DialogContent>
</Dialog>

@code {
    [CascadingParameter] private FormField.FormFieldContext? FormField { get; set; }

    // ---- Backwards-compatible params ----
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }
    [Parameter] public string? Placeholder { get; set; }
    private string EffectivePlaceholder => Placeholder ?? L["Editor.StartWriting"];
    [Parameter] public int MinHeight { get; set; } = 180;
    [Parameter] public int? MaxHeight { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Invalid { get; set; }
    [Parameter] public string? ErrorText { get; set; }
    [Parameter] public string? HelperText { get; set; }
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Name { get; set; }

    /// <summary>Legacy toolbar mode; superseded by <see cref="Toolbar"/>.</summary>
    [Parameter] public RichTextToolbarMode? ToolbarMode { get; set; }

    /// <summary>Toolbar density preset. Defaults to <see cref="EditorToolbarPreset.Standard"/>.</summary>
    [Parameter] public EditorToolbarPreset Toolbar { get; set; } = EditorToolbarPreset.Standard;

    // ---- New: rich features ----
    [Parameter] public IReadOnlyList<EditorTrigger>? Triggers { get; set; }
    [Parameter] public bool EnableSlashCommand { get; set; } = true;
    [Parameter] public bool EnableTables { get; set; } = true;
    [Parameter] public bool EnableCodeBlock { get; set; } = true;
    [Parameter] public bool EnableImages { get; set; } = true;
    [Parameter] public bool EnableTaskList { get; set; } = true;
    [Parameter] public bool EnableMarkdownShortcuts { get; set; } = true;
    [Parameter] public bool EnableAiActions { get; set; }
    [Parameter] public bool EnableBubbleMenu { get; set; } = true;
    [Parameter] public bool EnableDragHandle { get; set; } = true;
    [Parameter] public int? MaxLength { get; set; }
    [Parameter] public bool AllowWordImport { get; set; }

    /// <summary>
    /// Maximum size, in bytes, of a Word document accepted by the in-browser import path.
    /// Defaults to 8 MB. Larger files are refused before being read into memory and surfaced
    /// to the user via <c>WordImportError</c>. Set explicitly when consumers expect
    /// large documents and the deployment can afford the memory.
    /// </summary>
    [Parameter] public long MaxWordImportBytes { get; set; } = 8L * 1024L * 1024L;

    /// <summary>Resolves a picked image into a URL (or data URI). Receives file metadata
    /// from JS; consumer is expected to upload the file out-of-band (e.g. via a paired
    /// <c>InputFile</c>) and return a final URL. If null, images fall back to base64.</summary>
    [Parameter] public Func<EditorImageRequest, ValueTask<string?>>? OnImageRequested { get; set; }

    /// <summary>Selection-driven AI actions. Receives the action id and selected plain text;
    /// returns replacement HTML to be inserted in place of the selection.</summary>
    [Parameter] public Func<string, string, ValueTask<string?>>? OnAiAction { get; set; }

    /// <summary>Optional override for Word import. Receives the picked file payload
    /// (filename + bytes) and returns HTML to replace the editor content. When NOT set,
    /// the file is converted in-browser via <see cref="WordImporter"/> (Mammoth runs
    /// inside the WASM bundle), so the demo works on static hosting with no server.
    /// Set this when you want server-side conversion (better fidelity for complex docs).</summary>
    [Parameter] public Func<WordImportPayload, ValueTask<string>>? OnWordImportRequested { get; set; }

    [Parameter] public EventCallback<string> OnInitError { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool EffectiveInvalid => Invalid || FormField?.HasError == true;
    private bool InsideFormField => FormField is not null;

    // Stable ids so the editable surface can be associated with its Label,
    // helper, and error text via aria-labelledby / aria-describedby (Base UI
    // Field a11y parity). Generated once per instance; only emitted onto the
    // markup when the corresponding text is actually rendered.
    private readonly string _labelId = $"rte-label-{Guid.NewGuid():N}";
    private readonly string _helperId = $"rte-helper-{Guid.NewGuid():N}";
    private readonly string _errorId = $"rte-error-{Guid.NewGuid():N}";

    // The element id of the standalone label, when one is rendered (i.e. a Label
    // was supplied AND we're not inside a FormField, which owns its own label).
    private string? StandaloneLabelId =>
        Label is not null && !InsideFormField ? _labelId : null;

    // aria-labelledby for the editable surface: our own standalone label. Inside a
    // FormField the label association is owned by the FormField's <label for> ->
    // control id link, so we do NOT emit a (potentially wrong) aria-labelledby here.
    private string? EditorLabelledBy => StandaloneLabelId;

    // aria-describedby for the editable surface: the FormField's active message id
    // when nested, else whichever of our own helper/error <p> is currently shown.
    private string? EditorDescribedBy
    {
        get
        {
            if (InsideFormField) return FormField!.DescribedBy;
            if (_wordImportError is not null) return null; // role=alert <p> announces itself
            if (EffectiveInvalid && ErrorText is not null) return _errorId;
            if (HelperText is not null) return _helperId;
            return null;
        }
    }

    private EditorToolbarPreset EffectiveToolbar => ToolbarMode switch
    {
        RichTextToolbarMode.None => EditorToolbarPreset.None,
        RichTextToolbarMode.Basic => EditorToolbarPreset.Minimal,
        RichTextToolbarMode.Full => EditorToolbarPreset.Full,
        _ => Toolbar,
    };

    private Microsoft.AspNetCore.Components.ElementReference _contentRef;
    private DotNetObjectReference<RichTextEditor>? _selfRef;
    private string? _instanceId;
    // The live document the editor currently holds (seeded from Value, then driven
    // by OnContentUpdate). This is the source of truth for editor content — we never
    // store live edit state back into the [Parameter] Value, so an unrelated parent
    // re-render that re-supplies a stale Value cannot clobber in-progress typing.
    private string? _lastSetValue;
    // UNCONTROLLED discriminator: the last Value the PARENT supplied. Used only when
    // ValueChanged is NOT bound — we adopt the parameter only when it genuinely changes.
    private string? _lastParamValue;
    // CONTROLLED discriminator: the last value WE pushed UP via ValueChanged (set before
    // raising ValueChanged so the parent's synchronous re-render sees it immediately).
    // When ValueChanged IS bound the parent owns Value, so in OnParametersSet we compare
    // against _lastPushed: equal → echo of our own edit → keep editor state; unequal →
    // parent asserted a different value (normalization, reset, or REJECTION that left the
    // old Value in place) → authoritative re-sync, which is the controlled-rollback fix.
    private string? _lastPushed;
    // Snapshot of the trigger char-set last handed to JS, so a Triggers change after
    // init can be detected and the editor re-initialized (suggestion extensions are
    // registered at construction time inside the JS module).
    private string _lastTriggerChars = string.Empty;
    private bool _lastDisabled;
    private bool _lastReadOnly;
    // Last aria-invalid / aria-describedby values pushed to the editor's contenteditable
    // via rte.setAriaAttributes. Tracked so we only call the interop when they change —
    // validation state (EffectiveInvalid) and the describedby id both change post-mount
    // when a Form submit fires, which the init-time snapshot misses (Fix 2).
    private bool _lastAriaInvalid;
    private string? _lastAriaDescribedBy;
    private Services.Interop.RichTextActiveState? _active;
    private bool _initialized;
    private string? _initError;
    // Set by the Retry button; consumed in the next OnAfterRenderAsync once the content
    // host has been re-rendered, so init runs against a live ElementReference.
    private bool _retryRequested;

    // Link dialog state (replaces the native browser prompt for the toolbar
    // and bubble menu's Link button).
    private bool _linkDialogOpen;
    private string _linkDialogUrl = string.Empty;

    // Surface the most-recent Word import failure (size cap, decode error, etc.)
    // inline below the editor — same slot the EffectiveInvalid path uses.
    private string? _wordImportError;

    private void OpenLinkDialog(string? initial)
    {
        _linkDialogUrl = string.IsNullOrWhiteSpace(initial) ? "https://" : initial;
        _linkDialogOpen = true;
        StateHasChanged();
    }

    private void CancelLinkDialog()
    {
        _linkDialogOpen = false;
    }

    private async Task ApplyLinkDialog()
    {
        var url = _linkDialogUrl?.Trim();
        _linkDialogOpen = false;
        if (string.IsNullOrWhiteSpace(url) || _instanceId is null) return;
        await Interop.RichTextCommandAsync(_instanceId, "link", new object?[] { url });
    }

    private async Task HandleLinkDialogKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ApplyLinkDialog();
        else if (e.Key == "Escape") CancelLinkDialog();
    }

    [JSInvokable("OnLinkRequested")]
    public Task OnLinkRequestedJs(string? currentUrl)
    {
        OpenLinkDialog(currentUrl);
        return Task.CompletedTask;
    }

    private string RootClass =>
        $"rounded-lg border {(EffectiveInvalid ? "border-destructive focus-within:ring-destructive/20" : "border-border/40 focus-within:border-ring/60 focus-within:ring-ring/40")} bg-card overflow-hidden transition-colors focus-within:ring-[1.5px] {Class}".Trim();

    private string ContentStyle
    {
        get
        {
            var parts = new List<string> { $"min-height: {MinHeight}px" };
            if (MaxHeight is int max)
            {
                parts.Add($"max-height: {max}px");
                parts.Add("overflow-y: auto");
            }
            return string.Join("; ", parts) + ";";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _selfRef = DotNetObjectReference.Create(this);
            _lastSetValue = Value;
            _lastParamValue = Value;
            _lastPushed = Value;
            _lastDisabled = Disabled;
            _lastReadOnly = ReadOnly;

            await InitEditorAsync();
            return;
        }

        // Retry path: the user clicked "Retry" on the init-failure banner. The content
        // host stayed mounted (the error renders ABOVE it, not instead of it), so the
        // ElementReference is still valid and a fresh init can succeed. The flag is
        // consumed here — after a render that re-mounts the host — so _contentRef is live.
        if (_retryRequested)
        {
            _retryRequested = false;
            await InitEditorAsync();
        }
    }

    /// <summary>
    /// (Re-)creates the underlying JS editor instance against the current content host.
    /// Called once on first render, and again whenever a Triggers change requires the
    /// suggestion extensions to be rebuilt (they are registered at construction time in
    /// the JS module, so a live change cannot be applied in place without re-init).
    /// </summary>
    private async Task InitEditorAsync()
    {
        if (_selfRef is null) return;

        // Build the "trigger" descriptor list passed into JS — only the
        // metadata the JS needs (char + label). Item resolution happens via
        // the OnTriggerQuery JSInvokable below, which fans queries out to
        // the matching EditorTrigger registered server-side.
        var triggers = Triggers ?? Array.Empty<EditorTrigger>();
        var triggerMeta = triggers
            .Select(t => new { @char = t.Char.ToString(), label = $"{t.Char} suggestions" })
            .ToArray();
        _lastTriggerChars = TriggerCharSet(triggers);

        // Seed the new instance with the live document (what's currently in the
        // editor) rather than the [Parameter] Value, so a re-init triggered by an
        // unrelated parameter change (e.g. Triggers) preserves in-progress edits.
        var seed = _lastSetValue ?? Value ?? string.Empty;

        var options = new
        {
            content = seed,
            initialHtml = seed,
            placeholder = EffectivePlaceholder,
            disabled = Disabled,
            readOnly = ReadOnly,
            editable = !Disabled && !ReadOnly,
            mentionTriggers = triggerMeta,
            enableSlashCommand = EnableSlashCommand,
            enableTables = EnableTables,
            enableCodeBlock = EnableCodeBlock,
            enableImages = EnableImages,
            enableTaskList = EnableTaskList,
            enableMarkdownShortcuts = EnableMarkdownShortcuts,
            enableAiActions = EnableAiActions,
            enableBubbleMenu = EnableBubbleMenu,
            enableDragHandle = EnableDragHandle,
            maxLength = MaxLength,
            maxWordImportBytes = MaxWordImportBytes,
            // A11y: TipTap mounts the contenteditable as a child of the content
            // host, so role/aria-multiline/required/invalid and the label/desc
            // associations must be pushed onto it via editorProps.attributes too
            // (the host wrapper carries the same set for non-TipTap consumers).
            role = "textbox",
            ariaMultiline = true,
            ariaRequired = Required,
            ariaInvalid = EffectiveInvalid,
            ariaLabelledBy = EditorLabelledBy,
            ariaDescribedBy = EditorDescribedBy,
        };

        try
        {
            _instanceId = await Interop.RichTextInitAsync(_contentRef, _selfRef, options);
        }
        catch (JSDisconnectedException)
        {
            // The circuit went away mid-init (navigation/teardown). Nothing to surface —
            // there is no live UI to retry against — and this must not be reported as an
            // init failure the consumer can recover from.
            return;
        }
        catch (Exception ex)
        {
            // Catch the broader set (not just JSException): a malformed option payload,
            // a serialization error, or an exception thrown inside the JS module all
            // leave the editor unmounted. Surface a recoverable banner + Retry rather
            // than letting the component render blank or rethrow into the parent.
            _initError = ex.Message;
            Console.Error.WriteLine($"[Lumeo RichTextEditor] Init failed: {ex.Message}");
            if (OnInitError.HasDelegate)
                await OnInitError.InvokeAsync(ex.Message);
            StateHasChanged();
            return;
        }
        _initialized = !string.IsNullOrEmpty(_instanceId);
        if (_initialized)
        {
            // Recovered: a successful (re-)init clears any prior error banner so the
            // component returns to its normal rendered state.
            _initError = null;
            // Seed the aria snapshot with what we just passed to rte.init so the
            // post-init change-detection in OnParametersSetAsync starts from truth.
            _lastAriaInvalid = EffectiveInvalid;
            _lastAriaDescribedBy = EditorDescribedBy;
            await RefreshActiveAsync();
        }
    }

    /// <summary>
    /// Retry handler for the init-failure banner. Clears the error and flags a re-init,
    /// which runs in the NEXT OnAfterRenderAsync — by then the content host has been
    /// re-rendered (the banner sits above it, so the host is always mounted) and its
    /// ElementReference is valid to init against. Idempotent: a re-init already in flight
    /// is not double-scheduled.
    /// </summary>
    private void RetryInitAsync()
    {
        if (_initialized) return;
        _initError = null;
        _retryRequested = true;
        StateHasChanged();
    }

    // Normalize a trigger list to its (ordered, distinct) char set so Triggers changes
    // are detected by what JS actually keys off — the activation characters.
    private static string TriggerCharSet(IReadOnlyList<EditorTrigger> triggers)
        => triggers.Count == 0
            ? string.Empty
            : string.Concat(triggers.Select(t => t.Char).Distinct().OrderBy(c => c));

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || _instanceId is null) return;

        // Re-init when the activation char-set changes: suggestion extensions are wired
        // at construction in the JS module, so an added char would never fire and a
        // removed char would keep firing without a rebuild. Re-init seeds from the live
        // document (_lastSetValue), so this preserves in-progress edits.
        var triggerChars = TriggerCharSet(Triggers ?? Array.Empty<EditorTrigger>());
        if (!string.Equals(triggerChars, _lastTriggerChars, StringComparison.Ordinal))
        {
            var oldId = _instanceId;
            _instanceId = null;
            _initialized = false;
            try { await Interop.RichTextDestroyAsync(oldId); }
            catch (JSDisconnectedException) { /* circuit gone */ }
            await InitEditorAsync();
            return;
        }

        // Content sync — split on controlled vs. uncontrolled (same pattern as Input).
        //
        // CONTROLLED (ValueChanged bound): compare against _lastPushed (the last value WE
        // emitted). If Value equals _lastPushed the parent is echoing our own edit — skip so
        // we don't disturb the editor or cursor. If Value differs, the parent asserted a new
        // value: a normalization, a programmatic reset, or — crucially — a REJECTION that
        // kept the old Value in place (Value != html we pushed) → must re-sync TipTap to
        // roll back the rejected edit. (Codex P2 controlled-rollback fix.)
        //
        // UNCONTROLLED (no ValueChanged): compare against _lastParamValue (the last Value
        // the parent supplied). An unrelated re-render that re-supplies the same stale Value
        // must not clobber in-progress typing; adopt only on genuine parent-driven changes.
        if (ValueChanged.HasDelegate)
        {
            if (!string.Equals(Value, _lastPushed, StringComparison.Ordinal))
            {
                _lastPushed = Value;
                _lastSetValue = Value;
                await Interop.RichTextSetContentAsync(_instanceId, Value);
            }
        }
        else if (!string.Equals(Value, _lastParamValue, StringComparison.Ordinal))
        {
            _lastSetValue = Value;
            await Interop.RichTextSetContentAsync(_instanceId, Value);
        }
        // Always keep the uncontrolled discriminator current.
        _lastParamValue = Value;

        if (Disabled != _lastDisabled || ReadOnly != _lastReadOnly)
        {
            _lastDisabled = Disabled;
            _lastReadOnly = ReadOnly;
            await Interop.RichTextSetDisabledAsync(_instanceId, Disabled || ReadOnly);
        }

        // Aria attributes post-mount sync (Codex P2 aria-after-mount fix):
        // aria-invalid and aria-describedby are passed to TipTap at init but can change
        // later (e.g. a Form submit adds a validation error). The wrapper div re-renders
        // automatically, but TipTap's contenteditable keeps the init-time snapshot unless
        // we push the update via interop. Only call when the values actually changed.
        var currentAriaInvalid = EffectiveInvalid;
        var currentAriaDescribedBy = EditorDescribedBy;
        if (currentAriaInvalid != _lastAriaInvalid ||
            !string.Equals(currentAriaDescribedBy, _lastAriaDescribedBy, StringComparison.Ordinal))
        {
            _lastAriaInvalid = currentAriaInvalid;
            _lastAriaDescribedBy = currentAriaDescribedBy;
            await Interop.RichTextSetAriaAttributesAsync(_instanceId, currentAriaInvalid, currentAriaDescribedBy);
        }
    }

    // ---------------- JS callbacks ----------------

    [JSInvokable]
    public async Task OnContentUpdate(string html)
    {
        // Track the live document only; do NOT write back into the [Parameter] Value.
        // Value is a controlled input — storing our own edit state there would let an
        // unrelated parent re-render (which re-supplies the parent's stale Value) wipe
        // in-progress typing.
        _lastSetValue = html;
        // Record _lastPushed BEFORE raising ValueChanged: a controlled parent may
        // re-render synchronously inside InvokeAsync, so OnParametersSet must already
        // see this as "the value we pushed" to recognise the echo and not disturb the
        // editor. This is what makes the controlled-rollback detection work correctly.
        _lastPushed = html;
        await ValueChanged.InvokeAsync(html);
        await RefreshActiveAsync();
    }

    /// <summary>Mirror of <see cref="OnContentUpdate"/> kept for the new JS naming.</summary>
    [JSInvokable]
    public Task OnUpdate(string html) => OnContentUpdate(html);

    [JSInvokable]
    public Task OnSelectionUpdate() => RefreshActiveAsync();

    [JSInvokable]
    public async Task<IReadOnlyList<TriggerItem>> OnTriggerQuery(string triggerChar, string query)
    {
        // Slash command default — only kicks in if no consumer trigger overrides '/'.
        if (triggerChar == "/" && (Triggers is null || !Triggers.Any(t => t.Char == '/')))
        {
            return EnableSlashCommand
                ? await SlashCommands.Filter(query, L)
                : Array.Empty<TriggerItem>();
        }

        var trigger = Triggers?.FirstOrDefault(t => t.Char.ToString() == triggerChar);
        if (trigger is null) return Array.Empty<TriggerItem>();
        try
        {
            return await trigger.ItemSource(query) ?? Array.Empty<TriggerItem>();
        }
        catch
        {
            return Array.Empty<TriggerItem>();
        }
    }

    [JSInvokable("OnImageRequested")]
    public async Task<string?> OnImageRequestedJs(string fileName, string mimeType, long size)
    {
        if (OnImageRequested is null) return null;
        try
        {
            return await OnImageRequested(new EditorImageRequest(fileName, mimeType, size));
        }
        catch
        {
            return null;
        }
    }

    [JSInvokable("OnAiAction")]
    public async Task<string?> OnAiActionJs(string actionId, string selectedText)
    {
        if (OnAiAction is null) return null;
        try
        {
            return await OnAiAction(actionId, selectedText);
        }
        catch
        {
            return null;
        }
    }

    [JSInvokable("OnWordImportRequested")]
    public async Task OnWordImportRequestedJs(string fileName, string base64Content)
    {
        try
        {
            // Pre-allocation size guard — decoded length is computed from the base64
            // string length, so an oversized payload is rejected BEFORE the .NET
            // byte[] allocation that would normally double peak memory usage.
            var bytes = WordImporter.DecodeBase64WithLimit(base64Content, MaxWordImportBytes);
            var payload = new WordImportPayload(fileName, bytes);

            string html;
            if (OnWordImportRequested is not null)
            {
                html = await OnWordImportRequested(payload);
            }
            else
            {
                using var stream = new MemoryStream(bytes);
                var result = await WordImporter.ToHtmlAsync(stream);
                html = result.Html;
            }

            if (!string.IsNullOrEmpty(html))
            {
                _wordImportError = null;
                await SetHtmlAsync(html);
            }
        }
        catch (WordImportSizeException sizeEx)
        {
            _wordImportError = $"Word document too large ({FormatBytes(sizeEx.ActualBytes)}). Limit is {FormatBytes(sizeEx.LimitBytes)}.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            _wordImportError = "Word import failed. Try saving the document again or pick a different file.";
            Console.Error.WriteLine($"Word import failed: {ex.Message}");
            StateHasChanged();
        }
    }

    [JSInvokable("OnWordImportFailed")]
    public Task OnWordImportFailedJs(string reason, long size, long limit)
    {
        _wordImportError = reason switch
        {
            "file_too_large" => $"Word document too large ({FormatBytes(size)}). Limit is {FormatBytes(limit)}.",
            _ => "Word import failed. Try saving the document again or pick a different file.",
        };
        StateHasChanged();
        return Task.CompletedTask;
    }

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} KB";
        return $"{bytes / (1024.0 * 1024.0):0.#} MB";
    }

    // ---------------- Toolbar dispatch ----------------

    private async Task HandleToolbarCommand((string command, object? arg) cmd)
    {
        if (_instanceId is null || Disabled || ReadOnly) return;

        switch (cmd.command)
        {
            case "link":
            {
                OpenLinkDialog(null);
                break;
            }
            case "ai-menu":
                // Reserved for a future popover. For now, fire an "improve" against
                // current selection if the consumer wired OnAiAction.
                if (OnAiAction is not null)
                {
                    await Interop.RichTextCommandAsync(_instanceId, "noop", null);
                }
                break;
            default:
                var args = cmd.arg is null ? null : new object?[] { cmd.arg };
                await Interop.RichTextCommandAsync(_instanceId, cmd.command, args);
                break;
        }

        await RefreshActiveAsync();
    }

    private async Task RefreshActiveAsync()
    {
        if (_instanceId is null) return;
        _active = await Interop.RichTextGetActiveAsync(_instanceId);
        StateHasChanged();
    }

    // ---------------- Public API for consumers ----------------

    /// <summary>Replaces the editor content with the given HTML.</summary>
    public async ValueTask SetHtmlAsync(string? html)
    {
        if (_instanceId is null) return;
        // Imperative content replace (consumer API / Word import). Keep the live
        // document in sync and notify via ValueChanged, but do NOT write back into
        // the [Parameter] Value — it stays a controlled input owned by the parent.
        _lastSetValue = html;
        _lastPushed = html; // Set before ValueChanged so a controlled parent sees the echo.
        await Interop.RichTextSetContentAsync(_instanceId, html);
        await ValueChanged.InvokeAsync(html);
    }

    public async ValueTask DisposeAsync()
    {
        if (_instanceId is not null)
        {
            try
            {
                await Interop.RichTextDestroyAsync(_instanceId);
            }
            catch (JSDisconnectedException) { /* ignore — circuit already gone */ }
            _instanceId = null;
        }
        _selfRef?.Dispose();
        _selfRef = null;
    }

    /// <summary>Legacy toolbar mode — kept so existing call sites compile.</summary>
    public enum RichTextToolbarMode
    {
        None,
        Basic,
        Full,
    }
}
