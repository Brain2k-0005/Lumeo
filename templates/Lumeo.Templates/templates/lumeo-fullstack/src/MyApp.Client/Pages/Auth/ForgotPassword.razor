@page "/forgot-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@inject HttpClient Http

<PageTitle>Reset password — MyApp</PageTitle>

<Card Class="w-full max-w-md border-border/60 shadow-lg">
    <CardContent Class="px-8 pt-10 pb-8">
        @if (!_sent)
        {
            <Stack Gap="6">
                <Stack Gap="4" Class="items-center text-center">
                    <Flex Class="h-12 w-12 items-center justify-center rounded-[var(--radius-lg)] bg-primary/10">
                        <SvgGlyph Svg="@(LumeoIcons.Lock)" class="h-6 w-6 text-primary" />
                    </Flex>
                    <Stack Gap="1.5">
                        <Heading Level="1" Class="text-2xl font-bold tracking-tight">Forgot your password?</Heading>
                        <Lumeo.Text Color="muted" Size="sm" Class="max-w-xs">
                            Enter the email associated with your account and we'll send you a reset code.
                        </Lumeo.Text>
                    </Stack>
                </Stack>

                <EditForm Model="this" OnValidSubmit="SendReset">
                    <Stack Gap="4">
                        <Stack Gap="2">
                            <Label for="fp-email">Email address</Label>
                            <Lumeo.Input id="fp-email" type="email" placeholder="you@example.com" @bind-Value="_email">
                                <Prefix><SvgGlyph Svg="@(LumeoIcons.Mail)" class="h-4 w-4 text-muted-foreground" /></Prefix>
                            </Lumeo.Input>
                        </Stack>

                        <Button Type="Button.ButtonType.Submit" Class="w-full" IsLoading="@_loading" Disabled="@(string.IsNullOrWhiteSpace(_email))">
                            @if (!_loading)
                            {
                                <SvgGlyph Svg="@(LumeoIcons.Send)" class="h-4 w-4" />
                            }
                            Send reset code
                        </Button>
                    </Stack>
                </EditForm>

                <Flex Align="center" Justify="center" Gap="2">
                    <SvgGlyph Svg="@(LumeoIcons.ChevronLeft)" class="h-3.5 w-3.5 text-muted-foreground" />
                    <Lumeo.Link Href="login" Class="text-sm text-muted-foreground hover:text-foreground no-underline">
                        Back to sign in
                    </Lumeo.Link>
                </Flex>
            </Stack>
        }
        else
        {
            <Stack Gap="6">
                <Stack Gap="4" Class="items-center text-center">
                    <Flex Class="h-12 w-12 items-center justify-center rounded-[var(--radius-lg)] bg-emerald-500/15">
                        <SvgGlyph Svg="@(LumeoIcons.Mail)" class="h-6 w-6 text-emerald-600" />
                    </Flex>
                    <Stack Gap="1.5">
                        <Heading Level="1" Class="text-2xl font-bold tracking-tight">Check your inbox</Heading>
                        <Lumeo.Text Color="muted" Size="sm" Class="max-w-xs">
                            If an account exists for
                            <Lumeo.Text As="span" Weight="medium" Color="foreground">@(string.IsNullOrWhiteSpace(_email) ? "that email" : _email)</Lumeo.Text>,
                            we've sent a password reset code.
                        </Lumeo.Text>
                    </Stack>
                </Stack>

                <Flex Class="rounded-[var(--radius-lg)] bg-muted/50 border border-border/40 px-4 py-3 gap-3" Align="start">
                    <SvgGlyph Svg="@(LumeoIcons.Info)" class="h-4 w-4 text-muted-foreground mt-0.5 shrink-0" />
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed">
                        Complete the reset by POSTing the code with a new password to
                        <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono">/api/auth/resetPassword</code> —
                        wire a reset-password page to that endpoint to finish the flow.
                    </Lumeo.Text>
                </Flex>

                <Flex Align="center" Justify="center" Gap="2">
                    <SvgGlyph Svg="@(LumeoIcons.ChevronLeft)" class="h-3.5 w-3.5 text-muted-foreground" />
                    <Lumeo.Link Href="login" Class="text-sm text-muted-foreground hover:text-foreground no-underline">
                        Back to sign in
                    </Lumeo.Link>
                </Flex>
            </Stack>
        }
    </CardContent>
</Card>

@code {
    private string _email = string.Empty;
    private bool _sent;
    private bool _loading;

    private async Task SendReset()
    {
        _loading = true;
        // The endpoint always returns 200 (it never reveals whether the account exists).
        await Http.PostAsJsonAsync("api/auth/forgotPassword", new { email = _email });
        _loading = false;
        _sent = true;
    }
}
