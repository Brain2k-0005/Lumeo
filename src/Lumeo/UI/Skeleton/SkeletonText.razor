@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    @for (var i = 0; i < Lines; i++)
    {
        <Skeleton Animation="Animation" Class="@($"h-4 {(i == Lines - 1 ? "w-3/4" : "w-full")}")" />
    }
</div>

@code {
    /// <summary>Number of skeleton lines to render. Defaults to 3. The last line renders
    /// narrower (<c>w-3/4</c>) so the block reads as wrapped text.</summary>
    [Parameter] public int Lines { get; set; } = 3;
    /// <summary>Loading animation applied to every line. Defaults to
    /// <see cref="Skeleton.SkeletonAnimation.Pulse"/>.</summary>
    [Parameter] public Skeleton.SkeletonAnimation Animation { get; set; } = Skeleton.SkeletonAnimation.Pulse;
    /// <summary>Additional CSS classes merged onto the root <c>div</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("space-y-2", Class);
}
