@page "/components/calendar"

<PageTitle>Calendar — Lumeo</PageTitle>

<PageHeader Title="Calendar" Description="A date picker calendar component for selecting dates." />

<InstallUsage Component="Calendar" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Displaying a visual calendar for date selection and browsing</li>
        <li>Event scheduling interfaces where users pick start and end dates</li>
        <li>Date range visualization such as booking check-in and check-out</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Default" Code="@_defaultCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_selectedDate" />
            </Stack>
        </Flex>
        @if (_selectedDate.HasValue)
        {
            <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-4">Selected: @_selectedDate.Value.ToString("MMMM d, yyyy")</Lumeo.Text>
        }
    </ComponentDemo>

    <ComponentDemo Title="Date Range Display" Code="@_rangeCode">
        <Stack Gap="4" Class="w-full max-w-sm">
            <Stack Direction="Lumeo.Orientation.Horizontal" Gap="4" Class="flex-col sm:flex-row">
                <Stack Gap="1.5" Class="flex-1">
                    <Label>Check-in</Label>
                    <Stack Class="rounded-md border bg-card p-1">
                        <Calendar @bind-Value="_checkIn" />
                    </Stack>
                </Stack>
            </Stack>
            @if (_checkIn.HasValue)
            {
                <Flex Align="center" Gap="2" Class="p-3 rounded-md bg-muted/50 text-sm">
                    <DynamicIcon Name="Calendar" Class="h-4 w-4 text-muted-foreground" />
                    <Lumeo.Text As="span" Size="sm">Check-in: <strong>@_checkIn.Value.ToString("MMM d, yyyy")</strong></Lumeo.Text>
                </Flex>
            }
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Pre-selected Date" Code="@_preselectedCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_preselectedDate" />
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Min & Max Date" Code="@_minMaxCode">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_constrainedDate" MinDate="@_minDate" MaxDate="@_maxDate" />
            </Stack>
        </Flex>
        <Lumeo.Text Size="sm" Color="muted" Class="text-center mt-2">Selectable range: @_minDate.ToString("MMM d") — @_maxDate.ToString("MMM d, yyyy")</Lumeo.Text>
    </ComponentDemo>

    <ComponentDemo Title="Booking calendar — disable + tooltip + badge" Code="@_bookingCode">
        <Stack Gap="2">
            <Flex Justify="center">
                <Stack Class="rounded-md border bg-card p-1">
                    <Calendar @bind-Value="_bookingDate"
                              MinDate="DateOnly.FromDateTime(DateTime.Today)"
                              MaxDate="DateOnly.FromDateTime(DateTime.Today.AddDays(60))"
                              IsDateDisabled="@IsBookedOrClosed"
                              DateClass="@GetBookingClass"
                              DateTooltip="@GetBookingTooltip"
                              DateBadge="@GetBookingBadge" />
                </Stack>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Class="text-center">
                Hover any day for the tooltip; the badge dot indicates booking status — green = available, amber = partial, red = sold out, grey = closed.
            </Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Selection">
        <Stack Gap="2">
            <Flex Justify="center">
                <Stack Class="rounded-md border bg-card p-1">
                    <Calendar IsMultiple="true" @bind-Values="_multiDates" />
                </Stack>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Class="text-center">
                Selected @( _multiDates?.Count ?? 0) day(s).
            </Lumeo.Text>
        </Stack>
    </ComponentDemo>

    <ComponentDemo Title="Multiple Months">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_multiMonthDate" NumberOfMonths="2" />
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Week Numbers">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_weekNumDate" ShowWeekNumbers="true" />
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Initial View — Year Picker">
        <Flex Justify="center">
            <Stack Class="rounded-md border bg-card p-1">
                <Calendar @bind-Value="_yearViewDate" InitialView="Calendar.CalendarView.Years" />
            </Stack>
        </Flex>
    </ComponentDemo>

    <ComponentDemo Title="Date Range" Code="@_dateRangeCode">
        <Stack Gap="2">
            <Flex Justify="center">
                <Stack Class="rounded-md border bg-card p-1">
                    <Calendar IsRange="true" @bind-RangeStart="_rangeStart" @bind-RangeEnd="_rangeEnd" />
                </Stack>
            </Flex>
            <Lumeo.Text Size="sm" Color="muted" Class="text-center">
                @if (_rangeStart.HasValue && _rangeEnd.HasValue)
                {
                    @($"Selected: {_rangeStart:MMM dd} — {_rangeEnd:MMM dd}")
                }
                else if (_rangeStart.HasValue)
                {
                    @($"Start: {_rangeStart:MMM dd} — pick end date")
                }
                else
                {
                    <Lumeo.Text As="span">Pick a start date</Lumeo.Text>
                }
            </Lumeo.Text>
        </Stack>
    </ComponentDemo>
</Stack>

<Alert Variant="Alert.AlertVariant.Info" ShowIcon="true" Class="mt-8">
    <strong>Mobile (rc.52).</strong> Swipe left or right on the day grid to navigate between months — vertical page scroll is preserved. Nav chevrons are 44&times;44 px on mobile (<code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">h-11 w-11 sm:h-7 sm:w-7</code>). Set <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">SwipeEnabled="false"</code> to opt out.
</Alert>

<div class="mt-16">
    <Heading Id="api-reference" Level="2" Class="scroll-mt-20">API Reference</Heading>

    <Heading Id="calendar" Level="3" Class="mt-8 scroll-mt-20">Calendar</Heading>
    <div class="mt-4">
        <PropsTable Slug="calendar" />
    </div>
    <Lumeo.Text Size="sm" Color="muted" Class="mt-2">
        <code>DateTooltip</code> and <code>DateBadge</code> shipped in rc.20.
    </Lumeo.Text>
</div>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/date-picker" class="text-primary hover:underline">DatePicker</a> — For selecting dates via an input field with a calendar dropdown</li>
    </ul>
</div>

@code {
    private DateOnly? _selectedDate;
    private DateOnly? _preselectedDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? _checkIn;
    private DateOnly? _constrainedDate;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
    private List<DateOnly>? _multiDates = new();
    private DateOnly? _multiMonthDate;
    private DateOnly? _weekNumDate;
    private DateOnly? _yearViewDate;

    // Booking-style demo: synthesised hotel availability so the badges + tooltips
    // light up at varied positions across the next 60 days.
    private DateOnly? _bookingDate;
    private HashSet<DateOnly> _booked = Enumerable.Range(2, 60)
        .Where(i => i % 7 == 3 || i % 11 == 5)
        .Select(i => DateOnly.FromDateTime(DateTime.Today.AddDays(i))).ToHashSet();
    private HashSet<DateOnly> _partial = Enumerable.Range(1, 60)
        .Where(i => i % 5 == 0)
        .Select(i => DateOnly.FromDateTime(DateTime.Today.AddDays(i))).ToHashSet();
    private HashSet<DateOnly> _closed = Enumerable.Range(1, 60)
        .Select(i => DateOnly.FromDateTime(DateTime.Today.AddDays(i)))
        .Where(d => d.DayOfWeek == DayOfWeek.Sunday).ToHashSet();

    private bool IsBookedOrClosed(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        return _booked.Contains(date) || _closed.Contains(date);
    }

    private string GetBookingClass(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        if (_booked.Contains(date)) return "bg-destructive/10 text-destructive line-through";
        if (_closed.Contains(date)) return "bg-muted/40 italic";
        if (_partial.Contains(date)) return "bg-warning/15 ring-1 ring-warning/40";
        return "";
    }

    private string? GetBookingTooltip(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        if (_booked.Contains(date)) return $"{date:MMM d} — Sold out";
        if (_closed.Contains(date)) return $"{date:MMM d} — Closed (Sunday)";
        if (_partial.Contains(date)) return $"{date:MMM d} — Limited availability";
        if (date >= DateOnly.FromDateTime(DateTime.Today)) return $"{date:MMM d} — Available";
        return null;
    }

    private RenderFragment? GetBookingBadge(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        if (date < DateOnly.FromDateTime(DateTime.Today)) return null;
        var color =
            _booked.Contains(date) ? "bg-destructive" :
            _partial.Contains(date) ? "bg-warning" :
            _closed.Contains(date) ? "bg-muted-foreground/40" :
            "bg-success";
        return @<span class="@($"block h-1.5 w-1.5 rounded-full {color}")"></span>;
    }

    private string _defaultCode = @"<Calendar @bind-Value=""_selectedDate"" />";

    private string _rangeCode = @"<Stack Gap=""1.5"">
    <Label>Check-in</Label>
    <div class=""rounded-md border p-1"">
        <Calendar @bind-Value=""_checkIn"" />
    </div>
</Stack>
@if (_checkIn.HasValue)
{
    <Flex Align=""center"" Gap=""2"" Class=""p-3 rounded-md bg-muted/50 text-sm"">
        <DynamicIcon Name=""Calendar"" Class=""h-4 w-4 text-muted-foreground"" />
        <Lumeo.Text As=""span"" Size=""sm"">Check-in: <strong>@_checkIn.Value.ToString(""MMM d, yyyy"")</strong></Lumeo.Text>
    </Flex>
}";

    private string _preselectedCode = @"<Calendar @bind-Value=""_date"" />

@code {
    private DateOnly? _date = DateOnly.FromDateTime(DateTime.Today);
}";

    private string _minMaxCode = @"<Calendar @bind-Value=""_date"" MinDate=""@_minDate"" MaxDate=""@_maxDate"" />

@code {
    private DateOnly? _date;
    private DateOnly _minDate = DateOnly.FromDateTime(DateTime.Today.AddDays(-7));
    private DateOnly _maxDate = DateOnly.FromDateTime(DateTime.Today.AddDays(30));
}";

    private string _bookingCode = @"<Calendar @bind-Value=""_bookingDate""
          MinDate=""DateOnly.FromDateTime(DateTime.Today)""
          MaxDate=""DateOnly.FromDateTime(DateTime.Today.AddDays(60))""
          IsDateDisabled=""@IsBookedOrClosed""
          DateClass=""@GetBookingClass""
          DateTooltip=""@GetBookingTooltip""
          DateBadge=""@GetBookingBadge"" />

@code {
    private DateOnly? _bookingDate;
    private HashSet<DateOnly> _booked = new();      // Sold out → disabled, red strike-through
    private HashSet<DateOnly> _partial = new();     // Limited → amber ring
    private HashSet<DateOnly> _closed = new();      // Closed → disabled, grey italic

    private bool IsBookedOrClosed(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        return _booked.Contains(date) || _closed.Contains(date);
    }

    private string GetBookingClass(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        if (_booked.Contains(date))  return ""bg-destructive/10 text-destructive line-through"";
        if (_closed.Contains(date))  return ""bg-muted/40 italic"";
        if (_partial.Contains(date)) return ""bg-warning/15 ring-1 ring-warning/40"";
        return """";
    }

    private string? GetBookingTooltip(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        if (_booked.Contains(date))  return $""{date:MMM d} — Sold out"";
        if (_closed.Contains(date))  return $""{date:MMM d} — Closed"";
        if (_partial.Contains(date)) return $""{date:MMM d} — Limited availability"";
        return $""{date:MMM d} — Available"";
    }

    // Bottom-right indicator dot: green = available, amber = partial, red = booked, grey = closed.
    private RenderFragment? GetBookingBadge(DateTime d)
    {
        var date = DateOnly.FromDateTime(d);
        var color =
            _booked.Contains(date)  ? ""bg-destructive"" :
            _partial.Contains(date) ? ""bg-warning"" :
            _closed.Contains(date)  ? ""bg-muted-foreground/40"" :
            ""bg-success"";
        return @<span class=""@($""block h-1.5 w-1.5 rounded-full {color}"")""></span>;
    }
}";

    private string _dateRangeCode = @"<Calendar IsRange=""true"" @bind-RangeStart=""_rangeStart"" @bind-RangeEnd=""_rangeEnd"" />

@if (_rangeStart.HasValue && _rangeEnd.HasValue)
{
    <Lumeo.Text Size=""sm"" Color=""muted"">Selected: @($""{_rangeStart:MMM dd} — {_rangeEnd:MMM dd}"")</Lumeo.Text>
}

@code {
    private DateOnly? _rangeStart;
    private DateOnly? _rangeEnd;
}";
}
