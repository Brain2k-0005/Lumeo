    private string _searchQuery = string.Empty;
    private ElementReference _searchInput;

    private string CurrentPath => Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/').ToLowerInvariant();

    private bool IsBlocks => CurrentPath.StartsWith("blocks", StringComparison.OrdinalIgnoreCase);

    private bool ShowDocsLayout
    {
        get
        {
            // Landing and themes get full-width layout (no docs sidebar)
            if (CurrentPath == "" || CurrentPath == "themes") return false;
            return true;
        }
    }

    private string NavLinkClass(string segment)
    {
        bool isActive;
        if (segment == "docs")
        {
            isActive = CurrentPath.StartsWith("components", StringComparison.OrdinalIgnoreCase)
                    || CurrentPath.StartsWith("patterns", StringComparison.OrdinalIgnoreCase)
                    || CurrentPath.StartsWith("docs", StringComparison.OrdinalIgnoreCase);
        }
        else
        {
            isActive = CurrentPath.StartsWith(segment, StringComparison.OrdinalIgnoreCase);
        }
        return isActive
            ? "rounded-md px-3 py-1.5 text-foreground bg-accent transition-colors no-underline"
            : "rounded-md px-3 py-1.5 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors no-underline";
    }

