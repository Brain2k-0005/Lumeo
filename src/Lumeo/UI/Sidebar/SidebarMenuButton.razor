@namespace Lumeo

<a href="@Href" class="@CssClass" title="@Tooltip" @attributes="AdditionalAttributes">
    @{
#pragma warning disable CS0618 // obsolete property read for fallback
        var iconFrag = IconContent ?? Icon;
        var labelFrag = LabelContent ?? Label;
#pragma warning restore CS0618
    }
    @if (iconFrag is not null)
    {
        <span class="shrink-0 inline-flex items-center justify-center">@iconFrag</span>
        @if (labelFrag is not null)
        {
            <span class="@LabelCssClass">@labelFrag</span>
        }
    }
    else
    {
        @ChildContent
    }
</a>

@code {
    [CascadingParameter] public SidebarProvider.SidebarState? State { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Icon slot. Use instead of <c>Icon</c> to avoid a name collision with the <c>&lt;Icon&gt;</c> component.</summary>
    [Parameter] public RenderFragment? IconContent { get; set; }

    /// <summary>Label slot. Use instead of <c>Label</c> to avoid a name collision with the <c>&lt;Label&gt;</c> component.</summary>
    [Parameter] public RenderFragment? LabelContent { get; set; }

    [Parameter, System.Obsolete("Use IconContent — 'Icon' collides with the <Icon> component. This alias will be removed in 2.0.")]
    public RenderFragment? Icon { get; set; }

    [Parameter, System.Obsolete("Use LabelContent — 'Label' collides with the <Label> component. This alias will be removed in 2.0.")]
    public RenderFragment? Label { get; set; }

    [Parameter] public string? Href { get; set; }
    [Parameter] public string? Tooltip { get; set; }
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsCollapsed => State?.IsCollapsed ?? false;

    private string CssClass => string.Join(" ", new[] {
        "flex items-center gap-3 rounded-lg py-2 text-muted-foreground hover:text-foreground hover:bg-sidebar-accent w-full overflow-hidden",
        "transition-[padding,background-color,color] duration-300 ease-out",
        IsCollapsed ? "px-4" : "px-3",
        IsActive ? "bg-sidebar-accent text-sidebar-accent-foreground font-medium" : null,
        Class
    }.Where(s => !string.IsNullOrWhiteSpace(s)));

    // Opacity-only fade. The sidebar's own width transition handles the visual shrink
    // — the label stays at natural width and is clipped by the parent's overflow-x-hidden,
    // so the icon stays put while the sidebar narrows instead of "sliding to center".
    // A small delay on the fade makes the sidebar start shrinking first, avoiding the
    // awkward mid-state where labels are gone but sidebar is still wide.
    private string LabelCssClass => string.Join(" ", new[] {
        "whitespace-nowrap transition-opacity duration-150 ease-out",
        IsCollapsed ? "opacity-0 delay-0" : "opacity-100 delay-150"
    });
}
