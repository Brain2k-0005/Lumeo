@page "/components/datagrid/playground"
@namespace Lumeo.Docs.Pages.Components

<PageTitle>DataGrid Playground — Lumeo</PageTitle>

@* Two-pane playground (shadcn / Storybook style).
   Height is set via inline style because Tailwind v4's static scanner misses
   arbitrary dvh values inside Blazor C# render-fragments / @if branches.
   Desktop (≥1024px): left controls panel (272px) always visible, toggleable.
   Mobile (<1024px):  controls hidden; hamburger → left Sheet. *@

<div class="flex flex-col overflow-hidden" style="height:calc(100dvh - 76px)">

    @* ── Header bar ──────────────────────────────────────────────────────── *@
    <header class="shrink-0 flex items-center gap-3 px-4 border-b border-border/40 bg-card" style="height:3.25rem">

        <Lumeo.Link Href="/components/datagrid"
                    Class="inline-flex items-center gap-1.5 text-xs text-muted-foreground hover:text-foreground no-underline transition-colors shrink-0">
            <DynamicIcon Name="ArrowLeft" Class="h-3.5 w-3.5" />
            <span>DataGrid</span>
        </Lumeo.Link>

        <div class="w-px h-4 bg-border/50 shrink-0"></div>

        <Heading Level="1" Class="text-sm font-semibold tracking-tight leading-none flex-1 min-w-0 truncate">
            DataGrid Playground
        </Heading>

        @* Desktop panel toggle — visible only at lg+ *@
        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon"
                Class="hidden lg:inline-flex shrink-0"
                OnClick="@(() => _desktopOptionsOpen = !_desktopOptionsOpen)"
                title="@(_desktopOptionsOpen ? "Hide options panel" : "Show options panel")"
                aria-label="Toggle options panel">
            <DynamicIcon Name="@(_desktopOptionsOpen ? "PanelLeftClose" : "PanelLeftOpen")" Class="h-4 w-4" />
        </Button>

        @* Mobile hamburger — visible only below lg *@
        <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon"
                Class="lg:hidden shrink-0"
                OnClick="@(() => _mobileOptionsOpen = true)"
                aria-label="Open options">
            <DynamicIcon Name="SlidersHorizontal" Class="h-4 w-4" />
        </Button>

    </header>

    @* ── Body: side-by-side panes ─────────────────────────────────────────── *@
    <div class="flex-1 min-h-0 flex overflow-hidden">

        @* Controls panel — desktop only (conditionally shown when toggled) *@
        @if (_desktopOptionsOpen)
        {
            <aside class="hidden lg:flex flex-col shrink-0 border-r border-border/40 bg-muted/30" style="width:304px">
                <div class="flex-1 overflow-y-auto overscroll-contain">
                    @ControlsPanel
                </div>
                <div class="shrink-0 border-t border-border/40 px-3 py-2.5 bg-card/40">
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm"
                            Class="w-full gap-1.5 text-xs"
                            OnClick="ResetPlayground">
                        <DynamicIcon Name="RotateCcw" Class="h-3.5 w-3.5" />
                        Reset to defaults
                    </Button>
                </div>
            </aside>
        }

        @* DataGrid pane *@
        <main class="flex-1 min-w-0 overflow-hidden p-4">
            <div class="overflow-hidden rounded-xl border border-border/60 bg-card shadow-sm" style="height:100%">
                <DataGrid TItem="PlaygroundRow"
                          @ref="_pgGrid"
                          Height="@_pgHeight"
                          Items="@(_pgIsLoading ? new List<PlaygroundRow>() : _pgRows)"
                          ShowToolbar="_pgShowToolbar"
                          ShowSearch="_pgShowSearch"
                          ShowColumnChooser="_pgShowColumnChooser"
                          ShowExport="_pgShowExport"
                          ExportFormats="_pgExportFormats"
                          Expandable="_pgExpandable"
                          ShowPagination="_pgShowPagination"
                          PageSize="_pgPageSize"
                          PageSizeOptions="@_pgPageSizeOptions"
                          Striped="_pgStriped"
                          Bordered="_pgBordered"
                          Compact="_pgCompact"
                          Hoverable="_pgHoverable"
                          IsLoading="_pgIsLoading"
                          Reorderable="_pgReorderable"
                          RowReorderable="_pgRowReorderable"
                          ShowAddRow="_pgShowAddRow"
                          NewItemFactory="@(() => new PlaygroundRow($"New entry {++_pgAddCounter}", "Team", "Role", 0, "Active", DateTime.Today))"
                          Virtualized="_pgVirtualized"
                          ColumnVirtualize="_pgColumnVirtualize"
                          MaxVisibleColumns="@_pgMaxVisibleColumnsInt"
                          ShowGroupPanel="_pgShowGroupPanel"
                          GroupsExpandedByDefault="_pgGroupsExpanded"
                          GroupBy="@(_pgGroupBySel == "None" ? null : _pgGroupBySel)"
                          EnableLayoutPersistence="_pgEnableLayoutPersistence"
                          LayoutStorageKey="@_pgLayoutStorageKey"
                          SelectionMode="@_pgSelectionModeEnum"
                          EditMode="@_pgEditModeEnum">
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Name" Field="Name"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       Pinnable="_pgPinnable" Groupable="true" />
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Team" Field="Team"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       Pinnable="_pgPinnable" Groupable="true" />
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Role" Field="Role"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       Pinnable="_pgPinnable" Groupable="true" />
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Salary" Field="Salary" Format="C0"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       FilterType="DataGridFilterType.Number"
                                       Pinnable="_pgPinnable"
                                       Aggregate="AggregateType.Average" />
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Status" Field="Status"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       Pinnable="_pgPinnable" Groupable="true" />
                    <DataGridColumnDef TItem="PlaygroundRow" Title="Joined" Field="Joined" Format="yyyy-MM-dd"
                                       Sortable="_pgSortable" Filterable="_pgFilterable"
                                       FilterType="DataGridFilterType.Date"
                                       Pinnable="_pgPinnable" />
                </DataGrid>
            </div>
        </main>
    </div>

    @* ── Status bar ───────────────────────────────────────────────────────── *@
    @{
        // Always-rendered pills with toggleable on/off colors so toggling demo
        // state never reflows the bar (Phase 1 polish).
        string On  = "text-foreground/80";
        string Off = "text-muted-foreground/35";
    }
    <footer class="shrink-0 flex items-center px-4 border-t border-border/30 bg-card/60 text-xs select-none gap-3" style="height:2.25rem">
        <span class="font-medium text-foreground/80 tabular-nums shrink-0">@_pgRows.Count rows</span>
        <span class="opacity-25">|</span>
        <span class="tabular-nums shrink-0 @On">@_pgPageSize / page</span>
        <span class="opacity-25">|</span>
        <span class="shrink-0 @(_pgGroupBySel != "None" ? On : Off)">@(_pgGroupBySel != "None" ? $"Group: {_pgGroupBySel}" : "Group: —")</span>
        <span class="opacity-25">|</span>
        <span class="shrink-0 @(_pgStriped  ? On : Off)">Striped</span>
        <span class="shrink-0 @(_pgBordered ? On : Off)">Bordered</span>
        <span class="shrink-0 @(_pgCompact  ? On : Off)">Compact</span>
        <span class="opacity-25">|</span>
        <span class="shrink-0 @(_pgSelectionMode != "None" ? On : Off)">@(_pgSelectionMode != "None" ? $"Select: {_pgSelectionMode}" : "Select: —")</span>
        <span class="shrink-0 @(_pgEditMode      != "None" ? On : Off)">@(_pgEditMode      != "None" ? $"Edit: {_pgEditMode}"      : "Edit: —")</span>
        <span class="shrink-0 @(_pgVirtualized ? On : Off)">Virtualized</span>
        @if (_pgIsLoading)
        {
            <span class="opacity-25">|</span>
            <span class="text-amber-500/80 shrink-0">Loading skeleton</span>
        }
        <div class="flex-1"></div>
        <span class="shrink-0 flex items-center gap-1 @(_pgEnableLayoutPersistence ? On : Off)">
            <DynamicIcon Name="Save" Class="h-3 w-3" />Layout @(_pgEnableLayoutPersistence ? "saved" : "off")
        </span>
    </footer>

</div>

@* ── Mobile Sheet (left side) ─────────────────────────────────────────────── *@
<Sheet @bind-Open="_mobileOptionsOpen">
    <SheetContent Side="Lumeo.Side.Left" Class="flex flex-col p-0 gap-0 w-72">
        <div class="flex items-center justify-between px-4 py-3.5 border-b border-border/40 shrink-0">
            <SheetTitle>Playground options</SheetTitle>
            <SheetClose Class="inline-flex items-center justify-center h-7 w-7 rounded-md text-muted-foreground hover:text-foreground hover:bg-accent transition-colors">
                <DynamicIcon Name="X" Class="h-4 w-4" />
            </SheetClose>
        </div>
        <div class="flex-1 overflow-y-auto overscroll-contain">
            @ControlsPanel
        </div>
        <div class="shrink-0 border-t border-border/40 px-4 py-3">
            <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm"
                    Class="w-full gap-1.5"
                    OnClick="@(() => { ResetPlayground(); _mobileOptionsOpen = false; })">
                <DynamicIcon Name="RotateCcw" Class="h-3.5 w-3.5" />
                Reset to defaults
            </Button>
        </div>
    </SheetContent>
</Sheet>

@code {
    private DataGrid<PlaygroundRow>? _pgGrid;
    private bool _mobileOptionsOpen;
    private bool _desktopOptionsOpen = true;

    @* ── Shared controls panel (used in desktop aside + mobile Sheet) ─────── *@
    private RenderFragment ControlsPanel => __builder =>
    {
        <div class="py-1">

            @* ── Toolbar ── *@
            @SectionHeader("Toolbar")
            @ControlRow(label: "Show toolbar", active: true,         control: @<Switch @bind-Checked="_pgShowToolbar" />)
            @ControlRow(label: "Search box",    active: _pgShowToolbar, control: @<Switch @bind-Checked="_pgShowSearch"       Disabled="!_pgShowToolbar" />)
            @ControlRow(label: "Column chooser",active: _pgShowToolbar, control: @<Switch @bind-Checked="_pgShowColumnChooser" Disabled="!_pgShowToolbar" />)
            @ControlRow(label: "Export button", active: _pgShowToolbar, control: @<Switch @bind-Checked="_pgShowExport"        Disabled="!_pgShowToolbar" />)
            @ControlRow(label: "Expand fullscreen", active: _pgShowToolbar, control: @<Switch @bind-Checked="_pgExpandable"   Disabled="!_pgShowToolbar" />)

            @* ── Export formats ── *@
            @SectionHeader("Export formats")
            @ControlRow(label: "CSV",   active: _pgShowToolbar && _pgShowExport, control: @<Checkbox Checked="_pgExportCsv"   CheckedChanged="@((bool v) => { _pgExportCsv   = v; RecomputeExportFormats(); })" Disabled="!_pgShowToolbar || !_pgShowExport" />)
            @ControlRow(label: "Excel", active: _pgShowToolbar && _pgShowExport, control: @<Checkbox Checked="_pgExportExcel" CheckedChanged="@((bool v) => { _pgExportExcel = v; RecomputeExportFormats(); })" Disabled="!_pgShowToolbar || !_pgShowExport" />)
            @ControlRow(label: "PDF",   active: _pgShowToolbar && _pgShowExport, control: @<Checkbox Checked="_pgExportPdf"   CheckedChanged="@((bool v) => { _pgExportPdf   = v; RecomputeExportFormats(); })" Disabled="!_pgShowToolbar || !_pgShowExport" />)

            @* ── Columns ── *@
            @SectionHeader("Columns")
            @ControlRow(label: "Sortable",         active: true, control: @<Switch @bind-Checked="_pgSortable" />)
            @ControlRow(label: "Filterable",        active: true, control: @<Switch @bind-Checked="_pgFilterable" />)
            @ControlRow(label: "Drag to reorder",   active: true, control: @<Switch @bind-Checked="_pgReorderable" />)
            @ControlRow(label: "Pinnable",          active: true, control: @<Switch @bind-Checked="_pgPinnable" />)

            @* ── Rows ── *@
            @SectionHeader("Rows")
            @ControlRow(label: "Drag to reorder rows",   active: true, control: @<Switch @bind-Checked="_pgRowReorderable" />)
            @ControlRow(label: "Show add-row button", active: _pgEditMode == "Batch", control: @<Switch @bind-Checked="_pgShowAddRow" Disabled="@(_pgEditMode != "Batch")" />)

            @* ── Grouping ── *@
            @SectionHeader("Grouping")
            @ControlRow(label: "Show group panel",    active: true, control: @<Switch @bind-Checked="_pgShowGroupPanel" />)
            @ControlRow(label: "Expanded by default", active: true, control: @<Switch @bind-Checked="_pgGroupsExpanded" />)
            <div class="px-4 pb-3 pt-1">
                <Lumeo.Text Size="xs" Color="muted" Class="mb-1.5 block">Group by</Lumeo.Text>
                <Segmented Value="_pgGroupBySel" ValueChanged="@((string v) => { _pgGroupBySel = v; StateHasChanged(); })" Block="true">
                    <SegmentedItem Value="None">None</SegmentedItem>
                    <SegmentedItem Value="Team">Team</SegmentedItem>
                    <SegmentedItem Value="Role">Role</SegmentedItem>
                    <SegmentedItem Value="Status">Status</SegmentedItem>
                </Segmented>
            </div>

            @* ── Pagination ── *@
            @SectionHeader("Pagination")
            @ControlRow(label: "Show pagination", active: true, control: @<Switch @bind-Checked="_pgShowPagination" />)
            <div class="px-4 pb-3 pt-1">
                <NumberInput @bind-Value="_pgPageSizeNum" Min="3" Max="20" Step="1" Label="Page size" />
            </div>
            <div class="px-4 pb-3">
                <Lumeo.Text Size="xs" Color="muted" Class="mb-1.5 block">Page size options</Lumeo.Text>
                <Segmented @bind-Value="_pgPageSizeOptionsSel" Block="true">
                    <SegmentedItem Value="Default">Default</SegmentedItem>
                    <SegmentedItem Value="Small">Small</SegmentedItem>
                    <SegmentedItem Value="Large">Large</SegmentedItem>
                </Segmented>
            </div>

            @* ── Virtualization ── *@
            @SectionHeader("Virtualization")
            @ControlRow(label: "Virtualized rows",      active: true, control: @<Switch @bind-Checked="_pgVirtualized" />)
            @ControlRow(label: "Column virtualization", active: true, control: @<Switch @bind-Checked="_pgColumnVirtualize" />)
            <div class="px-4 pb-3 pt-1">
                <NumberInput @bind-Value="_pgMaxVisibleColumns" Min="2" Max="6" Step="1"
                             Label="Max visible columns" Disabled="!_pgColumnVirtualize" />
            </div>

            @* ── Display ── *@
            @SectionHeader("Display")
            @ControlRow(label: "Striped rows",    active: true, control: @<Switch @bind-Checked="_pgStriped" />)
            @ControlRow(label: "Bordered",        active: true, control: @<Switch @bind-Checked="_pgBordered" />)
            @ControlRow(label: "Compact rows",    active: true, control: @<Switch @bind-Checked="_pgCompact" />)
            @ControlRow(label: "Hover highlight", active: true, control: @<Switch @bind-Checked="_pgHoverable" />)
            @ControlRow(label: "Loading skeleton",active: true, control: @<Switch @bind-Checked="_pgIsLoading" />)
            <div class="px-4 pb-3 pt-1">
                <Lumeo.Text Size="xs" Color="muted" Class="mb-1.5 block">Row height</Lumeo.Text>
                <Segmented @bind-Value="_pgHeightSel" Block="true">
                    <SegmentedItem Value="Auto">Auto</SegmentedItem>
                    <SegmentedItem Value="Compact">Compact</SegmentedItem>
                    <SegmentedItem Value="Tall">Tall</SegmentedItem>
                </Segmented>
            </div>

            @* ── Persistence ── *@
            @SectionHeader("Persistence")
            @ControlRow(label: "Persist to localStorage", active: true, control: @<Switch @bind-Checked="_pgEnableLayoutPersistence" />)
            @if (_pgEnableLayoutPersistence)
            {
                <div class="px-4 pb-3 pt-1">
                    <Input @bind-Value="_pgLayoutStorageKey" Placeholder="playground-layout" />
                </div>
            }

            @* ── Selection & editing ── *@
            @SectionHeader("Selection &amp; editing")
            <div class="px-4 pb-3 pt-1">
                <Lumeo.Text Size="xs" Color="muted" Class="mb-1.5 block">Selection mode</Lumeo.Text>
                <Segmented @bind-Value="_pgSelectionMode" Block="true">
                    <SegmentedItem Value="None">None</SegmentedItem>
                    <SegmentedItem Value="Single">Single</SegmentedItem>
                    <SegmentedItem Value="Multiple">Multi</SegmentedItem>
                </Segmented>
            </div>
            <div class="px-4 pb-3">
                <Lumeo.Text Size="xs" Color="muted" Class="mb-1.5 block">Edit mode</Lumeo.Text>
                <Segmented @bind-Value="_pgEditMode" Block="true">
                    <SegmentedItem Value="None">None</SegmentedItem>
                    <SegmentedItem Value="Cell">Cell</SegmentedItem>
                    <SegmentedItem Value="Row">Row</SegmentedItem>
                    <SegmentedItem Value="Batch">Batch</SegmentedItem>
                </Segmented>
            </div>

            <div style="height:1rem"></div>
        </div>
    };

    @* ── Section header — uppercase label, whitespace-only separation
         (no border line — relies on extra top padding to break sections). *@
    private RenderFragment SectionHeader(string label) => __builder =>
    {
        <div class="px-4 pt-5 pb-1">
            <Lumeo.Text Size="xs" Class="font-semibold uppercase tracking-wider text-muted-foreground/45 select-none">@label</Lumeo.Text>
        </div>
    };

    @* ── Control row: label on left, control slot on right ────────────────── *@
    private RenderFragment ControlRow(string label, bool active, RenderFragment control) => __builder =>
    {
        <div class="@(!active ? "opacity-50" : "") flex items-center justify-between gap-3 px-4 py-1.5 hover:bg-accent/30 transition-colors">
            <Lumeo.Text Size="sm" Class="leading-none text-foreground/85 flex-1 min-w-0 select-none">@label</Lumeo.Text>
            <div class="shrink-0">@control</div>
        </div>
    };

    // ---- Live Playground state -----------------------------------------
    // Toolbar
    private bool _pgShowToolbar = true;
    private bool _pgShowSearch = true;
    private bool _pgShowColumnChooser = true;
    private bool _pgShowExport = true;
    private bool _pgExpandable = true;

    // Export formats (flags)
    private bool _pgExportCsv = true;
    private bool _pgExportExcel = true;
    private bool _pgExportPdf = true;
    private DataGridExportFormat _pgExportFormats = DataGridExportFormat.Csv | DataGridExportFormat.Excel | DataGridExportFormat.Pdf;

    private void RecomputeExportFormats()
    {
        DataGridExportFormat f = 0;
        if (_pgExportCsv)   f |= DataGridExportFormat.Csv;
        if (_pgExportExcel) f |= DataGridExportFormat.Excel;
        if (_pgExportPdf)   f |= DataGridExportFormat.Pdf;
        _pgExportFormats = f;
    }

    // Columns
    private bool _pgSortable = true;
    private bool _pgFilterable = true;
    private bool _pgReorderable = true;
    private bool _pgPinnable = true;

    // Rows
    private bool _pgRowReorderable;
    private bool _pgShowAddRow;

    // Virtualization
    private bool _pgVirtualized;
    private bool _pgColumnVirtualize;
    private double? _pgMaxVisibleColumns = 4;
    private int _pgMaxVisibleColumnsInt => (int)Math.Clamp((int)(_pgMaxVisibleColumns ?? 4), 2, 6);

    // Grouping
    private bool _pgShowGroupPanel = true;
    private bool _pgGroupsExpanded = true;
    private string _pgGroupBySel = "None";

    // Pagination
    private bool _pgShowPagination = true;
    private double? _pgPageSizeNum = 8;
    private int _pgPageSize => (int)Math.Clamp((int)(_pgPageSizeNum ?? 8), 3, 20);
    private string _pgPageSizeOptionsSel = "Default";
    private int[] _pgPageSizeOptions => _pgPageSizeOptionsSel switch
    {
        "Small" => new[] { 5, 10 },
        "Large" => new[] { 25, 50, 100 },
        _ => new[] { 5, 10, 25, 50 },
    };

    // Display
    private bool _pgStriped = true;
    private bool _pgBordered;
    private bool _pgCompact;
    private bool _pgHoverable = true;
    private bool _pgIsLoading;
    private string _pgHeightSel = "Auto";
    private string? _pgHeight => _pgHeightSel switch
    {
        "Compact" => "400px",
        "Tall"    => "calc(100vh - 200px)",
        _         => "100%",
    };

    // Persistence
    private bool _pgEnableLayoutPersistence;
    private string? _pgLayoutStorageKey = "datagrid-playground";

    // Selection & editing (enum bridges via Segmented string value)
    private string _pgSelectionMode = "Multiple";
    private string _pgEditMode = "None";

    private DataGridSelectionMode _pgSelectionModeEnum => _pgSelectionMode switch
    {
        "Single"   => DataGridSelectionMode.Single,
        "Multiple" => DataGridSelectionMode.Multiple,
        _          => DataGridSelectionMode.None,
    };

    private DataGridEditMode _pgEditModeEnum => _pgEditMode switch
    {
        "Cell"  => DataGridEditMode.Cell,
        "Row"   => DataGridEditMode.Row,
        "Batch" => DataGridEditMode.Batch,
        _       => DataGridEditMode.None,
    };

    private void ResetPlayground()
    {
        _pgShowToolbar = true;
        _pgShowSearch = true;
        _pgShowColumnChooser = true;
        _pgShowExport = true;
        _pgExpandable = true;

        _pgExportCsv = true;
        _pgExportExcel = true;
        _pgExportPdf = true;
        RecomputeExportFormats();

        _pgSortable = true;
        _pgFilterable = true;
        _pgReorderable = true;
        _pgPinnable = true;

        _pgRowReorderable = false;
        _pgShowAddRow = false;

        _pgVirtualized = false;
        _pgColumnVirtualize = false;
        _pgMaxVisibleColumns = 4;

        _pgShowGroupPanel = true;
        _pgGroupsExpanded = true;
        _pgGroupBySel = "None";

        _pgShowPagination = true;
        _pgPageSizeNum = 8;
        _pgPageSizeOptionsSel = "Default";

        _pgStriped = true;
        _pgBordered = false;
        _pgCompact = false;
        _pgHoverable = true;
        _pgIsLoading = false;
        _pgHeightSel = "Auto";

        _pgEnableLayoutPersistence = false;
        _pgLayoutStorageKey = "datagrid-playground";

        _pgSelectionMode = "Multiple";
        _pgEditMode = "None";
    }

    // Counter so each "Add row" produces a unique record.
    private int _pgAddCounter;

    private record PlaygroundRow(string Name, string Team, string Role, double Salary, string Status, DateTime Joined);

    private List<PlaygroundRow> _pgRows = new()
    {
        new("Ada Lovelace",      "Platform",       "Staff Engineer",   182_000, "Active",   new DateTime(2019, 03, 12)),
        new("Linus Torvalds",    "Platform",       "Principal",        225_000, "Active",   new DateTime(2015, 08, 01)),
        new("Margaret Hamilton", "Platform",       "Engineering Lead", 198_000, "Active",   new DateTime(2018, 06, 21)),
        new("Grace Hopper",      "Data",           "Director",         245_000, "Active",   new DateTime(2014, 02, 04)),
        new("Alan Turing",       "Data",           "Senior Engineer",  165_000, "Active",   new DateTime(2020, 11, 30)),
        new("Katherine Johnson", "Data",           "Analytics Lead",   172_000, "Active",   new DateTime(2017, 09, 14)),
        new("Tim Berners-Lee",   "Design",         "Design Director",  210_000, "Active",   new DateTime(2016, 05, 22)),
        new("Don Norman",        "Design",         "Principal UX",     188_000, "Active",   new DateTime(2018, 01, 17)),
        new("Susan Kare",        "Design",         "Senior Designer",  148_000, "On Leave", new DateTime(2021, 04, 09)),
        new("Dennis Ritchie",    "Infrastructure", "Distinguished",    260_000, "Active",   new DateTime(2013, 10, 30)),
        new("Brian Kernighan",   "Infrastructure", "Principal",        215_000, "Active",   new DateTime(2014, 07, 18)),
        new("Barbara Liskov",    "Infrastructure", "Senior Engineer",  170_000, "Active",   new DateTime(2019, 12, 03)),
        new("Donald Knuth",      "Research",       "Research Fellow",  235_000, "Active",   new DateTime(2012, 06, 11)),
        new("Edsger Dijkstra",   "Research",       "Principal",        205_000, "Inactive", new DateTime(2015, 02, 28)),
        new("John von Neumann",  "Research",       "Senior Researcher",178_000, "Active",   new DateTime(2017, 11, 25)),
    };
}
