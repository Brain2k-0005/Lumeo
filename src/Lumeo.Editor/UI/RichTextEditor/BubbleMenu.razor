@namespace Lumeo
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@*
    Static (non-floating) bubble-menu primitive consumers can drop into a
    custom toolbar. The live floating bubble menu is rendered in JS by the
    editor itself when EnableBubbleMenu=true on RichTextEditor. This component
    exists so consumers can also build their own selection menu out of band.
*@

<div class="@RootClass" role="toolbar" aria-label="@L["Editor.FormatSelection"]" @attributes="AdditionalAttributes">
    <Tooltip>
        <TooltipTrigger AsChild>
            <ChildContentSlot Context="slot">
                <button type="button" class="@BtnClass" aria-label="@L["Editor.Bold"]"
                        @onpointerdown:preventDefault="true" @onclick="@(() => OnCommand.InvokeAsync("bold"))"
                        @attributes="slot.Attributes">
                    <Icon Name="Bold" Size="Lumeo.Size.Sm" />
                </button>
            </ChildContentSlot>
        </TooltipTrigger>
        <TooltipContent>@L["Editor.Bold"]</TooltipContent>
    </Tooltip>
    <Tooltip>
        <TooltipTrigger AsChild>
            <ChildContentSlot Context="slot">
                <button type="button" class="@BtnClass" aria-label="@L["Editor.Italic"]"
                        @onpointerdown:preventDefault="true" @onclick="@(() => OnCommand.InvokeAsync("italic"))"
                        @attributes="slot.Attributes">
                    <Icon Name="Italic" Size="Lumeo.Size.Sm" />
                </button>
            </ChildContentSlot>
        </TooltipTrigger>
        <TooltipContent>@L["Editor.Italic"]</TooltipContent>
    </Tooltip>
    <Tooltip>
        <TooltipTrigger AsChild>
            <ChildContentSlot Context="slot">
                <button type="button" class="@BtnClass" aria-label="@L["Editor.Underline"]"
                        @onpointerdown:preventDefault="true" @onclick="@(() => OnCommand.InvokeAsync("underline"))"
                        @attributes="slot.Attributes">
                    <Icon Name="Underline" Size="Lumeo.Size.Sm" />
                </button>
            </ChildContentSlot>
        </TooltipTrigger>
        <TooltipContent>@L["Editor.Underline"]</TooltipContent>
    </Tooltip>
    <Tooltip>
        <TooltipTrigger AsChild>
            <ChildContentSlot Context="slot">
                <button type="button" class="@BtnClass" aria-label="@L["Editor.Link"]"
                        @onpointerdown:preventDefault="true" @onclick="@(() => OnCommand.InvokeAsync("link"))"
                        @attributes="slot.Attributes">
                    <Icon Name="Link" Size="Lumeo.Size.Sm" />
                </button>
            </ChildContentSlot>
        </TooltipTrigger>
        <TooltipContent>@L["Editor.Link"]</TooltipContent>
    </Tooltip>
    @if (EnableAiActions)
    {
        <Tooltip>
            <TooltipTrigger AsChild>
                <ChildContentSlot Context="slot">
                    <button type="button" class="@BtnClass" aria-label="@L["Editor.AiActions"]"
                            @onpointerdown:preventDefault="true" @onclick="@(() => OnAiMenuToggled.InvokeAsync())"
                            @attributes="slot.Attributes">
                        <Icon Name="Sparkles" Size="Lumeo.Size.Sm" />
                    </button>
                </ChildContentSlot>
            </TooltipTrigger>
            <TooltipContent>@L["Editor.AiActions"]</TooltipContent>
        </Tooltip>
    }
</div>

@code {
    [Parameter] public bool EnableAiActions { get; set; }
    [Parameter] public EventCallback<string> OnCommand { get; set; }
    [Parameter] public EventCallback OnAiMenuToggled { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string RootClass =>
        $"inline-flex items-center gap-0.5 rounded-lg border border-border/60 bg-popover text-popover-foreground shadow-md p-1 {Class}".Trim();

    private const string BtnClass =
        "inline-flex h-7 w-7 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring focus-visible:ring-offset-1";
}
