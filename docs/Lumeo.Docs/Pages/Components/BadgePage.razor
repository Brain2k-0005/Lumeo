@page "/components/badge"

<PageTitle>Badge — Lumeo</PageTitle>

<PageHeader Title="Badge" Description="Displays a small status indicator or label." />

<div class="space-y-8">
    <ComponentDemo Title="Variants" Code="@_variantCode">
        <div class="flex flex-wrap items-center gap-2">
            <Badge>Default</Badge>
            <Badge Variant="Badge.BadgeVariant.Secondary">Secondary</Badge>
            <Badge Variant="Badge.BadgeVariant.Outline">Outline</Badge>
            <Badge Variant="Badge.BadgeVariant.Destructive">Destructive</Badge>
            <Badge Variant="Badge.BadgeVariant.Success">Success</Badge>
            <Badge Variant="Badge.BadgeVariant.Warning">Warning</Badge>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Usage Examples" Code="@_usageCode">
        <div class="flex flex-col gap-4">
            <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-foreground">Status</span>
                <Badge Variant="Badge.BadgeVariant.Success">Active</Badge>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-foreground">Priority</span>
                <Badge Variant="Badge.BadgeVariant.Destructive">High</Badge>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-foreground">Version</span>
                <Badge Variant="Badge.BadgeVariant.Outline">v1.0.0</Badge>
            </div>
            <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-foreground">Build</span>
                <Badge Variant="Badge.BadgeVariant.Warning">Pending</Badge>
            </div>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="In a Card" Code="@_cardCode">
        <Card Class="w-full max-w-sm">
            <CardHeader>
                <div class="flex items-center justify-between">
                    <h3 class="text-lg font-semibold leading-none tracking-tight text-foreground">Notifications</h3>
                    <Badge>3 new</Badge>
                </div>
                <p class="text-sm text-muted-foreground">You have unread messages.</p>
            </CardHeader>
        </Card>
    </ComponentDemo>

    <ComponentDemo Title="Dot Badge" Code="@_dotCode">
        <div class="flex items-center gap-4">
            <div class="relative">
                <DynamicIcon Name="Bell" Class="h-5 w-5" />
                <Badge IsDot="true" Class="absolute -top-1 -right-1" />
            </div>
            <div class="relative">
                <DynamicIcon Name="Mail" Class="h-5 w-5" />
                <Badge IsDot="true" Variant="Badge.BadgeVariant.Destructive" Class="absolute -top-1 -right-1" />
            </div>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Removable Badge" Code="@_removableCode">
        <div class="flex flex-wrap gap-2">
            @foreach (var tag in _tags)
            {
                <Badge IsRemovable="true" OnRemove="@(() => RemoveTag(tag))">@tag</Badge>
            }
        </div>
    </ComponentDemo>
</div>

<!-- API Reference -->
<div class="mt-12 space-y-6">
    <h2 class="text-2xl font-bold text-foreground">API Reference</h2>

    <div class="space-y-8">
        <div>
            <h3 class="text-lg font-semibold text-foreground mb-3">Badge</h3>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Variant</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">BadgeVariant</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">Default</td>
                            <td class="p-3 text-muted-foreground">Visual style of the badge. Values: Default, Secondary, Destructive, Outline, Success, Warning.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsDot</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, renders as a small dot indicator without text content.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">IsRemovable</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">false</td>
                            <td class="p-3 text-muted-foreground">When true, displays a remove button inside the badge.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">OnRemove</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">EventCallback</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">—</td>
                            <td class="p-3 text-muted-foreground">Callback invoked when the remove button is clicked.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    private string _variantCode = @"<Badge>Default</Badge>
<Badge Variant=""Badge.BadgeVariant.Secondary"">Secondary</Badge>
<Badge Variant=""Badge.BadgeVariant.Outline"">Outline</Badge>
<Badge Variant=""Badge.BadgeVariant.Destructive"">Destructive</Badge>
<Badge Variant=""Badge.BadgeVariant.Success"">Success</Badge>
<Badge Variant=""Badge.BadgeVariant.Warning"">Warning</Badge>";

    private string _usageCode = @"<div class=""flex items-center gap-2"">
    <span>Status</span>
    <Badge Variant=""Badge.BadgeVariant.Success"">Active</Badge>
</div>
<div class=""flex items-center gap-2"">
    <span>Priority</span>
    <Badge Variant=""Badge.BadgeVariant.Destructive"">High</Badge>
</div>";

    private string _cardCode = @"<Card>
    <CardHeader>
        <div class=""flex items-center justify-between"">
            <h3 class=""text-lg font-semibold"">Notifications</h3>
            <Badge>3 new</Badge>
        </div>
        <p class=""text-sm text-muted-foreground"">You have unread messages.</p>
    </CardHeader>
</Card>";

    private List<string> _tags = new() { "Blazor", "C#", ".NET", "Tailwind" };

    private void RemoveTag(string tag) => _tags.Remove(tag);

    private string _dotCode = @"<div class=""relative"">
    <Blazicon Svg=""Lucide.Bell"" class=""h-5 w-5"" />
    <Badge IsDot=""true"" Class=""absolute -top-1 -right-1"" />
</div>
<div class=""relative"">
    <Blazicon Svg=""Lucide.Mail"" class=""h-5 w-5"" />
    <Badge IsDot=""true"" Variant=""Badge.BadgeVariant.Destructive"" Class=""absolute -top-1 -right-1"" />
</div>";

    private string _removableCode = @"@foreach (var tag in _tags)
{
    <Badge IsRemovable=""true"" OnRemove=""@(() => RemoveTag(tag))"">@tag</Badge>
}

@code {
    private List<string> _tags = new() { ""Blazor"", ""C#"", "".NET"", ""Tailwind"" };
    private void RemoveTag(string tag) => _tags.Remove(tag);
}";
}
