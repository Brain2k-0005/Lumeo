@page "/components/charts/treemap"

<PageTitle>Treemap Chart — Lumeo</PageTitle>

<PageHeader Title="Treemap Chart" Description="Visualize hierarchical data as nested rectangles. The area of each rectangle is proportional to its value, making it easy to spot the largest categories." />

<Stack Gap="8">
    <ComponentDemo Title="Department Budget Treemap" Code="@_basicCode">
        <Container>
            <TreemapChart Data="_data" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">TreemapChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Data</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;TreemapData&gt;</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">[]</td>
                            <td class="p-3 text-muted-foreground">Hierarchical data with Name, Value, and optional Children.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowLegend</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Shows or hides the chart legend.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Colors</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">List&lt;string&gt;?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Custom color palette.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private List<TreemapChart.TreemapData> _data = new()
    {
        new() { Name = "Engineering", Value = 580, Children = new()
        {
            new() { Name = "Frontend",  Value = 210 },
            new() { Name = "Backend",   Value = 240 },
            new() { Name = "DevOps",    Value = 130 }
        }},
        new() { Name = "Marketing", Value = 320, Children = new()
        {
            new() { Name = "Content",   Value = 130 },
            new() { Name = "SEO",       Value = 100 },
            new() { Name = "Paid Ads",  Value = 90  }
        }},
        new() { Name = "Design", Value = 230, Children = new()
        {
            new() { Name = "Product UI", Value = 140 },
            new() { Name = "Brand",      Value = 90  }
        }},
        new() { Name = "Sales", Value = 280 }
    };

    private string _basicCode = @"<TreemapChart Data=""_data"" />";
}
