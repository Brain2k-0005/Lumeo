@namespace Lumeo
@typeparam TItem

<div class="@CssClass" @attributes="AdditionalAttributes">
    <div class="flex items-center gap-2 flex-1">
        <div class="relative">
            <Blazicon Svg="Lucide.Search" class="absolute left-2.5 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground" />
            <input type="text"
                   placeholder="Search..."
                   class="h-8 w-56 rounded-md border border-input bg-transparent pl-8 pr-3 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-[1.5px] focus-visible:ring-ring"
                   value="@SearchText"
                   @oninput="OnSearchInput" />
        </div>

        @if (Context is not null)
        {
            @foreach (var filter in Context.Filters)
            {
                <div class="flex items-center gap-1 rounded-full bg-muted px-2.5 py-1 text-xs">
                    <span class="font-medium">@filter.Field</span>
                    <span class="text-muted-foreground">@GetOperatorLabel(filter.Operator)</span>
                    <span>@filter.Value</span>
                    <button type="button"
                            class="ml-1 inline-flex items-center justify-center h-4 w-4 rounded-full hover:bg-muted-foreground/20"
                            @onclick="@(() => RemoveFilter(filter))">
                        <Blazicon Svg="Lucide.X" class="h-3 w-3" />
                    </button>
                </div>
            }
        }
    </div>

    <div class="flex items-center gap-2">
        @if (ToolbarContent is not null)
        {
            @ToolbarContent
        }

        @* Copy selected rows to clipboard *@
        @if (SelectedItems is not null && SelectedItems.Count > 0 && EffectiveColumns is not null)
        {
            <button type="button"
                    class="inline-flex items-center justify-center h-8 px-3 rounded-md text-sm border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                    title="Copy selected rows to clipboard"
                    @onclick="CopySelected">
                <Blazicon Svg="Lucide.Clipboard" class="h-4 w-4 mr-1.5" />
                <span>Copy (@SelectedItems.Count)</span>
            </button>
        }

        <button type="button"
                class="inline-flex items-center justify-center h-8 px-3 rounded-md text-sm border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                @onclick="ToggleColumnVisibility">
            <Blazicon Svg="Lucide.Columns3" class="h-4 w-4 mr-1.5" />
            <span>Columns</span>
        </button>

        @* Export dropdown *@
        <div class="relative">
            <button type="button"
                    class="inline-flex items-center justify-center h-8 px-3 rounded-md text-sm border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                    @onclick="ToggleExportMenu">
                <Blazicon Svg="Lucide.Download" class="h-4 w-4 mr-1.5" />
                <span>Export</span>
                <Blazicon Svg="Lucide.ChevronDown" class="h-3.5 w-3.5 ml-1" />
            </button>

            @if (_exportMenuOpen)
            {
                <div class="absolute right-0 top-full mt-1 z-50 min-w-[140px] rounded-md border border-border/40 bg-popover p-1 shadow-md">
                    <button type="button"
                            class="w-full flex items-center gap-2 rounded px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground"
                            @onclick="@(() => Export("csv"))">
                        <Blazicon Svg="Lucide.FileText" class="h-4 w-4" />
                        <span>CSV</span>
                    </button>
                    <button type="button"
                            class="w-full flex items-center gap-2 rounded px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground"
                            @onclick="@(() => Export("excel"))">
                        <Blazicon Svg="Lucide.Sheet" class="h-4 w-4" />
                        <span>Excel</span>
                    </button>
                    <button type="button"
                            class="w-full flex items-center gap-2 rounded px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground"
                            @onclick="@(() => Export("json"))">
                        <Blazicon Svg="Lucide.Braces" class="h-4 w-4" />
                        <span>JSON</span>
                    </button>
                </div>
            }
        </div>

        @* Layout persistence dropdown *@
        @if (EnableLayoutPersistence)
        {
            <div class="relative">
                <button type="button"
                        class="inline-flex items-center justify-center h-8 px-3 rounded-md text-sm border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors"
                        @onclick="ToggleLayoutMenu">
                    <Blazicon Svg="Lucide.LayoutTemplate" class="h-4 w-4 mr-1.5" />
                    <span>Layout</span>
                    <Blazicon Svg="Lucide.ChevronDown" class="h-3.5 w-3.5 ml-1" />
                </button>

                @if (_layoutMenuOpen)
                {
                    <div class="absolute right-0 top-full mt-1 z-50 min-w-[150px] rounded-md border border-border/40 bg-popover p-1 shadow-md">
                        <button type="button"
                                class="w-full flex items-center gap-2 rounded px-3 py-1.5 text-sm hover:bg-accent hover:text-accent-foreground"
                                @onclick="SaveLayout">
                            <Blazicon Svg="Lucide.Save" class="h-4 w-4" />
                            <span>Save Layout</span>
                        </button>
                        <div class="my-1 border-t border-border/40"></div>
                        <button type="button"
                                class="w-full flex items-center gap-2 rounded px-3 py-1.5 text-sm text-destructive hover:bg-destructive/10"
                                @onclick="ResetLayout">
                            <Blazicon Svg="Lucide.RotateCcw" class="h-4 w-4" />
                            <span>Reset Layout</span>
                        </button>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    [CascadingParameter] private DataGridContext<TItem>? Context { get; set; }
    [Inject] private ComponentInteropService Interop { get; set; } = default!;

    [Parameter] public string? SearchText { get; set; }
    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public RenderFragment? ToolbarContent { get; set; }
    [Parameter] public EventCallback OnColumnVisibilityToggle { get; set; }
    [Parameter] public EventCallback<string> OnExport { get; set; }
    [Parameter] public EventCallback<FilterDescriptor> OnRemoveFilter { get; set; }
    [Parameter] public List<TItem>? SelectedItems { get; set; }
    [Parameter] public List<TItem>? AllItems { get; set; }
    [Parameter] public IReadOnlyList<DataGridColumn<TItem>>? EffectiveColumns { get; set; }
    [Parameter] public bool EnableLayoutPersistence { get; set; }
    [Parameter] public EventCallback OnSaveLayout { get; set; }
    [Parameter] public EventCallback OnResetLayout { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _exportMenuOpen;
    private bool _layoutMenuOpen;
    private string CssClass => $"flex items-center gap-2 px-4 py-3 border-b border-border/40 {Class}".Trim();

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        await SearchTextChanged.InvokeAsync(value);
    }

    private async Task RemoveFilter(FilterDescriptor filter)
    {
        await OnRemoveFilter.InvokeAsync(filter);
    }

    private async Task ToggleColumnVisibility()
    {
        await OnColumnVisibilityToggle.InvokeAsync();
    }

    private void ToggleExportMenu()
    {
        _exportMenuOpen = !_exportMenuOpen;
        _layoutMenuOpen = false;
    }

    private async Task Export(string format)
    {
        _exportMenuOpen = false;
        await OnExport.InvokeAsync(format);
    }

    private void ToggleLayoutMenu()
    {
        _layoutMenuOpen = !_layoutMenuOpen;
        _exportMenuOpen = false;
    }

    private async Task SaveLayout()
    {
        _layoutMenuOpen = false;
        await OnSaveLayout.InvokeAsync();
    }

    private async Task ResetLayout()
    {
        _layoutMenuOpen = false;
        await OnResetLayout.InvokeAsync();
    }

    private async Task CopySelected()
    {
        if (SelectedItems is null || SelectedItems.Count == 0 || EffectiveColumns is null) return;

        var visibleColumns = EffectiveColumns.Where(c => c.Visible).ToList();
        var lines = new List<string>();

        // Header row
        lines.Add(string.Join("\t", visibleColumns.Select(c => c.Title ?? c.Field ?? "")));

        // Data rows
        foreach (var item in SelectedItems)
        {
            lines.Add(string.Join("\t", visibleColumns.Select(c => c.GetFormattedValue(item))));
        }

        var text = string.Join("\n", lines);
        await Interop.CopyToClipboard(text);
    }

    private static string GetOperatorLabel(FilterOperator op) => op switch
    {
        FilterOperator.Contains => "contains",
        FilterOperator.NotContains => "not contains",
        FilterOperator.Equals => "=",
        FilterOperator.NotEquals => "!=",
        FilterOperator.StartsWith => "starts with",
        FilterOperator.EndsWith => "ends with",
        FilterOperator.GreaterThan => ">",
        FilterOperator.GreaterThanOrEqual => ">=",
        FilterOperator.LessThan => "<",
        FilterOperator.LessThanOrEqual => "<=",
        FilterOperator.IsEmpty => "is empty",
        FilterOperator.IsNotEmpty => "is not empty",
        FilterOperator.Between => "between",
        _ => op.ToString()
    };
}
