@namespace Lumeo

@if (Context?.Orientation == Timeline.TimelineOrientation.Horizontal)
{
    <div class="@HorizontalCssClass" @attributes="AdditionalAttributes">
        <div class="flex flex-col items-center">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border-2 border-primary bg-background text-primary">
                @{
#pragma warning disable CS0618 // obsolete property read for fallback
                    var iconFrag = IconContent ?? Icon;
#pragma warning restore CS0618
                }
                @if (iconFrag is not null)
                {
                    @iconFrag
                }
                else
                {
                    <div class="h-2.5 w-2.5 rounded-full bg-primary"></div>
                }
            </div>
            <div class="mt-2 flex flex-col items-center text-center">
                @if (!string.IsNullOrEmpty(Title))
                {
                    <p class="text-sm font-medium text-foreground">@Title</p>
                }
                @if (!string.IsNullOrEmpty(Description))
                {
                    <p class="text-xs text-muted-foreground">@Description</p>
                }
                @if (!string.IsNullOrEmpty(Time))
                {
                    <p class="text-xs text-muted-foreground/70">@Time</p>
                }
            </div>
        </div>
        <div class="mx-2 mt-4 h-px flex-1 bg-border"></div>
    </div>
}
else
{
    <div class="@VerticalCssClass" @attributes="AdditionalAttributes">
        <div class="flex flex-col items-center">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border-2 border-primary bg-background text-primary">
                @{
#pragma warning disable CS0618 // obsolete property read for fallback
                    var iconFragV = IconContent ?? Icon;
#pragma warning restore CS0618
                }
                @if (iconFragV is not null)
                {
                    @iconFragV
                }
                else
                {
                    <div class="h-2.5 w-2.5 rounded-full bg-primary"></div>
                }
            </div>
            <div class="my-1 w-px flex-1 bg-border"></div>
        </div>
        <div class="ml-3 pb-6">
            @if (!string.IsNullOrEmpty(Title))
            {
                <p class="text-sm font-medium text-foreground">@Title</p>
            }
            @if (!string.IsNullOrEmpty(Description))
            {
                <p class="text-xs text-muted-foreground">@Description</p>
            }
            @if (!string.IsNullOrEmpty(Time))
            {
                <p class="mt-1 text-xs text-muted-foreground/70">@Time</p>
            }
        </div>
    </div>
}

@code {
    [CascadingParameter] public Timeline.TimelineContext? Context { get; set; }

    /// <summary>Icon slot. Use instead of <c>Icon</c> to avoid a name collision with the <c>&lt;Icon&gt;</c> component.</summary>
    [Parameter] public RenderFragment? IconContent { get; set; }

    [Parameter, System.Obsolete("Use IconContent — 'Icon' collides with the <Icon> component. This alias will be removed in 2.0.")]
    public RenderFragment? Icon { get; set; }

    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Description { get; set; }
    [Parameter] public string? Time { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string VerticalCssClass => $"flex flex-row {Class}".Trim();
    private string HorizontalCssClass => $"flex flex-1 flex-row last:flex-initial {Class}".Trim();
}
