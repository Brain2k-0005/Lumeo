else
{
    <aside class="hidden lg:block w-64 shrink-0 m-3 rounded-[var(--radius-xl)] border border-border/60 bg-card shadow-lg overflow-y-auto sticky top-[84px]" style="max-height: calc(100vh - 100px)">
        <nav class="p-4 space-y-4 text-sm">
            <Heading Level="4" Class="mb-2 text-sm">Blocks</Heading>
            <ul class="space-y-1">
                <li><NavLink href="blocks/analytics" class="@LinkClass("blocks/analytics")">Analytics</NavLink></li>
                <li><NavLink href="blocks/authentication" class="@LinkClass("blocks/authentication")">Authentication</NavLink></li>
                <li><NavLink href="blocks/calendar" class="@LinkClass("blocks/calendar")">Calendar</NavLink></li>
                <li><NavLink href="blocks/chat" class="@LinkClass("blocks/chat")">Chat</NavLink></li>
                <li><NavLink href="blocks/dashboard" class="@LinkClass("blocks/dashboard")">Dashboard</NavLink></li>
                <li><NavLink href="blocks/ecommerce" class="@LinkClass("blocks/ecommerce")">E-Commerce</NavLink></li>
                <li><NavLink href="blocks/file-manager" class="@LinkClass("blocks/file-manager")">File Manager</NavLink></li>
                <li><NavLink href="blocks/filters" class="@LinkClass("blocks/filters")">Filters</NavLink></li>
                <li><NavLink href="blocks/form-wizard" class="@LinkClass("blocks/form-wizard")">Form Wizard</NavLink></li>
                <li><NavLink href="blocks/kanban" class="@LinkClass("blocks/kanban")">Kanban Board</NavLink></li>
                <li><NavLink href="blocks/mail" class="@LinkClass("blocks/mail")">Mail</NavLink></li>
                <li><NavLink href="blocks/music" class="@LinkClass("blocks/music")">Music Player</NavLink></li>
                <li><NavLink href="blocks/notifications" class="@LinkClass("blocks/notifications")">Notifications</NavLink></li>
                <li><NavLink href="blocks/settings" class="@LinkClass("blocks/settings")">Settings</NavLink></li>
                <li><NavLink href="blocks/social-feed" class="@LinkClass("blocks/social-feed")">Social Feed</NavLink></li>
                <li><NavLink href="blocks/task-tracker" class="@LinkClass("blocks/task-tracker")">Task Tracker</NavLink></li>
            </ul>
        </nav>
    </aside>
}

@code {
    [Parameter] public bool IsMobile { get; set; }

    private string CurrentPath => Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/').ToLowerInvariant();

    private string LinkClass(string href)
    {
        var isActive = CurrentPath.Equals(href, StringComparison.OrdinalIgnoreCase);
        return isActive
            ? "block rounded-md px-2 py-1.5 bg-accent text-foreground font-medium transition-colors no-underline"
            : "block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors no-underline";
    }
}
