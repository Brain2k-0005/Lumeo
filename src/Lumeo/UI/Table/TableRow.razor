@namespace Lumeo

<tr class="@CssClass" @attributes="AdditionalAttributes">
    @ChildContent
</tr>

@code {
    /// <summary>The row's cells, typically <see cref="TableCell"/> or <see cref="TableHead"/>.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the <c>&lt;tr&gt;</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Unmatched attributes splatted onto the <c>&lt;tr&gt;</c> element — e.g.
    /// <c>data-state="selected"</c> to enable the built-in selected-row highlight.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("border-b border-border/40 transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted", Class);
}
