@* [Obsolete] NumberCountUp is deprecated. Use NumberTicker instead — it now supports
   Prefix, Suffix, ThousandsSeparator, and Decimals parameters with the same feature set
   and uses a faster requestAnimationFrame animation loop via motion.js.
   This component is kept for backwards compatibility and forwards to the same rendering. *@
@namespace Lumeo
@implements IAsyncDisposable

<span class="@CssClass" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrEmpty(Prefix))
    {
        <span class="lumeo-countup-prefix">@Prefix</span>
    }
    <span class="lumeo-countup-value">@_displayed</span>
    @if (!string.IsNullOrEmpty(Suffix))
    {
        <span class="lumeo-countup-suffix">@Suffix</span>
    }
</span>

@code {
    /// <summary>Target value to count up to.</summary>
    [Parameter] public double Value { get; set; }
    /// <summary>Starting value.</summary>
    [Parameter] public double StartValue { get; set; } = 0;
    /// <summary>Animation duration in milliseconds.</summary>
    [Parameter] public int DurationMs { get; set; } = 1500;
    /// <summary>Number of decimal places.</summary>
    [Parameter] public int Decimals { get; set; } = 0;
    /// <summary>Prefix displayed before the number (e.g. "$").</summary>
    [Parameter] public string? Prefix { get; set; }
    /// <summary>Suffix displayed after the number (e.g. "K", "%").</summary>
    [Parameter] public string? Suffix { get; set; }
    /// <summary>Separator for thousands groups. Default ",".</summary>
    [Parameter] public string ThousandsSeparator { get; set; } = ",";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string _displayed = string.Empty;
    private double _lastTarget;
    private CancellationTokenSource? _cts;

    private string CssClass => string.Join(" ", new[] { "lumeo-countup tabular-nums inline-flex items-baseline", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    protected override void OnParametersSet()
    {
        if (string.IsNullOrEmpty(_displayed))
            _displayed = FormatValue(StartValue);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender || Math.Abs(_lastTarget - Value) > 1e-9)
        {
            var from = firstRender ? StartValue : _lastTarget;
            _lastTarget = Value;
            await CountAsync(from, Value);
        }
    }

    private async Task CountAsync(double from, double to)
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _cts = new CancellationTokenSource();
        var ct = _cts.Token;
        try
        {
            var steps = 60;
            var stepDelay = DurationMs / steps;
            for (int i = 1; i <= steps; i++)
            {
                if (ct.IsCancellationRequested) break;
                double t = (double)i / steps;
                double eased = 1 - Math.Pow(1 - t, 3); // easeOutCubic
                _displayed = FormatValue(from + (to - from) * eased);
                await InvokeAsync(StateHasChanged);
                await Task.Delay(stepDelay, ct);
            }
            _displayed = FormatValue(to);
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException) { }
    }

    private string FormatValue(double val)
    {
        var formatted = val.ToString($"F{Decimals}", System.Globalization.CultureInfo.InvariantCulture);
        if (Decimals > 0)
        {
            var parts = formatted.Split('.');
            parts[0] = AddThousandsSeparator(parts[0]);
            return string.Join(".", parts);
        }
        return AddThousandsSeparator(formatted);
    }

    private string AddThousandsSeparator(string whole)
    {
        if (string.IsNullOrEmpty(ThousandsSeparator)) return whole;
        return System.Text.RegularExpressions.Regex.Replace(whole, @"\B(?=(\d{3})+(?!\d))", ThousandsSeparator);
    }

    public async ValueTask DisposeAsync()
    {
        if (_cts != null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
        }
    }
}
