@page "/components/feature-item"

<PageTitle>Feature Item — Lumeo</PageTitle>

<PageHeader Title="Feature Item" Description="A single feature callout — an optional leading icon badge, a title, and a short description. The building block of FeatureGrid, and usable standalone in any card or column. Part of the Splash Kit." />

<InstallUsage Component="FeatureItem" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>One feature, capability, or benefit with an icon, title, and short blurb</li>
        <li>As a child of <a href="/components/feature-grid" class="text-primary hover:underline">FeatureGrid</a> for a responsive feature section</li>
        <li>Standalone inside a Card, a sidebar, or any column where a single callout fits</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic" Code="@_basicCode">
        <div class="max-w-xs">
            <FeatureItem Title="Fast by default" Description="A small CSS bundle and tree-shakeable components keep your app lean.">
                <IconContent>
                    <SvgGlyph Svg="@(Lucide.Zap)" class="h-5 w-5" />
                </IconContent>
            </FeatureItem>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="Without an Icon" Code="@_noIconCode">
        <div class="max-w-xs">
            <FeatureItem Title="Native components" Description="Pure Razor with thin interop where it counts — no JS framework overhead." />
        </div>
    </ComponentDemo>

    <ComponentDemo Title="With Extra Content" Code="@_childCode">
        <div class="max-w-xs">
            <FeatureItem Title="Accessible" Description="WAI-ARIA roles, keyboard navigation, and focus management built in.">
                <IconContent>
                    <SvgGlyph Svg="@(Lucide.Accessibility)" class="h-5 w-5" />
                </IconContent>
                <ChildContent>
                    <a href="/docs/accessibility" class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline">
                        Learn more
                        <SvgGlyph Svg="@(Lucide.ArrowRight)" class="h-4 w-4" />
                    </a>
                </ChildContent>
            </FeatureItem>
        </div>
    </ComponentDemo>

    <ComponentDemo Title="In a Feature Grid" Code="@_gridCode">
        <FeatureGrid Columns="2" Title="Composes into a grid">
            <FeatureItem Title="Fast" Description="Small CSS bundle, tree-shakeable.">
                <IconContent><SvgGlyph Svg="@(Lucide.Zap)" class="h-5 w-5" /></IconContent>
            </FeatureItem>
            <FeatureItem Title="Themeable" Description="Every color is a CSS variable.">
                <IconContent><SvgGlyph Svg="@(Lucide.Palette)" class="h-5 w-5" /></IconContent>
            </FeatureItem>
        </FeatureGrid>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <div class="mt-8">
        <PropsTable Slug="feature-item" />
    </div>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/feature-grid" class="text-primary hover:underline">Feature Grid</a> — Responsive grid that lays out FeatureItem children</li>
        <li><a href="/components/hero" class="text-primary hover:underline">Hero</a> — Opening band that typically precedes a feature section</li>
        <li><a href="/components/bento" class="text-primary hover:underline">Bento</a> — Asymmetric grid layout for richer feature showcases</li>
    </ul>
</div>

@code {
    private string _basicCode = @"<FeatureItem Title=""Fast by default"" Description=""A small CSS bundle keeps your app lean."">
    <IconContent><SvgGlyph Svg=""@(Lucide.Zap)"" class=""h-5 w-5"" /></IconContent>
</FeatureItem>";

    private string _noIconCode = @"<FeatureItem Title=""Native components"" Description=""Pure Razor with thin interop where it counts."" />";

    private string _childCode = @"<FeatureItem Title=""Accessible"" Description=""WAI-ARIA roles, keyboard navigation, and focus management built in."">
    <IconContent><SvgGlyph Svg=""@(Lucide.Accessibility)"" class=""h-5 w-5"" /></IconContent>
    <ChildContent>
        <a href=""/docs/accessibility"" class=""mt-3 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline"">
            Learn more
            <SvgGlyph Svg=""@(Lucide.ArrowRight)"" class=""h-4 w-4"" />
        </a>
    </ChildContent>
</FeatureItem>";

    private string _gridCode = @"<FeatureGrid Columns=""2"" Title=""Composes into a grid"">
    <FeatureItem Title=""Fast"" Description=""Small CSS bundle, tree-shakeable."">
        <IconContent><SvgGlyph Svg=""@(Lucide.Zap)"" class=""h-5 w-5"" /></IconContent>
    </FeatureItem>
    <FeatureItem Title=""Themeable"" Description=""Every color is a CSS variable."">
        <IconContent><SvgGlyph Svg=""@(Lucide.Palette)"" class=""h-5 w-5"" /></IconContent>
    </FeatureItem>
</FeatureGrid>";
}
