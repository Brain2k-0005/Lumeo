                        <SidebarContent>
                            <SidebarGroup>
                                <SidebarGroupLabel>Navigation</SidebarGroupLabel>
                                <SidebarMenu>
                                    <SidebarMenuItem>
                                        <SidebarMenuButton Href="#" IsActive="true">
                                            <IconContent><DynamicIcon Name="House" Class="h-4 w-4" /></IconContent>
