@namespace Lumeo

<div class="@CssClass" @attributes="AdditionalAttributes">
    <div class="flex flex-col items-center text-center">
        <div class="@IconContainerClasses">
            @{
#pragma warning disable CS0618 // obsolete property read for fallback
                var iconFrag = IconContent ?? Icon;
#pragma warning restore CS0618
            }
            @if (iconFrag is not null)
            {
                @iconFrag
            }
            else
            {
                @DefaultIcon
            }
        </div>
        @if (!string.IsNullOrEmpty(Title))
        {
            <h3 class="mt-4 text-xl font-semibold text-foreground">@Title</h3>
        }
        @if (!string.IsNullOrEmpty(SubTitle))
        {
            <p class="mt-2 text-sm text-muted-foreground">@SubTitle</p>
        }
        @if (Extra is not null)
        {
            <div class="mt-6 flex items-center gap-2">
                @Extra
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public ResultStatus Status { get; set; } = ResultStatus.Info;
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? SubTitle { get; set; }

    /// <summary>Icon slot. Use instead of <c>Icon</c> to avoid a name collision with the <c>&lt;Icon&gt;</c> component.</summary>
    [Parameter] public RenderFragment? IconContent { get; set; }

    [Parameter, System.Obsolete("Use IconContent — 'Icon' collides with the <Icon> component. This alias will be removed in 2.0.")]
    public RenderFragment? Icon { get; set; }

    [Parameter] public RenderFragment? Extra { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => $"py-12 px-6 {Class}".Trim();

    private string IconContainerClasses => $"flex h-16 w-16 items-center justify-center rounded-full {StatusBgClasses}";

    private string StatusBgClasses => Status switch
    {
        ResultStatus.Success => "bg-success-light text-success",
        ResultStatus.Error => "bg-destructive/10 text-destructive",
        ResultStatus.Warning => "bg-warning-light text-warning",
        ResultStatus.Info => "bg-primary/10 text-primary",
        ResultStatus.NotFound => "bg-muted text-muted-foreground",
        ResultStatus.Forbidden => "bg-destructive/10 text-destructive",
        ResultStatus.ServerError => "bg-destructive/10 text-destructive",
        _ => "bg-primary/10 text-primary"
    };

    private RenderFragment DefaultIcon => Status switch
    {
        ResultStatus.Success => @<Blazicon Svg="Lucide.CircleCheck" class="h-8 w-8" />,
        ResultStatus.Error => @<Blazicon Svg="Lucide.CircleAlert" class="h-8 w-8" />,
        ResultStatus.Warning => @<Blazicon Svg="Lucide.TriangleAlert" class="h-8 w-8" />,
        ResultStatus.Info => @<Blazicon Svg="Lucide.Info" class="h-8 w-8" />,
        ResultStatus.NotFound => @<Blazicon Svg="Lucide.Search" class="h-8 w-8" />,
        ResultStatus.Forbidden => @<Blazicon Svg="Lucide.Lock" class="h-8 w-8" />,
        ResultStatus.ServerError => @<Blazicon Svg="Lucide.CircleAlert" class="h-8 w-8" />,
        _ => @<Blazicon Svg="Lucide.Info" class="h-8 w-8" />
    };

    public enum ResultStatus { Success, Error, Warning, Info, NotFound, Forbidden, ServerError }
}
