{
  "$schema": "http://json.schemastore.org/template",
  "author": "nativ.sh",
  "classifications": ["Blazor", "Lumeo", "Component"],
  "identity": "Lumeo.Templates.Component",
  "name": "Lumeo Component",
  "shortName": "lumeo-component",
  "tags": {
    "language": "C#",
    "type": "item"
  },
  "symbols": {
    "ComponentName": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "__ComponentName__",
      "fileRename": "__ComponentName__",
      "description": "Component name (PascalCase)",
      "defaultValue": "MyComponent"
    },
    "namespace": {
      "type": "parameter",
      "datatype": "string",
      "replaces": "__Namespace__",
      "description": "Target namespace",
      "defaultValue": "MyApp.Components"
    }
  }
}
