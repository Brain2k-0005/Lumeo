    }

    // ---- Command palette ----
    private void OpenPalette() { _paletteOpen = true; _focusPaletteInput = true; StateHasChanged(); }
    private Task OpenPaletteAsync() { _paletteOpen = true; _focusPaletteInput = true; return InvokeAsync(StateHasChanged); }
    private void ClosePalette() { _paletteOpen = false; StateHasChanged(); }
    private void PaletteKeyDown(KeyboardEventArgs e) { if (e.Key == "Escape") ClosePalette(); }
    private void SelectFromPalette(string view) { ClosePalette(); SetView(view); }
    private void PaletteRefresh() { ClosePalette(); SetView("dashboard"); RefreshDashboard(); }

    // ---- Dashboard refresh (loading state) ----
    private void RefreshDashboard()
    {
        if (_refreshing) return;
        _refreshing = true;
        StateHasChanged();
        _refreshTimer?.Dispose();
        _refreshTimer = new System.Threading.Timer(_ => InvokeAsync(() =>
        {
            _refreshing = false;
            Toast.Success("Dashboard refreshed", "Metrics are current as of just now.");
            StateHasChanged();
        }), null, 750, System.Threading.Timeout.Infinite);
    }

    // ---- Board drag & drop ----
    private void OnDragStart(BoardCard c) => _dragCard = c;

    private void MoveCard(List<BoardCard> target, string columnName)
    {
        if (_dragCard is null) return;
        var moved = _todo.Remove(_dragCard) || _doing.Remove(_dragCard)
                 || _review.Remove(_dragCard) || _done.Remove(_dragCard) || _archived.Remove(_dragCard);
        if (moved && !target.Contains(_dragCard))
        {
            target.Add(_dragCard);
            if (columnName == "Done")
                Toast.Success("Marked as done", $"{_dragCard.Id} · {_dragCard.Title}");
        }
        _dragCard = null;
        StateHasChanged();
    }

    private RenderFragment BoardColumn(string title, List<BoardCard> cards) =>
        @<KanbanColumn Title="@title" Badge="cards.Count"
                       Class="flex flex-1 min-w-0 flex-col rounded-lg border border-border/40 bg-background min-h-[130px]"
                       OnDrop="@(_ => MoveCard(cards, title))">
            @foreach (var card in cards)
            {
                @DraggableCard(card)
            }
        </KanbanColumn>;

    private RenderFragment DraggableCard(BoardCard card) =>
        @<div draggable="true" @ondragstart="@(() => OnDragStart(card))" @key="card"
              class="mb-2 cursor-grab rounded-md border border-border/50 bg-card p-2.5 transition-colors hover:border-primary/40 active:cursor-grabbing">
            <Flex Align="center" Justify="between" Class="mb-1.5">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-5">@card.Tag</Badge>
                <Lumeo.Text Size="xs" Color="muted" Class="font-mono">@card.Id</Lumeo.Text>
            </Flex>
            <Lumeo.Text Size="sm" Weight="medium" Class="leading-snug">@card.Title</Lumeo.Text>
            @if (!string.IsNullOrEmpty(card.Description))
            {
                <Lumeo.Text Size="xs" Color="muted" Class="mt-1 block leading-snug">@card.Description</Lumeo.Text>
            }
            <Flex Align="center" Justify="end" Class="mt-2">
                <span class="inline-flex h-6 w-6 items-center justify-center rounded-full bg-accent/60 text-[10px] font-semibold text-foreground">@card.Assignee</span>
            </Flex>
        </div>;

    // ---- Settings actions ----
    private void SaveProfile()
    {
        _nameError = string.IsNullOrWhiteSpace(_name) ? "Name is required." : null;
        _emailError = IsValidEmail(_email) ? null : "Enter a valid email address.";
        if (_nameError is not null || _emailError is not null)
        {
            Toast.Error("Couldn't save", "Please fix the highlighted fields.");
            return;
        }
        Toast.Success("Profile saved", "Your changes are live across the workspace.");
    }

    private static bool IsValidEmail(string? email) =>
        !string.IsNullOrWhiteSpace(email)
        && System.Text.RegularExpressions.Regex.IsMatch(email, @"^[^@\s]+@[^@\s]+\.[^@\s]+$");

    private static string PlanRoleLabel(string? role) => role switch
    {
        "editor" => "Editor",
        "analyst" => "Analyst",
        "viewer" => "Viewer",
        _ => "Admin",
    };

    private void SaveNotifications()
    {
        var on = _prefs.Count(p => p.Enabled);
        Toast.Success("Preferences saved", $"{on} of {_prefs.Count} notification types enabled.");
    }

    private void UpdatePlan() => Toast.Success("Plan updated", $"You're now on the {PlanLabel(_billingPlan)} plan.");

    private static string PlanLabel(string plan) => plan switch
    {
        "starter" => "Starter",
        "enterprise" => "Enterprise",
        _ => "Pro",
    };

    // ---- Badge variant mapping ----
    private static Badge.BadgeVariant PlanVariant(string plan) => plan switch
    {
        "Enterprise" => Badge.BadgeVariant.Success,
        "Pro" => Badge.BadgeVariant.Default,
        "Starter" => Badge.BadgeVariant.Secondary,
        _ => Badge.BadgeVariant.Outline,
    };

    private static Badge.BadgeVariant StatusVariant(string status) => status switch
    {
        "Active" => Badge.BadgeVariant.Success,
        "Trial" => Badge.BadgeVariant.Default,
        "Paused" => Badge.BadgeVariant.Warning,
        _ => Badge.BadgeVariant.Destructive,
    };

    // ---- CRM cell helpers ----
    private static string Monogram(string company)
    {
        var parts = company.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[1][0])}";
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : $"{char.ToUpperInvariant(parts[0][0])}{char.ToUpperInvariant(parts[^1][0])}";
    }

    private static string HealthLabel(int score) => score switch
    {
        >= 70 => "Healthy",
        >= 40 => "At risk",
        _ => "Critical",
    };

    private static Badge.BadgeVariant HealthVariant(int score) => score switch
    {
        >= 70 => Badge.BadgeVariant.Success,
        >= 40 => Badge.BadgeVariant.Warning,
        _ => Badge.BadgeVariant.Destructive,
    };

    private static string HealthDot(int score) => score switch
    {
        >= 70 => "bg-emerald-500",
        >= 40 => "bg-amber-500",
        _ => "bg-rose-500",
    };

    private static string HealthClass(int score)
    {
        var tone = score switch
        {
            >= 70 => "text-emerald-600 dark:text-emerald-400",
            >= 40 => "text-amber-600 dark:text-amber-400",
            _ => "text-rose-600 dark:text-rose-400",
        };
        return $"inline-flex items-center gap-1.5 text-xs font-medium {tone}";
    }

    private static string DeltaClass(int delta)
    {
        var tone = delta >= 0
            ? "text-emerald-600 dark:text-emerald-400"
            : "text-rose-600 dark:text-rose-400";
        return $"inline-flex items-center gap-0.5 text-[11px] font-medium {tone}";
    }

    private static string LastSeenLabel(int days) => days switch
    {
        0 => "today",
        1 => "yesterday",
        < 7 => $"{days}d ago",
        < 30 => $"{days / 7}w ago",
        < 365 => $"{days / 30}mo ago",
        _ => "over a year",
    };

    private static string LastSeenClass(int days)
    {
        var tone = days switch
        {
            < 7 => "text-foreground",
            < 30 => "text-muted-foreground",
            _ => "text-amber-600 dark:text-amber-400",
        };
        return $"text-xs {tone}";
    }

    public async ValueTask DisposeAsync()
    {
        if (_refreshTimer is not null) await _refreshTimer.DisposeAsync();
        if (_chartsTimer is not null) await _chartsTimer.DisposeAsync();
        foreach (var s in _shortcuts)
        {
            try { await s.DisposeAsync(); }
            catch (Microsoft.JSInterop.JSDisconnectedException) { }
        }
    }
}
