@namespace Lumeo

<div class="@CssClass"
     style="--lumeo-shine-duration:@(DurationMs)ms; --lumeo-shine-width:@(ShineWidthPct)%; --lumeo-shine-color:@ShineColor; border-radius:@(BorderRadius)px;"
     @attributes="AdditionalAttributes">
    <div class="lumeo-shine-border" aria-hidden="true"></div>
    @if (ChildContent != null)
    {
        <div class="lumeo-shine-content">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Duration of one full perimeter sweep in ms.</summary>
    [Parameter] public int DurationMs { get; set; } = 3000;
    /// <summary>Border radius in pixels.</summary>
    [Parameter] public int BorderRadius { get; set; } = 8;
    /// <summary>Width of the shine highlight as percent of perimeter.</summary>
    [Parameter] public int ShineWidthPct { get; set; } = 20;
    /// <summary>Color of the shine. Defaults to primary.</summary>
    [Parameter] public string ShineColor { get; set; } = "var(--color-primary)";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => string.Join(" ", new[] { "lumeo-shine-border-wrap", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));
}
