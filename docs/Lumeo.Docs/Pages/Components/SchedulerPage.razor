@code {
    private IEnumerable<SchedulerEvent> _events = new List<SchedulerEvent> { /* ... */ };
}";

    // ── Recurring events demo ────────────────────────────────────────────
    private List<SchedulerEvent> _recurringEvents = BuildRecurringEvents();

    private static List<SchedulerEvent> BuildRecurringEvents()
    {
        var today = DateTime.Today;
        return new List<SchedulerEvent>
        {
            // Repeats Mon/Wed/Fri at 09:00–09:15 for 3 months
            new("rec1", "Daily stand-up",
                today.AddHours(9), today.AddHours(9).AddMinutes(15),
                DaysOfWeek: new[] { DayOfWeek.Monday, DayOfWeek.Wednesday, DayOfWeek.Friday },
                RecurrenceEnd: today.AddMonths(3),
                Color: "var(--color-primary)"),
            // Repeats every Tuesday at 14:00–15:00 (no end date = forever)
            new("rec2", "Design review",
                today.AddHours(14), today.AddHours(15),
                DaysOfWeek: new[] { DayOfWeek.Tuesday },
                Color: "var(--color-destructive)"),
            // One-off event on current day
            new("rec3", "Team lunch",
                today.AddHours(12), today.AddHours(13),
                Color: "var(--color-accent)")
        };
    }

    private string _recurringCode = @"@* Events with DaysOfWeek repeat on the selected days.
   Start/End time-of-day parts are used as the recurrence time window.
   RecurrenceEnd bounds the series; ExceptionDates skips specific days. *@
<Scheduler Events=""_events""
           InitialView=""SchedulerView.Week""
           NowIndicator=""true""
           SlotMinTime=""@(new TimeOnly(7, 0))""
           SlotMaxTime=""@(new TimeOnly(20, 0))"" />

