@namespace Lumeo
@implements IDisposable

@{
    var subContext = new ContextMenuSubContext(
        _open,
        EventCallback.Factory.Create<bool>(this, SetOpen),
        _wrapperId,
        _triggerId,
        _contentId,
        EventCallback.Factory.Create(this, CloseTree),
        ScheduleClose,
        CancelClose,
        EventCallback.Factory.Create(this, OpenFromKeyboard),
        ConsumeKeyboardOpen);
}

<CascadingValue Value="subContext" IsFixed="false">
    <div id="@_wrapperId" class="relative" @attributes="AdditionalAttributes">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [CascadingParameter] public ContextMenu.ContextMenuContext? RootContext { get; set; }
    [CascadingParameter] public ContextMenuSubContext? ParentSubContext { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool _open;
    private readonly string _wrapperId = LumeoIds.New("context-sub");
    internal readonly string _triggerId = LumeoIds.New("context-sub-trigger");
    internal readonly string _contentId = LumeoIds.New("context-sub-content");

    private CancellationTokenSource? _closeCts;
    private bool _disposed;

    // Set when the submenu is opened via the keyboard (ArrowRight); the content
    // consumes it on its first open render to focus the first item — race-free,
    // replacing a fixed Task.Delay that guessed when the content existed.
    private bool _openByKeyboard;

    private async Task SetOpen(bool value)
    {
        if (_open == value) return;
        _open = value;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OpenFromKeyboard()
    {
        _openByKeyboard = true;
        await SetOpen(true);
    }

    private bool ConsumeKeyboardOpen()
    {
        if (!_openByKeyboard) return false;
        _openByKeyboard = false;
        return true;
    }

    private async Task CloseTree()
    {
        await SetOpen(false);
        if (ParentSubContext is not null)
        {
            await ParentSubContext.CloseTree.InvokeAsync();
        }
        else if (RootContext is not null)
        {
            await RootContext.SetOpen.InvokeAsync(false);
        }
    }

    private void CancelClose()
    {
        try { _closeCts?.Cancel(); } catch (ObjectDisposedException) { }
        _closeCts?.Dispose();
        _closeCts = null;
    }

    private void ScheduleClose()
    {
        if (_disposed) return;
        CancelClose();
        _closeCts = new CancellationTokenSource();
        var token = _closeCts.Token;
        _ = Task.Run(async () =>
        {
            try { await Task.Delay(200, token); }
            catch (TaskCanceledException) { return; }
            if (token.IsCancellationRequested || _disposed) return;
            await InvokeAsync(async () => await SetOpen(false));
        });
    }

    public void Dispose()
    {
        if (_disposed) return;
        _disposed = true;
        // Cancel + dispose the pending close timer so its continuation cannot
        // run StateHasChanged against a torn-down component, and the CTS is
        // reclaimed. CancelClose already cancels, disposes and nulls _closeCts.
        CancelClose();
    }

    public record ContextMenuSubContext(
        bool IsOpen,
        EventCallback<bool> SetOpen,
        string WrapperId,
        string TriggerId,
        string ContentId,
        EventCallback CloseTree,
        Action ScheduleClose,
        Action CancelClose,
        EventCallback OpenByKeyboard,
        Func<bool> ConsumeKeyboardOpen);
}
