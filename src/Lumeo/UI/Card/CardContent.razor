@namespace Lumeo

<div class="@(Cx.Merge(PadClass, Class))" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    /// <summary>The card body content, rendered below the header with horizontal and
    /// bottom padding but no top padding (it abuts <see cref="CardHeader"/>'s bottom spacing).</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the section's root <c>div</c>, after the
    /// density-driven padding classes.</summary>
    [Parameter] public string? Class { get; set; }
    [CascadingParameter] private Lumeo.Density? Density { get; set; }
    /// <summary>Unmatched attributes splatted onto the root <c>div</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string PadClass => Density switch
    {
        Lumeo.Density.Compact => "p-4 pt-0",
        Lumeo.Density.Spacious => "p-8 pt-0",
        _ => "p-6 pt-0"
    };
}
