@namespace Lumeo

<button id="@TriggerId" class="@CssClass" tabindex="@TabIndex"
        role="menuitem" aria-haspopup="menu" data-state="@(IsOpen ? "open" : "closed")" aria-expanded="@IsOpen.ToString().ToLowerInvariant()"
        @onclick="HandleClick" @onmouseenter="HandleMouseEnter" @onkeydown="HandleKeyDown" @attributes="AdditionalAttributes">
    @ChildContent
</button>

@code {
    [CascadingParameter] public Menubar.MenubarContext Context { get; set; } = default!;
    [CascadingParameter] public MenubarMenu.MenubarMenuContext MenuContext { get; set; } = default!;
    /// <summary>The trigger's label content (e.g. "File", "Edit").</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Additional CSS classes merged onto the trigger's <c>&lt;button&gt;</c>.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Captures any unmatched attributes and applies them to the trigger's <c>&lt;button&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private bool IsOpen => Context.OpenMenuId == MenuContext.MenuId;

    // Deterministic id (derived from the menu wrapper) so MenubarContent can return
    // focus here on Escape (WCAG 2.4.3). Must match the id MenubarContent computes.
    private string TriggerId => $"{MenuContext.WrapperId}-trigger";

    // Roving tabindex: the active (open) trigger — or the first registered trigger
    // when none is open — gets tabindex=0; all others get tabindex=-1.
    private string TabIndex
    {
        get
        {
            if (IsOpen) return "0";
            if (Context.OpenMenuId is null && Context.MenuIds.Count > 0 && Context.MenuIds[0] == MenuContext.MenuId) return "0";
            return "-1";
        }
    }

    private string CssClass => Cx.Merge(
        "flex cursor-default select-none items-center rounded-sm px-3 py-1 text-sm font-medium outline-none",
        Cx.When(IsOpen, "bg-accent text-accent-foreground"),
        Class);

    private async Task HandleClick()
    {
        if (IsOpen)
        {
            await Context.SetOpenMenuId.InvokeAsync(null);
        }
        else
        {
            await Context.SetOpenMenuId.InvokeAsync(MenuContext.MenuId);
        }
    }

    private async Task HandleMouseEnter()
    {
        if (Context.AnyOpen)
        {
            await Context.SetOpenMenuId.InvokeAsync(MenuContext.MenuId);
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        // Enter and Space are deliberately NOT handled here: this is a native
        // <button>, so the browser synthesizes a click for them and HandleClick
        // performs the toggle. Opening from keydown as well made keyboard
        // activation a net no-op (keydown opened, the synthesized click
        // immediately toggled the menu closed again).
        switch (e.Key)
        {
            case "ArrowDown":
                if (!IsOpen)
                {
                    await Context.SetOpenMenuId.InvokeAsync(MenuContext.MenuId);
                }
                break;
            case "ArrowLeft":
                Context.NavigateMenus(-1);
                break;
            case "ArrowRight":
                Context.NavigateMenus(1);
                break;
            case "Escape":
                if (IsOpen)
                {
                    await Context.SetOpenMenuId.InvokeAsync(null);
                }
                break;
        }
    }
}
