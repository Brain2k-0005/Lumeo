@namespace Lumeo
@using Lumeo.Services
@implements IAsyncDisposable

@foreach (var overlay in _overlays)
{
    @switch (overlay.Type)
    {
        case OverlayType.Dialog:
            <Dialog @key="overlay.Id" Open="@IsOverlayOpen(overlay.Id)" OpenChanged="(bool val) => OnOverlayClosed(val, overlay.Id)">
                <DialogContent ZIndex="@overlay.ZIndex" Size="@EffectiveDialogSize(overlay.Options)" PreventClose="@overlay.Options.PreventClose" ShowCloseButton="@overlay.Options.ShowCloseButton" PlayExitAnimation="true" Class="@EffectiveClass(overlay.Options)">
                    @if (overlay.Title is not null)
                    {
                        <DialogHeader>
                            <DialogTitle>@overlay.Title</DialogTitle>
                        </DialogHeader>
                    }
                    <CascadingValue Value="@(new OverlayShellMarker(overlay.Id))" IsFixed="true">
                        <CascadingValue Value="@GetOrCreateReference(overlay)" IsFixed="true">
                            <DynamicComponent Type="@GetComponentType(overlay)" Parameters="@GetParameters(overlay)" />
                        </CascadingValue>
                    </CascadingValue>
                </DialogContent>
            </Dialog>
            break;

        case OverlayType.Sheet:
            <Sheet @key="overlay.Id" Open="@IsOverlayOpen(overlay.Id)" OpenChanged="(bool val) => OnOverlayClosed(val, overlay.Id)">
                <SheetContent ZIndex="@overlay.ZIndex" Side="@EffectiveSheetSide(overlay.Options)" Size="@EffectiveSheetSize(overlay.Options)" PreventClose="@overlay.Options.PreventClose" ShowCloseButton="@overlay.Options.ShowCloseButton" SwipeToClose="@EffectiveSwipeToClose(overlay.Options)" Class="@EffectiveClass(overlay.Options)">
                    @if (overlay.Title is not null)
                    {
                        <SheetHeader>
                            <SheetTitle>@overlay.Title</SheetTitle>
                        </SheetHeader>
                    }
                    @* Scrollable body wrapper. flex-1 + min-h-0 lets it take
                       the remaining height of SheetContent's flex column and
                       scroll independently of the header. The -mx-1 / px-1
                       trick gives Inputs' box-shadow focus rings 4px of
                       breathing room before the overflow:auto clip — without
                       it, edge-touching inputs lose ~2px of their ring on the
                       left/right edges (CSS spec: overflow-y:auto promotes
                       overflow-x:auto, which clips outer box-shadows). *@
                    @if (overlay.Options.ScrollableBody)
                    {
                        <div class="flex-1 min-h-0 overflow-y-auto overflow-x-clip -mx-1 px-1">
                            <CascadingValue Value="@(new OverlayShellMarker(overlay.Id))" IsFixed="true">
                                <CascadingValue Value="@GetOrCreateReference(overlay)" IsFixed="true">
                                    <DynamicComponent Type="@GetComponentType(overlay)" Parameters="@GetParameters(overlay)" />
                                </CascadingValue>
                            </CascadingValue>
                        </div>
                    }
                    else
                    {
                        <CascadingValue Value="@(new OverlayShellMarker(overlay.Id))" IsFixed="true">
                            <CascadingValue Value="@GetOrCreateReference(overlay)" IsFixed="true">
                                <DynamicComponent Type="@GetComponentType(overlay)" Parameters="@GetParameters(overlay)" />
                            </CascadingValue>
                        </CascadingValue>
                    }
                </SheetContent>
            </Sheet>
            break;

        case OverlayType.Drawer:
            <Drawer @key="overlay.Id" Open="@IsOverlayOpen(overlay.Id)" OpenChanged="(bool val) => OnOverlayClosed(val, overlay.Id)">
                <DrawerContent ZIndex="@overlay.ZIndex" PreventClose="@overlay.Options.PreventClose" PlayExitAnimation="true" Class="@EffectiveClass(overlay.Options)">
                    @if (overlay.Title is not null)
                    {
                        <DrawerHeader>
                            <DrawerTitle>@overlay.Title</DrawerTitle>
                        </DrawerHeader>
                    }
                    <CascadingValue Value="@(new OverlayShellMarker(overlay.Id))" IsFixed="true">
                        <CascadingValue Value="@GetOrCreateReference(overlay)" IsFixed="true">
                            <DynamicComponent Type="@GetComponentType(overlay)" Parameters="@GetParameters(overlay)" />
                        </CascadingValue>
                    </CascadingValue>
                </DrawerContent>
            </Drawer>
            break;

        case OverlayType.AlertDialog:
            @* OpenChanged wires Escape / overlay-click dismissals back to
               OverlayService.Cancel so ShowAlertDialogAsync resolves. Without
               it, the AlertDialog flips its local Open=false but the awaiting
               caller (e.g. ConfirmButton) blocks forever. *@
            <AlertDialog @key="overlay.Id" Open="@IsOverlayOpen(overlay.Id)" OpenChanged="(bool val) => OnOverlayClosed(val, overlay.Id)">
                <AlertDialogContent ZIndex="@overlay.ZIndex" PlayExitAnimation="true">
                    <AlertDialogHeader>
                        <AlertDialogTitle>@(overlay.AlertOptions?.Title ?? "Are you sure?")</AlertDialogTitle>
                        @if (overlay.AlertOptions?.Description is not null)
                        {
                            <AlertDialogDescription>@overlay.AlertOptions.Description</AlertDialogDescription>
                        }
                    </AlertDialogHeader>
                    <AlertDialogFooter>
                        <AlertDialogCancel @onclick="() => HandleCancel(overlay.Id)">@(overlay.AlertOptions?.CancelText ?? "Cancel")</AlertDialogCancel>
                        @if (overlay.AlertOptions?.IsDestructive == true)
                        {
                            <AlertDialogAction OnAction="() => HandleConfirm(overlay.Id)">@(overlay.AlertOptions?.ConfirmText ?? "Continue")</AlertDialogAction>
                        }
                        else
                        {
                            <Button OnClick="() => HandleConfirm(overlay.Id)">@(overlay.AlertOptions?.ConfirmText ?? "Continue")</Button>
                        }
                    </AlertDialogFooter>
                </AlertDialogContent>
            </AlertDialog>
            break;
    }
}

@inject OverlayService OverlayService
@inject IResponsiveService Responsive

@code {
    private readonly List<OverlayInstance> _overlays = new();
    private readonly Dictionary<string, OverlayReference> _referenceCache = new();

    // Ids whose overlay is currently playing its exit animation. While an id is in
    // this set the cascaded `Open` renders false (true→false), which is what the
    // hosted content's `_exiting` machinery (SheetContent, and now Dialog/Drawer/
    // AlertDialogContent via PlayExitAnimation) latches on to run the slide/zoom
    // out instead of vanishing. The instance stays in `_overlays` until the exit
    // window elapses, then `FinishClose` drops it. (Battle #82, extended.)
    private readonly HashSet<string> _closing = new();

    // Per-id deferred-removal timers for the exit-animation window. Keyed by id so
    // several overlays closing at once each get their own teardown, and each is
    // disposed when its overlay is finally removed (or on component dispose).
    private readonly Dictionary<string, DelayedDispatch> _exitDispatchers = new();

    // Ids whose close has already been dispatched through HandleClose
    // (confirm/cancel/dismiss). The destructive AlertDialog confirm path fires the
    // close twice — HandleConfirm's OverlayService.Close, then AlertDialogAction's
    // auto-dismiss flipping Open=false → OnOverlayClosed → Cancel. This set lets
    // OnOverlayClosed suppress the redundant second Cancel so the same id isn't
    // close-dispatched as both Ok and Cancel. (Battle #180.)
    private readonly HashSet<string> _terminated = new();

    // Every service-opened overlay plays an exit animation on close: the provider
    // keeps the instance mounted (Open=false, which drives the hosted content's
    // `_exiting` latch) for this window, then unmounts it. The VISIBLE unmount is
    // now driven by the content's own animationend (attachOverlayExitEnd drops the
    // backdrop + panel together on the real animation end) — this provider window
    // is a strict OUTER fallback that removes the by-then-empty instance. It must
    // sit at/above the content's own fallback window so it never preempts the
    // animation on the JS-dead path (content fallbacks: Sheet/Drawer 450ms,
    // Dialog/AlertDialog 280ms):
    //   Sheet/Drawer      — slide-out 300ms → 500ms
    //   Dialog/AlertDialog — zoom-out 150ms → 320ms
    private static int ExitWindowMs(OverlayType type) => type switch
    {
        OverlayType.Sheet => 500,
        OverlayType.Drawer => 500,
        OverlayType.Dialog => 320,
        OverlayType.AlertDialog => 320,
        _ => 0,
    };

    private bool _disposed;

    // The cascaded Open for an overlay: true while live, false once it enters the
    // exit-animation window (so the inner Sheet plays its slide-out).
    private bool IsOverlayOpen(string id) => !_closing.Contains(id);

    protected override void OnInitialized()
    {
        OverlayService.OnShow += HandleShow;
        OverlayService.OnClose += HandleClose;
        // 2.1.3 — react to viewport changes so overlays with responsive
        // Mobile* overrides swap their effective Side/Size/SwipeToClose when
        // the user rotates a tablet or resizes the window. Cheap StateHasChanged
        // re-render that flips through EffectiveSheet* per overlay.
        Responsive.ViewportChanged += HandleViewportChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Pull the initial viewport size + attach the JS resize listener
            // once, lazily. Subsequent overlays read straight from the cached
            // breakpoint.
            await Responsive.EnsureInitialisedAsync();
        }
    }

    private void HandleViewportChanged(ViewportInfo _)
    {
        // Only re-render if any open overlay actually has responsive Mobile*
        // overrides — common case (no responsive options on any sheet) costs
        // zero render churn.
        if (_overlays.Any(o => HasMobileOverrides(o.Options)))
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private static bool HasMobileOverrides(OverlayOptions opts) =>
        opts.MobileBreakpoint is not null
        && (opts.MobileSheetSide is not null
            || opts.MobileSize is not null
            || opts.MobileSwipeToClose is not null
            || opts.MobileFullscreen);

    // Effective Side/Size/SwipeToClose helpers — picked at each render so a
    // viewport crossing flips them automatically via HandleViewportChanged.
    private bool IsMobile(OverlayOptions opts)
    {
        if (opts.MobileBreakpoint is not int bp) return false;
        return Responsive.Width > 0 && Responsive.Width < bp;
    }

    private Lumeo.Side EffectiveSheetSide(OverlayOptions opts) =>
        IsMobile(opts) && opts.MobileSheetSide is { } ms ? ms : opts.SheetSide;

    private OverlaySize EffectiveSize(OverlayOptions opts) =>
        IsMobile(opts) && opts.MobileSize is { } ms ? ms : opts.Size;

    private SheetContent.SheetSize EffectiveSheetSize(OverlayOptions opts) =>
        MapSheetSize(EffectiveSize(opts));

    private DialogContent.DialogSize EffectiveDialogSize(OverlayOptions opts) =>
        MapDialogSize(EffectiveSize(opts));

    private bool EffectiveSwipeToClose(OverlayOptions opts) =>
        IsMobile(opts) && opts.MobileSwipeToClose is bool m ? m : opts.SwipeToClose;

    // Composes the Class string passed to the inner Dialog/Sheet/Drawer
    // content. When MobileFullscreen + viewport is below MobileBreakpoint,
    // appends the override classes that consumers previously shipped
    // themselves (max-md:!h-full max-md:!w-full …).
    //
    // We don't need the max-md: prefix because the provider already gates
    // by viewport via IsMobile(); the classes apply unconditionally at
    // render time and flip out when the breakpoint crosses. BUT we DO
    // need Tailwind's `!important` variant on every token: Tailwind
    // utility precedence comes from the generated stylesheet order, not
    // the class-attribute order. In the shipped lumeo-utilities.css,
    // SheetContent's `sm:max-w-sm` / `max-w-lg` and side-specific
    // rounded utilities are emitted *after* `.max-w-full` and
    // `.rounded-none`, so the non-important fullscreen tokens lose
    // against the defaults in the 640–767px range — dialogs stayed
    // capped at max-w-lg, sheets at sm:max-w-sm, corners stayed
    // rounded. The `!` prefix makes Tailwind emit the rule as
    // !important, restoring the override-chain behaviour consumers got
    // from their hand-rolled `max-md:!…` classes (Codex #91 review).
    //
    // Trim()s the final string so an opts.Class with trailing/leading
    // whitespace doesn't end up with double spaces in the rendered
    // class attribute.
    private string? EffectiveClass(OverlayOptions opts)
    {
        if (!IsMobile(opts) || !opts.MobileFullscreen) return opts.Class;
        const string fs = "!h-full !w-full !max-w-full !max-h-full !rounded-none";
        return (string.IsNullOrEmpty(opts.Class) ? fs : $"{opts.Class} {fs}").Trim();
    }

    private void HandleShow(OverlayInstance instance)
    {
        SafeAsyncDispatcher.FireAndForget(InvokeAsync, () => HandleShowAsync(instance), "OverlayProvider.HandleShow");
    }

    private Task HandleShowAsync(OverlayInstance instance)
    {
        _overlays.Add(instance);
        // Pre-cache the reference so the CascadingValue always receives the same
        // object reference for the lifetime of this overlay (prevents subtree re-renders).
        _referenceCache[instance.Id] = new OverlayReference(instance.Id, instance.Parameters, OverlayService, instance.ZIndex);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void HandleClose(string id, object? result, bool cancelled)
    {
        SafeAsyncDispatcher.FireAndForget(InvokeAsync, () => HandleCloseAsync(id, result, cancelled), "OverlayProvider.HandleClose");
    }

    private Task HandleCloseAsync(string id, object? result, bool cancelled)
    {
        var overlay = _overlays.FirstOrDefault(o => o.Id == id);
        // Null when this id is already being torn down (e.g. the destructive
        // AlertDialog's confirm-then-auto-dismiss double-dispatch, #180) — the
        // first close already resolved the Tcs, so there is nothing left to do.
        if (overlay is null || _closing.Contains(id)) return Task.CompletedTask;

        // Resolve the awaiting caller immediately — the result must NOT wait on the
        // exit animation. Only the visual teardown is deferred.
        if (cancelled)
            overlay.Tcs.TrySetResult(OverlayResult.CancelResult());
        else
            overlay.Tcs.TrySetResult(OverlayResult.Ok(result));

        // Every overlay type now plays an exit animation: flip the cascaded Open
        // to false (true→false drives the hosted content's `_exiting` latch) and
        // unmount only after the exit window. A missed animationend can never leak
        // a zombie entry — the DelayedDispatch fires FinishClose unconditionally
        // when the window elapses (safety-timeout fallback). (#82, extended.)
        var exitMs = ExitWindowMs(overlay.Type);
        if (exitMs > 0)
        {
            _closing.Add(id);
            StateHasChanged();

            var dispatch = new DelayedDispatch();
            _exitDispatchers[id] = dispatch;
            dispatch.Schedule(exitMs, () => InvokeAsync(() => FinishClose(id)));
        }
        else
        {
            RemoveOverlay(id);
            StateHasChanged();
        }

        return Task.CompletedTask;
    }

    // Final teardown after the exit-animation window: drop the instance and its
    // cached reference, then re-render so the now-unmounted overlay disappears.
    private void FinishClose(string id)
    {
        if (_disposed) return;
        RemoveOverlay(id);
        StateHasChanged();
    }

    // Removes an overlay's instance + reference + any deferred-removal timer and
    // clears its closing bookkeeping. Safe to call once per id.
    //
    // NOTE: this intentionally does NOT clear `_terminated`. The destructive
    // AlertDialog confirm removes the overlay here (via HandleConfirm →
    // HandleCloseAsync) and only THEN runs AlertDialogAction's auto-dismiss
    // (Open=false → OnOverlayClosed). If we dropped the `_terminated` marker now,
    // that trailing OnOverlayClosed would no longer be suppressed and would
    // re-dispatch the same id as a Cancel — the exact #180 double-close. The
    // marker is keyed by a never-reused GUID, so a lingering entry can never
    // falsely suppress a future overlay; it is cleared en masse on dispose.
    private void RemoveOverlay(string id)
    {
        var overlay = _overlays.FirstOrDefault(o => o.Id == id);
        if (overlay is not null) _overlays.Remove(overlay);
        _referenceCache.Remove(id);
        _closing.Remove(id);
        if (_exitDispatchers.Remove(id, out var dispatch)) dispatch.Dispose();
    }

    private void OnOverlayClosed(bool isOpen, string id)
    {
        // Only a user-initiated dismiss (Escape / backdrop / X) flips Open=false
        // through here. Suppress it when the id has already been close-dispatched
        // — the destructive AlertDialog confirm closes the overlay via
        // HandleConfirm, then AlertDialogAction auto-dismisses, which would
        // otherwise re-dispatch the same id as a Cancel (double close). (#180.)
        if (isOpen) return;
        if (_terminated.Contains(id) || _closing.Contains(id)) return;
        OverlayService.Cancel(id);
    }

    private void HandleConfirm(string id)
    {
        // Mark terminated BEFORE closing so the AlertDialogAction auto-dismiss that
        // follows this confirm (Open=false → OnOverlayClosed) can't re-dispatch the
        // same id as a Cancel. (#180.)
        _terminated.Add(id);
        OverlayService.Close(id, true);
    }

    private void HandleCancel(string id)
    {
        _terminated.Add(id);
        OverlayService.Cancel(id);
    }

    [return: System.Diagnostics.CodeAnalysis.DynamicallyAccessedMembers(System.Diagnostics.CodeAnalysis.DynamicallyAccessedMemberTypes.All)]
    private static Type GetComponentType(OverlayInstance overlay) => overlay.ComponentType ?? typeof(Fallback);
    private static Dictionary<string, object>? GetParameters(OverlayInstance overlay) => overlay.Parameters?.ToDictionary();

    private class Fallback : Microsoft.AspNetCore.Components.ComponentBase { }

    private OverlayReference GetOrCreateReference(OverlayInstance overlay)
    {
        if (!_referenceCache.TryGetValue(overlay.Id, out var reference))
        {
            reference = new OverlayReference(overlay.Id, overlay.Parameters, OverlayService, overlay.ZIndex);
            _referenceCache[overlay.Id] = reference;
        }
        return reference;
    }

    private static SheetContent.SheetSize MapSheetSize(OverlaySize size) => size switch
    {
        OverlaySize.Sm => SheetContent.SheetSize.Sm,
        OverlaySize.Lg => SheetContent.SheetSize.Lg,
        OverlaySize.Xl => SheetContent.SheetSize.Xl,
        OverlaySize.Full => SheetContent.SheetSize.Full,
        _ => SheetContent.SheetSize.Default
    };

    private static DialogContent.DialogSize MapDialogSize(OverlaySize size) => size switch
    {
        OverlaySize.Sm => DialogContent.DialogSize.Sm,
        OverlaySize.Lg => DialogContent.DialogSize.Lg,
        OverlaySize.Xl => DialogContent.DialogSize.Xl,
        OverlaySize.Full => DialogContent.DialogSize.Full,
        _ => DialogContent.DialogSize.Default
    };

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        OverlayService.OnShow -= HandleShow;
        OverlayService.OnClose -= HandleClose;
        Responsive.ViewportChanged -= HandleViewportChanged;

        // Cancel + dispose any in-flight exit-animation timers so a pending
        // FinishClose can't fire StateHasChanged after the component is gone.
        foreach (var dispatch in _exitDispatchers.Values)
        {
            dispatch.Dispose();
        }
        _exitDispatchers.Clear();

        foreach (var overlay in _overlays)
        {
            overlay.Tcs.TrySetResult(OverlayResult.CancelResult());
        }
        _overlays.Clear();
        _referenceCache.Clear();
        _closing.Clear();
        _terminated.Clear();
        await Task.CompletedTask;
    }
}
