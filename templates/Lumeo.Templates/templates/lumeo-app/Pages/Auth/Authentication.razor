@page "/authentication/{action}"
@layout AuthLayout
@attribute [AllowAnonymous]

<PageTitle>@Title — MyApp</PageTitle>

<Card Class="w-full max-w-md border-border/60 shadow-lg">
    <CardContent Class="px-8 pt-10 pb-8">
        <Stack Gap="6">
            <Stack Gap="4" Class="items-center text-center">
                <Flex Class="h-12 w-12 items-center justify-center rounded-[var(--radius-lg)] bg-primary text-primary-foreground shadow-sm">
                    <SvgGlyph Svg="@(LumeoIcons.Sparkles)" class="h-6 w-6" />
                </Flex>
                <Heading Level="1" Class="text-2xl font-bold tracking-tight">@Title</Heading>
            </Stack>

            @* Handles the whole OIDC round-trip (login redirect, callback, logout, profile).
               It renders its own status UI; the card above just gives it the Lumeo auth frame. *@
            <RemoteAuthenticatorView Action="@Action" />
        </Stack>
    </CardContent>
</Card>

@code {
    [Parameter] public string? Action { get; set; }

    private string Title => Action switch
    {
        RemoteAuthenticationActions.LogIn => "Signing in…",
        RemoteAuthenticationActions.LogInCallback => "Signing in…",
        RemoteAuthenticationActions.LogOut => "Signing out…",
        RemoteAuthenticationActions.LogOutCallback => "Signing out…",
        RemoteAuthenticationActions.Profile => "Profile",
        RemoteAuthenticationActions.Register => "Register",
        _ => "Authentication",
    };
}
