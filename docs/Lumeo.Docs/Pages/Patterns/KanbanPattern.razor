@page "/blocks/kanban"
@namespace Lumeo.Docs.Pages.Patterns

<PageTitle>Kanban Board — Lumeo</PageTitle>

<PageHeader Title="Kanban Board" Description="A project board with task cards organized by status columns. Drag cards between columns to change status." />

<Stack Gap="6" Class="w-full">

    <!-- Top bar -->
    <Flex Class="items-center justify-between">
        <Heading Level="2" Class="text-xl font-semibold text-foreground">Project Board</Heading>
        <Flex Class="items-center gap-3">
            <Stack Class="relative">
                <DynamicIcon Name="Search" Class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none" />
                <Input placeholder="Search tasks..." Class="pl-9 w-56" @bind-Value="_search" />
            </Stack>
            <Button Variant="Button.ButtonVariant.Default">
                <DynamicIcon Name="Plus" Class="h-4 w-4 mr-2" />
                New Task
            </Button>
        </Flex>
    </Flex>

    <!-- Kanban columns -->
    <Grid Class="grid-cols-1 md:grid-cols-4 gap-6 items-start">

        <!-- To Do -->
        <Stack Gap="3">
            <Flex Class="items-center justify-between">
                <Flex Class="items-center gap-2">
                    <Heading Level="3" Class="text-sm font-semibold text-foreground">To Do</Heading>
                    <Badge Variant="Badge.BadgeVariant.Secondary">@_todoCards.Count</Badge>
                </Flex>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                    <DynamicIcon Name="Plus" Class="h-4 w-4" />
                </Button>
            </Flex>
            <div class="@($"space-y-3 min-h-[80px] rounded-lg p-1 transition-colors {(_dropTarget == "todo" ? "bg-primary/10 ring-2 ring-primary/30" : "")}")"
                 @ondragover="@(() => _dropTarget = "todo")"
                 @ondragover:preventDefault="true"
                 @ondragleave="@(() => _dropTarget = "")"
                 @ondrop="() => Drop(_todoCards)">
                @foreach (var card in _todoCards)
                {
                    <Stack draggable="true"
                         @ondragstart="() => DragStart(card, _todoCards)">
                        @RenderTaskCard(card, "bg-muted-foreground/30")
                    </Stack>
                }
            </div>
        </Stack>

        <!-- In Progress -->
        <Stack Gap="3">
            <Flex Class="items-center justify-between">
                <Flex Class="items-center gap-2">
                    <Heading Level="3" Class="text-sm font-semibold text-foreground">In Progress</Heading>
                    <Badge Variant="Badge.BadgeVariant.Secondary">@_inProgressCards.Count</Badge>
                </Flex>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                    <DynamicIcon Name="Plus" Class="h-4 w-4" />
                </Button>
            </Flex>
            <div class="@($"space-y-3 min-h-[80px] rounded-lg p-1 transition-colors {(_dropTarget == "inprogress" ? "bg-primary/10 ring-2 ring-primary/30" : "")}")"
                 @ondragover="@(() => _dropTarget = "inprogress")"
                 @ondragover:preventDefault="true"
                 @ondragleave="@(() => _dropTarget = "")"
                 @ondrop="() => Drop(_inProgressCards)">
                @foreach (var card in _inProgressCards)
                {
                    <Stack draggable="true"
                         @ondragstart="() => DragStart(card, _inProgressCards)">
                        @RenderTaskCard(card, "bg-primary/60")
                    </Stack>
                }
            </div>
        </Stack>

        <!-- Review -->
        <Stack Gap="3">
            <Flex Class="items-center justify-between">
                <Flex Class="items-center gap-2">
                    <Heading Level="3" Class="text-sm font-semibold text-foreground">Review</Heading>
                    <Badge Variant="Badge.BadgeVariant.Secondary">@_reviewCards.Count</Badge>
                </Flex>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                    <DynamicIcon Name="Plus" Class="h-4 w-4" />
                </Button>
            </Flex>
            <div class="@($"space-y-3 min-h-[80px] rounded-lg p-1 transition-colors {(_dropTarget == "review" ? "bg-primary/10 ring-2 ring-primary/30" : "")}")"
                 @ondragover="@(() => _dropTarget = "review")"
                 @ondragover:preventDefault="true"
                 @ondragleave="@(() => _dropTarget = "")"
                 @ondrop="() => Drop(_reviewCards)">
                @foreach (var card in _reviewCards)
                {
                    <Stack draggable="true"
                         @ondragstart="() => DragStart(card, _reviewCards)">
                        @RenderTaskCard(card, "bg-chart-3/60")
                    </Stack>
                }
            </div>
        </Stack>

        <!-- Done -->
        <Stack Gap="3">
            <Flex Class="items-center justify-between">
                <Flex Class="items-center gap-2">
                    <Heading Level="3" Class="text-sm font-semibold text-foreground">Done</Heading>
                    <Badge Variant="Badge.BadgeVariant.Secondary">@_doneCards.Count</Badge>
                </Flex>
                <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Icon">
                    <DynamicIcon Name="Plus" Class="h-4 w-4" />
                </Button>
            </Flex>
            <div class="@($"space-y-3 min-h-[80px] rounded-lg p-1 transition-colors {(_dropTarget == "done" ? "bg-primary/10 ring-2 ring-primary/30" : "")}")"
                 @ondragover="@(() => _dropTarget = "done")"
                 @ondragover:preventDefault="true"
                 @ondragleave="@(() => _dropTarget = "")"
                 @ondrop="() => Drop(_doneCards)">
                @foreach (var card in _doneCards)
                {
                    <Stack draggable="true"
                         @ondragstart="() => DragStart(card, _doneCards)">
                        @RenderTaskCard(card, "bg-chart-1/60")
                    </Stack>
                }
            </div>
        </Stack>

    </Grid>
</Stack>

@code {
    private string _search = "";
    private TaskCard? _draggedCard;
    private List<TaskCard>? _dragSource;
    private string _dropTarget = "";

    public record TaskCard(string Id, string Title, string Description, TaskPriority Priority, string DueDate, string Category, int Attachments, int Comments);

    public enum TaskPriority { High, Medium, Low }

    private readonly List<TaskCard> _todoCards = new()
    {
        new("todo-1", "Design system tokens", "Define and document all color, spacing, and typography tokens for the new design system.", TaskPriority.High, "Mar 5", "Design", 3, 4),
        new("todo-2", "Write onboarding copy", "Draft welcome emails and in-app onboarding messages for new users.", TaskPriority.Medium, "Mar 8", "Marketing", 1, 2),
        new("todo-3", "API rate limiting", "Implement rate limiting middleware to protect public API endpoints from abuse.", TaskPriority.High, "Mar 6", "Backend", 0, 5),
        new("todo-4", "Mobile responsive nav", "Refactor navigation component to be fully responsive on small screens.", TaskPriority.Low, "Mar 12", "Frontend", 2, 1),
    };

    private readonly List<TaskCard> _inProgressCards = new()
    {
        new("ip-1", "Authentication flow", "Build complete sign-in, sign-up, and password reset flows using the new auth service.", TaskPriority.High, "Mar 4", "Frontend", 4, 7),
        new("ip-2", "Dashboard analytics", "Add real-time charts and metrics to the main dashboard overview page.", TaskPriority.Medium, "Mar 7", "Frontend", 2, 3),
        new("ip-3", "Component library docs", "Document all Lumeo components with usage examples, props, and accessibility notes.", TaskPriority.Low, "Mar 10", "Design", 1, 6),
    };

    private readonly List<TaskCard> _reviewCards = new()
    {
        new("review-1", "Code Review: Authentication Module", "Review PR #142 for security vulnerabilities and best practices", TaskPriority.High, "Today", "Frontend", 2, 5),
        new("review-2", "UX Review: Checkout Flow", "Review redesigned checkout flow mockups with the team", TaskPriority.Medium, "Tomorrow", "Design", 1, 3),
    };

    private readonly List<TaskCard> _doneCards = new()
    {
        new("done-1", "Project scaffolding", "Set up repository, CI/CD pipeline, and base project structure.", TaskPriority.Medium, "Feb 28", "DevOps", 0, 2),
        new("done-2", "Database schema", "Design and migrate initial database schema for users, projects, and tasks.", TaskPriority.High, "Mar 1", "Backend", 5, 8),
    };

    private void DragStart(TaskCard card, List<TaskCard> source)
    {
        _draggedCard = card;
        _dragSource = source;
    }

    private void Drop(List<TaskCard> target)
    {
        _dropTarget = "";
        if (_draggedCard is null || _dragSource is null || _dragSource == target) return;
        _dragSource.Remove(_draggedCard);
        target.Add(_draggedCard);
        _draggedCard = null;
        _dragSource = null;
    }

    private RenderFragment RenderTaskCard(TaskCard card, string columnColor) => __builder =>
    {
        var priorityVariant = card.Priority switch
        {
            TaskPriority.High => Badge.BadgeVariant.Destructive,
            TaskPriority.Medium => Badge.BadgeVariant.Secondary,
            _ => Badge.BadgeVariant.Outline
        };

        <Card Class="cursor-grab active:cursor-grabbing hover:shadow-md transition-shadow overflow-hidden">
            <Stack Class="@($"h-1 {columnColor}")" />
            <CardContent Class="p-4 space-y-3">
                <Flex Class="items-start justify-between gap-2">
                    <Flex Class="items-center gap-2 flex-wrap">
                        <Badge Variant="Badge.BadgeVariant.Outline" Class="text-xs">@card.Category</Badge>
                    </Flex>
                    <Badge Variant="@priorityVariant" Class="shrink-0 text-xs">@card.Priority.ToString()</Badge>
                </Flex>
                <Lumeo.Text Class="text-sm font-medium text-foreground leading-snug">@card.Title</Lumeo.Text>
                <Lumeo.Text Class="text-xs text-muted-foreground">@card.Description</Lumeo.Text>
                <Separator />
                <Flex Class="items-center gap-3 text-xs text-muted-foreground">
                    <Flex Class="h-6 w-6 rounded-full bg-primary items-center justify-center text-primary-foreground text-xs font-semibold shrink-0">
                        @card.Title.Substring(0, 1)
                    </Flex>
                    @if (card.Attachments > 0)
                    {
                        <Flex Class="items-center gap-1">
                            <DynamicIcon Name="Pin" Class="h-3 w-3" />
                            <Lumeo.Text As="span" Class="text-xs">@card.Attachments</Lumeo.Text>
                        </Flex>
                    }
                    <Flex Class="items-center gap-1">
                        <DynamicIcon Name="MessageCircle" Class="h-3 w-3" />
                        <Lumeo.Text As="span" Class="text-xs">@card.Comments</Lumeo.Text>
                    </Flex>
                    <Flex Class="items-center gap-1 ml-auto">
                        <DynamicIcon Name="CalendarDays" Class="h-3 w-3" />
                        <Lumeo.Text As="span" Class="text-xs">@card.DueDate</Lumeo.Text>
                    </Flex>
                </Flex>
            </CardContent>
        </Card>
    };
}
