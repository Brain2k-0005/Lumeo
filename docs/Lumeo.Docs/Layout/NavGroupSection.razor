@namespace Lumeo.Docs.Layout
@using Lumeo.Docs.Services

<Stack Gap="1">
    @if (Collapsible)
    {
        <button class="group flex items-center justify-between w-full mb-1.5 text-left transition-colors"
                aria-expanded="@IsExpanded"
                aria-label="@($"{(IsExpanded ? "Collapse" : "Expand")} {Group.Label}")"
                @onclick="OnToggle">
            <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground group-hover:text-foreground transition-colors pointer-events-none">@Group.Label</span>
            <SvgGlyph Svg="@(IsExpanded ? Lucide.ChevronDown : Lucide.ChevronRight)" class="h-3.5 w-3.5 text-muted-foreground/50 shrink-0 transition-transform" />
        </button>
    }
    else
    {
        <div class="mb-1.5 text-xs font-semibold uppercase tracking-wide text-muted-foreground">@Group.Label</div>
    }

    @if (!Collapsible || IsExpanded)
    {
        @if (Group.Items is { Count: > 0 } items)
        {
            <ul class="space-y-1">
                @foreach (var item in items)
                {
                    <li>
                        <NavLink href="@item.Href"
                                 class="block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors no-underline">
                            @item.Label
                        </NavLink>
                    </li>
                }
            </ul>
        }

        @if (Group.Subgroups is { Count: > 0 } subs)
        {
            @foreach (var sub in subs)
            {
                <ul class="space-y-1 mt-2">
                    <li class="px-2 pt-1 pb-0.5 text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
                        @sub.Label
                    </li>
                    @foreach (var item in sub.Items)
                    {
                        <li>
                            <NavLink href="@item.Href"
                                     class="block rounded-md px-2 py-1.5 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors no-underline">
                                @item.Label
                            </NavLink>
                        </li>
                    }
                </ul>
            }
        }
    }
</Stack>

@code {
    [Parameter, EditorRequired] public NavGroup Group { get; set; } = null!;
    [Parameter] public bool Collapsible { get; set; }
    [Parameter] public bool IsExpanded { get; set; } = true;
    [Parameter] public EventCallback OnToggle { get; set; }
}
