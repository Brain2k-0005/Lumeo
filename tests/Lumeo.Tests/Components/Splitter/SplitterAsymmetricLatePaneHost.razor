@namespace Lumeo.Tests.Components.Splitter

@* Test host for #258 follow-up — an asymmetric, fully-allocated 70/30 layout the
   user has deliberately sized. Adding a third pane to a full track must NOT
   force-equalize every pane (which would flatten the 70:30 split). *@
<Lumeo.Splitter Orientation="Lumeo.Orientation.Horizontal">
    <Lumeo.SplitterPane Size="70"><span data-testid="pane-0">0</span></Lumeo.SplitterPane>
    <Lumeo.SplitterDivider />
    <Lumeo.SplitterPane Size="30"><span data-testid="pane-1">1</span></Lumeo.SplitterPane>
    @if (ShowThird)
    {
        <Lumeo.SplitterDivider />
        <Lumeo.SplitterPane><span data-testid="pane-2">2</span></Lumeo.SplitterPane>
    }
</Lumeo.Splitter>

@code {
    [Parameter] public bool ShowThird { get; set; }
}
