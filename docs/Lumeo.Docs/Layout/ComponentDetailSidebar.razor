@namespace Lumeo.Docs.Layout
@using Lumeo.Docs.Services
@using Microsoft.AspNetCore.Components.Routing
@inject NavConfigService NavConfig
@inject NavigationManager Nav
@implements IDisposable

@* The component-detail sidebar shows ONLY the active component's category (resolved from
   the URL) — e.g. on /components/button it lists the Form components, not all 15 groups.
   The full-library overview lives in the header Components mega-menu; here we stay focused
   on "what's next to the thing I'm looking at." Falls back to the full collapsible component
   nav if the route can't be mapped to a category. *@
<aside class="hidden lg:block w-64 shrink-0 overflow-y-auto sticky top-16 h-[calc(100dvh-64px)] lumeo-sidebar-scroll" aria-label="Component sidebar">
    <div class="p-4 pb-2">
        <a href="components" class="flex items-center gap-2 text-xs text-muted-foreground hover:text-foreground transition-colors no-underline">
            <Blazicon Svg="Lucide.ArrowLeft" class="h-3 w-3" />
            All components
        </a>
    </div>
    <nav class="lumeo-sidebar-nav p-4 pt-2 text-sm" aria-label="@($"{_category?.Label ?? "Component"} navigation")">
        @if (_category is { } cat)
        {
            <NavGroupSection Group="@cat" Collapsible="false" />
        }
        else
        {
            <NavMenu Section="components" Collapsible="true" Embedded="true" />
        }
    </nav>
</aside>

@code {
    private NavGroup? _category;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await ResolveCategory();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await ResolveCategory();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ResolveCategory()
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri);
        var q = rel.IndexOf('?');
        if (q >= 0) rel = rel[..q];
        _category = await NavConfig.GetComponentCategoryAsync(rel.TrimEnd('/'));
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
