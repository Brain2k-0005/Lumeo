<!-- ======================= CAPABILITIES MARQUEE (desktop-only) ======================= -->
<section class="hidden lg:block py-14 border-y border-border/40 bg-gradient-to-b from-muted/30 via-muted/10 to-muted/30 overflow-hidden relative">
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-background to-transparent z-10"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-background to-transparent z-10"></div>
    @* The two marquees scroll forever via CSS. PauseWhenHidden stops them ticking
       the compositor whenever the band is off-screen (which is most of the time on
       this long page) and resumes on scroll-in. *@
    <PauseWhenHidden>
    <Stack Gap="4">
        <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Class="[--gap:1rem]">
            @foreach (var p in _marqueeRowA)
            {
                <span class="mx-2 inline-flex items-center gap-2 rounded-lg border border-border/40 bg-card px-4 py-2 text-sm font-medium text-foreground whitespace-nowrap shadow-sm hover:border-primary/40 hover:shadow-md transition-all">
                    <DynamicIcon Name="@p.Icon" Class="h-4 w-4 text-primary shrink-0" />
                    @p.Label
                </span>
            }
        </Marquee>
        <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Reverse="true" Class="[--gap:1rem]">
            @foreach (var p in _marqueeRowB)
            {
                <span class="mx-2 inline-flex items-center gap-2 rounded-lg bg-primary/10 text-primary px-4 py-2 text-sm font-semibold whitespace-nowrap hover:bg-primary/15 transition-colors">
                    <DynamicIcon Name="@p.Icon" Class="h-4 w-4 shrink-0" />
                    @p.Label
                </span>
            }
        </Marquee>
    </Stack>
    </PauseWhenHidden>
</section>

