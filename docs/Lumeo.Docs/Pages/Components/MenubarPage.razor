    <ComponentDemo Title="Text Editor" Code="@_editorCode">
        <Menubar>
            <MenubarMenu>
                <MenubarTrigger>Format</MenubarTrigger>
                <MenubarContent>
                    <MenubarLabel>Text</MenubarLabel>
                    <MenubarItem>
                        Bold <MenubarShortcut>Ctrl+B</MenubarShortcut>
                    </MenubarItem>
                    <MenubarItem>
                        Italic <MenubarShortcut>Ctrl+I</MenubarShortcut>
                    </MenubarItem>
                    <MenubarItem>
                        Underline <MenubarShortcut>Ctrl+U</MenubarShortcut>
                    </MenubarItem>
                    <MenubarSeparator />
                    <MenubarLabel>Alignment</MenubarLabel>
                    <MenubarItem>Align Left</MenubarItem>
                    <MenubarItem>Align Center</MenubarItem>
                    <MenubarItem>Align Right</MenubarItem>
                </MenubarContent>
            </MenubarMenu>
            <MenubarMenu>
                <MenubarTrigger>Insert</MenubarTrigger>
                <MenubarContent>
                    <MenubarItem>Image</MenubarItem>
                    <MenubarItem>Table</MenubarItem>
                    <MenubarItem>Link</MenubarItem>
                    <MenubarSeparator />
                    <MenubarItem Disabled="true">Video (Pro)</MenubarItem>
                </MenubarContent>
            </MenubarMenu>
            <MenubarMenu>
                <MenubarTrigger>Tools</MenubarTrigger>
                <MenubarContent>
                    <MenubarItem>
                        Word Count <MenubarShortcut>Ctrl+W</MenubarShortcut>
                    </MenubarItem>
                    <MenubarItem>Spell Check</MenubarItem>
                </MenubarContent>
            </MenubarMenu>
        </Menubar>
    </ComponentDemo>

    <ComponentDemo Title="Checkbox & Radio Items" Code="@_checkRadioCode" Description="Toggle items stay open on click so several can be flipped in one pass; radio items are single-select.">
        <Menubar>
            <MenubarMenu>
                <MenubarTrigger>View</MenubarTrigger>
                <MenubarContent>
                    <MenubarCheckboxItem @bind-Checked="_showToolbar">Show Toolbar</MenubarCheckboxItem>
                    <MenubarCheckboxItem @bind-Checked="_showStatusBar">Show Status Bar</MenubarCheckboxItem>
                    <MenubarSeparator />
                    <MenubarLabel Inset="true">Sidebar Position</MenubarLabel>
                    <MenubarRadioGroup @bind-Value="_sidebarSide">
                        <MenubarRadioItem Value="left">Left</MenubarRadioItem>
                        <MenubarRadioItem Value="right">Right</MenubarRadioItem>
                    </MenubarRadioGroup>
                </MenubarContent>
            </MenubarMenu>
        </Menubar>
    </ComponentDemo>

    <ComponentDemo Title="Destructive & Inset Items" Code="@_destructiveCode" Description="Variant=Destructive paints the item (and its icon) in the destructive color; Inset aligns label-only items under items that have a leading icon or checkmark.">
        <Menubar>
            <MenubarMenu>
                <MenubarTrigger>Edit</MenubarTrigger>
                <MenubarContent>
                    <MenubarItem Inset="true">Rename</MenubarItem>
                    <MenubarItem Inset="true">Duplicate</MenubarItem>
                    <MenubarSeparator />
                    <MenubarItem Variant="MenuItemVariant.Destructive">
                        <DynamicIcon Name="Trash" Class="mr-2 h-4 w-4" />
                        Delete <MenubarShortcut>Ctrl+Del</MenubarShortcut>
                    </MenubarItem>
                </MenubarContent>
            </MenubarMenu>
        </Menubar>
    </ComponentDemo>
</Stack>

<div class="mt-12 space-y-4">
    <Heading Id="submenus" Level="2" Class="scroll-mt-20">Submenus</Heading>
    <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
        Inside a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">MenubarContent</code>
        you can nest deeper menus with the <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">MenubarSub</code> /
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">MenubarSubTrigger</code> /
        <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">MenubarSubContent</code>
        triplet. Submenus open on hover (with intent delay) and nest recursively — useful for the classic
        File → Open Recent → … desktop pattern.
    </Lumeo.Text>

    <ComponentDemo Title="Submenus" Code="@_submenusCode">
        <Menubar>
            <MenubarMenu>
                <MenubarTrigger>File</MenubarTrigger>
                <MenubarContent>
                    <MenubarItem>New Tab <MenubarShortcut>Ctrl+T</MenubarShortcut></MenubarItem>

                    <MenubarSub>
                        <MenubarSubTrigger>Open Recent</MenubarSubTrigger>
                        <MenubarSubContent>
                            <MenubarItem>notes.md</MenubarItem>
                            <MenubarItem>todo.txt</MenubarItem>

                            <MenubarSub>
                                <MenubarSubTrigger>Archived</MenubarSubTrigger>
                                <MenubarSubContent>
                                    <MenubarItem>old-notes.md</MenubarItem>
                                </MenubarSubContent>
                            </MenubarSub>
                        </MenubarSubContent>
                    </MenubarSub>

                    <MenubarSeparator />
                    <MenubarItem>Quit</MenubarItem>
                </MenubarContent>
            </MenubarMenu>
        </Menubar>
    </ComponentDemo>

    <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
        Keyboard:
    </Lumeo.Text>
    <ul class="space-y-1 text-sm text-muted-foreground list-disc list-inside">
        <li><Kbd>ArrowRight</Kbd> on a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">SubTrigger</code> opens the submenu and focuses its first item.</li>
        <li><Kbd>ArrowLeft</Kbd> closes the current submenu and returns focus to the parent trigger (it does not jump to a neighbouring top-level menu).</li>
        <li><Kbd>Escape</Kbd> closes the entire menubar tree.</li>
    </ul>
</div>

