# Host-side ports and credentials for docker-compose. Change any value here and
# `docker compose up` picks it up — no compose-file edits needed.

# --- Ports (host : container) ------------------------------------------------
POSTGRES_PORT=5432
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
API_PORT=8080
CLIENT_PORT=8081

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=myapp
POSTGRES_PASSWORD=myapp_dev_password
POSTGRES_DB=myapp
