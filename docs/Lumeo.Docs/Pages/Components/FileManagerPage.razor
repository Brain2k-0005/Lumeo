        var node = FindNode(_editableTree, args.Node.Id);
        if (node is not null) node.Name = args.NewName;
    }

    private void HandleDelete(IReadOnlyList<FileSystemNode> nodes)
    {
        foreach (var n in nodes) RemoveNode(_editableTree, n.Id);
    }

    private void HandleNewFolder(FileSystemNode parentFolder)
    {
        var newFolder = new FileSystemNode
