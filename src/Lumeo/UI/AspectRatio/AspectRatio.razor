@namespace Lumeo

<div class="relative w-full" style="padding-bottom: @PaddingPercent%" @attributes="AdditionalAttributes">
    <div class="@CssClass">
        @ChildContent
    </div>
</div>

@code {
    /// <summary>The content (typically an image or video) constrained to the given <see cref="Ratio"/>, absolutely positioned to fill the box.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>The width-to-height ratio (e.g. <c>16.0/9</c>) the box is padded to maintain. Default <c>1</c> (square). Non-finite or non-positive values fall back to 1:1.</summary>
    [Parameter] public double Ratio { get; set; } = 1;

    /// <summary>Additional CSS classes merged onto the inner content wrapper.</summary>
    [Parameter] public string? Class { get; set; }

    /// <summary>Unmatched attributes splatted onto the outer padding-box element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => Cx.Merge("absolute inset-0", Class);

    // Invariant formatting: CurrentCulture rendered "56,25%" on comma-decimal
    // locales (de-DE Blazor Server) — an invalid declaration browsers drop,
    // collapsing the box to zero height. Non-finite or non-positive ratios
    // fall back to 1:1 (NaN/Infinity would emit "NaN%" / "0%").
    private string PaddingPercent =>
        (double.IsFinite(Ratio) && Ratio > 0 ? 100.0 / Ratio : 100.0).ToString(System.Globalization.CultureInfo.InvariantCulture);
}
