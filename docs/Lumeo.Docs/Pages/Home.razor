@page "/"
@using Lumeo.Services
@implements IAsyncDisposable
@inject ToastService ToastService
@inject IJSRuntime JS

<PageTitle>Lumeo — The Blazor component library you'd actually want to ship</PageTitle>

<!-- ======================= HERO ======================= -->
<section class="relative overflow-hidden">
    <!-- Subtle grid pattern background -->
    <div class="absolute inset-0 bg-[linear-gradient(to_right,hsl(var(--border))_1px,transparent_1px),linear-gradient(to_bottom,hsl(var(--border))_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_110%)] pointer-events-none opacity-50"></div>
    <!-- Radial gradient mesh orb — primary-tinted warm glow centered above the fold -->
    <div class="pointer-events-none absolute -top-40 left-1/2 -translate-x-1/2 h-[600px] w-[900px] rounded-full opacity-[0.12]"
         style="background: radial-gradient(ellipse at center, hsl(var(--primary)) 0%, transparent 70%);"></div>
    <!-- Secondary soft orb offset left for depth -->
    <div class="pointer-events-none absolute top-20 left-1/4 h-[300px] w-[400px] rounded-full opacity-[0.06]"
         style="background: radial-gradient(ellipse at center, hsl(var(--primary)) 0%, transparent 70%);"></div>

    <Container MaxWidth="6xl" Class="relative px-4 py-28 pb-20">
        <BlurFade DelayMs="0">
            <Stack Gap="5" Class="items-center text-center">
                <!-- Version badge — tighter, more structured pill -->
                <Lumeo.Link Href="docs/changelog" Class="no-underline group">
                    <Flex Inline="true" Align="center" Gap="2" Class="rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur-sm hover:border-primary/40 hover:text-foreground transition-colors">
                        <Badge Variant="Badge.BadgeVariant.Default" Class="h-4 px-1.5 text-[10px] leading-none">v3.2</Badge>
                        <Lumeo.Text As="span">Map Globe (MapLibre 5), Heatmap, Legend, Popup · CDN-deps CLI · DataGrid pin/grouping fixes · Home polish</Lumeo.Text>
                        <DynamicIcon Name="ArrowRight" Class="h-3 w-3 transition-transform group-hover:translate-x-0.5" />
                    </Flex>
                </Lumeo.Link>

                <!-- Giant headline — tighter tracking, stronger hierarchy -->
                <Heading Level="1" Class="text-5xl sm:text-7xl md:text-[5.5rem] font-bold tracking-[-0.02em] leading-[1.0] max-w-4xl">
                    The Blazor library<br />
                    you'd actually want to <Lumeo.Text As="span" Class="text-primary">ship</Lumeo.Text>.
                </Heading>

                <!-- Subtitle -->
                <Lumeo.Text Size="lg" Color="muted" Class="max-w-xl leading-relaxed">
                    149 components across a
                    <Lumeo.Link Href="/docs/bundle-facts" Class="font-semibold text-foreground decoration-dotted decoration-primary/60 underline underline-offset-4 hover:text-primary transition-colors no-underline">~400 KB core</Lumeo.Link>
                    plus opt-in satellites.
                </Lumeo.Text>

                <!-- CTA row -->
                <Flex Gap="3" Wrap="true" Justify="center" Class="pt-1">
                    <Lumeo.Link Href="docs/introduction" Class="no-underline">
                        <ShimmerButton Size="Button.ButtonSize.Lg" Class="rounded-lg">
                            Get Started
                            <DynamicIcon Name="ArrowRight" Class="h-4 w-4" />
                        </ShimmerButton>
                    </Lumeo.Link>
                    <Lumeo.Link Href="components/button" Class="inline-flex h-10 items-center gap-2 justify-center rounded-lg border border-border/60 bg-background px-6 text-sm font-semibold hover:bg-accent hover:text-accent-foreground transition-colors no-underline">
                        <DynamicIcon Name="LayoutGrid" Class="h-4 w-4" />
                        Browse Components
                    </Lumeo.Link>
                </Flex>

                <!-- Install command wrapped in BorderBeam -->
                <Stack Align="center" Gap="2" Class="pt-2">
                    <BorderBeam DurationMs="6000" Class="inline-block shadow-[0_0_28px_-12px_hsl(var(--primary)/0.5)] rounded-lg">
                        <Flex Align="center" Gap="0" Class="rounded-lg border border-border/40 bg-muted/30 pl-4 pr-2 py-2 font-mono text-xs text-foreground backdrop-blur-sm">
                            <Lumeo.Text As="span" Color="muted" Class="mr-2 select-none">$</Lumeo.Text>
                            <Lumeo.Text As="span" Class="whitespace-nowrap">dotnet add package Lumeo</Lumeo.Text>
                            <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm" Class="ml-3 inline-flex items-center justify-center h-8 w-8 p-0 rounded-md text-muted-foreground hover:text-foreground" OnClick="CopyInstall" aria-label="Copy install command">
                                @if (_installCopied)
                                {
                                    <DynamicIcon Name="Check" Class="h-4 w-4 text-primary" />
                                }
                                else
                                {
                                    <DynamicIcon Name="Copy" Class="h-4 w-4" />
                                }
                            </Button>
                        </Flex>
                    </BorderBeam>
                    <Lumeo.Text Size="xs" Color="muted">Core only — <Lumeo.Link Href="docs/introduction" Class="underline underline-offset-2 hover:text-foreground transition-colors">satellites</Lumeo.Link> ship separately.</Lumeo.Text>
                </Stack>

                <!-- Hero stats strip — moved below install for better hierarchy flow.
                     Four numbered facts as a clean inline row with dividers. -->
                <div class="pt-6 border-t border-border/30 w-full max-w-lg">
                    <Flex Align="center" Justify="center" Wrap="true" Gap="0" Class="text-sm">
                        <Flex Align="center" Gap="2" Class="px-4 py-1">
                            <span class="font-bold text-foreground tabular-nums text-base"><NumberTicker Value="149" DurationMs="1400" /></span>
                            <Lumeo.Text As="span" Size="xs" Color="muted">components</Lumeo.Text>
                        </Flex>
                        <span class="h-3 w-px bg-border/60" aria-hidden="true"></span>
                        <Flex Align="center" Gap="2" Class="px-4 py-1">
                            <span class="font-bold text-foreground tabular-nums text-base"><NumberTicker Value="2194" DurationMs="2000" /></span>
                            <Lumeo.Text As="span" Size="xs" Color="muted">tests</Lumeo.Text>
                        </Flex>
                        <span class="h-3 w-px bg-border/60" aria-hidden="true"></span>
                        <Flex Align="center" Gap="2" Class="px-4 py-1">
                            <span class="font-bold text-foreground tabular-nums text-base"><NumberTicker Value="8" DurationMs="1600" /></span>
                            <Lumeo.Text As="span" Size="xs" Color="muted">themes</Lumeo.Text>
                        </Flex>
                        <span class="h-3 w-px bg-border/60" aria-hidden="true"></span>
                        <Flex Align="center" Gap="2" Class="px-4 py-1">
                            <span class="font-bold text-foreground tabular-nums text-base"><NumberTicker Value="14" DurationMs="1800" /></span>
                            <Lumeo.Text As="span" Size="xs" Color="muted">locales</Lumeo.Text>
                        </Flex>
                    </Flex>
                </div>
            </Stack>
        </BlurFade>
    </Container>
</section>

<Separator Class="opacity-30" />


<!-- ======================= SIZE COMPARISON BENTO ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">The hook</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">A fraction of the size.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    Brotli-compressed assembly size — what an end user's browser actually downloads from your published app.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="4" Gap="Bento.BentoGap.Md">
            <!-- Central tile spans 2 cols and 2 rows — the size chart -->
            <BentoTile Span="2" RowSpan="2" Class="border-border/60 p-6">
                <Stack Gap="5" Class="h-full">
                    <Stack Gap="1">
                        <Flex Align="center" Gap="2">
                            <Heading Level="3" Class="text-2xl font-semibold tracking-tight">
                                149 components across 7 packages. <Lumeo.Text As="span" Class="text-primary">~400 KB core</Lumeo.Text>.
                            </Heading>
                        </Flex>
                        <Lumeo.Text Size="sm" Color="muted">Per-package breakdown — install only the satellites you use. Each row shows what that package adds to your app's bundle.</Lumeo.Text>
                    </Stack>

                    <Stack Gap="4" Class="flex-1 justify-center">
                        @foreach (var row in _sizeRows)
                        {
                            <Stack Gap="1.5">
                                <Flex Align="center" Justify="between" Class="text-sm">
                                    <Flex Align="center" Gap="2">
                                        <span class="h-2 w-2 rounded-full @(row.IsCore ? "bg-primary" : "bg-primary/50")"></span>
                                        <Lumeo.Text As="span" Weight="@(row.IsCore ? "semibold" : "medium")" Color="foreground">@row.Name</Lumeo.Text>
                                        <span class="hidden sm:inline-block w-16 opacity-70" aria-hidden="true">
                                            <Sparkline Values="row.Spark" Height="14" ShowArea="true" StrokeWidth="1" AriaLabel="@($"{row.Name} downloads trend")" />
                                        </span>
                                        <Lumeo.Text As="span" Size="xs" Color="muted">@row.Components</Lumeo.Text>
                                    </Flex>
                                    <Lumeo.Text As="span" Size="xs" Class="@(row.IsCore ? "font-mono text-primary font-semibold" : "font-mono text-muted-foreground")">@row.Size</Lumeo.Text>
                                </Flex>
                                <div class="relative h-2 rounded-md bg-muted/40 overflow-hidden">
                                    <div class="@(row.IsCore ? "bg-primary" : "bg-primary/50") h-full rounded-md transition-all"
                                         style="width: @(row.Percent)%;"></div>
                                </div>
                            </Stack>
                        }
                    </Stack>

                    <Flex Align="center" Gap="2" Class="pt-1 text-xs text-muted-foreground border-t border-border/40 pt-4">
                        <DynamicIcon Name="Info" Class="h-3.5 w-3.5" />
                        <Lumeo.Text As="span">Brotli-compressed assembly bytes (v3.1.0, 2026-05-22). NuGet <code class="text-foreground">.nupkg</code> ships at ~660 KB; the runtime core brotli-compresses to ~400 KB in your published app.</Lumeo.Text>
                    </Flex>
                </Stack>
            </BentoTile>

            <!-- 4 KPI tiles stacked on the right -->
            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="TestTube" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Tests</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="2194" DurationMs="1800" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">CI green, every commit.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Languages" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Locales</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="14" DurationMs="1600" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">Bundled ILumeoLocalizer.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Palette" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Themes</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">
                        <NumberTicker Value="8" DurationMs="1400" />
                    </div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">CSS-variable presets.</Lumeo.Text>
                </Stack>
            </BentoTile>

            <BentoTile Class="border-border/60 p-5">
                <Stack Gap="2" Class="h-full">
                    <Flex Align="center" Gap="2">
                        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-accent/40 text-primary">
                            <DynamicIcon Name="Accessibility" Class="h-4 w-4" />
                        </div>
                        <Lumeo.Text Size="sm" Color="muted">Compliance</Lumeo.Text>
                    </Flex>
                    <div class="text-3xl font-semibold tracking-tight text-foreground">WCAG AA</div>
                    <Lumeo.Text Size="xs" Color="muted" Class="mt-auto">Keyboard + ARIA built in.</Lumeo.Text>
                </Stack>
            </BentoTile>
        </Bento>
    </Container>
</section>


<!-- ======================= WHAT'S NEW IN 3.0 ======================= -->
<section class="py-20 bg-muted/[0.03]">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">New in 3.0</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">The 3.0 highlights.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A unified enum surface across the library, plus six new primitives you'd otherwise wire up yourself.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="3" Gap="Bento.BentoGap.Md">
            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="Menu" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">Menu submenus</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        The <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">DropdownMenuSub</code> / <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">SubTrigger</code> / <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">SubContent</code> triplet, recursively nestable with proper keyboard + roving-focus.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/dropdown-menu" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>

            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="Shield" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">OnBeforeClose</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        A dismiss-gate on Dialog, Sheet, Drawer and AlertDialog — inspect <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">DismissEventArgs.Reason</code>, cancel to keep open.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/dialog" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>

            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="Clock" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">Async field validation</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">FormField.AsyncValidator</code> debounces server checks, surfaces a pending state, and renders a spinner alongside the field.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/form-field" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>

            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="CornerUpLeft" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">DatePicker keyboard input</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        Type the date directly in the field's <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">Format</code> — auto-parses on Enter or blur. The calendar remains a click away.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/date-picker" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>

            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="Globe" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">DateTimePicker time zone</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        DST-aware <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">DateTimeOffset</code> binding — pick a zone, get the right wall-clock and the right instant.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/date-time-picker" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>

            <BentoTile Span="1" Class="border-t-2 border-t-primary/60 border-border/40 p-6 bg-card/60">
                <Stack Gap="3" Class="h-full">
                    <Flex Align="center" Gap="3">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-primary/10 text-primary shrink-0">
                            <DynamicIcon Name="SquareMousePointer" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">Tabs drag-to-reorder</Heading>
                    </Flex>
                    <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">
                        Opt-in <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">TabsList.Reorderable</code> with an <code class="rounded bg-muted px-1 py-0.5 text-xs font-mono text-foreground">OnReorder</code> callback — pointer + keyboard, both wired.
                    </Lumeo.Text>
                    <Lumeo.Link Href="components/tabs" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline mt-auto">
                        Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                    </Lumeo.Link>
                </Stack>
            </BentoTile>
        </Bento>
    </Container>
</section>


<!-- ======================= MARQUEE WALL (two rows, opposite directions) ======================= -->
<section class="py-14 border-y border-border/40 bg-gradient-to-b from-muted/30 via-muted/10 to-muted/30 overflow-hidden relative">
    @* Edge fades so pills dissolve in/out instead of hard-cutting at the container. *@
    <div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-background to-transparent z-10"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-background to-transparent z-10"></div>

    <BlurFade DelayMs="0">
        <Stack Gap="4">
            <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Class="[--gap:1rem]">
                @foreach (var p in _marqueeRowA)
                {
                    <span class="mx-2 inline-flex items-center gap-2 rounded-lg border border-border/40 bg-card px-4 py-2 text-sm font-medium text-foreground whitespace-nowrap shadow-sm hover:border-primary/40 hover:shadow-md transition-all">
                        <DynamicIcon Name="@p.Icon" Class="h-4 w-4 text-primary shrink-0" />
                        @p.Label
                    </span>
                }
            </Marquee>

            <Marquee Speed="Marquee.MarqueeSpeed.Slow" PauseOnHover="true" Reverse="true" Class="[--gap:1rem]">
                @foreach (var p in _marqueeRowB)
                {
                    <span class="mx-2 inline-flex items-center gap-2 rounded-lg bg-primary/10 text-primary px-4 py-2 text-sm font-semibold whitespace-nowrap hover:bg-primary/15 transition-colors">
                        <DynamicIcon Name="@p.Icon" Class="h-4 w-4 shrink-0" />
                        @p.Label
                    </span>
                }
            </Marquee>
        </Stack>
    </BlurFade>
</section>


<!-- ======================= LIVE COMPONENT SHOWCASE ======================= -->
<section class="py-24">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Live</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Real components. No screenshots.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    Every tile below is the actual Lumeo component rendered in your browser.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <Bento Columns="4" Gap="Bento.BentoGap.Md">

            <!-- DataGrid — wide tile (grouped by Team, Salary aggregated) -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 p-5 bg-muted/10">
                        <DataGrid TItem="Employee" Items="@_employees" PageSize="10" ShowPagination="false"
                                  GroupBy="Department" GroupsExpandedByDefault="true">
                            <DataGridColumnDef TItem="Employee" Title="Name" Field="Name" Sortable="true" />
                            <DataGridColumnDef TItem="Employee" Title="Role" Field="Role" />
                            <DataGridColumnDef TItem="Employee" Title="Salary" Field="Salary" Format="C0" Sortable="true" Aggregate="AggregateType.Sum" />
                        </DataGrid>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Table2" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">DataGrid</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/datagrid" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Map — Globe projection with great-circle arcs, DarkMatter basemap.
                 RowSpan=2 so the globe fills a tall tile next to the PdfViewer
                 row, and Zoom=2 so the sphere itself takes more of the canvas
                 instead of floating tiny in the middle.
                 `hidden lg:flex` keeps the entire tile out of the DOM layout
                 on mobile/tablet — LazyRender's IntersectionObserver never
                 fires for display:none placeholders, so MapLibre GL JS
                 (~250 KB) is not downloaded on phones where the globe would
                 be unusably small anyway. -->
            <BentoTile Span="2" RowSpan="2" Class="border-border/60 p-0 overflow-hidden hidden lg:flex">
                <div class="flex h-full flex-col overflow-hidden">
                    <div class="flex-1 min-h-0 relative overflow-hidden">
                        <LazyRender Height="100%">
                            <Map Center="(20.0, 10.0)" Zoom="2" Height="100%" TileLayer="DarkMatter" Projection="globe">
                                <ChildContent>
                                    <MapMarker Lat="51.5074" Lon="-0.1278"  Title="London"     Variant="Dot" Color="teal" Label="London" />
                                    <MapMarker Lat="40.7128" Lon="-74.0060" Title="New York"   Variant="Dot" Color="teal" Label="New York" />
                                    <MapMarker Lat="35.6762" Lon="139.6503" Title="Tokyo"      Variant="Dot" Color="teal" Label="Tokyo" />
                                    <MapMarker Lat="-33.8688" Lon="151.2093" Title="Sydney"    Variant="Dot" Color="teal" Label="Sydney" />
                                    <MapMarker Lat="-23.5505" Lon="-46.6333" Title="São Paulo" Variant="Dot" Color="teal" Label="São Paulo" />
                                    <MapArc From="(51.5074, -0.1278)" To="(40.7128, -74.0060)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                    <MapArc From="(51.5074, -0.1278)" To="(35.6762, 139.6503)"  Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                    <MapArc From="(51.5074, -0.1278)" To="(-33.8688, 151.2093)" Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                    <MapArc From="(40.7128, -74.0060)" To="(-23.5505, -46.6333)" Color="#60a5fa" Dashed="true" Weight="2" Opacity="0.85" Animate="true" />
                                </ChildContent>
                            </Map>
                        </LazyRender>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Globe" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Map · Globe projection</Lumeo.Text>
                            <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-4 ml-1">Lumeo.Maps</Badge>
                        </Flex>
                        <Lumeo.Link Href="components/map" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Charts — three live ECharts stacked vertically (Bar / Line /
                 Area), datasets reshuffle every ~2s in sync. Hover pauses.
                 RowSpan=2 so each chart gets ~240px height. No Pie/Donut.
                 Hidden on mobile: three ECharts re-rendering every 2 s pegs
                 the main thread on phones, and at 1-col width the labels
                 collide. Desktop visitors see the showcase intact. -->
            <BentoTile Span="2" RowSpan="2" Class="border-border/60 p-0 overflow-hidden hidden lg:flex">
                <div class="flex h-full flex-col overflow-hidden" @onmouseenter="@(() => _chartHovered = true)" @onmouseleave="@(() => _chartHovered = false)">
                    <div class="flex-1 min-h-0 grid grid-rows-3 gap-2 p-3 bg-muted/10">
                        <div class="rounded-md border border-border/40 bg-card/60 p-2 min-h-0 overflow-hidden">
                            <BarChart Categories="_barCategories" Series="_barSeries" Stacked="true" Height="100%" ShowLoadingSkeleton="false" />
                        </div>
                        <div class="rounded-md border border-border/40 bg-card/60 p-2 min-h-0 overflow-hidden">
                            <LineChart Categories="_lineCategories" Series="_lineSeries" Smooth="true" Height="100%" ShowLoadingSkeleton="false" />
                        </div>
                        <div class="rounded-md border border-border/40 bg-card/60 p-2 min-h-0 overflow-hidden">
                            <RadarChart Indicators="_radarIndicators" Series="_radarSeries" Height="100%" ShowLegend="false" ShowLoadingSkeleton="false" />
                        </div>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="BarChart3" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Charts · Bar · Line · Radar</Lumeo.Text>
                            <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-4 ml-1">Lumeo.Charts</Badge>
                        </Flex>
                        <Lumeo.Link Href="components/charts/bar" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- PdfViewer — inline PDF with search highlight. We use HARD heights
                 (not max-height) so the PdfViewer's `h-full` resolves to a real
                 number; without that, its inner `flex-1 overflow-auto` document
                 area has no upper bound and the canvas can't scroll when zoomed in.
                 Hidden on mobile: pdf.js + its worker (~150 KB) plus the PDF
                 download itself would crater LCP on a phone, and the viewer
                 chrome is unusable at narrow widths. -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden hidden lg:flex">
                <div class="flex flex-col overflow-hidden" style="height:560px">
                    <div class="flex-1 min-h-0 overflow-hidden">
                        <LazyRender Height="100%">
                            <PdfViewer Src="https://mozilla.github.io/pdf.js/web/compressed.tracemonkey-pldi-09.pdf"
                                       Page="1" Zoom="0.5" ShowSearch="true" ShowDownload="false" Class="h-full" />
                        </LazyRender>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="FileText" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">PdfViewer · Search + Highlight</Lumeo.Text>
                            <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px] h-4 ml-1">Lumeo.PdfViewer</Badge>
                        </Flex>
                        <Lumeo.Link Href="components/pdf-viewer" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- AudioPlayer — scrub bar, mute, keyboard shortcuts -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 flex items-center justify-center p-4 bg-gradient-to-br from-primary/5 via-transparent to-primary/10">
                        <AudioPlayer Src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"
                                     Title="SoundHelix Song 1" Artist="T. Schürger" Class="w-full max-w-md" />
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Music" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">AudioPlayer · Scrub + Download</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/audio-player" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            View docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Form controls — single row, content centered. RowSpan=2 left
                 too much dead space below the form so we dropped to RowSpan=1. -->
            <BentoTile Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <Stack Gap="4" Class="flex-1 justify-center p-6 bg-muted/10">
                        <Flex Align="center" Gap="3">
                            <Switch @bind-Checked="_switchOn" Label="Notifications" />
                            <Lumeo.Text Size="sm" Color="muted">@(_switchOn ? "On" : "Off")</Lumeo.Text>
                        </Flex>
                        <Stack Gap="2">
                            <Lumeo.Text Size="xs" Color="muted" id="lumeo-volume-label">Volume · @((int)_sliderVal)%</Lumeo.Text>
                            <Slider @bind-Value="_sliderVal" AriaLabel="Volume" />
                        </Stack>
                        <Stack Gap="2">
                            <Lumeo.Text Size="xs" Color="muted">Seats</Lumeo.Text>
                            <NumberInput @bind-Value="_seats" Min="1" Max="99" Suffix="users" />
                        </Stack>
                        <Stack Gap="2">
                            <Lumeo.Text Size="xs" Color="muted">Plan</Lumeo.Text>
                            <RadioGroup @bind-Value="_plan" AriaLabel="Plan" Class="flex gap-3">
                                <Flex Align="center" Gap="2">
                                    <RadioGroupItem Value="hobby" />
                                    <Lumeo.Text Size="sm">Hobby</Lumeo.Text>
                                </Flex>
                                <Flex Align="center" Gap="2">
                                    <RadioGroupItem Value="pro" />
                                    <Lumeo.Text Size="sm">Pro</Lumeo.Text>
                                </Flex>
                                <Flex Align="center" Gap="2">
                                    <RadioGroupItem Value="team" />
                                    <Lumeo.Text Size="sm">Team</Lumeo.Text>
                                </Flex>
                            </RadioGroup>
                        </Stack>
                        <Flex Gap="3" Align="center">
                            <Checkbox @bind-Checked="_checkOn" AriaLabel="Subscribe" />
                            <Lumeo.Text Size="sm" Color="muted">Subscribe</Lumeo.Text>
                        </Flex>
                        <Flex Gap="2" Align="center">
                            <Toggle @bind-Pressed="_togglePressed" AriaLabel="Bold">
                                <DynamicIcon Name="Bold" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle AriaLabel="Italic">
                                <DynamicIcon Name="Italic" Class="h-4 w-4" />
                            </Toggle>
                            <Toggle AriaLabel="Underline">
                                <DynamicIcon Name="Underline" Class="h-4 w-4" />
                            </Toggle>
                        </Flex>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="SlidersHorizontal" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Form controls</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/switch" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Kanban — real Lumeo.Kanban / KanbanColumn / KanbanCard, drag-enabled -->
            <BentoTile Span="3" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col">
                    <div class="flex-1 p-2 bg-muted/10 overflow-hidden">
                        <Kanban Class="!p-2 !gap-3">
                            <KanbanColumn Title="To do" Badge="@_kanbanTodo.Count" Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[200px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanTodo))">
                                @foreach (var card in _kanbanTodo)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description"
                                                    Draggable="false"
                                                    Class="rounded-md border border-border/40 bg-card p-2.5 cursor-grab active:cursor-grabbing hover:border-primary/40 transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                            <KanbanColumn Title="In progress" Badge="@_kanbanDoing.Count" Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[200px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanDoing))">
                                @foreach (var card in _kanbanDoing)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description"
                                                    Draggable="false"
                                                    Class="rounded-md border border-primary/40 bg-card p-2.5 ring-1 ring-primary/20 cursor-grab active:cursor-grabbing transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                            <KanbanColumn Title="Done" Badge="@_kanbanDone.Count" Class="flex flex-col flex-1 min-w-0 rounded-lg border border-border/40 bg-background min-h-[200px]"
                                          OnDrop="@(_ => MoveDraggingCard(_kanbanDone))">
                                @foreach (var card in _kanbanDone)
                                {
                                    <div draggable="true" @ondragstart="@(() => _draggingCard = card)" @key="card">
                                        <KanbanCard Title="@card.Title" Description="@card.Description"
                                                    Draggable="false"
                                                    Class="rounded-md border border-border/40 bg-card/60 p-2.5 opacity-75 cursor-grab active:cursor-grabbing transition-colors" />
                                    </div>
                                }
                            </KanbanColumn>
                        </Kanban>
                    </div>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="LayoutList" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Kanban · drag to reorder</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/kanban" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Auto-cycling Tabs — sliding indicator, advances every 3s. Pause-on-hover so
                 visitors who want to read a specific panel aren't fighting the timer. -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col" @onmouseenter="@(() => _tabsHovered = true)" @onmouseleave="@(() => _tabsHovered = false)">
                    <Stack Gap="3" Class="flex-1 justify-center p-5 min-h-[160px] bg-muted/10">
                        <Tabs @bind-ActiveValue="_tabsActive" AnimatedIndicator="true">
                            <TabsList>
                                <TabsTrigger Value="overview">Overview</TabsTrigger>
                                <TabsTrigger Value="activity">Activity</TabsTrigger>
                                <TabsTrigger Value="reports">Reports</TabsTrigger>
                                <TabsTrigger Value="settings">Settings</TabsTrigger>
                            </TabsList>
                            <TabsContent Value="overview">
                                <Stack Gap="2" Class="p-4">
                                    <Lumeo.Text Size="sm" Weight="semibold">Today at a glance</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">14 active workflows, 3 deploys, all CI green.</Lumeo.Text>
                                </Stack>
                            </TabsContent>
                            <TabsContent Value="activity">
                                <Stack Gap="2" Class="p-4">
                                    <Lumeo.Text Size="sm" Weight="semibold">Recent activity</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">Ava merged #482 · Jonas opened #491 · 2.4k events this week.</Lumeo.Text>
                                </Stack>
                            </TabsContent>
                            <TabsContent Value="reports">
                                <Stack Gap="2" Class="p-4">
                                    <Lumeo.Text Size="sm" Weight="semibold">Reports</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">Weekly digest · Bundle-size delta · Auth funnel · 4 scheduled.</Lumeo.Text>
                                </Stack>
                            </TabsContent>
                            <TabsContent Value="settings">
                                <Stack Gap="2" Class="p-4">
                                    <Lumeo.Text Size="sm" Weight="semibold">Settings</Lumeo.Text>
                                    <Lumeo.Text Size="xs" Color="muted">Workspace · Members · Integrations · Billing.</Lumeo.Text>
                                </Stack>
                            </TabsContent>
                        </Tabs>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="LayoutTemplate" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Tabs · sliding indicator</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/tabs" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

            <!-- Auto-advancing Steps tile — wraps 0→3→0 every 2.5s. Pause-on-hover. -->
            <BentoTile Span="2" Class="border-border/60 p-0 overflow-hidden">
                <div class="flex h-full flex-col" @onmouseenter="@(() => _stepsHovered = true)" @onmouseleave="@(() => _stepsHovered = false)">
                    <Stack Gap="5" Class="flex-1 justify-center p-6 min-h-[160px] bg-muted/10">
                        <Steps CurrentStep="_stepIndex" Animated="true" Class="w-full">
                            <StepsItem Title="Plan" Description="Scope the work" />
                            <StepsItem Title="Build" Description="Ship the code" />
                            <StepsItem Title="Test" Description="2,194 specs" />
                            <StepsItem Title="Ship" Description="Brotli to prod" />
                        </Steps>
                        <!-- Step label row — shows current active step name with a pulsing indicator -->
                        <Flex Align="center" Justify="center" Gap="2" Class="text-xs text-muted-foreground">
                            <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
                            <Lumeo.Text As="span" Size="xs" Color="muted">
                                Step @(_stepIndex + 1) of 4 —
                                @(_stepIndex switch {
                                    0 => "scoping the requirements",
                                    1 => "writing and reviewing code",
                                    2 => "running 2,194 CI specs",
                                    _ => "pushing Brotli to production"
                                })
                            </Lumeo.Text>
                        </Flex>
                    </Stack>
                    <Flex Align="center" Justify="between" Class="border-t border-border/40 px-4 py-2.5">
                        <Flex Align="center" Gap="2">
                            <DynamicIcon Name="Layers" Class="h-4 w-4 text-primary" />
                            <Lumeo.Text Size="xs" Weight="semibold">Steps · animated progression</Lumeo.Text>
                        </Flex>
                        <Lumeo.Link Href="components/steps" Class="text-xs text-muted-foreground hover:text-foreground flex items-center gap-1 no-underline">
                            Docs <DynamicIcon Name="ArrowRight" Class="h-3 w-3" />
                        </Lumeo.Link>
                    </Flex>
                </div>
            </BentoTile>

        </Bento>
    </Container>
</section>

<Separator Class="opacity-30" />


<!-- ======================= WHY LUMEO ======================= -->
<section class="py-20">
    <Container MaxWidth="6xl" Class="px-4">
        <BlurFade DelayMs="0">
            <Stack Gap="3" Class="text-center mb-12">
                <Badge Variant="Badge.BadgeVariant.Outline" Class="mx-auto w-fit">Built-in</Badge>
                <Heading Level="2" Class="text-3xl sm:text-4xl font-bold tracking-tight">Everything you'd otherwise build.</Heading>
                <Lumeo.Text Color="muted" Class="max-w-xl mx-auto">
                    A complete kit for modern Blazor apps — batteries included, DX-obsessed.
                </Lumeo.Text>
            </Stack>
        </BlurFade>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            @for (var i = 0; i < _features.Length; i++)
            {
                var f = _features[i];
                var delay = 40 * i;
                <BlurFade DelayMs="@delay">
                    <Stack Gap="3" Class="group h-full rounded-xl border border-border/40 bg-card p-5 hover:border-primary/50 hover:-translate-y-0.5 hover:shadow-sm transition-all duration-200">
                        <Flex Align="center" Justify="center" Class="h-9 w-9 rounded-md bg-accent/40 text-primary shrink-0 group-hover:bg-primary/15 transition-colors">
                            <DynamicIcon Name="@f.Icon" Class="h-5 w-5" />
                        </Flex>
                        <Heading Level="3" Class="text-base font-semibold">@f.Title</Heading>
                        <Lumeo.Text Size="sm" Color="muted" Class="leading-relaxed flex-1">@f.Body</Lumeo.Text>
                    </Stack>
                </BlurFade>
            }
        </div>
    </Container>
</section>

<Separator Class="opacity-30" />


