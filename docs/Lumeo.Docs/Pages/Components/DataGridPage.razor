                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">SelectedItems</td><td class="px-4 py-2 font-mono text-xs">IReadOnlyList&lt;TItem&gt;?</td><td class="px-4 py-2 text-xs">--</td><td class="px-4 py-2 text-muted-foreground">Two-way bindable selected items collection.</td></tr>
