@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Default OTP Input" Code="@_codeOtpDefault">
    <Stack Align="center" Gap="3">
        <Lumeo.Text Size="sm" Color="muted">Enter the 6-digit code sent to your email</Lumeo.Text>
        <OtpInput @bind-Value="_otpValue" Length="6" />
    </Stack>
</PatternCard>
</Stack>

@code {
    private string _otpValue = "";

    private string _codeOtpDefault = @"<OtpInput @bind-Value=""_otp"" Length=""6"" />";

    // FileUpload
    private string _codeFileUploadDefault = @"<FileUpload Description=""PNG, JPG up to 10MB"" />";
}
