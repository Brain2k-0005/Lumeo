@page "/counter"

<PageTitle>Counter — MyApp</PageTitle>

@* The counter you know from the standard Blazor template — rebuilt with Lumeo.
   Vanilla → Lumeo mapping:
     private int currentCount = 0;              →  same field, unchanged
     <button class="btn btn-primary">           →  <Button OnClick="Increment">
     <p role="status">Current count: @count</p>  →  a live <Badge> + a big number
   The step <Select> is the one net-new affordance — the logic underneath is
   identical to the classic sample. *@

<Stack Gap="6">
    <Stack Gap="1">
        <Heading Level="1" Size="2xl">Counter</Heading>
        <Lumeo.Text Color="muted">
            The classic Blazor counter, rebuilt with Lumeo components — a
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Button</code>,
            a <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Badge</code>, and a
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono">Select</code> over the same state.
        </Lumeo.Text>
    </Stack>

    <Container MaxWidth="md" Padding="0" Center="false">
        <Card>
            <CardHeader>
                <Flex Align="center" Justify="between" Gap="3">
                    <Stack Gap="1">
                        <CardTitle>Current count</CardTitle>
                        <CardDescription>Increments by the selected step.</CardDescription>
                    </Stack>
                    <Badge Variant="Badge.BadgeVariant.Secondary" Class="tabular-nums px-3 py-1 text-base">@_count</Badge>
                </Flex>
            </CardHeader>
            <CardContent>
                <Stack Gap="4">
                    <div class="flex items-center justify-center rounded-xl border border-border/50 bg-muted/30 py-10">
                        <span class="text-6xl font-bold tabular-nums tracking-tight text-foreground">@_count</span>
                    </div>
                    <FormField Label="Increment step">
                        <Select @bind-Value="_step">
                            <SelectTrigger><span>@_step</span></SelectTrigger>
                            <SelectContent>
                                <SelectItem Value="1">1</SelectItem>
                                <SelectItem Value="5">5</SelectItem>
                                <SelectItem Value="10">10</SelectItem>
                            </SelectContent>
                        </Select>
                    </FormField>
                </Stack>
            </CardContent>
            <CardFooter>
                <Flex Gap="2" Class="w-full">
                    <Button OnClick="Increment">
                        <SvgGlyph Svg="@(LumeoIcons.Plus)" class="mr-2 h-4 w-4" /> Increment
                    </Button>
                    <Button Variant="Button.ButtonVariant.Outline" OnClick="Decrement">
                        <SvgGlyph Svg="@(LumeoIcons.Minus)" class="mr-2 h-4 w-4" /> Decrement
                    </Button>
                    <div class="flex-1"></div>
                    <Button Variant="Button.ButtonVariant.Ghost" OnClick="Reset">
                        <SvgGlyph Svg="@(LumeoIcons.RotateCcw)" class="mr-2 h-4 w-4" /> Reset
                    </Button>
                </Flex>
            </CardFooter>
        </Card>
    </Container>
</Stack>

@code {
    private int _count;
    private string _step = "1";

    private int Step => int.TryParse(_step, out var s) ? s : 1;

    private void Increment() => _count += Step;
    private void Decrement() => _count -= Step;
    private void Reset() => _count = 0;
}
