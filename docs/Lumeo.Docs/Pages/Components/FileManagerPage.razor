                new FileSystemNode { Id = "e-thumb", Name = "thumb.png",  IsFolder = false, Size = 153_600,   Modified = new DateTime(2024, 2, 14) }
            ]
        },
        new FileSystemNode { Id = "e-readme", Name = "README.md", IsFolder = false, Size = 1_024 }
    ];

    // ── Operation handlers ────────────────────────────────────────────────────

    private void HandleRename((FileSystemNode Node, string NewName) args)
    {
        var node = FindNode(_editableTree, args.Node.Id);
        if (node is not null)
        {
            node.Name = args.NewName;
            _statusMessage = $"Renamed to: {args.NewName}";
            StateHasChanged();
        }
    }

    private void HandleDelete(IReadOnlyList<FileSystemNode> nodes)
    {
        foreach (var node in nodes)
            RemoveNode(_editableTree, node.Id);

        _statusMessage = $"Deleted: {string.Join(", ", nodes.Select(n => n.Name))}";
        StateHasChanged();
    }

    private void HandleNewFolder(FileSystemNode parentFolder)
    {
        var newFolder = new FileSystemNode
        {
            Id = $"new-folder-{Guid.NewGuid():N}",
            Name = "New Folder",
            IsFolder = true,
            Children = []
        };

        if (string.IsNullOrEmpty(parentFolder.Id))
        {
            _editableTree.Add(newFolder);
        }
        else
        {
            var parent = FindNode(_editableTree, parentFolder.Id);
            if (parent is not null)
            {
                parent.Children ??= [];
                parent.Children.Add(newFolder);
            }
        }

        _statusMessage = $"Created folder in: {(string.IsNullOrEmpty(parentFolder.Id) ? "root" : parentFolder.Name)}";
        StateHasChanged();
    }

    private static FileSystemNode? FindNode(List<FileSystemNode> nodes, string id)
    {
        foreach (var n in nodes)
        {
            if (n.Id == id) return n;
            if (n.Children is { Count: > 0 })
            {
                var found = FindNode(n.Children, id);
                if (found is not null) return found;
            }
        }
        return null;
    }

    private static bool RemoveNode(List<FileSystemNode> nodes, string id)
    {
        for (int i = 0; i < nodes.Count; i++)
        {
            if (nodes[i].Id == id)
            {
                nodes.RemoveAt(i);
                return true;
            }
            if (nodes[i].Children is { Count: > 0 } children && RemoveNode(children, id))
                return true;
        }
        return false;
    }

    private static string FormatSizeStatic(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        if (bytes < 1024L * 1024 * 1024) return $"{bytes / (1024.0 * 1024):F1} MB";
        return $"{bytes / (1024.0 * 1024 * 1024):F1} GB";
    }

