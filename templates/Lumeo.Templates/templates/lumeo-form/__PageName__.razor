@page "/__PageRoute__"

<PageTitle>__ModelName__</PageTitle>

@*
    Lumeo form scaffold.

    The form below is generated at build time from __ModelName__Model by the
    [LumeoForm] source generator: RenderForm() returns a ready-to-use
    RenderFragment that renders a Lumeo <Form> wired to the built-in
    DataAnnotationsFormValidator. Submitting with invalid input shows the
    DataAnnotations errors under each field automatically; OnValidSubmit only
    fires once every field passes. No hand-written FormField markup required.

    Prefer to lay the fields out yourself? Delete the model's [LumeoForm]
    attribute and compose <Form> + <FormField Name="..."> by hand — see
    https://lumeo.nativ.sh/docs/form-validation.
*@

<Container MaxWidth="lg">
    <Stack Gap="6" Class="py-8">
        <Stack Gap="2">
            <Heading Level="1" Size="3xl">__ModelName__</Heading>
            <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
                A starter form scaffolded with Lumeo's [LumeoForm] generator. Submit
                with empty fields to see live validation.
            </Lumeo.Text>
        </Stack>

        <Card>
            <CardContent Class="pt-6">
                @__ModelName__Model.RenderForm(
                    _model,
                    EventCallback.Factory.Create<__ModelName__Model>(this, OnValidSubmit))

                @if (_submitted)
                {
                    <Alert Variant="Alert.AlertVariant.Success" Class="mt-4">
                        Thanks, @_model.Name — your __ModelName__ was submitted.
                    </Alert>
                }
            </CardContent>
        </Card>
    </Stack>
</Container>

@code {
    private readonly __ModelName__Model _model = new();
    private bool _submitted;

    private void OnValidSubmit(__ModelName__Model model)
    {
        // TODO: send `model` to your API / service. It's already validated here.
        _submitted = true;
        StateHasChanged();
    }
}
