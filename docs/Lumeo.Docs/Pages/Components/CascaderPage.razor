@page "/components/cascader"

<PageTitle>Cascader — Lumeo</PageTitle>

<PageHeader Title="Cascader" Description="A multi-level dropdown for selecting hierarchical data like categories or locations." />

<InstallUsage Component="Cascader" />

<div class="mt-10 space-y-3">
    <Heading Id="when-to-use" Level="2" Class="scroll-mt-20">When to Use</Heading>
    <ul class="list-disc list-inside space-y-1 text-muted-foreground text-sm">
        <li>Hierarchical selection like country, state, and city pickers</li>
        <li>Category drill-down for product catalogs or file systems</li>
        <li>Location pickers with multi-level geography data</li>
        <li>Any nested data structure where users select a path from root to leaf</li>
    </ul>
</div>

<Stack Gap="8" Class="mt-8">
    <ComponentDemo Title="Basic Cascader" Code="@_basicCode">
        <Cascader Options="@_options" Placeholder="Select location..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Clearable" Code="@_clearableCode">
        <Cascader Options="@_options" Clearable="true" Placeholder="Select..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Disabled" Code="@_disabledCode">
        <Cascader Options="@_options" Disabled="true" Placeholder="Disabled" Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Searchable (ShowSearch)">
        <Cascader Options="@_options" ShowSearch="true" Placeholder="Search locations..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="With Label & Helper Text">
        <Cascader Options="@_options" Label="Region" HelperText="Pick a country, then a state." Placeholder="Select..." Class="max-w-sm" />
    </ComponentDemo>

    <ComponentDemo Title="Invalid with Error Text">
        <Cascader Options="@_options" Invalid="true" ErrorText="Please choose a location." Placeholder="Select..." Class="max-w-sm" />
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8" Class="mt-8">
        <Stack Gap="3">
            <Heading Level="3">Cascader</Heading>
            <Lumeo.Text Size="sm" Color="muted">Nested inside a FormField, the cascaded context wires up Label, Required, Invalid, and HelperText automatically — the same-named parameters below only apply when the Cascader is used standalone.</Lumeo.Text>
            <PropsTable Slug="cascader" />
        </Stack>
    </Stack>
</Stack>

<div class="mt-12">
    <Heading Id="related" Level="2" Class="scroll-mt-20">Related Components</Heading>
    <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/components/select" class="text-primary hover:underline">Select</a> — Single-level dropdown for flat option lists</li>
        <li><a href="/components/combobox" class="text-primary hover:underline">Combobox</a> — Searchable dropdown for flat option lists with filtering</li>
        <li><a href="/components/breadcrumb" class="text-primary hover:underline">Breadcrumb</a> — Display the selected hierarchical path as a breadcrumb trail</li>
    </ul>
</div>

@code {
    private List<Cascader.CascaderOption> _options = new()
    {
        new()
        {
            Label = "North America", Value = "na",
            Children = new()
            {
                new()
                {
                    Label = "United States", Value = "us",
                    Children = new()
                    {
                        new() { Label = "California", Value = "ca" },
                        new() { Label = "New York", Value = "ny" },
                        new() { Label = "Texas", Value = "tx" },
                    }
                },
                new()
                {
                    Label = "Canada", Value = "can",
                    Children = new()
                    {
                        new() { Label = "Ontario", Value = "on" },
                        new() { Label = "British Columbia", Value = "bc" },
                    }
                },
            }
        },
        new()
        {
            Label = "Europe", Value = "eu",
            Children = new()
            {
                new() { Label = "United Kingdom", Value = "uk" },
                new() { Label = "Germany", Value = "de" },
                new() { Label = "France", Value = "fr" },
            }
        },
    };

    private string _basicCode = @"<Cascader Options=""@_options"" Placeholder=""Select location..."" />";
    private string _clearableCode = @"<Cascader Options=""@_options"" Clearable=""true"" />";
    private string _disabledCode = @"<Cascader Options=""@_options"" Disabled=""true"" />";
}
