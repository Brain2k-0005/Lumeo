@page "/docs/registry"
@namespace Lumeo.Docs.Pages.Docs
@using System.Text.Json
@using System.Text.Json.Serialization
@inject HttpClient Http

<PageTitle>Component Registry — Lumeo</PageTitle>

<Container MaxWidth="5xl" Padding="0" Center="false">
<Stack Gap="10">

    <!-- Header -->
    <Stack Gap="4">
        <Heading Level="1" Size="3xl">Component Registry</Heading>
        <Lumeo.Text Size="base" Color="muted" Leading="relaxed">
            Every Lumeo component is indexed in a machine-readable registry —
            the same file the
            <Lumeo.Link Href="docs/cli" Class="text-foreground underline underline-offset-4 hover:text-muted-foreground transition-colors">CLI</Lumeo.Link>,
            the
            <Lumeo.Link Href="docs/mcp" Class="text-foreground underline underline-offset-4 hover:text-muted-foreground transition-colors">MCP server</Lumeo.Link>,
            and third-party tooling consume. Browse the catalog, filter by category, and inspect each
            component's files, dependencies, and CSS variables.
        </Lumeo.Text>
        <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">
            Source:
            <Lumeo.Link Href="https://github.com/Brain2k-0005/Lumeo/blob/master/src/Lumeo/registry/registry.json"
                        Class="text-foreground underline underline-offset-4 hover:text-muted-foreground transition-colors">
                src/Lumeo/registry/registry.json
            </Lumeo.Link>
            — generated by
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">tools/Lumeo.RegistryGen</code>.
            Served to the docs site at
            <code class="rounded bg-muted px-1.5 py-0.5 text-xs font-mono text-foreground">/_content/Lumeo/registry/registry.json</code>.
        </Lumeo.Text>
    </Stack>

    <Separator Class="my-2" />

    @if (_loadError != null)
    {
        <Alert Variant="Alert.AlertVariant.Destructive">
            <Stack Gap="1">
                <Heading Level="4" Class="text-sm">Couldn't load the registry</Heading>
                <Lumeo.Text Size="sm">@_loadError</Lumeo.Text>
            </Stack>
        </Alert>
    }
    else if (_document == null)
    {
        <Stack Gap="3">
            <Skeleton Class="h-10 w-full" />
            <Skeleton Class="h-24 w-full" />
            <Skeleton Class="h-24 w-full" />
            <Skeleton Class="h-24 w-full" />
        </Stack>
    }
    else
    {
        <!-- Filter bar -->
        <div class="grid grid-cols-1 md:grid-cols-[1fr_14rem] gap-3">
            <Input Value="@_query"
                   ValueChanged="OnQueryChanged"
                   Placeholder="Filter components by name, description, file…" />
            <Select @bind-Value="_category">
                <SelectTrigger>
                    <Lumeo.Text As="span">
                        @(string.IsNullOrEmpty(_category) ? "All categories" : _category)
                    </Lumeo.Text>
                </SelectTrigger>
                <SelectContent>
                    <SelectItem Value="">All categories</SelectItem>
                    @foreach (var cat in _categories)
                    {
                        <SelectItem Value="@cat">@cat</SelectItem>
                    }
                </SelectContent>
            </Select>
        </div>

        <!-- Stats row -->
        <Flex Wrap="true" Gap="2">
            <Badge Variant="Badge.BadgeVariant.Secondary">
                @_document.Components.Count total
            </Badge>
            @foreach (var cat in _categories)
            {
                var count = _document.Components.Count(c => c.Category == cat);
                <Badge Variant="Badge.BadgeVariant.Outline">@cat · @count</Badge>
            }
        </Flex>

        <!-- Results count -->
        <Lumeo.Text Size="sm" Color="muted">
            Showing <Lumeo.Text As="span" Weight="medium" Class="text-foreground">@_filtered.Count</Lumeo.Text>
            of <Lumeo.Text As="span" Weight="medium" Class="text-foreground">@_document.Components.Count</Lumeo.Text>
            components.
        </Lumeo.Text>

        <!-- Grid of cards -->
        @if (_filtered.Count == 0)
        {
            <Card>
                <CardContent Class="py-10 text-center">
                    <Lumeo.Text Color="muted">No components match that filter.</Lumeo.Text>
                </CardContent>
            </Card>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                @foreach (var entry in _filtered)
                {
                    <Card Class="h-full">
                        <CardHeader>
                            <Flex Justify="between" Align="start" Gap="3">
                                <NavLink href="@($"components/{entry.Slug}")"
                                         class="text-base font-semibold text-foreground hover:text-muted-foreground transition-colors no-underline">
                                    @entry.Name
                                </NavLink>
                                <Badge Variant="Badge.BadgeVariant.Secondary" Class="shrink-0">@entry.Category</Badge>
                            </Flex>
                        </CardHeader>
                        <CardContent>
                            <Stack Gap="3">
                                <Lumeo.Text Size="sm" Color="muted" Leading="relaxed">@entry.Description</Lumeo.Text>

                                <!-- Files (collapsible) -->
                                <details class="group rounded-md border border-border/60 bg-muted/30 open:bg-muted/50 transition-colors">
                                    <summary class="flex cursor-pointer items-center justify-between px-3 py-2 text-xs font-medium text-muted-foreground group-open:text-foreground">
                                        <span>@entry.Files.Count file@(entry.Files.Count == 1 ? "" : "s")</span>
                                        <Blazicon Svg="Lucide.ChevronDown" class="h-3.5 w-3.5 transition-transform group-open:rotate-180" />
                                    </summary>
                                    <ul class="px-3 pb-3 pt-1 space-y-1 text-xs font-mono text-muted-foreground">
                                        @foreach (var file in entry.Files)
                                        {
                                            <li class="truncate" title="@file">@file</li>
                                        }
                                    </ul>
                                </details>

                                <!-- Dependencies -->
                                @if (entry.Dependencies.Count > 0)
                                {
                                    <Stack Gap="1">
                                        <Lumeo.Text Size="xs" Color="muted" Weight="medium" Class="uppercase tracking-wide">Dependencies</Lumeo.Text>
                                        <Flex Wrap="true" Gap="1">
                                            @foreach (var dep in entry.Dependencies)
                                            {
                                                <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px]">@dep</Badge>
                                            }
                                        </Flex>
                                    </Stack>
                                }

                                <!-- CSS vars count -->
                                @if (entry.CssVars.Count > 0)
                                {
                                    <div title="@string.Join('\n', entry.CssVars)">
                                        <Badge Variant="Badge.BadgeVariant.Outline" Class="text-[10px]">
                                            @entry.CssVars.Count CSS var@(entry.CssVars.Count == 1 ? "" : "s")
                                        </Badge>
                                    </div>
                                }
                            </Stack>
                        </CardContent>
                    </Card>
                }
            </div>
        }

        <Lumeo.Text Size="xs" Color="muted" Class="mt-4">
            Registry v@_document.Version · generated @_document.Generated
        </Lumeo.Text>
    }

</Stack>
</Container>

@code {
    private RegistryDocument? _document;
    private string? _loadError;
    private string _query = "";
    private string? _category = "";
    private List<string> _categories = new();
    private List<RegistryEntry> _filtered = new();
    private System.Threading.Timer? _debounce;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _document = await Http.GetFromJsonAsync<RegistryDocument>(
                "_content/Lumeo/registry/registry.json",
                new JsonSerializerOptions(JsonSerializerDefaults.Web)
                {
                    Converters = { new RegistryComponentsConverter() }
                });

            if (_document != null)
            {
                _categories = _document.Components
                    .Select(c => c.Category)
                    .Distinct()
                    .OrderBy(c => c)
                    .ToList();
                ApplyFilter();
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
    }

    protected override void OnParametersSet()
    {
        if (_document != null)
        {
            ApplyFilter();
        }
    }

    private void OnQueryChanged(string? value)
    {
        _query = value ?? "";
        _debounce?.Dispose();
        _debounce = new System.Threading.Timer(_ =>
        {
            _ = InvokeAsync(() =>
            {
                ApplyFilter();
                StateHasChanged();
            });
        }, null, 120, System.Threading.Timeout.Infinite);
    }

    private void ApplyFilter()
    {
        if (_document == null)
        {
            _filtered = new List<RegistryEntry>();
            return;
        }

        IEnumerable<RegistryEntry> pool = _document.Components;

        if (!string.IsNullOrEmpty(_category))
        {
            pool = pool.Where(c => string.Equals(c.Category, _category, StringComparison.OrdinalIgnoreCase));
        }

        var q = _query?.Trim() ?? "";
        if (!string.IsNullOrEmpty(q))
        {
            pool = pool.Where(c =>
                c.Name.Contains(q, StringComparison.OrdinalIgnoreCase)
                || c.Slug.Contains(q, StringComparison.OrdinalIgnoreCase)
                || c.Description.Contains(q, StringComparison.OrdinalIgnoreCase)
                || c.Category.Contains(q, StringComparison.OrdinalIgnoreCase)
                || c.Files.Any(f => f.Contains(q, StringComparison.OrdinalIgnoreCase)));
        }

        _filtered = pool
            .OrderBy(c => c.Name, StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

    public void Dispose()
    {
        _debounce?.Dispose();
    }

    // ── Model + JSON shape ─────────────────────────────────────────────
    // registry.json's `components` is a map { "<slug>": { … } } rather
    // than an array, so we use a custom converter that flattens it into
    // a List<RegistryEntry> with the slug preserved on each entry.

    public sealed class RegistryDocument
    {
        public string Version { get; set; } = "";
        public string Generated { get; set; } = "";
        [JsonConverter(typeof(RegistryComponentsConverter))]
        public List<RegistryEntry> Components { get; set; } = new();
    }

    public sealed class RegistryEntry
    {
        public string Slug { get; set; } = "";
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public string Description { get; set; } = "";
        public List<string> Files { get; set; } = new();
        public List<string> Dependencies { get; set; } = new();
        public List<string> CssVars { get; set; } = new();
        public string? RegistryUrl { get; set; }
    }

    private sealed class RegistryComponentsConverter : JsonConverter<List<RegistryEntry>>
    {
        public override List<RegistryEntry> Read(ref Utf8JsonReader reader, Type typeToConvert, JsonSerializerOptions options)
        {
            var result = new List<RegistryEntry>();
            if (reader.TokenType != JsonTokenType.StartObject) return result;
            while (reader.Read() && reader.TokenType != JsonTokenType.EndObject)
            {
                if (reader.TokenType != JsonTokenType.PropertyName) continue;
                var slug = reader.GetString() ?? "";
                reader.Read();
                using var doc = JsonDocument.ParseValue(ref reader);
                var el = doc.RootElement;

                var entry = new RegistryEntry
                {
                    Slug = slug,
                    Name = el.TryGetProperty("name", out var n) ? n.GetString() ?? slug : slug,
                    Category = el.TryGetProperty("category", out var c) ? c.GetString() ?? "" : "",
                    Description = el.TryGetProperty("description", out var d) ? d.GetString() ?? "" : "",
                    RegistryUrl = el.TryGetProperty("registryUrl", out var ru) ? ru.GetString() : null,
                };
                if (el.TryGetProperty("files", out var files) && files.ValueKind == JsonValueKind.Array)
                    entry.Files = files.EnumerateArray().Select(x => x.GetString() ?? "").Where(s => s.Length > 0).ToList();
                if (el.TryGetProperty("dependencies", out var deps) && deps.ValueKind == JsonValueKind.Array)
                    entry.Dependencies = deps.EnumerateArray().Select(x => x.GetString() ?? "").Where(s => s.Length > 0).ToList();
                if (el.TryGetProperty("cssVars", out var vars) && vars.ValueKind == JsonValueKind.Array)
                    entry.CssVars = vars.EnumerateArray().Select(x => x.GetString() ?? "").Where(s => s.Length > 0).ToList();

                result.Add(entry);
            }
            return result;
        }

        public override void Write(Utf8JsonWriter writer, List<RegistryEntry> value, JsonSerializerOptions options)
        {
            // Not needed — we only read the registry.
            writer.WriteStartObject();
            writer.WriteEndObject();
        }
    }
}
