@namespace Lumeo
@implements IAsyncDisposable
@inject ComponentInteropService Interop

<CascadingValue Value="_context" IsFixed="true">
    <div id="@_mapId"
         role="application"
         aria-label="Map"
         class="@RootClass"
         style="@RootStyle"
         @attributes="AdditionalAttributes">
        @if (Overlay is not null)
        {
            @* Overlay slot — renders inside the map container so it floats above
               the canvas. Position it with absolute Tailwind classes on the child. *@
            <div class="absolute inset-0 pointer-events-none z-10" style="position:absolute;inset:0;pointer-events:none;z-index:10;">
                @Overlay
            </div>
        }
    </div>
    @* Markers + shapes register via the cascading context but do not render
       DOM themselves — Leaflet draws them on the canvas. We still walk the
       child content so the OnInitialized / OnParametersSet hooks fire. *@
    <div style="display:none">
        @ChildContent
    </div>
</CascadingValue>

@code {
    [Parameter] public (double Lat, double Lon) Center { get; set; } = (51.0, 10.4);
    [Parameter] public EventCallback<(double Lat, double Lon)> CenterChanged { get; set; }

    [Parameter] public int Zoom { get; set; } = 5;
    [Parameter] public EventCallback<int> ZoomChanged { get; set; }

    [Parameter] public string Height { get; set; } = "400px";

    /// <summary>Accepts a CARTO style preset (<c>Positron</c>, <c>DarkMatter</c>,
    /// <c>Voyager</c>), a legacy raster name (<c>OpenStreetMap</c>,
    /// <c>CartoLight</c>, <c>CartoDark</c>, <c>Satellite</c>, <c>Terrain</c>) —
    /// kept as aliases pointing at the closest GL vector style — or a raw
    /// MapLibre <c>style.json</c> URL. <c>Auto</c> (the default) picks Positron
    /// or DarkMatter based on the host page's theme, matching mapcn.dev.</summary>
    [Parameter] public string TileLayer { get; set; } = "Auto";

    /// <summary>When set, renders a chip-style switcher in the top-right that
    /// lets the user pick between presets (or custom <c>{ name, url }</c> records).</summary>
    [Parameter] public string[]? Layers { get; set; }

    [Parameter] public bool ZoomControl { get; set; } = true;
    [Parameter] public bool Attribution { get; set; } = true;
    [Parameter] public bool ScrollWheelZoom { get; set; } = true;

    /// <summary>Marker clustering via leaflet.markercluster. CDN-loaded on
    /// first use; falls back to plain markers if the script fails to fetch.</summary>
    [Parameter] public bool Cluster { get; set; }

    /// <summary>Adds a "My location" button that geolocates the user.</summary>
    [Parameter] public bool Geolocate { get; set; }

    /// <summary>Adds a fullscreen toggle button.</summary>
    [Parameter] public bool Fullscreen { get; set; }

    /// <summary>Adds a metric scale bar in the bottom-left corner.</summary>
    [Parameter] public bool Scale { get; set; }

    /// <summary>Adds a Nominatim-backed search bar in the top-left.</summary>
    [Parameter] public bool Search { get; set; }

    /// <summary>MapLibre projection name. <c>"mercator"</c> (default flat web-map)
    /// or <c>"globe"</c> for a 3-D spherical view. The globe becomes visible at
    /// zoom levels roughly 0–3; it blends back to mercator above zoom 4.</summary>
    [Parameter] public string Projection { get; set; } = "mercator";

    /// <summary>When <c>true</c> the map automatically fits its viewport to include
    /// all registered markers and shapes after the first render.</summary>
    [Parameter] public bool AutoFitBounds { get; set; }

    [Parameter] public RenderFragment? ChildContent { get; set; }

    /// <summary>Optional content rendered as an absolutely-positioned overlay
    /// <em>inside</em> the map container (z-index 10, pointer-events none on the
    /// wrapper so map interaction is not blocked). Use absolute-position classes
    /// on your own child element to place chips, legends, or status badges
    /// (e.g. <c>class="absolute bottom-2 right-2 pointer-events-auto …"</c>).</summary>
    [Parameter] public RenderFragment? Overlay { get; set; }

    [Parameter] public EventCallback<(double Lat, double Lon)> OnClick { get; set; }

    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _mapId = $"lumeo-map-{Guid.NewGuid():N}";
    private IJSObjectReference? _module;
    private DotNetObjectReference<Map>? _selfRef;
    private MapContext _context = null!;
    private readonly List<MapMarker> _markers = new();
    // Stable-id -> marker lookup, rebuilt on every SyncMarkersAsync so an
    // in-flight click/drag from JS routes to the marker JS actually drew,
    // even after an async remove shifts the positional order of _markers.
    private readonly Dictionary<string, MapMarker> _markersById = new();
    private readonly Dictionary<object, MapShape> _shapes = new();
    private readonly List<MapPopup> _standalonePopups = new();
    private bool _initialized;
    // Live view echoed back from JS (user pan/zoom). NOT the parameter.
    private (double Lat, double Lon) _lastCenter;
    private int _lastZoom;
    // Last *parameter* value the consumer actually supplied. We push setCenter to
    // the live map only when THIS changes — never when the live view (_lastCenter,
    // mutated by OnViewChanged) drifts from a re-pushed same-literal Center param.
    // Without this, an unrelated parent re-render that re-passes the original Center
    // overwrites the panned [Parameter] back to the literal, and the else-branch
    // below sees Center != _lastCenter and snaps the user's pan back to the start.
    private (double Lat, double Lon) _lastCenterParam;
    private int _lastZoomParam;
    private string _lastMarkerJson = "[]";
    private string _lastShapeJson = "[]";
    private string _lastPopupJson = "[]";

    private string RootClass => $"lumeo-map relative {Class}".Trim();
    private string RootStyle => $"width: 100%; height: {Height};";

    protected override void OnInitialized()
    {
        _context = new MapContext(this);
        _lastCenter = Center;
        _lastZoom = Zoom;
        _lastCenterParam = Center;
        _lastZoomParam = Zoom;
    }

    internal void RegisterMarker(MapMarker marker)
    {
        if (!_markers.Contains(marker)) _markers.Add(marker);
        if (_initialized) _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void UnregisterMarker(MapMarker marker)
    {
        if (_markers.Remove(marker) && _initialized)
            _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void NotifyMarkerChanged(MapMarker marker)
    {
        if (_initialized) _ = InvokeAsync(SyncMarkersAsync);
    }

    internal void RegisterShape(object owner, MapShape shape)
    {
        _shapes[owner] = shape;
        if (_initialized) _ = InvokeAsync(SyncShapesAsync);
    }

    internal void UnregisterShape(object owner)
    {
        if (_shapes.Remove(owner) && _initialized)
            _ = InvokeAsync(SyncShapesAsync);
    }

    internal void RegisterStandalonePopup(MapPopup popup)
    {
        if (!_standalonePopups.Contains(popup)) _standalonePopups.Add(popup);
        if (_initialized) _ = InvokeAsync(SyncStandalonePopupsAsync);
    }

    internal void UnregisterStandalonePopup(MapPopup popup)
    {
        if (_standalonePopups.Remove(popup) && _initialized)
            _ = InvokeAsync(SyncStandalonePopupsAsync);
    }

    internal void NotifyStandalonePopupChanged(MapPopup popup)
    {
        if (_initialized) _ = InvokeAsync(SyncStandalonePopupsAsync);
    }

    internal void NotifyShapeChanged(object owner, MapShape shape)
    {
        _shapes[owner] = shape;
        if (_initialized) _ = InvokeAsync(SyncShapesAsync);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await Interop.ImportModuleAsync("./_content/Lumeo.Maps/js/map.js");
            _selfRef = DotNetObjectReference.Create(this);

            var options = new
            {
                lat = Center.Lat,
                lon = Center.Lon,
                zoom = Zoom,
                tileLayer = TileLayer,
                layers = Layers,
                zoomControl = ZoomControl,
                attribution = Attribution,
                scrollWheelZoom = ScrollWheelZoom,
                cluster = Cluster,
                geolocate = Geolocate,
                fullscreen = Fullscreen,
                scale = Scale,
                search = Search,
                projection = Projection,
                autoFitBounds = AutoFitBounds,
            };

            try
            {
                await _module.InvokeVoidAsync("init", _mapId, options, _selfRef);
                _initialized = true;
                await SyncMarkersAsync();
                await SyncShapesAsync();
                await SyncStandalonePopupsAsync();
            }
            catch (JSDisconnectedException) { }
            catch (Exception ex)
            {
                // Without this branch, a non-disconnect failure inside init
                // (module load error, Leaflet runtime exception, misconfigured
                // tile layer) propagated out of OnAfterRender and Blazor
                // logged it once, but _initialized stayed false forever —
                // every subsequent render skipped the init branch
                // (firstRender is true exactly once), so the component
                // became permanently inert with no visible error. Surface
                // the failure on Console.Error so consumers can see what
                // broke during dev instead of staring at a silent dead map.
                Console.Error.WriteLine($"[Lumeo Map] init failed: {ex.Message}");
            }
            return;
        }

        if (!_initialized || _module is null) return;

        // Only push setCenter when the CONSUMER changed the Center/Zoom parameter —
        // i.e. the incoming param differs from the last param we applied. Comparing
        // against the live view (_lastCenter, mutated by OnViewChanged) would snap a
        // user-panned map back to the original literal on every unrelated re-render.
        if (Center != _lastCenterParam || Zoom != _lastZoomParam)
        {
            _lastCenterParam = Center;
            _lastZoomParam = Zoom;
            _lastCenter = Center;
            _lastZoom = Zoom;
            try
            {
                await _module.InvokeVoidAsync("setCenter", _mapId, Center.Lat, Center.Lon, Zoom);
            }
            catch (JSDisconnectedException) { }
        }
    }

    private async Task SyncMarkersAsync()
    {
        if (_module is null || !_initialized) return;
        // Rebuild the id->marker routing table to exactly match the set we are
        // about to hand JS, so OnMarkerClick/OnMarkerDragEnd resolve by stable
        // id rather than a positional index that shifts when a marker is removed.
        _markersById.Clear();
        foreach (var m in _markers) _markersById[m.MarkerId] = m;
        var payload = _markers.Select(m => new
        {
            id = m.MarkerId,
            lat = m.Lat,
            lon = m.Lon,
            title = m.Title,
            iconUrl = m.IconUrl,
            variant = m.Variant,
            color = m.Color,
            highlighted = m.Highlighted,
            label = m.Label,
            labelHoverOnly = m.LabelHoverOnly,
            iconHostId = m.HasIcon ? m.IconHostId : null,
            popupHtml = m.HasRichPopup ? null : m.GetPopupHtml(),
            popupHostId = m.HasRichPopup ? m.PopupHostId : null,
            hasClick = m.OnClick.HasDelegate,
            draggable = m.Draggable,
            hasDragEnd = m.OnDragEnd.HasDelegate,
        }).ToArray();

        var json = System.Text.Json.JsonSerializer.Serialize(payload);
        if (json == _lastMarkerJson) return;
        _lastMarkerJson = json;

        try
        {
            await _module.InvokeVoidAsync("setMarkers", _mapId, payload);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task SyncStandalonePopupsAsync()
    {
        if (_module is null || !_initialized) return;
        var payload = _standalonePopups.Select(p => new
        {
            id = p.PopupId,
            lat = p.Lat,
            lon = p.Lon,
            isOpen = p.IsOpen,
            closeButton = p.CloseButton,
            closeOnClick = p.CloseOnClick,
            html = p.GetHtml(),
            hostId = p.HasRichContent ? p.HostId : null,
            // Per-popup ref so JS can fire OnPopupClosed back to the right popup
            // when the user dismisses it; without this the two-way IsOpen binding
            // never updated and IsOpen desynced.
            dotNetRef = p.SelfRef,
        }).ToArray();
        // Diff key from serializable fields only — payload carries a per-popup
        // DotNetObjectReference (dotNetRef) that System.Text.Json has no converter
        // for; serializing it would walk the referenced component and throw,
        // aborting the sync before setStandalonePopups runs.
        var json = System.Text.Json.JsonSerializer.Serialize(
            payload.Select(p => new { p.id, p.lat, p.lon, p.isOpen, p.closeButton, p.closeOnClick, p.html, p.hostId }).ToArray());
        if (json == _lastPopupJson) return;
        _lastPopupJson = json;
        try
        {
            await _module.InvokeVoidAsync("setStandalonePopups", _mapId, payload);
        }
        catch (JSDisconnectedException) { }
    }

    private async Task SyncShapesAsync()
    {
        if (_module is null || !_initialized) return;
        var payload = _shapes.Values.ToArray();
        var json = System.Text.Json.JsonSerializer.Serialize(payload);
        if (json == _lastShapeJson) return;
        _lastShapeJson = json;

        try
        {
            await _module.InvokeVoidAsync("setShapes", _mapId, payload);
        }
        catch (JSDisconnectedException) { }
    }

    /// <summary>Returns the current map view as a PNG data-URL string
    /// (<c>data:image/png;base64,…</c>) by reading the underlying MapLibre GL canvas.
    /// Returns <c>null</c> when the map is not yet initialized.</summary>
    public async Task<string?> ExportPngAsync()
    {
        if (_module is null || !_initialized) return null;
        try
        {
            return await _module.InvokeAsync<string?>("exportPng", _mapId);
        }
        catch (JSDisconnectedException) { return null; }
    }

    /// <summary>Imperatively re-center the map. Useful for parent components
    /// driving the view from non-parameter state (e.g. a "Fit to results" button).</summary>
    public async Task FitBoundsAsync(double south, double west, double north, double east, int paddingPx = 30)
    {
        if (_module is null || !_initialized) return;
        try
        {
            await _module.InvokeVoidAsync("fitBounds", _mapId, south, west, north, east, paddingPx);
        }
        catch (JSDisconnectedException) { }
    }

    [JSInvokable]
    public async Task OnMapClick(double lat, double lon)
    {
        if (OnClick.HasDelegate) await OnClick.InvokeAsync((lat, lon));
    }

    [JSInvokable]
    public async Task OnViewChanged(double lat, double lon, int zoom)
    {
        // Track the live view separately from the parameter. Only write the
        // [Parameter] when the consumer is controlling it (a *Changed callback is
        // bound) — otherwise we'd store uncontrolled view state in the parameter and
        // a parent re-render that re-passes the original literal would snap us back.
        var newCenter = (lat, lon);
        if (newCenter != _lastCenter)
        {
            _lastCenter = newCenter;
            if (CenterChanged.HasDelegate)
            {
                Center = newCenter;
                // Keep the param-baseline in step so the parent's echo of this very
                // value does not re-trigger a redundant setCenter push.
                _lastCenterParam = newCenter;
                await CenterChanged.InvokeAsync(newCenter);
            }
        }
        if (zoom != _lastZoom)
        {
            _lastZoom = zoom;
            if (ZoomChanged.HasDelegate)
            {
                Zoom = zoom;
                _lastZoomParam = zoom;
                await ZoomChanged.InvokeAsync(zoom);
            }
        }
    }

    [JSInvokable]
    public async Task OnMarkerClick(string markerId)
    {
        // Route by stable id: an in-flight click that arrives after the marker
        // was removed simply finds no entry and is ignored, instead of indexing
        // _markers positionally and firing the WRONG (reused-index) marker.
        if (!_markersById.TryGetValue(markerId, out var marker)) return;
        if (marker.OnClick.HasDelegate) await marker.OnClick.InvokeAsync();
    }

    [JSInvokable]
    public async Task OnMarkerDragEnd(string markerId, double lat, double lon)
    {
        if (!_markersById.TryGetValue(markerId, out var marker)) return;
        if (marker.OnDragEnd.HasDelegate) await marker.OnDragEnd.InvokeAsync((lat, lon));
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroy", _mapId);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException) { }
            catch (ObjectDisposedException) { }
        }
        _selfRef?.Dispose();
    }

    /// <summary>Cascading context passed to <see cref="MapMarker"/> + shape
    /// children so they can register themselves with the parent <see cref="Map"/>.</summary>
    public record MapContext(Map Owner);
}
