                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">OnRangeRequest</td><td class="px-4 py-2 font-mono text-xs">Func&lt;DataGridRangeRequest, ValueTask&lt;DataGridRangeResponse&lt;TItem&gt;&gt;&gt;?</td><td class="px-4 py-2 text-xs">--</td><td class="px-4 py-2 text-muted-foreground">Range-fetch callback for virtualised server mode. Receives <code>StartIndex</code>, <code>Count</code>, current Sort/Filter/Search context; must return the slice plus current <code>TotalCount</code>.</td></tr>
                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">ServerMode</td><td class="px-4 py-2 font-mono text-xs">bool</td><td class="px-4 py-2 text-xs">false</td><td class="px-4 py-2 text-muted-foreground">Enable server-side sorting, filtering, and pagination.</td></tr>
                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">TotalCount</td><td class="px-4 py-2 font-mono text-xs">int</td><td class="px-4 py-2 text-xs">0</td><td class="px-4 py-2 text-muted-foreground">Total item count for server-side pagination.</td></tr>
                        <tr><td class="px-4 py-2 font-mono text-xs text-primary">IsLoading</td><td class="px-4 py-2 font-mono text-xs">bool</td><td class="px-4 py-2 text-xs">false</td><td class="px-4 py-2 text-muted-foreground">Show loading skeleton overlay.</td></tr>
