@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic Image" Code="@_codeBasic">
    <Image Src="https://picsum.photos/seed/lumeo/300/200" Alt="Sample image" Width="300" Height="200" Class="rounded-lg" />
</PatternCard>

<PatternCard Label="With Preview" Code="@_codePreview">
    <Image Src="https://picsum.photos/seed/preview/300/200" Alt="Previewable image" Width="300" Height="200" Preview="true" Class="rounded-lg" />
</PatternCard>
</Stack>

@code {
    private string _codeBasic = @"<Image Src=""https://picsum.photos/300/200"" Alt=""Sample"" Width=""300"" Height=""200"" />";

    private string _codePreview = @"<Image Src=""photo.jpg"" Alt=""Photo"" Width=""300"" Height=""200"" Preview=""true"" />";
}
