@page "/components/charts/radial"

<PageTitle>Radial Chart — Lumeo</PageTitle>

<PageHeader Title="Radial Chart" Description="Display a single metric against a scale as a gauge arc. Perfect for KPIs, system health indicators, or progress toward a goal." />

<Stack Gap="8">
    <ComponentDemo Title="Performance Gauge" Code="@_basicCode">
        <Container>
            <RadialChart Value="72" Label="Performance" Color="#6366f1" ShowProgress="true" />
        </Container>
    </ComponentDemo>

    <ComponentDemo Title="Custom Range" Code="@_rangeCode">
        <Container>
            <RadialChart Value="42" Min="0" Max="50" Label="Score" Color="#10b981" ShowProgress="true" />
        </Container>
    </ComponentDemo>
</Stack>

<!-- API Reference -->
<Stack Gap="6" Class="mt-12">
    <Heading Level="2">API Reference</Heading>
    <Stack Gap="8">
        <div>
            <Heading Level="3" Class="mb-3">RadialChart</Heading>
            <div class="rounded-lg border border-border overflow-hidden">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b bg-muted/40">
                            <th class="text-left p-3 font-medium text-foreground">Property</th>
                            <th class="text-left p-3 font-medium text-foreground">Type</th>
                            <th class="text-left p-3 font-medium text-foreground">Default</th>
                            <th class="text-left p-3 font-medium text-foreground">Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border/40">
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Value</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">The current gauge value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Min</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">0</td>
                            <td class="p-3 text-muted-foreground">Minimum value of the scale.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Max</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">double</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">100</td>
                            <td class="p-3 text-muted-foreground">Maximum value of the scale.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Label</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Label text displayed below the value.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">Color</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">string?</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">null</td>
                            <td class="p-3 text-muted-foreground">Accent color for the gauge arc.</td>
                        </tr>
                        <tr>
                            <td class="p-3 font-mono text-xs text-primary">ShowProgress</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">bool</td>
                            <td class="p-3 font-mono text-xs text-muted-foreground">true</td>
                            <td class="p-3 text-muted-foreground">Renders the filled progress arc.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </Stack>
</Stack>

@code {
    private string _basicCode = @"<RadialChart Value=""72"" Label=""Performance"" Color=""#6366f1"" ShowProgress=""true"" />";
    private string _rangeCode = @"<RadialChart Value=""42"" Min=""0"" Max=""50"" Label=""Score"" Color=""#10b981"" ShowProgress=""true"" />";
}
