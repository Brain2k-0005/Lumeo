@page "/components"
@namespace Lumeo.Docs.Pages
@using Lumeo.Docs.Services
@using Lumeo.Docs.Shared
@inject RegistryService Registry
@inject Lumeo.Services.OverlayService Overlays

<PageTitle>Components — Lumeo</PageTitle>

@if (_groups is null)
{
    <Container MaxWidth="7xl" Class="px-4 py-12">
        <Stack Gap="4"><Skeleton Height="32" Width="40%" /><Skeleton Height="200" Width="100%" /></Stack>
    </Container>
}
else
{
    <Container MaxWidth="7xl" Class="px-4 py-12">
        <Stack Gap="6" Class="mb-8">
            <Stack Gap="2">
                <Heading Level="1" Class="text-3xl sm:text-4xl font-bold tracking-tight">Components</Heading>
                <Lumeo.Text Color="muted">Browse all @_total components across @_groups.Count categories.</Lumeo.Text>
            </Stack>

            @* Desktop: filter chips inline. Mobile: single "Filter" button that opens a Drawer. *@
            <div class="hidden lg:block">
                <CatalogFilterChips Categories="@_categoryNames" Selected="@_filters" SelectedChanged="OnFiltersChanged" />
            </div>
            <div class="lg:hidden flex items-center gap-3">
                <Button Variant="Button.ButtonVariant.Outline" Size="Button.ButtonSize.Sm"
                        OnClick="OpenFilterSheet"
                        Class="gap-2">
                    <DynamicIcon Name="SlidersHorizontal" Class="h-4 w-4" />
                    Filter
                    @if (_filters.Count > 0)
                    {
                        <span class="inline-flex items-center justify-center rounded-full bg-primary text-primary-foreground h-4 min-w-4 px-1 text-[10px] font-semibold">@_filters.Count</span>
                    }
                </Button>
                @if (_filters.Count > 0)
                {
                    <Lumeo.Text Size="sm" Color="muted" Class="truncate">@string.Join(", ", _filters)</Lumeo.Text>
                    <Button Variant="Button.ButtonVariant.Ghost" Size="Button.ButtonSize.Sm"
                            OnClick="ClearFilters"
                            Class="h-auto p-1 text-muted-foreground"
                            aria-label="Clear filters">
                        <DynamicIcon Name="X" Class="h-3.5 w-3.5" />
                    </Button>
                }
            </div>
        </Stack>

        <div class="space-y-12">
            @foreach (var (cat, items) in _groups)
            {
                @if (_filters.Count == 0 || _filters.Contains(cat))
                {
                    <section id="@Slug(cat)">
                        <Heading Level="2" Class="text-xl font-semibold mb-4">@cat <span class="text-sm font-normal text-muted-foreground">(@items.Count)</span></Heading>

                        @* Mobile: large vertical App-Store-style cards. Desktop: same grid as before. *@
                        <div class="hidden lg:grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                            @foreach (var component in items)
                            {
                                <CatalogCard Component="@component" />
                            }
                        </div>
                        <div class="lg:hidden flex flex-col divide-y divide-border/30 rounded-xl border border-border/40 bg-card overflow-hidden">
                            @foreach (var component in items)
                            {
                                @if (component.HasDocsPage)
                                {
                                    <a href="components/@component.Slug"
                                       class="flex items-center gap-4 px-4 py-3.5 hover:bg-accent/40 transition-colors no-underline group">
                                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-muted/40 text-muted-foreground/60">
                                            <DynamicIcon Name="Box" Class="h-5 w-5" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-foreground group-hover:text-primary transition-colors truncate">@component.Name</p>
                                            <p class="text-xs text-muted-foreground line-clamp-1 mt-0.5">@component.Description</p>
                                        </div>
                                        <DynamicIcon Name="ChevronRight" Class="h-4 w-4 text-muted-foreground/40 shrink-0" aria-hidden="true" />
                                    </a>
                                }
                                else
                                {
                                    <div class="flex items-center gap-4 px-4 py-3.5 opacity-50">
                                        <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-muted/40 text-muted-foreground/40">
                                            <DynamicIcon Name="Box" Class="h-5 w-5" />
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-sm font-semibold text-foreground truncate">@component.Name</p>
                                            <p class="text-xs text-muted-foreground line-clamp-1 mt-0.5">Docs coming soon</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </section>
                }
            }
        </div>
    </Container>
}

@* Mobile filter sheet is now opened via Lumeo's OverlayService — rendered
   by the central OverlayProvider in MainLayout (at body root), not inline
   inside this page. That avoids any CSS containing-block trap from the
   page's wrappers (page-transition, BlurFade, etc). *@

@code {
    private Dictionary<string, List<RegistryComponent>>? _groups;
    private IReadOnlyList<string> _categoryNames = [];
    private int _total;
    private HashSet<string> _filters = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _groups = await Registry.GroupsByCategoryAsync();
        _categoryNames = _groups.Keys.ToList();
        _total = _groups.Sum(g => g.Value.Count);
    }

    private void OnFiltersChanged(IReadOnlyCollection<string> next)
    {
        _filters = new HashSet<string>(next, StringComparer.OrdinalIgnoreCase);
    }

    private void ClearFilters()
    {
        _filters = new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    }

    private async Task OpenFilterSheet()
    {
        var parameters = new Lumeo.Services.OverlayParameters()
            .Add(nameof(CatalogFilterSheet.Categories), _categoryNames)
            .Add(nameof(CatalogFilterSheet.InitialSelected), (IReadOnlyCollection<string>)_filters);

        var result = await Overlays.ShowDrawerAsync<CatalogFilterSheet>(
            title: "Filter by category",
            parameters: parameters);

        if (!result.Cancelled)
        {
            var next = result.GetData<IReadOnlyCollection<string>>() ?? Array.Empty<string>();
            _filters = new HashSet<string>(next, StringComparer.OrdinalIgnoreCase);
            StateHasChanged();
        }
    }

    private static string Slug(string s) => s.ToLowerInvariant().Replace(' ', '-').Replace('&', '-');
}
