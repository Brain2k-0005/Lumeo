    // Largest per-category stacked total — scales the static IdleMount placeholder bars.
    private double _chartMaxTotal => Enumerable.Range(0, _barCategories.Count)
        .Select(i => _barSeries.Sum(s => s.Values[i])).DefaultIfEmpty(0).Max();
    private int _chartSnapshot;
    private bool _chartHovered;
    private static readonly List<double>[][] _chartSnapshots =
    {
        new[] { new List<double> { 28400, 31200, 36800, 42100, 48700, 55300 }, new List<double> { 8700, 10400, 13100, 15800, 19200, 22700 }, new List<double> { 4100, 6800, 9200, 11400, 14600, 18100 } },
        new[] { new List<double> { 32100, 29800, 41200, 38400, 52600, 47900 }, new List<double> { 12400, 15600, 11800, 18900, 14700, 21300 }, new List<double> { 6200, 8900, 5400, 12100, 9800, 15600 } },
        new[] { new List<double> { 41200, 47800, 38400, 55600, 49100, 62300 }, new List<double> { 18400, 14200, 22600, 17800, 26400, 21900 }, new List<double> { 9100, 14600, 10800, 17400, 13200, 19800 } },
        new[] { new List<double> { 24800, 35400, 31200, 44600, 39800, 51400 }, new List<double> { 10200, 16800, 13400, 21700, 18200, 24600 }, new List<double> { 5400, 11200, 8600, 14800, 12400, 17900 } },
    };

    // Timers / visibility.
    //
    // The revenue chart shows "live" data by reshuffling on a timer, but a
    // premium landing page must feel SMOOTH first — a perpetual re-render that
    // wakes Blazor + ECharts every few seconds is the top runtime-jank source.
    // So the liveness is bounded by four gates and then retires:
    //   • pause while the tab is hidden          (_pageVisible)
    //   • pause while the card is off-screen      (_chartInView, IntersectionObserver)
    //   • pause while the user is inspecting it   (_chartHovered)
    //   • run at most LiveCycles times, then dispose the timer ("settled").
    // prefers-reduced-motion disables the liveness entirely (static hero).
    private const int LiveCycles = 3;

    private bool _pageVisible = true;
    private bool _chartInView = true;   // assume visible until the observer reports
    private bool _reducedMotion;
    private int _liveCyclesLeft = LiveCycles;

    private ElementReference _chartCard;
    private IJSObjectReference? _visibilityHandle;
    private IJSObjectReference? _chartInViewObserver;
    private DotNetObjectReference<Home>? _selfRef;
    private readonly List<System.Threading.Timer> _timers = new();

    [JSInvokable]
    public void SetPageVisibility(bool visible) => _pageVisible = visible;

    [JSInvokable]
    public void SetChartInView(bool visible) => _chartInView = visible;

    protected override Task OnInitializedAsync()
    {
        _timers.Add(new System.Threading.Timer(_ => ChartTick(), null, 5000, 5000));
        return Task.CompletedTask;
    }

    // Fired by the reshuffle timer. Returns cheaply while any gate is closed,
    // applies one data snapshot while visible, and disposes the timer once the
    // demo has shown enough life — after that the chart rests with zero
    // recurring CPU (no timer wakeup, no StateHasChanged, no ECharts setOption).
    private void ChartTick()
    {
        if (_reducedMotion || _chartHovered || !_pageVisible || !_chartInView || _liveCyclesLeft <= 0)
            return;

        _chartSnapshot = (_chartSnapshot + 1) % _chartSnapshots.Length;
        var snap = _chartSnapshots[_chartSnapshot];
        if (--_liveCyclesLeft <= 0) StopLiveTimer();

        _ = InvokeAsync(() =>
        {
            for (int i = 0; i < _barSeries.Count && i < snap.Length; i++)
                _barSeries[i].Values = new List<double>(snap[i]);
            StateHasChanged();
        });
    }

    // Safe to call from the timer callback itself (Timer.Dispose is re-entrant).
    private void StopLiveTimer()
    {
        foreach (var t in _timers) t.Dispose();
        _timers.Clear();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _selfRef = DotNetObjectReference.Create(this);

            // Honour prefers-reduced-motion: retire the live timer immediately so
            // these users get a completely static (but fully populated) hero.
            try { _reducedMotion = await JS.InvokeAsync<bool>("lumeo.prefersReducedMotion"); }
            catch { _reducedMotion = false; }
            if (_reducedMotion) StopLiveTimer();

            _visibilityHandle = await JS.InvokeAsync<IJSObjectReference>(
                "lumeo.onPageVisibility", _selfRef, nameof(SetPageVisibility));

            // Pause the reshuffle whenever the chart card scrolls off-screen.
            _chartInViewObserver = await JS.InvokeAsync<IJSObjectReference?>(
                "lumeo.observeInViewport", _chartCard, _selfRef, nameof(SetChartInView), 150);
        }
        catch (JSException) { /* SSR / prerender */ }
        catch (JSDisconnectedException) { }
    }

    private void MoveDraggingCard(List<KanbanItem> target)
    {
        if (_draggingCard is null) return;
        if (_kanbanTodo.Remove(_draggingCard)
            || _kanbanDoing.Remove(_draggingCard)
            || _kanbanDone.Remove(_draggingCard))
        {
            if (!target.Contains(_draggingCard))
                target.Add(_draggingCard);
        }
        _draggingCard = null;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        foreach (var t in _timers) t.Dispose();
        _timers.Clear();
        try
        {
            if (_visibilityHandle is not null)
            {
                await _visibilityHandle.InvokeVoidAsync("dispose");
                await _visibilityHandle.DisposeAsync();
            }
            if (_chartInViewObserver is not null)
            {
                await JS.InvokeVoidAsync("lumeo.disconnectObserver", _chartInViewObserver);
                await _chartInViewObserver.DisposeAsync();
            }
        }
        catch (JSDisconnectedException) { }
        catch { }
        _selfRef?.Dispose();
    }
