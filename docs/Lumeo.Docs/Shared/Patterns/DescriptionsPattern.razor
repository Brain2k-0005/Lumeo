@namespace Lumeo.Docs.Shared.Patterns

<Stack Gap="3">
<PatternCard Label="Basic Descriptions" Code="@_codeBasic">
    <Descriptions Title="User Info" Class="w-full max-w-lg">
        <DescriptionsItem Label="Name">John Doe</DescriptionsItem>
        <DescriptionsItem Label="Email">john@example.com</DescriptionsItem>
        <DescriptionsItem Label="Role">Administrator</DescriptionsItem>
    </Descriptions>
</PatternCard>

<PatternCard Label="Bordered" Code="@_codeBordered">
    <Descriptions Title="Order Details" Bordered="true" Column="2" Class="w-full max-w-lg">
        <DescriptionsItem Label="Order ID">#12345</DescriptionsItem>
        <DescriptionsItem Label="Status">Shipped</DescriptionsItem>
        <DescriptionsItem Label="Amount">$99.00</DescriptionsItem>
        <DescriptionsItem Label="Date">Mar 10, 2026</DescriptionsItem>
    </Descriptions>
</PatternCard>
</Stack>

@code {
    private string _codeBasic = @"<Descriptions Title=""User Info"">
    <DescriptionsItem Label=""Name"">John Doe</DescriptionsItem>
    <DescriptionsItem Label=""Email"">john@example.com</DescriptionsItem>
    <DescriptionsItem Label=""Role"">Administrator</DescriptionsItem>
</Descriptions>";

    private string _codeBordered = @"<Descriptions Title=""Order Details"" Bordered=""true"" Column=""2"">
    <DescriptionsItem Label=""Order ID"">#12345</DescriptionsItem>
    <DescriptionsItem Label=""Status"">Shipped</DescriptionsItem>
    <DescriptionsItem Label=""Amount"">$99.00</DescriptionsItem>
    <DescriptionsItem Label=""Date"">Mar 10, 2026</DescriptionsItem>
</Descriptions>";
}
