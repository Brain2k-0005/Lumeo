@namespace Lumeo

@* ShineBorder — Magic UI port.
   Creates an animated shining border by layering a radial-gradient
   over the element using mask-composite to reveal only the border area.
   No @property CSS hack needed — background-position is natively animatable.
   Usage: wrap any card content in <ShineBorder>...</ShineBorder>. *@
<div class="@WrapClass"
     style="@WrapStyle"
     @attributes="AdditionalAttributes">
    @* The shine overlay — positioned absolute, inset 0, masked to border only.
       CSS variables are on the wrapper so tests/callers can read them from the root div. *@
    <div class="lumeo-shine-border"
         style="@ShineStyle"
         aria-hidden="true"></div>
    @if (ChildContent != null)
    {
        <div class="lumeo-shine-content">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>Duration of one full shine cycle in milliseconds.</summary>
    [Parameter] public int DurationMs { get; set; } = 14000;
    /// <summary>Border radius in pixels.</summary>
    [Parameter] public int BorderRadius { get; set; } = 8;
    /// <summary>Width of the border in pixels.</summary>
    [Parameter] public int BorderWidth { get; set; } = 1;
    /// <summary>
    /// One or more CSS colors for the shine gradient.
    /// Pass a single color or comma-separated list for multi-color shine.
    /// </summary>
    [Parameter] public string ShineColor { get; set; } = "var(--color-primary)";
    [Parameter] public string? Class { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private string WrapClass => string.Join(" ", new[] { "lumeo-shine-border-wrap", Class }.Where(s => !string.IsNullOrWhiteSpace(s)));

    // CSS vars on the wrapper so tests can assert on cut.Find("div").GetAttribute("style")
    private string WrapStyle =>
        $"--lumeo-shine-duration:{DurationMs}ms; --lumeo-shine-radius:{BorderRadius}px; --lumeo-shine-border-width:{BorderWidth}px;";

    private string ShineStyle
    {
        get
        {
            // Build the radial-gradient with the configured shine color(s).
            // Magic UI pattern: transparent, transparent, [colors], transparent, transparent
            // so the gradient creates a "glow" spot that sweeps with background-position.
            var gradient = $"radial-gradient(transparent, transparent, {ShineColor}, transparent, transparent)";
            return $"background-image:{gradient};";
        }
    }
}
