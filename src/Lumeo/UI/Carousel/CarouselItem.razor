@namespace Lumeo
@implements IDisposable
@inject Lumeo.Services.Localization.ILumeoLocalizer L

@{
    var isHorizontal = Context.Orientation == Lumeo.Orientation.Horizontal;
    var cssClass = isHorizontal
        ? Cx.Merge("min-w-0 shrink-0 grow-0 basis-full ps-4", Class)
        : Cx.Merge("min-w-0 shrink-0 grow-0 basis-full pt-4", Class);
}

<div role="group" aria-roledescription="slide" aria-label="@SlideLabel" class="@cssClass" style="scroll-snap-align: start;" @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    [CascadingParameter] public Carousel.CarouselContext Context { get; set; } = default!;
    /// <summary>The slide's content.</summary>
    [Parameter] public RenderFragment? ChildContent { get; set; }
    /// <summary>1-based position of this slide, used together with <see cref="Total"/> to build the
    /// accessible "Slide N of M" label. Optional — leave both unset to omit the label.</summary>
    [Parameter] public int? Index { get; set; }
    /// <summary>Total number of slides in the deck, paired with <see cref="Index"/> for the
    /// accessible "Slide N of M" label.</summary>
    [Parameter] public int? Total { get; set; }
    /// <summary>Additional CSS classes merged onto the slide's <c>group</c> element.</summary>
    [Parameter] public string? Class { get; set; }
    /// <summary>Additional HTML attributes captured and forwarded to the slide's <c>group</c> element.</summary>
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly object _token = new();

    protected override void OnInitialized() => Context?.RegisterItem(_token);
    public void Dispose() => Context?.UnregisterItem(_token);

    private string? SlideLabel => Index.HasValue && Total.HasValue
        ? L["Carousel.SlideXofY", Index.Value, Total.Value]
        : null;
}
